  achievementsRu: "\u0410\u0440\u0442\u0443\u0440 \u041A\u044D\u043B\u0438 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439 \u0441\u043B\u0435\u0434 \u0432
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0438 \u0435\u0433\u043E
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0442
    \u0446\u0435\u043B\u044B\u0439 \u0440\u044F\u0434 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439. \u041E\u043D \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E
    \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439
    \u044F\u0437\u044B\u043A \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440 \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432.  ### \U0001F52C
    \u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0443 
    \u041A\u044D\u043B\u0438 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0443\u044E
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0435,
    \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0438\u0432 \u0435\u0451
    \u0431\u0430\u0437\u043E\u0432\u044B\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u044F. 
    *   **\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u0430\u0442\u0440\u0438\u0446:** \u041A\u044D\u043B\u0438 \u043F\u043E
    \u043F\u0440\u0430\u0432\u0443 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u0430\u0442\u0440\u0438\u0446. \u0412
    \u0441\u0432\u043E\u0435\u043C \u043C\u0435\u043C\u0443\u0430\u0440\u0435 1858
    \u0433\u043E\u0434\u0430 \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0442\u044C
    \u043C\u0430\u0442\u0440\u0438\u0446\u044B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043A\u0430\u043A \u0443\u0434\u043E\u0431\u043D\u0443\u044E \u0444\u043E\u0440\u043C\u0443
    \u0437\u0430\u043F\u0438\u0441\u0438 \u0441\u0438\u0441\u0442\u0435\u043C \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439,
    \u0430 \u043A\u0430\u043A \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0431\u044A\u0435\u043A\u0442\u044B, \u043F\u043E\u0434\u0447\u0438\u043D\u044F\u044E\u0449\u0438\u0435\u0441\u044F
    \u0441\u0432\u043E\u0438\u043C \u0437\u0430\u043A\u043E\u043D\u0430\u043C. \u041E\u043D
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438
    \u0441\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u0438 \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u044F
    \u043C\u0430\u0442\u0440\u0438\u0446 \u0438, \u0447\u0442\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u043E\u0435,
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435
    \u043C\u0430\u0442\u0440\u0438\u0446 \u043D\u0435\u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E
    (\u0442\u043E \u0435\u0441\u0442\u044C \u043F\u043E\u0440\u044F\u0434\u043E\u043A
    \u0441\u043E\u043C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u0435\u0439 \u0432\u0430\u0436\u0435\u043D).
    \u0421 \u044D\u0442\u043E\u0433\u043E \u043C\u043E\u043C\u0435\u043D\u0442\u0430
    \u043C\u0430\u0442\u0440\u0438\u0447\u043D\u0430\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043D\u043E\u0432\u043E\u0439, \u043C\u043E\u0449\u043D\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430\u2013\u041A\u044D\u043B\u0438:**
    \u042D\u0442\u043E, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0435\u0433\u043E
    \u0441\u0430\u043C\u043E\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u0430\u0442\u0440\u0438\u0446. \u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0433\u043B\u0430\u0441\u0438\u0442, \u0447\u0442\u043E **\u043B\u044E\u0431\u0430\u044F
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u0430\u044F \u043C\u0430\u0442\u0440\u0438\u0446\u0430
    \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u044F\u0435\u0442
    \u0441\u0432\u043E\u0435\u043C\u0443 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C\u0443
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044E**. \u041A\u044D\u043B\u0438
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0435\u0451 \u0434\u043B\u044F \u043C\u0430\u0442\u0440\u0438\u0446
    \u0440\u0430\u0437\u043C\u0435\u0440\u043E\u0432 2\xD72 \u0438 3\xD73, \u0438,
    \u0445\u043E\u0442\u044F \u043E\u043D \u043D\u0435 \u0434\u0430\u043B \u043E\u0431\u0449\u0435\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0434\u043B\u044F \u0432\u0441\u0435\u0445 \u0440\u0430\u0437\u043C\u0435\u0440\u043E\u0432,
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0430
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E
    \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u043E\u0433\u043E
    \u043A\u0430\u043C\u043D\u044F \u043B\u0438\u043D\u0435\u0439\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B. *   **\u0424\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u044F
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0433\u043E \u043F\u043E\u043D\u044F\u0442\u0438\u044F
    \u0433\u0440\u0443\u043F\u043F\u044B:** \u042D\u0442\u043E \u043E\u0434\u043D\u043E
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439
    \u041A\u044D\u043B\u0438. \u0414\u043E \u043D\u0435\u0433\u043E \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \"\u0433\u0440\u0443\u043F\u043F\u0430\" \u0431\u044B\u043B\u043E \u0442\u0435\u0441\u043D\u043E
    \u0441\u0432\u044F\u0437\u0430\u043D\u043E \u0441 \u0433\u0440\u0443\u043F\u043F\u0430\u043C\u0438
    **\u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A**
    (\u0432 \u0440\u0430\u0431\u043E\u0442\u0430\u0445 \u0413\u0430\u043B\u0443\u0430).
    \u041A\u044D\u043B\u0438 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0440\u043E\u0440\u044B\u0432,
    \u0434\u0430\u0432 \u0432 1854 \u0433\u043E\u0434\u0443 \u043F\u0435\u0440\u0432\u043E\u0435
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    **\u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439 \u0433\u0440\u0443\u043F\u043F\u044B**.
    \u041E\u043D \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B \u0433\u0440\u0443\u043F\u043F\u0443
    \u043A\u0430\u043A \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432
    \u0441 \u0431\u0438\u043D\u0430\u0440\u043D\u043E\u0439 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u0434\u0447\u0438\u043D\u044F\u0435\u0442\u0441\u044F
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u043C \u0437\u0430\u043A\u043E\u043D\u0430\u043C,
    \u0430\u0431\u0441\u0442\u0440\u0430\u0433\u0438\u0440\u043E\u0432\u0430\u0432\u0448\u0438\u0441\u044C
    \u043E\u0442 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0439 \u043F\u0440\u0438\u0440\u043E\u0434\u044B
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432. \u0412 \u0435\u0433\u043E
    \u0447\u0435\u0441\u0442\u044C \u043D\u0430\u0437\u0432\u0430\u043D\u044B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043E\u0431\u044A\u0435\u043A\u0442\u044B \u0442\u0435\u043E\u0440\u0438\u0438
    \u0433\u0440\u0443\u043F\u043F: **\u0442\u0430\u0431\u043B\u0438\u0446\u0430
    \u041A\u044D\u043B\u0438** (\u0434\u043B\u044F \u0437\u0430\u0434\u0430\u043D\u0438\u044F
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438), **\u0433\u0440\u0430\u0444
    \u041A\u044D\u043B\u0438** \u0438 **\u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u041A\u044D\u043B\u0438** (\u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044E\u0449\u0430\u044F,
    \u0447\u0442\u043E \u043B\u044E\u0431\u0430\u044F \u0433\u0440\u0443\u043F\u043F\u0430
    \u0438\u0437\u043E\u043C\u043E\u0440\u0444\u043D\u0430 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u0435 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A).
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432:**
    \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u0414\u0436\u0435\u0439\u043C\u0441\u043E\u043C
    \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440\u043E\u043C, \u041A\u044D\u043B\u0438
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432
    \u2014 \u0440\u0430\u0437\u0434\u0435\u043B\u0430 \u0430\u043B\u0433\u0435\u0431\u0440\u044B,
    \u0438\u0437\u0443\u0447\u0430\u044E\u0449\u0435\u0433\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u043E\u0440\u043C (\u043E\u0434\u043D\u043E\u0440\u043E\u0434\u043D\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432), \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0435 \u043C\u0435\u043D\u044F\u044E\u0442\u0441\u044F \u043F\u0440\u0438
    \u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0445 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F\u0445
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445. \u041A\u043B\u044E\u0447\u0435\u0432\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u043E\u0439 \u0437\u0434\u0435\u0441\u044C \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0435\u0433\u043E \u0441\u0435\u0440\u0438\u044F \u0438\u0437 \u0434\u0435\u0441\u044F\u0442\u0438
    \"\u041C\u0435\u043C\u0443\u0430\u0440\u043E\u0432 \u043E \u043A\u0432\u0430\u043D\u0442\u0430\u0445\"
    (1854\u20131878), \u0433\u0434\u0435 \u043E\u043D \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u044D\u0442\u0443 \u0442\u0435\u043E\u0440\u0438\u044E. 
    ### \U0001F4D0 \u041D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u0435
    \u0438\u0434\u0435\u0438 \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 
    \u041A\u044D\u043B\u0438 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0435, \u043D\u043E \u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B
    \u0435\u0451 \u0434\u043B\u044F \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u044F
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438 \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. 
    *   **\u041F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u0430\u044F \u043C\u0435\u0442\u0440\u0438\u043A\u0430
    \u0438 \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:**
    \u041E\u0434\u043D\u043E \u0438\u0437 \u0435\u0433\u043E \u0441\u0430\u043C\u044B\u0445
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439
    \u2014 \u044D\u0442\u043E \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0441\u0432\u044F\u0437\u0438 \u043C\u0435\u0436\u0434\u0443 **\u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0438 \u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439**.
    \u0412 1859 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u043A\u0430\u043A \u043C\u043E\u0436\u043D\u043E \u0432\u0432\u0435\u0441\u0442\u0438
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    \u0432 \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.
    \u042D\u0442\u043E\u0442 \u043F\u043E\u0434\u0445\u043E\u0434 \u043F\u0440\u0438\u0432\u0435\u043B
    \u043A \u043E\u0448\u0435\u043B\u043E\u043C\u043B\u044F\u044E\u0449\u0435\u043C\u0443
    \u0432\u044B\u0432\u043E\u0434\u0443: **\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043B\u0438\u0448\u044C \u0447\u0430\u0441\u0442\u043D\u044B\u043C \u0441\u043B\u0443\u0447\u0430\u0435\u043C
    \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439**. \u0411\u043E\u043B\u0435\u0435
    \u0442\u043E\u0433\u043E, \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430
    \"\u043B\u0435\u0433\u043B\u0430 \u0432 \u043E\u0441\u043D\u043E\u0432\u0443
    \u0438\u0441\u0442\u043E\u043B\u043A\u043E\u0432\u0430\u043D\u0438\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E\", \u0447\u0442\u043E
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 **\u0438\u043D\u0442\u0435\u0440\u043F\u0440\u0435\u0442\u0430\u0446\u0438\u0438
    \u041A\u044D\u043B\u0438\u2013\u041A\u043B\u0435\u0439\u043D\u0430** \u2014 \u043C\u043E\u0434\u0435\u043B\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0430
    \u043F\u043E\u043D\u044F\u0442\u044C \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u044B
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0441 \u0442\u043E\u0447\u043A\u0438
    \u0437\u0440\u0435\u043D\u0438\u044F \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439.
    *   **\u041E\u0441\u043D\u043E\u0432\u044B \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438:** \u041A\u044D\u043B\u0438
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    **\u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438**. \u042D\u0442\u0430
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u0438\u0437\u0443\u0447\u0430\u0435\u0442
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0431\u044A\u0435\u043A\u0442\u044B (\u043A\u0440\u0438\u0432\u044B\u0435,
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438), \u0437\u0430\u0434\u0430\u0432\u0430\u0435\u043C\u044B\u0435
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C\u0438. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u0414\u0436\u043E\u0440\u0434\u0436\u0435\u043C
    \u0421\u0430\u043B\u043C\u043E\u043D\u043E\u043C \u043E\u043D \u043E\u0442\u043A\u0440\u044B\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0438
    27 \u043F\u0440\u044F\u043C\u044B\u0445 \u043D\u0430 \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438.  ### \U0001F9E9
    \u0414\u0440\u0443\u0433\u0438\u0435 \u0437\u043D\u0430\u0447\u0438\u043C\u044B\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438  \u041C\u0430\u0441\u0448\u0442\u0430\u0431
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u0431\u044B\u043B \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435
    \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u043C.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0432\u043D\u0435\u0441 \u0432\u0430\u0436\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432:  *   **\u0422\u0435\u043E\u0440\u0438\u044E
    \u0433\u0440\u0430\u0444\u043E\u0432:** \u0415\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C
    \u043D\u0430\u0437\u0432\u0430\u043D\u0430 **\u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u041A\u044D\u043B\u0438**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u0434\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u0435\u0442
    \u0447\u0438\u0441\u043B\u043E \u043F\u043E\u043C\u0435\u0447\u0435\u043D\u043D\u044B\u0445
    \u0434\u0435\u0440\u0435\u0432\u044C\u0435\u0432 \u0441 \u0437\u0430\u0434\u0430\u043D\u043D\u044B\u043C
    \u0447\u0438\u0441\u043B\u043E\u043C \u0432\u0435\u0440\u0448\u0438\u043D. *  
    **\u042D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438:** \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \"\u042D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u044B\u0439
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442 \u043F\u043E \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C\" (1876). *   **\u041A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0443
    \u0438 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F**. *   **\u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044E
    \u0438 \u0430\u0441\u0442\u0440\u043E\u0444\u0438\u0437\u0438\u043A\u0443:**
    \u041E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435\u043C \u041B\u0443\u043D\u044B
    \u0438 \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0434\u0432\u0430 \u0448\u0438\u0440\u043E\u043A\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u043E\u0442\u0447\u0435\u0442\u0430
    \u043F\u043E \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435.  \u041E\u0431\u044A\u0435\u043C
    \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044F
    \u043F\u043E\u0440\u0430\u0436\u0430\u0435\u0442: \u0437\u0430 \u0432\u0441\u044E
    \u0436\u0438\u0437\u043D\u044C \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043E\u043A\u043E\u043B\u043E **900 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442**, \u0438 \u0431\u043E\u043B\u0435\u0435 300 \u0438\u0437
    \u043D\u0438\u0445 \u0431\u044B\u043B\u0438 \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u044B
    \u0432 \u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434, \u043A\u043E\u0433\u0434\u0430
    \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0430\u0434\u0432\u043E\u043A\u0430\u0442\u043E\u043C.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u0431\u044B\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u043D
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u0432\u044B\u0441\u0448\u0438\u043C\u0438
    \u043D\u0430\u0433\u0440\u0430\u0434\u0430\u043C\u0438, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u0443\u044E \u043C\u0435\u0434\u0430\u043B\u044C
    (1859), \u041C\u0435\u0434\u0430\u043B\u044C \u041A\u043E\u043F\u043B\u0438 (1882)
    \u0438 \u043F\u0435\u0440\u0432\u0443\u044E \u041C\u0435\u0434\u0430\u043B\u044C
    \u0434\u0435 \u041C\u043E\u0440\u0433\u0430\u043D\u0430 (1884)."
  achievementsEn: 
  personalLifeRu: "\u0425\u043E\u0442\u044F, \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439, \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0445
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0439 \u043F\u043E\u0432\u0441\u0435\u0434\u043D\u0435\u0432\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0410\u0440\u0442\u0443\u0440\u0430 \u041A\u044D\u043B\u0438
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C \u043D\u0435\u043C\u043D\u043E\u0433\u043E,
    \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0435 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438
    \u0440\u0438\u0441\u0443\u044E\u0442 \u043E\u0431\u0440\u0430\u0437 \u0443\u0447\u0435\u043D\u043E\u0433\u043E,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u0431\u0440\u0435\u043B \u0432
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438 \u0442\u043E,
    \u0447\u0442\u043E \u0438\u0441\u043A\u0430\u043B: \u0442\u0438\u0445\u043E\u0435
    \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0435 \u0441\u0447\u0430\u0441\u0442\u044C\u0435
    \u0438 \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u044E.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466
    \u0421\u0435\u043C\u044C\u044F \u0438 \u0431\u0440\u0430\u043A  \u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u0439
    \u043C\u043E\u043C\u0435\u043D\u0442 \u0432 \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u041A\u044D\u043B\u0438 \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 1863 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    42 \u043B\u0435\u0442 \u043E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D
    \u043F\u0435\u0440\u0432\u044B\u043C \u0421\u044D\u0434\u043B\u0435\u0440\u043E\u0432\u0441\u043A\u0438\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0447\u0438\u0441\u0442\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435.
    \u042D\u0442\u043E \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0435\u043C\u0443 \u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0434\u043E\u0445\u043E\u0434\u043D\u0443\u044E \u044E\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0443 \u0432 \u041B\u043E\u043D\u0434\u043E\u043D\u0435
    \u0440\u0430\u0434\u0438 \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u043E\u0433\u043E
    \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u0438\u044F. \u041A\u044D\u043B\u0438
    \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0436\u0430\u043B\u0435\u043B
    \u043E\u0431 \u044D\u0442\u043E\u043C \u0440\u0435\u0448\u0435\u043D\u0438\u0438,
    \u0442\u0430\u043A \u043A\u0430\u043A \u043E\u043D\u043E \u043E\u0442\u043A\u0440\u044B\u043B\u043E
    \u0435\u043C\u0443 \u043F\u0443\u0442\u044C \u043A \u043F\u043E\u043B\u043D\u043E\u0439
    \u0441\u0430\u043C\u043E\u0440\u0435\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438.
    \u0412 \u0442\u043E\u043C \u0436\u0435 \u0437\u043D\u0430\u043A\u043E\u0432\u043E\u043C
    1863 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B
    \u0435\u0449\u0435 \u043E\u0434\u0438\u043D \u0432\u0430\u0436\u043D\u044B\u0439
    \u0448\u0430\u0433: **8 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0421\u044C\u044E\u0437\u0435\u043D \u041C\u043E\u043B\u0430\u0439\u043D
    (Susan Moline, 1831\u20131923)**. \u0421\u044C\u044E\u0437\u0435\u043D \u0431\u044B\u043B\u0430
    \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u0420\u043E\u0431\u0435\u0440\u0442\u0430
    \u041C\u043E\u043B\u0430\u0439\u043D\u0430, \u043F\u0440\u043E\u0432\u0438\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0431\u0430\u043D\u043A\u0438\u0440\u0430 \u0438\u0437 \u0413\u0440\u0438\u043D\u0432\u0438\u0447\u0430. 
    \u0412\u0441\u043A\u043E\u0440\u0435 \u043F\u043E\u0441\u043B\u0435 \u0441\u0432\u0430\u0434\u044C\u0431\u044B
    \u041A\u044D\u043B\u0438 \u043A\u0443\u043F\u0438\u043B \u0434\u043E\u043C \u0432
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435 \u043D\u0430 \u0413\u0430\u0440\u0434\u0435\u043D-\u0445\u0430\u0443\u0441,
    \u041B\u0438\u0442\u0442\u043B \u0421\u0435\u043D\u0442-\u041C\u044D\u0440\u0438
    \u041B\u0435\u0439\u043D, \u0433\u0434\u0435 \u0438 \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u043C\u043E\u043B\u043E\u0434\u0430\u044F \u0441\u0435\u043C\u044C\u044F. \u0423
    \u0410\u0440\u0442\u0443\u0440\u0430 \u0438 \u0421\u044C\u044E\u0437\u0435\u043D
    \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0434\u0432\u043E\u0435 \u0434\u0435\u0442\u0435\u0439
    :  *   **\u0413\u0435\u043D\u0440\u0438 \u041A\u044D\u043B\u0438 (Henry Cayley,
    1870\u20131949)** \u2014 \u043F\u043E\u0448\u0435\u043B \u043F\u043E \u0441\u0442\u043E\u043F\u0430\u043C
    \u043E\u0442\u0446\u0430 \u0438 \u0438\u0437\u0443\u0447\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435, \u043D\u043E,
    \u043A\u0430\u043A \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u0441\u044F, \u0440\u0435\u0448\u0438\u043B,
    \u0447\u0442\u043E \u043D\u0435 \u0441\u043C\u043E\u0436\u0435\u0442 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u0432\u044B\u0441\u043E\u0442\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439
    \u043E\u0442\u0446\u0430, \u0438 \u0432\u044B\u0431\u0440\u0430\u043B \u043A\u0430\u0440\u044C\u0435\u0440\u0443
    \u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u043E\u0440\u0430. *   **\u041C\u044D\u0440\u0438
    \u041A\u044D\u043B\u0438 (Mary Cayley, 1872\u20131950)**.  ### \U0001F496 \u0421\u0435\u043C\u0435\u0439\u043D\u043E\u0435
    \u0441\u0447\u0430\u0441\u0442\u044C\u0435 \u0438 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440 
    \u0412\u0441\u0435 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438 \u0441\u0445\u043E\u0434\u044F\u0442\u0441\u044F
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u0441\u0435\u043C\u0435\u0439\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u041A\u044D\u043B\u0438 \u0431\u044B\u043B\u0430
    \u043E\u0431\u0440\u0430\u0437\u0446\u043E\u043C \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0438
    \u0438 \u0441\u0447\u0430\u0441\u0442\u044C\u044F. \u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u044F\u0440\u043A\u043E \u044D\u0442\u043E \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0438 \u0441 \u0435\u0433\u043E
    \u0434\u0440\u0443\u0433\u043E\u043C \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u043E\u0439,
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u0414\u0436\u0435\u0439\u043C\u0441\u043E\u043C
    \u0414\u0436\u043E\u0437\u0435\u0444\u043E\u043C \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440\u043E\u043C.
    \u041E\u0431\u0430 \u043E\u043D\u0438 \u0434\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F
    \u0431\u044B\u043B\u0438 \u0445\u043E\u043B\u043E\u0441\u0442\u044F\u043A\u0430\u043C\u0438
    \u0438 \u0436\u0438\u043B\u0438 \u0432 \u041B\u043E\u043D\u0434\u043E\u043D\u0435,
    \u043D\u043E, \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442
    \u0436\u0435\u043D\u0430\u0442\u043E\u0433\u043E \u041A\u044D\u043B\u0438, \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440
    \u0442\u0430\u043A \u0438 \u043D\u0435 \u0432\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0431\u0440\u0430\u043A. \u0414\u0440\u0443\u0433 \u041A\u044D\u043B\u0438
    \u043E\u0434\u043D\u0430\u0436\u0434\u044B \u0437\u0430\u043C\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u0442\u043E\u0442 \u0431\u043E\u043B\u0435\u0435 \u0443\u0434\u0430\u0447\u043B\u0438\u0432
    \u0432 \u0436\u0438\u0437\u043D\u0438, \u0442\u0430\u043A \u043A\u0430\u043A
    \u043E\u0431\u0440\u0435\u043B \u0442\u0438\u0445\u0443\u044E \u0438 \u043C\u0438\u0440\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435,
    \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u0430\u043A \u043E\u043D,
    \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440, \u043E\u0441\u0442\u0430\u043B\u0441\u044F
    \u043E\u0434\u0438\u043D \u0438 \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C
    \"\u0441\u0440\u0430\u0436\u0430\u043B\u0441\u044F \u0441\u043E \u0432\u0441\u0435\u043C
    \u043C\u0438\u0440\u043E\u043C\". \u0414\u043E\u043C \u041A\u044D\u043B\u0438,
    \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0434\u043E\u043C\u0430
    \u0435\u0433\u043E \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430
    \u0423\u0438\u043B\u044C\u044F\u043C\u0430 \u0420\u043E\u0443\u044D\u043D\u0430
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430, \u0431\u044B\u043B
    \"\u043F\u043E\u043B\u043E\u043D \u0441\u0447\u0430\u0441\u0442\u044C\u044F\". 
    \u0421\u0430\u043C \u041A\u044D\u043B\u0438 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u0439,
    \u043D\u043E \u0440\u0435\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439,
    \u043E\u0431\u043B\u0430\u0434\u0430\u044E\u0449\u0438\u0439 \u044F\u0441\u043D\u044B\u043C
    \u0443\u043C\u043E\u043C \u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u043E\u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C\u044E.
    \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438 \u043E\u0442\u043C\u0435\u0447\u0430\u043B\u0438,
    \u0447\u0442\u043E \u043E\u043D \u043C\u043E\u0433 \u0441 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043B\u0435\u0433\u043A\u043E\u0441\u0442\u044C\u044E \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0442\u044C\u0441\u044F
    \u043C\u0435\u0436\u0434\u0443 \u044E\u0440\u0438\u0441\u043F\u0440\u0443\u0434\u0435\u043D\u0446\u0438\u0435\u0439
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439, \u043F\u043E\u0441\u0432\u044F\u0449\u0430\u044F
    \u043A\u0430\u0436\u0434\u043E\u0439 \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438.  ### \U0001F3DB\uFE0F \u041E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0438 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F 
    \u041F\u043E\u043C\u0438\u043C\u043E \u0441\u0435\u043C\u044C\u0438 \u0438 \u043D\u0430\u0443\u043A\u0438,
    \u041A\u044D\u043B\u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0436\u0438\u0437\u043D\u0438 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u0438 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430. \u041E\u043D \u0431\u044B\u043B
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B\u043C \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440\u043E\u043C
    \u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B \u0432\u044B\u0441\u0448\u0435\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0434\u043B\u044F
    \u0436\u0435\u043D\u0449\u0438\u043D. \u0412 \u0442\u0435\u0447\u0435\u043D\u0438\u0435
    1880-\u0445 \u0433\u043E\u0434\u043E\u0432 \u043E\u043D \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u043B\u044F\u043B
    \u0441\u043E\u0432\u0435\u0442 \u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430
    \u041D\u044C\u044E\u043D\u0445\u0435\u043C \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435,
    \u043E\u0434\u043D\u043E\u0433\u043E \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u0436\u0435\u043D\u0441\u043A\u0438\u0445 \u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0435\u0439.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u043E\u0433\u043E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430,
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430, \u0411\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u043E\u0439
    \u0430\u0441\u0441\u043E\u0446\u0438\u0430\u0446\u0438\u0438 \u0441\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044E \u043D\u0430\u0443\u043A\u0438
    \u0438 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430.  \u0427\u0442\u043E \u043A\u0430\u0441\u0430\u0435\u0442\u0441\u044F
    \u043B\u0438\u0447\u043D\u044B\u0445 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0439,
    \u041A\u044D\u043B\u0438 \u043D\u0435 \u0431\u044B\u043B \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u0441\u043F\u043E\u0440\u0442\u0441\u043C\u0435\u043D\u043E\u043C, \u043D\u043E
    \u0431\u044B\u043B \u0437\u0430\u044F\u0434\u043B\u044B\u043C \u043F\u0435\u0448\u0435\u0445\u043E\u0434\u043E\u043C
    \u0438 \u0432\u0445\u043E\u0434\u0438\u043B \u0432 \u0410\u043B\u044C\u043F\u0438\u0439\u0441\u043A\u0438\u0439
    \u043A\u043B\u0443\u0431.  ### \u26B0\uFE0F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B  \u0410\u0440\u0442\u0443\u0440 \u041A\u044D\u043B\u0438
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 26 \u044F\u043D\u0432\u0430\u0440\u044F
    1895 \u0433\u043E\u0434\u0430 \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 73 \u043B\u0435\u0442
    , \u043E\u0441\u0442\u0430\u0432\u0438\u0432 \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F
    \u0436\u0435\u043D\u0443 \u0438 \u0434\u0432\u043E\u0438\u0445 \u0434\u0435\u0442\u0435\u0439.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430 \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u043C
    \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u0433\u043B\u0443\u0431\u043E\u043A\u0430\u044F
    \u043F\u0440\u0435\u0434\u0430\u043D\u043D\u043E\u0441\u0442\u044C \u043D\u0430\u0443\u043A\u0435
    \u043C\u043E\u0436\u0435\u0442 \u0441\u043E\u0447\u0435\u0442\u0430\u0442\u044C\u0441\u044F
    \u0441 \u0442\u0438\u0445\u0438\u043C \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u043C
    \u0441\u0447\u0430\u0441\u0442\u044C\u0435\u043C \u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u043E\u0439 \u043F\u043E\u0437\u0438\u0446\u0438\u0435\u0439."
  personalLifeEn: 
  shortBioRu: "\u0410\u0440\u0442\u0443\u0440 \u041A\u044D\u043B\u0438 (Arthur Cayley,
    1821\u20131895) \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u043F\u043B\u043E\u0434\u043E\u0432\u0438\u0442\u044B\u0445 \u0438 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0412\u0438\u043A\u0442\u043E\u0440\u0438\u0430\u043D\u0441\u043A\u043E\u0439
    \u044D\u043F\u043E\u0445\u0438, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0447\u0430\u0441\u0442\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \xAB\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C-\u043B\u0430\u0443\u0440\u0435\u0430\u0442\u043E\u043C\xBB
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u044B \u043C\u043D\u043E\u0433\u0438\u0445 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0442\u0435\u043E\u0440\u0438\u044E
    \u0433\u0440\u0443\u043F\u043F, \u0442\u0435\u043E\u0440\u0438\u044E \u043C\u0430\u0442\u0440\u0438\u0446
    \u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E. \u0417\u0430 \u0441\u0432\u043E\u044E
    \u0436\u0438\u0437\u043D\u044C \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043E\u043A\u043E\u043B\u043E 900 \u0441\u0442\u0430\u0442\u0435\u0439 \u0438
    \u043A\u043D\u0438\u0433.  \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u0435\u0433\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F. 
    ### \U0001F9EC \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0410\u0440\u0442\u0443\u0440 \u041A\u044D\u043B\u0438 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    16 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1821 \u0433\u043E\u0434\u0430 \u0432
    \u0420\u0438\u0447\u043C\u043E\u043D\u0434\u0435, \u0433\u0440\u0430\u0444\u0441\u0442\u0432\u043E
    \u0421\u0443\u0440\u0440\u0435\u0439, \u0410\u043D\u0433\u043B\u0438\u044F. \u0415\u0433\u043E
    \u043E\u0442\u0435\u0446, \u0413\u0435\u043D\u0440\u0438 \u041A\u044D\u043B\u0438,
    \u0431\u044B\u043B \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0435\u043C \u0438
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B \u0432 \u0434\u0430\u043B\u044C\u043D\u0435\u043C
    \u0440\u043E\u0434\u0441\u0442\u0432\u0435 \u0441 \u0441\u044D\u0440\u043E\u043C
    \u0414\u0436\u043E\u0440\u0434\u0436\u0435\u043C \u041A\u044D\u043B\u0438, \u043F\u0438\u043E\u043D\u0435\u0440\u043E\u043C
    \u0432\u043E\u0437\u0434\u0443\u0445\u043E\u043F\u043B\u0430\u0432\u0430\u043D\u0438\u044F.
    \u041C\u0430\u0442\u044C, \u041C\u0430\u0440\u0438\u044F \u0410\u043D\u0442\u043E\u043D\u0438\u044F
    \u0414\u043E\u0442\u0438, \u0431\u044B\u043B\u0430 \u0434\u043E\u0447\u0435\u0440\u044C\u044E
    \u0423\u0438\u043B\u044C\u044F\u043C\u0430 \u0414\u043E\u0442\u0438.  \u041F\u0435\u0440\u0432\u044B\u0435
    \u0432\u043E\u0441\u0435\u043C\u044C \u043B\u0435\u0442 \u0441\u0432\u043E\u0435\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0410\u0440\u0442\u0443\u0440 \u043F\u0440\u043E\u0432\u0451\u043B
    \u0432 \u0421\u0430\u043D\u043A\u0442-\u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0435,
    \u0433\u0434\u0435 \u0435\u0433\u043E \u043E\u0442\u0435\u0446 \u0432\u0451\u043B
    \u043A\u043E\u043C\u043C\u0435\u0440\u0447\u0435\u0441\u043A\u0438\u0435 \u0434\u0435\u043B\u0430,
    \u0430 \u0435\u0433\u043E \u0434\u0435\u0434 \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u043F\u043E\u0441\u0442 \u0431\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u0433\u0435\u043D\u0435\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043A\u043E\u043D\u0441\u0443\u043B\u0430.
    \u0412 1829 \u0433\u043E\u0434\u0443 \u0441\u0435\u043C\u044C\u044F \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0432\u0435\u0440\u043D\u0443\u043B\u0430\u0441\u044C \u0432 \u0410\u043D\u0433\u043B\u0438\u044E
    \u0438 \u043F\u043E\u0441\u0435\u043B\u0438\u043B\u0430\u0441\u044C \u0432 \u0411\u043B\u044D\u043A\u0445\u0438\u0442\u0435,
    \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E \u043E\u0442 \u041B\u043E\u043D\u0434\u043E\u043D\u0430. 
    ### \U0001F468\u200D\U0001F393 \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u043D\u0430\u0447\u0430\u043B\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B
    \u0421 \u0440\u0430\u043D\u043D\u0438\u0445 \u043B\u0435\u0442 \u041A\u044D\u043B\u0438
    \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438. \u0415\u0433\u043E
    \u0443\u0447\u0438\u0442\u0435\u043B\u044C \u0432 \u0448\u043A\u043E\u043B\u0435
    \u041A\u0438\u043D\u0433\u0441-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430,
    \u043A\u0443\u0434\u0430 \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 14 \u043B\u0435\u0442, \u0440\u0430\u0437\u0433\u043B\u044F\u0434\u0435\u043B
    \u0432 \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0435 \u0433\u0435\u043D\u0438\u044F
    \u0438 \u0443\u0431\u0435\u0434\u0438\u043B \u043E\u0442\u0446\u0430 \u043E\u0442\u043A\u0430\u0437\u0430\u0442\u044C\u0441\u044F
    \u043E\u0442 \u0438\u0434\u0435\u0438 \u043E\u0431\u0443\u0447\u0430\u0442\u044C
    \u0441\u044B\u043D\u0430 \u0431\u0438\u0437\u043D\u0435\u0441\u0443, \u0447\u0442\u043E\u0431\u044B
    \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C \u0435\u0433\u043E
    \u043A \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044E \u0432
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442. 
    \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 17 \u043B\u0435\u0442
    \u041A\u044D\u043B\u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430. \u0415\u0433\u043E
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C \u0431\u044B\u043B
    \u0423\u0438\u043B\u044C\u044F\u043C \u0425\u043E\u043F\u043A\u0438\u043D\u0441,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043A\u0430\u043A \xAB\u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432\xBB. \u0412
    1842 \u0433\u043E\u0434\u0443 \u041A\u044D\u043B\u0438 \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u043A\u0430\u043A
    **Senior Wrangler** (\u043B\u0443\u0447\u0448\u0438\u0439 \u0441\u0442\u0443\u0434\u0435\u043D\u0442
    \u043D\u0430 \u0432\u044B\u043F\u0443\u0441\u043A\u043D\u043E\u043C \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0435
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435) \u0438
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0435\u0440\u0432\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E \u0421\u043C\u0438\u0442\u0430 \u0437\u0430
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443. \u041E\u043D \u043E\u0441\u0442\u0430\u043B\u0441\u044F
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435 \u043D\u0430 \u0447\u0435\u0442\u044B\u0440\u0435
    \u0433\u043E\u0434\u0430, \u0432 \u0442\u0435\u0447\u0435\u043D\u0438\u0435 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B 28 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442 \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0436\u0443\u0440\u043D\u0430\u043B\u0435.  ### \u2696\uFE0F \u0410\u0434\u0432\u043E\u043A\u0430\u0442\u0441\u043A\u0430\u044F
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0430 \u0414\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u041A\u044D\u043B\u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435, \u0431\u044B\u043B\u0430
    \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439. \u041A\u0440\u043E\u043C\u0435
    \u0442\u043E\u0433\u043E, \u0434\u043B\u044F \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0435\u043D\u0438\u044F
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F
    \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u043E\u0441\u044C \u043F\u0440\u0438\u043D\u044F\u0442\u044C
    \u0434\u0443\u0445\u043E\u0432\u043D\u044B\u0439 \u0441\u0430\u043D, \u0447\u0442\u043E
    \u041A\u044D\u043B\u0438 \u043D\u0435 \u0443\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u043B\u043E.
    \u041F\u043E\u044D\u0442\u043E\u043C\u0443 \u0432 1846 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u043A\u0438\u043D\u0443\u043B \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u0438 \u043D\u0430\u0447\u0430\u043B \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u043F\u0440\u0430\u0432\u043E \u0432 \u043B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u043C
    \u0441\u0443\u0434\u0435\u0431\u043D\u043E\u043C \u0438\u043D\u043D\u0435 \u041B\u0438\u043D\u043A\u043E\u043B\u044C\u043D\u0430. 
    \u0421 1849 \u043F\u043E 1863 \u0433\u043E\u0434 \u041A\u044D\u043B\u0438 \u0443\u0441\u043F\u0435\u0448\u043D\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0430\u0434\u0432\u043E\u043A\u0430\u0442\u0441\u043A\u043E\u0439
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u043E\u0439, \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u0443\u044F\u0441\u044C
    \u043D\u0430 \u0434\u0435\u043B\u0430\u0445, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445
    \u0441 \u0442\u0440\u0430\u043D\u0441\u043F\u043E\u0440\u0442\u0438\u0440\u043E\u0432\u043A\u043E\u0439.
    \u041E\u0434\u043D\u0430\u043A\u043E \u044E\u0440\u0438\u0441\u043F\u0440\u0443\u0434\u0435\u043D\u0446\u0438\u044F
    \u043D\u0435 \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u043F\u0440\u0438\u0437\u0432\u0430\u043D\u0438\u0435\u043C. \u0412\u0441\u0451
    \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0435 \u0432\u0440\u0435\u043C\u044F
    \u043E\u043D \u043F\u043E\u0441\u0432\u044F\u0449\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u043E\u0442 14-\u043B\u0435\u0442\u043D\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0431\u043E\u043B\u0435\u0435 300 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442, \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0441\u0432\u043E\u0438
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435 \xAB\u041C\u0435\u043C\u0443\u0430\u0440\u044B
    \u043E \u043A\u0432\u0430\u043D\u0442\u0430\u0445\xBB (\u0441\u0435\u0440\u0438\u044F
    \u0438\u0437 10 \u0440\u0430\u0431\u043E\u0442, 1854\u20131878). \u0412 \u041B\u043E\u043D\u0434\u043E\u043D\u0435
    \u043E\u043D \u0447\u0430\u0441\u0442\u043E \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u043B\u0441\u044F
    \u0438 \u0433\u0443\u043B\u044F\u043B \u0441\u043E \u0441\u0432\u043E\u0438\u043C
    \u0434\u0440\u0443\u0433\u043E\u043C, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0414\u0436\u0435\u0439\u043C\u0441\u043E\u043C \u0414\u0436\u043E\u0437\u0435\u0444\u043E\u043C
    \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440\u043E\u043C, \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044E \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432. 
    ### \U0001F393 \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0443\u0440\u0430 \u0432
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435 \u0412 1863 \u0433\u043E\u0434\u0443
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435 \u0431\u044B\u043B\u0430
    \u0443\u0447\u0440\u0435\u0436\u0434\u0435\u043D\u0430 \u043D\u043E\u0432\u0430\u044F
    \u0421\u044D\u0434\u043B\u0435\u0440\u043E\u0432\u0441\u043A\u0430\u044F \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0443\u0440\u0430
    \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0438 \u043D\u0430 \u043D\u0435\u0451 \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D
    \u0410\u0440\u0442\u0443\u0440 \u041A\u044D\u043B\u0438. \u041E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0434\u043E\u0445\u043E\u0434\u043D\u0443\u044E \u0430\u0434\u0432\u043E\u043A\u0430\u0442\u0441\u043A\u0443\u044E
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0443 \u0440\u0430\u0434\u0438 \u0433\u043E\u0440\u0430\u0437\u0434\u043E
    \u0431\u043E\u043B\u0435\u0435 \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0433\u043E
    \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u0438\u044F \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430,
    \u043D\u043E \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043E\u0431 \u044D\u0442\u043E\u043C
    \u043D\u0435 \u0436\u0430\u043B\u0435\u043B, \u0442\u0430\u043A \u043A\u0430\u043A
    \u043D\u0430\u043A\u043E\u043D\u0435\u0446 \u0441\u043C\u043E\u0433 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C \u0441\u0435\u0431\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u0412 \u0442\u043E\u043C
    \u0436\u0435 \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0421\u044C\u044E\u0437\u0435\u043D \u041C\u043E\u043B\u0430\u0439\u043D,
    \u0434\u043E\u0447\u0435\u0440\u0438 \u043F\u0440\u043E\u0432\u0438\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0431\u0430\u043D\u043A\u0438\u0440\u0430.  \u041A\u044D\u043B\u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u044D\u0442\u0443 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0434\u043E
    \u043A\u043E\u043D\u0446\u0430 \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438.
    \u041E\u043D \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u043A\u0430\u043A \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B\u0439 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440
    \u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B \u0432\u044B\u0441\u0448\u0435\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0434\u043B\u044F
    \u0436\u0435\u043D\u0449\u0438\u043D, \u0432 \u0442\u0435\u0447\u0435\u043D\u0438\u0435
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u043B\u0435\u0442
    \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u043B\u044F\u044F \u0441\u043E\u0432\u0435\u0442
    \u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430 \u041D\u044C\u044E\u043D\u0445\u0435\u043C
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435. \u041E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435 26 \u044F\u043D\u0432\u0430\u0440\u044F
    1895 \u0433\u043E\u0434\u0430.  ### \U0001F52C \u041D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0438
    \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0410\u0440\u0442\u0443\u0440 \u041A\u044D\u043B\u0438 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0435\u0435
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u0441\u0435
    \u0440\u0430\u0437\u0434\u0435\u043B\u044B \u0447\u0438\u0441\u0442\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0412\u043E\u0442
    \u0435\u0433\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F: 
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432:**
    \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440\u043E\u043C
    \u043E\u043D \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u044D\u0442\u043E\u0439 \u0432\u0430\u0436\u043D\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B, \u0438\u0437\u0443\u0447\u0430\u044E\u0449\u0435\u0439
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0435 \u043C\u0435\u043D\u044F\u044E\u0442\u0441\u044F \u043F\u0440\u0438
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F\u0445.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u043C\u0430\u0442\u0440\u0438\u0446:**
    \u041A\u044D\u043B\u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u0430\u0442\u0440\u0438\u0446. \u041E\u043D
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430-\u041A\u044D\u043B\u0438,
    \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043A\u0430\u0436\u0434\u0430\u044F \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u0430\u044F
    \u043C\u0430\u0442\u0440\u0438\u0446\u0430 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043A\u043E\u0440\u043D\u0435\u043C \u0441\u0432\u043E\u0435\u0433\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u0430. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0433\u0440\u0443\u043F\u043F:** \u041E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0434\u0430\u043B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u044B \u043A\u0430\u043A \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0441 \u0431\u0438\u043D\u0430\u0440\u043D\u043E\u0439 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0435\u0439,
    \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u044F\u044E\u0449\u0435\u0439
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u043C \u0437\u0430\u043A\u043E\u043D\u0430\u043C,
    \u043E\u0442\u0434\u0435\u043B\u0438\u0432 \u044D\u0442\u043E \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \u043E\u0442 \u0433\u0440\u0443\u043F\u043F \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A.
    \u0412 \u0435\u0433\u043E \u0447\u0435\u0441\u0442\u044C \u043D\u0430\u0437\u0432\u0430\u043D\u044B
    \u0442\u0430\u0431\u043B\u0438\u0446\u0430 \u041A\u044D\u043B\u0438, \u0433\u0440\u0430\u0444
    \u041A\u044D\u043B\u0438 \u0438 \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u041A\u044D\u043B\u0438.
    *   **\u0410\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:** \u041E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u044D\u0442\u043E\u0439 \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u044B.
    \u0412\u043C\u0435\u0441\u0442\u0435 \u0441 \u0414\u0436\u043E\u0440\u0434\u0436\u0435\u043C
    \u0421\u0430\u043B\u043C\u043E\u043D\u043E\u043C \u043E\u0442\u043A\u0440\u044B\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u043E 27 \u043F\u0440\u044F\u043C\u044B\u0445 \u043D\u0430 \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438. *   **\u041D\u0435\u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:** \u041A\u044D\u043B\u0438
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E
    \u0441\u0432\u044F\u0437\u044C \u043C\u0435\u0436\u0434\u0443 \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0438 \u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439,
    \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0435\u043C\u0443
    \u0434\u0430\u0442\u044C \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u0443\u044E
    \u043C\u043E\u0434\u0435\u043B\u044C \u0434\u043B\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E. \u042D\u0442\u0430
    \u043C\u043E\u0434\u0435\u043B\u044C \u043F\u043E\u0437\u0436\u0435 \u0431\u044B\u043B\u0430
    \u0440\u0430\u0437\u0432\u0438\u0442\u0430 \u0424\u0435\u043B\u0438\u043A\u0441\u043E\u043C
    \u041A\u043B\u0435\u0439\u043D\u043E\u043C \u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u043A\u0430\u043A \u0438\u043D\u0442\u0435\u0440\u043F\u0440\u0435\u0442\u0430\u0446\u0438\u044F
    \u041A\u044D\u043B\u0438-\u041A\u043B\u0435\u0439\u043D\u0430. *   **\u0414\u0440\u0443\u0433\u0438\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438:** \u041E\u043D \u0432\u043D\u0451\u0441
    \u0432\u0430\u0436\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E
    \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 (\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0432
    \u0432 1876 \u0433\u043E\u0434\u0443 \xAB\u042D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u044B\u0439
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442 \u043F\u043E \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C\xBB), \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0443
    (\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430 \u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u041A\u044D\u043B\u0438 \u0434\u043B\u044F \u0447\u0438\u0441\u043B\u0430 \u0434\u0435\u0440\u0435\u0432\u044C\u0435\u0432),
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0435\u0439
    \u0438 \u0430\u0441\u0442\u0440\u043E\u0444\u0438\u0437\u0438\u043A\u043E\u0439. 
    ### \U0001F3C6 \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u041C\u0430\u0441\u0448\u0442\u0430\u0431
    \u0442\u0430\u043B\u0430\u043D\u0442\u0430 \u041A\u044D\u043B\u0438 \u0431\u044B\u043B
    \u0448\u0438\u0440\u043E\u043A\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u043D
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438. \u041E\u043D \u0431\u044B\u043B
    \u0447\u043B\u0435\u043D\u043E\u043C \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430
    (\u0438\u0437\u0431\u0440\u0430\u043D \u0432 1852 \u0433\u043E\u0434\u0443),
    \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u043C\u0435\u0434\u0430\u043B\u0438 (1859), \u041C\u0435\u0434\u0430\u043B\u0438
    \u041A\u043E\u043F\u043B\u0438 (1882) \u0438 \u043F\u0435\u0440\u0432\u043E\u0439
    \u041C\u0435\u0434\u0430\u043B\u0438 \u0434\u0435 \u041C\u043E\u0440\u0433\u0430\u043D\u0430
    \u043E\u0442 \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 (1884), \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043E\u043D \u0431\u044B\u043B
    \u0441 1868 \u043F\u043E 1870 \u0433\u043E\u0434. \u0415\u0433\u043E \u0438\u043C\u044F
    \u0442\u0430\u043A\u0436\u0435 \u043D\u043E\u0441\u0438\u0442 \u043A\u0440\u0430\u0442\u0435\u0440
    \u043D\u0430 \u041B\u0443\u043D\u0435."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0410\u0440\u0442\u0443\u0440\u0430
    \u041A\u044D\u043B\u0438 \u043F\u043E\u043B\u043D\u0430 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0445
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u0435\u043B\u0430\u044E\u0442 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439,
    \u043D\u043E \u0438 \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u043E\u043C \u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0435,
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0432\u0448\u0435\u043C \u0441\u0435\u0431\u044F
    \u0441\u0442\u0440\u0430\u0441\u0442\u0438 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. 
    ### \U0001F913 \u0414\u0435\u0442\u0441\u0442\u0432\u043E, \u043E\u0434\u0430\u0440\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0432\u044B\u0431\u043E\u0440 \u043F\u0443\u0442\u0438  \u0415\u0449\u0435
    \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u041A\u044D\u043B\u0438 \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B
    \u043D\u0435\u0437\u0430\u0443\u0440\u044F\u0434\u043D\u044B\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u2014 \u043E\u043D
    **\u0440\u0435\u0448\u0430\u043B \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0440\u0430\u0434\u0438 \u0437\u0430\u0431\u0430\u0432\u044B**. \u0415\u0433\u043E
    \u0442\u0430\u043B\u0430\u043D\u0442 \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0447\u0435\u0432\u0438\u0434\u0435\u043D, \u0447\u0442\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044F
    \u0432 \u0448\u043A\u043E\u043B\u0435 \u041A\u0438\u043D\u0433\u0441-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430
    \u043D\u0430\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u043E\u0432\u0430\u043B\u0438
    \u043E\u0442\u0446\u0443 \u043D\u0435 \u043F\u0440\u0438\u043E\u0431\u0449\u0430\u0442\u044C
    \u0441\u044B\u043D\u0430 \u043A \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u043C\u0443
    \u0431\u0438\u0437\u043D\u0435\u0441\u0443, \u0430 \u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C
    \u0435\u0433\u043E \u043A \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044E
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442.  \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    **17 \u043B\u0435\u0442** \u043E\u043D \u0443\u0436\u0435 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0430 \u2014 \u044D\u0442\u043E
    \u0441\u0447\u0438\u0442\u0430\u043B\u043E\u0441\u044C \u043D\u0435\u043E\u0431\u044B\u043A\u043D\u043E\u0432\u0435\u043D\u043D\u043E
    \u0440\u0430\u043D\u043D\u0438\u043C \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u043E\u043C
    \u0434\u043B\u044F \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430 \u0432 \u0442\u043E
    \u0432\u0440\u0435\u043C\u044F. \u0422\u0430\u043C \u043E\u043D \u043F\u0440\u0435\u0443\u0441\u043F\u0435\u043B
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u043D\u043E \u0438 \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u044F\u0437\u044B\u043A\u0430\u0445, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    **\u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0439, \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439,
    \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0439 \u0438 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u0439**. 
    ### \u2696\uFE0F \u041A\u0430\u0440\u044C\u0435\u0440\u0430 \u044E\u0440\u0438\u0441\u0442\u0430
    \u0438 \u044D\u043F\u043E\u0445\u0430 \xAB\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u043E\u0433\u0443\u043B\u043E\u043A\xBB  \u041E\u0434\u0438\u043D
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u2014 \u044D\u0442\u043E **14-\u043B\u0435\u0442\u043D\u044F\u044F \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u043F\u0440\u0435\u0443\u0441\u043F\u0435\u0432\u0430\u044E\u0449\u0435\u0433\u043E
    \u0430\u0434\u0432\u043E\u043A\u0430\u0442\u0430**, \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u0443\u044E\u0449\u0435\u0433\u043E\u0441\u044F
    \u043D\u0430 \u0442\u0440\u0430\u043D\u0441\u043F\u043E\u0440\u0442\u043D\u043E\u043C
    \u043F\u0440\u0430\u0432\u0435. \u0425\u043E\u0442\u044F \u0435\u0433\u043E \u0434\u043E\u0445\u043E\u0434
    \u043A\u0430\u043A \u044E\u0440\u0438\u0441\u0442\u0430 \u0431\u044B\u043B \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0432\u044B\u0448\u0435 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u043E\u0433\u043E
    \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u0438\u044F, \u043E\u043D \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0436\u0430\u043B\u0435\u043B \u043E\u0431 \u0443\u0445\u043E\u0434\u0435
    \u0438\u0437 \u044E\u0440\u0438\u0441\u043F\u0440\u0443\u0434\u0435\u043D\u0446\u0438\u0438,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C \u0441\u0435\u0431\u044F
    \u043D\u0430\u0443\u043A\u0435.  \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u0432 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0435\u0433\u043E \u0431\u043B\u0438\u0437\u043A\u0438\u043C \u0434\u0440\u0443\u0433\u043E\u043C
    \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u043E\u0439 \u043F\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u043C
    \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u044F\u043C \u0441\u0442\u0430\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A **\u0414\u0436\u0435\u0439\u043C\u0441
    \u0414\u0436\u043E\u0437\u0435\u0444 \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440**.
    \u0423 \u043D\u0438\u0445 \u0431\u044B\u043B\u0430 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u044F
    **\u0433\u0443\u043B\u044F\u0442\u044C \u0432\u043C\u0435\u0441\u0442\u0435 \u043F\u043E
    \u0434\u0432\u043E\u0440\u0430\u043C \u041B\u0438\u043D\u043A\u043E\u043B\u044C\u043D\u0441-\u0418\u043D\u043D\u0430**
    (\u0441\u0443\u0434\u0435\u0431\u043D\u043E\u0433\u043E \u0438\u043D\u043D\u0430
    \u0432 \u041B\u043E\u043D\u0434\u043E\u043D\u0435), \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044E \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432
    \u0438 \u043A\u043E\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432. \u0418
    \u0438\u043C\u0435\u043D\u043D\u043E \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0430\u0434\u0432\u043E\u043A\u0430\u0442\u0441\u043A\u043E\u0439 \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0438,
    \u0432 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0435 \u0432\u0440\u0435\u043C\u044F,
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043E\u0442 200 \u0434\u043E
    300 \u0441\u0432\u043E\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442.  \u0415\u0449\u0451 \u043E\u0434\u0438\u043D
    \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u044B\u0439 \u044D\u043F\u0438\u0437\u043E\u0434:
    \u0433\u043E\u0442\u043E\u0432\u044F\u0441\u044C \u043A \u0430\u0434\u0432\u043E\u043A\u0430\u0442\u0441\u043A\u043E\u043C\u0443
    \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0443, \u041A\u044D\u043B\u0438 \u0441\u044A\u0435\u0437\u0434\u0438\u043B
    \u0432 \u0414\u0443\u0431\u043B\u0438\u043D, \u0447\u0442\u043E\u0431\u044B **\u043F\u043E\u0441\u043B\u0443\u0448\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0423\u0438\u043B\u044C\u044F\u043C\u0430
    \u0420\u043E\u0443\u044D\u043D\u0430 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    \u043E \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u0430\u0445**. 
    ### \U0001F3E1 \u0421\u0435\u043C\u0435\u0439\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C:
    \u0441\u0447\u0430\u0441\u0442\u044C\u0435 \u0438 \u0437\u0430\u0432\u0438\u0441\u0442\u044C 
    \u041A\u043E\u0433\u0434\u0430 \u0432 1863 \u0433\u043E\u0434\u0443 \u041A\u044D\u043B\u0438
    \u043D\u0430\u043A\u043E\u043D\u0435\u0446 \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435, \u043E\u043D \u0441\u0440\u0430\u0437\u0443
    \u0436\u0435 \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u0438, \u043F\u043E
    \u0441\u043B\u043E\u0432\u0430\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u0435\u0433\u043E \u0434\u043E\u043C \u0431\u044B\u043B \u043F\u043E\u043B\u043E\u043D
    \u0441\u0447\u0430\u0441\u0442\u044C\u044F. \u042D\u0442\u043E\u0442 \u0444\u0430\u043A\u0442
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u044F\u0440\u043A\u043E \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u0438\u0440\u0443\u0435\u0442
    \u0441 \u0436\u0438\u0437\u043D\u044C\u044E \u0435\u0433\u043E \u0434\u0440\u0443\u0433\u0430
    \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u041A\u044D\u043B\u0438, \u0442\u0430\u043A \u0438 \u043D\u0435
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F. \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440
    \u043A\u0430\u043A-\u0442\u043E \u0437\u0430\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E
    \u041A\u044D\u043B\u0438 \u0431\u044B\u043B \u0433\u043E\u0440\u0430\u0437\u0434\u043E
    \u0443\u0434\u0430\u0447\u043B\u0438\u0432\u0435\u0435 \u0435\u0433\u043E \u0432
    \u0436\u0438\u0437\u043D\u0438: \u043E\u043D \u043E\u0431\u0440\u0435\u043B \u0442\u0438\u0445\u0443\u044E
    \u0438 \u043C\u0438\u0440\u043D\u0443\u044E \u0441\u0435\u043C\u0435\u0439\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435,
    \u0442\u043E\u0433\u0434\u0430 \u043A\u0430\u043A \u043E\u043D \u0432\u0441\u044E
    \u0436\u0438\u0437\u043D\u044C \xAB\u0441\u0440\u0430\u0436\u0430\u043B\u0441\u044F
    \u0441\u043E \u0432\u0441\u0435\u043C \u043C\u0438\u0440\u043E\u043C\xBB.  ###
    \U0001F3A8 \u0423\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F: \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0446\u0438\u0444\u0440\u044B, \u043D\u043E
    \u0438 \u043A\u0438\u0441\u0442\u0438  \u0423 \u041A\u044D\u043B\u0438 \u0431\u044B\u043B\u0438
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B. \u041E\u043D \u043F\u0438\u0442\u0430\u043B
    \u0441\u0442\u0440\u0430\u0441\u0442\u044C \u043A **\u0447\u0442\u0435\u043D\u0438\u044E
    \u0440\u043E\u043C\u0430\u043D\u043E\u0432, \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F\u043C
    \u0438 \u0436\u0438\u0432\u043E\u043F\u0438\u0441\u0438**. \u041E\u043D \u0441\u0430\u043C
    \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F **\u0430\u043A\u0432\u0430\u0440\u0435\u043B\u044C\u043D\u043E\u0439
    \u0436\u0438\u0432\u043E\u043F\u0438\u0441\u044C\u044E** \u0438 \u0434\u0430\u0436\u0435
    \u043D\u0430\u0445\u043E\u0434\u0438\u043B \u044D\u0442\u043E\u043C\u0443 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u043D\u0430\u0432\u044B\u043A\u0438 \u0440\u0438\u0441\u043E\u0432\u0430\u043D\u0438\u044F
    \u0434\u043B\u044F \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0441\u0432\u043E\u0438\u0445
    **\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u0438\u0430\u0433\u0440\u0430\u043C\u043C**.  ### \U0001F9E9 \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0432 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u044F\u0445  \u041F\u043B\u043E\u0434\u043E\u0432\u0438\u0442\u043E\u0441\u0442\u044C
    \u041A\u044D\u043B\u0438 \u0438 \u0432\u043A\u043B\u0430\u0434, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043D \u0432\u043D\u0435\u0441 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u043E\u0442\u0440\u0430\u0436\u0430\u044E\u0442\u0441\u044F \u0432 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u043C
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0435 \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432,
    \u043D\u043E\u0441\u044F\u0449\u0438\u0445 \u0435\u0433\u043E \u0438\u043C\u044F.
    \u0421\u0440\u0435\u0434\u0438 \u043D\u0438\u0445:  *   \u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0438 \u0433\u0440\u0430\u0444 \u041A\u044D\u043B\u0438. *   \u0422\u0430\u0431\u043B\u0438\u0446\u0430
    \u041A\u044D\u043B\u0438. *   \u0421\u0435\u043A\u0441\u0442\u0438\u043A\u0430
    \u041A\u044D\u043B\u0438 (\u043A\u0440\u0438\u0432\u0430\u044F) \u0438 \u0434\u0430\u0436\u0435
    \u0438\u0433\u0440\u0430 **\xAB\u041C\u044B\u0448\u0435\u043B\u043E\u0432\u043A\u0430
    \u041A\u044D\u043B\u0438\xBB** \u2014 \u0437\u0430\u0434\u0430\u0447\u0430-\u0433\u043E\u043B\u043E\u0432\u043E\u043B\u043E\u043C\u043A\u0430
    \u0441 \u043A\u0430\u0440\u0442\u0430\u043C\u0438. *   \u041A\u0440\u0430\u0442\u0435\u0440
    \u041A\u044D\u043B\u0438 \u043D\u0430 \u041B\u0443\u043D\u0435.  ### \U0001F4DC
    \u041C\u0430\u0441\u0448\u0442\u0430\u0431 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044F 
    \u041E\u0431\u0449\u0435\u0435 \u0447\u0438\u0441\u043B\u043E \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442 \u043F\u0440\u0435\u0432\u044B\u0448\u0430\u0435\u0442
    **900, \u0430 \u043F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0434\u0430\u043D\u043D\u044B\u043C \u0434\u043E\u0441\u0442\u0438\u0433\u0430\u0435\u0442
    967**. \u041F\u043E\u0437\u0434\u043D\u0435\u0435, \u043D\u0435\u0437\u0430\u0434\u043E\u043B\u0433\u043E
    \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438, \u041A\u044D\u043B\u0438 \u043B\u0438\u0447\u043D\u043E
    \u0440\u0435\u0434\u0430\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043B \u0441\u0435\u043C\u044C
    \u0442\u043E\u043C\u043E\u0432 \u0441\u0432\u043E\u0438\u0445 \u0441\u0431\u043E\u0440\u043D\u0438\u043A\u043E\u0432,
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043C\u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u044E\u044E \u0431\u043E\u043B\u0435\u0437\u043D\u044C.
    \u0415\u0433\u043E \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u044B \u0432 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0435
    \u0441\u0442\u0430\u043B\u0438 \u0441\u043E\u0431\u044B\u0442\u0438\u0435\u043C
    \u043C\u0438\u0440\u043E\u0432\u043E\u0433\u043E \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u0430,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u0435\u043B\u0438
    \u0438\u0437 \u0420\u043E\u0441\u0441\u0438\u0438 \u0438 \u0410\u043C\u0435\u0440\u0438\u043A\u0438."
