  achievementsRu: "\u0414\u0436\u043E\u043D \u041D\u044D\u0448 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F \u043D\u0435 \u043E\u0434\u043D\u043E,
    \u0430, \u043F\u043E \u0441\u0443\u0442\u0438, \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u044B\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0439. \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u0432 \u043D\u0430\u0443\u043A\u0443 \u043C\u043E\u0436\u043D\u043E \u0441\u0440\u0430\u0432\u043D\u0438\u0442\u044C
    \u0441 \u0441\u0435\u0440\u0438\u0435\u0439 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u0432 \u0432 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u0440\u0430\u0437\u043D\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445,
    \u043A\u0430\u0436\u0434\u044B\u0439 \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B \u043B\u0438\u0446\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0438.
    \u0417\u0430 \u0441\u0432\u043E\u044E \u043A\u0430\u0440\u044C\u0435\u0440\u0443
    \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0432\u0441\u0435\u0433\u043E \u043E\u043A\u043E\u043B\u043E \u0434\u0432\u0443\u0445
    \u0434\u0435\u0441\u044F\u0442\u043A\u043E\u0432 \u0440\u0430\u0431\u043E\u0442,
    \u043D\u043E \u0438\u0445 \u0433\u043B\u0443\u0431\u0438\u043D\u0430 \u0438 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u0442\u0430\u043A\u043E\u0432\u044B, \u0447\u0442\u043E \u0434\u0435\u043B\u044F\u0442
    \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u043D\u0430 \u0434\u0432\u0435 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435,
    \u043F\u043E\u0447\u0442\u0438 \u043D\u0435 \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438: **\u0442\u0435\u043E\u0440\u0438\u044E
    \u0438\u0433\u0440** \u0438 **\u0447\u0438\u0441\u0442\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443**. 
    ### \U0001F3B2 \u0422\u0435\u043E\u0440\u0438\u044F \u0438\u0433\u0440: \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u0432 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0435 \u0438 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u043D\u0430\u0443\u043A\u0430\u0445  \u0418\u043C\u0435\u043D\u043D\u043E \u0440\u0430\u0431\u043E\u0442\u0430
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430
    \u041D\u044D\u0448\u0443 \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0441\u043B\u0430\u0432\u0443
    \u0438 \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E.
    \u0414\u043E \u041D\u044D\u0448\u0430 \u0442\u0435\u043E\u0440\u0438\u044F \u0438\u0433\u0440,
    \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u0430\u044F \u0414\u0436\u043E\u043D\u043E\u043C
    \u0444\u043E\u043D \u041D\u0435\u0439\u043C\u0430\u043D\u043E\u043C \u0438 \u041E\u0441\u043A\u0430\u0440\u043E\u043C
    \u041C\u043E\u0440\u0433\u0435\u043D\u0448\u0442\u0435\u0440\u043D\u043E\u043C,
    \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0430\u0441\u044C
    \"\u0438\u0433\u0440\u0430\u043C\u0438 \u0441 \u043D\u0443\u043B\u0435\u0432\u043E\u0439
    \u0441\u0443\u043C\u043C\u043E\u0439\" \u0434\u043B\u044F \u0434\u0432\u0443\u0445
    \u0438\u0433\u0440\u043E\u043A\u043E\u0432, \u0433\u0434\u0435 \u0432\u044B\u0438\u0433\u0440\u044B\u0448
    \u043E\u0434\u043D\u043E\u0433\u043E \u0440\u0430\u0432\u0435\u043D \u043F\u0440\u043E\u0438\u0433\u0440\u044B\u0448\u0443
    \u0434\u0440\u0443\u0433\u043E\u0433\u043E. \u041D\u044D\u0448 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432, \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0438\u0432
    \u0442\u0435\u043E\u0440\u0438\u044E \u043D\u0430 \u0431\u043E\u043B\u0435\u0435
    \u0440\u0435\u0430\u043B\u0438\u0441\u0442\u0438\u0447\u043D\u044B\u0435 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438. 
    #### \U0001F4DC \"\u0420\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435
    \u041D\u044D\u0448\u0430\" (Nash Equilibrium)  \u0412 1950 \u0433\u043E\u0434\u0443,
    \u0431\u0443\u0434\u0443\u0447\u0438 22-\u043B\u0435\u0442\u043D\u0438\u043C
    \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u043E\u043C \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0430,
    \u041D\u044D\u0448 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0442\u0430\u0442\u044C\u044E **\"Equilibrium Points in N-person Games\"**
    \u0432 *Proceedings of the National Academy of Sciences* (PNAS). \u042D\u0442\u043E
    \u0431\u044B\u043B\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u0432\u0441\u0435\u0433\u043E
    \u043D\u0430 \u043E\u0434\u043D\u0443 \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0443,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443.  *   **\u041E\u0441\u043D\u043E\u0432\u043D\u0430\u044F
    \u0438\u0434\u0435\u044F:** \u041D\u044D\u0448 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B
    **\u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435** \u043A\u0430\u043A
    \u043D\u0430\u0431\u043E\u0440 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u0439,
    \u043F\u043E \u043E\u0434\u043D\u043E\u0439 \u0434\u043B\u044F \u043A\u0430\u0436\u0434\u043E\u0433\u043E
    \u0438\u0433\u0440\u043E\u043A\u0430, \u043F\u0440\u0438 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043D\u0438 \u043E\u0434\u0438\u043D \u0438\u0437 \u0438\u0433\u0440\u043E\u043A\u043E\u0432
    \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u0443\u043B\u0443\u0447\u0448\u0438\u0442\u044C
    \u0441\u0432\u043E\u0439 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442,
    \u0438\u0437\u043C\u0435\u043D\u0438\u0432 \u0441\u0432\u043E\u044E \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044E
    \u0432 \u043E\u0434\u0438\u043D\u043E\u0447\u043A\u0443, \u043F\u0440\u0438 \u0443\u0441\u043B\u043E\u0432\u0438\u0438,
    \u0447\u0442\u043E \u0434\u0440\u0443\u0433\u0438\u0435 \u0438\u0433\u0440\u043E\u043A\u0438
    \u0441\u0432\u043E\u0438\u0445 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u0439
    \u043D\u0435 \u043C\u0435\u043D\u044F\u044E\u0442. \u041F\u0440\u043E\u0441\u0442\u044B\u043C\u0438
    \u0441\u043B\u043E\u0432\u0430\u043C\u0438, \u044D\u0442\u043E \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044F,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 **\u043D\u0438\u043A\u043E\u043C\u0443
    \u043D\u0435 \u0432\u044B\u0433\u043E\u0434\u043D\u043E \u043E\u0442\u043A\u043B\u043E\u043D\u044F\u0442\u044C\u0441\u044F
    \u043E\u0442 \u0432\u044B\u0431\u0440\u0430\u043D\u043D\u043E\u0439 \u043B\u0438\u043D\u0438\u0438
    \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F**, \u0435\u0441\u043B\u0438
    \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u044E\u0442
    \u0442\u0430\u043A \u0436\u0435. \u042D\u0442\u043E \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u043E\u0435
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u0438\u0433\u0440\u044B,
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0443\u0435\u043C\u044B\u0439
    \u0438\u0441\u0445\u043E\u0434 \u0434\u043B\u044F \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u0433\u0440\u043E\u043A\u043E\u0432. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F:**
    \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u043C \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C
    \u041D\u044D\u0448\u0430 \u0441\u0442\u0430\u043B\u043E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435, \u043D\u043E
    \u0438 \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E **\u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0439
    \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0439 \u0438\u0433\u0440\u044B (\u0441
    \u043B\u044E\u0431\u044B\u043C \u0447\u0438\u0441\u043B\u043E\u043C \u0438\u0433\u0440\u043E\u043A\u043E\u0432)
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u043A\u0430\u043A
    \u043C\u0438\u043D\u0438\u043C\u0443\u043C \u043E\u0434\u043D\u043E \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435**,
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0432 \"\u0441\u043C\u0435\u0448\u0430\u043D\u043D\u044B\u0445
    \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044F\u0445\" (\u043A\u043E\u0433\u0434\u0430
    \u0438\u0433\u0440\u043E\u043A \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0442
    \u043C\u0435\u0436\u0434\u0443 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u043C\u0438
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F\u043C\u0438 \u0441 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0439
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u044C\u044E).  ####
    \U0001F48E \u0412\u043B\u0438\u044F\u043D\u0438\u0435 \"\u0420\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u044F
    \u041D\u044D\u0448\u0430\"  \u041A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044F
    \u041D\u044D\u0448\u0430 \u0441\u0442\u0430\u043B\u0430 \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C
    \u043A\u0430\u043C\u043D\u0435\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438. \u041E\u043D\u0430 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u0430\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043B\u044E\u0431\u044B\u0435 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
    \u2014 \u043E\u0442 \u0440\u044B\u043D\u043E\u0447\u043D\u043E\u0439 \u043A\u043E\u043D\u043A\u0443\u0440\u0435\u043D\u0446\u0438\u0438
    \u0438 \u0430\u0443\u043A\u0446\u0438\u043E\u043D\u043E\u0432 \u0434\u043E \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0435\u0440\u0435\u0433\u043E\u0432\u043E\u0440\u043E\u0432 \u0438 \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u0445
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u043E\u0432. \u042D\u043A\u043E\u043D\u043E\u043C\u0438\u0441\u0442
    \u0420\u043E\u0434\u0436\u0435\u0440 \u041C\u0430\u0439\u0435\u0440\u0441\u043E\u043D
    \u043D\u0430\u0437\u0432\u0430\u043B \u0435\u0435 \"\u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439 XX \u0432\u0435\u043A\u0430...
    \u0441\u0440\u0430\u0432\u043D\u0438\u043C\u044B\u043C \u0441 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\u043C
    \u0434\u0432\u043E\u0439\u043D\u043E\u0439 \u0441\u043F\u0438\u0440\u0430\u043B\u0438
    \u0414\u041D\u041A\".  #### \U0001F9E9 \u0414\u0440\u0443\u0433\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u0433\u0440  \u0412\u0441\u043B\u0435\u0434
    \u0437\u0430 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u0441\u0442\u0430\u0442\u044C\u0435\u0439
    \u041D\u044D\u0448 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0440\u044F\u0434 \u0434\u0440\u0443\u0433\u0438\u0445 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442: *   **\"The Bargaining Problem\" (1950):** \u041A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u043F\u0435\u0440\u0435\u0433\u043E\u0432\u043E\u0440\u043E\u0432, \u0433\u0434\u0435
    \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0435
    \u0432\u044B\u0433\u043E\u0434\u044B \u043C\u0435\u0436\u0434\u0443 \u0434\u0432\u0443\u043C\u044F
    \u0441\u0442\u043E\u0440\u043E\u043D\u0430\u043C\u0438. *   **\"Non-cooperative
    Games\" (1951):** \u0420\u0430\u0437\u0432\u0435\u0440\u043D\u0443\u0442\u0430\u044F
    \u0432\u0435\u0440\u0441\u0438\u044F \u0435\u0433\u043E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438
    \u0432 *Annals of Mathematics*, \u0433\u0434\u0435 \u0431\u044B\u043B\u0430 \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0430 \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044F
    \u0434\u043B\u044F \u0438\u0433\u0440 \u0441 \u043B\u044E\u0431\u044B\u043C \u0447\u0438\u0441\u043B\u043E\u043C
    \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u043E\u0432. *   **\"Two-person
    Cooperative Games\" (1953):** \u0420\u0430\u0431\u043E\u0442\u0430, \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0430\u044F
    \u043A\u043E\u043E\u043F\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u043C
    \u0438\u0433\u0440\u0430\u043C, \u0433\u0434\u0435 \u043E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0442\u043E\u0433\u043E, \u0447\u0442\u043E
    \u043F\u043E\u0437\u0436\u0435 \u0441\u0442\u0430\u043B\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E
    \u043A\u0430\u043A \"\u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430 \u041D\u044D\u0448\u0430\"
    \u2014 \u043F\u043E\u043F\u044B\u0442\u043A\u0430 \u0441\u0432\u0435\u0441\u0442\u0438
    \u0432\u0441\u0435 \u043A\u043E\u043E\u043F\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u043A \u043D\u0435\u043A\u043E\u043E\u043F\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u043E\u0441\u043D\u043E\u0432\u0435.  ### \U0001F9CA \u0427\u0438\u0441\u0442\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430: \u0413\u0435\u043D\u0438\u0439
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438 \u0430\u043D\u0430\u043B\u0438\u0437\u0430 
    \u041F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u043E \u0441 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u0438\u0433\u0440, \u0432 \u043D\u0430\u0447\u0430\u043B\u0435 1950-\u0445 \u0433\u043E\u0434\u043E\u0432
    \u041D\u044D\u0448 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u044D\u0442\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043F\u043E \u0441\u0432\u043E\u0435\u0439
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438 \u0438 \u0433\u043B\u0443\u0431\u0438\u043D\u0435
    \u043D\u0435 \u0443\u0441\u0442\u0443\u043F\u0430\u044E\u0442 \u0435\u0433\u043E
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u043C \u0432 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0435
    \u0438, \u043F\u043E \u043C\u043D\u0435\u043D\u0438\u044E \u043C\u043D\u043E\u0433\u0438\u0445,
    \u0441\u0442\u0430\u0432\u044F\u0442 \u0435\u0433\u043E \u0432 \u043E\u0434\u0438\u043D
    \u0440\u044F\u0434 \u0441 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F. 
    #### \U0001F4D0 \u0422\u0435\u043E\u0440\u0435\u043C\u044B \u041D\u044D\u0448\u0430
    \u043E \u0432\u043B\u043E\u0436\u0435\u043D\u0438\u0438 (Nash Embedding Theorems) 
    \u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u044C\u0442\u0435, \u0447\u0442\u043E
    \u0443 \u0432\u0430\u0441 \u0435\u0441\u0442\u044C \u0438\u0441\u043A\u0440\u0438\u0432\u043B\u0435\u043D\u043D\u043E\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C \u0441\u0444\u0435\u0440\u044B).
    \u0422\u0435\u043E\u0440\u0435\u043C\u044B \u041D\u044D\u0448\u0430, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u0432 1954 \u0438 1956 \u0433\u043E\u0434\u0430\u0445, \u043E\u0442\u0432\u0435\u0447\u0430\u044E\u0442
    \u043D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441: \u043C\u043E\u0436\u043D\u043E
    \u043B\u0438 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u044D\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u043A\u0430\u043A \u0447\u0430\u0441\u0442\u044C \u043E\u0431\u044B\u0447\u043D\u043E\u0433\u043E,
    \u043F\u043B\u043E\u0441\u043A\u043E\u0433\u043E \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0430
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430, \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432
    \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u0432\u0441\u0435 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    (\u0442\u043E \u0435\u0441\u0442\u044C \u0431\u0435\u0437 \u0440\u0430\u0441\u0442\u044F\u0436\u0435\u043D\u0438\u0439
    \u0438 \u0441\u0436\u0430\u0442\u0438\u0439)?. \u041D\u044D\u0448 \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E **\u0434\u0430, \u043B\u044E\u0431\u043E\u0435 \u0442\u0430\u043A\u043E\u0435
    \u0438\u0441\u043A\u0440\u0438\u0432\u043B\u0435\u043D\u043D\u043E\u0435 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    (\u0440\u0438\u043C\u0430\u043D\u043E\u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0435)
    \u043C\u043E\u0436\u043D\u043E \"\u0432\u043B\u043E\u0436\u0438\u0442\u044C\"
    \u0432 \u043F\u043B\u043E\u0441\u043A\u043E\u0435 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u0431\u043E\u043B\u044C\u0448\u0435\u0439 \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438,
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432 \u0432\u0441\u0435 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F**. 
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0434\u043B\u044F C\xB9-\u0433\u043B\u0430\u0434\u043A\u0438\u0445
    \u0432\u043B\u043E\u0436\u0435\u043D\u0438\u0439 (1954):** \u042D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u043A\u0430\u043A **\u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u041D\u044D\u0448\u0430-\u041A\u043E\u0439\u043F\u0435\u0440\u0430**,
    \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u044B\u0439
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442. \u041E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F,
    \u043B\u044E\u0431\u043E\u0435 \u0438\u0441\u043A\u0440\u0438\u0432\u043B\u0435\u043D\u043D\u043E\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E \u043C\u043E\u0436\u043D\u043E
    \u043E\u0447\u0435\u043D\u044C \u0433\u043B\u0430\u0434\u043A\u043E (C\xB9) \u0432\u043B\u043E\u0436\u0438\u0442\u044C
    \u0432 \u043F\u043B\u043E\u0441\u043A\u043E\u0435 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E,
    \u043F\u0440\u0438\u0447\u0435\u043C \u0434\u0430\u0436\u0435 \u0432 \u0441\u043A\u043E\u043B\u044C
    \u0443\u0433\u043E\u0434\u043D\u043E \u043C\u0430\u043B\u0443\u044E \u0435\u0433\u043E
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C. \u042D\u0442\u043E \u0437\u043D\u0430\u0447\u0438\u0442,
    \u0447\u0442\u043E, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C
    \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438 (\u043A\u043E\u0442\u043E\u0440\u0430\u044F,
    \u043A\u0430\u043A \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u043D\u0435
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u0433\u043B\u0430\u0434\u043A\u043E
    \u0432\u043B\u043E\u0436\u0435\u043D\u0430 \u0432 \u0442\u0440\u0435\u0445\u043C\u0435\u0440\u043D\u043E\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E \u0431\u0435\u0437
    \u0438\u0441\u043A\u0430\u0436\u0435\u043D\u0438\u0439) \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u0421\xB9-\u0432\u043B\u043E\u0436\u0435\u043D\u0430
    \u0432 \u0432\u0438\u0434\u0435 \u0433\u043B\u0430\u0434\u043A\u043E\u0439, \u043D\u043E
    \"\u0441\u043C\u043E\u0440\u0449\u0435\u043D\u043D\u043E\u0439\" \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    \u0432\u043D\u0443\u0442\u0440\u0438 \u043A\u0440\u043E\u0448\u0435\u0447\u043D\u043E\u0433\u043E
    \u0448\u0430\u0440\u0430. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0434\u043B\u044F
    C\u1D4F-\u0433\u043B\u0430\u0434\u043A\u0438\u0445 \u0432\u043B\u043E\u0436\u0435\u043D\u0438\u0439
    (1956, k\u22653):** \u042D\u0442\u043E \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438
    \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u0431\u043E\u043B\u0435\u0435 \u0441\u043B\u043E\u0436\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430. \u041E\u043D\u0430 \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u0443\u0435\u0442
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u0431\u043E\u043B\u0435\u0435 \u0433\u043B\u0430\u0434\u043A\u0438\u0445 (\u0434\u043E
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0439 \u0433\u043B\u0430\u0434\u043A\u043E\u0441\u0442\u0438)
    \u0432\u043B\u043E\u0436\u0435\u043D\u0438\u0439, \u043D\u043E \u0443\u0436\u0435
    \u0432 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E \u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438. \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u044D\u0442\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043F\u043E\u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u043E
    \u043E\u0442 \u041D\u044D\u0448\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E
    \u043D\u043E\u0432\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0442\u0435\u043F\u0435\u0440\u044C \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u043A\u0430\u043A...  #### \U0001F6E0\uFE0F \u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u041D\u044D\u0448\u0430 \u2014 \u041C\u043E\u0437\u0435\u0440\u0430 (Nash\u2013Moser
    theorem)  \u0412 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u0433\u043B\u0430\u0434\u043A\u0438\u0445
    \u0432\u043B\u043E\u0436\u0435\u043D\u0438\u044F\u0445 \u041D\u044D\u0448 \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F
    \u0441 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u043E\u0439 \"\u043F\u043E\u0442\u0435\u0440\u0438
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0445\" \u2014 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u043D\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438.
    \u0422\u043E\u0433\u0434\u0430 \u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043C\u043E\u0449\u043D\u044B\u0439 \u043D\u043E\u0432\u044B\u0439 \u043C\u0435\u0442\u043E\u0434,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0439 \u043D\u0430 \u043C\u043E\u0434\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u043C
    **\u043C\u0435\u0442\u043E\u0434\u0435 \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u0441 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043E\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u043E\u0432 \u0441\u0433\u043B\u0430\u0436\u0438\u0432\u0430\u043D\u0438\u044F**.
    \u042D\u0442\u0430 \u0442\u0435\u0445\u043D\u0438\u043A\u0430 \u0431\u044B\u043B\u0430
    \u043F\u043E\u0437\u0436\u0435 \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0430
    \u042E\u0440\u0433\u0435\u043D\u043E\u043C \u041C\u043E\u0437\u0435\u0440\u043E\u043C
    (\u0434\u043B\u044F \u0437\u0430\u0434\u0430\u0447 \u043D\u0435\u0431\u0435\u0441\u043D\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438) \u0438 \u0442\u0435\u043F\u0435\u0440\u044C
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430 \u043A\u0430\u043A **\u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u041D\u044D\u0448\u0430 \u2014 \u041C\u043E\u0437\u0435\u0440\u0430** \u2014
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432 \u0434\u043B\u044F
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u043D\u0435\u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0445 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0432 \u0447\u0430\u0441\u0442\u043D\u044B\u0445
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0445.  #### \U0001F525
    \u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0414\u0435 \u0414\u0436\u043E\u0440\u0434\u0436\u0438
    \u2014 \u041D\u044D\u0448\u0430 \u2014 \u041C\u043E\u0437\u0435\u0440\u0430 (1958) 
    \u0412 1958 \u0433\u043E\u0434\u0443 \u041D\u044D\u0448 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0440\u0430\u0431\u043E\u0442\u0443 \"Continuity of solutions of parabolic and
    elliptic equations\". \u0412 \u043D\u0435\u0439 \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u043E **\u0440\u0435\u0433\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u0438
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u043E
    \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u043F\u0430\u0440\u0430\u0431\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0432 \u0447\u0430\u0441\u0442\u043D\u044B\u0445
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0445** \u0441 \u0440\u0430\u0437\u0440\u044B\u0432\u043D\u044B\u043C\u0438
    \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u0430\u043C\u0438.
    \u041E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C, \u0447\u0442\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0442\u0430\u043A\u0438\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439,
    \u0434\u0430\u0436\u0435 \u043F\u0440\u0438 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0438
    \u0433\u043B\u0430\u0434\u043A\u043E\u0441\u0442\u0438 \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u043E\u0432,
    **\u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u043C\u0438 \u0438
    \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u044F\u044E\u0442
    \u0443\u0441\u043B\u043E\u0432\u0438\u044E \u0413\u0451\u043B\u044C\u0434\u0435\u0440\u0430**.
    \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435, \u0441\u0434\u0435\u043B\u0430\u043D\u043D\u043E\u0435
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E \u043E\u0442 \u042D\u043D\u043D\u0438\u043E
    \u0414\u0435 \u0414\u0436\u043E\u0440\u0434\u0436\u0438, \u0441\u0442\u0430\u043B\u043E
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u043A\u0430\u043C\u043D\u0435\u0439 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0438 \u043D\u0430\u0448\u043B\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0432\u043E \u043C\u043D\u043E\u0433\u0438\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445 \u0444\u0438\u0437\u0438\u043A\u0438
    \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438.  \u0414\u0436\u043E\u043D
    \u041D\u044D\u0448 \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0441\u043B\u0435\u0434 \u0432 \u043D\u0430\u0443\u043A\u0435. \u0412 \u043A\u0430\u0436\u0434\u043E\u0439
    \u0438\u0437 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u043D \u043A\u0430\u0441\u0430\u043B\u0441\u044F, \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u0446\u0435\u043B\u044B\u0435 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u044E\u0442\u0441\u044F
    \u0442\u044B\u0441\u044F\u0447\u0438 \u0443\u0447\u0435\u043D\u044B\u0445 \u043F\u043E
    \u0441\u0435\u0439 \u0434\u0435\u043D\u044C. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u2014 \u044D\u0442\u043E \u0440\u0435\u0434\u043A\u0438\u0439 \u043F\u0440\u0438\u043C\u0435\u0440
    \u0441\u043E\u0447\u0435\u0442\u0430\u043D\u0438\u044F \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0438, \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u0430 \u0438 \u0441\u043C\u0435\u043B\u043E\u0441\u0442\u0438
    \u0432 \u043F\u043E\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0435 \u0437\u0430\u0434\u0430\u0447.
    \u041E\u0442 \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u0438\u0433\u0440\u043E\u043A\u043E\u0432 \u043D\u0430 \u0440\u044B\u043D\u043A\u0435
    \u0434\u043E \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439 \u2014 \u0435\u0433\u043E
    \u0438\u0434\u0435\u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044E\u0442
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u0438 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u0442\u044C."
  achievementsEn: 
  personalLifeRu: "\u0416\u0438\u0437\u043D\u044C \u0414\u0436\u043E\u043D\u0430
    \u041D\u044D\u0448\u0430 \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u0430
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u0445 \u0432\u0437\u043B\u0435\u0442\u043E\u0432,
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043F\u0430\u0434\u0435\u043D\u0438\u0439
    \u0438 \u0441\u0442\u043E\u043B\u044C \u0436\u0435 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F. \u042D\u0442\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0433\u0435\u043D\u0438\u044F, \u0447\u044C\u044F
    \u043B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C, \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0438 \u0431\u043E\u0440\u044C\u0431\u0430 \u0441 \u0431\u043E\u043B\u0435\u0437\u043D\u044C\u044E
    \u0431\u044B\u043B\u0438 \u0442\u0430\u043A \u0436\u0435 \u0441\u043B\u043E\u0436\u043D\u044B,
    \u043A\u0430\u043A \u0438 \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438.  ### \U0001F3E1 \u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u0441\u0435\u043C\u044C\u044F  \u0414\u0436\u043E\u043D \u0424\u043E\u0440\u0431\u0441
    \u041D\u044D\u0448-\u043C\u043B\u0430\u0434\u0448\u0438\u0439 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    **13 \u0438\u044E\u043D\u044F 1928 \u0433\u043E\u0434\u0430** \u0432 \u0433\u043E\u0440\u043E\u0434\u0435
    \u0411\u043B\u0443\u0444\u0438\u043B\u0434, \u0448\u0442\u0430\u0442 \u0417\u0430\u043F\u0430\u0434\u043D\u0430\u044F
    \u0412\u0438\u0440\u0433\u0438\u043D\u0438\u044F. \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u0414\u0436\u043E\u043D \u0424\u043E\u0440\u0431\u0441 \u041D\u044D\u0448-\u0441\u0442\u0430\u0440\u0448\u0438\u0439,
    \u0431\u044B\u043B \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C-\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u043A\u043E\u043C,
    \u0430 \u043C\u0430\u0442\u044C, \u041C\u0430\u0440\u0442\u0430 \u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F
    \u041C\u0430\u0440\u0442\u0438\u043D, \u0434\u043E \u0437\u0430\u043C\u0443\u0436\u0435\u0441\u0442\u0432\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430 \u0448\u043A\u043E\u043B\u044C\u043D\u043E\u0439
    \u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0435\u0439. \u0412
    1930 \u0433\u043E\u0434\u0443 \u0443 \u043D\u0435\u0433\u043E \u043F\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C
    \u043C\u043B\u0430\u0434\u0448\u0430\u044F \u0441\u0435\u0441\u0442\u0440\u0430
    \u041C\u0430\u0440\u0442\u0430. \u0421\u0435\u043C\u044C\u044F \u0436\u0438\u043B\u0430
    \u0432 \u0434\u043E\u0441\u0442\u0430\u0442\u043A\u0435, \u0442\u0430\u043A \u043A\u0430\u043A
    \u043E\u0442\u0435\u0446 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B \u0440\u0430\u0431\u043E\u0442\u0443
    \u0434\u0430\u0436\u0435 \u0432 \u0433\u043E\u0434\u044B \u0412\u0435\u043B\u0438\u043A\u043E\u0439
    \u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u0438.  \u0412 \u0434\u0435\u0442\u0441\u0442\u0432\u0435
    \u041D\u044D\u0448 \u0431\u044B\u043B \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u043C
    \u0438 \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u043B \u043A\u043D\u0438\u0433\u0438
    \u0438\u0433\u0440\u0430\u043C \u0441\u043E \u0441\u0432\u0435\u0440\u0441\u0442\u043D\u0438\u043A\u0430\u043C\u0438.
    \u041E\u043D \u0431\u044B\u043B \u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D,
    \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043D\u0430\u0441\u0432\u0438\u0441\u0442\u044B\u0432\u0430\u0442\u044C
    \u0446\u0435\u043B\u044B\u0435 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u044F. \u0412
    \u0448\u043A\u043E\u043B\u0435 \u0435\u0433\u043E \u0434\u0430\u0436\u0435 \u0441\u0447\u0438\u0442\u0430\u043B\u0438
    \u043C\u0435\u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C, \u043D\u043E,
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u044D\u0442\u043E \u0431\u044B\u043B\u043E
    \u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0435\u043C \u0441\u043A\u0443\u043A\u0438.
    \u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u0439 \u043C\u043E\u043C\u0435\u043D\u0442
    \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B \u0432 14 \u043B\u0435\u0442,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043B
    \u043A\u043D\u0438\u0433\u0443 \u042D\u0440\u0438\u043A\u0430 \u0422. \u0411\u0435\u043B\u043B\u0430
    \"\u0412\u0435\u043B\u0438\u043A\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\".
    \u042D\u0442\u043E \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B\u043E \u0432
    \u043D\u0435\u043C \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0439 \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0438 \u043E\u043D
    \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u043C\u0430\u043B\u0443\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u0424\u0435\u0440\u043C\u0430. \u0420\u043E\u0434\u0438\u0442\u0435\u043B\u0438
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0438 \u0435\u0433\u043E
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435, \u0437\u0430\u043F\u0438\u0441\u0430\u0432
    \u043D\u0430 \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043A\u0443\u0440\u0441\u044B \u0432 \u043C\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u043E\u043B\u043B\u0435\u0434\u0436.  ### \U0001F393 \u0423\u0447\u0451\u0431\u0430
    \u0438 \u043D\u0430\u0447\u0430\u043B\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B 
    \u0412 1945 \u0433\u043E\u0434\u0443 \u041D\u044D\u0448 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0422\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u041A\u0430\u0440\u043D\u0435\u0433\u0438
    (\u043D\u044B\u043D\u0435 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u041A\u0430\u0440\u043D\u0435\u0433\u0438-\u041C\u0435\u043B\u043B\u043E\u043D)
    \u043F\u043E \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u0438 \u0414\u0436\u043E\u0440\u0434\u0436\u0430
    \u0412\u0435\u0441\u0442\u0438\u043D\u0433\u0430\u0443\u0437\u0430. \u041E\u043D
    \u043D\u0430\u0447\u0430\u043B \u0441 \u0445\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0448\u0438\u043D\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F,
    \u043D\u043E \u0431\u044B\u0441\u0442\u0440\u043E \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0445\u0438\u043C\u0438\u044E, \u0430 \u0437\u0430\u0442\u0435\u043C,
    \u043F\u043E \u0441\u043E\u0432\u0435\u0442\u0443 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0414\u0436\u043E\u043D\u0430 \u041B\u0430\u0439\u0442\u0442\u043E\u043D\u0430
    \u0421\u0438\u043D\u0434\u0436\u0430, \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0441\u044F \u043D\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u0417\u0430 \u0442\u0440\u0438
    \u0433\u043E\u0434\u0430 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430 \u0438 \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430. 
    \u0415\u0433\u043E \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C,
    \u0420\u0438\u0447\u0430\u0440\u0434 \u0414\u0430\u0444\u0444\u0438\u043D, \u0434\u0430\u043B
    \u0435\u043C\u0443 \u0441\u0430\u043C\u0443\u044E \u043B\u0430\u043A\u043E\u043D\u0438\u0447\u043D\u0443\u044E
    \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u044E \u0434\u043B\u044F
    \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F \u0432 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u0443\u0440\u0443,
    \u0441\u043E\u0441\u0442\u043E\u044F\u0449\u0443\u044E \u0438\u0437 \u043E\u0434\u043D\u043E\u0433\u043E
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F: **\"\u042D\u0442\u043E\u0442
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u2014 \u0433\u0435\u043D\u0438\u0439\"**.
    \u041D\u044D\u0448 \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u043E\u0442 \u0413\u0430\u0440\u0432\u0430\u0440\u0434\u0430 \u0438 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0430
    \u0438 \u0432\u044B\u0431\u0440\u0430\u043B \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439.
    \u0412 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435, \u0433\u0434\u0435
    \u0446\u0430\u0440\u0438\u043B\u0430 \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \"\u0437\u043E\u043B\u043E\u0442\u043E\u0433\u043E \u0432\u0435\u043A\u0430\",
    \u043E\u043D \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B \u0442\u0430\u043A\u0438\u0445
    \u0441\u0432\u0435\u0442\u0438\u043B, \u043A\u0430\u043A **\u0410\u043B\u044C\u0431\u0435\u0440\u0442
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D** \u0438 **\u0414\u0436\u043E\u043D
    \u0444\u043E\u043D \u041D\u0435\u0439\u043C\u0430\u043D**. \u0412 1950 \u0433\u043E\u0434\u0443,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 22 \u043B\u0435\u0442,
    \u043E\u043D \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u043E\u0431\u044A\u0435\u043C\u043E\u043C
    \u0432\u0441\u0435\u0433\u043E 28 \u0441\u0442\u0440\u0430\u043D\u0438\u0446,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0430
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \"\u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u044F
    \u041D\u044D\u0448\u0430\".  ### \U0001F4BC \u0420\u0430\u0431\u043E\u0442\u0430
    \u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438
    \u0443\u0447\u0451\u043D\u044B\u043C\u0438  \u041F\u043E\u0441\u043B\u0435 \u0437\u0430\u0449\u0438\u0442\u044B
    \u041D\u044D\u0448 \u043D\u0435\u0434\u043E\u043B\u0433\u043E \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0441\u0442\u0430\u043B \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0430\u043D\u0442\u043E\u043C
    \u0432 **RAND Corporation** \u2014 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 \u0432\u0440\u0435\u043C\u0435\u043D \u0425\u043E\u043B\u043E\u0434\u043D\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B. \u041E\u0434\u043D\u0430\u043A\u043E \u0432 \u0440\u0430\u0437\u0433\u0430\u0440
    \u043C\u0430\u043A\u043A\u0430\u0440\u0442\u0438\u0437\u043C\u0430 \u0435\u0433\u043E
    \u0443\u0432\u043E\u043B\u0438\u043B\u0438 \u043E\u0442\u0442\u0443\u0434\u0430
    \u043A\u0430\u043A \"\u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u0443\u044E
    \u0443\u0433\u0440\u043E\u0437\u0443 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438\".
    \u0412 **1951 \u0433\u043E\u0434\u0443** \u043E\u043D \u043D\u0430\u0447\u0430\u043B
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C \u0432 \u041C\u0430\u0441\u0441\u0430\u0447\u0443\u0441\u0435\u0442\u0441\u043A\u043E\u043C
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 (MIT).  \u0412 MIT, \u0431\u0443\u0434\u0443\u0447\u0438
    \u043C\u043E\u043B\u043E\u0434\u044B\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C,
    \u041D\u044D\u0448 \u0431\u043B\u0438\u0441\u0442\u0430\u043B, \u0440\u0435\u0448\u0430\u044F
    \u0437\u0430\u0434\u0430\u0447\u0438, \u0441\u0447\u0438\u0442\u0430\u0432\u0448\u0438\u0435\u0441\u044F
    \"\u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u043C\u0438\".
    \u0415\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438 \u043F\u043E
    \u0446\u0435\u0445\u0443 \u0431\u044B\u043B\u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0441\u0442\u044B
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438: **\u041D\u043E\u0440\u0431\u0435\u0440\u0442
    \u0412\u0438\u043D\u0435\u0440, \u0414\u0436\u043E\u043D \u041C\u0438\u043B\u043D\u043E\u0440,
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A,
    \u041A\u0435\u043D\u043D\u0435\u0442 \u042D\u0440\u0440\u043E\u0443, \u0420\u043E\u0431\u0435\u0440\u0442
    \u0421\u043E\u043B\u043E\u0443 \u0438 \u041F\u043E\u043B \u0421\u0430\u043C\u0443\u044D\u043B\u044C\u0441\u043E\u043D**.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435, \u0435\u0433\u043E \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0435
    \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0438 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435
    \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445 \u043D\u0430\u0432\u044B\u043A\u043E\u0432
    \u0447\u0430\u0441\u0442\u043E \u0434\u0435\u043B\u0430\u043B\u0438 \u0435\u0433\u043E
    \u043E\u0434\u0438\u043D\u043E\u043A\u0438\u043C \u0438 \u0434\u0430\u0436\u0435
    \"\u043D\u0435\u0432\u044B\u043D\u043E\u0441\u0438\u043C\u044B\u043C\" \u0432
    \u0433\u043B\u0430\u0437\u0430\u0445 \u043E\u043A\u0440\u0443\u0436\u0430\u044E\u0449\u0438\u0445. 
    ### \u2764\uFE0F \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C:
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438 \u0438 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438 
    \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u041D\u044D\u0448\u0430
    \u0431\u044B\u043B\u0430 \u0437\u0430\u043F\u0443\u0442\u0430\u043D\u043D\u043E\u0439:
    *   \u0412 1953 \u0433\u043E\u0434\u0443 \u0443 \u043D\u0435\u0433\u043E \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0441\u044B\u043D **\u0414\u0436\u043E\u043D \u0414\u044D\u0432\u0438\u0434
    \u0421\u0442\u0438\u0440** \u043E\u0442 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0439
    \u0441 \u042D\u043B\u0435\u043E\u043D\u043E\u0440 \u0421\u0442\u0438\u0440, \u043D\u0430
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u0442\u0430\u043A \u0438
    \u043D\u0435 \u0436\u0435\u043D\u0438\u043B\u0441\u044F. *   \u0412 **\u0444\u0435\u0432\u0440\u0430\u043B\u0435
    1957 \u0433\u043E\u0434\u0430** \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0410\u043B\u0438\u0441\u0438\u0438 \u041B\u043E\u043F\u0435\u0441-\u0425\u0430\u0440\u0440\u0438\u0441\u043E\u043D
    \u0434\u0435 \u041B\u0430\u0440\u0434\u0435, \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u043E\u0439
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043A\u0435-\u0444\u0438\u0437\u0438\u043A\u0435
    \u0438\u0437 \u0421\u0430\u043B\u044C\u0432\u0430\u0434\u043E\u0440\u0430, \u0441
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0432 MIT. *   \u0412 1959 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430
    \u0410\u043B\u0438\u0441\u0438\u044F \u0431\u044B\u043B\u0430 \u0431\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u0430
    \u0438\u0445 \u0441\u044B\u043D\u043E\u043C **\u0414\u0436\u043E\u043D\u043E\u043C
    \u0427\u0430\u0440\u043B\u044C\u0437\u043E\u043C \u041C\u0430\u0440\u0442\u0438\u043D\u043E\u043C**,
    \u0443 \u041D\u044D\u0448\u0430 \u043D\u0430\u0447\u0430\u043B\u0438\u0441\u044C
    \u043F\u0435\u0440\u0432\u044B\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043A\u0438
    \u043F\u0441\u0438\u0445\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430. 
    \u0411\u043E\u043B\u0435\u0437\u043D\u044C \u041D\u044D\u0448\u0430, \u0434\u0438\u0430\u0433\u043D\u043E\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u043A\u0430\u043A \u043F\u0430\u0440\u0430\u043D\u043E\u0438\u0434\u0430\u043B\u044C\u043D\u0430\u044F
    \u0448\u0438\u0437\u043E\u0444\u0440\u0435\u043D\u0438\u044F, \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u043B\u0430
    \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0443 \u0438 \u0431\u0440\u0430\u043A.
    \u0412 1963 \u0433\u043E\u0434\u0443 \u043E\u043D\u0438 \u0441 \u0410\u043B\u0438\u0441\u0438\u0435\u0439
    \u0440\u0430\u0437\u0432\u0435\u043B\u0438\u0441\u044C. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043F\u043E\u0441\u043B\u0435 \u0432\u044B\u043F\u0438\u0441\u043A\u0438 \u0438\u0437
    \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u044B \u0432 1970 \u0433\u043E\u0434\u0443
    \u0410\u043B\u0438\u0441\u0438\u044F, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0440\u0430\u0437\u0432\u043E\u0434, \u043F\u0440\u0438\u043D\u044F\u043B\u0430
    \u0435\u0433\u043E \u0432 \u0441\u0432\u043E\u0439 \u0434\u043E\u043C \u043A\u0430\u043A
    \"\u0436\u0438\u043B\u044C\u0446\u0430\" (boarder), \u0447\u0442\u043E \u0441\u043F\u0430\u0441\u043B\u043E
    \u0435\u0433\u043E \u043E\u0442 \u0431\u0435\u0437\u0434\u043E\u043C\u043D\u043E\u0441\u0442\u0438.
    \u0418\u0445 \u0441\u044B\u043D, \u0442\u043E\u0436\u0435 \u043E\u0434\u0430\u0440\u0435\u043D\u043D\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0432 \u043F\u043E\u0434\u0440\u043E\u0441\u0442\u043A\u043E\u0432\u043E\u043C
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u0442\u0430\u043A\u0436\u0435
    \u0437\u0430\u0431\u043E\u043B\u0435\u043B \u0448\u0438\u0437\u043E\u0444\u0440\u0435\u043D\u0438\u0435\u0439. 
    \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u041D\u044D\u0448\u0430
    \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438 \u043F\u043E\u0441\u043B\u0435
    \u0431\u043E\u043B\u0435\u0437\u043D\u0438 \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438\u0441\u044C.
    \u041E\u043D \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u0441\u044F
    \u0432 \"\u043F\u0440\u0438\u0437\u0440\u0430\u0447\u043D\u0443\u044E\" \u0444\u0438\u0433\u0443\u0440\u0443
    \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0430, \u0433\u0434\u0435 \u0435\u0433\u043E
    \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0441\u0442\u0438 \u0442\u0435\u0440\u043F\u0435\u043B\u0438,
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044F \u0431\u0440\u043E\u0434\u0438\u0442\u044C
    \u043F\u043E \u043A\u0430\u043C\u043F\u0443\u0441\u0443 \u0438 \u043F\u0438\u0441\u0430\u0442\u044C
    \u043D\u0430 \u0434\u043E\u0441\u043A\u0430\u0445. \u0413\u043E\u0434\u044B \u0448\u043B\u0438,
    \u0438 \u0435\u0433\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u043D\u0430\u0447\u0430\u043B\u043E \u0443\u043B\u0443\u0447\u0448\u0430\u0442\u044C\u0441\u044F.
    \u0412 **2001 \u0433\u043E\u0434\u0443**, \u0447\u0435\u0440\u0435\u0437 38 \u043B\u0435\u0442
    \u043F\u043E\u0441\u043B\u0435 \u0440\u0430\u0437\u0432\u043E\u0434\u0430, \u043E\u043D\u0438
    \u0441 \u0410\u043B\u0438\u0441\u0438\u0435\u0439 \u043F\u043E\u0436\u0435\u043D\u0438\u043B\u0438\u0441\u044C
    \u0432\u043D\u043E\u0432\u044C.  ### \U0001F31F \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0438 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0441\u043C\u0435\u0440\u0442\u044C 
    \u0412\u0435\u0440\u0448\u0438\u043D\u043E\u0439 \u0435\u0433\u043E \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u0441\u0442\u0430\u043B\u043E \u043F\u0440\u0438\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0435
    **\u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    \u043F\u043E \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0435 \u0432 1994
    \u0433\u043E\u0434\u0443** \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u0443
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u0433\u0440, \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u0443\u044E
    \u0435\u0449\u0451 \u0432 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u0443\u0440\u0435.
    \u0417\u0430 \u043A\u0443\u043B\u0438\u0441\u0430\u043C\u0438 \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u043C\u0438\u0442\u0435\u0442\u0430 \u0448\u043B\u0430 \u0431\u043E\u0440\u044C\u0431\u0430
    \u0437\u0430 \u0442\u043E, \u0441\u0442\u043E\u0438\u0442 \u043B\u0438 \u043F\u0440\u0438\u0441\u0443\u0436\u0434\u0430\u0442\u044C
    \u043D\u0430\u0433\u0440\u0430\u0434\u0443 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0443,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0441\u0447\u0438\u0442\u0430\u043B\u0438
    \"\u0431\u0435\u0437\u0443\u043C\u043D\u044B\u043C\". \u041E\u043D \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u043B
    \u043F\u0440\u0435\u043C\u0438\u044E \u0441 \u0420\u0435\u0439\u043D\u0445\u0430\u0440\u0434\u043E\u043C
    \u0417\u0435\u043B\u044C\u0442\u0435\u043D\u043E\u043C \u0438 \u0414\u0436\u043E\u043D\u043E\u043C
    \u0425\u0430\u0440\u0441\u0430\u043D\u044C\u0438.  \u0412 2015 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B **\u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E** \u2014 \u043E\u0434\u043D\u0443 \u0438\u0437
    \u0432\u044B\u0441\u0448\u0438\u0445 \u043D\u0430\u0433\u0440\u0430\u0434 \u0432
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. 23 \u043C\u0430\u044F
    2015 \u0433\u043E\u0434\u0430, \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044F\u0441\u044C
    \u0438\u0437 \u041E\u0441\u043B\u043E, \u0433\u0434\u0435 \u0435\u043C\u0443
    \u0432\u0440\u0443\u0447\u0438\u043B\u0438 \u043F\u0440\u0435\u043C\u0438\u044E,
    **86-\u043B\u0435\u0442\u043D\u0438\u0439 \u0414\u0436\u043E\u043D \u041D\u044D\u0448
    \u0438 \u0435\u0433\u043E 82-\u043B\u0435\u0442\u043D\u044F\u044F \u0436\u0435\u043D\u0430
    \u0410\u043B\u0438\u0441\u0438\u044F \u043F\u043E\u0433\u0438\u0431\u043B\u0438
    \u0432 \u0430\u0432\u0442\u043E\u043C\u043E\u0431\u0438\u043B\u044C\u043D\u043E\u0439
    \u0430\u0432\u0430\u0440\u0438\u0438 \u0432 \u041D\u044C\u044E-\u0414\u0436\u0435\u0440\u0441\u0438**."
  personalLifeEn: 
  shortBioRu: "\u0414\u0436\u043E\u043D \u0424\u043E\u0440\u0431\u0441 \u041D\u044D\u0448-\u043C\u043B\u0430\u0434\u0448\u0438\u0439
    (13 \u0438\u044E\u043D\u044F 1928 \u2014 23 \u043C\u0430\u044F 2015) \u2014 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u0439
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043D\u0430\u0443\u043A\u0438.
    \u041E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u0433\u0440, \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E,
    \u043F\u0435\u0440\u0435\u0436\u0438\u043B \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u0442\u044F\u0436\u0435\u043B\u043E\u0439 \u0431\u043E\u0440\u044C\u0431\u044B
    \u0441 \u043F\u0430\u0440\u0430\u043D\u043E\u0438\u0434\u0430\u043B\u044C\u043D\u043E\u0439
    \u0448\u0438\u0437\u043E\u0444\u0440\u0435\u043D\u0438\u0435\u0439 \u0438 \u0441\u043C\u043E\u0433
    \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F \u043A \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435. \u0415\u0433\u043E \u0441\u0443\u0434\u044C\u0431\u0430,
    \u043F\u043E\u043B\u043D\u0430\u044F \u0432\u0437\u043B\u0435\u0442\u043E\u0432
    \u0438 \u043F\u0430\u0434\u0435\u043D\u0438\u0439, \u0431\u044B\u043B\u0430 \u0443\u0432\u0435\u043A\u043E\u0432\u0435\u0447\u0435\u043D\u0430
    \u0432 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u043C \u0444\u0438\u043B\u044C\u043C\u0435
    \xAB\u0418\u0433\u0440\u044B \u0440\u0430\u0437\u0443\u043C\u0430\xBB.  ### \U0001F4DC
    \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B \u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0433\u0435\u043D\u0438\u044F  \u0414\u0436\u043E\u043D \u041D\u044D\u0448 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0411\u043B\u0443\u0444\u0438\u043B\u0434\u0435, \u0448\u0442\u0430\u0442
    \u0417\u0430\u043F\u0430\u0434\u043D\u0430\u044F \u0412\u0438\u0440\u0433\u0438\u043D\u0438\u044F,
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430-\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u043A\u0430
    \u0438 \u0448\u043A\u043E\u043B\u044C\u043D\u043E\u0439 \u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u044B.
    \u0412 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u043E\u043D \u0431\u044B\u043B
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u043C \u0440\u0435\u0431\u0435\u043D\u043A\u043E\u043C,
    \u0431\u043E\u043B\u044C\u0448\u0435 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u043D\u044B\u043C
    \u043A\u043D\u0438\u0433\u0430\u043C\u0438 \u0438 \u0448\u0430\u0445\u043C\u0430\u0442\u0430\u043C\u0438,
    \u0447\u0435\u043C \u0438\u0433\u0440\u0430\u043C\u0438 \u0441\u043E \u0441\u0432\u0435\u0440\u0441\u0442\u043D\u0438\u043A\u0430\u043C\u0438.
    \u0412 \u0448\u043A\u043E\u043B\u0435 \u043E\u043D \u043D\u0435 \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F \u0443\u0441\u043F\u0435\u0445\u043E\u0432
    \u0438 \u0434\u0430\u0436\u0435 \u0441\u0447\u0438\u0442\u0430\u043B\u0441\u044F
    \u043C\u0435\u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C, \u043F\u043E\u043A\u0430
    \u0432 14 \u043B\u0435\u0442 \u0435\u043C\u0443 \u043D\u0435 \u043F\u043E\u043F\u0430\u043B\u0430\u0441\u044C
    \u043A\u043D\u0438\u0433\u0430 \u042D\u0440\u0438\u043A\u0430 \u0422. \u0411\u0435\u043B\u043B\u0430
    \xAB\u0412\u0435\u043B\u0438\u043A\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB.
    \u041F\u0440\u043E\u0447\u0438\u0442\u0430\u0432 \u0435\u0435, \u041D\u044D\u0448
    \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u043C\u0430\u043B\u0443\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u0424\u0435\u0440\u043C\u0430, \u0438 \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0433\u0435\u043D\u0438\u0439 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u0432 \u043F\u043E\u043B\u043D\u043E\u0439 \u043C\u0435\u0440\u0435.  \u0412
    1945 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0422\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u041A\u0430\u0440\u043D\u0435\u0433\u0438
    (\u043D\u044B\u043D\u0435 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u041A\u0430\u0440\u043D\u0435\u0433\u0438-\u041C\u0435\u043B\u043B\u043E\u043D\u0430),
    \u0433\u0434\u0435 \u043F\u0440\u043E\u0431\u043E\u0432\u0430\u043B \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u0445\u0438\u043C\u0438\u044E \u0438 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0443,
    \u043D\u043E \u0432 \u0438\u0442\u043E\u0433\u0435 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0441\u044F
    \u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0431\u044B\u0441\u0442\u0440\u043E \u0440\u0430\u0437\u0433\u043B\u044F\u0434\u0435\u043B\u0438
    \u0435\u0433\u043E \u0442\u0430\u043B\u0430\u043D\u0442. \u0420\u0438\u0447\u0430\u0440\u0434
    \u0414\u0430\u0444\u0444\u0438\u043D, \u0435\u0433\u043E \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C,
    \u0434\u0430\u043B \u0435\u043C\u0443 \u0441\u0430\u043C\u0443\u044E \u043B\u0430\u043A\u043E\u043D\u0438\u0447\u043D\u0443\u044E
    \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u044E \u0434\u043B\u044F
    \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F \u0432 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u0443\u0440\u0443:
    \xAB\u042D\u0442\u043E\u0442 \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u2014
    \u0433\u0435\u043D\u0438\u0439!\xBB.  \u0412 1948 \u0433\u043E\u0434\u0443 \u041D\u044D\u0448
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u0433\u0434\u0435,
    \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u044B\u0439
    \u043D\u043E\u0432\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u0438\u0433\u0440
    \u0414\u0436\u043E\u043D\u0430 \u0444\u043E\u043D \u041D\u0435\u0439\u043C\u0430\u043D\u0430
    \u0438 \u041E\u0441\u043A\u0430\u0440\u0430 \u041C\u043E\u0440\u0433\u0435\u043D\u0448\u0442\u0435\u0440\u043D\u0430,
    \u0440\u0435\u0448\u0438\u043B \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C
    \u0441\u0435\u0431\u044F \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438.
    \u041E\u043D \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435 \u043F\u043E\u0441\u0435\u0449\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438,
    \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u044F \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F, \u0438
    \u0443\u0436\u0435 \u0432 1950 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    22 \u043B\u0435\u0442, \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u043E\u0431\u044A\u0435\u043C\u043E\u043C \u0432\u0441\u0435\u0433\u043E 28
    \u0441\u0442\u0440\u0430\u043D\u0438\u0446 \u043D\u0430 \u0442\u0435\u043C\u0443
    \xAB\u041D\u0435\u043A\u043E\u043E\u043F\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u0435
    \u0438\u0433\u0440\u044B\xBB. \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0430 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0438 \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430 \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u0437\u0436\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430
    \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \xAB\u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435
    \u041D\u044D\u0448\u0430\xBB.  ### \U0001F4A1 \xAB\u0420\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435
    \u041D\u044D\u0448\u0430\xBB \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F  *   **\u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u0433\u0440:** \u0414\u043E
    \u041D\u044D\u0448\u0430 \u0442\u0435\u043E\u0440\u0438\u044F \u0438\u0433\u0440
    \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B\u0430
    \xAB\u0438\u0433\u0440\u044B \u0441 \u043D\u0443\u043B\u0435\u0432\u043E\u0439
    \u0441\u0443\u043C\u043C\u043E\u0439\xBB (\u0432\u044B\u0438\u0433\u0440\u044B\u0448
    \u043E\u0434\u043D\u043E\u0433\u043E \u0440\u0430\u0432\u0435\u043D \u043F\u0440\u043E\u0438\u0433\u0440\u044B\u0448\u0443
    \u0434\u0440\u0443\u0433\u043E\u0433\u043E). \u041D\u044D\u0448 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432, \u043F\u0440\u043E\u0430\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0432
    \xAB\u0438\u0433\u0440\u044B \u0441 \u043D\u0435\u043D\u0443\u043B\u0435\u0432\u043E\u0439
    \u0441\u0443\u043C\u043C\u043E\u0439\xBB, \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0432\u0441\u0435 \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u0438 \u043C\u043E\u0433\u0443\u0442
    \u043A\u0430\u043A \u0432\u044B\u0438\u0433\u0440\u0430\u0442\u044C, \u0442\u0430\u043A
    \u0438 \u043F\u0440\u043E\u0438\u0433\u0440\u0430\u0442\u044C. \u0415\u0433\u043E
    \xAB\u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435 \u041D\u044D\u0448\u0430\xBB
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044E,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043D\u0438 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0438\u0433\u0440\u043E\u043A\u043E\u0432 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
    \u0443\u043B\u0443\u0447\u0448\u0438\u0442\u044C \u0441\u0432\u043E\u044E \u043F\u043E\u0437\u0438\u0446\u0438\u044E,
    \u0438\u0437\u043C\u0435\u043D\u0438\u0432 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044E
    \u0432 \u043E\u0434\u0438\u043D\u043E\u0447\u043A\u0443, \u0442\u0430\u043A \u043A\u0430\u043A
    \u044D\u0442\u043E \u0443\u0445\u0443\u0434\u0448\u0438\u0442 \u0435\u0433\u043E
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435. \u042D\u0442\u0430 \u0438\u0434\u0435\u044F
    \u0441\u0442\u0430\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0438 \u043D\u0430\u0448\u043B\u0430 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0432 \u0431\u0438\u0437\u043D\u0435\u0441-\u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044F\u0445,
    \u043F\u043E\u043B\u0438\u0442\u043E\u043B\u043E\u0433\u0438\u0438 \u0438 \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438.
    *   **\u0412\u043A\u043B\u0430\u0434 \u0432 \xAB\u0447\u0438\u0441\u0442\u0443\u044E\xBB
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443:** \u041F\u043E\u043C\u0438\u043C\u043E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u0433\u0440, \u041D\u044D\u0448 \u0432\u043D\u0435\u0441
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0438 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. \u0412 1950-\u0445 \u0433\u043E\u0434\u0430\u0445
    \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B **\u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u041D\u044D\u0448\u0430 \u043E \u0432\u043B\u043E\u0436\u0435\u043D\u0438\u0438**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u0447\u0438\u0442\u0430\u044E\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C\u0438 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432
    \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0430\u043D\u0430\u043B\u0438\u0437\u0435 XX \u0432\u0435\u043A\u0430. \u041E\u043D
    \u0442\u0430\u043A\u0436\u0435 \u0440\u0435\u0448\u0438\u043B \u043E\u0434\u043D\u0443
    \u0438\u0437 \u0444\u043E\u0440\u043C **19-\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430**, \u0440\u0430\u0431\u043E\u0442\u0430\u044F
    \u043D\u0430\u0434 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C\u0438
    \u0432 \u0447\u0430\u0441\u0442\u043D\u044B\u0445 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0445.
    \u0415\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u044B \u0432 \u044D\u0442\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043F\u0440\u0438\u0432\u0435\u043B\u0438
    \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E **\u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u041D\u044D\u0448\u0430 \u2014 \u041C\u043E\u0437\u0435\u0440\u0430** \u2014
    \u0432\u0430\u0436\u043D\u043E\u0433\u043E \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0430\u043D\u0430\u043B\u0438\u0437\u0435. *   **\u041A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u044F:**
    \u041D\u044D\u0448 \u0442\u0430\u043A\u0436\u0435 \u043E\u0431\u043B\u0430\u0434\u0430\u043B
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0435\u0439 \u0432 \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438.
    \u0412 1950-\u0445 \u0433\u043E\u0434\u0430\u0445 \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0438\u0434\u0435\u044E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439 \u0434\u043B\u044F
    \u0448\u0438\u0444\u0440\u043E\u0432\u0430\u043D\u0438\u044F, \u0447\u0442\u043E
    \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u043E \u0441\u0432\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F. \u042D\u0442\u0438 \u043F\u0438\u0441\u044C\u043C\u0430
    \u0431\u044B\u043B\u0438 \u0440\u0430\u0441\u0441\u0435\u043A\u0440\u0435\u0447\u0435\u043D\u044B
    \u0410\u0433\u0435\u043D\u0442\u0441\u0442\u0432\u043E\u043C \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438 \u0421\u0428\u0410
    \u0442\u043E\u043B\u044C\u043A\u043E \u0432 2011 \u0433\u043E\u0434\u0443.  ###
    \U0001F494 \u0422\u0440\u0430\u0433\u0435\u0434\u0438\u044F \u0438 \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u044F\u044F
    \u0431\u043E\u0440\u044C\u0431\u0430 \u0441 \u0431\u043E\u043B\u0435\u0437\u043D\u044C\u044E 
    \u041D\u0430 \u043F\u0438\u043A\u0435 \u043A\u0430\u0440\u044C\u0435\u0440\u044B,
    \u0432 \u043A\u043E\u043D\u0446\u0435 1950-\u0445 \u0433\u043E\u0434\u043E\u0432,
    \u0443 30-\u043B\u0435\u0442\u043D\u0435\u0433\u043E \u041D\u044D\u0448\u0430
    \u043D\u0430\u0447\u0430\u043B\u0438 \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u0442\u044C\u0441\u044F
    \u043F\u0435\u0440\u0432\u044B\u0435 \u0441\u0438\u043C\u043F\u0442\u043E\u043C\u044B
    \u043F\u0430\u0440\u0430\u043D\u043E\u0438\u0434\u0430\u043B\u044C\u043D\u043E\u0439
    \u0448\u0438\u0437\u043E\u0444\u0440\u0435\u043D\u0438\u0438. \u0412 1959 \u0433\u043E\u0434\u0443,
    \u043A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E \u0436\u0435\u043D\u0430 \u0410\u043B\u0438\u0441\u0438\u044F
    \u0431\u044B\u043B\u0430 \u0431\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u0430
    \u0438\u0445 \u043F\u0435\u0440\u0432\u044B\u043C \u0441\u044B\u043D\u043E\u043C,
    \u043E\u043D \u0431\u044B\u043B \u043D\u0430\u0441\u0438\u043B\u044C\u043D\u043E
    \u043F\u043E\u043C\u0435\u0449\u0435\u043D \u0432 \u043F\u0441\u0438\u0445\u0438\u0430\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u043B\u0438\u043D\u0438\u043A\u0443. \u0411\u043E\u043B\u0435\u0437\u043D\u044C
    \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u043B\u0430 \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u0438 \u043A\u0430\u0440\u044C\u0435\u0440\u0443.
    \u041D\u044D\u0448 \u0431\u044B\u043B \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u0443\u0439\u0442\u0438 \u0438\u0437 \u041C\u0430\u0441\u0441\u0430\u0447\u0443\u0441\u0435\u0442\u0441\u043A\u043E\u0433\u043E
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 (MIT). \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B
    \u0441\u0435\u0431\u044F \xAB\u043C\u0435\u0441\u0441\u0438\u0430\u043D\u0441\u043A\u043E\u0439
    \u0444\u0438\u0433\u0443\u0440\u043E\u0439\xBB, \u0438\u0441\u043A\u0430\u043B
    \u0441\u043A\u0440\u044B\u0442\u044B\u0435 \u043F\u043E\u0441\u043B\u0430\u043D\u0438\u044F
    \u0432 \u0447\u0438\u0441\u043B\u0430\u0445 \u0438 \u0433\u0430\u0437\u0435\u0442\u0430\u0445,
    \u0430 \u0432 1962 \u0433\u043E\u0434\u0443 \u0410\u043B\u0438\u0441\u0438\u044F,
    \u043D\u0435 \u0432\u044B\u0434\u0435\u0440\u0436\u0430\u0432, \u043F\u043E\u0434\u0430\u043B\u0430
    \u043D\u0430 \u0440\u0430\u0437\u0432\u043E\u0434.  \u0421 1966 \u043F\u043E
    1996 \u0433\u043E\u0434 \u041D\u044D\u0448 \u043D\u0435 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043D\u0438 \u043E\u0434\u043D\u043E\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B. \u041E\u043D \u0441\u0442\u0430\u043B \xAB\u043F\u0440\u0438\u0437\u0440\u0430\u043A\u043E\u043C\xBB
    \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430, \u0433\u0434\u0435
    \u0435\u043C\u0443 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u0438 \u0431\u0440\u043E\u0434\u0438\u0442\u044C
    \u043F\u043E \u043A\u0430\u043C\u043F\u0443\u0441\u0443, \u043F\u0438\u0441\u0430\u0442\u044C
    \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0435 \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u043D\u0430 \u0434\u043E\u0441\u043A\u0430\u0445, \u0430 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B
    \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0438\u0441\u044C \u043A \u043D\u0435\u043C\u0443
    \u0441 \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435\u043C \u0438 \u0441\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u0438\u0435\u043C. 
    ### \U0001F305 \u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435  \u0412 1970 \u0433\u043E\u0434\u0443
    \u0410\u043B\u0438\u0441\u0438\u044F, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0440\u0430\u0437\u0432\u043E\u0434, \u0432\u043D\u043E\u0432\u044C
    \u043F\u0440\u0438\u043D\u044F\u043B\u0430 \u0435\u0433\u043E \u0432 \u0441\u0432\u043E\u0439
    \u0434\u043E\u043C, \u0447\u0442\u043E \u0441\u043F\u0430\u0441\u043B\u043E \u0435\u0433\u043E
    \u043E\u0442 \u0431\u0435\u0437\u0434\u043E\u043C\u043D\u043E\u0441\u0442\u0438.
    \u0412 1980-\u0445 \u0433\u043E\u0434\u0430\u0445, \u0432\u043E\u043F\u0440\u0435\u043A\u0438
    \u043F\u0440\u043E\u0433\u043D\u043E\u0437\u0430\u043C \u0432\u0440\u0430\u0447\u0435\u0439,
    \u0431\u043E\u043B\u0435\u0437\u043D\u044C \u041D\u044D\u0448\u0430 \u043D\u0430\u0447\u0430\u043B\u0430
    \u043E\u0442\u0441\u0442\u0443\u043F\u0430\u0442\u044C. \u041E\u043D \u043D\u0430\u0443\u0447\u0438\u043B\u0441\u044F
    \u0438\u0433\u043D\u043E\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C \u0441\u0432\u043E\u0438
    \u0431\u0440\u0435\u0434\u043E\u0432\u044B\u0435 \u043C\u044B\u0441\u043B\u0438
    \u0438 \u0441\u043C\u043E\u0433 \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
    \u043A \u0437\u0430\u043D\u044F\u0442\u0438\u044F\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439. 
    \u0412 1994 \u0433\u043E\u0434\u0443, \u0441\u043F\u0443\u0441\u0442\u044F 45
    \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435 \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u0441\u0432\u043E\u0435\u0439 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438,
    \u0414\u0436\u043E\u043D \u041D\u044D\u0448 \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    **\u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    \u043F\u043E \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0435** (\u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0414\u0436. \u0425\u0430\u0440\u0441\u0430\u043D\u044C\u0438 \u0438
    \u0420. \u0417\u0435\u043B\u044C\u0442\u0435\u043D\u043E\u043C) \xAB\u0437\u0430
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u044F
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u043D\u0435\u043A\u043E\u043E\u043F\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0433\u0440\xBB. \u041E\u043D \u0438 \u0410\u043B\u0438\u0441\u0438\u044F
    \u0432\u043D\u043E\u0432\u044C \u043F\u043E\u0436\u0435\u043D\u0438\u043B\u0438\u0441\u044C
    \u0432 2001 \u0433\u043E\u0434\u0443.  \u041A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u0435\u0439
    \u0435\u0433\u043E \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u0441\u0442\u0430\u043B\u043E \u043F\u0440\u0438\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0435
    \u0432 2015 \u0433\u043E\u0434\u0443 **\u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438** \u2014 \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u0432\u044B\u0441\u0448\u0438\u0445 \u043D\u0430\u0433\u0440\u0430\u0434
    \u0432 \u043C\u0438\u0440\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u2014 \u0437\u0430 \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. \u0422\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438,
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0434\u043D\u0435\u0439
    \u0441\u043F\u0443\u0441\u0442\u044F, \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044F\u0441\u044C
    \u0438\u0437 \u041E\u0441\u043B\u043E, \u0433\u0434\u0435 \u0435\u043C\u0443
    \u0432\u0440\u0443\u0447\u0438\u043B\u0438 \u043F\u0440\u0435\u043C\u0438\u044E,
    86-\u043B\u0435\u0442\u043D\u0438\u0439 \u0414\u0436\u043E\u043D \u041D\u044D\u0448
    \u0438 \u0435\u0433\u043E 82-\u043B\u0435\u0442\u043D\u044F\u044F \u0436\u0435\u043D\u0430
    \u0410\u043B\u0438\u0441\u0438\u044F \u043F\u043E\u0433\u0438\u0431\u043B\u0438
    \u0432 \u0430\u0432\u0430\u0440\u0438\u0438 \u0442\u0430\u043A\u0441\u0438 \u0432
    \u041D\u044C\u044E-\u0414\u0436\u0435\u0440\u0441\u0438.  ### \U0001F3AC \u0414\u0436\u043E\u043D
    \u041D\u044D\u0448 \u0432 \u043C\u0430\u0441\u0441\u043E\u0432\u043E\u0439 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u0435 
    \u0416\u0438\u0437\u043D\u044C \u041D\u044D\u0448\u0430 \u0441\u0442\u0430\u043B\u0430
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430 \u0448\u0438\u0440\u043E\u043A\u043E\u0439
    \u043F\u0443\u0431\u043B\u0438\u043A\u0435 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0431\u0435\u0441\u0442\u0441\u0435\u043B\u043B\u0435\u0440\u0443 \u0421\u0438\u043B\u044C\u0432\u0438\u0438
    \u041D\u0430\u0437\u0430\u0440 \xAB\u0418\u0433\u0440\u044B \u0440\u0430\u0437\u0443\u043C\u0430\xBB
    (1998) \u0438 \u043E\u0434\u043D\u043E\u0438\u043C\u0435\u043D\u043D\u043E\u043C\u0443
    \u0444\u0438\u043B\u044C\u043C\u0443 \u0420\u043E\u043D\u0430 \u0425\u043E\u0432\u0430\u0440\u0434\u0430
    (2001), \u0433\u0434\u0435 \u0435\u0433\u043E \u0440\u043E\u043B\u044C \u0441\u044B\u0433\u0440\u0430\u043B
    \u0420\u0430\u0441\u0441\u0435\u043B \u041A\u0440\u043E\u0443. \u0412\u0430\u0436\u043D\u043E
    \u043E\u0442\u043C\u0435\u0442\u0438\u0442\u044C, \u0447\u0442\u043E \u0444\u0438\u043B\u044C\u043C
    \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u0445\u0443\u0434\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0432\u044B\u043C\u044B\u0441\u0435\u043B (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435 \u0433\u0430\u043B\u043B\u044E\u0446\u0438\u043D\u0430\u0446\u0438\u0438,
    \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u0430\u043A \u0443
    \u041D\u044D\u0448\u0430 \u0431\u044B\u043B\u0438 \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C
    \u0441\u043B\u0443\u0445\u043E\u0432\u044B\u0435 \u0433\u043E\u043B\u043E\u0441\u0430),
    \u043D\u043E \u0432\u0435\u0440\u043D\u043E \u043F\u0435\u0440\u0435\u0434\u0430\u0435\u0442
    \u0441\u0443\u0442\u044C \u0435\u0433\u043E \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0431\u043E\u0440\u044C\u0431\u044B \u0438 \u0442\u0440\u0438\u0443\u043C\u0444\u0430."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0414\u0436\u043E\u043D\u0430
    \u041D\u044D\u0448\u0430, \u0434\u0430\u0436\u0435 \u043F\u043E\u043C\u0438\u043C\u043E
    \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u0432,
    \u043F\u043E\u043B\u043D\u0430 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445,
    \u0430 \u043F\u043E\u0440\u043E\u0439 \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439. \u041E\u043D\u0438 \u0440\u0438\u0441\u0443\u044E\u0442
    \u043E\u0431\u0440\u0430\u0437 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u0447\u0435\u0439 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u0443\u043C \u0432\u0441\u0435\u0433\u0434\u0430 \u0448\u0435\u043B \u0441\u0432\u043E\u0438\u043C,
    \u043D\u0435\u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0443\u0435\u043C\u044B\u043C
    \u043F\u0443\u0442\u0435\u043C, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0432 \u043F\u0435\u0440\u0438\u043E\u0434\u044B \u0435\u0433\u043E \u0431\u043E\u043B\u0435\u0437\u043D\u0438.
    \u0412\u043E\u0442 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432.  ### \U0001F9E0 \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0438 \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0432 \u044E\u043D\u043E\u0441\u0442\u0438  \u0415\u0433\u043E \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B\u0430\u0441\u044C \u0441 \u0440\u0430\u043D\u043D\u0438\u0445
    \u043B\u0435\u0442.  *   **\u0423\u0447\u0438\u0442\u0435\u043B\u044C\u0441\u043A\u0430\u044F
    \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u044F:** \u041F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0434\u0435\u0442\u0430\u043B\u044C \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u2014 \u044D\u0442\u043E \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043F\u0438\u0441\u044C\u043C\u043E \u0434\u043B\u044F \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
    \u0432 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u0443\u0440\u0443 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0430
    \u043E\u0442 \u0435\u0433\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0438\u0437 \u0422\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 \u041A\u0430\u0440\u043D\u0435\u0433\u0438
    \u0420.\u0414\u0436. \u0414\u0430\u0444\u0444\u0438\u043D\u0430. \u0412 \u043D\u0435\u043C
    \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E \u043E\u0434\u043D\u043E
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435: **\xAB\u042D\u0442\u043E\u0442
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u2014 \u0433\u0435\u043D\u0438\u0439\xBB**.
    *   **\"\u0418\u0433\u0440\u044B \u0440\u0430\u0437\u0443\u043C\u0430\" \u0432
    \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438:** \u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u0441\u0446\u0435\u043D\u0430 \u0432 \u0444\u0438\u043B\u044C\u043C\u0435, \u0433\u0434\u0435
    \u041D\u044D\u0448 \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0435\u0442 \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435
    \u0432 \u0431\u0430\u0440\u0435, \u043D\u0430 \u0441\u0430\u043C\u043E\u043C
    \u0434\u0435\u043B\u0435 \u0432\u044B\u0434\u0443\u043C\u0430\u043D\u0430. \u0412
    \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438 \u043E\u043D \u043F\u0440\u0438\u0448\u0435\u043B
    \u043A \u0441\u0432\u043E\u0435\u0439 \u0442\u0435\u043E\u0440\u0438\u0438, \u0438\u0437\u0443\u0447\u0430\u044F
    \u0431\u043E\u043B\u0435\u0435 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438, \u0430 \u043D\u0435 \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u044F
    \u0437\u0430 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044F\u043C\u0438
    \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432. *   **\u0418\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u044C
    \u0438\u0433\u0440\u044B:** \u0412 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435
    \u041D\u044D\u0448 \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u043E\u0447\u0435\u043D\u044C
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u0443\u044E \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043D\u0443\u044E \u0438\u0433\u0440\u0443
    \u043D\u0430 \u0434\u043E\u0441\u043A\u0435 \u0441 \u0448\u0435\u0441\u0442\u0438\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C\u0438
    \u043A\u043B\u0435\u0442\u043A\u0430\u043C\u0438. \u041E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430
    \u0445\u0438\u0442\u043E\u043C \u0432 \u0441\u0442\u0443\u0434\u0435\u043D\u0447\u0435\u0441\u043A\u043E\u043C
    \u043E\u0431\u0449\u0435\u0436\u0438\u0442\u0438\u0438, \u0438 \u0432\u0441\u0435
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438 \u0435\u0451 \u043F\u0440\u043E\u0441\u0442\u043E
    \"\u041D\u044D\u0448\" \u0438\u043B\u0438 \"\u0414\u0436\u043E\u043D\". \u041F\u043E\u0437\u0436\u0435
    \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u044F Parker Brothers \u0432\u044B\u043F\u0443\u0441\u0442\u0438\u043B\u0430
    \u0435\u0451 \u043F\u043E\u0434 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435\u043C
    **\xAB\u0413\u0435\u043A\u0441\xBB (Hex)**. *   **\u0420\u0430\u0437\u0433\u043E\u0432\u043E\u0440
    \u0441 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C:** \u0411\u0443\u0434\u0443\u0447\u0438
    \u0435\u0449\u0435 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u043E\u043C,
    \u041D\u044D\u0448, \u043F\u043E\u043B\u043D\u044B\u0439 \u0434\u0435\u0440\u0437\u043E\u0441\u0442\u0438,
    \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B \u0430\u0443\u0434\u0438\u0435\u043D\u0446\u0438\u0438
    \u0443 \u0410\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430
    \u0432 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. \u041E\u043D
    \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u0435\u043C\u0443 \u0441\u0432\u043E\u0438
    \u0438\u0434\u0435\u0438 \u043F\u043E \u0444\u0438\u0437\u0438\u043A\u0435, \u043D\u043E
    \u043F\u043E\u0441\u043B\u0435 \u0447\u0430\u0441\u0430 \u0431\u0435\u0441\u0435\u0434\u044B
    \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u0443\u0447\u0435\u043D\u044B\u0439
    \u043F\u043E\u0441\u043E\u0432\u0435\u0442\u043E\u0432\u0430\u043B \u0435\u043C\u0443
    \u043B\u0443\u0447\u0448\u0435 \u0432\u044B\u0443\u0447\u0438\u0442\u044C \u0444\u0438\u0437\u0438\u043A\u0443. 
    ### \U0001F3AD \"\u041F\u0440\u0438\u0437\u0440\u0430\u043A\" \u0438 \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0441\u0442\u0438
    \u0431\u043E\u043B\u0435\u0437\u043D\u0438  \u041F\u0435\u0440\u0438\u043E\u0434\u044B
    \u0435\u0433\u043E \u0442\u044F\u0436\u0435\u043B\u043E\u0439 \u0431\u043E\u043B\u0435\u0437\u043D\u0438,
    \u0434\u043B\u0438\u0432\u0448\u0438\u0435\u0441\u044F \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F\u043C\u0438,
    \u043E\u043A\u0443\u0442\u0430\u043D\u044B \u043F\u043E\u0447\u0442\u0438 \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0438 \u0442\u0440\u0430\u0433\u0438\u043A\u043E\u043C\u0438\u0447\u043D\u044B\u043C\u0438
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F\u043C\u0438.  *   **\u0418\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440
    \u0410\u043D\u0442\u0430\u0440\u043A\u0442\u0438\u0434\u044B:** \u041A\u043E\u0433\u0434\u0430
    \u041D\u044D\u0448\u0430 \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B\u0438
    \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 \u0427\u0438\u043A\u0430\u0433\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u043E\u043D
    \u043E\u0442\u043A\u043B\u043E\u043D\u0438\u043B \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435,
    \u0442\u0430\u043A \u043A\u0430\u043A \u0431\u044B\u043B \u0443\u0432\u0435\u0440\u0435\u043D,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0432\u043E\u0442-\u0432\u043E\u0442 \u043A\u043E\u0440\u043E\u043D\u0443\u044E\u0442
    **\u0418\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u043E\u043C \u0410\u043D\u0442\u0430\u0440\u043A\u0442\u0438\u0434\u044B**.
    *   **\u0412\u0435\u0447\u0435\u0440\u0438\u043D\u043A\u0430 \u0432 \u043F\u043E\u0434\u0433\u0443\u0437\u043D\u0438\u043A\u0435:**
    \u041D\u0430 \u043D\u043E\u0432\u043E\u0433\u043E\u0434\u043D\u0435\u043C \u0431\u0430\u043B\u0443
    \u0432 1958 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u0432 \u043E\u0434\u043D\u043E\u043C \u043F\u043E\u0434\u0433\u0443\u0437\u043D\u0438\u043A\u0435
    \u0438 \u043B\u0435\u043D\u0442\u0435, \u0441 \u0434\u0435\u0442\u0441\u043A\u043E\u0439
    \u0431\u0443\u0442\u044B\u043B\u043E\u0447\u043A\u043E\u0439 \u0431\u0443\u0440\u0431\u043E\u043D\u0430
    \u0441 \u043C\u043E\u043B\u043E\u043A\u043E\u043C, \u0441\u0438\u0434\u044F \u043D\u0430
    \u043A\u043E\u043B\u0435\u043D\u044F\u0445 \u0443 \u0441\u0432\u043E\u0435\u0439
    \u0436\u0435\u043D\u044B \u0410\u043B\u0438\u0441\u0438\u0438. *   **\u0421\u0442\u0440\u0430\u043D\u043D\u044B\u0435
    \u043D\u0430\u0434\u043F\u0438\u0441\u0438:** \u0421\u0442\u0443\u0434\u0435\u043D\u0442\u044B
    \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0430 \u043F\u0440\u043E\u0437\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E **\xAB\u041F\u0440\u0438\u0437\u0440\u0430\u043A\u043E\u043C
    \u0424\u0430\u0439\u043D-\u0445\u043E\u043B\u043B\u0430\xBB**. \u041E\u043D \u0431\u0440\u043E\u0434\u0438\u043B
    \u043F\u043E \u0437\u0434\u0430\u043D\u0438\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0430, \u0447\u0430\u0441\u0442\u043E
    \u0431\u043E\u0441\u0438\u043A\u043E\u043C \u0438 \u0432 \u043D\u0435\u0441\u043E\u0447\u0435\u0442\u0430\u044E\u0449\u0435\u0439\u0441\u044F
    \u043E\u0434\u0435\u0436\u0434\u0435, \u0438 \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B
    \u043D\u0430 \u0434\u043E\u0441\u043A\u0430\u0445 \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u044B\u0435
    \u043D\u0430\u0434\u043F\u0438\u0441\u0438. \u041E\u0434\u043D\u0430 \u0438\u0437
    \u043D\u0438\u0445 \u0433\u043B\u0430\u0441\u0438\u043B\u0430: **\xAB\u0411\u0430\u0440-\u043C\u0438\u0446\u0432\u0430
    \u041C\u0430\u043E \u0426\u0437\u044D\u0434\u0443\u043D\u0430 \u0431\u044B\u043B\u0430
    \u043D\u0430 13 \u043B\u0435\u0442, 13 \u043C\u0435\u0441\u044F\u0446\u0435\u0432
    \u0438 13 \u0434\u043D\u0435\u0439 \u043F\u043E\u0437\u0436\u0435, \u0447\u0435\u043C
    \u043E\u0431\u0440\u0435\u0437\u0430\u043D\u0438\u0435 \u0411\u0440\u0435\u0436\u043D\u0435\u0432\u0430\xBB**.
    *   **\u041E\u0431\u043B\u043E\u0436\u043A\u0430 Life:** \u041D\u0430 \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u043B\u0435\u043A\u0446\u0438\u0439 \u043E\u043D \u043E\u0431\u044A\u044F\u0432\u0438\u043B
    \u0441\u0432\u043E\u0438\u043C \u0438\u0437\u0443\u043C\u043B\u0435\u043D\u043D\u044B\u043C
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C, \u0447\u0442\u043E \u043E\u043D
    \u043D\u0430 \u043E\u0431\u043B\u043E\u0436\u043A\u0435 \u0436\u0443\u0440\u043D\u0430\u043B\u0430
    Life \u0432 \u043E\u0431\u0440\u0430\u0437\u0435 \u041F\u0430\u043F\u044B \u0420\u0438\u043C\u0441\u043A\u043E\u0433\u043E
    \u0418\u043E\u0430\u043D\u043D\u0430 XXIII.  ### \U0001F4A1 \u041F\u043E\u0437\u0434\u043D\u0435\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438 \u043F\u043E\u0432\u0441\u0435\u0434\u043D\u0435\u0432\u043D\u044B\u0435
    \u043A\u0443\u0440\u044C\u0435\u0437\u044B  \u0414\u0430\u0436\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F \u043A \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u041D\u044D\u0448 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0439
    \u0444\u0438\u0433\u0443\u0440\u043E\u0439.  *   **\u0421\u0430\u043C\u0430\u044F
    \u043A\u043E\u0440\u043E\u0442\u043A\u0430\u044F \u043D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430:** \u0415\u0433\u043E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F,
    \u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E,
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0430 \u0432\u0441\u0435\u0433\u043E
    27 \u0441\u0442\u0440\u0430\u043D\u0438\u0446 \u0441 **\xAB\u043E\u0447\u0435\u043D\u044C
    \u0449\u0435\u0434\u0440\u044B\u043C\xBB** \u0434\u0432\u043E\u0439\u043D\u044B\u043C
    \u043C\u0435\u0436\u0441\u0442\u0440\u043E\u0447\u043D\u044B\u043C \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u043E\u043C,
    \u043A\u0430\u043A \u043F\u043E\u0448\u0443\u0442\u0438\u043B \u0435\u0433\u043E
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430. \u0410 \u043F\u0435\u0440\u0432\u0430\u044F
    \u0441\u0442\u0430\u0442\u044C\u044F, \u0438\u0437\u043B\u0430\u0433\u0430\u044E\u0449\u0430\u044F
    \"\u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435 \u041D\u044D\u0448\u0430\",
    \u0431\u044B\u043B\u0430 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430
    \u0432 1950 \u0433\u043E\u0434\u0443 \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0430
    \u0432\u0441\u0435\u0433\u043E \u043E\u0434\u043D\u0443 \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0443
    (317 \u0441\u043B\u043E\u0432). *   **\u041C\u044B\u0441\u043B\u0438 \u043E \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438:** \u041A\u043E\u0433\u0434\u0430 \u041D\u044D\u0448
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E, \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u043E\u0439
    \u0440\u0435\u0430\u043A\u0446\u0438\u0435\u0439 \u043D\u0430 \u0434\u0435\u043D\u0435\u0436\u043D\u0443\u044E
    \u0447\u0430\u0441\u0442\u044C (\u0435\u0433\u043E \u0434\u043E\u043B\u044F \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430
    \u043E\u043A\u043E\u043B\u043E 310 000 \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432)
    \u0431\u044B\u043B\u0430 \u0441\u0443\u0445\u0430\u044F \u0448\u0443\u0442\u043A\u0430
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u0441\u0443\u043C\u043C\u0430
    \u043D\u0435 \u0442\u0430\u043A\u0430\u044F \u0443\u0436 \u0438 \u0431\u043E\u043B\u044C\u0448\u0430\u044F.
    *   **\"\u0418\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u0435 \u0434\u0435\u043D\u044C\u0433\u0438\":**
    \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u043E\u043D \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E
    \u0443\u0432\u043B\u0435\u043A\u0441\u044F \u0438\u0434\u0435\u0435\u0439 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F
    \u0438\u043D\u0434\u0435\u043A\u0441\u0438\u0440\u0443\u0435\u043C\u043E\u0439
    **\xAB\u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E\u0439 \u0432\u0430\u043B\u044E\u0442\u044B\xBB**,
    \u0441\u0442\u043E\u0438\u043C\u043E\u0441\u0442\u044C \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0431\u044B\u043B\u0430 \u0431\u044B \u043D\u0435\u0438\u0437\u043C\u0435\u043D\u043D\u0430,
    \u043A\u0430\u043A \u043C\u0435\u0442\u0440 \u0438\u043B\u0438 \u043A\u0438\u043B\u043E\u0433\u0440\u0430\u043C\u043C.
    \u042D\u0442\u0430 \u0438\u0434\u0435\u044F \u0431\u044B\u043B\u0430 \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u043E\u0439,
    \u043D\u043E \u043D\u0438\u043A\u0442\u043E \u0443\u0436\u0435 \u043D\u0435 \u0441\u043F\u0435\u0448\u0438\u043B
    \u043D\u0430\u0437\u044B\u0432\u0430\u0442\u044C \u0435\u0451 \u0431\u0435\u0437\u0443\u043C\u043D\u043E\u0439. 
    \u042D\u0442\u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u044B \u2014 \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438, \u0430 \u043F\u043E\u043F\u044B\u0442\u043A\u0430
    \u0437\u0430\u0433\u043B\u044F\u043D\u0443\u0442\u044C \u0432 \u0441\u043E\u0437\u043D\u0430\u043D\u0438\u0435
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B \u043C\u0438\u0440
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u0438\u043D\u0430\u0447\u0435,
    \u0447\u0435\u043C \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
    \u0438\u0437 \u043D\u0430\u0441. \u0415\u0433\u043E \u0441\u043B\u0443\u0447\u0430\u0439
    \u2014 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0435 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0431\u0435\u0437\u0443\u043C\u0438\u0435 \u043C\u043E\u0433\u0443\u0442
    \u0438\u0434\u0442\u0438 \u0440\u0443\u043A\u0430 \u043E\u0431 \u0440\u0443\u043A\u0443,
    \u0438 \u043A\u0430\u043A \u0441\u0438\u043B\u0430 \u0432\u043E\u043B\u0438 \u0438
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0430 \u0431\u043B\u0438\u0437\u043A\u0438\u0445
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0442 \u043E\u0434\u0435\u0440\u0436\u0430\u0442\u044C
    \u043F\u043E\u0431\u0435\u0434\u0443 \u043D\u0430\u0434, \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C
    \u0431\u044B, \u043D\u0435\u043F\u0440\u0435\u043E\u0434\u043E\u043B\u0438\u043C\u044B\u043C\u0438
    \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C\u0438."
