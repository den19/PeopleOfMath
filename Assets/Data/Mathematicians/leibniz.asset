  achievementsRu: "\u0413\u043E\u0442\u0444\u0440\u0438\u0434 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439 \u0441\u043B\u0435\u0434 \u0432
    \u0441\u0430\u043C\u044B\u0445 \u0440\u0430\u0437\u043D\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445
    \u0437\u043D\u0430\u043D\u0438\u044F. \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u043D\u0435 \u0441\u0432\u043E\u0434\u0438\u0442\u0441\u044F \u043A \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u043C
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F\u043C \u2014 \u044D\u0442\u043E
    \u0431\u044B\u043B\u0430 \u043F\u043E\u043F\u044B\u0442\u043A\u0430 \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u0435\u0434\u0438\u043D\u0443\u044E, \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043E\u0445\u0432\u0430\u0442\u0438\u043B\u0430
    \u0431\u044B \u0432\u0441\u0435 \u0430\u0441\u043F\u0435\u043A\u0442\u044B \u043C\u0438\u0440\u043E\u0437\u0434\u0430\u043D\u0438\u044F.
    \u0412\u043E\u0442 \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u044B\u0439 \u043E\u0431\u0437\u043E\u0440
    \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439
    \u0438 \u0442\u0440\u0443\u0434\u043E\u0432 \u043F\u043E \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u043C
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F\u043C.  ###
    \u2797 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430: \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u044F\u0437\u044B\u043A\u0430, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043D\u0430\u0443\u043A\u0430  \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u2014 \u044D\u0442\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0441\u0442\u043E\u0438\u0442
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F \u043D\u0430\u0443\u043A\u0430.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0437\u0434\u0435\u0441\u044C:  *   **\u0414\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0435
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435:** \u042D\u0442\u043E
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0435\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u043E\u043A\u043E\u043B\u043E 1675
    \u0433\u043E\u0434\u0430, **\u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E
    \u043E\u0442 \u0418\u0441\u0430\u0430\u043A\u0430 \u041D\u044C\u044E\u0442\u043E\u043D\u0430**.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0438\u043C\u0435\u043D\u043D\u043E **\u043D\u043E\u0442\u0430\u0446\u0438\u044F
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430** (\u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B `\u222B` \u0438 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u0430\u044F
    `dy/dx`) \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0443\u0434\u043E\u0431\u043D\u043E\u0439, \u0447\u0442\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0438 \u043F\u043E \u0441\u0435\u0439 \u0434\u0435\u043D\u044C. \u0421\u0432\u043E\u0438
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0432 1684 \u0433\u043E\u0434\u0443, \u043D\u0430 \u0442\u0440\u0438 \u0433\u043E\u0434\u0430
    \u0440\u0430\u043D\u044C\u0448\u0435 \u041D\u044C\u044E\u0442\u043E\u043D\u0430,
    \u0447\u0442\u043E \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0435\u043C\u0443
    \u0441\u043F\u043E\u0440\u0443 \u043E \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0435
    \u043C\u0435\u0436\u0434\u0443 \u0443\u0447\u0435\u043D\u044B\u043C\u0438 \u043A\u043E\u043D\u0442\u0438\u043D\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0415\u0432\u0440\u043E\u043F\u044B \u0438 \u0410\u043D\u0433\u043B\u0438\u0438.
    *   **\u0414\u0432\u043E\u0438\u0447\u043D\u0430\u044F \u0441\u0438\u0441\u0442\u0435\u043C\u0430
    \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F:** \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u044D\u0442\u0443 \u0441\u0438\u0441\u0442\u0435\u043C\u0443, \u043D\u043E \u0438
    \u0432\u0438\u0434\u0435\u043B \u0432 \u043D\u0435\u0439 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0441\u043C\u044B\u0441\u043B,
    \u0430\u0441\u0441\u043E\u0446\u0438\u0438\u0440\u0443\u044F `1` \u0441 \u0411\u043E\u0433\u043E\u043C,
    \u0430 `0` \u0441 \u043F\u0443\u0441\u0442\u043E\u0442\u043E\u0439. \u042D\u0442\u043E\u0442
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F, \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0439
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u0432, \u0441\u0442\u0430\u043B
    \u0435\u0449\u0435 \u043E\u0434\u043D\u0438\u043C \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u043C
    \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u0440\u0435\u0434\u0432\u0438\u0434\u0435\u043D\u0438\u044F. \u041E\u043D
    \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B
    \u0435\u0451 \u0434\u043B\u044F \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u044F
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u043E\u0432 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441\u0432\u043E\u0435\u0433\u043E \u043A\u0430\u043B\u044C\u043A\u0443\u043B\u044F\u0442\u043E\u0440\u0430.
    *   **\u0410\u0440\u0438\u0444\u043C\u043E\u043C\u0435\u0442\u0440 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430:**
    \u0412 1673 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0441\u0447\u0435\u0442\u043D\u0443\u044E
    \u043C\u0430\u0448\u0438\u043D\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C
    \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u043C. \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u043A\u0430\u043B\u044C\u043A\u0443\u043B\u044F\u0442\u043E\u0440\u0430
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F, \u043C\u0430\u0448\u0438\u043D\u0430
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430 \u0443\u043C\u0435\u043B\u0430
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0442\u044C
    \u0438 \u0432\u044B\u0447\u0438\u0442\u0430\u0442\u044C, \u043D\u043E \u0438
    **\u0443\u043C\u043D\u043E\u0436\u0430\u0442\u044C, \u0434\u0435\u043B\u0438\u0442\u044C
    \u0438 \u0438\u0437\u0432\u043B\u0435\u043A\u0430\u0442\u044C \u043A\u043E\u0440\u043D\u0438**
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u043D\u043E\u043C\u0443
    \u0438\u043C \u0441\u0442\u0443\u043F\u0435\u043D\u0447\u0430\u0442\u043E\u043C\u0443
    \u0432\u0430\u043B\u0438\u043A\u0443 (\u043A\u043E\u043B\u0435\u0441\u043E \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430).
    \u042D\u0442\u043E \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435
    \u043E\u043D \u043B\u0438\u0447\u043D\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B
    \u0432 \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u043C \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u043C
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435.  ### \u269B\uFE0F \u0424\u0438\u0437\u0438\u043A\u0430:
    \u041E\u0442 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438 \u043A \u044D\u043D\u0435\u0440\u0433\u0438\u0438 
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u043D\u043E\u0432\u043E\u0439 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438, \u0431\u0440\u043E\u0441\u0438\u0432 \u0432\u044B\u0437\u043E\u0432
    \u0433\u043E\u0441\u043F\u043E\u0434\u0441\u0442\u0432\u043E\u0432\u0430\u0432\u0448\u0435\u0439
    \u0442\u043E\u0433\u0434\u0430 \u043A\u0430\u0440\u0442\u0435\u0437\u0438\u0430\u043D\u0441\u043A\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435:  *   **\u0414\u0438\u043D\u0430\u0301\u043C\u0438\u043A\u0430
    \u0438 \"\u0436\u0438\u0432\u0430\u044F \u0441\u0438\u043B\u0430\":** \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u043E\u0441\u043D\u043E\u0432\u0430\u043B \u043D\u043E\u0432\u0443\u044E \u043D\u0430\u0443\u043A\u0443
    \u2014 **\u0434\u0438\u043D\u0430\u0301\u043C\u0438\u043A\u0443**, \u043D\u0430\u0443\u043A\u0443
    \u043E \u0441\u0438\u043B\u0435, \u0438 \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    **\"\u0436\u0438\u0432\u043E\u0439 \u0441\u0438\u043B\u044B\"** (vis viva), \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0432
    \u0435\u0435 \u043A\u0430\u043A \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u043C\u0430\u0441\u0441\u044B \u043D\u0430 \u043A\u0432\u0430\u0434\u0440\u0430\u0442
    \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438 (`mv\xB2`). \u041E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u0430 \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u0430
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0439
    \u043C\u0435\u0440\u043E\u0439 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F,
    \u0430 \u043D\u0435 \"\u043C\u0435\u0440\u0442\u0432\u0430\u044F \u0441\u0438\u043B\u0430\"
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430 (`mv`), \u0438 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    **\u0437\u0430\u043A\u043E\u043D \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \"\u0436\u0438\u0432\u044B\u0445 \u0441\u0438\u043B\"**. \u042D\u0442\u043E \u0431\u044B\u043B\u0430
    \u043E\u0434\u043D\u0430 \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043E\u043A
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \u044D\u043D\u0435\u0440\u0433\u0438\u0438, \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043A\u0438\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u044D\u043D\u0435\u0440\u0433\u0438\u0438. *   **\u041F\u0440\u0438\u043D\u0446\u0438\u043F
    \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0433\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F:**
    \u0418\u0441\u0445\u043E\u0434\u044F \u0438\u0437 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0433\u043E \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u0430 \u043C\u0438\u0440\u0430,
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E\u0442 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0439
    \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439 \u043F\u0440\u0438\u043D\u0446\u0438\u043F,
    \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u043F\u0440\u0438\u0440\u043E\u0434\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442
    \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0447\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C.  ### \U0001F4A1 \u041B\u043E\u0433\u0438\u043A\u0430
    \u0438 \u043C\u0435\u0442\u043E\u0434\u043E\u043B\u043E\u0433\u0438\u044F: \u041C\u0435\u0447\u0442\u0430
    \u043E \u0432\u0441\u0435\u043E\u0431\u0449\u0435\u0439 \u043D\u0430\u0443\u043A\u0435 
    \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u043D\u0435\u0440\u0430\u0437\u0440\u044B\u0432\u043D\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u0430
    \u0441 \u0435\u0433\u043E \u0441\u0442\u0440\u0435\u043C\u043B\u0435\u043D\u0438\u0435\u043C
    \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u044B\u0439
    \u043C\u0435\u0442\u043E\u0434 \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u044F: 
    *   **\"\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u0430\u044F
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0430\"
    \u0438 \"\u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435 \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0439\":**
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u043C\u0435\u0447\u0442\u043E\u0439
    \u0431\u044B\u043B\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B
    \u0431\u044B \u0441\u0432\u0435\u0441\u0442\u0438 \u043B\u044E\u0431\u043E\u0435
    \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0435 \u043A \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F\u043C.
    \u041E\u043D \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u043B
    \u0438\u0434\u0435\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438, \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044F,
    \u0447\u0442\u043E \u0432 \u0441\u043F\u043E\u0440\u0435 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430\u043C
    \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E \u0431\u044B\u043B\u043E
    \u0431\u044B \"\u0432\u0437\u044F\u0442\u044C \u0432 \u0440\u0443\u043A\u0438
    \u043F\u0435\u0440\u044C\u044F, \u0441\u0435\u0441\u0442\u044C \u0437\u0430 \u0441\u0432\u043E\u0438
    \u0441\u0447\u0435\u0442\u043D\u044B\u0435 \u0434\u043E\u0441\u043A\u0438 \u0438
    \u0441\u043A\u0430\u0437\u0430\u0442\u044C \u0434\u0440\u0443\u0433 \u0434\u0440\u0443\u0433\u0443:
    \u0434\u0430\u0432\u0430\u0439\u0442\u0435 \u043F\u043E\u0441\u0447\u0438\u0442\u0430\u0435\u043C!\".
    \u0412 \u0440\u0430\u043D\u043D\u0435\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    **\"\u041E\u0431 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435 \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0438\"**
    (1666) \u043E\u043D \u0443\u0436\u0435 \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u044D\u0442\u043E\u0439 \u0438\u0434\u0435\u0438,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u043E\u0439 \u043D\u0430 \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0446\u0438\u0438
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432.
    *   **\u0414\u0432\u0430 \u0442\u0438\u043F\u0430 \u0438\u0441\u0442\u0438\u043D
    \u0438 \u0437\u0430\u043A\u043E\u043D\u044B \u043B\u043E\u0433\u0438\u043A\u0438:**
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0440\u0430\u0437\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u043B
    **\"\u0438\u0441\u0442\u0438\u043D\u044B \u0440\u0430\u0437\u0443\u043C\u0430\"**
    (\u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u044B\u0435 \u0438 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0435 \u043D\u0430 \u0437\u0430\u043A\u043E\u043D\u0435
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u044F) \u0438
    **\"\u0438\u0441\u0442\u0438\u043D\u044B \u0444\u0430\u043A\u0442\u0430\"** (\u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0435,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0435 \u043D\u0430 \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u043C
    \u0438\u043C **\u0437\u0430\u043A\u043E\u043D\u0435 \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0433\u043E
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F**). \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u043E\u0442\u0441\u0442\u0430\u0438\u0432\u0430\u043B \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0437\u043C
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u044F,
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044F, \u0447\u0442\u043E \u0434\u0443\u0448\u0430
    \u2014 \u043D\u0435 \"\u0447\u0438\u0441\u0442\u0430\u044F \u0434\u043E\u0441\u043A\u0430\"
    (tabula rasa), \u0438 \u0434\u043E\u0431\u0430\u0432\u0438\u043B \u043A \u0442\u0435\u0437\u0438\u0441\u0443
    \u0441\u0435\u043D\u0441\u0443\u0430\u043B\u0438\u0441\u0442\u043E\u0432 \"\u041D\u0435\u0442
    \u043D\u0438\u0447\u0435\u0433\u043E \u0432 \u0440\u0430\u0437\u0443\u043C\u0435,
    \u0447\u0435\u0433\u043E \u043F\u0440\u0435\u0436\u0434\u0435 \u043D\u0435 \u0431\u044B\u043B\u043E
    \u0431\u044B \u0432 \u0447\u0443\u0432\u0441\u0442\u0432\u0430\u0445\" \u0441\u0432\u043E\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u043E\u0433\u043E\u0432\u043E\u0440\u043A\u0443:
    **\"...\u043A\u0440\u043E\u043C\u0435 \u0441\u0430\u043C\u043E\u0433\u043E \u0440\u0430\u0437\u0443\u043C\u0430\"**. 
    ### \U0001F9E0 \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F (\u041C\u0435\u0442\u0430\u0444\u0438\u0437\u0438\u043A\u0430):
    \u041C\u043E\u043D\u0430\u0434\u044B \u0438 \u043F\u0440\u0435\u0434\u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u0430\u044F
    \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u044F  \u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0435
    \u043C\u0435\u0441\u0442\u043E \u0432 \u0437\u0440\u0435\u043B\u043E\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430 \u0437\u0430\u043D\u0438\u043C\u0430\u044E\u0442
    \u0435\u0433\u043E \u043C\u0435\u0442\u0430\u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B:  *   **\"\u041C\u043E\u043D\u0430\u0434\u043E\u043B\u043E\u0433\u0438\u044F\"
    (1714):** \u0412 \u044D\u0442\u043E\u043C \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    \u043C\u0438\u0440 \u0441\u043E\u0441\u0442\u043E\u044F\u0449\u0438\u043C \u0438\u0437
    \u0431\u0435\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445 \u043F\u0440\u043E\u0441\u0442\u044B\u0445,
    \u043D\u0435\u0434\u0435\u043B\u0438\u043C\u044B\u0445 \u0438 \u0434\u0443\u0445\u043E\u0432\u043D\u044B\u0445
    \u0441\u0443\u0431\u0441\u0442\u0430\u043D\u0446\u0438\u0439 \u2014 **\u043C\u043E\u043D\u0430\u0434**.
    \u041A\u0430\u0436\u0434\u0430\u044F \u043C\u043E\u043D\u0430\u0434\u0430 \u2014
    \u044D\u0442\u043E \"\u0437\u0435\u0440\u043A\u0430\u043B\u043E \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439\",
    \u043E\u0442\u0440\u0430\u0436\u0430\u044E\u0449\u0435\u0435 \u0432\u0435\u0441\u044C
    \u043C\u0438\u0440 \u0432 \u0441\u0435\u0431\u0435, \u043D\u043E \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C \u043D\u0435 \u0438\u043C\u0435\u044E\u0449\u0435\u0435
    \"\u043E\u043A\u043E\u043D\", \u0442\u043E \u0435\u0441\u0442\u044C \u043D\u0435
    \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0435
    \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u043C\u043E\u043D\u0430\u0434\u0430\u043C\u0438.
    *   **\"\u0422\u0435\u043E\u0434\u0438\u0446\u0435\u044F\" (1710):** \u0412 \u044D\u0442\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u043F\u044B\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u043F\u0440\u0430\u0432\u0434\u0430\u0442\u044C
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u0437\u043B\u0430 \u0432 \u043C\u0438\u0440\u0435, \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u043E\u043C
    \u0432\u0441\u0435\u0431\u043B\u0430\u0433\u0438\u043C \u0411\u043E\u0433\u043E\u043C.
    \u0415\u0433\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u043E\u0439 \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442
    \u2014 **\u043D\u0430\u0448 \u043C\u0438\u0440 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \"\u043D\u0430\u0438\u043B\u0443\u0447\u0448\u0438\u043C \u0438\u0437 \u0432\u0441\u0435\u0445
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0445 \u043C\u0438\u0440\u043E\u0432\"**.
    \u042D\u0442\u043E\u0442 \u0442\u0435\u0437\u0438\u0441 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0431\u044B\u043B \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u0432\u044B\u0441\u043C\u0435\u044F\u043D
    \u0412\u043E\u043B\u044C\u0442\u0435\u0440\u043E\u043C \u0432 \u043F\u043E\u0432\u0435\u0441\u0442\u0438
    \"\u041A\u0430\u043D\u0434\u0438\u0434\". *   **\"\u0420\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u044F
    \u043E \u043C\u0435\u0442\u0430\u0444\u0438\u0437\u0438\u043A\u0435\" (1686):**
    \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u0441\u0442\u0430\u043B\u0430
    \u0432\u0430\u0436\u043D\u044B\u043C \u044D\u0442\u0430\u043F\u043E\u043C, \u0433\u0434\u0435
    \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u043F\u043E\u043B\u043D\u043E \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u044B \u0441\u0432\u043E\u0435\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B.  ### \U0001F4DC \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B  \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043D\u0435
    \u0431\u044B\u043B \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C
    \u0432 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0441\u043C\u044B\u0441\u043B\u0435. \u0415\u0433\u043E \u0438\u0434\u0435\u0438
    \u0447\u0430\u0441\u0442\u043E \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u044B
    \u043D\u0435 \u0432 \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0442\u043E\u043C\u0430\u0445, \u0430 \u0432 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0438\u0445
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0430\u0445 \u0438 \u043E\u0431\u0448\u0438\u0440\u043D\u043E\u0439
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435. \u041A \u0447\u0438\u0441\u043B\u0443
    \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442
    \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F:  *   *\u041E\u0431 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435
    \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0438*
    (1666) *   *\u041D\u043E\u0432\u0430\u044F \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430* (1671) *   *\u0420\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u044F
    \u043E \u043C\u0435\u0442\u0430\u0444\u0438\u0437\u0438\u043A\u0435* (1686) *  
    *\u041D\u043E\u0432\u0430\u044F \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u043F\u0440\u0438\u0440\u043E\u0434\u044B*
    (1695) *   *\u041D\u043E\u0432\u044B\u0435 \u043E\u043F\u044B\u0442\u044B \u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u043C \u0440\u0430\u0437\u0443\u043C\u0435\u043D\u0438\u0438*
    (1704) \u2014 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439 \u043E\u0442\u0432\u0435\u0442
    \u043D\u0430 \u0442\u0440\u0443\u0434 \u0414\u0436\u043E\u043D\u0430 \u041B\u043E\u043A\u043A\u0430
    *   *\u0422\u0435\u043E\u0434\u0438\u0446\u0435\u044F* (1710) *   *\u041C\u043E\u043D\u0430\u0434\u043E\u043B\u043E\u0433\u0438\u044F*
    (1714) *   *\u041D\u0430\u0447\u0430\u043B\u0430 \u043F\u0440\u0438\u0440\u043E\u0434\u044B
    \u0438 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0442\u0438, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u043D\u0430 \u0440\u0430\u0437\u0443\u043C\u0435* (1714)  \u0422\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0432\u043A\u043B\u0430\u0434 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u043F\u0438\u0441\u043E\u043A
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439, \u0430 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u0430\u044F
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430, \u043D\u0430\u0446\u0435\u043B\u0435\u043D\u043D\u0430\u044F
    \u043D\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \"\u0432\u0441\u0435\u043E\u0431\u0449\u0435\u0439
    \u043D\u0430\u0443\u043A\u0438\", \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u043B\u0430 \u0431\u044B \u043B\u043E\u0433\u0438\u043A\u0443,
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443, \u0444\u0438\u0437\u0438\u043A\u0443
    \u0438 \u043C\u0435\u0442\u0430\u0444\u0438\u0437\u0438\u043A\u0443 \u0432 \u0435\u0434\u0438\u043D\u0443\u044E
    \u0441\u0442\u0440\u043E\u0439\u043D\u0443\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B, \u043E\u0442 \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439
    \u0434\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0439, \u0441\u0442\u0430\u043B\u0438
    \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C \u043A\u0430\u043C\u043D\u0435\u043C
    \u0434\u043B\u044F \u043C\u043D\u043E\u0433\u0438\u0445 \u043D\u0430\u0443\u043A,
    \u0437\u0430\u0434\u043E\u043B\u0433\u043E \u0434\u043E \u0442\u043E\u0433\u043E,
    \u043A\u0430\u043A \u0438\u0445 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0441\u0442\u0430\u043B\u043E
    \u043E\u0447\u0435\u0432\u0438\u0434\u043D\u044B\u043C."
  achievementsEn: 
  personalLifeRu: "\u0413\u043E\u0442\u0444\u0440\u0438\u0434 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043F\u0440\u043E\u0436\u0438\u043B
    \u0436\u0438\u0437\u043D\u044C, \u0446\u0435\u043B\u0438\u043A\u043E\u043C \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0443\u044E
    \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u044E \u0438 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0443,
    \u043D\u043E \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043F\u043E\u043B\u043D\u0430 \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u043E\u0432:
    \u043E\u0442 \u0432\u0441\u0435\u043E\u0431\u0449\u0435\u0433\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F
    \u0432 \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438 \u0434\u043E \u043F\u043E\u0447\u0442\u0438
    \u043F\u043E\u043B\u043D\u043E\u0433\u043E \u0437\u0430\u0431\u0432\u0435\u043D\u0438\u044F
    \u0432 \u043A\u043E\u043D\u0446\u0435, \u043E\u0442 \u043E\u0431\u0448\u0438\u0440\u043D\u0435\u0439\u0448\u0435\u0439
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0438 \u0434\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0433\u043E
    \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u0430. \u0412\u043E\u0442
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0445\u0440\u043E\u043D\u0438\u043A\u0430
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u0443\u0442\u0438.  ### \U0001F476 \u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435:
    \u041F\u0440\u0435\u0434\u0437\u043D\u0430\u043C\u0435\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0442\u0430\u043B\u0430\u043D\u0442\u044B 
    \u0413\u043E\u0442\u0444\u0440\u0438\u0434 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    1 \u0438\u044E\u043B\u044F 1646 \u0433\u043E\u0434\u0430 \u0432 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0435,
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u043C\u043E\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u0438 \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u044B \u0428\u043C\u0443\u043A\u043A.
    \u0415\u0433\u043E \u043F\u0440\u0435\u0434\u043A\u0438 \u043F\u043E \u043E\u0442\u0446\u0443,
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0438\u043C\u0435\u043B\u0438
    \u0441\u043B\u0430\u0432\u044F\u043D\u0441\u043A\u0438\u0435 \u043A\u043E\u0440\u043D\u0438,
    \u0430 \u0444\u0430\u043C\u0438\u043B\u0438\u044F, \u043A\u0430\u043A \u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0442,
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043E\u043D\u0435\u043C\u0435\u0447\u0435\u043D\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u043E\u0439 \u0438\u043C\u0435\u043D\u0438 \xAB\u041B\u0443\u0431\u0435\u043D\u0435\u0446\xBB.
    \u0421 \u043E\u0431\u0435\u0438\u0445 \u0441\u0442\u043E\u0440\u043E\u043D \u0432
    \u0441\u0435\u043C\u044C\u0435 \u0431\u044B\u043B\u0438 \u044E\u0440\u0438\u0441\u0442\u044B
    \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430, \u0447\u0442\u043E
    \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C \u043F\u0440\u0435\u0434\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u043E
    \u0435\u0433\u043E \u0431\u0443\u0434\u0443\u0449\u0438\u0435 \u0437\u0430\u043D\u044F\u0442\u0438\u044F. 
    \u0421 \u0440\u0430\u043D\u043D\u0438\u043C \u0434\u0435\u0442\u0441\u0442\u0432\u043E\u043C
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430 \u0441\u0432\u044F\u0437\u0430\u043D\u044B
    \u043F\u043E\u0447\u0442\u0438 \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438. \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0439 \u0445\u0440\u043E\u043D\u0438\u043A\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0432\u0435\u043B \u0435\u0433\u043E
    \u043E\u0442\u0435\u0446, \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u0440\u0435\u0449\u0435\u043D\u0438\u044F
    \u043C\u043B\u0430\u0434\u0435\u043D\u0435\u0446 \u043F\u043E\u0434\u043D\u044F\u043B
    \u0433\u043B\u0430\u0437\u0430 \u043A \u043F\u043E\u0442\u043E\u043B\u043A\u0443,
    \u0438 \u0424\u0440\u0438\u0434\u0440\u0438\u0445 \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u0443\u0441\u043C\u043E\u0442\u0440\u0435\u043B \u0432 \u044D\u0442\u043E\u043C
    \u0437\u043D\u0430\u043A \u0431\u0443\u0434\u0443\u0449\u0438\u0445 \xAB\u0441\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0439
    \u0432\u0435\u0449\u0435\u0439 \u0447\u0443\u0434\u0435\u0441\u043D\u044B\u0445\xBB.
    \u041E\u0442\u0435\u0446 \u0443\u043C\u0435\u0440, \u043A\u043E\u0433\u0434\u0430
    \u0413\u043E\u0442\u0444\u0440\u0438\u0434\u0443 \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E
    \u0448\u0435\u0441\u0442\u044C \u043B\u0435\u0442. \u0412\u0441\u043A\u043E\u0440\u0435
    \u043F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0433\u043E \u0441\u043B\u0443\u0447\u0438\u043B\u0441\u044F
    \u0435\u0449\u0435 \u043E\u0434\u0438\u043D \u0441\u043B\u0443\u0447\u0430\u0439:
    \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439 \u0413\u043E\u0442\u0444\u0440\u0438\u0434
    \u0443\u043F\u0430\u043B \u0441\u043E \u0441\u0442\u043E\u043B\u0430, \u043D\u043E
    \u043E\u0442\u0434\u0435\u043B\u0430\u043B\u0441\u044F \u0441\u043C\u0435\u0445\u043E\u043C.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u0431\u044B\u0432\u0448\u0438\u0439
    \u0432 \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442 \u0434\u043E\u043C\u0430,
    \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u044F\u043B \u044D\u0442\u043E \u043A\u0430\u043A
    \u0411\u043E\u0436\u044C\u0435 \u043F\u0440\u043E\u0432\u0438\u0434\u0435\u043D\u0438\u0435
    \u0438 \u043F\u0440\u0438\u043A\u0430\u0437\u0430\u043B \u043E\u0442\u0441\u043B\u0443\u0436\u0438\u0442\u044C
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u043C\u043E\u043B\u0435\u0431\u0435\u043D. \u0423\u0432\u044B, \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u0430
    \u043E\u0442\u0446\u0430 \u043D\u0435 \u0441\u0443\u0436\u0434\u0435\u043D\u043E
    \u0431\u044B\u043B\u043E \u0441\u0431\u044B\u0442\u044C\u0441\u044F \u043F\u0440\u0438
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.  \u041C\u0430\u0442\u044C,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438 \u043A\u0430\u043A \u0443\u043C\u043D\u0443\u044E
    \u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u0443\u044E \u0436\u0435\u043D\u0449\u0438\u043D\u0443,
    \u043E\u0442\u0434\u0430\u043B\u0430 \u0441\u044B\u043D\u0430 \u0432 \u043B\u0443\u0447\u0448\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0430
    \u2014 \u0448\u043A\u043E\u043B\u0443 \u041D\u0438\u043A\u043E\u043B\u0430\u0438.
    \u0413\u043E\u0442\u0444\u0440\u0438\u0434 \u0440\u0430\u043D\u043E \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0443\u044E \u0442\u044F\u0433\u0443
    \u043A \u0437\u043D\u0430\u043D\u0438\u044F\u043C \u0438 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C.
    \u041E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u0441\u0442\u0443\u043F
    \u043A \u0431\u043E\u0433\u0430\u0442\u043E\u0439 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0435
    \u043E\u0442\u0446\u0430. \u0427\u0442\u043E\u0431\u044B \u0447\u0438\u0442\u0430\u0442\u044C
    \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u0438\u0435 \u0438 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043D\u0438\u0433\u0438, \u043E\u043D \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0431\u0435\u0437 \u0441\u043B\u043E\u0432\u0430\u0440\u0435\u0439, \u0432\u044B\u0443\u0447\u0438\u043B
    \u044D\u0442\u0438 \u044F\u0437\u044B\u043A\u0438. \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u043C
    \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C \u0441\u0442\u0430\u043B\u0430
    \u043A\u043D\u0438\u0433\u0430 \u0422\u0438\u0442\u0430 \u041B\u0438\u0432\u0438\u044F
    \u0441 \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0430\u0446\u0438\u044F\u043C\u0438
    \u0438 \u043F\u043E\u0434\u043F\u0438\u0441\u044F\u043C\u0438 \u043A \u043D\u0438\u043C
    \u2014 \u043F\u043E \u043D\u0438\u043C \u043E\u043D \u043D\u0430\u0447\u0430\u043B
    \u043F\u043E\u0441\u0442\u0438\u0433\u0430\u0442\u044C \u043B\u0430\u0442\u044B\u043D\u044C,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u043F\u0435\u0440\u0435\u0448\u0435\u043B
    \u043A \u0447\u0442\u0435\u043D\u0438\u044E \u043A\u043B\u0430\u0441\u0441\u0438\u043A\u043E\u0432.
    \u0423\u0436\u0435 \u0432 12 \u043B\u0435\u0442 \u043E\u043D \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E
    \u0432\u043B\u0430\u0434\u0435\u043B \u043B\u0430\u0442\u044B\u043D\u044C\u044E
    \u0438 \u0441\u043E\u0447\u0438\u043D\u044F\u043B \u0441\u0442\u0438\u0445\u0438,
    \u0430 \u0432 14 \u043B\u0435\u0442, \u0447\u0442\u043E \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0434\u043B\u044F \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438,
    \u043D\u0430\u0447\u0430\u043B \u0437\u0430\u0434\u0443\u043C\u044B\u0432\u0430\u0442\u044C\u0441\u044F
    \u043E \u0440\u0435\u0444\u043E\u0440\u043C\u0435 \u0448\u043A\u043E\u043B\u044C\u043D\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438.  ### \U0001F3DB\uFE0F \u0423\u0447\u0451\u0431\u0430
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\u0445:
    \u041F\u0443\u0442\u044C \u043A \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044E 
    \u0412 1661 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    15 \u043B\u0435\u0442, \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u043D\u0430 \u044E\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442, \u043D\u043E \u0435\u0433\u043E
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B \u0431\u044B\u043B\u0438 \u0433\u043E\u0440\u0430\u0437\u0434\u043E
    \u0448\u0438\u0440\u0435. \u041E\u043D \u0438\u0437\u0443\u0447\u0430\u043B \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E
    \u0443 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u042F\u043A\u043E\u0431\u0430
    \u0422\u043E\u043C\u0430\u0437\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0438 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B \u0441 \u0442\u0440\u0443\u0434\u0430\u043C\u0438
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430. \u0412 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u043E\u043D \u0442\u0430\u043A\u0436\u0435 \u0443\u0432\u043B\u0435\u043A\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439 \u0438 \u0444\u0438\u0437\u0438\u043A\u043E\u0439,
    \u0447\u0438\u0442\u0430\u044F \u041A\u0435\u043F\u043B\u0435\u0440\u0430, \u0413\u0430\u043B\u0438\u043B\u0435\u044F
    \u0438 \u0414\u0435\u043A\u0430\u0440\u0442\u0430. \u0412 1663 \u0433\u043E\u0434\u0443,
    \u0447\u0442\u043E\u0431\u044B \u0443\u0433\u043B\u0443\u0431\u0438\u0442\u044C
    \u0441\u0432\u043E\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u043D\u0430\u043D\u0438\u044F, \u043E\u043D \u043D\u0430 \u043B\u0435\u0442\u043D\u0438\u0439
    \u0441\u0435\u043C\u0435\u0441\u0442\u0440 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u0419\u0435\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u0433\u0434\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u043F\u043E\u0434
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u042D\u0440\u0445\u0430\u0440\u0434\u0430
    \u0412\u0435\u0439\u0433\u0435\u043B\u044F.  \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u0431\u044B\u043B\u0430 \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439:
    *   **1663 \u0433\u043E\u0434:** \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430. *   **1664 \u0433\u043E\u0434:**
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438. 
    \u0412 1666 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    20 \u043B\u0435\u0442, \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u043F\u0435\u0440\u0432\u044B\u0439 \u0437\u043D\u0430\u0447\u0438\u043C\u044B\u0439
    \u0442\u0440\u0443\u0434 **\xAB\u041E\u0431 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435
    \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0438\xBB**
    (*De arte combinatoria*), \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0441\u0432\u043E\u0435\u0439 \u0431\u0443\u0434\u0443\u0449\u0435\u0439
    \u043C\u0435\u0447\u0442\u044B \u043E \u0432\u0441\u0435\u043E\u0431\u0449\u0435\u043C
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C \u044F\u0437\u044B\u043A\u0435. 
    \u041A\u043E\u0433\u0434\u0430 \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0441\u044F
    \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0432 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u0435\u043C\u0443 \u0431\u044B\u043B\u043E \u043E\u0442\u043A\u0430\u0437\u0430\u043D\u043E.
    \u041E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439 \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439
    \u0441\u0442\u0430\u043B \u0435\u0433\u043E \u043C\u043E\u043B\u043E\u0434\u043E\u0439
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442. \u0420\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u0432\u0448\u0438\u0441\u044C,
    \u043E\u043D \u043F\u043E\u043A\u0438\u043D\u0443\u043B \u0440\u043E\u0434\u043D\u043E\u0439
    \u0433\u043E\u0440\u043E\u0434 \u0438 \u0432 \u0442\u043E\u043C \u0436\u0435
    1666 \u0433\u043E\u0434\u0443 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u0410\u043B\u044C\u0442\u0434\u043E\u0440\u0444\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 (\u0432 \u041D\u044E\u0440\u043D\u0431\u0435\u0440\u0433\u0435),
    \u0433\u0434\u0435 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    **\xAB\u041E \u0437\u0430\u043F\u0443\u0442\u0430\u043D\u043D\u044B\u0445 \u0441\u0443\u0434\u0435\u0431\u043D\u044B\u0445
    \u0434\u0435\u043B\u0430\u0445\xBB** (*De casibus perplexis in jure*) \u0438
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0434\u043E\u043A\u0442\u043E\u0440\u0430 \u043F\u0440\u0430\u0432\u0430. \u0415\u043C\u0443
    \u0441\u0440\u0430\u0437\u0443 \u0436\u0435 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B\u0438
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C, \u043D\u043E \u041B\u0435\u0439\u0431\u043D\u0438\u0446,
    \u043F\u043E \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0441\u043B\u043E\u0432\u0430\u043C, \u0438\u043C\u0435\u043B \xAB\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u0438\u043D\u044B\u0435 \u043F\u043B\u0430\u043D\u044B\xBB.  ### \U0001F9D1\u200D\U0001F4BC
    \u041A\u0430\u0440\u044C\u0435\u0440\u0430: \u041D\u0430 \u0441\u043B\u0443\u0436\u0431\u0435
    \u0443 \u043A\u043D\u044F\u0437\u0435\u0439 \u0438 \u043D\u0430 \u043D\u0438\u0432\u0435
    \u043D\u0430\u0443\u043A\u0438  \u041E\u0442\u043A\u0430\u0437\u0430\u0432\u0448\u0438\u0441\u044C
    \u043E\u0442 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B, \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u043D\u0430 \u0434\u0438\u043F\u043B\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0438 \u044E\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0441\u043B\u0443\u0436\u0431\u0443. 
    #### \u041C\u0430\u0439\u043D\u0446\u0441\u043A\u0438\u0439 \u043F\u0435\u0440\u0438\u043E\u0434
    (1667\u20131672): \u041F\u0435\u0440\u0432\u044B\u0435 \u0448\u0430\u0433\u0438 
    \u0412 1667 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u0431\u0430\u0440\u043E\u043D\u043E\u043C \u0418\u043E\u0433\u0430\u043D\u043D\u043E\u043C
    \u041A\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u043E\u043C \u0444\u043E\u043D
    \u0411\u043E\u0439\u043D\u0435\u0431\u0443\u0440\u0433\u043E\u043C, \u0431\u044B\u0432\u0448\u0438\u043C
    \u043C\u0438\u043D\u0438\u0441\u0442\u0440\u043E\u043C \u043C\u0430\u0439\u043D\u0446\u0441\u043A\u043E\u0433\u043E
    \u043A\u0443\u0440\u0444\u044E\u0440\u0441\u0442\u0430, \u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u043A \u043D\u0435\u043C\u0443 \u043D\u0430 \u0441\u043B\u0443\u0436\u0431\u0443.
    \u0412 \u041C\u0430\u0439\u043D\u0446\u0435 \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u0432 \u0440\u0435\u0444\u043E\u0440\u043C\u0435
    \u0437\u0430\u043A\u043E\u043D\u043E\u0434\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430,
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u0430\u0434 \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E-\u043F\u0440\u0430\u0432\u043E\u0432\u044B\u043C\u0438
    \u0438 \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0441\u043A\u0438\u043C\u0438
    \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u043C\u0438.  #### \u041F\u0430\u0440\u0438\u0436
    \u0438 \u041B\u043E\u043D\u0434\u043E\u043D (1672\u20131676): \u0421\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0433\u0435\u043D\u0438\u044F  \u0412 1672 \u0433\u043E\u0434\u0443 \u0441 \u0432\u0430\u0436\u043D\u043E\u0439
    \u0434\u0438\u043F\u043B\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0438\u0441\u0441\u0438\u0435\u0439 (\u043F\u043B\u0430\u043D \u043E\u0442\u0432\u043B\u0435\u0447\u044C
    \u041B\u044E\u0434\u043E\u0432\u0438\u043A\u0430 XIV \u043E\u0442 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0445
    \u0437\u0435\u043C\u0435\u043B\u044C) \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432 \u041F\u0430\u0440\u0438\u0436.
    \u042D\u0442\u0430 \u043F\u043E\u0435\u0437\u0434\u043A\u0430 \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C
    \u043D\u0435\u0443\u0434\u0430\u0447\u043D\u043E\u0439 \u0432 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043F\u043B\u0430\u043D\u0435, \u043D\u043E \u0441\u0442\u0430\u043B\u0430 \u0440\u0435\u0448\u0430\u044E\u0449\u0435\u0439
    \u0434\u043B\u044F \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F. \u0412 \u041F\u0430\u0440\u0438\u0436\u0435
    \u043E\u043D \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0438 \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0441 \u0432\u0435\u043B\u0438\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0425\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u043E\u043C \u0413\u044E\u0439\u0433\u0435\u043D\u0441\u043E\u043C,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0441 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430\u043C\u0438
    \u0410\u043D\u0442\u0443\u0430\u043D\u043E\u043C \u0410\u0440\u043D\u043E \u0438
    \u041D\u0438\u043A\u043E\u043B\u044F \u041C\u0430\u043B\u044C\u0431\u0440\u0430\u043D\u0448\u0435\u043C.
    \u041E\u0431\u0449\u0435\u043D\u0438\u0435 \u0441 \u0413\u044E\u0439\u0433\u0435\u043D\u0441\u043E\u043C
    \u0432\u044B\u044F\u0432\u0438\u043B\u043E \u043F\u0440\u043E\u0431\u0435\u043B\u044B
    \u0432 \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0438 \u0438 \u043F\u043E\u0434\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u043E
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430 \u043A \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u043C
    \u0437\u0430\u043D\u044F\u0442\u0438\u044F\u043C.  \u0412 1673 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u043E\u0435\u0437\u0434\u043A\u0443
    \u0432 \u041B\u043E\u043D\u0434\u043E\u043D \u0438 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B
    \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u043C\u0443 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0443
    \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0443\u044E
    \u0438\u043C \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u043C\u0430\u0448\u0438\u043D\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043C\u043E\u0433\u043B\u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0442\u044C \u0438 \u0432\u044B\u0447\u0438\u0442\u0430\u0442\u044C,
    \u043D\u043E \u0438 \u0443\u043C\u043D\u043E\u0436\u0430\u0442\u044C, \u0434\u0435\u043B\u0438\u0442\u044C
    \u0438 \u0438\u0437\u0432\u043B\u0435\u043A\u0430\u0442\u044C \u043A\u043E\u0440\u043D\u0438.
    \u042D\u0442\u043E \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u043E \u0435\u043C\u0443
    \u0437\u0432\u0430\u043D\u0438\u0435 \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0433\u043E
    \u0447\u043B\u0435\u043D\u0430 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430.  \u0418\u043C\u0435\u043D\u043D\u043E
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435, \u0432 1675 \u0433\u043E\u0434\u0443,
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0443 \u043E\u0441\u043D\u043E\u0432
    **\u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F**. \u041E\u043D
    \u0441\u0434\u0435\u043B\u0430\u043B \u044D\u0442\u043E \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E
    \u043E\u0442 \u041D\u044C\u044E\u0442\u043E\u043D\u0430, \u043D\u043E \u0435\u0433\u043E
    \u043D\u043E\u0442\u0430\u0446\u0438\u044F \u0438 \u043C\u0435\u0442\u043E\u0434\u044B
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C \u0431\u043E\u043B\u0435\u0435
    \u0443\u0434\u043E\u0431\u043D\u044B\u043C\u0438 \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438
    \u0432\u0441\u0435\u043E\u0431\u0449\u0435\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435.
    \u041D\u0430 \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u043C \u043F\u0443\u0442\u0438
    \u0432 \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440 \u0432 1676 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u0441\u0435\u0442\u0438\u043B \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u044E
    \u0438 \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B\u0441\u044F \u0432 \u0413\u0430\u0430\u0433\u0435
    \u0441 \u0411\u0435\u043D\u0435\u0434\u0438\u043A\u0442\u043E\u043C \u0421\u043F\u0438\u043D\u043E\u0437\u043E\u0439,
    \u0447\u044C\u0438 \u0438\u0434\u0435\u0438 \u0442\u0430\u043A\u0436\u0435 \u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u043D\u0430 \u043D\u0435\u0433\u043E \u0432\u043B\u0438\u044F\u043D\u0438\u0435. 
    #### \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440 (1676\u20131716): \u0417\u0440\u0435\u043B\u043E\u0441\u0442\u044C
    \u0438 \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u043E  \u0421
    1676 \u0433\u043E\u0434\u0430 \u0438 \u0434\u043E \u043A\u043E\u043D\u0446\u0430
    \u0436\u0438\u0437\u043D\u0438 \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0441\u043B\u0443\u0436\u0438\u043B
    \u043F\u0440\u0438 \u0434\u0432\u043E\u0440\u0435 \u0433\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0441\u043A\u0438\u0445
    \u0433\u0435\u0440\u0446\u043E\u0433\u043E\u0432, \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u044F
    \u043E\u0431\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u0438 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0430\u0440\u044F,
    \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u0430 \u044E\u0441\u0442\u0438\u0446\u0438\u0438
    \u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u043E\u0433\u0440\u0430\u0444\u0430. 
    \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0438\u043E\u0434 \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0439
    \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438.
    \u041E\u043D: *   **\u0417\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439**
    \u0434\u043E\u043C\u0430 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u043E\u0432,
    \u0434\u043B\u044F \u0447\u0435\u0433\u043E \u0432 1687\u20131690 \u0433\u043E\u0434\u0430\u0445
    \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u044F\u043B \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435
    \u043F\u043E \u042E\u0436\u043D\u043E\u0439 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438,
    \u0410\u0432\u0441\u0442\u0440\u0438\u0438 \u0438 \u0418\u0442\u0430\u043B\u0438\u0438.
    *   **\u041E\u0441\u043D\u043E\u0432\u0430\u043B \u0438 \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u043B**
    \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0443\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E
    \u043D\u0430\u0443\u043A (\u0432 1700 \u0433\u043E\u0434\u0443). *   **\u0412\u0441\u0442\u0440\u0435\u0447\u0430\u043B\u0441\u044F
    \u0441 \u041F\u0435\u0442\u0440\u043E\u043C I** (\u0432 1711, 1712 \u0438 1716
    \u0433\u043E\u0434\u0430\u0445) \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u043F\u0440\u043E\u0435\u043A\u0442\u044B
    \u0440\u0435\u0444\u043E\u0440\u043C \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F, \u043D\u0430\u0443\u043A\u0438
    \u0438 \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u043B\u0435\u0433\u043B\u0438
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A.  \u041E\u0434\u043D\u0430\u043A\u043E
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u0431\u044B\u043B\u0438 \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u044B. \u041F\u043E\u0441\u043B\u0435
    \u0442\u043E\u0433\u043E \u043A\u0430\u043A \u0435\u0433\u043E \u0433\u0435\u0440\u0446\u043E\u0433
    \u0441\u0442\u0430\u043B \u043A\u043E\u0440\u043E\u043B\u0435\u043C \u0412\u0435\u043B\u0438\u043A\u043E\u0431\u0440\u0438\u0442\u0430\u043D\u0438\u0438
    \u0413\u0435\u043E\u0440\u0433\u043E\u043C I, \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u043F\u043E\u0442\u0435\u0440\u044F\u043B \u0431\u044B\u043B\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043F\u0440\u0438 \u0434\u0432\u043E\u0440\u0435. \u041E\u043D \u043E\u0441\u0442\u0430\u043B\u0441\u044F
    \u0432 \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u0435, \u0430
    \u0435\u0433\u043E \u0440\u043E\u043B\u044C \u0432 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u043E\u0441\u043F\u0430\u0440\u0438\u0432\u0430\u043B\u0430\u0441\u044C
    \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438
    \u0432 \u0445\u043E\u0434\u0435 \u0437\u0430\u0442\u044F\u0436\u043D\u043E\u0433\u043E
    \u0438 \u0433\u043E\u0440\u044C\u043A\u043E\u0433\u043E **\u0441\u043F\u043E\u0440\u0430
    \u0441 \u041D\u044C\u044E\u0442\u043E\u043D\u043E\u043C**.  ### \U0001FAC2 \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0443\u0447\u0435\u043D\u044B\u043C\u0438  \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0431\u044B\u043B \u0436\u0435\u043D\u0430\u0442
    \u0438, \u0441\u0443\u0434\u044F \u043F\u043E \u0432\u0441\u0435\u043C\u0443,
    \u043D\u0435 \u0438\u043C\u0435\u043B \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0445
    \u0440\u043E\u043C\u0430\u043D\u043E\u0432. \u0412\u0441\u044F \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u043D\u0430\u0443\u043A\u0435, \u0438 \u0438\u043C\u0435\u043D\u043D\u043E \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u0449\u0435\u043D\u0438\u0435 \u0431\u044B\u043B\u043E \u0434\u043B\u044F
    \u043D\u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u0441\u0442\u0440\u0430\u0441\u0442\u044C\u044E. 
    \u0415\u0433\u043E **\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441
    \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438**
    \u0431\u044B\u043B\u0438 \u0441\u043B\u043E\u0436\u043D\u044B\u043C\u0438 \u0438
    \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u044B\u043C\u0438:
    *   **\u041D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u0438**: \u041E\u043D
    \u0432\u0441\u0435\u0433\u0434\u0430 \u0438\u0441\u043A\u0430\u043B \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439
    \u0438 \u043D\u0430\u0448\u0435\u043B \u0438\u0445 \u0432 \u043B\u0438\u0446\u0435
    \u0422\u043E\u043C\u0430\u0437\u0438\u044F, \u0412\u0435\u0439\u0433\u0435\u043B\u044F
    \u0438, \u0432 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0438,
    **\u0413\u044E\u0439\u0433\u0435\u043D\u0441\u0430**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    *   **\u0414\u0440\u0443\u0436\u0435\u0441\u043A\u0438\u0435 \u0438 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u044B**: \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B \u043E\u0431\u0448\u0438\u0440\u043D\u0443\u044E
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443 \u0441 \u0441\u043E\u0442\u043D\u044F\u043C\u0438
    \u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u0432
    \u043F\u043E \u0432\u0441\u0435\u0439 \u0415\u0432\u0440\u043E\u043F\u0435. \u0421\u0440\u0435\u0434\u0438
    \u043D\u0438\u0445 \u0431\u044B\u043B\u0438 \u0442\u0430\u043A\u0438\u0435 \u0441\u0432\u0435\u0442\u0438\u043B\u0430,
    \u043A\u0430\u043A **\u042F\u043A\u043E\u0431 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438**
    \u0438 **\u0425\u0440\u0438\u0441\u0442\u0438\u0430\u043D \u0412\u043E\u043B\u044C\u0444**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B\u0438
    \u0438 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \u0438\u0434\u0435\u0438. *   **\u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442
    \u0441 \u041D\u044C\u044E\u0442\u043E\u043D\u043E\u043C**: \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 **\u0418\u0441\u0430\u0430\u043A\u043E\u043C \u041D\u044C\u044E\u0442\u043E\u043D\u043E\u043C**
    \u0431\u044B\u043B\u0438 \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u044B
    \u0433\u043E\u0440\u044C\u043A\u0438\u043C \u0441\u043F\u043E\u0440\u043E\u043C
    \u043E \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0435 \u0432 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430. \u0425\u043E\u0442\u044F \u0432 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0435
    \u0432\u0440\u0435\u043C\u044F \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043E,
    \u0447\u0442\u043E \u043E\u0431\u0430 \u0443\u0447\u0435\u043D\u044B\u0445 \u0441\u043E\u0437\u0434\u0430\u043B\u0438
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435 \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E,
    \u0432 \u043D\u0430\u0447\u0430\u043B\u0435 XVIII \u0432\u0435\u043A\u0430 \u044D\u0442\u043E\u0442
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u043F\u0440\u0438\u0432\u0435\u043B
    \u043A \u0440\u0430\u0441\u043A\u043E\u043B\u0443 \u043C\u0435\u0436\u0434\u0443
    \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u043C\u0438 \u0438
    \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u043C\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438
    \u0438 \u043D\u0430\u043D\u0435\u0441 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0439
    \u0443\u0440\u043E\u043D \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u0438
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430 \u0432 \u0410\u043D\u0433\u043B\u0438\u0438. 
    ### \U0001F54A\uFE0F \u0421\u043C\u0435\u0440\u0442\u044C \u0438 \u0437\u0430\u0431\u0432\u0435\u043D\u0438\u0435 
    \u0413\u043E\u0442\u0444\u0440\u0438\u0434 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    14 \u043D\u043E\u044F\u0431\u0440\u044F 1716 \u0433\u043E\u0434\u0430 \u0432
    \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0435 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    70 \u043B\u0435\u0442.  \u0415\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u044C
    \u043F\u0440\u043E\u0448\u043B\u0430 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435\u0437\u0430\u043C\u0435\u0447\u0435\u043D\u043D\u043E\u0439. \u041D\u0430
    \u0435\u0433\u043E \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u044B \u043D\u0435
    \u044F\u0432\u0438\u043B\u0441\u044F \u043D\u0438\u043A\u0442\u043E \u0438\u0437
    \u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u044B\u0445, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u043D \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0441\u043E\u0440\u043E\u043A
    \u043B\u0435\u0442. \u041D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u0435 \u043D\u0430
    \u0435\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u0435 \u0431\u044B\u043B\u043E
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043E \u043B\u0438\u0448\u044C
    \u0441\u043F\u0443\u0441\u0442\u044F \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F,
    \u0438 \u043D\u0430 \u043D\u0435\u043C \u0431\u044B\u043B\u0430 \u0432\u044B\u0431\u0438\u0442\u0430
    \u043B\u0438\u0448\u044C \u043F\u0440\u043E\u0441\u0442\u0430\u044F \u043D\u0430\u0434\u043F\u0438\u0441\u044C:
    **\"OSSA LEIBNITII\"** \u2014 \xAB\u041F\u0440\u0430\u0445 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430\xBB.
    \u042D\u0442\u043E\u0442 \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u0439 \u043F\u0430\u043C\u044F\u0442\u043D\u0438\u043A
    \u043D\u0430 \u044E\u0436\u043D\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u0435
    \u0446\u0435\u0440\u043A\u0432\u0438 \u0432 \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0435
    \u2014 \u0432\u0441\u0451, \u0447\u0442\u043E \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C
    \u043E\u0442 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u0447\u044C\u0438
    \u0438\u0434\u0435\u0438 \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443\u043B\u0438
    \u043C\u0438\u0440.  \u0416\u0438\u0437\u043D\u044C \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u2014 \u044D\u0442\u043E \u043F\u0443\u0442\u044C \u0433\u0435\u043D\u0438\u044F-\u043E\u0434\u0438\u043D\u043E\u0447\u043A\u0438,
    \u0447\u044C\u0438 \u043F\u043E\u0438\u0441\u043A\u0438 \u0438\u0441\u0442\u0438\u043D\u044B
    \u0438 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0437\u043D\u0430\u043D\u0438\u044F \u043D\u0430\u043C\u043D\u043E\u0433\u043E
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438 \u0432\u0440\u0435\u043C\u044F,
    \u043D\u043E \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0438
    \u0435\u043C\u0443 \u0438 \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0441\u043B\u0430\u0432\u0443,
    \u0438 \u0433\u043E\u0440\u044C\u043A\u043E\u0435 \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u0435."
  personalLifeEn: 
  shortBioRu: "\u0413\u043E\u0442\u0444\u0440\u0438\u0434 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u2014 \u0444\u0438\u0433\u0443\u0440\u0430,
    \u043C\u0430\u0441\u0448\u0442\u0430\u0431 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043F\u043E\u0440\u0430\u0436\u0430\u0435\u0442 \u0434\u0430\u0436\u0435 \u043F\u043E
    \u043C\u0435\u0440\u043A\u0430\u043C \u044D\u043F\u043E\u0445\u0438 \u0433\u0435\u043D\u0438\u0435\u0432-\u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u043E\u0432.
    \u041E\u043D \u0431\u044B\u043B \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u043C,
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u0444\u0438\u0437\u0438\u043A\u043E\u043C,
    \u044E\u0440\u0438\u0441\u0442\u043E\u043C, \u0434\u0438\u043F\u043B\u043E\u043C\u0430\u0442\u043E\u043C,
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u043C \u0438 \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u043E\u043C,
    \u0447\u044C\u0438 \u0438\u0434\u0435\u0438 \u043D\u0430 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438 \u0432\u0440\u0435\u043C\u044F.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043D\u0435\u0443\u0442\u043E\u043C\u0438\u043C\u043E\u0433\u043E \u0438\u0441\u043A\u0430\u0442\u0435\u043B\u044F
    \u0437\u043D\u0430\u043D\u0438\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F \u043E\u0445\u0432\u0430\u0442\u0438\u0442\u044C
    \u0438 \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C \u0432\u0441\u0435
    \u0441\u0444\u0435\u0440\u044B \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438.  ### \U0001F4DC \u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u044E\u043D\u043E\u0441\u0442\u044C: \u0424\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u043C\u0430  \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    1 \u0438\u044E\u043B\u044F 1646 \u0433\u043E\u0434\u0430 \u0432 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0435,
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u043C\u043E\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u0424\u0440\u0438\u0434\u0440\u0438\u0445
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446, \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F,
    \u043A\u043E\u0433\u0434\u0430 \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0443
    \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E \u0448\u0435\u0441\u0442\u044C
    \u043B\u0435\u0442, \u043E\u0441\u0442\u0430\u0432\u0438\u0432 \u0435\u043C\u0443
    \u0432 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E \u0431\u043E\u0433\u0430\u0442\u0435\u0439\u0448\u0443\u044E
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0443. \u042D\u0442\u043E
    \u0441\u043E\u0431\u044B\u0442\u0438\u0435 \u0441\u0442\u0430\u043B\u043E \u0440\u0435\u0448\u0430\u044E\u0449\u0438\u043C
    \u0434\u043B\u044F \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438. \u0421 \u0440\u0430\u043D\u043D\u0438\u0445
    \u043B\u0435\u0442 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u044B\u0439
    \u0434\u043E\u0441\u0442\u0443\u043F \u043A \u043A\u043D\u0438\u0433\u0430\u043C,
    \u0438\u0437\u0443\u0447\u0430\u044F \u043B\u0430\u0442\u044B\u043D\u044C \u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445
    \u0438 \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0441\u043A\u0438\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432, \u0447\u0442\u043E \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0440\u0430\u0441\u0448\u0438\u0440\u0438\u043B\u043E \u0435\u0433\u043E \u043A\u0440\u0443\u0433\u043E\u0437\u043E\u0440.
    \u0423\u0436\u0435 \u0432 12 \u043B\u0435\u0442 \u043E\u043D \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E
    \u0432\u043B\u0430\u0434\u0435\u043B \u043B\u0430\u0442\u044B\u043D\u044C\u044E,
    \u0430 \u0432 14 \u0441\u043E\u0447\u0438\u043D\u0438\u043B 300 \u0433\u0435\u043A\u0437\u0430\u043C\u0435\u0442\u0440\u043E\u0432
    \u043D\u0430 \u043B\u0430\u0442\u044B\u043D\u0438 \u0437\u0430 \u043E\u0434\u0438\u043D
    \u0434\u0435\u043D\u044C, \u043F\u043E\u0440\u0430\u0437\u0438\u0432 \u0441\u0432\u043E\u0438\u0445
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439.  \u0412 15 \u043B\u0435\u0442
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u0433\u0434\u0435 \u0438\u0437\u0443\u0447\u0430\u043B \u044E\u0440\u0438\u0441\u043F\u0440\u0443\u0434\u0435\u043D\u0446\u0438\u044E,
    \u043E\u0434\u043D\u0430\u043A\u043E \u0441 \u0436\u0430\u0434\u043D\u043E\u0441\u0442\u044C\u044E
    \u0432\u043F\u0438\u0442\u044B\u0432\u0430\u043B \u0437\u043D\u0430\u043D\u0438\u044F
    \u043F\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u041E\u043D \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u043B\u0441\u044F
    \u0440\u043E\u0434\u043D\u044B\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u043E\u043C
    \u0438 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432 \u0419\u0435\u043D\u0443,
    \u0447\u0442\u043E\u0431\u044B \u0443\u0433\u043B\u0443\u0431\u0438\u0442\u044C
    \u0441\u0432\u043E\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u044F. \u0415\u0433\u043E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0443\u0442\u044C \u0431\u044B\u043B \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C: 
    *   **1663 \u0433\u043E\u0434:** \u041F\u043E\u043B\u0443\u0447\u0430\u0435\u0442
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430
    \u0437\u0430 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    **\xAB\u041E \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0435 \u0438\u043D\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u0446\u0438\u0438\xBB**
    (*De principio individui*), \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0443\u0436\u0435 \u043F\u0440\u043E\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u044E\u0442\u0441\u044F
    \u0437\u0435\u0440\u043D\u0430 \u0435\u0433\u043E \u0431\u0443\u0434\u0443\u0449\u0435\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438. *   **1664 \u0433\u043E\u0434:**
    \u0421\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u043E\u043C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438. *   **1666 \u0433\u043E\u0434:**
    \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 20 \u043B\u0435\u0442
    \u043F\u0443\u0431\u043B\u0438\u043A\u0443\u0435\u0442 \u0441\u0432\u043E\u0439
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 **\xAB\u041E\u0431 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435
    \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0438\xBB**
    (*De arte combinatoria*). \u0412 \u044D\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    \u043E\u043D \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0435\u0442 \u0438\u0434\u0435\u044E
    \xAB\u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430\xBB
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F, \u0441\u0442\u0440\u0435\u043C\u044F\u0441\u044C
    \u0441\u0432\u0435\u0441\u0442\u0438 \u0432\u0441\u0435 \u0437\u043D\u0430\u043D\u0438\u044F
    \u043A \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0446\u0438\u044F\u043C \u043F\u0440\u043E\u0441\u0442\u0435\u0439\u0448\u0438\u0445
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432 \u2014 \u044D\u0442\u043E
    \u0431\u044B\u043B \u0440\u0430\u043D\u043D\u0438\u0439 \u043D\u0430\u0431\u0440\u043E\u0441\u043E\u043A
    \u0435\u0433\u043E \u043C\u0435\u0447\u0442\u044B \u043E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u044F\u0437\u044B\u043A\u0430. 
    \u041F\u043E\u043F\u044B\u0442\u043A\u0430 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u043F\u043E \u043F\u0440\u0430\u0432\u0443 \u0432 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0435
    \u0431\u044B\u043B\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0435\u043D\u0430
    \u043F\u0440\u0435\u043F\u044F\u0442\u0441\u0442\u0432\u0438\u044F\u043C\u0438
    \u0438\u0437-\u0437\u0430 \u0435\u0433\u043E \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438,
    \u0438 \u041B\u0435\u0439\u0431\u043D\u0438\u0446, \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u0432\u0448\u0438\u0441\u044C,
    \u043F\u043E\u043A\u0438\u043D\u0443\u043B \u0440\u043E\u0434\u043D\u043E\u0439
    \u0433\u043E\u0440\u043E\u0434. \u041E\u043D \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u041D\u044E\u0440\u043D\u0431\u0435\u0440\u0433 \u0438 \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0410\u043B\u044C\u0442\u0434\u043E\u0440\u0444\u0430 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435
    \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    **\xAB\u041E \u0437\u0430\u043F\u0443\u0442\u0430\u043D\u043D\u044B\u0445 \u0441\u0443\u0434\u0435\u0431\u043D\u044B\u0445
    \u0434\u0435\u043B\u0430\u0445\xBB** (*De casibus perplexis in jure*), \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0438 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0443\u0440\u044B,
    \u043E\u0442 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043E\u043D \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F,
    \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0442\u044F \u0441\u0432\u043E\u0431\u043E\u0434\u0443
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439.  ###
    \U0001F3DB\uFE0F \u041D\u0430 \u0441\u043B\u0443\u0436\u0431\u0435 \u0443 \u043A\u043D\u044F\u0437\u0435\u0439:
    \u0414\u0438\u043F\u043B\u043E\u043C\u0430\u0442, \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A
    \u0438 \u0443\u0447\u0451\u043D\u044B\u0439  \u0412\u0441\u044F \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u043F\u0440\u043E\u0448\u043B\u0430 \u043D\u0430 \u0441\u043B\u0443\u0436\u0431\u0435
    \u0443 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0445 \u043A\u043D\u044F\u0437\u0435\u0439,
    \u0447\u0442\u043E \u0434\u0430\u0432\u0430\u043B\u043E \u0435\u043C\u0443 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u0443\u044E
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u044C
    \u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u043D\u0430\u0443\u043A\u043E\u0439, \u043D\u043E \u0442\u0430\u043A\u0436\u0435
    \u0438 \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u043B\u043E \u0435\u0433\u043E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u043C\u0438
    \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C\u0438. 
    #### **\u041C\u0430\u0439\u043D\u0446\u0441\u043A\u0438\u0439 \u043F\u0435\u0440\u0438\u043E\u0434
    (1667\u20131676): \u041F\u0435\u0440\u0432\u044B\u0435 \u0434\u0438\u043F\u043B\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0448\u0430\u0433\u0438**  \u0412 \u041D\u044E\u0440\u043D\u0431\u0435\u0440\u0433\u0435
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u0431\u0430\u0440\u043E\u043D\u043E\u043C \u0418\u043E\u0433\u0430\u043D\u043D\u043E\u043C
    \u041A\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u043E\u043C \u0444\u043E\u043D
    \u0411\u043E\u0439\u043D\u0435\u0431\u0443\u0440\u0433\u043E\u043C, \u0431\u044B\u0432\u0448\u0438\u043C
    \u043C\u0438\u043D\u0438\u0441\u0442\u0440\u043E\u043C \u043C\u0430\u0439\u043D\u0446\u0441\u043A\u043E\u0433\u043E
    \u043A\u0443\u0440\u0444\u044E\u0440\u0441\u0442\u0430. \u0411\u043E\u0439\u043D\u0435\u0431\u0443\u0440\u0433
    \u0432\u0437\u044F\u043B \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E
    \u043F\u043E\u0434 \u0441\u0432\u043E\u0435 \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0438 \u0432\u0432\u0435\u043B \u0435\u0433\u043E \u043F\u0440\u0438 \u0434\u0432\u043E\u0440.
    \u041D\u0430 \u0441\u043B\u0443\u0436\u0431\u0435 \u0443 \u043A\u0443\u0440\u0444\u044E\u0440\u0441\u0442\u0430
    \u041C\u0430\u0439\u043D\u0446\u0430 \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438 \u043F\u0443\u0431\u043B\u0438\u0446\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043D\u0430\u0434 \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043F\u0440\u0430\u0432\u043E\u0432\u043E\u0433\u043E \u043A\u043E\u0434\u0435\u043A\u0441\u0430. 
    \u041E\u0434\u043D\u0438\u043C \u0438\u0437 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u0435\u0433\u043E \u043F\u0440\u043E\u0435\u043A\u0442\u043E\u0432 \u0442\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0431\u044B\u043B\u0430 \u043F\u043E\u043F\u044B\u0442\u043A\u0430
    \u043E\u0442\u0432\u043B\u0435\u0447\u044C \u0430\u043C\u0431\u0438\u0446\u0438\u0438
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u044F
    \u041B\u044E\u0434\u043E\u0432\u0438\u043A\u0430 XIV \u043E\u0442 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0445
    \u0437\u0435\u043C\u0435\u043B\u044C. \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u043F\u043B\u0430\u043D
    \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u043D\u0438\u044F \u0415\u0433\u0438\u043F\u0442\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u043A\u0430\u043A \u043E\u043D \u043D\u0430\u0434\u0435\u044F\u043B\u0441\u044F,
    \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u043B \u043D\u0430\u043F\u0440\u0430\u0432\u0438\u0442\u044C
    \u0432\u043E\u0435\u043D\u043D\u0443\u044E \u043C\u043E\u0449\u044C \u0424\u0440\u0430\u043D\u0446\u0438\u0438
    \u043F\u0440\u043E\u0442\u0438\u0432 \u041E\u0441\u043C\u0430\u043D\u0441\u043A\u043E\u0439
    \u0438\u043C\u043F\u0435\u0440\u0438\u0438. \u0421 \u044D\u0442\u043E\u0439 \u0434\u0438\u043F\u043B\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0438\u0441\u0441\u0438\u0435\u0439 \u043E\u043D \u0432 1672 \u0433\u043E\u0434\u0443
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432 \u041F\u0430\u0440\u0438\u0436. 
    #### **\u041F\u0430\u0440\u0438\u0436 (1672\u20131676): \u041A\u043E\u043B\u044B\u0431\u0435\u043B\u044C
    \u0433\u0435\u043D\u0438\u044F**  \u041F\u0440\u0435\u0431\u044B\u0432\u0430\u043D\u0438\u0435
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435, \u0434\u043B\u0438\u0432\u0448\u0435\u0435\u0441\u044F
    \u0447\u0435\u0442\u044B\u0440\u0435 \u0433\u043E\u0434\u0430, \u0441\u0442\u0430\u043B\u043E,
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0441\u0430\u043C\u044B\u043C
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C \u043F\u0435\u0440\u0438\u043E\u0434\u043E\u043C
    \u0432 \u0436\u0438\u0437\u043D\u0438 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430.
    \u0417\u0434\u0435\u0441\u044C \u043E\u043D \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0432 \u0446\u0435\u043D\u0442\u0440\u0435 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0415\u0432\u0440\u043E\u043F\u044B. \u041E\u043D
    \u043E\u0431\u0449\u0430\u043B\u0441\u044F \u0441 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0438\u0441\u044F
    \u0443\u043C\u0430\u043C\u0438: \u0444\u0438\u0437\u0438\u043A\u043E\u043C \u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C **\u0425\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u043E\u043C
    \u0413\u044E\u0439\u0433\u0435\u043D\u0441\u043E\u043C**, \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u043C
    **\u041D\u0438\u043A\u043E\u043B\u044F \u041C\u0430\u043B\u044C\u0431\u0440\u0430\u043D\u0448\u0435\u043C**,
    \u0442\u0435\u043E\u043B\u043E\u0433\u043E\u043C **\u0410\u043D\u0442\u0443\u0430\u043D\u043E\u043C
    \u0410\u0440\u043D\u043E**. \u0413\u044E\u0439\u0433\u0435\u043D\u0441 \u0437\u0430\u043C\u0435\u0442\u0438\u043B
    \u043F\u0440\u043E\u0431\u0435\u043B\u044B \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u043D\u0430\u043D\u0438\u044F\u0445 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430,
    \u0447\u0442\u043E \u043F\u043E\u0431\u0443\u0434\u0438\u043B\u043E \u0442\u043E\u0433\u043E
    \u043A \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0438\u043D\u0442\u0435\u043D\u0441\u0438\u0432\u043D\u044B\u043C \u0437\u0430\u043D\u044F\u0442\u0438\u044F\u043C,
    \u0432 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u043D \u0431\u044B\u0441\u0442\u0440\u043E \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u0441\u044F
    \u0432 \u043E\u0434\u043D\u043E\u0433\u043E \u0438\u0437 \u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438.  \u0418\u043C\u0435\u043D\u043D\u043E
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435, \u0432 1675 \u0433\u043E\u0434\u0443,
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0441\u0432\u043E\u0435 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0435\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435, \u0437\u0430\u043B\u043E\u0436\u0438\u0432
    \u043E\u0441\u043D\u043E\u0432\u044B **\u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F**, \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E
    \u043E\u0442 \u041D\u044C\u044E\u0442\u043E\u043D\u0430. \u0422\u0430\u043A\u0436\u0435
    \u0432 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D
    \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    **\u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0430\u0440\u0438\u0444\u043C\u043E\u043C\u0435\u0442\u0440**,
    \u043F\u0435\u0440\u0432\u0443\u044E \u043C\u0430\u0448\u0438\u043D\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043C\u043E\u0433\u043B\u0430 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0442\u044C
    \u0432\u0441\u0435 \u0447\u0435\u0442\u044B\u0440\u0435 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F, \u0438 \u043F\u0440\u043E\u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0432 **\u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u043C
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u043C \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435**
    \u0432 1673 \u0433\u043E\u0434\u0443, \u0433\u0434\u0435 \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D
    \u0435\u0433\u043E \u0447\u043B\u0435\u043D\u043E\u043C.  \u0412 1676 \u0433\u043E\u0434\u0443,
    \u043D\u0430 \u043F\u0443\u0442\u0438 \u0438\u0437 \u041F\u0430\u0440\u0438\u0436\u0430
    \u0432 \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440, \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u043E\u0435\u0437\u0434\u043A\u0443
    \u0432 \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u044E, \u0433\u0434\u0435
    \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B\u0441\u044F \u0441 **\u0411\u0435\u043D\u0435\u0434\u0438\u043A\u0442\u043E\u043C
    \u0421\u043F\u0438\u043D\u043E\u0437\u043E\u0439**, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0443\u0437\u043D\u0430\u043B \u043E\u0431 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F\u0445 **\u0410\u043D\u0442\u043E\u043D\u0438
    \u0432\u0430\u043D \u041B\u0435\u0432\u0435\u043D\u0433\u0443\u043A\u0430** \u0432
    \u043C\u0438\u0440\u0435 \u043C\u0438\u043A\u0440\u043E\u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u043E\u0432.
    \u042D\u0442\u0438 \u0432\u0441\u0442\u0440\u0435\u0447\u0438 \u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0435\u0433\u043E \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435 \u0432\u0437\u0433\u043B\u044F\u0434\u044B. 
    ### \U0001F451 \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B (1676\u20131716): \u0417\u0440\u0435\u043B\u043E\u0441\u0442\u044C,
    \u0441\u043B\u0430\u0432\u0430 \u0438 \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u043E 
    \u0421 1676 \u0433\u043E\u0434\u0430 \u0438 \u0434\u043E \u043A\u043E\u043D\u0446\u0430
    \u0436\u0438\u0437\u043D\u0438 \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0441\u043E\u0441\u0442\u043E\u044F\u043B
    \u043D\u0430 \u0441\u043B\u0443\u0436\u0431\u0435 \u0443 \u0433\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0441\u043A\u0438\u0445
    \u0433\u0435\u0440\u0446\u043E\u0433\u043E\u0432, \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0430\u0440\u044F,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u2014 \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u0430
    \u044E\u0441\u0442\u0438\u0446\u0438\u0438 \u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u043E\u0433\u0440\u0430\u0444\u0430.
    \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0438\u043E\u0434 \u0432\u044B\u0441\u043E\u0447\u0430\u0439\u0448\u0435\u0439
    \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438.
    \u041E\u043D:  *   **\u0417\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439:**
    \u041F\u043E \u043F\u043E\u0440\u0443\u0447\u0435\u043D\u0438\u044E \u0433\u0435\u0440\u0446\u043E\u0433\u0430
    \u042D\u0440\u043D\u0441\u0442\u0430 \u0410\u0432\u0433\u0443\u0441\u0442\u0430
    \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u043F\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0434\u043E\u043C\u0430 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u043E\u0432,
    \u0434\u043B\u044F \u0447\u0435\u0433\u043E \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u044F\u043B
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u043F\u043E
    \u042E\u0436\u043D\u043E\u0439 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438,
    \u0410\u0432\u0441\u0442\u0440\u0438\u0438 \u0438 \u0418\u0442\u0430\u043B\u0438\u0438
    (1687\u20131690). *   **\u0421\u0442\u0430\u043B \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C
    \u043D\u0430\u0443\u043A\u0438:** \u041F\u043E \u0435\u0433\u043E \u0438\u043D\u0438\u0446\u0438\u0430\u0442\u0438\u0432\u0435
    \u0432 1700 \u0433\u043E\u0434\u0443 \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0435
    \u0431\u044B\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043E \u0411\u0440\u0430\u043D\u0434\u0435\u043D\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0435
    \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E
    (\u043F\u043E\u0437\u0436\u0435 \u2014 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0430\u044F
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044F \u043D\u0430\u0443\u043A), \u043F\u0435\u0440\u0432\u044B\u043C
    \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043E\u043D \u0441\u0442\u0430\u043B. *   **\u041F\u044B\u0442\u0430\u043B\u0441\u044F
    \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C \u0446\u0435\u0440\u043A\u0432\u0438:**
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0431\u044B\u043B \u043E\u0434\u0435\u0440\u0436\u0438\u043C
    \u0438\u0434\u0435\u0435\u0439 \u043F\u0440\u0438\u043C\u0438\u0440\u0435\u043D\u0438\u044F
    \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0438
    \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u0441\u043A\u043E\u0439
    \u0446\u0435\u0440\u043A\u0432\u0435\u0439, \u0432\u0435\u0434\u044F \u0430\u043A\u0442\u0438\u0432\u043D\u0443\u044E
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443 \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u044F
    \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0441\u043A\u0438\u0435 \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438,
    \u043E\u0434\u043D\u0430\u043A\u043E \u044D\u0442\u0438 \u043F\u0440\u043E\u0435\u043A\u0442\u044B
    \u043D\u0435 \u0443\u0432\u0435\u043D\u0447\u0430\u043B\u0438\u0441\u044C \u0443\u0441\u043F\u0435\u0445\u043E\u043C.
    *   **\u0412\u043B\u0438\u044F\u043B \u043D\u0430 \u0420\u043E\u0441\u0441\u0438\u044E:**
    \u0422\u0440\u0438\u0436\u0434\u044B \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u043B\u0441\u044F
    \u0441 \u041F\u0435\u0442\u0440\u043E\u043C I (\u0432 1711, 1712 \u0438 1716
    \u0433\u043E\u0434\u0430\u0445) \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u043F\u0440\u043E\u0435\u043A\u0442\u044B
    \u043F\u043E \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u0438
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438 \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043F\u043B\u0430\u043D \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0437\u0436\u0435 \u0431\u044B\u043B \u0440\u0435\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043D. 
    \u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E, \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0436\u0438\u0437\u043D\u0438 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u0431\u044B\u043B\u0438 \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u044B \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u043E\u043C
    \u0441 \u0433\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0441\u043A\u0438\u043C
    \u0434\u0432\u043E\u0440\u043E\u043C. \u041A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E
    \u0433\u0435\u0440\u0446\u043E\u0433 \u0441\u0442\u0430\u043B \u043A\u043E\u0440\u043E\u043B\u0435\u043C
    \u0412\u0435\u043B\u0438\u043A\u043E\u0431\u0440\u0438\u0442\u0430\u043D\u0438\u0438
    \u0413\u0435\u043E\u0440\u0433\u043E\u043C I, \u041B\u0435\u0439\u0431\u043D\u0438\u0446,
    \u0447\u044C\u0438 \u0437\u0430\u0441\u043B\u0443\u0433\u0438 \u0432 \u0410\u043D\u0433\u043B\u0438\u0438
    \u0431\u044B\u043B\u0438 \u043F\u0440\u0438\u043D\u0438\u0436\u0435\u043D\u044B
    \u0438\u0437-\u0437\u0430 \u0441\u043F\u043E\u0440\u0430 \u0441 \u041D\u044C\u044E\u0442\u043E\u043D\u043E\u043C
    \u043E \u043F\u0435\u0440\u0432\u0435\u043D\u0441\u0442\u0432\u0435 \u0432 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0438
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F, \u043E\u0441\u0442\u0430\u043B\u0441\u044F
    \u043D\u0435 \u0443 \u0434\u0435\u043B. \u0412 1716 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0435,
    \u043E\u0434\u0438\u043D\u043E\u043A\u0438\u043C \u0438 \u043F\u043E\u0447\u0442\u0438
    \u0437\u0430\u0431\u044B\u0442\u044B\u043C, \u0430 \u0435\u0433\u043E \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u044B
    \u043F\u0440\u043E\u0448\u043B\u0438 \u043F\u043E\u0447\u0442\u0438 \u043D\u0435\u0437\u0430\u043C\u0435\u0447\u0435\u043D\u043D\u044B\u043C\u0438. 
    ### \U0001F48E \u0412\u043A\u043B\u0430\u0434 \u0432 \u043D\u0430\u0443\u043A\u0443 
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0442\u0440\u0443\u0434\u043D\u043E
    \u043F\u0435\u0440\u0435\u043E\u0446\u0435\u043D\u0438\u0442\u044C. \u0415\u0433\u043E
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0432\u043A\u043B\u044E\u0447\u0430\u044E\u0442:  *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:**
    \u041D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0435 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u043E\u043C \u0438 \u043D\u043E\u0442\u0430\u0446\u0438\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    **\u0434\u0432\u043E\u0438\u0447\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u0442\u0430\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0432\u0441\u0435\u0445 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0446\u0438\u0444\u0440\u043E\u0432\u044B\u0445 \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0439.
    *   **\u041B\u043E\u0433\u0438\u043A\u0430 \u0438 \u044F\u0437\u044B\u043A:**
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u2014 \u043F\u0440\u0435\u0434\u0442\u0435\u0447\u0430
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438. \u041E\u043D \u043C\u0435\u0447\u0442\u0430\u043B
    \u043E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438 **\xAB\u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0438\xBB**
    (characteristica universalis) \u0438 **\xAB\u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0439\xBB** (calculus
    ratiocinator) \u2014 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B
    \u0431\u044B \u0440\u0435\u0448\u0430\u0442\u044C \u043B\u044E\u0431\u044B\u0435
    \u0441\u043F\u043E\u0440\u044B \u043F\u0440\u043E\u0441\u0442\u044B\u043C\u0438
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F\u043C\u0438. *  
    **\u0424\u0438\u0437\u0438\u043A\u0430:** \u0417\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u043D\u043E\u0432\u043E\u0439 \u043D\u0430\u0443\u043A\u0438
    \u2014 **\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438**, \u0432\u0432\u0435\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\xAB\u0436\u0438\u0432\u043E\u0439
    \u0441\u0438\u043B\u044B\xBB** (\u043A\u0438\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u044D\u043D\u0435\u0440\u0433\u0438\u0438) \u0438 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    **\u0437\u0430\u043A\u043E\u043D \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \u044D\u043D\u0435\u0440\u0433\u0438\u0438** \u0432 \u0435\u0435 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0432\u0435\u0440\u0441\u0438\u0438, \u0430 \u0442\u0430\u043A\u0436\u0435 **\u043F\u0440\u0438\u043D\u0446\u0438\u043F
    \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0433\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F**.
    *   **\u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F:** \u0421\u043E\u0437\u0434\u0430\u043B
    \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u0443\u044E \u043C\u0435\u0442\u0430\u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u2014 **\xAB\u041C\u043E\u043D\u0430\u0434\u043E\u043B\u043E\u0433\u0438\u044E\xBB**,
    \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043C\u0438\u0440 \u0441\u043E\u0441\u0442\u043E\u0438\u0442 \u0438\u0437 \u0431\u0435\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445
    \u0434\u0443\u0445\u043E\u0432\u043D\u044B\u0445 \u0438 \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0441\u0443\u0431\u0441\u0442\u0430\u043D\u0446\u0438\u0439 \u2014 **\u043C\u043E\u043D\u0430\u0434**.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    **\u0437\u0430\u043A\u043E\u043D \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0433\u043E
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F** \u0438 \u0440\u0430\u0437\u0432\u0438\u043B
    \u0443\u0447\u0435\u043D\u0438\u0435 \u043E **\xAB\u043D\u0430\u0438\u043B\u0443\u0447\u0448\u0435\u043C
    \u0438\u0437 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0445 \u043C\u0438\u0440\u043E\u0432\xBB**,
    \u0447\u0442\u043E \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0431\u044B\u043B\u043E \u0432\u044B\u0441\u043C\u0435\u044F\u043D\u043E \u0412\u043E\u043B\u044C\u0442\u0435\u0440\u043E\u043C
    \u0432 \xAB\u041A\u0430\u043D\u0434\u0438\u0434\u0435\xBB, \u043D\u043E \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0432\u0435\u0440\u0448\u0438\u043D
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0439 \u043C\u044B\u0441\u043B\u0438
    XVII \u0432\u0435\u043A\u0430.  \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0431\u044B\u043B
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0443\u0447\u0435\u043D\u044B\u043C;
    \u043E\u043D \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u044B\u0442\u0430\u043B\u0441\u044F
    \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u0435\u0434\u0438\u043D\u0443\u044E
    \u043A\u0430\u0440\u0442\u0438\u043D\u0443 \u043C\u0438\u0440\u0430, \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0432
    \u043D\u0430\u0443\u043A\u0443, \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E
    \u0438 \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044E. \u0415\u0433\u043E \u0438\u0434\u0435\u0438
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438
    \u0435\u0433\u043E \u0432\u0440\u0435\u043C\u044F, \u0447\u0442\u043E \u043C\u043D\u043E\u0433\u0438\u0435
    \u0438\u0437 \u043D\u0438\u0445 \u043E\u0431\u0440\u0435\u043B\u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0432\u043E\u043F\u043B\u043E\u0449\u0435\u043D\u0438\u0435 \u043B\u0438\u0448\u044C
    \u0447\u0435\u0440\u0435\u0437 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0413\u043E\u0442\u0444\u0440\u0438\u0434\u0430
    \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u0430 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0435\u0440\u0435\u0434\u0430
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0445 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439,
    \u043D\u043E \u0438 \u043A\u043B\u0430\u0434\u0435\u0437\u044C \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445,
    \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445 \u0438 \u0434\u0430\u0436\u0435
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439. \u0415\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u0430, \u0447\u0442\u043E
    \u043F\u043E\u0440\u043E\u0436\u0434\u0430\u043B\u0430 \u0441\u0430\u043C\u044B\u0435
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u0435 \u0441\u043B\u0443\u0445\u0438
    \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u044B.  \u0412\u043E\u0442 \u043F\u043E\u0434\u0431\u043E\u0440\u043A\u0430
    \u0441\u0430\u043C\u044B\u0445 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u043E \xAB\u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u043C
    \u0433\u0435\u043D\u0438\u0438\xBB:  ### \U0001F92F \u041F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u0430
    \u0438 \u0447\u0443\u0434\u0435\u0441\u0430  - **\u041A\u0440\u0435\u0441\u0442\u0438\u043B\u044C\u043D\u043E\u0435
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0435:** \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u0424\u0440\u0438\u0434\u0440\u0438\u0445
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446, \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0438 \u0441\u043A\u043B\u043E\u043D\u043D\u044B\u043C \u043A \u043C\u0438\u0441\u0442\u0438\u043A\u0435.
    \u041D\u0430 \u043A\u0440\u0435\u0441\u0442\u0438\u043D\u0430\u0445 \u043C\u043B\u0430\u0434\u0435\u043D\u0446\u0430
    \u0413\u043E\u0442\u0444\u0440\u0438\u0434\u0430 \u043E\u043D \u0437\u0430\u043C\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u043D\u043E\u0432\u043E\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u044B\u0439
    \u043F\u043E\u0434\u043D\u044F\u043B \u0433\u043B\u0430\u0437\u0430 \u043A \u043F\u043E\u0442\u043E\u043B\u043A\u0443
    \u0438 \u043F\u0440\u0438\u0441\u0442\u0430\u043B\u044C\u043D\u043E \u043D\u0430
    \u043D\u0435\u0433\u043E \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u043B.
    \u041E\u0442\u0435\u0446 \u0442\u0443\u0442 \u0436\u0435 \u0437\u0430\u043F\u0438\u0441\u0430\u043B
    \u0432 \u0441\u0435\u043C\u0435\u0439\u043D\u0443\u044E \u0445\u0440\u043E\u043D\u0438\u043A\u0443,
    \u0447\u0442\u043E \u0432\u0438\u0434\u0438\u0442 \u0432 \u044D\u0442\u043E\u043C
    \u0437\u043D\u0430\u043A \u0431\u0443\u0434\u0443\u0449\u0438\u0445 \u0432\u0435\u043B\u0438\u043A\u0438\u0445
    \u0441\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0439. - **\u0421\u043F\u0430\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043F\u0430\u0434\u0435\u043D\u0438\u0435:** \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u0434\u0432\u0443\u0445 \u043B\u0435\u0442 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439
    \u0413\u043E\u0442\u0444\u0440\u0438\u0434 \u0443\u043F\u0430\u043B \u0441\u043E
    \u0441\u0442\u043E\u043B\u0430, \u043D\u043E, \u043A \u0441\u0447\u0430\u0441\u0442\u044C\u044E,
    \u043D\u0435 \u0443\u0448\u0438\u0431\u0441\u044F \u0438 \u0434\u0430\u0436\u0435
    \u0440\u0430\u0441\u0441\u043C\u0435\u044F\u043B\u0441\u044F. \u0415\u0433\u043E
    \u043E\u0442\u0435\u0446, \u043D\u0430\u0445\u043E\u0434\u0438\u0432\u0448\u0438\u0439\u0441\u044F
    \u0432 \u043A\u043E\u043C\u043D\u0430\u0442\u0435, \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u044F\u043B
    \u044D\u0442\u043E \u043A\u0430\u043A \u0411\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \u043F\u0440\u043E\u0432\u0438\u0434\u0435\u043D\u0438\u0435 \u0438 \u0440\u0430\u0441\u043F\u043E\u0440\u044F\u0434\u0438\u043B\u0441\u044F
    \u043E\u0442\u0441\u043B\u0443\u0436\u0438\u0442\u044C \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u043C\u043E\u043B\u0435\u0431\u0435\u043D. \u0423\u0432\u044B, \u0441\u043F\u0430\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043F\u0440\u043E\u0432\u0438\u0434\u0435\u043D\u0438\u0435 \u043D\u0435 \u0443\u0431\u0435\u0440\u0435\u0433\u043B\u043E
    \u0441\u0430\u043C\u043E\u0433\u043E \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430
    \u2014 \u043E\u043D \u0443\u043C\u0435\u0440, \u043A\u043E\u0433\u0434\u0430
    \u0413\u043E\u0442\u0444\u0440\u0438\u0434\u0443 \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E
    \u0448\u0435\u0441\u0442\u044C.  ### \U0001F4DA \u0427\u0442\u0435\u043D\u0438\u0435
    \u043A\u0430\u043A \u0441\u043F\u043E\u0440\u0442  - **\u0421\u0430\u043C\u043E\u0443\u0447\u043A\u0430
    \u0432 \u0447\u0435\u0442\u044B\u0440\u0435 \u0433\u043E\u0434\u0430:** \u041E\u0441\u0442\u0430\u0432\u0448\u0438\u0441\u044C
    \u0441 \u0431\u043E\u0433\u0430\u0442\u043E\u0439 \u043E\u0442\u0446\u043E\u0432\u0441\u043A\u043E\u0439
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u043E\u0439, \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043D\u0435 \u0441\u0442\u0430\u043B
    \u0436\u0434\u0430\u0442\u044C \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439.
    \u041E\u043D \u043D\u0430\u0443\u0447\u0438\u043B\u0441\u044F \u0447\u0438\u0442\u0430\u0442\u044C
    \u043F\u043E \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u043C\u0443
    \u0438\u0437\u0434\u0430\u043D\u0438\u044E \u0422\u0438\u0442\u0430 \u041B\u0438\u0432\u0438\u044F,
    \u0433\u0434\u0435 \u043F\u043E\u0434 \u043A\u0430\u0440\u0442\u0438\u043D\u043A\u0430\u043C\u0438
    \u0431\u044B\u043B\u0438 \u043A\u0440\u0430\u0442\u043A\u0438\u0435 \u043F\u043E\u0434\u043F\u0438\u0441\u0438
    \u043D\u0430 \u043B\u0430\u0442\u044B\u043D\u0438. \u0422\u0430\u043A, \u043A
    \u0447\u0435\u0442\u044B\u0440\u0435\u043C \u0433\u043E\u0434\u0430\u043C \u043E\u043D
    \u043E\u0441\u0432\u043E\u0438\u043B \u043E\u0434\u0438\u043D \u0438\u0437 \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u044F\u0437\u044B\u043A\u043E\u0432 \u043C\u0438\u0440\u0430. - **\u0413\u0435\u043A\u0437\u0430\u043C\u0435\u0442\u0440\u044B
    \u0437\u0430 \u0434\u0435\u043D\u044C:** \u0412 14 \u043B\u0435\u0442, \u0447\u0442\u043E\u0431\u044B
    \u0440\u0430\u0437\u0432\u043B\u0435\u0447\u044C \u0438\u043B\u0438 \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u044C
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439, \u043E\u043D \u0437\u0430 \u043E\u0434\u0438\u043D
    \u0434\u0435\u043D\u044C \u0441\u043E\u0447\u0438\u043D\u0438\u043B 300 (!) \u0433\u0435\u043A\u0437\u0430\u043C\u0435\u0442\u0440\u043E\u0432
    \u043D\u0430 \u043B\u0430\u0442\u044B\u043D\u0438 \u0432 \u0441\u0442\u0438\u043B\u0435
    \u0412\u0435\u0440\u0433\u0438\u043B\u0438\u044F. \u0414\u043B\u044F \u043F\u043E\u0434\u0440\u043E\u0441\u0442\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u0441\u0442\u0443\u043F\u0430\u043B \u043D\u0430 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0442\u0435\u0437\u044E, \u044D\u0442\u043E \u0431\u044B\u043B\u043E \u043F\u0440\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u0435\u043C
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439 \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u043F\u0430\u043C\u044F\u0442\u0438 \u0438 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u043E\u0433\u043E
    \u0434\u0430\u0440\u0430.  ### \U0001F9EE \u041A\u0443\u0440\u044C\u0435\u0437\u044B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0439 
    - **\u041A\u043E\u043B\u0435\u0441\u043E \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    (\u0441\u0442\u0443\u043F\u0435\u043D\u0447\u0430\u0442\u044B\u0439 \u0432\u0430\u043B\u0438\u043A):**
    \u0421\u043E\u0437\u0434\u0430\u0432\u0430\u044F \u0441\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0430\u0440\u0438\u0444\u043C\u043E\u043C\u0435\u0442\u0440, \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043C\u043E\u0436\u043D\u043E \u0441\u0447\u0438\u0442\u0430\u0442\u044C
    \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u0436\u0435\u0441\u0442\u043A\u043E\u0433\u043E \u0434\u0438\u0441\u043A\u0430.
    \u0412\u043C\u0435\u0441\u0442\u043E \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0448\u0435\u0441\u0442\u0435\u0440\u0435\u043D\u043E\u043A \u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B
    \u0446\u0438\u043B\u0438\u043D\u0434\u0440 \u0441 \u0437\u0443\u0431\u0446\u0430\u043C\u0438
    \u0440\u0430\u0437\u043D\u043E\u0439 \u0434\u043B\u0438\u043D\u044B (9 \u0441\u0442\u0443\u043F\u0435\u043D\u0435\u0439),
    \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u043E \u043C\u0430\u0448\u0438\u043D\u0435
    \u0443\u043C\u043D\u043E\u0436\u0430\u0442\u044C \u0438 \u0434\u0435\u043B\u0438\u0442\u044C
    \u0432 \u0440\u0430\u0437\u044B \u0431\u044B\u0441\u0442\u0440\u0435\u0435, \u0447\u0435\u043C
    \u043B\u044E\u0431\u044B\u0435 \u043F\u0440\u0435\u0434\u044B\u0434\u0443\u0449\u0438\u0435
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430. \u041E\u043D \u043B\u0438\u0447\u043D\u043E
    \u043F\u0440\u0438\u0432\u0435\u0437 \u044D\u0442\u0443 \u0447\u0443\u0434\u043E-\u043C\u0430\u0448\u0438\u043D\u0443
    \u0432 \u041B\u043E\u043D\u0434\u043E\u043D \u0432 1673 \u0433\u043E\u0434\u0443
    \u0438 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B \u0444\u0443\u0440\u043E\u0440.
    - **\u0414\u0432\u043E\u0439\u043A\u0430 \u043A\u0430\u043A \u043A\u0430\u043C\u0435\u043D\u044C
    \u043F\u0440\u0435\u0442\u043A\u043D\u043E\u0432\u0435\u043D\u0438\u044F:** \u0415\u0433\u043E
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0435\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u2014 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435 \u2014 \u0431\u044B\u043B\u043E
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043E \u0432
    1684 \u0433\u043E\u0434\u0443 \u0432 \u0441\u0442\u0430\u0442\u044C\u0435, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043D\u0430\u0447\u0438\u043D\u0430\u043B\u0430\u0441\u044C \u0441... **\u043E\u043F\u0435\u0447\u0430\u0442\u043A\u0438**!
    \u0412 \u043D\u0435\u0439 \u0431\u044B\u043B\u0430 \u0434\u043E\u043F\u0443\u0449\u0435\u043D\u0430
    \u043E\u0448\u0438\u0431\u043A\u0430 \u043F\u0440\u0438 \u043D\u0430\u0431\u043E\u0440\u0435
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B. \u041A \u0441\u0447\u0430\u0441\u0442\u044C\u044E,
    \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u0431\u044B\u0441\u0442\u0440\u043E
    \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u043B\u0438\u0441\u044C \u0432 \u0441\u0443\u0442\u0438
    \u0434\u0435\u043B\u0430, \u043D\u043E \u0437\u0430\u0431\u0430\u0432\u043D\u043E,
    \u0447\u0442\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u043D\u043E\u0432\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438 \u0435\u0434\u0432\u0430 \u043D\u0435 \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u043B\u0430
    \u0442\u0438\u043F\u043E\u0433\u0440\u0430\u0444\u0441\u043A\u0430\u044F \u043D\u0435\u0431\u0440\u0435\u0436\u043D\u043E\u0441\u0442\u044C. 
    ### \U0001F5E3\uFE0F \u0414\u0438\u043F\u043B\u043E\u043C\u0430\u0442\u0438\u044F
    \u0438 \u043D\u0435\u043B\u0435\u043F\u044B\u0435 \u0441\u043B\u0443\u0445\u0438 
    - **\u0421\u043F\u0430\u0441\u0438\u0442\u0435\u043B\u044C \u0415\u0433\u0438\u043F\u0442\u0430:**
    \u0412 1672 \u0433\u043E\u0434\u0443 \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u041B\u044E\u0434\u043E\u0432\u0438\u043A\u0443
    XIV \u043F\u043B\u0430\u043D... \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u0442\u044C
    \u0415\u0433\u0438\u043F\u0435\u0442. \u0413\u043B\u0430\u0432\u043D\u043E\u0439
    \u0446\u0435\u043B\u044C\u044E \u044D\u0442\u043E\u0433\u043E \u0430\u0432\u0430\u043D\u0442\u044E\u0440\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0435\u043A\u0442\u0430 \u0431\u044B\u043B\u043E \u043E\u0442\u0432\u043B\u0435\u0447\u044C
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u044F
    \u043E\u0442 \u0440\u0430\u0437\u043E\u0440\u0435\u043D\u0438\u044F \u0433\u0435\u0440\u043C\u0430\u043D\u0441\u043A\u0438\u0445
    \u0437\u0435\u043C\u0435\u043B\u044C. \u041F\u043B\u0430\u043D \u0431\u044B\u043B
    \u043E\u0442\u0432\u0435\u0440\u0433\u043D\u0443\u0442, \u043D\u043E \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D
    \u0441\u043F\u0443\u0441\u0442\u044F \u0441\u0442\u043E \u043B\u0435\u0442 \u0440\u0435\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u043F\u043E\u0447\u0442\u0438 \u043F\u043E \u0442\u043E\u043C\u0443
    \u0436\u0435 \u043C\u0430\u0440\u0448\u0440\u0443\u0442\u0443. - **\u0428\u043F\u0438\u043E\u043D,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0431\u043E\u044F\u043B\u0438\u0441\u044C:**
    \u041F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0443\u044F \u043F\u043E
    \u0415\u0432\u0440\u043E\u043F\u0435 \u0432 1676 \u0433\u043E\u0434\u0443, \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u0437\u0430\u0435\u0445\u0430\u043B \u0432 \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u044E,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0432\u0438\u0434\u0430\u0442\u044C
    \u0421\u043F\u0438\u043D\u043E\u0437\u0443. \u0414\u0440\u0443\u0437\u044C\u044F
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430 \u0434\u043E\u043B\u0433\u043E
    \u043E\u0442\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u043B\u0438 \u0435\u0433\u043E
    \u043E\u0442 \u0432\u0441\u0442\u0440\u0435\u0447\u0438, \u043E\u043F\u0430\u0441\u0430\u044F\u0441\u044C,
    \u0447\u0442\u043E \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u2014 \u0442\u0430\u0439\u043D\u044B\u0439
    \u0448\u043F\u0438\u043E\u043D \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0433\u043E
    \u043A\u043D\u044F\u0437\u044F. \u0421\u043F\u0438\u043D\u043E\u0437\u0430 \u043F\u0440\u0438\u043D\u044F\u043B
    \u0433\u043E\u0441\u0442\u044F, \u043D\u043E \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C \u0441\u0442\u044B\u0434\u0438\u043B\u0441\u044F
    \u044D\u0442\u043E\u0433\u043E \u0432\u0438\u0437\u0438\u0442\u0430 (\u0438\u0437-\u0437\u0430
    \u0440\u0430\u0437\u043D\u0438\u0446\u044B \u0432 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0445
    \u0432\u0437\u0433\u043B\u044F\u0434\u0430\u0445) \u0438 \u043F\u043E\u0437\u0436\u0435
    \u043D\u0430\u0447\u0438\u0441\u0442\u043E \u043E\u0442\u0440\u0438\u0446\u0430\u043B,
    \u0447\u0442\u043E \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u043B
    \u0441 \u043D\u0438\u043C. - **\xAB\u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0441\u043A\u0438\u0439
    \u0424\u0430\u0443\u0441\u0442\xBB:** \u041F\u0440\u0438 \u0433\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0441\u043A\u043E\u043C
    \u0434\u0432\u043E\u0440\u0435 \u0437\u0430 \u043D\u0438\u043C \u0437\u0430\u043A\u0440\u0435\u043F\u0438\u043B\u0430\u0441\u044C
    \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044F \u043C\u0430\u0433\u0430
    \u0438 \u0430\u043B\u0445\u0438\u043C\u0438\u043A\u0430. \u041A\u043E\u0433\u0434\u0430
    \u043E\u043D \u0432 1679 \u0433\u043E\u0434\u0443 \u0443\u0433\u043E\u0432\u043E\u0440\u0438\u043B
    \u0433\u0435\u0440\u0446\u043E\u0433\u0430 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u044C
    \u0433\u043E\u0440\u043D\u044B\u0439 \u0437\u0430\u0432\u043E\u0434, \u043C\u0435\u0441\u0442\u043D\u044B\u0435
    \u0436\u0438\u0442\u0435\u043B\u0438 \u0431\u044B\u043B\u0438 \u0443\u0432\u0435\u0440\u0435\u043D\u044B,
    \u0447\u0442\u043E \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043D\u0430\u043C\u0435\u0440\u0435\u0432\u0430\u0435\u0442\u0441\u044F
    \u043F\u0440\u0438 \u043F\u043E\u043C\u043E\u0449\u0438 \u0430\u0434\u0441\u043A\u0438\u0445
    \u0441\u0438\u043B \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0442\u044C
    \u0441\u0432\u0438\u043D\u0435\u0446 \u0432 \u0437\u043E\u043B\u043E\u0442\u043E.
    \u0421\u043B\u0443\u0445\u0438 \u0434\u043E\u0448\u043B\u0438 \u0434\u043E \u0442\u043E\u0433\u043E,
    \u0447\u0442\u043E \u043A\u043D\u044F\u0437\u044C \u0434\u0430\u043B \u0435\u043C\u0443
    \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435 \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u043D\u0430 \xAB\u043E\u043F\u044B\u0442\u044B \u0441 \u043C\u0435\u0442\u0430\u043B\u043B\u0430\u043C\u0438\xBB,
    \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u0435\u0441\u0435\u0447\u044C \u043F\u0430\u043D\u0438\u043A\u0443. 
    ### \U0001F3AD \u042D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0438  - **\u041F\u0430\u0440\u0438\u043A-\u043A\u043E\u043F\u0438\u043B\u043A\u0430:**
    \u041A\u0430\u043A \u0438 \u043C\u043D\u043E\u0433\u0438\u0435 \u0434\u0436\u0435\u043D\u0442\u043B\u044C\u043C\u0435\u043D\u044B
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u043D\u043E\u0441\u0438\u043B \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u043F\u0430\u0440\u0438\u043A. \u0418 \u0443 \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u0430
    \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0430 **\u043F\u0440\u044F\u0442\u0430\u0442\u044C
    \u0434\u0435\u043D\u044C\u0433\u0438** \u0432 \u0441\u043A\u043B\u0430\u0434\u043A\u0430\u0445
    \u043F\u0430\u0440\u0438\u043A\u0430! \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B\u0438, \u043A\u0430\u043A
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043E\u0436\u0438\u0432\u043B\u0435\u043D\u043D\u044B\u0445
    \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0439 \u043E\u043D \u0432\u0434\u0440\u0443\u0433
    \u043D\u0430\u0447\u0438\u043D\u0430\u043B \u0440\u044B\u0442\u044C\u0441\u044F
    \u0432 \u0441\u0432\u043E\u0435\u0439 \u0448\u0435\u0432\u0435\u043B\u044E\u0440\u0435,
    \u0447\u0442\u043E\u0431\u044B \u0434\u043E\u0441\u0442\u0430\u0442\u044C \u043C\u043E\u043D\u0435\u0442\u0443
    \u0438 \u043F\u0440\u043E\u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043A\u0430\u043A\u043E\u0439-\u043D\u0438\u0431\u0443\u0434\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0447\u0435\u0440\u0442\u0435\u0436, \u043D\u0430\u0440\u0438\u0441\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043D\u0430 \u043D\u0435\u0439. - **\u0423\u0447\u0435\u043D\u044B\u0439 \u0434\u043E
    \u043C\u043E\u0437\u0433\u0430 \u043A\u043E\u0441\u0442\u0435\u0439:** \u041E\u043D
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 \u043A\u0440\u0435\u0441\u043B\u0435,
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u043E\u043C
    \u043D\u0430 \u043A\u043E\u043B\u0435\u0441\u0438\u043A\u0430\u0445, \u0447\u0442\u043E\u0431\u044B
    \u043A\u0430\u0442\u0430\u0442\u044C\u0441\u044F \u043F\u043E \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u0443,
    \u043D\u0435 \u0432\u0441\u0442\u0430\u0432\u0430\u044F. \u0415\u0433\u043E \u043A\u0430\u0431\u0438\u043D\u0435\u0442
    \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0437\u0430\u0445\u043B\u0430\u043C\u043B\u0435\u043D
    \u0431\u0443\u043C\u0430\u0433\u0430\u043C\u0438, \u0447\u0442\u043E \u043E\u043D
    \u0447\u0430\u0441\u0442\u043E \u0437\u0430\u0441\u044B\u043F\u0430\u043B \u043F\u0440\u044F\u043C\u043E
    \u0437\u0430 \u0441\u0442\u043E\u043B\u043E\u043C, \u0430 \u043F\u0440\u043E\u0441\u044B\u043F\u0430\u044F\u0441\u044C,
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u043F\u0438\u0441\u0430\u0442\u044C,
    \u043D\u0435 \u0434\u0435\u043B\u0430\u044F \u0440\u0430\u0437\u043B\u0438\u0447\u0438\u044F
    \u043C\u0435\u0436\u0434\u0443 \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C
    \u0441\u0443\u0442\u043E\u043A. - **\u041B\u044E\u0431\u043E\u0432\u044C \u043A
    \u041A\u0438\u0442\u0430\u044E:** \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D
    \u043A\u0438\u0442\u0430\u0439\u0441\u043A\u043E\u0439 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043E\u0439,
    \u0447\u0442\u043E \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u043B \u043E\u0431\u0443\u0447\u0438\u0442\u044C
    \u043A\u0438\u0442\u0430\u0439\u0446\u0435\u0432 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0430 \u0443 \u043D\u0438\u0445
    \u043F\u0435\u0440\u0435\u043D\u044F\u0442\u044C \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E.
    \u041E\u043D \u0434\u0430\u0436\u0435 \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B
    \u043F\u0440\u043E\u0435\u043A\u0442 \u043E\u0442\u043F\u0440\u0430\u0432\u043A\u0438
    \u0432 \u041A\u0438\u0442\u0430\u0439 \u043C\u0438\u0441\u0441\u0438\u043E\u043D\u0435\u0440\u043E\u0432-\u0443\u0447\u0435\u043D\u044B\u0445
    \u0438 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0440\u0443\u0447\u043D\u043E
    \u043D\u0430\u0440\u0438\u0441\u043E\u0432\u0430\u043B \u0433\u0435\u0440\u0431
    \u0434\u043B\u044F \u0431\u0443\u0434\u0443\u0449\u0435\u0439 \u043A\u0438\u0442\u0430\u0439\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A.  ###
    \U0001F974 \u041F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438 \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u0435 \u043D\u0435\u0443\u0440\u044F\u0434\u0438\u0446\u044B 
    - **\u0427\u0435\u0440\u043D\u044B\u0439 \u0441\u043F\u0438\u0441\u043E\u043A
    \u043A\u043E\u0440\u043E\u043B\u044F:** \u041A\u043E\u0433\u0434\u0430 \u0433\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0441\u043A\u0438\u0439
    \u0433\u0435\u0440\u0446\u043E\u0433 \u0441\u0442\u0430\u043B \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u043C
    \u043A\u043E\u0440\u043E\u043B\u0435\u043C \u0413\u0435\u043E\u0440\u0433\u043E\u043C
    I, \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u041B\u043E\u043D\u0434\u043E\u043D, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C\u0441\u044F
    \u043C\u043E\u043D\u0430\u0440\u0445\u0443. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043A\u043E\u0440\u043E\u043B\u044C \u0432\u044B\u0447\u0435\u0440\u043A\u043D\u0443\u043B
    \u0435\u0433\u043E \u0438\u043C\u044F \u0438\u0437 \u0441\u043F\u0438\u0441\u043A\u0430
    \u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u044B\u0445, \u043F\u0440\u0438\u043F\u0438\u0441\u0430\u0432
    \u043D\u0430 \u043F\u043E\u043B\u044F\u0445: *\xAB\u041E\u043D \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0441\u0442\u0430\u0440 \u0438 \u0432\u0440\u0435\u0434\u0435\u043D\xBB*. \u0423\u0447\u0435\u043D\u044B\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043D\u0430 \u0433\u0435\u0440\u0446\u043E\u0433\u043E\u0432 40 \u043B\u0435\u0442,
    \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0432 \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0435
    \u043D\u0438 \u0441 \u0447\u0435\u043C. - **\u041D\u0435\u0441\u043E\u0441\u0442\u043E\u044F\u0432\u0448\u0438\u0439\u0441\u044F
    \u0441\u043A\u0443\u043B\u044C\u043F\u0442\u043E\u0440:** \u0412 1689 \u0433\u043E\u0434\u0443
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043F\u043E\u0441\u0435\u0442\u0438\u043B
    \u0420\u0438\u043C \u0438 \u0431\u044B\u043B \u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D
    \u0434\u0440\u0435\u0432\u043D\u0438\u043C\u0438 \u0441\u0442\u0430\u0442\u0443\u044F\u043C\u0438.
    \u041E\u043D \u0441\u0440\u043E\u0447\u043D\u043E \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u043F\u0438\u0441\u044C\u043C\u043E \u0434\u043E\u043C\u043E\u0439 \u0441 \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043F\u0440\u0438\u0441\u043B\u0430\u0442\u044C \u0435\u043C\u0443... **\u043C\u043E\u043B\u043E\u0442\u043E\u043A
    \u0438 \u0437\u0443\u0431\u0438\u043B\u043E**. \u041E\u043D \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0435
    \u0432\u0435\u0440\u0438\u043B, \u0447\u0442\u043E \u0441\u043C\u043E\u0436\u0435\u0442
    \u0441\u0430\u043C \u0432\u044B\u0440\u0435\u0437\u0430\u0442\u044C \u0438\u0437
    \u043C\u0440\u0430\u043C\u043E\u0440\u0430 \u0441\u043A\u0443\u043B\u044C\u043F\u0442\u0443\u0440\u0443,
    \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u044E\u0449\u0443\u044E \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u0435
    \u0448\u0435\u0434\u0435\u0432\u0440\u044B.  ### \U0001F56F\uFE0F \u041F\u043E\u0445\u043E\u0440\u043E\u043D\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043D\u0435 \u0431\u044B\u043B\u043E 
    - **\u0423\u043A\u0440\u0430\u0434\u0435\u043D\u043D\u043E\u0435 \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u0435:**
    \u041F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443 \u0443 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u043D\u0435 \u0431\u044B\u043B\u043E \u0441\u0435\u043C\u044C\u0438, \u0435\u0433\u043E
    \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u044B \u043F\u0440\u043E\u0448\u043B\u0438
    \u043F\u043E\u0447\u0442\u0438 \u043D\u0435\u0437\u0430\u043C\u0435\u0442\u043D\u043E.
    \u041F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u044B\u0435 \u043D\u0435 \u044F\u0432\u0438\u043B\u0438\u0441\u044C,
    \u0438 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442, \u0437\u0430\u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0432 \u0446\u0435\u0440\u043A\u043E\u0432\u043D\u043E\u0439 \u043A\u043D\u0438\u0433\u0435,
    \u2014 \u044D\u0442\u043E \u0442\u043E, \u0447\u0442\u043E \u0437\u0430 \u0433\u0440\u043E\u0431\u043E\u043C
    \u0448\u0435\u043B \u0442\u043E\u043B\u044C\u043A\u043E \u0435\u0433\u043E \u0441\u0442\u0430\u0440\u044B\u0439
    \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u044C. \u041D\u043E \u0441\u0430\u043C\u043E\u0435
    \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u043E\u0435 \u0441\u043B\u0443\u0447\u0438\u043B\u043E\u0441\u044C
    \u043F\u043E\u0437\u0436\u0435: **\u0435\u0433\u043E \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u0435
    \u0431\u044B\u043B\u043E \u0443\u043A\u0440\u0430\u0434\u0435\u043D\u043E**!
    \u0427\u0435\u0440\u0435\u0437 \u043C\u043D\u043E\u0433\u043E \u043B\u0435\u0442,
    \u043A\u043E\u0433\u0434\u0430 \u0446\u0435\u0440\u043A\u043E\u0432\u044C \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u043B\u0438
    \u043F\u043E\u0441\u043B\u0435 \u0432\u043E\u0439\u043D\u044B, \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u0438
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B\u0438 \u043C\u043E\u0433\u0438\u043B\u044C\u043D\u0443\u044E
    \u043F\u043B\u0438\u0442\u0443 \u043F\u043E\u0434 \u043A\u043E\u0440\u043D\u044F\u043C\u0438
    \u0441\u0442\u0430\u0440\u043E\u0433\u043E \u0434\u0443\u0431\u0430 \u043D\u0430
    \u043E\u043A\u0440\u0430\u0438\u043D\u0435 \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0430
    \u2014 \u0432\u0438\u0434\u0438\u043C\u043E, \u0435\u0451 \u0440\u0435\u0448\u0438\u043B\u0438
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0432
    \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u0430
    \u0434\u043B\u044F \u043C\u043E\u0441\u0442\u043E\u0432\u043E\u0439. - **\u041C\u043E\u0433\u0438\u043B\u0430
    \u0441 \u043E\u0434\u043D\u043E\u0439 \u043D\u0430\u0434\u043F\u0438\u0441\u044C\u044E:**
    \u041D\u0430 \u043D\u044B\u043D\u0435\u0448\u043D\u0435\u043C \u043F\u0430\u043C\u044F\u0442\u043D\u0438\u043A\u0435
    \u0432\u044B\u0431\u0438\u0442\u0430 \u0432\u0441\u0435\u0433\u043E \u043E\u0434\u043D\u0430
    \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u0430\u044F \u0444\u0440\u0430\u0437\u0430:
    **\xABOSSA LEIBNITII\xBB** (\xAB\u041F\u0440\u0430\u0445 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430\xBB).
    \u041D\u0438 \u0434\u0430\u0442 \u0436\u0438\u0437\u043D\u0438, \u043D\u0438
    \u0442\u0438\u0442\u0443\u043B\u043E\u0432, \u043D\u0438 \u0437\u0432\u0430\u043D\u0438\u0439
    \u2014 \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0435
    \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0435 \u043E \u0442\u043E\u043C,
    \u043A\u0442\u043E \u043B\u0435\u0436\u0438\u0442 \u0432 \u0437\u0435\u043C\u043B\u0435. 
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u0431\u044B\u043B \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C: \u043E\u043D \u043C\u043E\u0433
    \u043F\u043E\u0442\u0435\u0440\u044F\u0442\u044C \u043A\u0430\u0440\u0435\u0442\u0443
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F, \u0441\u043F\u043E\u0440\u0438\u0442\u044C
    \u0441 \u043A\u043E\u0440\u043E\u043B\u044F\u043C\u0438 \u043E \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0435
    \u0432 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F\u0445 \u0438 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u0442\u044C\u0441\u044F
    \u0430\u043B\u0445\u0438\u043C\u0438\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u043D\u0435
    \u043C\u0430\u0433\u0438\u0435\u0439, \u0430 \u0440\u0430\u043D\u043D\u0435\u0439
    \u0445\u0438\u043C\u0438\u0435\u0439. \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C
    \u2014 \u044D\u0442\u043E \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0439
    \u0447\u0435\u0440\u043D\u043E\u0432\u0438\u043A \u0432\u0435\u043B\u0438\u043A\u043E\u0439
    \u043A\u043D\u0438\u0433\u0438, \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D
    \u0442\u0430\u043A \u0438 \u043D\u0435 \u0443\u0441\u043F\u0435\u043B \u0434\u043E\u043F\u0438\u0441\u0430\u0442\u044C."
