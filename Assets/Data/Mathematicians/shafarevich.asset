  personalLifeRu: 
  personalLifeEn: 
  shortBioRu: "\u0418\u0301\u0433\u043E\u0440\u044C \u0420\u043E\u0441\u0442\u0438\u0441\u043B\u0430\u0301\u0432\u043E\u0432\u0438\u0447
    \u0428\u0430\u0444\u0430\u0440\u0435\u0301\u0432\u0438\u0447\_\u2014 \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u0438\u0439
    \u0438 \u0440\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0434\u043E\u043A\u0442\u043E\u0440 \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A, \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440,
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A. \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u044B
    \u0430\u043B\u0433\u0435\u0431\u0440\u0435, \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B \u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u041B\u0430\u0443\u0440\u0435\u0430\u0442
    \u041B\u0435\u043D\u0438\u043D\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    (1959). \u0418\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0442\u0430\u043A\u0436\u0435
    \u043A\u0430\u043A \u0434\u0438\u0441\u0441\u0438\u0434\u0435\u043D\u0442, \u043F\u0443\u0431\u043B\u0438\u0446\u0438\u0441\u0442,
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439 \u0434\u0435\u044F\u0442\u0435\u043B\u044C."
