    \u0434\u043B\u044F \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440
    \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.  ### \U0001F4D0 \u0410\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F  \u0412 1960-\u0445 \u0433\u043E\u0434\u0430\u0445
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447 \u0441\u0442\u0430\u043B
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0438\u043E\u043D\u0435\u0440\u043E\u0432
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u044F \u043D\u043E\u0432\u044B\u0445
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u0435\u0442\u043E\u0434\u043E\u0432 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0441\u0445\u0435\u043C \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0432 \u0421\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u043C
    \u0421\u043E\u044E\u0437\u0435.  *   **\u041A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439:** \u041E\u043D
    \u043E\u0441\u043D\u043E\u0432\u0430\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0431\u044B\u043B\u0438 \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u044B
