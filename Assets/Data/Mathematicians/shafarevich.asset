    12 \u043B\u0435\u0442 \u043E\u043D \u0443\u0432\u043B\u0435\u043A\u0441\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439, \u0430 \u0437\u0430\u0442\u0435\u043C,
    \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E \u0432 14 \u043B\u0435\u0442,
    \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0438 \u0437\u0430\u043F\u043E\u0435\u043C \u0438\u0437\u0443\u0447\u0438\u043B
    \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0439 \u043A\u0443\u0440\u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0421\u0440\u0435\u0434\u0438 \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u043A\u043E\u0432
    \u0431\u044B\u043B\u0438 \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u043E\u0441\u043B\u0443\u0436\u0438\u0442\u0435\u043B\u0438,
    \u043D\u043E \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438, \u043A\u0430\u043A
    \u0438 \u043C\u043D\u043E\u0433\u0438\u0435 \u0438\u0445 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438,
    \u0431\u044B\u043B\u0438 \u043D\u0435\u0432\u0435\u0440\u0443\u044E\u0449\u0438\u043C\u0438,
    \u0445\u043E\u0442\u044F \u0438 \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u043B\u0438
    \u0441\u0432\u044F\u0437\u044C \u0441 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043E\u0439
    \u043F\u0440\u0430\u0432\u043E\u0441\u043B\u0430\u0432\u0438\u044F.  ### \U0001F393
    \u041F\u0443\u0442\u044C \u0432 \u041D\u0430\u0443\u043A\u0443: \u041E\u0442
    \u0412\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434\u0430 \u0434\u043E
    \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430  *   **\u0421\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0443\u0447\u0435\u0431\u0430:** \u0423\u0436\u0435 \u0432 8-\u043C \u043A\u043B\u0430\u0441\u0441\u0435
    \u043D\u0430 \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447\u0430 \u043E\u0431\u0440\u0430\u0442\u0438\u043B\u0438
    \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u041C\u0413\u0423. \u041A 15 \u0433\u043E\u0434\u0430\u043C \u043E\u043D \u0441\u0434\u0430\u043B
    \u044D\u043A\u0441\u0442\u0435\u0440\u043D\u043E\u043C \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u044B
    \u0437\u0430 \u0432\u0435\u0441\u044C \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0439
    \u043A\u0443\u0440\u0441 \u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u043D\u0430 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442 \u041C\u0413\u0423. \u041F\u043E\u043B\u043D\u044B\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0439
    \u043A\u0443\u0440\u0441 \u043E\u043D \u043F\u0440\u043E\u0448\u0435\u043B \u0432\u0441\u0435\u0433\u043E
    \u0437\u0430 \u0434\u0432\u0430 \u0433\u043E\u0434\u0430 \u0438 \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0432 **1940
    \u0433\u043E\u0434\u0443** \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    17 \u043B\u0435\u0442, \u043F\u043E\u043B\u0443\u0447\u0430\u044F \u043D\u0430
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u043C \u043A\u0443\u0440\u0441\u0435
    \u0421\u0442\u0430\u043B\u0438\u043D\u0441\u043A\u0443\u044E \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E.
    *   **\u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435:**
    \u0415\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044F\u043C\u0438
    \u0441\u0442\u0430\u043B\u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 **\u0411.\u041D.
    \u0414\u0435\u043B\u043E\u043D\u0435** (\u043D\u0430\u043F\u0440\u0430\u0432\u0438\u043B
    \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u0447\u0438\u0441\u0435\u043B) \u0438
    **\u0410.\u0413. \u041A\u0443\u0440\u043E\u0448** (\u0432 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0413\u0430\u043B\u0443\u0430). \u0418\u0445 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u043E \u0441\u0444\u0435\u0440\u0443
    \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432 \u043D\u0430
    \u0434\u043E\u043B\u0433\u0438\u0435 \u0433\u043E\u0434\u044B. *   **\u0421\u0430\u043C\u044B\u0439
    \u043C\u043E\u043B\u043E\u0434\u043E\u0439 \u0434\u043E\u043A\u0442\u043E\u0440
    \u043D\u0430\u0443\u043A:**     *   \u0412 **1942 \u0433\u043E\u0434\u0443**,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 **19 \u043B\u0435\u0442**,
    \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E.     *   \u0412
    **1946 \u0433\u043E\u0434\u0443**, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    **23 \u043B\u0435\u0442**, \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E. \u042D\u0442\u043E
    \u0431\u044B\u043B \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0443\u0441\u043F\u0435\u0445, \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0432\u0448\u0438\u0439
    \u0435\u0433\u043E \u043A\u0430\u043A \u043E\u0434\u043D\u043E\u0433\u043E \u0438\u0437
    \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0441\u0442\u0440\u0430\u043D\u044B.  ### \U0001F3E2 \u041C\u0435\u0441\u0442\u0430
    \u0420\u0430\u0431\u043E\u0442\u044B \u0438 \u041F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0430\u044F
    \u0414\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C  *  
    **\u041A\u0430\u0440\u044C\u0435\u0440\u0430 \u0432 \u041C\u0418\u0410\u041D:**
    \u0421 1943 \u0433\u043E\u0434\u0430 (\u043F\u043E \u0434\u0440\u0443\u0433\u0438\u043C
    \u0434\u0430\u043D\u043D\u044B\u043C, \u0441 1946) \u0438 \u0434\u043E \u043A\u043E\u043D\u0446\u0430
    \u0436\u0438\u0437\u043D\u0438 \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447
    \u0431\u044B\u043B \u0441\u0432\u044F\u0437\u0430\u043D \u0441 **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u043E\u043C \u0438\u043C\u0435\u043D\u0438
    \u0412.\u0410. \u0421\u0442\u0435\u043A\u043B\u043E\u0432\u0430 (\u041C\u0418\u0410\u041D)**
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A \u0421\u0421\u0421\u0420/\u0420\u0410\u041D.
    \u0421 **1960 \u043F\u043E 1995 \u0433\u043E\u0434** \u043E\u043D \u0437\u0430\u0432\u0435\u0434\u043E\u0432\u0430\u043B
    \u0442\u0430\u043C \u043E\u0442\u0434\u0435\u043B\u043E\u043C \u0430\u043B\u0433\u0435\u0431\u0440\u044B,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0441\u0442\u0430\u043B \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u043C
    \u0438 \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u043E\u043C \u0420\u0410\u041D.
    *   **\u041F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435
    \u0432 \u041C\u0413\u0423:** \u0421 **1943 \u043F\u043E 1975 \u0433\u043E\u0434**
    \u043E\u043D \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B \u043D\u0430
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0435 \u041C\u0413\u0423,
    \u0433\u0434\u0435 \u0432 1953 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0437\u0432\u0430\u043D\u0438\u0435 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430.
    \u0415\u0433\u043E \u043B\u0435\u043A\u0446\u0438\u0438 \u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043D\u0430\u0443\u0447\u043D\u044B\u0439 \u0441\u0435\u043C\u0438\u043D\u0430\u0440
    \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u0430\u043B\u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432
    \u0438 \u043A\u043E\u043B\u043B\u0435\u0433. \u0412 1975 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0431\u044B\u043B **\u0443\u0432\u043E\u043B\u0435\u043D \u0438\u0437
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430** \u0438\u0437-\u0437\u0430
    \u0441\u0432\u043E\u0435\u0439 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E-\u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438, \u043E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u0441\u0435\u043C\u0438\u043D\u0430\u0440 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 \u0441\u0442\u0435\u043D\u0430\u0445
    \u041C\u0418\u0410\u041D\u0430.  ### \U0001F52C \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0414\u0440\u0443\u0433\u0438\u043C\u0438 \u0423\u0447\u0435\u043D\u044B\u043C\u0438
    \u0438 \u041D\u0430\u0443\u0447\u043D\u0430\u044F \u0428\u043A\u043E\u043B\u0430 
    *   **\u0421\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C \u0448\u043A\u043E\u043B\u044B:**
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447 \u0431\u044B\u043B \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u0443\u0447\u0435\u043D\u044B\u043C, \u043D\u043E \u0438 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0446\u0435\u043B\u043E\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u044B
    \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B. \u0415\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438 \u0435\u0433\u043E \xAB\u041C\u043E\u0446\u0430\u0440\u0442\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB. *   **\u0423\u0447\u0435\u043D\u0438\u043A\u0438:**
    \u041E\u043D \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043B \u0431\u043E\u043B\u0435\u0435
    30 \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u043E\u0432 \u043D\u0430\u0443\u043A,
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u0441\u0442\u0430\u043B\u0438
    \u0434\u043E\u043A\u0442\u043E\u0440\u0430\u043C\u0438 \u043D\u0430\u0443\u043A
    \u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438
    \u043C\u0438\u0440\u0430. \u0421\u0440\u0435\u0434\u0438 \u0435\u0433\u043E \u0441\u0430\u043C\u044B\u0445
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432
    \u2014 **\u042E.\u0418. \u041C\u0430\u043D\u0438\u043D, \u0415.\u0421. \u0413\u043E\u043B\u043E\u0434,
    \u0410.\u0418. \u041A\u043E\u0441\u0442\u0440\u0438\u043A\u0438\u043D, \u0421.\u042E.
    \u0410\u0440\u0430\u043A\u0435\u043B\u043E\u0432, \u0410.\u041D. \u0422\u044E\u0440\u0438\u043D,
    \u0410.\u041D. \u041F\u0430\u0440\u0448\u0438\u043D** \u0438 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0434\u0440\u0443\u0433\u0438\u0435. *   **\u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435:** \u0415\u0433\u043E
    \u0442\u0440\u0443\u0434\u044B \u0431\u044B\u043B\u0438 \u0432\u044B\u0441\u043E\u043A\u043E
    \u043E\u0446\u0435\u043D\u0435\u043D\u044B \u0437\u0430 \u0440\u0443\u0431\u0435\u0436\u043E\u043C.
    \u041E\u043D \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C \u0438\u043B\u0438
    \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u043C\u043D\u043E\u0433\u0438\u0445 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0445
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    **\u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0435 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E (1981)**, **\u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A \u0421\u0428\u0410
    (1974)**, \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u0434\u0435\u0438
    \u041B\u0438\u043D\u0447\u0435\u0438 \u0432 \u0418\u0442\u0430\u043B\u0438\u0438
    \u0438 \u0413\u0435\u0440\u043C\u0430\u043D\u0441\u043A\u0443\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E
    \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u043E\u0438\u0441\u043F\u044B\u0442\u0430\u0442\u0435\u043B\u0435\u0439
    \xAB\u041B\u0435\u043E\u043F\u043E\u043B\u044C\u0434\u0438\u043D\u0430\xBB. 
    ### \U0001F56F\uFE0F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0413\u043E\u0434\u044B
    \u0438 \u0421\u043C\u0435\u0440\u0442\u044C  *   **\u0414\u043E\u043B\u0433\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C:** \u0418\u0433\u043E\u0440\u044C \u0420\u043E\u0441\u0442\u0438\u0441\u043B\u0430\u0432\u043E\u0432\u0438\u0447
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    **19 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 2017 \u0433\u043E\u0434\u0430**
    \u0432 \u041C\u043E\u0441\u043A\u0432\u0435 \u043D\u0430 94-\u043C \u0433\u043E\u0434\u0443
    \u0436\u0438\u0437\u043D\u0438. *   **\u041F\u043E\u0445\u043E\u0440\u043E\u043D\u044B:**
    \u041E\u043D \u0431\u044B\u043B \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u043D\u0430 **\u0422\u0440\u043E\u0435\u043A\u0443\u0440\u043E\u0432\u0441\u043A\u043E\u043C
    \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435** \u0432 \u041C\u043E\u0441\u043A\u0432\u0435.
    *   **\u0421\u0435\u043C\u044C\u044F:** \u0423 \u043D\u0435\u0433\u043E \u043E\u0441\u0442\u0430\u043B\u0441\u044F
    \u0441\u044B\u043D, **\u0410\u043D\u0434\u0440\u0435\u0439 \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447**
    (\u0440\u043E\u0434. 1963), \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0448\u0435\u043B
    \u043F\u043E \u0441\u0442\u043E\u043F\u0430\u043C \u043E\u0442\u0446\u0430 \u0438
    \u0441\u0442\u0430\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u0420\u0410\u041D \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u041C\u0413\u0423.  \u0412 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u0442\u0430\u043A\u0436\u0435 \u0435\u0441\u0442\u044C \u044F\u0440\u043A\u0430\u044F
    \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0430 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0434\u0438\u0441\u0441\u0438\u0434\u0435\u043D\u0442\u0441\u0442\u0432\u0430.
    \u041C\u043D\u043E\u0433\u043E\u0435 \u0432 \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0435\u0433\u043E \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435 \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0435\u0439, \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E
    \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u043E \u043D\u0430 \u0435\u0433\u043E
    \u043F\u0443\u0431\u043B\u0438\u0446\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u0438 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u0443\u044E
    \u043F\u043E\u0437\u0438\u0446\u0438\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u0434\u0435\u043B\u0430\u043B\u0430 \u0435\u0433\u043E \u0444\u0438\u0433\u0443\u0440\u043E\u0439,
    \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u0432\u043F\u0438\u0441\u0430\u0432\u0448\u0435\u0439\u0441\u044F
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043D\u043E \u0438
    \u0440\u0443\u0441\u0441\u043A\u043E\u0439 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438 XX \u0432\u0435\u043A\u0430."
  personalLifeEn: 
  shortBioRu: "\u0418\u0433\u043E\u0440\u044C \u0420\u043E\u0441\u0442\u0438\u0441\u043B\u0430\u0432\u043E\u0432\u0438\u0447
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447 \u2014 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439 \u0434\u0435\u044F\u0442\u0435\u043B\u044C.
    \u0415\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442
    \u043A\u0430\u043A \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0435
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B, \u0442\u0430\u043A
    \u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u0443\u044E \u043F\u0443\u0431\u043B\u0438\u0446\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043F\u043E\u0437\u0438\u0446\u0438\u044E \u0432 \u043F\u043E\u0437\u0434\u043D\u0438\u0439
    \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u0438\u0439 \u0438 \u043F\u043E\u0441\u0442\u0441\u043E\u0432\u0435\u0442\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434\u044B.  \u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0435
    \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u0435\u0445\u0438 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u0443\u0442\u0438:  ### \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 (1923\u20131940-\u0435)
    *   **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B**: \u0420\u043E\u0434\u0438\u043B\u0441\u044F
    3 \u0438\u044E\u043D\u044F 1923 \u0433\u043E\u0434\u0430 \u0432 \u0416\u0438\u0442\u043E\u043C\u0438\u0440\u0435
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u0432\u043E\u0435\u043D\u043D\u043E\u0433\u043E
    \u044E\u0440\u0438\u0441\u0442\u0430. \u0412 \u0440\u0430\u043D\u043D\u0435\u043C
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u041C\u043E\u0441\u043A\u0432\u0443, \u0433\u0434\u0435 \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438. \u0412 \u0433\u043E\u0434\u044B
    \u0411\u043E\u043B\u044C\u0448\u043E\u0433\u043E \u0442\u0435\u0440\u0440\u043E\u0440\u0430
    \u0435\u0433\u043E \u043E\u0442\u0435\u0446 \u0431\u044B\u043B \u0440\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u0440\u043E\u0432\u0430\u043D,
    \u0447\u0442\u043E, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u043E
    \u043D\u0430 \u0435\u0433\u043E \u043C\u0438\u0440\u043E\u0432\u043E\u0437\u0437\u0440\u0435\u043D\u0438\u0435.
    *   **\u041D\u0430\u0443\u0447\u043D\u044B\u0439 \u0441\u0442\u0430\u0440\u0442**:
    \u0412 16 \u043B\u0435\u0442 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u041C\u0413\u0423, \u0430 \u0443\u0436\u0435 \u0432 1940 \u0433\u043E\u0434\u0443,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C,
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u044E
    \u043F\u0435\u0440\u0432\u0443\u044E \u043D\u0430\u0443\u0447\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443. \u041E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0432 1943
    \u0433\u043E\u0434\u0443, \u0432 \u0440\u0430\u0437\u0433\u0430\u0440 \u0432\u043E\u0439\u043D\u044B,
    \u0438 \u0441\u0440\u0430\u0437\u0443 \u0432\u043E\u0448\u0435\u043B \u0432 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u0443\u0440\u0443
    \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0411\u043E\u0440\u0438\u0441\u0430 \u0414\u0435\u043B\u043E\u043D\u0435. \u041A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0432 1946 \u0433\u043E\u0434\u0443, \u0430 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u2014 \u0432 1953 \u0433\u043E\u0434\u0443 (\u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0434\u043E\u043A\u0442\u043E\u0440\u0430 \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A \u0431\u044B\u043B\u0430 \u043F\u0440\u0438\u0441\u0443\u0436\u0434\u0435\u043D\u0430
    \u0437\u0430 \u0441\u043E\u0432\u043E\u043A\u0443\u043F\u043D\u043E\u0441\u0442\u044C
    \u0440\u0430\u0431\u043E\u0442 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B).  ### \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F (1950\u20131970-\u0435)
    \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u0441\u0442\u0430\u043B
    \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C \u0435\u0433\u043E \u043C\u0438\u0440\u043E\u0432\u043E\u0433\u043E
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435:
    *   **\u0412\u043A\u043B\u0430\u0434 \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0443**:
    \u041E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0443\u043F\u043F \u0413\u0430\u043B\u0443\u0430
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445 \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u0439,
    \u0441\u043E\u0437\u0434\u0430\u0432 \u0442\u0435\u043E\u0440\u0438\u044E, \u043F\u043E\u0437\u0436\u0435
    \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u0443\u044E \u0435\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C
    (\u0442\u0435\u043E\u0440\u0438\u044F \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447\u0430
    \u2014 \u0413\u043E\u043B\u043E\u0434\u0430). \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0414\u0436\u043E\u043D\u043E\u043C \u0422\u0435\u0439\u0442\u043E\u043C
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u043E \u043F\u043E\u043B\u044F\u0445 \u043A\u043B\u0430\u0441\u0441\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C.
    *   **\u0420\u0435\u0448\u0435\u043D\u0438\u0435 \u043F\u0440\u043E\u0431\u043B\u0435\u043C**:
    \u0414\u043E\u043A\u0430\u0437\u0430\u043B \u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u043E \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0441\u0442\u0438
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0432\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u043F\u043E\u043B\u0435\u0439, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0432\u043D\u0435\u0441
    \u0440\u0435\u0448\u0430\u044E\u0449\u0438\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
    \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0438
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0413\u0430\u043B\u0443\u0430. \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439 \u0438
    \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u044F\u043C \u0433\u0440\u0443\u043F\u043F
    \u0441\u0442\u0430\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u0446\u0435\u043B\u044B\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0448\u043A\u043E\u043B.
    *   **\u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435**: \u0411\u044B\u043B
    \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u0410\u041D \u0421\u0421\u0421\u0420 (1958), \u0430 \u043F\u043E\u0437\u0436\u0435
    \u2014 \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u043C\u043D\u043E\u0433\u0438\u0445 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u043C\u0438\u0440\u0430 (\u0421\u0428\u0410, \u0424\u0440\u0430\u043D\u0446\u0438\u044F,
    \u0410\u043D\u0433\u043B\u0438\u044F). \u0412 1970 \u0433\u043E\u0434\u0443 \u0431\u044B\u043B
    \u0432\u0438\u0446\u0435-\u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u044E\u0437\u0430.  ### \u041E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0438
    \u0434\u0438\u0441\u0441\u0438\u0434\u0435\u043D\u0442\u0441\u0442\u0432\u043E
    (1960\u20131980-\u0435) \u041F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u043E
    \u0441 \u043D\u0430\u0443\u043A\u043E\u0439 \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447
    \u0437\u0430\u043D\u044F\u043B \u0436\u0435\u0441\u0442\u043A\u0443\u044E \u0430\u043D\u0442\u0438\u043A\u043E\u043C\u043C\u0443\u043D\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0438 \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043F\u043E\u0437\u0438\u0446\u0438\u044E: *   **\u0421\u0430\u043C\u0438\u0437\u0434\u0430\u0442
    \u0438 \xAB\u0412\u0435\u0445\u0438\xBB**: \u0412 1970-\u0445 \u0433\u043E\u0434\u0430\u0445
    \u043E\u043D \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u0438\u0434\u0435\u043E\u043B\u043E\u0433\u043E\u0432
    \u0440\u0443\u0441\u0441\u043A\u043E\u0433\u043E \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F. \u0412 1974 \u0433\u043E\u0434\u0443
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438 \u0432\u044B\u0448\u0435\u043B
    \u0435\u0433\u043E \u0441\u0431\u043E\u0440\u043D\u0438\u043A \xAB\u0418\u0437-\u043F\u043E\u0434
    \u0433\u043B\u044B\u0431\xBB, \u0433\u0434\u0435 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0442\u0430\u0442\u044C\u044E \xAB\u0420\u0443\u0441\u043E\u0444\u043E\u0431\u0438\u044F\xBB,
    \u0432\u044B\u0437\u0432\u0430\u0432\u0448\u0443\u044E \u0448\u0438\u0440\u043E\u043A\u0438\u0439
    \u0440\u0435\u0437\u043E\u043D\u0430\u043D\u0441 \u043D\u0430 \u0417\u0430\u043F\u0430\u0434\u0435
    \u0438 \u043E\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0435 \u0432 \u0421\u0421\u0421\u0420.
    \u0412 \u044D\u0442\u0438\u0445 \u0442\u0435\u043A\u0441\u0442\u0430\u0445 \u043E\u043D
    \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B \u043B\u0438\u0431\u0435\u0440\u0430\u043B\u0438\u0437\u043C
    \u0438 \u043C\u0430\u0440\u043A\u0441\u0438\u0437\u043C, \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u044F
    \u0438\u043C \u043F\u0440\u0430\u0432\u043E\u0441\u043B\u0430\u0432\u043D\u044B\u0435
    \u0438 \u0440\u0443\u0441\u0441\u043A\u0438\u0435 \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u0438. *   **\u041F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435**:
    \u0418\u0437-\u0437\u0430 \u043F\u0443\u0431\u043B\u0438\u0446\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438 \u0435\u0433\u043E
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B\u0438 \u0432\u044B\u043F\u0443\u0441\u043A\u0430\u0442\u044C
    \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0443, \u0430 \u0432 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u043A \u043D\u0435\u043C\u0443 \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0438\u0441\u044C
    \u043A\u0430\u043A \u043A \xAB\u0438\u043D\u0430\u043A\u043E\u043C\u044B\u0441\u043B\u044F\u0449\u0435\u043C\u0443\xBB,
    \u0445\u043E\u0442\u044F \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E
    \u0435\u0433\u043E \u043D\u0435 \u0438\u0441\u043A\u043B\u044E\u0447\u0430\u043B\u0438. 
    ### \u041F\u043E\u0437\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B \u0438
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 (1990-\u0435 \u2013 2017) \u041F\u043E\u0441\u043B\u0435
    \u0440\u0430\u0441\u043F\u0430\u0434\u0430 \u0421\u0421\u0421\u0420 \u0435\u0433\u043E
    \u0441\u0442\u0430\u0442\u0443\u0441 \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0441\u044F:
    *   **\u041E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C**: \u0412 1990-\u0435 \u0433\u043E\u0434\u044B
    \u043E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0440\u0430\u0431\u043E\u0442\u0435 \u0412\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0433\u043E
    \u0440\u0443\u0441\u0441\u043A\u043E\u0433\u043E \u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0433\u043E
    \u0441\u043E\u0431\u043E\u0440\u0430, \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B
    \u043A\u043E\u043C\u043C\u0443\u043D\u0438\u0441\u0442\u043E\u0432 \u0438 \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B-\u043F\u0430\u0442\u0440\u0438\u043E\u0442\u043E\u0432
    \u0432 \u0438\u0445 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0438
    \u043B\u0438\u0431\u0435\u0440\u0430\u043B\u044C\u043D\u044B\u043C \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u043C.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0440\u0435\u0437\u043A\u043E \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F
    \u043E \xAB\u0437\u0430\u043F\u0430\u0434\u043D\u043E\u043C \u0432\u043B\u0438\u044F\u043D\u0438\u0438\xBB
    \u0438 \u0433\u043B\u043E\u0431\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438.
    *   **\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B**:
    \u0423\u0448\u0435\u043B \u0438\u0437 \u0436\u0438\u0437\u043D\u0438 19 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    2017 \u0433\u043E\u0434\u0430 \u0432 \u041C\u043E\u0441\u043A\u0432\u0435 \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 93 \u043B\u0435\u0442. \u0415\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 (\u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439, \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u0438 \u043B\u0435\u043A\u0446\u0438\u0438) \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C\u0441\u044F, \u0430 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u043C \u043E\u0436\u0435\u0441\u0442\u043E\u0447\u0435\u043D\u043D\u044B\u0445
    \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0439 \u2014 \u043E\u0442 \u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u044F
    \u0434\u043E \u0436\u0435\u0441\u0442\u043A\u043E\u0439 \u043A\u0440\u0438\u0442\u0438\u043A\u0438
    \u0437\u0430 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0437\u043C."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0418\u0433\u043E\u0440\u044F
    \u0420\u043E\u0441\u0442\u0438\u0441\u043B\u0430\u0432\u043E\u0432\u0438\u0447\u0430
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447\u0430 \u043F\u043E\u043B\u043D\u0430
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u043E\u0432
    \u0438 \u044F\u0440\u043A\u0438\u0445 \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432\u044B\u0445\u043E\u0434\u044F\u0442
    \u0434\u0430\u043B\u0435\u043A\u043E \u0437\u0430 \u0440\u0430\u043C\u043A\u0438
    \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439. \u0412\u043E\u0442
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0445 \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438. 
    ### \u2728 \u0412\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434, \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0438\u0439
    \u0432\u0440\u0435\u043C\u044F  \u0415\u0433\u043E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B\u0430\u0441\u044C
    \u0441 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E,
    \u0447\u0442\u043E \u0441\u0430\u043C\u043E \u043F\u043E \u0441\u0435\u0431\u0435
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0444\u0430\u043A\u0442\u043E\u043C,
    \u0433\u0440\u0430\u043D\u0438\u0447\u0430\u0449\u0438\u043C \u0441 \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u043C: 
    *   **\u041E\u0442 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0437\u0430 \u043E\u0434\u0438\u043D \u0433\u043E\u0434**: \u0412 \u0448\u043A\u043E\u043B\u0435
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0443\u0432\u043B\u0435\u043A\u0441\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439,
    \u0447\u0442\u043E \u043D\u0430\u0447\u0430\u043B \u043E\u0442\u0441\u0442\u0430\u0432\u0430\u0442\u044C
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u041E\u0441\u043E\u0437\u043D\u0430\u0432
    \u044D\u0442\u043E, \u043E\u043D \u0432 14 \u043B\u0435\u0442 \u0441\u0435\u043B
    \u0437\u0430 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0438 \u0438 **\u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u0441\u0432\u043E\u0438\u043B \u0432\u0435\u0441\u044C \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0439
    \u043A\u0443\u0440\u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438**
    \u0437\u0430 \u043E\u0434\u0438\u043D \u0433\u043E\u0434. \u0415\u0433\u043E
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u0442\u0430\u043A
    \u043F\u043E\u0440\u0430\u0437\u0438\u043B\u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u0432
    \u041C\u0413\u0423, \u0447\u0442\u043E \u043E\u043D\u0438 \u043D\u0430\u0447\u0430\u043B\u0438
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F \u0441 \u043D\u0438\u043C
    \u0438\u043D\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u043B\u044C\u043D\u043E.
    *   **\u0421\u0430\u043C\u044B\u0439 \u043C\u043E\u043B\u043E\u0434\u043E\u0439
    \u0434\u043E\u043A\u0442\u043E\u0440 \u043D\u0430\u0443\u043A**: \u0412 15 \u043B\u0435\u0442
    \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0441\u0434\u0430\u0432\u0430\u0442\u044C
    \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u044B \u044D\u043A\u0441\u0442\u0435\u0440\u043D\u043E\u043C
    \u043D\u0430 \u043C\u0435\u0445\u043C\u0430\u0442 \u041C\u0413\u0423. \u0412
    1940 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    **17 \u043B\u0435\u0442**, \u043E\u043D \u0443\u0436\u0435 \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u043F\u043E\u043B\u0443\u0447\u0430\u044F
    \u043D\u0430 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u043C \u043A\u0443\u0440\u0441\u0435
    \u0421\u0442\u0430\u043B\u0438\u043D\u0441\u043A\u0443\u044E \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E.
    **\u041A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0432 19 \u043B\u0435\u0442, \u0430
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u2014 \u0432 23
    \u0433\u043E\u0434\u0430**. \u0412 \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0439
    \u043D\u0430\u0443\u043A\u0435 \u044D\u0442\u043E \u0431\u044B\u043B \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u0441\u043B\u0443\u0447\u0430\u0439.  ### \U0001F4DA \xAB\u041C\u043E\u0446\u0430\u0440\u0442
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB \u0438 \u0431\u0443\u043A\u0432\u0430
    \xAB\u0428\xBB  \u0412 \u043D\u0430\u0443\u0447\u043D\u043E\u043C \u043C\u0438\u0440\u0435
    \u0441 \u043D\u0438\u043C \u0441\u0432\u044F\u0437\u0430\u043D\u043E \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u044B\u0445 \u0434\u0435\u0442\u0430\u043B\u0435\u0439: 
    *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u041C\u043E\u0446\u0430\u0440\u0442**: \u041A\u043E\u043B\u043B\u0435\u0433\u0438
    \u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u0438, \u0441\u0440\u0435\u0434\u0438
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0431\u044B\u043B \u0438 \u0431\u0443\u0434\u0443\u0449\u0438\u0439
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u042E.\u0418. \u041C\u0430\u043D\u0438\u043D, \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447\u0430 **\xAB\u041C\u043E\u0446\u0430\u0440\u0442\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB** \u0437\u0430
    \u0435\u0433\u043E \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u044F\u0441\u043D\u043E\u0435, \u0438\u0437\u044F\u0449\u043D\u043E\u0435 \u0438
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0435 \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0435.
    *   **\u0420\u0443\u0441\u0441\u043A\u0430\u044F \u0431\u0443\u043A\u0432\u0430
    \u0432 \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435**:
    \u0412 \u0447\u0435\u0441\u0442\u044C \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447\u0430
    \u043D\u0430\u0437\u0432\u0430\u043D\u0430 **\u0433\u0440\u0443\u043F\u043F\u0430
    \u0422\u0435\u0439\u0442\u0430 \u2014 \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447\u0430**
    \u2014 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0439 \u043E\u0431\u044A\u0435\u043A\u0442
    \u0432 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u041A\u0443\u0440\u044C\u0435\u0437
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u0432 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0435 \u044D\u0442\u0443
    \u0433\u0440\u0443\u043F\u043F\u0443 \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0430\u044E\u0442
    **\u0437\u0430\u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u0440\u0443\u0441\u0441\u043A\u043E\u0439
    \u0431\u0443\u043A\u0432\u043E\u0439 \"\u0428\"**. \u042D\u0442\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0441\u043B\u0443\u0447\u0430\u0435\u0432 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u043A\u0438\u0440\u0438\u043B\u043B\u0438\u0446\u044B \u0432 \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u0445
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u0445. 
    ### \u2694\uFE0F \u0413\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u0430\u044F
    \u043F\u043E\u0437\u0438\u0446\u0438\u044F \u0438 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u044B 
    \u0415\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u043F\u043E\u043B\u043D\u0430
    \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u0432 \u0431\u0435\u0441\u043A\u043E\u043C\u043F\u0440\u043E\u043C\u0438\u0441\u0441\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0445 \u043F\u043E\u0441\u0442\u0443\u043F\u043A\u043E\u0432: 
    *   **\u041F\u0440\u043E\u0432\u043E\u0434\u044B \u0421\u043E\u043B\u0436\u0435\u043D\u0438\u0446\u044B\u043D\u0430**:
    \u0412 1974 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0430
    \u0421\u043E\u043B\u0436\u0435\u043D\u0438\u0446\u044B\u043D\u0430 \u0434\u0435\u043F\u043E\u0440\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u0438\u0437 \u0421\u0421\u0421\u0420, \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447
    \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0445,
    \u043A\u0442\u043E \u043F\u0440\u0438\u0448\u0435\u043B \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u0442\u044C
    \u0435\u0433\u043E \u0432 \u0430\u044D\u0440\u043E\u043F\u043E\u0440\u0442. \u0414\u043B\u044F
    \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0433\u043E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u0430
    \u044D\u0442\u043E \u0431\u044B\u043B \u0441\u043C\u0435\u043B\u044B\u0439 \u0438
    \u0440\u0438\u0441\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0439 \u0434\u0435\u043C\u0430\u0440\u0448.
    *   **\u041F\u0440\u043E\u0433\u0443\u043B\u043A\u0430 \u043F\u043E\u0434 \u043F\u0443\u043B\u044F\u043C\u0438**:
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u041F\u0440\u0438\u0434\u043D\u0435\u0441\u0442\u0440\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0430 \u0432 1992 \u0433\u043E\u0434\u0443
    \u043F\u043E\u0436\u0438\u043B\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A
    (\u0435\u043C\u0443 \u0431\u044B\u043B\u043E \u043F\u043E\u0447\u0442\u0438 70
    \u043B\u0435\u0442) \u0432 \u0441\u043E\u0441\u0442\u0430\u0432\u0435 \u0434\u0435\u043B\u0435\u0433\u0430\u0446\u0438\u0438
    \u0440\u0443\u0441\u0441\u043A\u0438\u0445 \u043F\u0430\u0442\u0440\u0438\u043E\u0442\u043E\u0432
    **\u043F\u0440\u043E\u0448\u0435\u043B \u043F\u043E \u043F\u0440\u043E\u0441\u0442\u0440\u0435\u043B\u0438\u0432\u0430\u0435\u043C\u043E\u0439
    \u043F\u043B\u043E\u0442\u0438\u043D\u0435 \u0414\u0443\u0431\u043E\u0441\u0441\u0430\u0440\u0441\u043A\u043E\u0439
    \u0413\u042D\u0421** \u043D\u0430\u0432\u0441\u0442\u0440\u0435\u0447\u0443 \u0441\u043D\u0430\u0439\u043F\u0435\u0440\u0430\u043C.
    \u042D\u0442\u043E \u0431\u044B\u043B \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439,
    \u043D\u043E \u043A\u0440\u0430\u0439\u043D\u0435 \u043E\u043F\u0430\u0441\u043D\u044B\u0439
    \u0436\u0435\u0441\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0440\u0430\u0437\u0438\u043B
    \u0434\u0430\u0436\u0435 \u0432\u0438\u0434\u0430\u0432\u0448\u0438\u0445 \u0432\u0438\u0434\u044B
    \u043E\u043F\u043E\u043B\u0447\u0435\u043D\u0446\u0435\u0432. *   **\u0414\u0438\u0441\u0441\u0438\u0434\u0435\u043D\u0442,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043D\u0435 \u0441\u0430\u0436\u0430\u043B\u0438**:
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447 \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0436\u0435\u0441\u0442\u043A\u0438\u0445
    \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432 \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0439
    \u0432\u043B\u0430\u0441\u0442\u0438 \u0441\u0440\u0435\u0434\u0438 \u0434\u0438\u0441\u0441\u0438\u0434\u0435\u043D\u0442\u043E\u0432,
    \u043D\u043E, \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442
    \u043C\u043D\u043E\u0433\u0438\u0445, \u043E\u043D \u043D\u0435 \u0431\u044B\u043B
    \u0430\u0440\u0435\u0441\u0442\u043E\u0432\u0430\u043D \u0438\u043B\u0438 \u043F\u043E\u0441\u0430\u0436\u0435\u043D
    \u0432 \u043F\u0441\u0438\u0445\u0443\u0448\u043A\u0443. \u0415\u0433\u043E \u0441\u043F\u0430\u0441\u0430\u043B
    **\u0441\u0442\u0430\u0442\u0443\u0441 \u043B\u0430\u0443\u0440\u0435\u0430\u0442\u0430
    \u041B\u0435\u043D\u0438\u043D\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438**
    \u0438 \u043C\u0438\u0440\u043E\u0432\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C.
    \u0412\u043B\u0430\u0441\u0442\u0438 \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u043B\u0438
    \u0435\u0433\u043E \u043F\u0440\u043E\u0441\u0442\u043E \u0443\u0432\u043E\u043B\u0438\u0442\u044C
    \u0438\u0437 \u041C\u0413\u0423. *   **\u041F\u0438\u0441\u044C\u043C\u0430 \u043F\u0440\u043E\u0442\u0438\u0432
    \u0430\u043D\u0442\u0438\u0441\u0435\u043C\u0438\u0442\u0438\u0437\u043C\u0430**:
    \u041F\u0440\u0438 \u0432\u0441\u0435\u0439 \u0441\u0432\u043E\u0435\u0439 \u043A\u0440\u0438\u0442\u0438\u043A\u0435
    \u0432 \u0430\u0434\u0440\u0435\u0441 \"\u043C\u0430\u043B\u043E\u0433\u043E
    \u043D\u0430\u0440\u043E\u0434\u0430\", \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447
    **\u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E \u043E\u0441\u0443\u0436\u0434\u0430\u043B**
    \u0434\u0438\u0441\u043A\u0440\u0438\u043C\u0438\u043D\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u043C\u0435\u0440\u044B, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u043F\u0440\u0435\u0441\u043B\u043E\u0432\u0443\u0442\u0443\u044E \"\u043F\u0440\u043E\u0446\u0435\u043D\u0442\u043D\u0443\u044E
    \u043D\u043E\u0440\u043C\u0443\" \u0434\u043B\u044F \u0435\u0432\u0440\u0435\u0435\u0432
    \u043F\u0440\u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0438
    \u0432 \u0432\u0443\u0437\u044B. \u042D\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B\u043E
    \u0435\u043C\u0443 \u0432\u0440\u0430\u0433\u043E\u0432 \u0432 \u0441\u0430\u043C\u044B\u0445
    \u0440\u0430\u0437\u043D\u044B\u0445 \u043B\u0430\u0433\u0435\u0440\u044F\u0445. 
    ### \U0001F3AD \u042D\u043A\u0441\u0442\u0440\u0430\u0432\u0430\u0433\u0430\u043D\u0442\u043D\u044B\u0435
    \u0436\u0435\u0441\u0442\u044B  *   **\u041E\u0442\u043A\u0430\u0437 \u043E\u0442
    \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438**:
    \u0412 2003 \u0433\u043E\u0434\u0443, \u0432 \u0437\u043D\u0430\u043A \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0432\u043E\u0439\u043D\u044B \u0432 \u0418\u0440\u0430\u043A\u0435,
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447 \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u043E
    **\u0432\u044B\u0448\u0435\u043B \u0438\u0437 \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A \u0421\u0428\u0410**.
    \u042D\u0442\u043E \u0431\u044B\u043B \u0440\u0435\u0434\u043A\u0438\u0439 \u0441\u043B\u0443\u0447\u0430\u0439,
    \u043A\u043E\u0433\u0434\u0430 \u0447\u043B\u0435\u043D \u0442\u0430\u043A\u043E\u0439
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0439 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u0438
    \u0434\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u043E \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u0441\u0432\u043E\u0435\u0433\u043E \u0441\u0442\u0430\u0442\u0443\u0441\u0430
    \u043F\u043E \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043C\u043E\u0442\u0438\u0432\u0430\u043C.  \u0418\u0433\u043E\u0440\u044C \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447
    \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u0441\u0435\u0433\u0434\u0430 \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438\u043C \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F\u043C,
    \u043D\u0435 \u043E\u0433\u043B\u044F\u0434\u044B\u0432\u0430\u044F\u0441\u044C
    \u043D\u0430 \u0442\u043E, \"\u0447\u0442\u043E \u0441\u043A\u0430\u0436\u0443\u0442\".
    \u042D\u0442\u0430 \u0447\u0435\u0440\u0442\u0430 \u0434\u0435\u043B\u0430\u043B\u0430
    \u0435\u0433\u043E \"\u043D\u0435\u0443\u0434\u043E\u0431\u043D\u044B\u043C\"
    \u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0439 \u0432\u043B\u0430\u0441\u0442\u0438
    \u0438 \u043B\u044E\u0431\u043E\u0439 \u0438\u0434\u0435\u043E\u043B\u043E\u0433\u0438\u0438,
    \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u044F \u044F\u0440\u043A\u0438\u0439
    \u0441\u043B\u0435\u0434 \u043A\u0430\u043A \u0432 \u043D\u0430\u0443\u043A\u0435,
    \u0442\u0430\u043A \u0438 \u0432 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0441\u0432\u043E\u0435\u0439 \u0441\u0442\u0440\u0430\u043D\u044B."
