    ### \U0001F4DC \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0414\u0435\u0442\u0441\u0442\u0432\u043E  *   **\u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435:**
    \u0418\u0433\u043E\u0440\u044C \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **3 \u0438\u044E\u043D\u044F 1923
    \u0433\u043E\u0434\u0430** \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 **\u0416\u0438\u0442\u043E\u043C\u0438\u0440\u0435**,
    \u0423\u043A\u0440\u0430\u0438\u043D\u0441\u043A\u0430\u044F \u0421\u0421\u0420.
    \u0415\u0433\u043E \u043C\u0430\u0442\u044C \u0443\u0435\u0445\u0430\u043B\u0430
    \u0442\u0443\u0434\u0430, \u0447\u0442\u043E\u0431\u044B \u0440\u043E\u0434\u0438\u0442\u044C
    \u0432 \u0434\u043E\u043C\u0435 \u0441\u0432\u043E\u0435\u0433\u043E \u043E\u0442\u0446\u0430,
    \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u044E\u0449\u0435\u0433\u043E \u043C\u0435\u0441\u0442\u043D\u044B\u043C
    \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u0435\u043C \u0413\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0431\u0430\u043D\u043A\u0430. *   **\u0421\u0435\u043C\u044C\u044F \u0438 \u043F\u0435\u0440\u0435\u0435\u0437\u0434
    \u0432 \u041C\u043E\u0441\u043A\u0432\u0443:** \u0412\u0441\u043A\u043E\u0440\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0441\u0435\u043C\u044C\u044F \u0432\u0435\u0440\u043D\u0443\u043B\u0430\u0441\u044C
    \u0432 \u041C\u043E\u0441\u043A\u0432\u0443. \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    **\u0420\u043E\u0441\u0442\u0438\u0441\u043B\u0430\u0432 \u0421\u0442\u0435\u043F\u0430\u043D\u043E\u0432\u0438\u0447**,
    \u0431\u044B\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438 \u0438 \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442 \u041C\u0413\u0423. \u041C\u0430\u0442\u044C,
    **\u042E\u043B\u0438\u044F \u042F\u043A\u043E\u0432\u043B\u0435\u0432\u043D\u0430**,
    \u043F\u043E \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044E
    \u0431\u044B\u043B\u0430 \u0444\u0438\u043B\u043E\u043B\u043E\u0433\u043E\u043C.
    *   **\u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B:** \u0416\u0438\u043B\u0438
    \u043E\u043D\u0438 \u0432 \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u043A\u043E\u043C\u043C\u0443\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435, \u0433\u0434\u0435 \u0432 \u043E\u0434\u043D\u043E\u0439
    \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435 \u0441 \u043D\u0438\u043C\u0438
