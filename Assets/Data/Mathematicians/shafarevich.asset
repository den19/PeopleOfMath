  achievementsRu: "\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0418\u0433\u043E\u0440\u044F
    \u0420\u043E\u0441\u0442\u0438\u0441\u043B\u0430\u0432\u043E\u0432\u0438\u0447\u0430
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447\u0430 \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439, \u0438 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B, \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B \u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u0447\u0430\u0441\u0442\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0437\u0443\u0435\u0442\u0441\u044F
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C\u0438 \u0441\u0432\u044F\u0437\u044F\u043C\u0438
    \u043C\u0435\u0436\u0434\u0443 \u044D\u0442\u0438\u043C\u0438, \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C
    \u0431\u044B, \u0440\u0430\u0437\u043D\u044B\u043C\u0438 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C\u0438. 
    ### \U0001F9E0 \u0422\u0435\u043E\u0440\u0438\u044F \u0413\u0430\u043B\u0443\u0430
    \u0438 \u0422\u0435\u043E\u0440\u0438\u044F \u0427\u0438\u0441\u0435\u043B  \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043C\u0438\u0440\u043E\u0432\u043E\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0441\u0432\u043E\u0438\u043C \u0440\u0430\u0431\u043E\u0442\u0430\u043C \u0432
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0413\u0430\u043B\u0443\u0430.  *   **\u0420\u0435\u0448\u0435\u043D\u0438\u0435
    \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0438
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0413\u0430\u043B\u0443\u0430 \u0434\u043B\u044F
    \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u044B\u0445 \u0433\u0440\u0443\u043F\u043F:**
    \u0412 1954 \u0433\u043E\u0434\u0443 \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u043E \u0442\u043E\u043C, \u0447\u0442\u043E
    \u043B\u044E\u0431\u0430\u044F \u043A\u043E\u043D\u0435\u0447\u043D\u0430\u044F
    \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u0430\u044F \u0433\u0440\u0443\u043F\u043F\u0430
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u0440\u0435\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043D\u0430
    \u043A\u0430\u043A \u0433\u0440\u0443\u043F\u043F\u0430 \u0413\u0430\u043B\u0443\u0430
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u044F
    \u043D\u0430\u0434 \u043B\u044E\u0431\u044B\u043C \u043F\u043E\u043B\u0435\u043C
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B. \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0441\u0442\u0430\u043B\u0430 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u043C
    \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u043C \u0432 \u0440\u0435\u0448\u0435\u043D\u0438\u0438
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0413\u043E\u043B\u043E\u0434\u0430 \u2014 \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447\u0430:**
    \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u0415.\u0421.
    \u0413\u043E\u043B\u043E\u0434\u043E\u043C \u043E\u043D \u0440\u0435\u0448\u0438\u043B
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0443\u044E \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443
    \u043E \u0431\u0430\u0448\u043D\u0435 \u043F\u043E\u043B\u0435\u0439 \u043A\u043B\u0430\u0441\u0441\u043E\u0432.
    \u041E\u043D\u0438 \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B\u0438 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0435
    \u0431\u0430\u0448\u043D\u0438 \u043D\u0435\u0440\u0430\u0437\u0432\u0435\u0442\u0432\u043B\u0435\u043D\u043D\u044B\u0445
    \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u0439 \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u0445
    \u043F\u043E\u043B\u0435\u0439, \u0447\u0442\u043E \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043B\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443, \u0432\u043E\u0441\u0445\u043E\u0434\u044F\u0449\u0443\u044E
    \u043A \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0443. \u0412 \u0445\u043E\u0434\u0435
    \u044D\u0442\u043E\u0433\u043E \u043E\u043D\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043F\u0440\u043E\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445 \u0433\u0440\u0443\u043F\u043F:
    \u0434\u043B\u044F \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0439 p-\u0433\u0440\u0443\u043F\u043F\u044B
    \u0447\u0438\u0441\u043B\u043E \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0439
    `r` \u0434\u043E\u043B\u0436\u043D\u043E \u0431\u044B\u0442\u044C \u0431\u043E\u043B\u044C\u0448\u0435
    `(d-1)^2/4`, \u0433\u0434\u0435 `d` \u2014 \u0447\u0438\u0441\u043B\u043E \u043E\u0431\u0440\u0430\u0437\u0443\u044E\u0449\u0438\u0445.
    *   **\u0413\u0440\u0443\u043F\u043F\u0430 \u0422\u0435\u0439\u0442\u0430 \u2014
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447\u0430 (\u0433\u0440\u0443\u043F\u043F\u0430
    \u0428):** \u0412 \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u043E\u0434\u043D\u043E\u0440\u043E\u0434\u043D\u044B\u0445 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432
    \u043E\u043D \u0432\u0432\u0435\u043B \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0443\u044E
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0443
    \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0432 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0435 \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442\u0441\u044F
    \u043A\u0438\u0440\u0438\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0431\u0443\u043A\u0432\u043E\u0439 **\u0428**. \u042D\u0442\u0430 \u0433\u0440\u0443\u043F\u043F\u0430
    \u0438\u0437\u043C\u0435\u0440\u044F\u0435\u0442 \u043F\u0440\u0435\u043F\u044F\u0442\u0441\u0442\u0432\u0438\u0435
    \u043A \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u044E \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430
    \u0425\u0430\u0441\u0441\u0435 \u0434\u043B\u044F \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439 \u0438
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043E\u0434\u043D\u043E\u0439
