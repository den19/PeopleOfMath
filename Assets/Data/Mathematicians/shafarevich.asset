  fullNameRu: "\u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447, \u0418\u0433\u043E\u0440\u044C
    \u0420\u043E\u0441\u0442\u0438\u0441\u043B\u0430\u0432\u043E\u0432\u0438\u0447"
