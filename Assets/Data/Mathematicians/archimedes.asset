    \u0441\u043F\u0438\u0440\u0430\u043B\u0438, \u043D\u0430\u0448\u0435\u043B \u0432\u0441\u0435
    \u043F\u043E\u043B\u0443\u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0435
