    (\u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0430):**
    \u041E\u043D \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A\u043E\u043C
    \u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0438. \u0412
    \u0441\u0432\u043E\u0435\u043C \u0442\u0440\u0443\u0434\u0435 \xAB\u041E \u043F\u043B\u0430\u0432\u0430\u044E\u0449\u0438\u0445
    \u0442\u0435\u043B\u0430\u0445\xBB \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0437\u0430\u043A\u043E\u043D,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0433\u043B\u0430\u0441\u0438\u0442:
    \u043D\u0430 \u0442\u0435\u043B\u043E, \u043F\u043E\u0433\u0440\u0443\u0436\u0435\u043D\u043D\u043E\u0435
    \u0432 \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u044C, \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442
    \u0432\u044B\u0442\u0430\u043B\u043A\u0438\u0432\u0430\u044E\u0449\u0430\u044F
    \u0441\u0438\u043B\u0430, \u0440\u0430\u0432\u043D\u0430\u044F \u0432\u0435\u0441\u0443
    \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0438 \u0432 \u043E\u0431\u044A\u0435\u043C\u0435
    \u044D\u0442\u043E\u0433\u043E \u0442\u0435\u043B\u0430 . \u041B\u0435\u0433\u0435\u043D\u0434\u0430
    \u043E \u0442\u043E\u043C, \u043A\u0430\u043A \u043E\u043D, \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u044F
    \u0432\u0430\u043D\u043D\u0443, \u043E\u0441\u043E\u0437\u043D\u0430\u043B \u044D\u0442\u043E\u0442
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0438 \u0441 \u043A\u0440\u0438\u043A\u043E\u043C
    \xAB\u042D\u0432\u0440\u0438\u043A\u0430!\xBB (\xAB\u041D\u0430\u0448\u0435\u043B!\xBB)
    \u043F\u043E\u0431\u0435\u0436\u0430\u043B \u0434\u043E\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0442\u044C
    \u043E \u0441\u0432\u043E\u0435\u043C \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0438,
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439.  \u0418\u043D\u0436\u0435\u043D\u0435\u0440\u0438\u044F:
    \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u044C.
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A\u043E\u043C, \u043D\u043E \u0438
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u043C \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C,
    \u0447\u044C\u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F
    \u043F\u043E\u0440\u0430\u0436\u0430\u043B\u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432. 
    *   **\u0410\u0440\u0445\u0438\u043C\u0435\u0434\u043E\u0432 \u0432\u0438\u043D\u0442:**
    \u042D\u0442\u043E \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E
    \u0434\u043B\u044F \u043F\u043E\u0434\u044A\u0435\u043C\u0430 \u0432\u043E\u0434\u044B
    \u043D\u0430 \u0432\u044B\u0441\u043E\u0442\u0443, \u043F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E,
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u043E\u0435
    \u0434\u043B\u044F \u043E\u0441\u0443\u0448\u0435\u043D\u0438\u044F \u043A\u043E\u0440\u0430\u0431\u043B\u0435\u0439
    \u0438\u043B\u0438 \u043E\u0440\u043E\u0448\u0435\u043D\u0438\u044F \u043F\u043E\u043B\u0435\u0439.
    \u041E\u043D\u043E \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0434\u0430\u0447\u043D\u043E,
    \u0447\u0442\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0438 \u043F\u043E \u0441\u0435\u0439 \u0434\u0435\u043D\u044C \u0432 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445
    \u043C\u043E\u0434\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044F\u0445. *  
    **\u041E\u0431\u043E\u0440\u043E\u043D\u0430 \u0421\u0438\u0440\u0430\u043A\u0443\u0437:**
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u043E\u0441\u0430\u0434\u044B \u0435\u0433\u043E
    \u0440\u043E\u0434\u043D\u043E\u0433\u043E \u0433\u043E\u0440\u043E\u0434\u0430
    \u0440\u0438\u043C\u043B\u044F\u043D\u0430\u043C\u0438, \u043F\u0440\u0435\u0441\u0442\u0430\u0440\u0435\u043B\u044B\u0439
    \u0443\u0447\u0435\u043D\u044B\u0439 \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043E\u0431\u043E\u0440\u043E\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043C\u0430\u0448\u0438\u043D. \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u041F\u043B\u0443\u0442\u0430\u0440\u0445\u0443, \u0435\u0433\u043E \u043C\u043E\u0449\u043D\u044B\u0435
    \u043A\u0430\u0442\u0430\u043F\u0443\u043B\u044C\u0442\u044B \u0438 \u043A\u0440\u0430\u043D\u044B-\xAB\u043A\u043E\u0433\u0442\u0438\xBB,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u043B\u0438
    \u0438 \u0442\u043E\u043F\u0438\u043B\u0438 \u0432\u0440\u0430\u0436\u0435\u0441\u043A\u0438\u0435
    \u043A\u043E\u0440\u0430\u0431\u043B\u0438, \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u043B\u0438
    \u0440\u0438\u043C\u043B\u044F\u043D \u043E\u0442\u043A\u0430\u0437\u0430\u0442\u044C\u0441\u044F
    \u043E\u0442 \u043C\u044B\u0441\u043B\u0438 \u0432\u0437\u044F\u0442\u044C \u0433\u043E\u0440\u043E\u0434
    \u0448\u0442\u0443\u0440\u043C\u043E\u043C \u0438 \u043F\u0435\u0440\u0435\u0439\u0442\u0438
    \u043A \u0434\u043E\u043B\u0433\u043E\u0439 \u043E\u0441\u0430\u0434\u0435. *  
    **\u041D\u0435\u0431\u0435\u0441\u043D\u0430\u044F \u0441\u0444\u0435\u0440\u0430:**
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0441\u043E\u0437\u0434\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u044B\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u043B\u0430\u043D\u0435\u0442\u0430\u0440\u0438\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435
    \u0421\u043E\u043B\u043D\u0446\u0430, \u041B\u0443\u043D\u044B \u0438 \u043F\u044F\u0442\u0438
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u0442\u043E\u0433\u0434\u0430
    \u043F\u043B\u0430\u043D\u0435\u0442, \u0430 \u0442\u0430\u043A\u0436\u0435 \u043C\u043E\u0433
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u0444\u0430\u0437\u044B \u041B\u0443\u043D\u044B \u0438 \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u044F. 
    \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430
    \u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u043D\u043E. \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u0441\u0442\u0430\u043B\u0438 \u043C\u043E\u0441\u0442\u043E\u043C
    \u043C\u0435\u0436\u0434\u0443 \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u0438 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u043C\u0438\u0440\u043E\u043C,
    \u0438 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u043B\u0438 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0443\u043C\u043E\u0432 \u0420\u0435\u043D\u0435\u0441\u0441\u0430\u043D\u0441\u0430
    \u0438 \u041D\u043E\u0432\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438,
    \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A \u0413\u0430\u043B\u0438\u043B\u0435\u0439,
    \u041A\u0435\u043F\u043B\u0435\u0440 \u0438 \u041D\u044C\u044E\u0442\u043E\u043D."
  achievementsEn: "Archimedes, one of the greatest scientists in history, left an
    indelible mark on mathematics, physics, and engineering. His achievements were
    so far ahead of their time that their true significance was only appreciated
    nearly two millennia later, when they formed the basis of differential and integral
    calculus.  Here are the key areas in which Archimedes' contributions were truly
    fundamental:  Mathematics: Forerunner of integral calculus. Archimedes revolutionized
    mathematics by developing methods for solving problems that today we consider
    calculus.  * **Method of Exhaustion:** He refined and masterfully applied this
    method to calculate the areas and volumes of complex figures. The essence of
    the method was to inscribe increasingly smaller polygons within a figure and,
    by summing their areas, ultimately obtain the area of \u200B\u200Bthe figure
    itself. This was a direct precursor to integral calculus. * **Volume of a Sphere
    and a Cylinder:** The pinnacle of his geometric discoveries was the proof that
    the volume of a sphere is equal to 2/3 of the volume of the cylinder circumscribed
    around it. He valued this discovery so much that he bequeathed this very drawing
    to his tombstone. * **Squaring the Parabola:** In his work \"Squaring the Parabola,\"
    he proved that the area of \u200B\u200Ba segment cut off by a line from a parabola
    is exactly 4/3 of the area of \u200B\u200Bthe triangle inscribed in that segment.
    To achieve this, Archimedes was the first in the history of mathematics to calculate
    the sum of an infinite geometric series. * **Calculating the Number \u03C0:**
    In his treatise \"The Measurement of the Circle,\" Archimedes determined the
    value of \u03C0 (pi) with high precision. He showed that it lies between **3
    10/71** and **3 1/7** (which in decimal notation gives the interval 3.1408...
    < \u03C0 < 3.1428...).  Physics: The founder of mechanics and hydrostatics. Archimedes
    was the first to apply rigorous mathematics to the description of physical laws,
    laying the foundations of theoretical mechanics and hydrostatics.  * **Law of
    the lever:** Although the lever was known before him, it was Archimedes who provided
    its complete mathematical theory. In his work \"On the Equilibrium of Plane Figures,\"
    he formulated the law of the lever and introduced the fundamental concept of
    a body's **center of gravity.** His famous quote, \"Give me a fulcrum, and I
    will move the Earth,\" perfectly illustrates his understanding of this law. *
    **Archimedes' Principle (Hydrostatics):** He is the founder of hydrostatics.
    In his work \"On Floating Bodies,\" he formulated the famous law, which states
    that a body immersed in a liquid experiences a buoyant force equal to the weight
    of the liquid in the volume of the body. The legend of how he realized this principle
    while taking a bath and, shouting \"Eureka!\" (\"I've found it!\"), ran to report
    his discovery has become one of the most famous scientific stories.  Engineering:
    A Brilliant Inventor. Archimedes was not only a theorist but also a brilliant
    engineer whose inventions astounded his contemporaries.  * **Archimedes' Screw:**
    This device for raising water to a height, likely originally created for draining
    ships or irrigating fields. It was so successful that it is still used today
    in various modifications. * **Defense of Syracuse:** During the siege of his
    hometown by the Romans, the aging scientist designed numerous defensive machines.
    According to Plutarch, his powerful catapults and \"claw\" cranes, which captured
    and sank enemy ships, forced the Romans to abandon their plans to take the city
    by storm and resort to a lengthy siege. * **Celestial sphere:** Archimedes created
    a complex mechanical planetarium that showed the movements of the Sun, Moon,
    and the five then-known planets, and could also predict lunar phases and eclipses. 
    Archimedes' legacy is immortal. His works became a bridge between pure mathematics
    and the physical world, and inspired the greatest minds of the Renaissance and
    modern times, such as Galileo, Kepler, and Newton."
  personalLifeRu: "\u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442
    \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439
    \u0438\u043B\u0438 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u044B\u0445
    \u043F\u043E\u0434\u0432\u0438\u0433\u043E\u0432, \u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0441\u043A\u0440\u044B\u0442\u0430 \u0432\u043E \u0442\u044C\u043C\u0435 \u0432\u0435\u043A\u043E\u0432.
    \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0430\u043C \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E
    \u043E \u043D\u0435\u0439 \u043A\u0440\u0430\u0439\u043D\u0435 \u043C\u0430\u043B\u043E. 
    \u0421\u0435\u043C\u044C\u044F \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435.
    \u0421\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u043E \u0441\u0435\u043C\u044C\u0435
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430 \u043E\u0442\u0440\u044B\u0432\u043E\u0447\u043D\u044B
    \u0438 \u043F\u043E\u0447\u0435\u0440\u043F\u043D\u0443\u0442\u044B \u0438\u0437
    \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442 \u0438 \u043F\u043E\u0437\u0434\u043D\u0438\u0445
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432:  *  
    **\u041E\u0442\u0435\u0446:** \u0412 \u0441\u0432\u043E\u0435\u043C \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435
    \xAB\u041F\u0441\u0430\u043C\u043C\u0438\u0442\xBB (\u0438\u043B\u0438 \xAB\u0418\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435
    \u043F\u0435\u0441\u0447\u0438\u043D\u043E\u043A\xBB) \u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442, \u0447\u0442\u043E \u0435\u0433\u043E
    \u043E\u0442\u0446\u0430 \u0437\u0432\u0430\u043B\u0438 **\u0424\u0438\u0434\u0438\u0439**
    \u0438 \u043E\u043D \u0431\u044B\u043B \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C.
    *   **\u0420\u043E\u0434\u0441\u0442\u0432\u043E \u0441 \u0446\u0430\u0440\u0435\u043C:**
    \u0414\u0440\u0435\u0432\u043D\u0435\u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A \u041F\u043B\u0443\u0442\u0430\u0440\u0445
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E \u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B \u0432 \u0431\u043B\u0438\u0437\u043A\u043E\u043C
    \u0440\u043E\u0434\u0441\u0442\u0432\u0435 \u0441 **\u0413\u0438\u0435\u0440\u043E\u043D\u043E\u043C
    II**, \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u0435\u043C \u0421\u0438\u0440\u0430\u043A\u0443\u0437.
    \u042D\u0442\u043E \u043C\u043E\u0433\u043B\u043E \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0442\u044C
    \u0443\u0447\u0435\u043D\u043E\u043C\u0443 \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C \u0441\u0435\u0431\u044F
    \u043D\u0430\u0443\u043A\u0435. *   **\u041C\u0430\u0442\u044C \u0438 \u0434\u0440\u0443\u0433\u0438\u0435
    \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0438:** \u041E
    \u043C\u0430\u0442\u0435\u0440\u0438 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430,
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0445 \u0431\u0440\u0430\u0442\u044C\u044F\u0445
    \u0438\u043B\u0438 \u0441\u0435\u0441\u0442\u0440\u0430\u0445 \u043D\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E
    \u043D\u0438\u0447\u0435\u0433\u043E.  \u0416\u0435\u043D\u0430 \u0438 \u0434\u0435\u0442\u0438.
    \u041D\u0430 \u0441\u0435\u0433\u043E\u0434\u043D\u044F\u0448\u043D\u0438\u0439
    \u0434\u0435\u043D\u044C **\u043D\u0435\u0442 \u043D\u0438\u043A\u0430\u043A\u0438\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432**
    \u043E \u0442\u043E\u043C, \u0431\u044B\u043B \u043B\u0438 \u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u0436\u0435\u043D\u0430\u0442 \u0438\u043B\u0438 \u0438\u043C\u0435\u043B \u0434\u0435\u0442\u0435\u0439.
    \u042D\u0442\u0430 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F,
    \u0441\u043A\u043E\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043E, \u0431\u044B\u043B\u0430
    \u0443\u0442\u0435\u0440\u044F\u043D\u0430 \u0432\u043C\u0435\u0441\u0442\u0435
    \u0441 \u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0439 \u0440\u0430\u043D\u043D\u0435\u0439
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0435\u0439, \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0439
    \u0434\u0440\u0443\u0433\u043E\u043C \u0413\u0435\u0440\u0430\u043A\u043B\u0438\u0434\u043E\u043C. 
    \u041A\u0440\u0443\u0433 \u043E\u0431\u0449\u0435\u043D\u0438\u044F. \u0413\u043E\u0440\u0430\u0437\u0434\u043E
    \u0431\u043E\u043B\u044C\u0448\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E
    \u043E \u043D\u0430\u0443\u0447\u043D\u043E\u043C \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u0438
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430. \u041E\u043D \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u0432\u044F\u0437\u0438 \u0441 \u0432\u0435\u0434\u0443\u0449\u0438\u043C\u0438
    \u0443\u0447\u0435\u043D\u044B\u043C\u0438 \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438: 
    *   \u041E\u043D \u0443\u0447\u0438\u043B\u0441\u044F, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0441\u044F
    \u0441 **\u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u043E\u043C**
    (\u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443 \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u0441\u0432\u043E\u0439 \u0442\u0440\u0443\u0434 \xAB\u041C\u0435\u0442\u043E\u0434\xBB)
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C **\u041A\u043E\u043D\u043E\u043D\u043E\u043C
    \u0421\u0430\u043C\u043E\u0441\u0441\u043A\u0438\u043C**.  \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435
    \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0435. \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435,
    \u0447\u0442\u043E \u043C\u043E\u0436\u043D\u043E \u043D\u0430\u0437\u0432\u0430\u0442\u044C
    \xAB\u043B\u0438\u0447\u043D\u044B\u043C \u0436\u0435\u043B\u0430\u043D\u0438\u0435\u043C\xBB
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430, \u2014 \u044D\u0442\u043E \u0435\u0433\u043E
    \u0432\u043E\u043B\u044F, \u043A\u0430\u0441\u0430\u044E\u0449\u0430\u044F\u0441\u044F
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u044F.
    \u041E\u043D \u043F\u0440\u043E\u0441\u0438\u043B \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u043D\u0430 \u0441\u0432\u043E\u0435\u0439 \u043C\u043E\u0433\u0438\u043B\u0435
    \u043F\u0430\u043C\u044F\u0442\u043D\u0438\u043A \u0441 \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435\u043C
    \u0448\u0430\u0440\u0430, \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E
    \u0432 \u0446\u0438\u043B\u0438\u043D\u0434\u0440, \u0442\u0430\u043A \u043A\u0430\u043A
    \u0441\u0447\u0438\u0442\u0430\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0438\u0445
    \u043E\u0431\u044A\u0435\u043C\u043E\u0432 \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u0441\u0432\u043E\u0438\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439
    . \u042D\u0442\u043E\u0442 \u043F\u0430\u043C\u044F\u0442\u043D\u0438\u043A,
    \u0441\u043F\u0443\u0441\u0442\u044F 137 \u043B\u0435\u0442, \u0441\u043C\u043E\u0433
    \u043D\u0430\u0439\u0442\u0438 \u0438 \u043E\u043F\u0438\u0441\u0430\u0442\u044C
    \u0440\u0438\u043C\u0441\u043A\u0438\u0439 \u043E\u0440\u0430\u0442\u043E\u0440
    \u0426\u0438\u0446\u0435\u0440\u043E\u043D.  \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C,
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0435\u0442
    \u043F\u0435\u0440\u0435\u0434 \u043D\u0430\u043C\u0438 \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A,
    \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430 \u0432\u0441\u0435\u0446\u0435\u043B\u043E
    \u043F\u043E\u0434\u0447\u0438\u043D\u0435\u043D\u0430 \u043D\u0430\u0443\u043A\u0435.
    \u041E \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u0435 \u0438\u043B\u0438 \u0447\u0443\u0432\u0441\u0442\u0432\u0430\u0445
    \u043C\u044B \u043C\u043E\u0436\u0435\u043C \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0442\u0440\u043E\u0438\u0442\u044C \u0434\u043E\u0433\u0430\u0434\u043A\u0438,
    \u043D\u043E \u0435\u0433\u043E \u0441\u0442\u0440\u0430\u0441\u0442\u044C \u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F\u043C
    \u0441\u0434\u0435\u043B\u0430\u043B\u0430 \u0435\u0433\u043E \u0438\u043C\u044F
    \u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u043C."
  personalLifeEn: 'Unlike his scientific discoveries or engineering feats, Archimedes''
    personal life is almost entirely shrouded in the mists of time. Historians know
    very little about it.  Family and Origins Information about Archimedes'' family
    is fragmentary and gleaned from his own works and later accounts:  * **Father:**
    In his treatise "Psammitus" (or "Calculation of the Sand Grains"), Archimedes
    mentions that his father''s name was **Phidias** and that he was an astronomer.
    * **Royal Relationship:** The ancient Greek historian Plutarch claimed that Archimedes
    was closely related to **Hiero II**, ruler of Syracuse. This could have provided
    the scientist with patronage and the opportunity to devote himself entirely to
    science. * **Mother and Other Relatives:** Nothing is known about Archimedes''
    mother or any possible siblings.  Wife and Children. To date, there is no historical
    evidence to indicate whether Archimedes was married or had children. This information
    was likely lost along with his earliest biography, written by his friend Heraclides. 
    Society. Much more is known about Archimedes''s scientific circle. He maintained
    intellectual ties with leading scholars of the time:  * He studied with and later
    corresponded with Eratosthenes (to whom he dedicated his work "The Method") and
    the astronomer Conon of Samos.  Last Will. The only thing that can be considered
    a "personal wish" of Archimedes is his will concerning his tombstone. He requested
    a monument depicting a sphere inscribed within a cylinder be erected on his tomb,
    as he considered proving the ratio of their volumes to be one of his greatest
    achievements. This monument, 137 years later, was discovered and described by
    the Roman orator Cicero.  Thus, Archimedes emerges as a man whose life was entirely
    devoted to science. We can only speculate about his family or his feelings, but
    his passion for mathematics and invention made his name immortal.'
  shortBioRu: "\u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u2014 \u044D\u0442\u043E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0438\u043C\u044F \u0438\u0437
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0430 \u0444\u0438\u0437\u0438\u043A\u0438.
    \u042D\u0442\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u043B\u0435\u0433\u0435\u043D\u0434\u043E\u0439 \u0435\u0449\u0435
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438, \u0430 \u0435\u0433\u043E
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438 \u0432\u0440\u0435\u043C\u044F,
    \u0447\u0442\u043E \u043F\u043E-\u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u043C\u0443
    \u0438\u0445 \u043E\u0446\u0435\u043D\u0438\u043B\u0438 \u043B\u0438\u0448\u044C
    \u0441\u043F\u0443\u0441\u0442\u044F \u043F\u043E\u0447\u0442\u0438 \u0434\u0432\u0435
    \u0442\u044B\u0441\u044F\u0447\u0438 \u043B\u0435\u0442. \u041E\u043D \u0431\u044B\u043B
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C, \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C
    \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u0435\u043C,
    \u0447\u044C\u0438 \u0438\u0434\u0435\u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u044B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438.  \u0412\u043E\u0442 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0432\u0435\u0445\u0438 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u0438 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u043C\u0430\u0441\u0448\u0442\u0430\u0431 \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u044F. 
    \u041F\u0443\u0442\u044C \u0443\u0447\u0435\u043D\u043E\u0433\u043E: \u043E\u0442
    \u0421\u0438\u0440\u0430\u043A\u0443\u0437 \u0434\u043E \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438. 
    *   **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435:**
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u043E\u043A\u043E\u043B\u043E **287 \u0433\u043E\u0434\u0430 \u0434\u043E \u043D.\u044D.**
    \u0432 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u043C \u0433\u043E\u0440\u043E\u0434\u0435
    \u0421\u0438\u0440\u0430\u043A\u0443\u0437\u044B \u043D\u0430 \u043E\u0441\u0442\u0440\u043E\u0432\u0435
    \u0421\u0438\u0446\u0438\u043B\u0438\u044F . \u0415\u0433\u043E \u043E\u0442\u0446\u043E\u043C
    \u0431\u044B\u043B \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0424\u0438\u0434\u0438\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u0438 \u043F\u0440\u0438\u0432\u0438\u043B \u0441\u044B\u043D\u0443 \u043B\u044E\u0431\u043E\u0432\u044C
    \u043A \u0442\u043E\u0447\u043D\u044B\u043C \u043D\u0430\u0443\u043A\u0430\u043C.
    \u041F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0434\u0430\u043D\u043D\u044B\u043C,
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0441\u043E\u0441\u0442\u043E\u044F\u043B
    \u0432 \u0440\u043E\u0434\u0441\u0442\u0432\u0435 \u0441 \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u0435\u043C
    \u0421\u0438\u0440\u0430\u043A\u0443\u0437, \u0446\u0430\u0440\u0435\u043C \u0413\u0438\u0435\u0440\u043E\u043D\u043E\u043C
    II . *   **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:**
    \u042E\u043D\u044B\u0439 \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0437\u0430 \u0437\u043D\u0430\u043D\u0438\u044F\u043C\u0438 \u0432 **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u044E
    \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0443\u044E** \u2014 \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u043D\u0430\u0443\u0447\u043D\u044B\u0439 \u0438 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u044B\u0439
    \u0446\u0435\u043D\u0442\u0440 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430. \u0422\u0430\u043C \u043E\u043D \u0443\u0447\u0438\u043B\u0441\u044F
