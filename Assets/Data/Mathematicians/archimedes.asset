    \u0440\u0435\u0448\u0435\u043D\u0438\u044F, \u043F\u043E\u043A\u0430 \u043E\u0434\u043D\u0430\u0436\u0434\u044B,
    \u043F\u043E\u0433\u0440\u0443\u0436\u0430\u044F\u0441\u044C \u0432 \u0432\u0430\u043D\u043D\u0443,
    \u043D\u0435 \u0437\u0430\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u0443\u0440\u043E\u0432\u0435\u043D\u044C
