    \u0442\u044F\u0436\u0435\u0441\u0442\u0438.  3.  **\u041E\u0431\u043E\u0440\u043E\u043D\u0430
    \u0421\u0438\u0440\u0430\u043A\u0443\u0437.** \u0412\u043E \u0432\u0440\u0435\u043C\u044F
    \u0412\u0442\u043E\u0440\u043E\u0439 \u041F\u0443\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u0440\u0438\u043C\u043B\u044F\u043D\u0435 \u043E\u0441\u0430\u0434\u0438\u043B\u0438
    \u0421\u0438\u0440\u0430\u043A\u0443\u0437\u044B. 75-\u043B\u0435\u0442\u043D\u0438\u0439
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0441\u043E\u0437\u0434\u0430\u043B
    \u0434\u043B\u044F \u0437\u0430\u0449\u0438\u0442\u044B \u0433\u043E\u0440\u043E\u0434\u0430
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0432\u043E\u0435\u043D\u043D\u044B\u0445 \u043C\u0430\u0448\u0438\u043D. \u041C\u043E\u0449\u043D\u044B\u0435
    \u043A\u0430\u0442\u0430\u043F\u0443\u043B\u044C\u0442\u044B \u0438 \u0431\u0430\u043B\u043B\u0438\u0441\u0442\u044B
    \u0437\u0430\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043B\u0438 \u0432\u0440\u0430\u0433\u0430
    \u043A\u0430\u043C\u043D\u044F\u043C\u0438 \u0438 \u044F\u0434\u0440\u0430\u043C\u0438,
    \u0430 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u043A\u0440\u0430\u043D\u044B
    \u0441 \u043A\u0440\u044E\u043A\u0430\u043C\u0438 (\xAB**\u041A\u043E\u0433\u043E\u0442\u044C
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430**\xBB) \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u043B\u0438
    \u0440\u0438\u043C\u0441\u043A\u0438\u0435 \u043A\u043E\u0440\u0430\u0431\u043B\u0438,
    \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u043B\u0438 \u0438\u0445 \u0432 \u0432\u043E\u0437\u0434\u0443\u0445
    \u0438 \u0431\u0440\u043E\u0441\u0430\u043B\u0438 \u0432\u043D\u0438\u0437, \u0442\u043E\u043F\u044F
    \u0438\u0445 . \u041F\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435, \u043E\u043D
    \u0442\u0430\u043A\u0436\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0437\u0435\u0440\u043A\u0430\u043B,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0434\u0436\u0435\u0447\u044C \u0432\u0440\u0430\u0436\u0435\u0441\u043A\u0438\u0435
    \u043A\u043E\u0440\u0430\u0431\u043B\u0438 \u0441\u0444\u043E\u043A\u0443\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u043C\u0438
    \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u043C\u0438 \u043B\u0443\u0447\u0430\u043C\u0438.
    \u0418\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430
    \u0431\u044B\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u044B, \u0447\u0442\u043E
    \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u043B\u0438 \u0440\u0438\u043C\u043B\u044F\u043D
    \u043E\u0442\u043A\u0430\u0437\u0430\u0442\u044C\u0441\u044F \u043E\u0442 \u0448\u0442\u0443\u0440\u043C\u0430
    \u0438 \u043F\u0435\u0440\u0435\u0439\u0442\u0438 \u043A \u0434\u043E\u043B\u0433\u043E\u0439
    \u043E\u0441\u0430\u0434\u0435.  \u0421\u043C\u0435\u0440\u0442\u044C \u0438
    \u043F\u0430\u043C\u044F\u0442\u044C.  \u0413\u043E\u0440\u043E\u0434 \u043F\u0430\u043B
    \u0432 **212 \u0433\u043E\u0434\u0443 \u0434\u043E \u043D.\u044D.** \u0438\u0437-\u0437\u0430
    \u0438\u0437\u043C\u0435\u043D\u044B. \u0413\u0438\u0431\u0435\u043B\u044C \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0431\u044B\u043B\u0430 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0439
    \u0438 \u0436\u0435\u0441\u0442\u043E\u043A\u043E\u0439. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
