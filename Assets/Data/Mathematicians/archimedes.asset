    \u0442\u0435\u043B\u0430\u0445\xBB \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0437\u0430\u043A\u043E\u043D: \u043D\u0430 \u0442\u0435\u043B\u043E, \u043F\u043E\u0433\u0440\u0443\u0436\u0435\u043D\u043D\u043E\u0435
    \u0432 \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u044C, \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442
    \u0432\u044B\u0442\u0430\u043B\u043A\u0438\u0432\u0430\u044E\u0449\u0430\u044F
    \u0441\u0438\u043B\u0430, \u0440\u0430\u0432\u043D\u0430\u044F \u0432\u0435\u0441\u0443
    \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0438 \u0432 \u043E\u0431\u044A\u0435\u043C\u0435
    \u044D\u0442\u043E\u0433\u043E \u0442\u0435\u043B\u0430. *   **\u041B\u0435\u0433\u0435\u043D\u0434\u0430
    \u043E\u0431 \xAB\u042D\u0432\u0440\u0438\u043A\u0435!\xBB**: \u0421 \u044D\u0442\u0438\u043C
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\u043C \u0441\u0432\u044F\u0437\u0430\u043D\u0430
    \u0441\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430. \u0426\u0430\u0440\u044C \u0413\u0438\u0435\u0440\u043E\u043D
    \u043F\u043E\u0440\u0443\u0447\u0438\u043B \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0443
    \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C, \u043D\u0435 \u043E\u0431\u043C\u0430\u043D\u0443\u043B
    \u043B\u0438 \u0435\u0433\u043E \u044E\u0432\u0435\u043B\u0438\u0440, \u0441\u0434\u0435\u043B\u0430\u0432\u0448\u0438\u0439
    \u0437\u043E\u043B\u043E\u0442\u0443\u044E \u043A\u043E\u0440\u043E\u043D\u0443.
    \u0420\u0430\u0437\u043C\u044B\u0448\u043B\u044F\u044F \u043D\u0430\u0434 \u0437\u0430\u0434\u0430\u0447\u0435\u0439,
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434, \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u0432\u0448\u0438\u0441\u044C
    \u0432 \u0432\u0430\u043D\u043D\u0443, \u0437\u0430\u043C\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u0432\u043E\u0434\u044B
    \u043F\u043E\u0434\u043D\u044F\u043B\u0441\u044F, \u0438 \u043F\u043E\u043D\u044F\u043B,
    \u043A\u0430\u043A \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u044C \u043E\u0431\u044A\u0435\u043C
    \u043A\u043E\u0440\u043E\u043D\u044B \u043F\u043E \u043E\u0431\u044A\u0435\u043C\u0443
    \u0432\u044B\u0442\u0435\u0441\u043D\u0435\u043D\u043D\u043E\u0439 \u0432\u043E\u0434\u044B.
    \u0421 \u043A\u0440\u0438\u043A\u043E\u043C \xAB\u042D\u0432\u0440\u0438\u043A\u0430!\xBB
    (\xAB\u041D\u0430\u0448\u0435\u043B!\xBB) \u043E\u043D \u0432\u044B\u0441\u043A\u043E\u0447\u0438\u043B
    \u0438\u0437 \u0432\u0430\u043D\u043D\u044B \u0438 \u043F\u043E\u0431\u0435\u0436\u0430\u043B
    \u043A \u0446\u0430\u0440\u044E. \u0422\u0430\u043A \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043A\u043E\u0440\u043E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u0441\u0434\u0435\u043B\u0430\u043D\u0430 \u043D\u0435 \u0438\u0437 \u0447\u0438\u0441\u0442\u043E\u0433\u043E
    \u0437\u043E\u043B\u043E\u0442\u0430.  ### \u0418\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u043E\u0435
    \u0434\u0435\u043B\u043E \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F 
    \u041F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0438
    \u0435\u043C\u0443 \u043E\u0433\u0440\u043E\u043C\u043D\u0443\u044E \u0441\u043B\u0430\u0432\u0443
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438.  *   **\u041E\u0431\u043E\u0440\u043E\u043D\u0430
    \u0421\u0438\u0440\u0430\u043A\u0443\u0437**: \u0412\u043E \u0432\u0440\u0435\u043C\u044F
    \u043E\u0441\u0430\u0434\u044B \u0435\u0433\u043E \u0440\u043E\u0434\u043D\u043E\u0433\u043E
    \u0433\u043E\u0440\u043E\u0434\u0430 \u0440\u0438\u043C\u043B\u044F\u043D\u0430\u043C\u0438
    \u0432\u043E \u0412\u0442\u043E\u0440\u043E\u0439 \u041F\u0443\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0432\u043E\u0439\u043D\u0435, \u043F\u0440\u0435\u0441\u0442\u0430\u0440\u0435\u043B\u044B\u0439
    \u0443\u0447\u0435\u043D\u044B\u0439 \u0441\u043E\u0437\u0434\u0430\u043B \u043C\u0430\u0448\u0438\u043D\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432 \u0442\u0435\u0447\u0435\u043D\u0438\u0435
    \u0434\u0432\u0443\u0445 \u043B\u0435\u0442 \u043D\u0435 \u0434\u0430\u0432\u0430\u043B\u0438
    \u0432\u0440\u0430\u0433\u0443 \u0432\u0437\u044F\u0442\u044C \u0433\u043E\u0440\u043E\u0434.
    \u041E\u043D \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u043C\u043E\u0449\u043D\u044B\u0435 \u043A\u0430\u0442\u0430\u043F\u0443\u043B\u044C\u0442\u044B
    \u0438 \u0431\u0430\u043B\u043B\u0438\u0441\u0442\u044B, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043F\u043E\u0434\u044A\u0435\u043C\u043D\u044B\u0435 \u043A\u0440\u0430\u043D\u044B
    (\xAB\u041A\u043E\u0433\u043E\u0442\u044C \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430\xBB),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u043B\u0438
    \u043D\u043E\u0441\u044B \u0440\u0438\u043C\u0441\u043A\u0438\u0445 \u0433\u0430\u043B\u0435\u0440,
    \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u043B\u0438 \u0438\u0445 \u0432 \u0432\u043E\u0437\u0434\u0443\u0445
    \u0438 \u0440\u0430\u0437\u0431\u0438\u0432\u0430\u043B\u0438 \u043E \u0441\u043A\u0430\u043B\u044B
    \u0438\u043B\u0438 \u043F\u0435\u0440\u0435\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u043B\u0438.
    \u0415\u043C\u0443 \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0437\u0430\u0436\u0438\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0437\u0435\u0440\u043A\u0430\u043B \u0434\u043B\u044F \u043F\u043E\u0434\u0436\u043E\u0433\u0430
    \u0432\u0440\u0430\u0436\u0435\u0441\u043A\u043E\u0433\u043E \u0444\u043B\u043E\u0442\u0430,
    \u0445\u043E\u0442\u044F \u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E\u0441\u0442\u044C
    \u044D\u0442\u043E\u0433\u043E \u0444\u0430\u043A\u0442\u0430 \u0441\u0442\u0430\u0432\u0438\u0442\u0441\u044F
    \u043F\u043E\u0434 \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u0435. *   **\xAB\u0410\u0440\u0445\u0438\u043C\u0435\u0434\u043E\u0432
    \u0432\u0438\u043D\u0442\xBB**: \u042D\u0442\u043E \u0432\u043E\u0434\u043E\u043F\u043E\u0434\u044A\u0435\u043C\u043D\u044B\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C (\u0448\u043D\u0435\u043A),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u0434\u043B\u044F \u043E\u0440\u043E\u0448\u0435\u043D\u0438\u044F \u043F\u043E\u043B\u0435\u0439
    \u0438 \u043E\u0441\u0443\u0448\u0435\u043D\u0438\u044F \u0431\u043E\u043B\u043E\u0442.
    \u041F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E, \u043D\u043E
    \u0435\u0433\u043E \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u043D\u044B\u0439
    \u0432\u0430\u0440\u0438\u0430\u043D\u0442 \u043C\u043E\u0436\u043D\u043E \u043D\u0430\u0439\u0442\u0438
    \u0438 \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u043C\u044F\u0441\u043E\u0440\u0443\u0431\u043A\u0430\u0445. *   **\u041C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u044B
    \u0434\u043B\u044F \u043F\u043E\u0434\u044A\u0435\u043C\u0430 \u0442\u044F\u0436\u0435\u0441\u0442\u0435\u0439**:
    \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u0431\u043B\u043E\u043A\u043E\u0432 (\u043F\u043E\u043B\u0438\u0441\u043F\u0430\u0441\u0442),
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043A\u043E\u0442\u043E\u0440\u043E\u0439,
    \u043A\u0430\u043A \u0433\u043B\u0430\u0441\u0438\u0442 \u043B\u0435\u0433\u0435\u043D\u0434\u0430,
    \u0432 \u043E\u0434\u0438\u043D\u043E\u0447\u043A\u0443 \u0441\u043C\u043E\u0433
    \u0441\u043F\u0443\u0441\u0442\u0438\u0442\u044C \u043D\u0430 \u0432\u043E\u0434\u0443
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439 \u043A\u043E\u0440\u0430\u0431\u043B\u044C
    \xAB\u0421\u0438\u0440\u0430\u043A\u0443\u0437\u0438\u044F\xBB, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0435 \u043C\u043E\u0433\u043B\u0438 \u0441\u0434\u0432\u0438\u043D\u0443\u0442\u044C
    \u0441\u043E\u0442\u043D\u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A. *  
    **\u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F \u0438 \u043F\u043B\u0430\u043D\u0435\u0442\u0430\u0440\u0438\u0439**:
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u044B\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u043B\u0430\u043D\u0435\u0442\u0430\u0440\u0438\u0439 (\xAB\u043D\u0435\u0431\u0435\u0441\u043D\u0443\u044E
    \u0441\u0444\u0435\u0440\u0443\xBB), \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435
    \u043F\u043B\u0430\u043D\u0435\u0442, \u0421\u043E\u043B\u043D\u0446\u0430 \u0438
    \u041B\u0443\u043D\u044B, \u0430 \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B
    \u0444\u0430\u0437\u044B \u0438 \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u044F. 
    \u0418\u0434\u0435\u0438 \u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430 \u043D\u0430 \u0446\u0435\u043B\u044B\u0445
    \u0434\u0432\u0430 \u0442\u044B\u0441\u044F\u0447\u0435\u043B\u0435\u0442\u0438\u044F
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438 \u0441\u0432\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441\u0442\u0430\u043B\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0432 \u044D\u043F\u043E\u0445\u0443
    \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0432\u044B\u0440\u043E\u0441\u043B\u043E
    \u0437\u0434\u0430\u043D\u0438\u0435 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0444\u0438\u0437\u0438\u043A\u0438."
  achievementsEn: 
  personalLifeRu: "\u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u043B\u0438\u0447\u043D\u0443\u044E \u0436\u0438\u0437\u043D\u044C \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430
    \u043F\u043E \u0433\u043E\u0434\u0430\u043C \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E.
    \u041D\u0430\u0443\u0447\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F,
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u0430\u044F \u0435\u0433\u043E
    \u0434\u0440\u0443\u0433\u043E\u043C \u0413\u0435\u0440\u0430\u043A\u043B\u0438\u0434\u043E\u043C,
    \u0431\u044B\u043B\u0430 \u0443\u0442\u0435\u0440\u044F\u043D\u0430, \u0430 \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432
    \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0435\u043D\u044B
    \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C \u043D\u0430 \u0435\u0433\u043E
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F\u0445 \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F\u0445. 
    \u0412\u0441\u044F \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u0430\u044F \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F
    \u043E \u0435\u0433\u043E \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u043C \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u0441\u0432\u043E\u0434\u0438\u0442\u0441\u044F \u043A \u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E\u043C\u0443
    \u0444\u0430\u043A\u0442\u0443: **\u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u0431\u044B\u043B \u043B\u0438 \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0436\u0435\u043D\u0430\u0442
    \u0438 \u0438\u043C\u0435\u043B \u043B\u0438 \u0434\u0435\u0442\u0435\u0439**
    . \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043D\u0435 \u043D\u0430\u0448\u043B\u0438
    \u043D\u0438\u043A\u0430\u043A\u0438\u0445 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0431\u044B \u043F\u0440\u043E\u043B\u0438\u0432\u0430\u043B\u0438
    \u0441\u0432\u0435\u0442 \u043D\u0430 \u044D\u0442\u0443 \u0441\u0442\u043E\u0440\u043E\u043D\u0443
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.  \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u044B
    \u043B\u0438\u0448\u044C \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u043E \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u0435:
    *   **\u041E\u0442\u0435\u0446**: \u0424\u0438\u0434\u0438\u0439, \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A. *   **\u0420\u043E\u0434\u0441\u0442\u0432\u043E**:
    \u041F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B \u0432 \u0440\u043E\u0434\u0441\u0442\u0432\u0435
    \u0441 \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u0435\u043C \u0421\u0438\u0440\u0430\u043A\u0443\u0437
    \u0413\u0438\u0435\u0440\u043E\u043D\u043E\u043C II.  \u041E\u0441\u0442\u0430\u0451\u0442\u0441\u044F
    \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u0440\u0438\u043D\u044F\u0442\u044C
    \u0442\u043E\u0442 \u0444\u0430\u043A\u0442, \u0447\u0442\u043E \xAB\u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C\xBB \u044D\u0442\u043E\u0433\u043E \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u0443\u0447\u0451\u043D\u043E\u0433\u043E \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C \u0432\u043D\u0435 \u043F\u043E\u043B\u044F
    \u0437\u0440\u0435\u043D\u0438\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u0438,
    \u0443\u0441\u0442\u0443\u043F\u0438\u0432 \u043C\u0435\u0441\u0442\u043E \u0435\u0433\u043E
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C \u0442\u0440\u0443\u0434\u0430\u043C
    \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F\u043C."
  personalLifeEn: 
  shortBioRu: "\u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u043E \u0436\u0438\u0437\u043D\u0438 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430
    \u0434\u043E\u0448\u043B\u0438 \u0434\u043E \u043D\u0430\u0441 \u0438\u0437 \u0442\u0440\u0443\u0434\u043E\u0432
    \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432,
    \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A \u041F\u043B\u0443\u0442\u0430\u0440\u0445,
    \u0422\u0438\u0442 \u041B\u0438\u0432\u0438\u0439 \u0438 \u0426\u0438\u0446\u0435\u0440\u043E\u043D,
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0434\u0430\u0442\u044B \u0438 \u0441\u043E\u0431\u044B\u0442\u0438\u044F \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u043F\u0440\u0438\u0431\u043B\u0438\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438. 
    ### \u041D\u0430\u0447\u0430\u043B\u043E \u043F\u0443\u0442\u0438 \u0432 \u0421\u0438\u0440\u0430\u043A\u0443\u0437\u0430\u0445
    (\u043E\u043A. 287 \u0433. \u0434\u043E \u043D. \u044D.)  **\u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u043E\u043A\u043E\u043B\u043E 287
    \u0433\u043E\u0434\u0430 \u0434\u043E \u043D\u0430\u0448\u0435\u0439 \u044D\u0440\u044B**
    \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u0421\u0438\u0440\u0430\u043A\u0443\u0437\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0441\u044F
    \u043D\u0430 \u043E\u0441\u0442\u0440\u043E\u0432\u0435 \u0421\u0438\u0446\u0438\u043B\u0438\u044F.
    \u0412 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u044D\u0442\u043E \u0431\u044B\u043B
    \u043A\u0440\u0443\u043F\u043D\u044B\u0439 \u0438 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0439 \u043F\u043E\u043B\u0438\u0441.
    \u0415\u0433\u043E \u043E\u0442\u0446\u043E\u043C, \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0431\u044B\u043B \u0424\u0438\u0434\u0438\u0439 \u2014 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0441\u043E\u0441\u0442\u043E\u044F\u0432\u0448\u0438\u0439
    \u0432 \u0431\u043B\u0438\u0437\u043A\u043E\u043C \u0440\u043E\u0434\u0441\u0442\u0432\u0435
    \u0441 \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u0435\u043C \u0421\u0438\u0440\u0430\u043A\u0443\u0437,
    \u0442\u0438\u0440\u0430\u043D\u043E\u043C \u0413\u0438\u0435\u0440\u043E\u043D\u043E\u043C
    II . \u042D\u0442\u043E \u0440\u043E\u0434\u0441\u0442\u0432\u043E \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u043B\u043E \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0443
    \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438 \u0434\u043B\u044F
    \u0437\u0430\u043D\u044F\u0442\u0438\u0439 \u043D\u0430\u0443\u043A\u043E\u0439. 
    ### \u0413\u043E\u0434\u044B \u0443\u0447\u0435\u043D\u0438\u044F \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438
    (\u043E\u043A. 287 - \u043E\u043A. 265 \u0433. \u0434\u043E \u043D. \u044D.) 
    \u0414\u043B\u044F \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u044E \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0443\u044E**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u044B\u043B\u0430 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u043C
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0438 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u044B\u043C
    \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430. \u0422\u0430\u043C, \u0432 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u043C
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u043C
    \u043C\u0443\u0441\u0435\u0439\u043E\u043D\u0435 \u0438 \u043F\u0440\u0438 \u0435\u0433\u043E
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0435, \u0441\u043E\u0431\u0440\u0430\u0432\u0448\u0435\u0439
    \u0441\u043E\u0442\u043D\u0438 \u0442\u044B\u0441\u044F\u0447 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0435\u0439,
    \u043E\u043D \u0441\u043C\u043E\u0433 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0442\u044C\u0441\u044F
    \u0441 \u0442\u0440\u0443\u0434\u0430\u043C\u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0445 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u043E\u0432,
    \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A \u0414\u0435\u043C\u043E\u043A\u0440\u0438\u0442
    \u0438 \u0415\u0432\u0434\u043E\u043A\u0441. \u0412 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0442\u0430\u043A\u0436\u0435 \u043F\u043E\u0434\u0440\u0443\u0436\u0438\u043B\u0441\u044F
    \u0438 \u0432\u0451\u043B \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443
    \u0441 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C\u0438 \u0443\u0447\u0451\u043D\u044B\u043C\u0438
    \u2014 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C \u041A\u043E\u043D\u043E\u043D\u043E\u043C
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u043E\u043C. 
    ### \u0417\u0440\u0435\u043B\u044B\u0435 \u0433\u043E\u0434\u044B \u0438 \u0440\u0430\u0441\u0446\u0432\u0435\u0442
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    (\u043E\u043A. 265 - 215 \u0433. \u0434\u043E \u043D. \u044D.)  \u041F\u043E
    \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0438 \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u044F
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u0440\u043E\u0434\u043D\u044B\u0435 \u0421\u0438\u0440\u0430\u043A\u0443\u0437\u044B,
    \u0433\u0434\u0435 \u043F\u0440\u043E\u0432\u0451\u043B \u0431\u043E\u043B\u044C\u0448\u0443\u044E
    \u0447\u0430\u0441\u0442\u044C \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438.
    \u041E\u043D \u043D\u0435 \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F
    \u043A \u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u043E\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u0435
    \u0438, \u0431\u0443\u0434\u0443\u0447\u0438 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u043D\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043C\u043E\u0433 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C \u0441\u0435\u0431\u044F
    \u043D\u0430\u0443\u043A\u0435. \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u043E\u0442
    \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D \u0434\u0435\u043B\u0430\u0435\u0442
    \u0441\u0432\u043E\u0438 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F. \u0421\u0440\u0435\u0434\u0438
    \u043D\u0438\u0445:  *   **\u0417\u0430\u043A\u043E\u043D \u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0438
    (\xAB\u0417\u0430\u043A\u043E\u043D \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430\xBB)**.
    \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435,
    \u0446\u0430\u0440\u044C \u0413\u0438\u0435\u0440\u043E\u043D \u043F\u043E\u0440\u0443\u0447\u0438\u043B
    \u0435\u043C\u0443 \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C, \u043D\u0435
    \u043E\u0431\u043C\u0430\u043D\u0443\u043B \u043B\u0438 \u044E\u0432\u0435\u043B\u0438\u0440,
    \u0441\u0434\u0435\u043B\u0430\u0432\u0448\u0438\u0439 \u0437\u043E\u043B\u043E\u0442\u0443\u044E
    \u043A\u043E\u0440\u043E\u043D\u0443, \u043F\u043E\u0434\u043C\u0435\u0448\u0430\u0432
    \u0432 \u043D\u0435\u0451 \u0441\u0435\u0440\u0435\u0431\u0440\u043E. \u0420\u0430\u0437\u043C\u044B\u0448\u043B\u044F\u044F
    \u043D\u0430\u0434 \u0437\u0430\u0434\u0430\u0447\u0435\u0439, \u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u043D\u0430\u0448\u0451\u043B \u0440\u0435\u0448\u0435\u043D\u0438\u0435, \u043A\u043E\u0433\u0434\u0430
    \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u043B\u0441\u044F \u0432 \u0432\u0430\u043D\u043D\u0443:
    \u043E\u0431\u044A\u0451\u043C \u0432\u044B\u0442\u0435\u0441\u043D\u0435\u043D\u043D\u043E\u0439
    \u0432\u043E\u0434\u044B \u0440\u0430\u0432\u0435\u043D \u043E\u0431\u044A\u0451\u043C\u0443
    \u043F\u043E\u0433\u0440\u0443\u0436\u0451\u043D\u043D\u043E\u0433\u043E \u0442\u0435\u043B\u0430.
    \u0421 \u043A\u0440\u0438\u043A\u043E\u043C \xAB\u042D\u0432\u0440\u0438\u043A\u0430!\xBB
    \u043E\u043D \u0432\u044B\u0441\u043A\u043E\u0447\u0438\u043B \u0438\u0437 \u0432\u0430\u043D\u043D\u044B
    \u0438 \u043F\u043E\u0431\u0435\u0436\u0430\u043B \u0434\u043E\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0442\u044C
    \u043E \u0441\u0432\u043E\u0451\u043C \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0438.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0440\u044B\u0447\u0430\u0433\u0430
    \u0438 \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u044B**.
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u043F\u0438\u0441\u0430\u043B \u0437\u0430\u043A\u043E\u043D \u0440\u044B\u0447\u0430\u0433\u0430,
    \u043D\u043E \u0438 \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u0431\u043B\u043E\u0447\u043D\u044B\u0435 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u044B
    (\u043F\u043E\u043B\u0438\u0441\u043F\u0430\u0441\u0442\u044B). \u0415\u043C\u0443
    \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0444\u0440\u0430\u0437\u0443: **\xAB\u0414\u0430\u0439\u0442\u0435 \u043C\u043D\u0435
    \u0442\u043E\u0447\u043A\u0443 \u043E\u043F\u043E\u0440\u044B, \u0438 \u044F
    \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443 \u043C\u0438\u0440\xBB**.
    \u0421 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u044D\u0442\u0438\u0445 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432
    \u043E\u043D \u0441\u043C\u043E\u0433 \u0432 \u043E\u0434\u0438\u043D\u043E\u0447\u043A\u0443
    \u0441\u043F\u0443\u0441\u0442\u0438\u0442\u044C \u043D\u0430 \u0432\u043E\u0434\u0443
    \u0442\u044F\u0436\u0435\u043B\u043E\u0433\u0440\u0443\u0436\u0451\u043D\u044B\u0439
    \u043A\u043E\u0440\u0430\u0431\u043B\u044C \xAB\u0421\u0438\u0440\u0430\u043A\u0443\u0437\u0438\u044F\xBB,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043D\u0435 \u043C\u043E\u0433\u043B\u0438
    \u0441\u0434\u0432\u0438\u043D\u0443\u0442\u044C \u0441\u043E\u0442\u043D\u0438
    \u043B\u044E\u0434\u0435\u0439. \u0422\u0430\u043A\u0436\u0435 \u0435\u043C\u0443
    \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435
    \u0432\u043E\u0434\u043E\u043F\u043E\u0434\u044A\u0451\u043C\u043D\u043E\u0433\u043E
    \u0432\u0438\u043D\u0442\u0430 (\xAB\u0430\u0440\u0445\u0438\u043C\u0435\u0434\u043E\u0432
    \u0432\u0438\u043D\u0442\xBB), \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u0442\u0440\u0430\u043D\u0430\u0445.
    *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430**. \u0412
    \u0441\u0432\u043E\u0438\u0445 \u0442\u0440\u0443\u0434\u0430\u0445 (\xAB\u041E\u0431
    \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0438 \u043A\u0440\u0443\u0433\u0430\xBB,
    \xAB\u041E \u0448\u0430\u0440\u0435 \u0438 \u0446\u0438\u043B\u0438\u043D\u0434\u0440\u0435\xBB)
    \u043E\u043D \u0441 \u0432\u044B\u0441\u043E\u043A\u043E\u0439 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B \u0447\u0438\u0441\u043B\u043E
    \u03C0 \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \u043E\u0431\u044A\u0451\u043C \u0448\u0430\u0440\u0430 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0441\u044F
    \u043A \u043E\u0431\u044A\u0451\u043C\u0443 \u043E\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E
    \u0432\u043E\u043A\u0440\u0443\u0433 \u043D\u0435\u0433\u043E \u0446\u0438\u043B\u0438\u043D\u0434\u0440\u0430
    \u043A\u0430\u043A 2:3. \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u043E\u043D \u0446\u0435\u043D\u0438\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E,
    \u0447\u0442\u043E \u0437\u0430\u0432\u0435\u0449\u0430\u043B \u0432\u044B\u0441\u0435\u0447\u044C
    \u043D\u0430 \u0441\u0432\u043E\u0435\u0439 \u043C\u043E\u0433\u0438\u043B\u0435
    \u0438\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u0443 \u0444\u0438\u0433\u0443\u0440\u0443
    .  ### \u0418\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u0430\u044F \u043E\u0431\u043E\u0440\u043E\u043D\u0430
    \u0421\u0438\u0440\u0430\u043A\u0443\u0437 (214 - 212 \u0433\u0433. \u0434\u043E
    \u043D. \u044D.)  \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u0412\u0442\u043E\u0440\u043E\u0439
    \u041F\u0443\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0432\u043E\u0439\u043D\u044B
    \u0440\u0438\u043C\u0441\u043A\u0438\u0439 \u0444\u043B\u043E\u0442 \u0438 \u0430\u0440\u043C\u0438\u044F
    \u043F\u043E\u0434 \u043A\u043E\u043C\u0430\u043D\u0434\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043A\u043E\u043D\u0441\u0443\u043B\u0430 \u041C\u0430\u0440\u0446\u0435\u043B\u043B\u0430
    \u043E\u0441\u0430\u0434\u0438\u043B\u0438 \u0421\u0438\u0440\u0430\u043A\u0443\u0437\u044B.
    **75-\u043B\u0435\u0442\u043D\u0438\u0439 \u0410\u0440\u0445\u0438\u043C\u0435\u0434**
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043B \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u0443\u044E
    \u043E\u0431\u043E\u0440\u043E\u043D\u0443 \u0433\u043E\u0440\u043E\u0434\u0430. 
    *   **\u0412\u043E\u0435\u043D\u043D\u044B\u0435 \u043C\u0430\u0448\u0438\u043D\u044B**.
    \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u043C\u043E\u0449\u043D\u044B\u0435
    \u043A\u0430\u0442\u0430\u043F\u0443\u043B\u044C\u0442\u044B \u0438 \u0431\u0430\u043B\u043B\u0438\u0441\u0442\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u0435\u0442\u0430\u043B\u0438
    \u0442\u044F\u0436\u0451\u043B\u044B\u0435 \u043A\u0430\u043C\u043D\u0438 \u0438
    \u043A\u043E\u043F\u044C\u044F \u0432 \u0440\u0438\u043C\u0441\u043A\u0438\u0435
    \u043A\u043E\u0440\u0430\u0431\u043B\u0438 \u0438 \u0441\u043E\u043B\u0434\u0430\u0442.
    *   **\xAB\u041A\u043E\u0433\u043E\u0442\u044C \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430\xBB**.
    \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F\u043C,
    \u043E\u043D \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u043F\u043E\u0434\u044A\u0451\u043C\u043D\u044B\u0435 \u043A\u0440\u0430\u043D\u044B
    \u0441 \u0436\u0435\u043B\u0435\u0437\u043D\u044B\u043C\u0438 \u043A\u0440\u044E\u043A\u0430\u043C\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u043B\u0438
    \u043D\u043E\u0441\u044B \u0440\u0438\u043C\u0441\u043A\u0438\u0445 \u0433\u0430\u043B\u0435\u0440,
    \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u043B\u0438 \u0438\u0445 \u0432 \u0432\u043E\u0437\u0434\u0443\u0445
    \u0438 \u0448\u0432\u044B\u0440\u044F\u043B\u0438 \u0432\u043D\u0438\u0437, \u0440\u0430\u0437\u0431\u0438\u0432\u0430\u044F
    \u043E \u0441\u043A\u0430\u043B\u044B \u0438\u043B\u0438 \u043F\u0435\u0440\u0435\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u044F.
    \u042D\u0442\u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0430\u043F\u0443\u0433\u0430\u043B\u0438
    \u0440\u0438\u043C\u043B\u044F\u043D, \u0447\u0442\u043E \u043E\u043D\u0438 \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C
    \u043E\u0442 \u0448\u0442\u0443\u0440\u043C\u0430 \u0438 \u043F\u0435\u0440\u0435\u0448\u043B\u0438
    \u043A \u0434\u043E\u043B\u0433\u043E\u0439 \u043E\u0441\u0430\u0434\u0435. 
    ### \u0413\u0438\u0431\u0435\u043B\u044C (212 \u0433. \u0434\u043E \u043D. \u044D.) 
    **\u041E\u0441\u0435\u043D\u044C\u044E 212 \u0433\u043E\u0434\u0430 \u0434\u043E
    \u043D. \u044D.** \u0440\u0438\u043C\u043B\u044F\u043D\u0430\u043C \u0443\u0434\u0430\u043B\u043E\u0441\u044C
    \u0432\u0437\u044F\u0442\u044C \u0421\u0438\u0440\u0430\u043A\u0443\u0437\u044B
    \u0438\u0437-\u0437\u0430 \u043F\u0440\u0435\u0434\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0438 \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043F\u0440\u0430\u0437\u0434\u043D\u0438\u043A\u0430.
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u0448\u0442\u0443\u0440\u043C\u0430
    \u0433\u043E\u0440\u043E\u0434\u0430 \u0440\u0438\u043C\u0441\u043A\u0438\u0439
    \u0441\u043E\u043B\u0434\u0430\u0442 \u0443\u0431\u0438\u043B \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430. 
    \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0432\u0435\u0440\u0441\u0438\u0439 \u0435\u0433\u043E \u0433\u0438\u0431\u0435\u043B\u0438,
    \u043D\u043E \u0432\u0441\u0435 \u043E\u043D\u0438 \u0441\u0445\u043E\u0434\u044F\u0442\u0441\u044F
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u0443\u0447\u0451\u043D\u044B\u0439
    \u0431\u044B\u043B \u0443\u0431\u0438\u0442 \u0432 \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442,
    \u043A\u043E\u0433\u0434\u0430 \u0431\u044B\u043B \u043F\u043E\u0433\u0440\u0443\u0436\u0451\u043D
    \u0432 \u0441\u0432\u043E\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F. \u041F\u043E
    \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439
    \u0432\u0435\u0440\u0441\u0438\u0438, \u043E\u043D \u0447\u0435\u0440\u0442\u0438\u043B
    \u043D\u0430 \u043F\u0435\u0441\u043A\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0444\u0438\u0433\u0443\u0440\u044B \u0438, \u043A\u043E\u0433\u0434\u0430 \u043A
    \u043D\u0435\u043C\u0443 \u043F\u043E\u0434\u043E\u0448\u0451\u043B \u0440\u0438\u043C\u0441\u043A\u0438\u0439
    \u0432\u043E\u0438\u043D, \u0432\u043E\u0441\u043A\u043B\u0438\u043A\u043D\u0443\u043B:
    **\xAB\u041D\u0435 \u0442\u0440\u043E\u0433\u0430\u0439 \u043C\u043E\u0438\u0445
    \u0447\u0435\u0440\u0442\u0435\u0436\u0435\u0439!\xBB**, \u043F\u043E\u0441\u043B\u0435
    \u0447\u0435\u0433\u043E \u0431\u044B\u043B \u0437\u0430\u0440\u0443\u0431\u043B\u0435\u043D. 
    ### \u041F\u0430\u043C\u044F\u0442\u044C  **\u0421\u043F\u0443\u0441\u0442\u044F
    \u043F\u043E\u0447\u0442\u0438 150 \u043B\u0435\u0442**, \u0432 75 \u0433\u043E\u0434\u0443
    \u0434\u043E \u043D. \u044D., \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0440\u0438\u043C\u0441\u043A\u0438\u0439 \u043E\u0440\u0430\u0442\u043E\u0440
    \u0426\u0438\u0446\u0435\u0440\u043E\u043D, \u0431\u0443\u0434\u0443\u0447\u0438
    \u043D\u0430 \u0421\u0438\u0446\u0438\u043B\u0438\u0438, \u0440\u0430\u0437\u044B\u0441\u043A\u0430\u043B
    \u0438 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B \u0437\u0430\u043F\u0443\u0449\u0435\u043D\u043D\u0443\u044E
    \u043C\u043E\u0433\u0438\u043B\u0443 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430.
    \u041D\u0430 \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u0438 \u043E\u043D
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E \u0432 \u0446\u0438\u043B\u0438\u043D\u0434\u0440
    \u0448\u0430\u0440\u0430, \u043A\u0430\u043A \u0438 \u0437\u0430\u0432\u0435\u0449\u0430\u043B
    \u0443\u0447\u0451\u043D\u044B\u0439."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0438 \u0441\u043C\u0435\u0440\u0442\u044C
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430 \u043E\u043A\u0443\u0442\u0430\u043D\u044B
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E\u043C \u043B\u0435\u0433\u0435\u043D\u0434,
    \u0430\u043D\u0435\u043A\u0434\u043E\u0442\u043E\u0432 \u0438 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u0435\u0440\u0435\u0434\u0430\u0432\u0430\u043B\u0438\u0441\u044C \u0438\u0437
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F \u0432 \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0435.
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0440\u0438\u0441\u0443\u044E\u0442
    \u0435\u0433\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043A\u0430\u043A
    \u0441\u0443\u0445\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E,
    \u043D\u043E \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    \u0441 \u044F\u0440\u043A\u0438\u043C \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C
    \u0438 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439 \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0435\u0439. 
    ### 1. \xAB\u042D\u0432\u0440\u0438\u043A\u0430!\xBB \u0438 \u0432\u0430\u043D\u043D\u0430
    (\u043B\u0435\u0433\u0435\u043D\u0434\u0430 \u043E \u043A\u043E\u0440\u043E\u043D\u0435)
    \u042D\u0442\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u044B\u0439
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u0430\u043D\u0435\u043A\u0434\u043E\u0442 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438.
    \u0426\u0430\u0440\u044C \u0413\u0438\u0435\u0440\u043E\u043D \u0437\u0430\u043F\u043E\u0434\u043E\u0437\u0440\u0438\u043B
    \u044E\u0432\u0435\u043B\u0438\u0440\u0430 \u0432 \u043A\u0440\u0430\u0436\u0435
    \u0437\u043E\u043B\u043E\u0442\u0430 \u043F\u0440\u0438 \u0438\u0437\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u0438\u0438
    \u0440\u0438\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439 \u043A\u043E\u0440\u043E\u043D\u044B
    \u0438 \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430
    \u0440\u0430\u0437\u043E\u0431\u043B\u0430\u0447\u0438\u0442\u044C \u043E\u0431\u043C\u0430\u043D,
    \u043D\u0435 \u0440\u0430\u0437\u0440\u0443\u0448\u0430\u044F \u0438\u0437\u0434\u0435\u043B\u0438\u044F. 
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u043C\u0443\u0447\u0438\u043B\u0441\u044F
    \u043D\u0430\u0434 \u0437\u0430\u0434\u0430\u0447\u0435\u0439 \u0434\u043E\u043B\u0433\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F, \u043F\u043E\u043A\u0430 \u043E\u0434\u043D\u0430\u0436\u0434\u044B,
    \u043F\u043E\u0433\u0440\u0443\u0436\u0430\u044F\u0441\u044C \u0432 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u0443\u044E
    \u0434\u043E \u043A\u0440\u0430\u0435\u0432 \u0432\u0430\u043D\u043D\u0443, \u043D\u0435
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u0447\u0430\u0441\u0442\u044C
    \u0432\u043E\u0434\u044B \u0432\u044B\u043F\u043B\u0435\u0441\u043D\u0443\u043B\u0430\u0441\u044C
    \u043D\u0430\u0440\u0443\u0436\u0443. \u0412 \u044D\u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442
    \u0435\u0433\u043E \u043E\u0441\u0435\u043D\u0438\u043B\u043E: \u043E\u0431\u044A\u0435\u043C
    \u0432\u044B\u0442\u0435\u0441\u043D\u0435\u043D\u043D\u043E\u0439 \u0432\u043E\u0434\u044B
    \u0440\u0430\u0432\u0435\u043D \u043E\u0431\u044A\u0435\u043C\u0443 \u0435\u0433\u043E
    \u0442\u0435\u043B\u0430. \u0417\u043D\u0430\u0447\u0438\u0442, \u0447\u0442\u043E\u0431\u044B
    \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C \u043A\u043E\u0440\u043E\u043D\u0443,
    \u043D\u0443\u0436\u043D\u043E \u0441\u0440\u0430\u0432\u043D\u0438\u0442\u044C
    \u043E\u0431\u044A\u0435\u043C\u044B \u0432\u044B\u0442\u0435\u0441\u043D\u0435\u043D\u043D\u043E\u0439
    \u0432\u043E\u0434\u044B \u0434\u043B\u044F \u043A\u043E\u0440\u043E\u043D\u044B
    \u0438 \u0434\u043B\u044F \u0441\u043B\u0438\u0442\u043A\u0430 \u0437\u043E\u043B\u043E\u0442\u0430
    \u0442\u043E\u0433\u043E \u0436\u0435 \u0432\u0435\u0441\u0430.  \u041B\u0435\u0433\u0435\u043D\u0434\u0430
    \u0433\u043B\u0430\u0441\u0438\u0442, \u0447\u0442\u043E \u043E\u043D \u0431\u044B\u043B
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0432\u0437\u0431\u0443\u0434\u043E\u0440\u0430\u0436\u0435\u043D,
    \u0447\u0442\u043E \u0432\u044B\u0441\u043A\u043E\u0447\u0438\u043B \u0438\u0437
    \u0432\u0430\u043D\u043D\u044B \u0438 \u0433\u043E\u043B\u044B\u0448\u043E\u043C
    \u043F\u043E\u0431\u0435\u0436\u0430\u043B \u043F\u043E \u0443\u043B\u0438\u0446\u0430\u043C
    \u0421\u0438\u0440\u0430\u043A\u0443\u0437, \u043A\u0440\u0438\u0447\u0430 \u0432\u043E
    \u0432\u0435\u0441\u044C \u0433\u043E\u043B\u043E\u0441: **\xAB\u042D\u0432\u0440\u0438\u043A\u0430!
    \u042D\u0432\u0440\u0438\u043A\u0430!\xBB** (\xAB\u041D\u0430\u0448\u0435\u043B!
    \u041D\u0430\u0448\u0435\u043B!\xBB). \u042D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u043B \u043F\u043E\u0434\u043C\u0435\u043D\u0443:
    \u044E\u0432\u0435\u043B\u0438\u0440 \u0431\u044B\u043B \u043A\u0430\u0437\u043D\u0435\u043D,
    \u0430 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u043E
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u043E \u0437\u0430\u043A\u043E\u043D
    \u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0438.  ###
    2. \xAB\u0414\u0430\u0439\u0442\u0435 \u043C\u043D\u0435 \u0442\u043E\u0447\u043A\u0443
    \u043E\u043F\u043E\u0440\u044B, \u0438 \u044F \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443
    \u043C\u0438\u0440\xBB \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u043B \u0437\u0430\u043A\u043E\u043D
    \u0440\u044B\u0447\u0430\u0433\u0430, \u043D\u043E \u0438 \u043D\u0430\u0433\u043B\u044F\u0434\u043D\u043E
    \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438.
    \u0427\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0441\u0442\u0438
    \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u0438\u0435 \u043D\u0430
    \u0446\u0430\u0440\u044F \u0413\u0438\u0435\u0440\u043E\u043D\u0430, \u043E\u043D
    \u044F\u043A\u043E\u0431\u044B \u0437\u0430\u044F\u0432\u0438\u043B, \u0447\u0442\u043E
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0440\u044B\u0447\u0430\u0433\u0430
    \u0438 \u0431\u043B\u043E\u043A\u043E\u0432 \u0441\u043C\u043E\u0436\u0435\u0442
    \u0441\u0434\u0432\u0438\u043D\u0443\u0442\u044C \u0441 \u043C\u0435\u0441\u0442\u0430
    \u043B\u044E\u0431\u043E\u0439 \u0433\u0440\u0443\u0437, \u043A\u0430\u043A\u0438\u043C
    \u0431\u044B \u0442\u044F\u0436\u0435\u043B\u044B\u043C \u043E\u043D \u043D\u0438
    \u0431\u044B\u043B.  \u0426\u0430\u0440\u044C \u043F\u0440\u0438\u043A\u0430\u0437\u0430\u043B
    \u043F\u0440\u043E\u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u044D\u0442\u043E \u043D\u0430 \u043A\u043E\u0440\u0430\u0431\u043B\u0435 \xAB\u0421\u0438\u0440\u0430\u043A\u0443\u0437\u0438\u044F\xBB
    \u2014 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439 \u0433\u0440\u0443\u0436\u0435\u043D\u043E\u0439
    \u0442\u0440\u0438\u0440\u0435\u043C\u0435, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0441\u043E\u0442\u043D\u0438 \u043B\u044E\u0434\u0435\u0439 \u043D\u0435 \u043C\u043E\u0433\u043B\u0438
    \u0441\u0434\u0432\u0438\u043D\u0443\u0442\u044C \u0441 \u043C\u0435\u0441\u0442\u0430.
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0431\u043B\u043E\u043A\u043E\u0432 (\u043F\u043E\u043B\u0438\u0441\u043F\u0430\u0441\u0442\u043E\u0432)
    \u0438, \u0443\u0441\u0435\u0432\u0448\u0438\u0441\u044C \u043D\u0430 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0438, \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E
    \u043F\u043E\u0442\u044F\u043D\u0443\u043B \u0437\u0430 \u0432\u0435\u0440\u0435\u0432\u043A\u0443.
    **\u041A\u043E\u0440\u0430\u0431\u043B\u044C \u043F\u043B\u0430\u0432\u043D\u043E
    \u043F\u043E\u043F\u043B\u044B\u043B \u043F\u043E \u0432\u043E\u0434\u0435**,
    \u0441\u043B\u043E\u0432\u043D\u043E \u0435\u0433\u043E \u0442\u044F\u043D\u0443\u043B\u0430
    \u043D\u0435\u0432\u0438\u0434\u0438\u043C\u0430\u044F \u0441\u0438\u043B\u0430.
    \u0421 \u0442\u0435\u0445 \u043F\u043E\u0440 \u0444\u0440\u0430\u0437\u0430 \xAB\u0414\u0430\u0439\u0442\u0435
    \u043C\u043D\u0435 \u0442\u043E\u0447\u043A\u0443 \u043E\u043F\u043E\u0440\u044B...\xBB
    \u0441\u0442\u0430\u043B\u0430 \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C
    \u0441\u0438\u043B\u044B \u0443\u043C\u0430, \u0442\u043E\u0440\u0436\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0433\u043E
    \u043D\u0430\u0434 \u0433\u0440\u0443\u0431\u043E\u0439 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u043E\u0449\u044C\u044E.  ### 3. \u041D\u0435\u0431\u0435\u0441\u043D\u0430\u044F
    \u0441\u0444\u0435\u0440\u0430 \u2014 \u0434\u0440\u0435\u0432\u043D\u0438\u0439
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440 \u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u043B\u0430\u043D\u0435\u0442\u0430\u0440\u0438\u0439 \u2014 \xAB\u043D\u0435\u0431\u0435\u0441\u043D\u0443\u044E
    \u0441\u0444\u0435\u0440\u0443\xBB. \u042D\u0442\u043E \u0431\u044B\u043B\u043E
    \u0441\u043B\u043E\u0436\u043D\u043E\u0435 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E
    \u0441 \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439 \u0448\u0435\u0441\u0442\u0435\u0440\u0435\u043D\u043E\u043A,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u043E
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u0421\u043E\u043B\u043D\u0446\u0430,
    \u041B\u0443\u043D\u044B \u0438 \u043F\u044F\u0442\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0442\u043E\u0433\u0434\u0430 \u043F\u043B\u0430\u043D\u0435\u0442 \u043F\u043E
    \u043D\u0435\u0431\u0443. \u0423\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043D\u043E \u044D\u0442\u043E\u0442 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C
    \u043C\u043E\u0433 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u0444\u0430\u0437\u044B \u041B\u0443\u043D\u044B \u0438 \u0434\u0430\u0436\u0435
    \u043B\u0443\u043D\u043D\u044B\u0435 \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u044F. 
    \u042D\u0442\u043E \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0440\u0430\u0437\u0438\u043B\u043E
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u0447\u0442\u043E \u0434\u0430\u0436\u0435 \u0441\u043F\u0443\u0441\u0442\u044F
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0439
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u043E\u0440\u0430\u0442\u043E\u0440
    \u0426\u0438\u0446\u0435\u0440\u043E\u043D \u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u043D\u043E
    \u043F\u0438\u0441\u0430\u043B \u043E \u043D\u0435\u043C. \u041F\u043E \u0441\u0443\u0442\u0438,
    \u044D\u0442\u043E \u0431\u044B\u043B \u0434\u0440\u0435\u0432\u043D\u0435\u0439\u0448\u0438\u0439
    \u0432 \u043C\u0438\u0440\u0435 \u0430\u043D\u0430\u043B\u043E\u0433\u043E\u0432\u044B\u0439
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440, \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0438\u0439
    \u0441\u0432\u043E\u0435 \u0432\u0440\u0435\u043C\u044F \u043D\u0430 \u0434\u0432\u0435
    \u0442\u044B\u0441\u044F\u0447\u0438 \u043B\u0435\u0442.  ### 4. \u041E\u0431\u043E\u0440\u043E\u043D\u0430
    \u0421\u0438\u0440\u0430\u043A\u0443\u0437 \u043F\u0440\u043E\u0442\u0438\u0432
    \u0420\u0438\u043C\u0430 \u041A\u043E\u0433\u0434\u0430 \u0440\u0438\u043C\u0441\u043A\u0438\u0435
    \u0432\u043E\u0439\u0441\u043A\u0430 \u043E\u0441\u0430\u0434\u0438\u043B\u0438
    \u0421\u0438\u0440\u0430\u043A\u0443\u0437\u044B, \u043F\u0440\u0435\u0441\u0442\u0430\u0440\u0435\u043B\u044B\u0439
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B
    \u0440\u043E\u0434\u043D\u043E\u0439 \u0433\u043E\u0440\u043E\u0434 \u0432 \u043D\u0435\u043F\u0440\u0438\u0441\u0442\u0443\u043F\u043D\u0443\u044E
    \u043A\u0440\u0435\u043F\u043E\u0441\u0442\u044C. *   **\xAB\u041A\u043E\u0433\u043E\u0442\u044C
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430\xBB**: \u041E\u043D \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u043F\u043E\u0434\u044A\u0435\u043C\u043D\u044B\u0435 \u043A\u0440\u0430\u043D\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043F\u0443\u0441\u043A\u0430\u043B\u0438\u0441\u044C
    \u043D\u0430 \u043A\u043E\u0440\u0430\u0431\u043B\u0438 \u043D\u0435\u043F\u0440\u0438\u044F\u0442\u0435\u043B\u044F,
    \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u043B\u0438 \u0438\u0445
    \u0436\u0435\u043B\u0435\u0437\u043D\u044B\u043C\u0438 \u043A\u0440\u044E\u043A\u0430\u043C\u0438
    \u0437\u0430 \u043D\u043E\u0441, \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u043B\u0438
    \u0432 \u0432\u043E\u0437\u0434\u0443\u0445, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0441\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043B\u0438 \u0432\u043D\u0438\u0437,
    \u0440\u0430\u0437\u0431\u0438\u0432\u0430\u044F \u043E \u0441\u043A\u0430\u043B\u044B.
    \u0421\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u0438 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0438,
    \u0447\u0442\u043E \u043A\u043E\u0440\u0430\u0431\u043B\u0438 \u043F\u0435\u0440\u0435\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u043B\u0438\u0441\u044C
    \u0438 \u0442\u043E\u043D\u0443\u043B\u0438, \u0430 \u044D\u043A\u0438\u043F\u0430\u0436\u0438
    \u0431\u044B\u043B\u0438 \u0432 \u0443\u0436\u0430\u0441\u0435. *   **\u0413\u0438\u0433\u0430\u043D\u0442\u0441\u043A\u0438\u0435
    \u043A\u0430\u0442\u0430\u043F\u0443\u043B\u044C\u0442\u044B**: \u041E\u043D
    \u0441\u043E\u0437\u0434\u0430\u043B \u043C\u0435\u0442\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043C\u0430\u0448\u0438\u043D\u044B \u0440\u0430\u0437\u043D\u043E\u0439 \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u0438:
    \u043E\u0434\u043D\u0438 \u0431\u0438\u043B\u0438 \u043D\u0430 \u0434\u0430\u043B\u044C\u043D\u0438\u0435
    \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F, \u043F\u043E\u0440\u0430\u0436\u0430\u044F
    \u043A\u043E\u0440\u0430\u0431\u043B\u0438 \u0434\u043E \u0442\u043E\u0433\u043E,
    \u043A\u0430\u043A \u0442\u0435 \u043F\u043E\u0434\u043E\u0439\u0434\u0443\u0442
    \u043A \u0431\u0435\u0440\u0435\u0433\u0443, \u0434\u0440\u0443\u0433\u0438\u0435
    \u2014 \u0441 \u0431\u043B\u0438\u0437\u043A\u043E\u0439 \u0434\u0438\u0441\u0442\u0430\u043D\u0446\u0438\u0438,
    \u043F\u0440\u043E\u0431\u0438\u0432\u0430\u044F \u0431\u043E\u0440\u0442\u0430. 
    \u0412 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435 \u0440\u0438\u043C\u0441\u043A\u0438\u0439
    \u043F\u043E\u043B\u043A\u043E\u0432\u043E\u0434\u0435\u0446 \u041C\u0430\u0440\u0446\u0435\u043B\u043B,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u0441\u0432\u043E\u0435\u0439
    \u0445\u0440\u0430\u0431\u0440\u043E\u0441\u0442\u044C\u044E, \u0432 \u0443\u0436\u0430\u0441\u0435
    \u0432\u043E\u0441\u043A\u043B\u0438\u043A\u043D\u0443\u043B, \u0447\u0442\u043E
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0432\u0435\u0434\u0435\u0442 \u0441
    \u043D\u0438\u043C \u0432\u043E\u0439\u043D\u0443, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u043A\u043E\u0440\u0430\u0431\u043B\u0438 \u043A\u0430\u043A \xAB\u0447\u0435\u0440\u043F\u0430\u043A\u0438
    \u0434\u043B\u044F \u0432\u043E\u0434\u044B\xBB, \u0438 \u0441\u0440\u0430\u0432\u043D\u0438\u043B
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0441\u043E \u0441\u0442\u043E\u0433\u043B\u0430\u0432\u044B\u043C
    \u043C\u0438\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u0433\u0438\u0433\u0430\u043D\u0442\u043E\u043C
    \u0411\u0440\u0438\u0430\u0440\u0435\u0435\u043C. \u0420\u0438\u043C\u043B\u044F\u043D\u0435
    \u043F\u0435\u0440\u0435\u0448\u043B\u0438 \u043E\u0442 \u0448\u0442\u0443\u0440\u043C\u0430
    \u043A \u0434\u043E\u043B\u0433\u043E\u0439 \u043E\u0441\u0430\u0434\u0435, \u0441\u043C\u0438\u0440\u0438\u0432\u0448\u0438\u0441\u044C
    \u0441 \u0442\u0435\u043C, \u0447\u0442\u043E \u043E\u0434\u043D\u043E\u0433\u043E
    \u0441\u0442\u0430\u0440\u0438\u043A\u0430 \u0431\u043E\u044F\u0442\u0441\u044F
    \u0431\u043E\u043B\u044C\u0448\u0435, \u0447\u0435\u043C \u0446\u0435\u043B\u043E\u0439
    \u0430\u0440\u043C\u0438\u0438.  ### 5. \u0422\u0430\u0439\u043D\u0430 \xAB\u043E\u0433\u043D\u0435\u043D\u043D\u044B\u0445
    \u0437\u0435\u0440\u043A\u0430\u043B\xBB \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043F\u0440\u0435\u0434\u0430\u043D\u0438\u0435, \u0447\u0442\u043E \u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u0441\u0436\u0438\u0433\u0430\u043B \u0440\u0438\u043C\u0441\u043A\u0438\u0435
    \u043A\u043E\u0440\u0430\u0431\u043B\u0438, \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u044F\u044F
    \u043D\u0430 \u043D\u0438\u0445 \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0435
    \u043B\u0443\u0447\u0438 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0445 \u0432\u043E\u0433\u043D\u0443\u0442\u044B\u0445
    \u0437\u0435\u0440\u043A\u0430\u043B. \u0412 \u0442\u043E \u0432\u0440\u0435\u043C\u044F
    \u043A\u0430\u043A \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u0441\u0447\u0438\u0442\u0430\u044E\u0442 \u044D\u0442\u043E \u0432\u044B\u043C\u044B\u0441\u043B\u043E\u043C
    (\u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u044F \u0441\u0442\u0435\u043A\u043B\u0430
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0431\u044B\u043B\u0430
    \u043D\u0435\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u0430), \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
    \u044D\u043D\u0442\u0443\u0437\u0438\u0430\u0441\u0442\u044B \u0438 \u0442\u0435\u043B\u0435\u0432\u0438\u0437\u0438\u043E\u043D\u043D\u044B\u0435
    \u0448\u043E\u0443 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0441\u0435\u0440\u0438\u044F
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u043E\u0432
    \u043E\u0442 \u041C\u0438\u043D\u0438\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u0430
    \u041E\u0431\u043E\u0440\u043E\u043D\u044B \u0421\u0428\u0410) \u0434\u043E\u043A\u0430\u0437\u0430\u043B\u0438,
    \u0447\u0442\u043E \u043F\u0440\u0438 \u0431\u043E\u043B\u044C\u0448\u043E\u043C
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0435 \u043C\u0435\u0434\u043D\u044B\u0445
    \u043F\u043E\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445 \u0449\u0438\u0442\u043E\u0432
    \u0438 \u044F\u0441\u043D\u043E\u0439 \u043F\u043E\u0433\u043E\u0434\u0435 \u0434\u0435\u0440\u0435\u0432\u044F\u043D\u043D\u043E\u0435
    \u0441\u0443\u0434\u043D\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043C\u043E\u0436\u043D\u043E \u043F\u043E\u0434\u0436\u0435\u0447\u044C. \u0422\u0430\u043A
    \u0447\u0442\u043E \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u043C\u043E\u0433
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u044D\u0442\u043E\u0442
    \u043E\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0442\u0440\u044E\u043A,
    \u043F\u0443\u0441\u0442\u044C \u0438 \u043D\u0435 \u0442\u0430\u043A \u044D\u0444\u0444\u0435\u043A\u0442\u043D\u043E,
    \u043A\u0430\u043A \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442 \u043B\u0435\u0433\u0435\u043D\u0434\u044B. 
    ### 6. \u0424\u0438\u043D\u0430\u043B: \xAB\u041D\u0435 \u0442\u0440\u043E\u0433\u0430\u0439
    \u043C\u043E\u0438\u0445 \u0447\u0435\u0440\u0442\u0435\u0436\u0435\u0439!\xBB
    \u0413\u0438\u0431\u0435\u043B\u044C \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430
    \u0432 212 \u0433\u043E\u0434\u0443 \u0434\u043E \u043D.\u044D. \u0441\u0442\u0430\u043B\u0430
    \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C \u0433\u0438\u0431\u0435\u043B\u0438
    \u043D\u0430\u0443\u043A\u0438 \u043E\u0442 \u0440\u0443\u043A \u0432\u0430\u0440\u0432\u0430\u0440\u0441\u0442\u0432\u0430.
    \u041A\u043E\u0433\u0434\u0430 \u0440\u0438\u043C\u043B\u044F\u043D\u0435 \u0432\u043E\u0440\u0432\u0430\u043B\u0438\u0441\u044C
    \u0432 \u0433\u043E\u0440\u043E\u0434 \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u043D\u043E\u0447\u043D\u043E\u0433\u043E \u0448\u0442\u0443\u0440\u043C\u0430,
    \u0441\u043E\u043B\u0434\u0430\u0442\u0430\u043C \u0431\u044B\u043B\u043E \u043F\u0440\u0438\u043A\u0430\u0437\u0430\u043D\u043E
    \u043D\u0430\u0439\u0442\u0438 \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0438
    \u043F\u0440\u0438\u0432\u0435\u0441\u0442\u0438 \u043A \u041C\u0430\u0440\u0446\u0435\u043B\u043B\u0443
    (\u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0445\u043E\u0442\u0435\u043B \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C
    \u0435\u043C\u0443 \u0436\u0438\u0437\u043D\u044C).  \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u0441\u0430\u043C\u043E\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439
    \u0432\u0435\u0440\u0441\u0438\u0438, 75-\u043B\u0435\u0442\u043D\u0438\u0439
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0441\u0438\u0434\u0435\u043B \u043D\u0430
    \u043F\u0435\u0441\u043A\u0435 \u0438 \u0447\u0435\u0440\u0442\u0438\u043B \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0444\u0438\u0433\u0443\u0440\u044B, \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0433\u0440\u0443\u0436\u0435\u043D\u043D\u044B\u0439 \u0432 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438. \u041A\u043E\u0433\u0434\u0430 \u043A \u043D\u0435\u043C\u0443
    \u043F\u043E\u0434\u043E\u0448\u0435\u043B \u0440\u0438\u043C\u0441\u043A\u0438\u0439
    \u043B\u0435\u0433\u0438\u043E\u043D\u0435\u0440, \u0442\u0440\u0435\u0431\u0443\u044F
    \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u044C \u0437\u0430 \u043D\u0438\u043C,
    \u0441\u0442\u0430\u0440\u0435\u0446 \u043D\u0435 \u043E\u0431\u0440\u0430\u0442\u0438\u043B
    \u043D\u0430 \u043D\u0435\u0433\u043E \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u044F,
    \u0430 \u043B\u0438\u0448\u044C \u043C\u0430\u0445\u043D\u0443\u043B \u0440\u0443\u043A\u043E\u0439
    \u0438 \u0441\u043A\u0430\u0437\u0430\u043B: **\xAB\u041D\u0435 \u0442\u0440\u043E\u0433\u0430\u0439
    \u043C\u043E\u0438\u0445 \u0447\u0435\u0440\u0442\u0435\u0436\u0435\u0439\xBB**.
    \u0420\u0430\u0437\u0433\u043D\u0435\u0432\u0430\u043D\u043D\u044B\u0439 \u0433\u0440\u0443\u0431\u043E\u0441\u0442\u044C\u044E
    \xAB\u043F\u043B\u0435\u043D\u043D\u043E\u0433\u043E\xBB, \u0441\u043E\u043B\u0434\u0430\u0442
    \u0437\u0430\u0440\u0443\u0431\u0438\u043B \u0435\u0433\u043E \u043C\u0435\u0447\u043E\u043C
    \u043F\u0440\u044F\u043C\u043E \u043D\u0430 \u043F\u0435\u0441\u043A\u0435. 
    \u0420\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u0442\u0430\u043A\u0436\u0435,
    \u0447\u0442\u043E \u043F\u043E\u043B\u043A\u043E\u0432\u043E\u0434\u0435\u0446
    \u041C\u0430\u0440\u0446\u0435\u043B\u043B \u0431\u044B\u043B \u0432 \u044F\u0440\u043E\u0441\u0442\u0438
    \u043E\u0442 \u0442\u0430\u043A\u043E\u0433\u043E \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u0430,
    \u043F\u0440\u0438\u043A\u0430\u0437\u0430\u043B \u043A\u0430\u0437\u043D\u0438\u0442\u044C
    \u0443\u0431\u0438\u0439\u0446\u0443 \u0438 \u0441 \u043F\u043E\u0447\u0435\u0441\u0442\u044F\u043C\u0438
    \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0438\u0442\u044C \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430. 
    ### 7. \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F \u0432\u043E\u043B\u044F
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0446\u0435\u043D\u0438\u043B \u0441\u0432\u043E\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u0432\u044B\u0448\u0435 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u044B\u0445
