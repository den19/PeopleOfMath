    (\u0430\u0440\u0445\u0438\u043C\u0435\u0434\u043E\u0432\u044B \u0442\u0435\u043B\u0430),
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u0434\u043B\u044F \u0437\u0430\u043F\u0438\u0441\u0438 \u0441\u0432\u0435\u0440\u0445\u0431\u043E\u043B\u044C\u0448\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B \u0432 \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435
    \xAB\u041F\u0441\u0430\u043C\u043C\u0438\u0442\xBB (\xAB\u0418\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435
    \u043F\u0435\u0441\u0447\u0438\u043D\u043E\u043A\xBB) \u0438 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0430\u043A\u0441\u0438\u043E\u043C\u0443, \u043D\u043E\u0441\u044F\u0449\u0443\u044E
    \u0435\u0433\u043E \u0438\u043C\u044F .  ### \u0424\u0438\u0437\u0438\u043A\u0430:
    \u041E\u0441\u043D\u043E\u0432\u044B \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438
    \u0438 \u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0438 
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043E\u0442\u0446\u043E\u0432-\u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438 \u043A\u0430\u043A \u043D\u0430\u0443\u043A\u0438. 
