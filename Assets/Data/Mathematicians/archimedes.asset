    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439, \u0440\u0438\u043C\u0441\u043A\u0438\u0439
    \u0441\u043E\u043B\u0434\u0430\u0442 \u0443\u0431\u0438\u043B \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430,
    \u043A\u043E\u0433\u0434\u0430 \u0442\u043E\u0442, \u043F\u043E\u0433\u043B\u043E\u0449\u0435\u043D\u043D\u044B\u0439
    \u0440\u0438\u0441\u043E\u0432\u0430\u043D\u0438\u0435\u043C \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0433\u0443\u0440\u044B \u043D\u0430 \u043F\u0435\u0441\u043A\u0435,
    \u0441 \u0432\u043E\u0437\u043C\u0443\u0449\u0435\u043D\u0438\u0435\u043C \u043F\u0440\u0438\u043A\u0430\u0437\u0430\u043B
    \u0435\u043C\u0443 \u043D\u0435 \u043D\u0430\u0441\u0442\u0443\u043F\u0430\u0442\u044C
    \u043D\u0430 \u0447\u0435\u0440\u0442\u0435\u0436\u0438.  \u0420\u0438\u043C\u0441\u043A\u0438\u0439
    \u043F\u043E\u043B\u043A\u043E\u0432\u043E\u0434\u0435\u0446 \u041C\u0430\u0440\u0446\u0435\u043B\u043B,
    \u0432\u043E\u0441\u0445\u0438\u0449\u0430\u0432\u0448\u0438\u0439\u0441\u044F
    \u0442\u0430\u043B\u0430\u043D\u0442\u043E\u043C \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430
    \u0438 \u043F\u0440\u0438\u043A\u0430\u0437\u0430\u0432\u0448\u0438\u0439 \u043D\u0435
    \u0442\u0440\u043E\u0433\u0430\u0442\u044C \u0435\u0433\u043E, \u0431\u044B\u043B
    \u0440\u0430\u0437\u0433\u043D\u0435\u0432\u0430\u043D \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u043E\u043C.
    \u0422\u0435\u043B\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0431\u044B\u043B\u043E
    \u043F\u043E\u0433\u0440\u0435\u0431\u0435\u043D\u043E \u0441 \u043F\u043E\u0447\u0435\u0441\u0442\u044F\u043C\u0438.
    \u041D\u0430 \u0435\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u0435, \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u044E, \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0438
    \u043F\u0430\u043C\u044F\u0442\u043D\u0438\u043A \u0441 \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435\u043C
    \u0448\u0430\u0440\u0430, \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E
    \u0432 \u0446\u0438\u043B\u0438\u043D\u0434\u0440. \u042D\u0442\u0443 \u043C\u043E\u0433\u0438\u043B\u0443
    \u0441\u043F\u0443\u0441\u0442\u044F 137 \u043B\u0435\u0442 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B
    \u0438 \u043E\u043F\u0438\u0441\u0430\u043B \u0440\u0438\u043C\u0441\u043A\u0438\u0439
    \u043E\u0440\u0430\u0442\u043E\u0440 \u0426\u0438\u0446\u0435\u0440\u043E\u043D. 
    \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0435\u0435
    \u0432\u0440\u0435\u043C\u044F.  \u0425\u043E\u0442\u044F \u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u043F\u0440\u043E\u0441\u043B\u0430\u0432\u0438\u043B\u0441\u044F \u0438 \u043A\u0430\u043A
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440, \u0433\u043B\u0430\u0432\u043D\u044B\u0435
    \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043B\u0435\u0436\u0430\u0442 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438, \u043F\u0440\u0435\u0436\u0434\u0435 \u0432\u0441\u0435\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0444\u0438\u0437\u0438\u043A\u0438
    .  *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:** \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u0441\u0442\u0430\u043B\u0438 \u043F\u0440\u0435\u0434\u0442\u0435\u0447\u0435\u0439
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F. \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \xAB\u043C\u0435\u0442\u043E\u0434 \u0438\u0441\u0447\u0435\u0440\u043F\u044B\u0432\u0430\u043D\u0438\u044F\xBB,
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B \u043F\u043B\u043E\u0449\u0430\u0434\u0438
    \u0438 \u043E\u0431\u044A\u0435\u043C\u044B \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0444\u0438\u0433\u0443\u0440 . \u041E\u043D \u0441 \u0432\u044B\u0441\u043E\u043A\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B
    \u0447\u0438\u0441\u043B\u043E **\u03C0**, \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0432
    \u0435\u0433\u043E \u0433\u0440\u0430\u043D\u0438\u0446\u044B \u043C\u0435\u0436\u0434\u0443
    3.1408 \u0438 3.1428 . \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435 \u043E\u0431\u044A\u0435\u043C\u0430
    \u0448\u0430\u0440\u0430 \u043A \u043E\u0431\u044A\u0435\u043C\u0443 \u043E\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E
    \u0432\u043E\u043A\u0440\u0443\u0433 \u043D\u0435\u0433\u043E \u0446\u0438\u043B\u0438\u043D\u0434\u0440\u0430
    \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 2:3 \u2014 \u0438\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043E\u043D
    \u0438 \u0437\u0430\u0432\u0435\u0449\u0430\u043B \u0443\u0432\u0435\u043A\u043E\u0432\u0435\u0447\u0438\u0442\u044C
    \u043D\u0430 \u0441\u0432\u043E\u0435\u043C \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u0438.
    *   **\u0424\u0438\u0437\u0438\u043A\u0430:** \u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0442\u0446\u043E\u043C
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438 \u0438 \u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0438.
    \u041E\u043D \u0434\u0430\u043B \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0440\u044B\u0447\u0430\u0433\u0430, \u0432\u0432\u0435\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u0446\u0435\u043D\u0442\u0440\u0430
    \u0442\u044F\u0436\u0435\u0441\u0442\u0438 \u0438, \u043A\u043E\u043D\u0435\u0447\u043D\u043E,
    \u043E\u0442\u043A\u0440\u044B\u043B \u0441\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0437\u0430\u043A\u043E\u043D \u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0438
    . \u0412 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435 \u043E\u043D \u0438\u0437\u043E\u0431\u0440\u0435\u043B
    **\u0430\u0440\u0445\u0438\u043C\u0435\u0434\u043E\u0432 \u0432\u0438\u043D\u0442**
    \u2014 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E \u0434\u043B\u044F
    \u043F\u043E\u0434\u044A\u0435\u043C\u0430 \u0432\u043E\u0434\u044B, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440. *   **\u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F:**
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u044B\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u043B\u0430\u043D\u0435\u0442\u0430\u0440\u0438\u0439 (\xAB\u043D\u0435\u0431\u0435\u0441\u043D\u0443\u044E
    \u0441\u0444\u0435\u0440\u0443\xBB), \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435
    \u043F\u043B\u0430\u043D\u0435\u0442, \u0421\u043E\u043B\u043D\u0446\u0430 \u0438
    \u041B\u0443\u043D\u044B, \u0430 \u0442\u0430\u043A\u0436\u0435 \u043C\u043E\u0433
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u044F.  \u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \xAB\u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u0435\u043C\xBB.
    \u041E\u043D \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u043C \u0443\u0447\u0435\u043D\u044B\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B
    \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u044F\u0432\u043B\u0435\u043D\u0438\u0439, \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0432
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u043E\u0435 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E
    \u0432 \u043D\u0430\u0443\u043A\u0443. \u0415\u0433\u043E \u0438\u0434\u0435\u0438
    \u0441\u0442\u0430\u043B\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0441\u043F\u0443\u0441\u0442\u044F
    \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F \u0432\u044B\u0440\u043E\u0441\u043B\u0430
    \u043D\u0430\u0443\u043A\u0430 \u041D\u043E\u0432\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438."
  shortBioEn: "Archimedes is more than just a name from a physics textbook. He became
    a legend even in his lifetime, and his discoveries were so far ahead of their
    time that they were only truly appreciated nearly two thousand years later. He
    was a brilliant mathematician, engineer, astronomer, and inventor, whose ideas
    laid the foundations of modern science.  Here are the key milestones in his biography
    and the astonishing facts that demonstrate the scale of his genius.  A scientist's
    path: from Syracuse to Alexandria.  * **Origin:** Archimedes was born around
    **287 BC** in the Greek city of Syracuse on the island of Sicily. His father
    was the astronomer and mathematician Phidias, who likely instilled in his son
    a love of the exact sciences. According to some sources, Archimedes was related
    to the ruler of Syracuse, King Hieron II. * **Education:** Young Archimedes sought
    knowledge in Alexandria, Egypt\u2014the leading scientific and cultural center
    of the ancient world. There, he studied at the famous Museion and enjoyed the
    riches of the Library of Alexandria. In Alexandria, he met and befriended outstanding
    scholars of his time: the astronomer Conon and the mathematician Eratosthenes. 
    Archimedes the Engineer: Three Great Legends  Many legends are associated with
    Archimedes, and although their veracity is difficult to verify, they all vividly
    characterize his inventive genius.  1. **\"Eureka!\" and the Golden Crown.**
    King Hiero II suspected a jeweler of cheating in the manufacture of a golden
    crown and commissioned Archimedes to verify this without destroying it. The scientist
    was unable to find a solution for a long time, until one day, while immersing
    himself in a bath, he noticed the water level rising. He had a brilliant idea:
    the volume of the crown could be measured by the volume of water it displaced.
    By comparing this volume with the volume of a pure gold bar of the same weight,
    Archimedes proved that the crown contained silver. According to legend, he jumped
    out of the bath and, shouting \"Eureka!\" (\"I found it!\"), ran to report his
    discovery. Thus was discovered the law of hydrostatics (now known as Archimedes'
    principle).  2. \"Give me a fulcrum, and I will move the Earth.\" To launch the
    enormous ship built by order of the king, Archimedes designed a system of pulleys
    and levers\u2014a block and tackle. With its help, he was able to do it single-handedly,
    astonishing everyone present. This legend illustrates his work on the theory
    of the lever and center of gravity.  3. The Defense of Syracuse. During the Second
    Punic War, the Romans besieged Syracuse. 75-year-old Archimedes created numerous
    amazing military machines to defend the city. Powerful catapults and ballistas
    pelted the enemy with stones and cannonballs, while special cranes with hooks
    (the \"Archimedes' Claw\") seized Roman ships, lifted them into the air, and
    then dropped them, sinking them. According to legend, he also used a system of
    mirrors to set enemy ships ablaze with focused sunbeams. Archimedes' inventions
    were so effective that they forced the Romans to abandon their assault and resort
    to a lengthy siege.  Death and Memory.  The city fell in 212 BC due to treason.
    The great scientist's death was accidental and brutal. There are several versions
    of his death. According to the most famous, a Roman soldier killed Archimedes
    when he, absorbed in drawing a geometric figure in the sand, angrily ordered
    him not to step on the drawings.  The Roman general Marcellus, who admired Archimedes'
    talent and ordered that he be spared, was enraged by the murder. The scientist's
    body was buried with honors. According to his will, a monument depicting a sphere
    inscribed within a cylinder was erected on his tomb. This tomb was discovered
    and described 137 years later by the Roman orator Cicero.  A Legacy Ahead of
    Its Time.  Although Archimedes also became famous as an engineer, his greatest
    achievements lay in the field of fundamental science, primarily mathematics and
    physics.  * **Mathematics:** His work became a precursor to integral calculus.
    He developed the \"method of exhaustion,\" which he used to calculate the areas
    and volumes of complex figures. He calculated the number **\u03C0** with high
    accuracy, determining its limits between 3.1408 and 3.1428. He also proved that
    the ratio of the volume of a sphere to the volume of the cylinder circumscribed
    around it is 2:3\u2014a discovery he bequeathed to be immortalized on his tombstone.
    * **Physics:** Archimedes is considered the father of theoretical mechanics and
    hydrostatics. He provided a rigorous mathematical proof of the law of the lever,
    introduced the concept of the center of gravity, and, of course, discovered his
    famous law of hydrostatics. In mechanics, he invented the **Archimedes screw**\u2014a
    device for lifting water that is still used today. * **Astronomy:** Archimedes
    constructed a complex mechanical planetarium (\"celestial sphere\") that showed
    the motion of the planets, the Sun, and the Moon, and could also predict eclipses. 
    Archimedes was more than just an \"inventor.\" He was the first scientist to
    apply rigorous mathematics to the description of physical phenomena, transforming
    engineering into a science. His ideas became the foundation on which, centuries
    later, modern science grew."
