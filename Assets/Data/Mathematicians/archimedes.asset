    \u041C\u0435\u0441\u0442\u043D\u044B\u0435 \u0436\u0438\u0442\u0435\u043B\u0438
    \u043D\u0438\u0447\u0435\u0433\u043E \u043E \u043D\u0435\u0439 \u043D\u0435 \u0437\u043D\u0430\u043B\u0438.
    \u0426\u0438\u0446\u0435\u0440\u043E\u043D \u0431\u0440\u043E\u0434\u0438\u043B
    \u043F\u043E \u0437\u0430\u0440\u043E\u0441\u0448\u0438\u043C \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0430\u043C,
