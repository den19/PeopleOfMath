    \u0440\u0438\u0441\u0443\u043D\u043E\u043A \u0448\u0430\u0440\u0430, \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E
    \u0432 \u0446\u0438\u043B\u0438\u043D\u0434\u0440, \u0438 \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u044E
    2:3, \u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443 \u0441\u0447\u0438\u0442\u0430\u043B
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0438\u0445
    \u043E\u0431\u044A\u0435\u043C\u043E\u0432 \u0441\u0430\u043C\u044B\u043C \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u0441\u0432\u043E\u0438\u043C \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C. 
    \u0418\u0440\u043E\u043D\u0438\u044F \u0441\u0443\u0434\u044C\u0431\u044B: \u0441\u043F\u0443\u0441\u0442\u044F
    137 \u043B\u0435\u0442 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043E\u0440\u0430\u0442\u043E\u0440 \u0426\u0438\u0446\u0435\u0440\u043E\u043D,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u043E\u043C
