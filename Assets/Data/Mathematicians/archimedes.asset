  achievementsRu: "\u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u2014 \u0444\u0438\u0433\u0443\u0440\u0430,
    \u0447\u0435\u0439 \u0433\u0435\u043D\u0438\u0439 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0441\u0440\u0430\u0437\u0443
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D. \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u043D\u0430 \u0442\u0440\u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0441\u0444\u0435\u0440\u044B:
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430, \u0444\u0438\u0437\u0438\u043A\u0430
    \u0438 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0438\u044F.  ### \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:
    \u041F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0449\u0430\u044F \u0430\u043D\u0430\u043B\u0438\u0437 
    \u0412 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u043D\u0430\u043C\u043D\u043E\u0433\u043E \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B
    \u0441\u0432\u043E\u0435 \u0432\u0440\u0435\u043C\u044F, \u043F\u043E\u0434\u043E\u0439\u0434\u044F
    \u0432\u043F\u043B\u043E\u0442\u043D\u0443\u044E \u043A \u0438\u0434\u0435\u044F\u043C
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F.  *   **\u041C\u0435\u0442\u043E\u0434
    \u0438\u0441\u0447\u0435\u0440\u043F\u044B\u0432\u0430\u043D\u0438\u044F \u0438
    \u043F\u0440\u0435\u0434\u0442\u0435\u0447\u0430 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u0432**:
    \u041E\u043D \u0432\u0438\u0440\u0442\u0443\u043E\u0437\u043D\u043E \u0440\u0430\u0437\u0432\u0438\u043B
    \u043C\u0435\u0442\u043E\u0434 \u0438\u0441\u0447\u0435\u0440\u043F\u044B\u0432\u0430\u043D\u0438\u044F
    \u0415\u0432\u0434\u043E\u043A\u0441\u0430 \u0434\u043B\u044F \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u043F\u043B\u043E\u0449\u0430\u0434\u0435\u0439 \u0438 \u043E\u0431\u044A\u0435\u043C\u043E\u0432
    \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u0444\u0438\u0433\u0443\u0440. \u041F\u0440\u0438\u043C\u0435\u043D\u044F\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0441\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F,
    \u043E\u043D \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \"\u043D\u0430\u0445\u043E\u0434\u0438\u043B\"
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0441\u0442\u0440\u043E\u0433\u043E \u0435\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438.
    \u0412 \u0441\u0432\u043E\u0435\u043C \u0442\u0440\u0443\u0434\u0435 \xAB\u041F\u043E\u0441\u043B\u0430\u043D\u0438\u0435
    \u043A \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0443 \u043E \u043C\u0435\u0442\u043E\u0434\u0435\xBB
    \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F, \u0431\u043B\u0438\u0437\u043A\u0438\u0435
    \u043A \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E \u043C\u0430\u043B\u044B\u043C,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u043F\u0440\u0435\u0434\u0432\u0435\u0441\u0442\u043D\u0438\u043A\u043E\u043C
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u0438 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430. *   **\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F**: \u041E\u043D \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B
    \u043F\u043B\u043E\u0449\u0430\u0434\u044C \u0441\u0435\u0433\u043C\u0435\u043D\u0442\u0430
    \u043F\u0430\u0440\u0430\u0431\u043E\u043B\u044B (\u043E\u043D\u0430 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    4/3 \u043E\u0442 \u043F\u043B\u043E\u0449\u0430\u0434\u0438 \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430) \u0438
    \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043D\u0430\u0448\u0435\u043B
    \u0441\u0443\u043C\u043C\u0443 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0440\u044F\u0434\u0430 \u0441\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0430\u0442\u0435\u043B\u0435\u043C
    1/4. *   **\u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F**: \u0412 \u0440\u0430\u0431\u043E\u0442\u0435
    \xAB\u041E \u0448\u0430\u0440\u0435 \u0438 \u0446\u0438\u043B\u0438\u043D\u0434\u0440\u0435\xBB
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043E\u0431\u044A\u0435\u043C \u0448\u0430\u0440\u0430 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0441\u044F
    \u043A \u043E\u0431\u044A\u0435\u043C\u0443 \u043E\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E
    \u0432\u043E\u043A\u0440\u0443\u0433 \u043D\u0435\u0433\u043E \u0446\u0438\u043B\u0438\u043D\u0434\u0440\u0430
    \u043A\u0430\u043A 2:3, \u0430 \u043F\u043B\u043E\u0449\u0430\u0434\u0438 \u0438\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439 \u043D\u0430\u0445\u043E\u0434\u044F\u0442\u0441\u044F
    \u0432 \u0442\u043E\u043C \u0436\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0438.
    \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043E\u043D
    \u0446\u0435\u043D\u0438\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E,
    \u0447\u0442\u043E \u0437\u0430\u0432\u0435\u0449\u0430\u043B \u0432\u044B\u0441\u0435\u0447\u044C
    \u043D\u0430 \u0441\u0432\u043E\u0435\u0439 \u043C\u043E\u0433\u0438\u043B\u0435
    \u0438\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u043E\u0442 \u0447\u0435\u0440\u0442\u0435\u0436.
    *   **\u0412\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435 \u0447\u0438\u0441\u043B\u0430
    \u03C0 (\u041F\u0438)**: \u0412 \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435
    \xAB\u0418\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0435 \u043A\u0440\u0443\u0433\u0430\xBB
    \u043E\u043D \u0434\u0430\u043B \u043F\u0435\u0440\u0432\u043E\u0435 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435 \u0447\u0438\u0441\u043B\u0430
    \u03C0, \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0432 \u0435\u0433\u043E
    \u0432 \u0442\u043E\u0447\u043D\u044B\u0445 \u0433\u0440\u0430\u043D\u0438\u0446\u0430\u0445:
    `3 + 10/71 < \u03C0 < 3 + 1/7`. *   **\u0414\u0440\u0443\u0433\u0438\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F**:
    \u041E\u043D \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430
