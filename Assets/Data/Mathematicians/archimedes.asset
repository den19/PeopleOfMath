    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0431\u043B\u043E\u043A\u043E\u0432
    \u0438 \u0440\u044B\u0447\u0430\u0433\u043E\u0432 \u2014 **\u043F\u043E\u043B\u0438\u0441\u043F\u0430\u0441\u0442**.
    \u0421 \u0435\u0435 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043E\u043D \u0441\u043C\u043E\u0433
    \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u044D\u0442\u043E \u0432 \u043E\u0434\u0438\u043D\u043E\u0447\u043A\u0443,
    \u0447\u0442\u043E \u043F\u043E\u0440\u0430\u0437\u0438\u043B\u043E \u0432\u0441\u0435\u0445
    \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0445
    . \u042D\u0442\u0430 \u043B\u0435\u0433\u0435\u043D\u0434\u0430 \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0430\u0434 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
