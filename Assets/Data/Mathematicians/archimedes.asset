    \u0417\u0435\u043C\u043B\u044E\".** \u0427\u0442\u043E\u0431\u044B \u0441\u043F\u0443\u0441\u0442\u0438\u0442\u044C
    \u043D\u0430 \u0432\u043E\u0434\u0443 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u043A\u043E\u0440\u0430\u0431\u043B\u044C, \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u044B\u0439
