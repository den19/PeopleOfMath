  achievementsRu: "\u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439
    \u043E\u0431\u0437\u043E\u0440 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439
    \u0438 \u0432\u043A\u043B\u0430\u0434\u0430 \u041F\u044C\u0435\u0440\u0430 \u0414\u0435\u043B\u0438\u043D\u044F,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0439 \u043D\u0430 \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445 \u0438 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F\u0445.  ### \U0001F3C6
    \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437 \u0412\u0435\u0439\u043B\u044F: \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u043F\u0440\u043E\u0440\u044B\u0432  \u0413\u043B\u0430\u0432\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0414\u0435\u043B\u0438\u043D\u044F
    \u2014 **\u043F\u043E\u043B\u043D\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437 \u0412\u0435\u0439\u043B\u044F \u0432
    1973 \u0433\u043E\u0434\u0443**. \u042D\u0442\u0438 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B,
    \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u0442\u044B\u0435 \u0410\u043D\u0434\u0440\u0435
    \u0412\u0435\u0439\u043B\u0435\u043C \u0432 1949 \u0433\u043E\u0434\u0443, \u043A\u0430\u0441\u0430\u043B\u0438\u0441\u044C
    \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439 \u043D\u0430\u0434
    \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u043C\u0438 \u043F\u043E\u043B\u044F\u043C\u0438
    \u0438 \u0432\u043A\u043B\u044E\u0447\u0430\u043B\u0438 \u0430\u043D\u0430\u043B\u043E\u0433
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B
    \u0420\u0438\u043C\u0430\u043D\u0430. \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E,
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u043D\u043E\u0435 \u0432 \u0434\u0432\u0443\u0445
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0441\u0442\u0430\u0442\u044C\u044F\u0445 \u043E\u0431\u0449\u0438\u043C \u043E\u0431\u044A\u0435\u043C\u043E\u043C
    \u043E\u043A\u043E\u043B\u043E 150 \u0441\u0442\u0440\u0430\u043D\u0438\u0446,
    \u0431\u044B\u043B\u043E \u043D\u0430\u0437\u0432\u0430\u043D\u043E \"\u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C
    \u043F\u043E\u0434\u0432\u0438\u0433\u043E\u043C\" \u0438 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u043E
    \u0414\u0435\u043B\u0438\u043D\u044E \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0443\u044E
    \u043C\u0435\u0434\u0430\u043B\u044C \u0432 1978 \u0433\u043E\u0434\u0443.  \u042D\u0442\u043E\u0442
    \u043F\u0440\u043E\u0440\u044B\u0432 \u0441\u0442\u0430\u043B \u0432\u0435\u0440\u0448\u0438\u043D\u043E\u0439
    \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0435\u0439 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B,
    \u0438\u043D\u0438\u0446\u0438\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u043C
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0434\u043B\u044F
    \u044D\u0442\u043E\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044E **\u044D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0439**. \u0414\u0435\u043B\u0438\u043D\u044C
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B
    \u044D\u0442\u043E\u0442 \u043C\u043E\u0449\u043D\u044B\u0439 \u0430\u043F\u043F\u0430\u0440\u0430\u0442,
    \u0447\u0442\u043E\u0431\u044B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u0441\u0430\u043C\u0443\u044E \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E
    \u0438\u0437 \u0433\u0438\u043F\u043E\u0442\u0435\u0437 \u0412\u0435\u0439\u043B\u044F
    \u2014 \u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F\u0445 \u044D\u043D\u0434\u043E\u043C\u043E\u0440\u0444\u0438\u0437\u043C\u0430
    \u0424\u0440\u043E\u0431\u0435\u043D\u0438\u0443\u0441\u0430.  \u0420\u0430\u0431\u043E\u0442\u0430
    \u0438\u043C\u0435\u043B\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435
    \u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u044F \u0434\u043B\u044F
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B, \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0432:
    *   **\u0414\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430-\u041F\u0435\u0442\u0435\u0440\u0441\u043E\u043D\u0430**
    \u0434\u043B\u044F \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u044B\u0445
    \u0444\u043E\u0440\u043C. *   **\u041F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u043E\u0446\u0435\u043D\u043A\u0438 \u044D\u043A\u0441\u043F\u043E\u043D\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0441\u0443\u043C\u043C**, \u0432\u0430\u0436\u043D\u044B\u0435 \u0434\u043B\u044F
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B.  ### \U0001F52C
    \u0414\u0440\u0443\u0433\u0438\u0435 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0432\u043A\u043B\u0430\u0434\u044B  \u0414\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0414\u0435\u043B\u0438\u043D\u044F \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u044E\u0442\u0441\u044F
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437 \u0412\u0435\u0439\u043B\u044F. \u041E\u043D
    \u0432\u043D\u0435\u0441 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u044E\u0449\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0434\u0440\u0443\u0433\u0438\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439. 
    #### \u0421\u043C\u0435\u0448\u0430\u043D\u043D\u044B\u0435 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B
    \u0425\u043E\u0434\u0436\u0430 \u0414\u0435\u043B\u0438\u043D\u044C \u043E\u0431\u043E\u0431\u0449\u0438\u043B
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0442\u0435\u043E\u0440\u0438\u044E
    \u0425\u043E\u0434\u0436\u0430, \u0434\u043E\u043A\u0430\u0437\u0430\u0432, \u0447\u0442\u043E
    \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438 \u0441\u0438\u043D\u0433\u0443\u043B\u044F\u0440\u043D\u044B\u0445
    \u0438 \u043D\u0435\u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u044B\u0445
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439 \u043D\u0435\u0441\u0443\u0442
    \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E **\u0441\u043C\u0435\u0448\u0430\u043D\u043D\u0443\u044E
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0443 \u0425\u043E\u0434\u0436\u0430**.
    \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0441\u0442\u0430\u043B\u043E
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435
    \u043C\u043E\u0449\u043D\u044B\u0445 \u0438 \u0447\u0430\u0441\u0442\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C\u044B\u0445
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432 \u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u041A\u0430\u0442\u0442\u0430\u043D\u0438 \u0438 \u041A\u0430\u043F\u043B\u0430\u043D\u043E\u043C
    \u043E\u043D \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u044D\u0442\u0443
    \u0442\u0435\u043E\u0440\u0438\u044E \u0434\u043B\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E\u0431 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u043D\u043E\u0441\u0442\u0438,
    \u0434\u0430\u044E\u0449\u0435\u0439 \u0441\u0438\u043B\u044C\u043D\u044B\u0435
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442\u044B \u0432 \u043F\u043E\u043B\u044C\u0437\u0443
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B
    \u0425\u043E\u0434\u0436\u0430.  #### \u0422\u0435\u043E\u0440\u0438\u044F \u043C\u043E\u0442\u0438\u0432\u043E\u0432
    \u0438 \u0435\u0435 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u0414\u0435\u043B\u0438\u043D\u044C \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B \u0442\u0435\u043E\u0440\u0438\u044E
    **\u043C\u043E\u0442\u0438\u0432\u043E\u0432** \u2014 \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u043E\u0433\u043E
    \u0437\u0430\u043C\u044B\u0441\u043B\u0430 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430,
    \u043F\u0440\u0438\u0437\u0432\u0430\u043D\u043D\u043E\u0433\u043E \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C
    \u0432\u0441\u0435 \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438. \u041E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043D\u0430\u0434 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435\u043C \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u044B\u0445
    \u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432 \u044D\u0442\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438, \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u044B\u0445
    \u0434\u043B\u044F \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0445
    \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0439. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043E\u043D \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    **1-\u043C\u043E\u0442\u0438\u0432\u043E\u0432** \u2014 \u043F\u0440\u043E\u0441\u0442\u044B\u0445
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432, \u0447\u044C\u0438 \u0441\u043C\u0435\u0448\u0430\u043D\u043D\u044B\u0435
    \u0440\u0435\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438 \u0434\u0430\u044E\u0442
    \u043F\u0440\u0438\u043C\u0435\u0440\u044B \u0441\u043C\u0435\u0448\u0430\u043D\u043D\u044B\u0445
    \u043C\u043E\u0442\u0438\u0432\u043E\u0432. \u0415\u0433\u043E **\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u043E\u0431 \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u044F\u0445
    1-\u043C\u043E\u0442\u0438\u0432\u043E\u0432**, \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044E\u0449\u0430\u044F,
    \u0447\u0442\u043E \u043B\u044E\u0431\u043E\u0435 \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u0435
    \u0442\u0430\u043A\u0438\u0445 \u043C\u043E\u0442\u0438\u0432\u043E\u0432 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442
    \u0438\u0437 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0432\u0430\u0436\u043D\u043E\u0439 \u0438 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0438\u0437\u0443\u0447\u0430\u0435\u043C\u043E\u0439
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u043E\u0439, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0447\u0430\u0441\u0442\u043D\u044B\u0445
    \u0441\u043B\u0443\u0447\u0430\u044F\u0445.  #### \u041F\u0443\u0447\u043A\u0438
    \u0438 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0414\u0435\u043B\u0438\u043D\u044C \u0432\u043D\u0435\u0441 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u044E\u0449\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E **\u043F\u0443\u0447\u043A\u043E\u0432**:
    *   **\u041F\u0443\u0447\u043A\u0438 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A**:
    \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u0411\u0435\u0439\u043B\u0438\u043D\u0441\u043E\u043D\u043E\u043C,
    \u0411\u0435\u0440\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C \u0438 \u0413\u0430\u0431\u0431\u0435\u0440\u043E\u043C
    \u043E\u043D \u0434\u0430\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 **\u043F\u0443\u0447\u043A\u043E\u0432
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A**, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0433\u0440\u0430\u044E\u0442 \u043A\u043B\u044E\u0447\u0435\u0432\u0443\u044E
    \u0440\u043E\u043B\u044C \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u0432 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435
    \u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u043B\u0435\u043C\u043C\u044B \u041D\u0433\u043E \u0411\u0430\u043E \u0427\u0430\u0443.
    *   **\u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445 \u0433\u0440\u0443\u043F\u043F**:
    \u0412\u043C\u0435\u0441\u0442\u0435 \u0441 \u041B\u044E\u0441\u0442\u0438\u0433\u043E\u043C
    \u043E\u043D \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u2113-\u0430\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438 \u0434\u043B\u044F
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F \u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0445
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u043E\u0431\u0449\u0438\u0445 \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445
    \u0433\u0440\u0443\u043F\u043F \u0442\u0438\u043F\u0430 \u041B\u0438, \u0447\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u0432\u0430\u0436\u043D\u044B\u043C \u0448\u0430\u0433\u043E\u043C
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439. 
    #### \u0414\u0440\u0443\u0433\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    *   **\u041C\u043E\u0434\u0443\u043B\u0438 \u043A\u0440\u0438\u0432\u044B\u0445**:
    \u0412 \u0440\u0430\u043D\u043D\u0435\u0439 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 \u0441 \u041C\u0430\u043C\u0444\u043E\u0440\u0434\u043E\u043C
    \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u043D\u0435\u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u044C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430 \u043C\u043E\u0434\u0443\u043B\u0435\u0439
    \u043A\u0440\u0438\u0432\u044B\u0445 \u0434\u0430\u043D\u043D\u043E\u0433\u043E
    \u0440\u043E\u0434\u0430, \u0432\u0432\u0435\u0434\u044F \u0432\u0430\u0436\u043D\u043E\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u0442\u0435\u043A\u0430**. *   **\u041F\u0440\u043E\u0431\u043B\u0435\u043C\u0430
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430**: \u041F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u043D\u043E\u0432\u043E\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0435 21-\u0439
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u0445 \u0441 \u0440\u0435\u0433\u0443\u043B\u044F\u0440\u043D\u044B\u043C\u0438
    \u043E\u0441\u043E\u0431\u044B\u043C\u0438 \u0442\u043E\u0447\u043A\u0430\u043C\u0438.
    *   **\u0422\u0435\u043D\u0437\u043E\u0440\u043D\u044B\u0435 \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0438**:
    \u0412\u043D\u0435\u0441 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E **\u0442\u0430\u043D\u043D\u0430\u043A\u0438\u0435\u0432\u044B\u0445
    \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0439**, \u043E\u0431\u043E\u0431\u0449\u0438\u0432
    \u0438\u0434\u0435\u044E \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0439
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u0433\u0440\u0443\u043F\u043F.  ### \U0001F30D \u041E\u0431\u0449\u0435\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u041A\u0430\u043A \u0441\u043A\u0430\u0437\u0430\u043D\u043E \u0432 \u0446\u0438\u0442\u0430\u0442\u0435
    \u0438\u0437 \u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u043C\u0438\u0442\u0435\u0442\u0430, \u0432\u043A\u043B\u0430\u0434
    \u0414\u0435\u043B\u0438\u043D\u044F \u043E\u043A\u0430\u0437\u0430\u043B **\"\u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u0443\u044E\u0449\u0435\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0447\u0438\u0441\u0435\u043B, \u0442\u0435\u043E\u0440\u0438\u044E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u0438 \u0441\u043C\u0435\u0436\u043D\u044B\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438\"**.
    \u0415\u0433\u043E \u0438\u0434\u0435\u0438 \u0438 \u043C\u0435\u0442\u043E\u0434\u044B
    \u0441\u0442\u0430\u043B\u0438 \u043D\u0435\u043E\u0442\u044A\u0435\u043C\u043B\u0435\u043C\u043E\u0439
    \u0447\u0430\u0441\u0442\u044C\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u044F. 
    ### \U0001F3C5 \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043D\u0430\u0433\u0440\u0430\u0434\u044B
    \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435  *   **\u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F (1978)**  *   **\u041F\u0440\u0435\u043C\u0438\u044F
    \u041A\u0440\u0430\u0444\u043E\u0440\u0434\u0430 (1988)**  *   **\u041F\u0440\u0435\u043C\u0438\u044F
    \u0411\u0430\u043B\u044C\u0446\u0430\u043D\u0430 (2004)**  *   **\u041F\u0440\u0435\u043C\u0438\u044F
    \u0412\u043E\u043B\u044C\u0444\u0430 (2008)**  *   **\u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F (2013)**   \u042D\u0442\u0438 \u043D\u0430\u0433\u0440\u0430\u0434\u044B
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044E\u0442 \u0435\u0433\u043E
    \u0441\u0442\u0430\u0442\u0443\u0441 \u043E\u0434\u043D\u043E\u0433\u043E \u0438\u0437
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0441\u0442\u0438."
  achievementsEn: 
  personalLifeRu: "\u0425\u043E\u0442\u044F \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u0430\u044F
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F \u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u041F\u044C\u0435\u0440\u0430 \u0414\u0435\u043B\u0438\u043D\u044F
    \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E \u0441\u043A\u0443\u0434\u043D\u0430,
    \u0442\u0430\u043A \u043A\u0430\u043A \u043E\u043D \u0432\u0441\u0435\u0433\u0434\u0430
    \u0431\u044B\u043B \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0435\u043D
    \u043D\u0430 \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435,
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0444\u0430\u043A\u0442\u044B
    \u0432\u0441\u0451 \u0436\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B. 
    ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466 \u0421\u0435\u043C\u044C\u044F
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B  \u041F\u044C\u0435\u0440
    \u0414\u0435\u043B\u0438\u043D\u044C \u2014 \u043C\u043B\u0430\u0434\u0448\u0438\u0439
    \u0438\u0437 \u0442\u0440\u043E\u0438\u0445 \u0434\u0435\u0442\u0435\u0439 \u0410\u043B\u044C\u0431\u0435\u0440\u0430
    \u0414\u0435\u043B\u0438\u043D\u044F (\u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440\u0430
    \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u0438) \u0438 \u0420\u0435\u043D\u0435
    \u0411\u043E\u0434\u0430\u0440. \u0420\u043E\u0434\u0438\u043B\u0441\u044F 3
    \u043E\u043A\u0442\u044F\u0431\u0440\u044F 1944 \u0433\u043E\u0434\u0430 \u0432
    \u0431\u0440\u044E\u0441\u0441\u0435\u043B\u044C\u0441\u043A\u043E\u043C \u0440\u0430\u0439\u043E\u043D\u0435
    \u042D\u0442\u0442\u0435\u0440\u0431\u0435\u043A. \u0415\u0433\u043E \u0431\u0440\u0430\u0442
    \u0431\u044B\u043B \u0441\u0442\u0430\u0440\u0448\u0435 \u043D\u0430 \u0441\u0435\u043C\u044C
    \u043B\u0435\u0442, \u0430 \u0441\u0435\u0441\u0442\u0440\u0430 \u2014 \u043D\u0430
    \u043E\u0434\u0438\u043D\u043D\u0430\u0434\u0446\u0430\u0442\u044C. \u0420\u043E\u0434\u0438\u0442\u0435\u043B\u0438
    \u0414\u0435\u043B\u0438\u043D\u044F, \u0431\u0443\u0434\u0443\u0447\u0438 \u043E\u0447\u0435\u043D\u044C
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B\u043C\u0438 \u043B\u044E\u0434\u044C\u043C\u0438,
    \u043D\u0435 \u0441\u043C\u043E\u0433\u043B\u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0432\u044B\u0441\u0448\u0435\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u043F\u043E \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043F\u0440\u0438\u0447\u0438\u043D\u0430\u043C, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \u043E\u0447\u0435\u043D\u044C \u0445\u043E\u0442\u0435\u043B\u0438, \u0447\u0442\u043E\u0431\u044B
    \u0438\u0445 \u0434\u0435\u0442\u0438 \u0445\u043E\u0440\u043E\u0448\u043E \u0443\u0447\u0438\u043B\u0438\u0441\u044C
    \u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B\u0438 \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u044B. 
    \u0421\u0432\u043E\u0438\u043C \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439 \u043E\u043D
    \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C \u043E\u0431\u044F\u0437\u0430\u043D
    \u0431\u0440\u0430\u0442\u0443, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432
    \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u0439 \u0444\u043E\u0440\u043C\u0435
    \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u043B \u0435\u043C\u0443 \u043E\u0441\u043D\u043E\u0432\u044B.
    \u0412 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u043E\u043D \u0431\u044B\u043B
    \u0443\u0434\u0438\u0432\u043B\u0451\u043D, \u0443\u0437\u043D\u0430\u0432, \u0447\u0442\u043E
    \xAB\u043C\u0438\u043D\u0443\u0441 \u043E\u0434\u0438\u043D \u0443\u043C\u043D\u043E\u0436\u0438\u0442\u044C
    \u043D\u0430 \u043C\u0438\u043D\u0443\u0441 \u043E\u0434\u0438\u043D \u0440\u0430\u0432\u043D\u044F\u0435\u0442\u0441\u044F
    \u043F\u043B\u044E\u0441 \u043E\u0434\u0438\u043D\xBB, \u0438 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u0448\u0435\u0441\u0442\u0438-\u0441\u0435\u043C\u0438 \u043B\u0435\u0442 \u0443\u0436\u0435
    \u0440\u0435\u0448\u0430\u043B \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F.  ### \u2764\uFE0F \u0416\u0435\u043D\u0430
    \u0438 \u0434\u0435\u0442\u0438  \u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u043A\u043E\u043C\u0430\u043D\u0434\u0438\u0440\u043E\u0432\u043A\u0438
    \u0414\u0435\u043B\u0438\u043D\u044F \u0432 \u0420\u043E\u0441\u0441\u0438\u044E
    \u0441\u044B\u0433\u0440\u0430\u043B\u0438 \u0432\u0430\u0436\u043D\u0443\u044E
    \u0440\u043E\u043B\u044C \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0432
    \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0435, \u043D\u043E \u0438
    \u0432 \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438. **9
    \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F 1980 \u0433\u043E\u0434\u0430**
    \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u0415\u043B\u0435\u043D\u0435
    \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440\u043E\u0432\u043D\u0435 \u0410\u043B\u0435\u043A\u0441\u0435\u0435\u0432\u043E\u0439**,
    \u0441 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438\u0437 \u0432\u0438\u0437\u0438\u0442\u043E\u0432 \u0432 \u0421\u0421\u0421\u0420.
    \u0423 \u043D\u0438\u0445 \u0435\u0441\u0442\u044C \u0434\u0432\u043E\u0435 \u0434\u0435\u0442\u0435\u0439:
    \u0434\u043E\u0447\u044C \u041D\u0430\u0442\u0430\u043B\u044C\u044F \u0438 \u0441\u044B\u043D
    \u0410\u043B\u0435\u043A\u0441\u0438\u0441.  ### \U0001F3D5\uFE0F \u0423\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F
    \u0438 \u043F\u043E\u0432\u0441\u0435\u0434\u043D\u0435\u0432\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0437\u0430\u043D\u044F\u0442\u043E\u0441\u0442\u044C \u0432 \u043D\u0430\u0443\u043A\u0435,
    \u0414\u0435\u043B\u0438\u043D\u044C \u2014 \u0447\u0435\u043B\u043E\u0432\u0435\u043A
    \u0441 \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043C\u0438
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0430\u043C\u0438. \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u0447\u0442\u043E \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u043E\u043D
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B \u0432 \u0441\u043A\u0430\u0443\u0442\u0441\u043A\u043E\u043C
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043F\u0440\u0438\u0432\u0438\u043B\u043E \u0435\u043C\u0443 \u043B\u044E\u0431\u043E\u0432\u044C
    \u043A \u043F\u0440\u0438\u0440\u043E\u0434\u0435 \u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u043C\u0443
    \u043E\u0442\u0434\u044B\u0445\u0443. \u041E\u043D \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u043B
    \u0438\u0433\u0440\u0430\u0442\u044C \u0432 \u043B\u0435\u0441\u0443, \u0430
    \u043D\u0435 \u0432 \u0433\u043E\u0440\u043E\u0434\u0435, \u0438 \u043D\u0430\u0443\u0447\u0438\u043B\u0441\u044F
    \u0440\u0430\u0437\u0436\u0438\u0433\u0430\u0442\u044C \u043A\u043E\u0441\u0442\u0451\u0440
    \u0441 \u043E\u0434\u043D\u043E\u0439 \u0441\u043F\u0438\u0447\u043A\u0438. \u042D\u0442\u0430
    \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0430 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C
    \u0443 \u043D\u0435\u0433\u043E \u0438 \u0432\u043E \u0432\u0437\u0440\u043E\u0441\u043B\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438: \u043E\u043D \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B,
    \u0447\u0442\u043E \u043A\u0430\u0436\u0434\u043E\u0435 \u0437\u0438\u043C\u043D\u0435\u0435
    \u0443\u0442\u0440\u043E \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442 \u0441
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0440\u0430\u0437\u0436\u0438\u0433\u0430\u0435\u0442
    \u043E\u0433\u043E\u043D\u044C \u0432 \u043A\u0430\u043C\u0438\u043D\u0435. 
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0443\u0432\u043B\u0435\u043A\u0430\u0435\u0442\u0441\u044F
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F\u043C\u0438
    \u043F\u043E \u0432\u0441\u0435\u043C\u0443 \u043C\u0438\u0440\u0443, \u0447\u0442\u043E\u0431\u044B
    \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u044C \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0435
    \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u044F, \u0430 \u0437\u0438\u043C\u043E\u0439
    \u043C\u043E\u0436\u0435\u0442 \u0441\u0442\u0440\u043E\u0438\u0442\u044C \u0438\u0433\u043B\u0443.
    \u041A\u0440\u043E\u043C\u0435 \u0442\u043E\u0433\u043E, \u0414\u0435\u043B\u0438\u043D\u044C,
    \u0436\u0438\u0432\u044F \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435,
    \u043D\u0435\u0440\u0435\u0434\u043A\u043E \u043F\u0435\u0440\u0435\u0434\u0432\u0438\u0433\u0430\u0435\u0442\u0441\u044F
    \u043F\u043E \u0433\u043E\u0440\u043E\u0434\u0443 \u043D\u0430 \u0432\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434\u0435,
    \u0434\u0430\u0436\u0435 \u0447\u0442\u043E\u0431\u044B \u0441\u044A\u0435\u0437\u0434\u0438\u0442\u044C
    \u0437\u0430 \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0430\u043C\u0438 \u0432
    \u043C\u0430\u0433\u0430\u0437\u0438\u043D."
  personalLifeEn: 
  shortBioRu: "\u041F\u044C\u0435\u0440 \u0420\u0435\u043D\u0435 \u0414\u0435\u043B\u0438\u043D\u044C
    (\u0440\u043E\u0434\u0438\u043B\u0441\u044F 3 \u043E\u043A\u0442\u044F\u0431\u0440\u044F
    1944 \u0433\u043E\u0434\u0430) \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0441\u0442\u0438,
    \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B, \u043F\u0440\u0435\u0436\u0434\u0435
    \u0432\u0441\u0435\u0433\u043E \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0447\u0438\u0441\u0435\u043B \u0438 \u0441\u043C\u0435\u0436\u043D\u044B\u0435
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u044B. \u041E\u043D \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043E\u0431\u043B\u0430\u0434\u0430\u0442\u0435\u043B\u0435\u043C \u0432\u0441\u0435\u0445
    \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u0438 \u0424\u0438\u043B\u0434\u0441\u0430, \u0412\u043E\u043B\u044C\u0444\u0430
    \u0438 \u0410\u0431\u0435\u043B\u044F.  ### \U0001F4D6 \u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u043D\u0430\u0447\u0430\u043B\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B 
    \u041F\u044C\u0435\u0440 \u0420\u0435\u043D\u0435 \u0414\u0435\u043B\u0438\u043D\u044C
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0432 \u0411\u0440\u044E\u0441\u0441\u0435\u043B\u0435,
    \u0411\u0435\u043B\u044C\u0433\u0438\u044F. \u0415\u0433\u043E \u043F\u0443\u0442\u044C
    \u0432 \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043D\u0430\u0447\u0430\u043B\u0441\u044F \u0432 \u0411\u0440\u044E\u0441\u0441\u0435\u043B\u044C\u0441\u043A\u043E\u043C
    \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    (Universit\xE9 Libre de Bruxelles), \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043D \u0443\u0441\u043F\u0435\u0448\u043D\u043E \u043E\u043A\u043E\u043D\u0447\u0438\u043B. 
    \u0420\u0435\u0448\u0430\u044E\u0449\u0438\u043C \u044D\u0442\u0430\u043F\u043E\u043C
    \u0432 \u0435\u0433\u043E \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0438
    \u0441\u0442\u0430\u043B\u0430 \u0437\u0430\u0449\u0438\u0442\u0430 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u043E\u0439
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438. \u0415\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C
    \u0431\u044B\u043B \u043D\u0435 \u043A\u0442\u043E \u0438\u043D\u043E\u0439,
    \u043A\u0430\u043A **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A**
    \u2014 \u043E\u0434\u043D\u0430 \u0438\u0437 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u0444\u0438\u0433\u0443\u0440 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    XX \u0432\u0435\u043A\u0430. \u041F\u043E\u0441\u043B\u0435 \u0437\u0430\u0449\u0438\u0442\u044B
    \u0414\u0435\u043B\u0438\u043D\u044C \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u043E\u043C
    \u0432\u043E \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u043C
    **\u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u0432\u044B\u0441\u0448\u0438\u0445
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    (IH\xC9S)** \u043F\u043E\u0434 \u041F\u0430\u0440\u0438\u0436\u0435\u043C.  ###
    \U0001F52C \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F  \u041D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0414\u0435\u043B\u0438\u043D\u044F
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E, \u043D\u043E \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442 \u0441\u0442\u0430\u043B\u0438
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C\u0438 \u043F\u0440\u043E\u0440\u044B\u0432\u0430\u043C\u0438. 
    *   **\u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437 \u0412\u0435\u0439\u043B\u044F**:
    \u042D\u0442\u043E, \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E,
    \u0441\u0430\u043C\u043E\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0414\u0435\u043B\u0438\u043D\u044F.
    \u0413\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u0412\u0435\u0439\u043B\u044F,
    \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u0442\u044B\u0435 \u0410\u043D\u0434\u0440\u0435
    \u0412\u0435\u0439\u043B\u0435\u043C \u0432 1949 \u0433\u043E\u0434\u0443, \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0438
    \u0441\u043E\u0431\u043E\u0439 \u0441\u0435\u0440\u0438\u044E \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0439 \u043E \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u043D\u0430\u0434 \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u043C\u0438 \u043F\u043E\u043B\u044F\u043C\u0438.
    \u0414\u0435\u043B\u0438\u043D\u044C \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0438\u0445 \u0432 1973 \u0433\u043E\u0434\u0443,
    \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0432 \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u043D\u0443\u044E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443, \u043D\u0430\u0447\u0430\u0442\u0443\u044E
    \u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u043E\u043C.
    \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430
    \u0435\u043C\u0443 \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0441\u043B\u0430\u0432\u0443
    \u0438 \u0432 1978 \u0433\u043E\u0434\u0443 \u2014 \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E. *   **\u0414\u0440\u0443\u0433\u0438\u0435
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B**: \u0421\u0444\u0435\u0440\u0430
    \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432 \u043D\u0435
    \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u043B\u0430\u0441\u044C
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430\u043C\u0438 \u0412\u0435\u0439\u043B\u044F.
    \u041E\u043D \u0432\u043D\u0435\u0441 \u0440\u0435\u0448\u0430\u044E\u0449\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    **\u0442\u0435\u043E\u0440\u0438\u0438 \u0441\u043C\u0435\u0448\u0430\u043D\u043D\u044B\u0445
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440 \u0425\u043E\u0434\u0436\u0430**
    \u0438 \u0432 **\u0442\u0435\u043E\u0440\u0438\u044E \u043C\u043E\u0442\u0438\u0432\u043E\u0432**
    \u2014 \u0435\u0449\u0451 \u043E\u0434\u0438\u043D \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u044B\u0439
    \u043F\u0440\u043E\u0435\u043A\u0442, \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0439
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u043E\u043C. \u0422\u0430\u043A\u0436\u0435
    \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u0430\u0434 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432 \u043C\u043E\u0434\u0443\u043B\u0435\u0439
    \u043A\u0440\u0438\u0432\u044B\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0414\u044D\u0432\u0438\u0434\u043E\u043C \u041C\u0430\u043C\u0444\u043E\u0440\u0434\u043E\u043C
    \u0438 \u0432\u043D\u0435\u0441 \u0432\u0430\u0436\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u0442\u0435\u043D\u0437\u043E\u0440\u043D\u044B\u0445
    \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0439.  ### \U0001F468\u200D\U0001F3EB
    \u041A\u0430\u0440\u044C\u0435\u0440\u0430 \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u041D\u0430\u0443\u0447\u043D\u0430\u044F \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u0414\u0435\u043B\u0438\u043D\u044F \u0442\u0435\u0441\u043D\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u0430
    \u0441 \u0434\u0432\u0443\u043C\u044F \u0432\u0435\u0434\u0443\u0449\u0438\u043C\u0438
    \u043C\u0438\u0440\u043E\u0432\u044B\u043C\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438
    \u0446\u0435\u043D\u0442\u0440\u0430\u043C\u0438:  *   **\u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442
    \u0432\u044B\u0441\u0448\u0438\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 (IH\xC9S),
    \u0424\u0440\u0430\u043D\u0446\u0438\u044F**: \u041E\u043D \u0431\u044B\u043B
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u044B\u043C \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u043C
    \u044D\u0442\u043E\u0433\u043E \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430,
    \u0433\u0434\u0435 \u043D\u0430\u0447\u0430\u043B \u0441\u0432\u043E\u0439 \u043F\u0443\u0442\u044C
    \u0441 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u043E\u043C. *  
    **\u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 (IAS),
    \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D, \u0421\u0428\u0410**: \u0421
    1970 \u043F\u043E 1984 \u0433\u043E\u0434 \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435, \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u044F
    \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u043F\u043E\u0437\u0438\u0446\u0438\u044E
    \u0432 IH\xC9S. \u0412 1984 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u044B\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0432 IAS, \u0430 \u0441 2008 \u0433\u043E\u0434\u0430 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0435\u0433\u043E \u043F\u043E\u0447\u0435\u0442\u043D\u044B\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    (Professor Emeritus).  \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u0432
    \u043D\u0430\u0443\u043A\u0443 \u043E\u0442\u043C\u0435\u0447\u0435\u043D \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E\u043C
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0445 \u043D\u0430\u0433\u0440\u0430\u0434: 
    *   **\u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0430\u044F \u043F\u0440\u0435\u043C\u0438\u044F
    (1978)**  *   **\u041F\u0440\u0435\u043C\u0438\u044F \u041A\u0440\u0430\u0444\u043E\u0440\u0434\u0430
    \u043E\u0442 \u0428\u0432\u0435\u0434\u0441\u043A\u043E\u0439 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A (1988)** 
    *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0411\u0430\u043B\u044C\u0446\u0430\u043D\u0430
    (2004)**  *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0412\u043E\u043B\u044C\u0444\u0430
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 (2008)** 
    *   **\u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u043F\u0440\u0435\u043C\u0438\u044F
    (2013)** \u2014 \u044D\u0442\u0430 \u043D\u0430\u0433\u0440\u0430\u0434\u0430
    \u0431\u044B\u043B\u0430 \u043F\u0440\u0438\u0441\u0443\u0436\u0434\u0435\u043D\u0430
    \u0435\u043C\u0443 \"\u0437\u0430 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438 \u0438\u0445 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B, \u0442\u0435\u043E\u0440\u0438\u0438
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u0438 \u0441\u043C\u0435\u0436\u043D\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445\". 
    \u0412 2006 \u0433\u043E\u0434\u0443 \u043A\u043E\u0440\u043E\u043B\u044C \u0411\u0435\u043B\u044C\u0433\u0438\u0438
    \u0432\u043E\u0437\u0432\u0435\u043B \u0435\u0433\u043E \u0432 \u0434\u0432\u043E\u0440\u044F\u043D\u0441\u043A\u043E\u0435
    \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u043E \u0441 \u0442\u0438\u0442\u0443\u043B\u043E\u043C
    \u0432\u0438\u043A\u043E\u043D\u0442\u0430. \u0414\u0435\u043B\u0438\u043D\u044C
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0447\u043B\u0435\u043D\u043E\u043C
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u043D\u0430\u0443\u043A \u043F\u043E \u0432\u0441\u0435\u043C\u0443 \u043C\u0438\u0440\u0443,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A (1978),
    \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0443\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E
    \u043D\u0430\u0443\u043A \u0421\u0428\u0410 (2007) \u0438 \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A (2016). 
    ### \U0001F91D \u041F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0430 \u043C\u043E\u043B\u043E\u0434\u044B\u0445
    \u0443\u0447\u0435\u043D\u044B\u0445  \u041F\u044C\u0435\u0440 \u0414\u0435\u043B\u0438\u043D\u044C
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0432\u043E\u0438\u043C\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438
    \u0442\u0440\u0443\u0434\u0430\u043C\u0438, \u043D\u043E \u0438 \u0431\u043B\u0430\u0433\u043E\u0442\u0432\u043E\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E.
    \u041F\u043E\u0441\u043B\u0435 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F
    \u043F\u0440\u0435\u043C\u0438\u0438 \u0411\u0430\u043B\u044C\u0446\u0430\u043D\u0430
    \u0432 2004 \u0433\u043E\u0434\u0443, \u043F\u043E \u043F\u0440\u0430\u0432\u0438\u043B\u0430\u043C
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0430
    \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u0434\u043E\u043B\u0436\u043D\u0430
    \u0438\u0434\u0442\u0438 \u043D\u0430 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0443
    \u043C\u043E\u043B\u043E\u0434\u044B\u0445 \u0443\u0447\u0435\u043D\u044B\u0445,
    \u043E\u043D \u0443\u0447\u0440\u0435\u0434\u0438\u043B **\"\u041A\u043E\u043D\u043A\u0443\u0440\u0441
    \u0414\u0435\u043B\u0438\u043D\u044F\"** \u0434\u043B\u044F \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0438\u0437
    \u0420\u043E\u0441\u0441\u0438\u0438, \u0423\u043A\u0440\u0430\u0438\u043D\u044B
    \u0438 \u0411\u0435\u043B\u043E\u0440\u0443\u0441\u0441\u0438\u0438. \u041F\u043E\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u0438
    \u043F\u043E\u043B\u0443\u0447\u0430\u043B\u0438 \u0442\u0440\u0435\u0445\u0433\u043E\u0434\u0438\u0447\u043D\u044B\u0435
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u0438. \u0414\u0435\u043B\u0438\u043D\u044C
    \u043B\u0438\u0447\u043D\u043E \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0440\u0430\u0431\u043E\u0442\u0435 \u0436\u044E\u0440\u0438 \u044D\u0442\u043E\u0433\u043E
    \u043A\u043E\u043D\u043A\u0443\u0440\u0441\u0430, \u0430 \u043F\u043E\u0437\u0436\u0435
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u0435\u0433\u043E \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E
    \u043D\u0430 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043F\u043E\u0447\u0435\u0442\u043D\u044B\u043C
    \u043F\u0440\u0435\u0434\u0441\u0435\u0434\u0430\u0442\u0435\u043B\u0435\u043C
    \u042D\u043A\u0441\u043F\u0435\u0440\u0442\u043D\u043E\u0433\u043E \u0441\u043E\u0432\u0435\u0442\u0430
    \u0444\u043E\u043D\u0434\u0430 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \"\u0411\u0430\u0437\u0438\u0441\"."
  shortBioEn: 
  interestingFactsRu: "\u041F\u044C\u0435\u0440 \u0414\u0435\u043B\u0438\u043D\u044C
    \u2014 \u043E\u0434\u043D\u0430 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u044F\u0440\u043A\u0438\u0445
    \u0444\u0438\u0433\u0443\u0440 \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0438 \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C \u0438 \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u043F\u043E\u043B\u043D\u044B \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0445
    \u0438 \u043F\u043E-\u0441\u0432\u043E\u0435\u043C\u0443 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0434\u0435\u0442\u0430\u043B\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u0435\u043B\u0430\u044E\u0442 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E
    \u0435\u0449\u0435 \u0431\u043E\u043B\u0435\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E\u0439. 
    ### \U0001F9E0 \u041D\u0435\u043E\u0431\u044B\u0447\u043D\u043E\u0435 \u043D\u0430\u0447\u0430\u043B\u043E:
    \u0411\u0443\u0440\u0431\u0430\u043A\u0438 \u0432 14 \u043B\u0435\u0442  \u041E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0442\u043E, \u043A\u0430\u043A \u0440\u0430\u043D\u043E \u0414\u0435\u043B\u0438\u043D\u044C
    \u0441\u043E\u043F\u0440\u0438\u043A\u043E\u0441\u043D\u0443\u043B\u0441\u044F
    \u0441 \"\u0432\u044B\u0441\u043E\u043A\u043E\u0439\" \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439.
    \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u043E\u043A\u043E\u043B\u043E
    12 \u043B\u0435\u0442 \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0447\u0438\u0442\u0430\u0442\u044C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0435
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0438 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0441\u0432\u043E\u0435\u0433\u043E \u0441\u0442\u0430\u0440\u0448\u0435\u0433\u043E
    \u0431\u0440\u0430\u0442\u0430. \u041D\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439
    \u043F\u0435\u0440\u0435\u0432\u043E\u0440\u043E\u0442 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u0435\u043B,
    \u043A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0419. \u041D\u0438\u0439\u0441
    \u0434\u0430\u043B \u0435\u043C\u0443 \u043F\u043E\u0447\u0438\u0442\u0430\u0442\u044C
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0442\u043E\u043C\u043E\u0432
    \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0430 \"\u042D\u043B\u0435\u043C\u0435\u043D\u0442\u044B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\" \u041D\u0438\u043A\u043E\u043B\u044F
    \u0411\u0443\u0440\u0431\u0430\u043A\u0438 (\u043A\u043E\u043B\u043B\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0439
    \u043F\u0441\u0435\u0432\u0434\u043E\u043D\u0438\u043C \u0433\u0440\u0443\u043F\u043F\u044B
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432). 
    \u042D\u0442\u0438 \u043A\u043D\u0438\u0433\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u0431\u044B\u0447\u043D\u043E \u043D\u0435 \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u044E\u0442
    14-\u043B\u0435\u0442\u043D\u0435\u043C\u0443 \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0441\u0442\u0443,
    \u0441\u0442\u0430\u043B\u0438 \u0434\u043B\u044F \u0414\u0435\u043B\u0438\u043D\u044F
    \u0441\u043E\u0431\u044B\u0442\u0438\u0435\u043C, \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0438\u043C
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C. \u041E\u043D \u0443\u0432\u043B\u0435\u043A\u0441\u044F
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E, \u0447\u0442\u043E \u0441
    \u044D\u0442\u043E\u0433\u043E \u0434\u043D\u044F, \u043F\u043E \u0435\u0433\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C\u0443 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044E,
    \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u043E\u0433\u043B\u044F\u0434\u044B\u0432\u0430\u043B\u0441\u044F
    \u043D\u0430\u0437\u0430\u0434. \u042D\u0442\u043E\u0442 \u0444\u0430\u043A\u0442
    \u043D\u0430\u0433\u043B\u044F\u0434\u043D\u043E \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
    \u0435\u0433\u043E \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u0438 \u0441\u0442\u0440\u0430\u0441\u0442\u044C
    \u043A \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0443 \u0441 \u0441\u0430\u043C\u043E\u0433\u043E
    \u0440\u0430\u043D\u043D\u0435\u0433\u043E \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0430. 
    ### \U0001F3AF \"\u0418\u0433\u0440\u0430\u044F, \u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0442\u044C
    \u043D\u0430 \u0436\u0438\u0437\u043D\u044C\"  \u0412 \u044E\u043D\u043E\u0441\u0442\u0438
    \u0414\u0435\u043B\u0438\u043D\u044C \u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0442\u0430\u0442\u044C \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432 \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0438
    \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0442\u044C \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u043D\u0430\u0443\u043A\u043E\u0439 \u0432 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u0434\u043B\u044F \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0443\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u044F. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u043F\u0443\u0442\u044C \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0441\u044F.
    \u041F\u043E\u0441\u0442\u0443\u043F\u0438\u0432 \u0432 \u0421\u0432\u043E\u0431\u043E\u0434\u043D\u044B\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0411\u0440\u044E\u0441\u0441\u0435\u043B\u044F,
    \u043E\u043D \u043F\u043E\u043F\u0430\u043B \u043F\u043E\u0434 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0433\u043E\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0416\u0430\u043A\u0430 \u0422\u0438\u0442\u0441\u0430.  \u0418\u043C\u0435\u043D\u043D\u043E
    \u0442\u043E\u0433\u0434\u0430 \u0414\u0435\u043B\u0438\u043D\u044C \u0441 \u0440\u0430\u0434\u043E\u0441\u0442\u044C\u044E
    \u043E\u0442\u043A\u0440\u044B\u043B \u0434\u043B\u044F \u0441\u0435\u0431\u044F,
    \u0447\u0442\u043E \"\u043C\u043E\u0436\u043D\u043E \u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0442\u044C
    \u043D\u0430 \u0436\u0438\u0437\u043D\u044C, \u0438\u0433\u0440\u0430\u044F,
    \u0442.\u0435. \u0437\u0430\u043D\u0438\u043C\u0430\u044F\u0441\u044C \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\u043C\u0438
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435\". \u042D\u0442\u043E
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u0435\u0433\u043E
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435 \u043A \u043D\u0430\u0443\u043A\u0435
    \u043A\u0430\u043A \u043A \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0438\u0433\u0440\u0435, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C \u0441\u0442\u0430\u043B\u0430 \u0434\u0435\u043B\u043E\u043C
    \u0432\u0441\u0435\u0439 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438. 
    ### \U0001F3AD \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A-\u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B
    \u0441 \"\u043D\u0435\u0437\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u043C\u0438\"
    \u0438\u0434\u0435\u044F\u043C\u0438  \u0414\u0435\u043B\u0438\u043D\u044C \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0433\u0438\u0431\u043A\u043E\u0441\u0442\u044C\u044E \u0443\u043C\u0430. \u041E\u0442\u043C\u0435\u0447\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0441 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439
    \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0442
    \u0438 \u043E\u0432\u043B\u0430\u0434\u0435\u0432\u0430\u0435\u0442 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u043C\u0438
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430\u043C\u0438 \u043B\u044E\u0431\u043E\u0439
    \u043D\u043E\u0432\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043B\u0438
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B, \u043F\u043E\u0441\u043B\u0435
    \u0447\u0435\u0433\u043E \u043C\u043E\u0436\u0435\u0442 \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u0442\u044C
    \u0435\u0435 \u043A\u0430\u043A \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u0437\u043D\u0430\u043A\u043E\u043C\u044B\u0439 \u043E\u0431\u044A\u0435\u043A\u0442.
    \u041E\u043D \u043B\u0435\u0433\u043A\u043E \u043F\u0435\u0440\u0435\u043D\u0438\u043C\u0430\u0435\u0442
    \u044F\u0437\u044B\u043A \u0438 \u0442\u0435\u0440\u043C\u0438\u043D\u043E\u043B\u043E\u0433\u0438\u044E
    \u0441\u043E\u0431\u0435\u0441\u0435\u0434\u043D\u0438\u043A\u0430, \u0447\u0442\u043E
    \u0434\u0435\u043B\u0430\u0435\u0442 \u0435\u0433\u043E \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u0434\u043B\u044F
    \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0439 \u0438 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0430. 
    \u041F\u0440\u0438 \u044D\u0442\u043E\u043C \u0443 \u043D\u0435\u0433\u043E \u0435\u0441\u0442\u044C
    \u043E\u0434\u043D\u0430 \u043F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0447\u0435\u0440\u0442\u0430: \u0438\u0437-\u0437\u0430 \u043B\u0430\u043A\u043E\u043D\u0438\u0447\u043D\u043E\u0441\u0442\u0438
    \u0441\u0442\u0438\u043B\u044F \u0438 \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0438
    \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u043F\u0438\u0441\u0430\u0442\u044C
    \u043E\u0434\u043D\u043E \u0438 \u0442\u043E \u0436\u0435 \u0434\u0432\u0430\u0436\u0434\u044B,
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0438\u0437 \u0435\u0433\u043E \u043B\u0443\u0447\u0448\u0438\u0445
    \u0438\u0434\u0435\u0439 \u0442\u0430\u043A \u0438 \u043D\u0435 \u0431\u044B\u043B\u0438
    \u0438\u043C \u0437\u0430\u043F\u0438\u0441\u0430\u043D\u044B!  \u042D\u0442\u043E
    \u0434\u0435\u043B\u0430\u0435\u0442 \u0435\u0433\u043E \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0443 \u043D\u0435\u0433\u043E \u043E\u043A\u043E\u043B\u043E \u0441\u0442\u0430
    , \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u0435\u043C
    \u0431\u043E\u0433\u0430\u0442\u0441\u0442\u0432\u0430 \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430.  ### \U0001F451
    \u0412\u0438\u043A\u043E\u043D\u0442 \u0438 \u043F\u043E\u0447\u0442\u043E\u0432\u0430\u044F
    \u043C\u0430\u0440\u043A\u0430  \u0414\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0414\u0435\u043B\u0438\u043D\u044F \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432 \u043D\u0430\u0443\u0447\u043D\u043E\u043C \u043C\u0438\u0440\u0435, \u043D\u043E
    \u0438 \u043D\u0430 \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
    \u0443\u0440\u043E\u0432\u043D\u0435. \u0412 2006 \u0433\u043E\u0434\u0443 \u0431\u0435\u043B\u044C\u0433\u0438\u0439\u0441\u043A\u0438\u0439
    \u043A\u043E\u0440\u043E\u043B\u044C \u0410\u043B\u044C\u0431\u0435\u0440\u0442
    II \u0432\u043E\u0437\u0432\u0435\u043B \u0435\u0433\u043E \u0432 \u0434\u0432\u043E\u0440\u044F\u043D\u0441\u0442\u0432\u043E
    \u0441 \u0442\u0438\u0442\u0443\u043B\u043E\u043C \u0432\u0438\u043A\u043E\u043D\u0442\u0430. 
    \u0410 \u0432 \u0437\u043D\u0430\u043A \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F
    \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434\u0430 \u0432 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u041F\u043E\u0447\u0442\u0430
    \u0411\u0435\u043B\u044C\u0433\u0438\u0438 \u0434\u0430\u0436\u0435 \u0432\u044B\u043F\u0443\u0441\u0442\u0438\u043B\u0430
    \u043F\u043E\u0447\u0442\u043E\u0432\u0443\u044E \u043C\u0430\u0440\u043A\u0443
    \u0432 \u0435\u0433\u043E \u0447\u0435\u0441\u0442\u044C.  ### \U0001F4B0 \u041F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0430
    \u043C\u043E\u043B\u043E\u0434\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 
    \u041F\u043E\u043B\u0443\u0447\u0438\u0432 \u0432 2004 \u0433\u043E\u0434\u0443
    \u041F\u0440\u0435\u043C\u0438\u044E \u0411\u0430\u043B\u044C\u0446\u0430\u043D\u0430
    \u0441 \u043F\u0440\u0438\u0437\u043E\u0432\u044B\u043C \u0444\u043E\u043D\u0434\u043E\u043C
    \u0432 1 \u043C\u0438\u043B\u043B\u0438\u043E\u043D \u0448\u0432\u0435\u0439\u0446\u0430\u0440\u0441\u043A\u0438\u0445
    \u0444\u0440\u0430\u043D\u043A\u043E\u0432, \u0414\u0435\u043B\u0438\u043D\u044C,
    \u043F\u043E \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u043C \u0444\u043E\u043D\u0434\u0430,
    \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u043B \u043F\u043E\u0442\u0440\u0430\u0442\u0438\u0442\u044C
    \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443 \u0441\u0443\u043C\u043C\u044B
    \u043D\u0430 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0443 \u043C\u043E\u043B\u043E\u0434\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439.
    \u041E\u043D \u0443\u0447\u0440\u0435\u0434\u0438\u043B \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u0438
    \u0434\u043B\u044F \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u043C\u043E\u043B\u043E\u0434\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0438\u0437 \u0420\u043E\u0441\u0441\u0438\u0438, \u0423\u043A\u0440\u0430\u0438\u043D\u044B
    \u0438 \u0411\u0435\u043B\u043E\u0440\u0443\u0441\u0441\u0438\u0438, \u0430 \u043F\u043E\u0437\u0436\u0435
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u043A\u043E\u043D\u043A\u0443\u0440\u0441
    \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E \u043D\u0430 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430. \u042D\u0442\u043E\u0442 \u0436\u0435\u0441\u0442
    \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u0438\u0432\u0430\u0435\u0442 \u0435\u0433\u043E
    \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0437\u0430\u0431\u043E\u0442\u0443
    \u043E \u0431\u0443\u0434\u0443\u0449\u0435\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438.  ### \U0001F91D \"\u041F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u0435
    \u0443\u0447\u0435\u043D\u044B\u0445 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0443\" 
    \u0412 1992 \u0433\u043E\u0434\u0443 \u0414\u0435\u043B\u0438\u043D\u044C \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u043B
    \"\u041F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u0435
    \u0443\u0447\u0435\u043D\u044B\u0445 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0443\"
    \u2014 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0435 \u0443\u0447\u0435\u043D\u044B\u0435
    \u043C\u0438\u0440\u0430 \u0432\u044B\u0440\u0430\u0437\u0438\u043B\u0438 \u043E\u0431\u0435\u0441\u043F\u043E\u043A\u043E\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u043D\u0435\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u043C
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0430
    \u043A \u043F\u0440\u0438\u0440\u043E\u0434\u0435 \u0438 \u043F\u0440\u0438\u0437\u0432\u0430\u043B\u0438
    \u043A \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u044B\u043C \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F\u043C
    \u043F\u043E \u0437\u0430\u0449\u0438\u0442\u0435 \u043E\u043A\u0440\u0443\u0436\u0430\u044E\u0449\u0435\u0439
    \u0441\u0440\u0435\u0434\u044B. \u042D\u0442\u043E\u0442 \u0444\u0430\u043A\u0442
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u0435\u0433\u043E
    \u043A\u0430\u043A \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0441 \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u043E\u0439 \u043F\u043E\u0437\u0438\u0446\u0438\u0435\u0439,
    \u043D\u0435\u0440\u0430\u0432\u043D\u043E\u0434\u0443\u0448\u043D\u043E\u0433\u043E
    \u043A \u0433\u043B\u043E\u0431\u0430\u043B\u044C\u043D\u044B\u043C \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430\u043C."
