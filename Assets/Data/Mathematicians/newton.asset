  achievementsRu: "\u0418\u0441\u0430\u0430\u043A \u041D\u044C\u044E\u0442\u043E\u043D
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0441\u0442\u0430\u043B\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u0432\u0441\u0435\u0439 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438. \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u0444\u0438\u0437\u0438\u043A\u0443 \u0438 \u043E\u043F\u0442\u0438\u043A\u0443,
    \u0438 \u043A\u0430\u0436\u0434\u044B\u0439 \u0438\u0437 \u044D\u0442\u0438\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432 \u043F\u043E-\u0441\u0432\u043E\u0435\u043C\u0443
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u0435\u043D.  ###
    \U0001F4D0 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430: \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u044F\u0437\u044B\u043A\u0430 \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F  \u0413\u043B\u0430\u0432\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    **\u043C\u0435\u0442\u043E\u0434\u0430 \u0444\u043B\u044E\u043A\u0441\u0438\u0439**
    \u2014 \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u043C\u044B \u0441\u0435\u0433\u043E\u0434\u043D\u044F
    \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u044B\u043C
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435\u043C. \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0438\u0434\u0435\u0438 \u044D\u0442\u043E\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u0430
    \u0431\u044B\u043B\u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u044B
    \u0438\u043C \u043E\u043A\u043E\u043B\u043E 1665\u20131667 \u0433\u043E\u0434\u043E\u0432,
    \u0432 \u043F\u0435\u0440\u0438\u043E\u0434 \u0435\u0433\u043E \u0443\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F
    \u0432 \u0412\u0443\u043B\u0441\u0442\u043E\u0440\u043F\u0435.  *   **\u041E\u0441\u043D\u043E\u0432\u043D\u0430\u044F
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044F**: \u041D\u044C\u044E\u0442\u043E\u043D
    \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u044B (\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B **\u0444\u043B\u044E\u044D\u043D\u0442\u0430\u043C\u0438**)
    \u043A\u0430\u043A \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E
    \"\u0442\u0435\u043A\u0443\u0449\u0438\u0435\" \u0432\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    \u0421\u043A\u043E\u0440\u043E\u0441\u0442\u044C \u044D\u0442\u043E\u0433\u043E
    \"\u0442\u0435\u0447\u0435\u043D\u0438\u044F\" \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B
    **\u0444\u043B\u044E\u043A\u0441\u0438\u0435\u0439**. \u041F\u043E \u0441\u0443\u0442\u0438,
    \u0444\u043B\u044E\u043A\u0441\u0438\u044F \u2014 \u044D\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u0430\u044F,
    \u0430 \u0444\u043B\u044E\u044D\u043D\u0442\u0430 \u2014 \u043F\u0435\u0440\u0432\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u0430\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F. *   **\u0414\u0432\u0435 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438**: \u041C\u0435\u0442\u043E\u0434 \u0441\u0432\u043E\u0434\u0438\u043B
    \u0432\u0441\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u043A \u0434\u0432\u0443\u043C \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430\u043C:    
    1.  \u041F\u043E \u0434\u0430\u043D\u043D\u043E\u043C\u0443 \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044E
    \u043C\u0435\u0436\u0434\u0443 \u0444\u043B\u044E\u044D\u043D\u0442\u0430\u043C\u0438
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435
    \u043C\u0435\u0436\u0434\u0443 \u0438\u0445 \u0444\u043B\u044E\u043A\u0441\u0438\u044F\u043C\u0438
    (\u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435).    
    2.  \u041F\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044E, \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0435\u043C\u0443
    \u0444\u043B\u044E\u043A\u0441\u0438\u0438, \u043D\u0430\u0439\u0442\u0438 \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435
    \u043C\u0435\u0436\u0434\u0443 \u0444\u043B\u044E\u044D\u043D\u0442\u0430\u043C\u0438
    (\u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435).
    *   **\u0411\u0438\u043D\u043E\u043C \u041D\u044C\u044E\u0442\u043E\u043D\u0430**:
    \u0427\u0442\u043E\u0431\u044B \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0441\u043E \u0441\u043B\u043E\u0436\u043D\u044B\u043C\u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C\u0438,
    \u041D\u044C\u044E\u0442\u043E\u043D \u043E\u0442\u043A\u0440\u044B\u043B \u043E\u0431\u0449\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0431\u0438\u043D\u043E\u043C\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0440\u044F\u0434\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u0430
    \u0440\u0430\u0437\u043B\u043E\u0436\u0438\u0442\u044C `(1 + x)^n` \u0432 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0439
    \u0440\u044F\u0434 \u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0433\u043E \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044F
    `n`. \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u043C\u043E\u0449\u043D\u0435\u0439\u0448\u0438\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439. *   **\u041F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438**:
    \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0442\u0430\u043A\u0438\u0435
    \u043A\u0430\u043A \"\u0410\u043D\u0430\u043B\u0438\u0437 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0441 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u043C
    \u0447\u0438\u0441\u043B\u043E\u043C \u0447\u043B\u0435\u043D\u043E\u0432\" (\u043D\u0430\u043F\u0438\u0441\u0430\u043D
    \u0432 1669, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D
    \u0432 1711) \u0438 \"\u041C\u0435\u0442\u043E\u0434 \u0444\u043B\u044E\u043A\u0441\u0438\u0439
    \u0438 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445 \u0440\u044F\u0434\u043E\u0432\"
    (\u043D\u0430\u043F\u0438\u0441\u0430\u043D \u0432 1671, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D
    \u0432 1736), \u0431\u044B\u043B\u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u044B
    \u0441 \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u0437\u0430\u0434\u0435\u0440\u0436\u043A\u043E\u0439.
    \"\u0412\u0441\u0435\u043E\u0431\u0449\u0430\u044F \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430\",
    \u0441\u0431\u043E\u0440\u043D\u0438\u043A \u0435\u0433\u043E \u043B\u0435\u043A\u0446\u0438\u0439
    \u043F\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0435, \u0432\u044B\u0448\u043B\u0430
    \u0432 1707 \u0433\u043E\u0434\u0443.  ### \U0001F30C \u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430
    \u0438 \u0417\u0430\u043A\u043E\u043D \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0433\u043E
    \u0442\u044F\u0433\u043E\u0442\u0435\u043D\u0438\u044F: \u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442
    \u043C\u0438\u0440\u043E\u0437\u0434\u0430\u043D\u0438\u044F  \u0412\u0435\u0440\u0448\u0438\u043D\u043E\u0439
    \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u0441\u0442\u0430\u043B\u0438 **\"\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043D\u0430\u0447\u0430\u043B\u0430 \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438\"** (1687). \u0412 \u044D\u0442\u043E\u043C
    \u0442\u0440\u0443\u0434\u0435 \u043E\u043D \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u043B
    \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u0435 \u0438\u043C \u0437\u0430\u043A\u043E\u043D\u044B
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0438 \u0442\u044F\u0433\u043E\u0442\u0435\u043D\u0438\u044F
    \u0432 \u0435\u0434\u0438\u043D\u0443\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442
    \u043A\u0430\u043A \u043F\u0430\u0434\u0435\u043D\u0438\u0435 \u044F\u0431\u043B\u043E\u043A\u0430,
    \u0442\u0430\u043A \u0438 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u043F\u043B\u0430\u043D\u0435\u0442. 
    *   **\u0422\u0440\u0438 \u0437\u0430\u043A\u043E\u043D\u0430 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F**
    (\u0437\u0430\u043A\u043E\u043D\u044B \u041D\u044C\u044E\u0442\u043E\u043D\u0430):
    \u0417\u0430\u043A\u043E\u043D\u044B, \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0449\u0438\u0435
    \u0441\u0432\u044F\u0437\u044C \u043C\u0435\u0436\u0434\u0443 \u0441\u0438\u043B\u043E\u0439,
    \u043C\u0430\u0441\u0441\u043E\u0439 \u0438 \u0443\u0441\u043A\u043E\u0440\u0435\u043D\u0438\u0435\u043C
    \u0442\u0435\u043B\u0430, \u0441\u0442\u0430\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u043E\u0439
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438.
    *   **\u0417\u0430\u043A\u043E\u043D \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0433\u043E
    \u0442\u044F\u0433\u043E\u0442\u0435\u043D\u0438\u044F**: \u041D\u044C\u044E\u0442\u043E\u043D
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0441\u0438\u043B\u0430
    \u043F\u0440\u0438\u0442\u044F\u0436\u0435\u043D\u0438\u044F \u043C\u0435\u0436\u0434\u0443
    \u0434\u0432\u0443\u043C\u044F \u0442\u0435\u043B\u0430\u043C\u0438 \u043F\u0440\u044F\u043C\u043E
    \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u044E \u0438\u0445
    \u043C\u0430\u0441\u0441 \u0438 \u043E\u0431\u0440\u0430\u0442\u043D\u043E \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0443 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    \u043C\u0435\u0436\u0434\u0443 \u043D\u0438\u043C\u0438 (`F = G * (m1 * m2) /
    r^2`). \u041B\u0435\u0433\u0435\u043D\u0434\u0430 \u043E \u044F\u0431\u043B\u043E\u043A\u0435,
    \u0445\u043E\u0442\u044C \u0438 \u0443\u043F\u0440\u043E\u0449\u0430\u0435\u0442
    \u0438\u0441\u0442\u043E\u0440\u0438\u044E, \u043E\u0442\u0440\u0430\u0436\u0430\u0435\u0442
    \u0435\u0433\u043E \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u0435 \u043E \u0442\u043E\u043C,
    \u0447\u0442\u043E \u043E\u0434\u043D\u0430 \u0438 \u0442\u0430 \u0436\u0435
    \u0441\u0438\u043B\u0430 \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435\u043C \u043D\u0430 \u0417\u0435\u043C\u043B\u0435
    \u0438 \u0432 \u043D\u0435\u0431\u0435\u0441\u0430\u0445.  ### \U0001F308 \u041E\u043F\u0442\u0438\u043A\u0430:
    \u041F\u0440\u0438\u0440\u043E\u0434\u0430 \u0441\u0432\u0435\u0442\u0430 \u0438
    \u0446\u0432\u0435\u0442\u0430  \u041D\u044C\u044E\u0442\u043E\u043D \u0432\u043D\u0435\u0441
    \u043D\u0435 \u043C\u0435\u043D\u0435\u0435 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0438 \u0432 \u0443\u0447\u0435\u043D\u0438\u0435
    \u043E \u0441\u0432\u0435\u0442\u0435. \u0421\u0432\u043E\u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043E\u043D
    \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u0432 \u0442\u0440\u0443\u0434\u0435
    **\"\u041E\u043F\u0442\u0438\u043A\u0430\"**, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u043E\u043C
    \u0432 1704 \u0433\u043E\u0434\u0443.  *   **\u042D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u044B
    \u0441 \u043F\u0440\u0438\u0437\u043C\u0430\u043C\u0438**: \u041F\u0440\u043E\u0432\u043E\u0434\u044F
    \u043E\u043F\u044B\u0442\u044B \u0441 \u043F\u0440\u0438\u0437\u043C\u0430\u043C\u0438
    \u0432 \u0437\u0430\u0442\u0435\u043C\u043D\u0435\u043D\u043D\u043E\u0439 \u043A\u043E\u043C\u043D\u0430\u0442\u0435,
    \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0431\u0435\u043B\u044B\u0439 \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0439
    \u0441\u0432\u0435\u0442 \u043D\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u043E\u0440\u043E\u0434\u043D\u044B\u043C, \u0430 \u0441\u043E\u0441\u0442\u043E\u0438\u0442
    \u0438\u0437 \u043B\u0443\u0447\u0435\u0439 \u0441 \u0440\u0430\u0437\u043D\u043E\u0439
    **\u043F\u0440\u0435\u043B\u043E\u043C\u043B\u044F\u0435\u043C\u043E\u0441\u0442\u044C\u044E**,
    \u043A\u0430\u0436\u0434\u044B\u0439 \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u0435\u0442
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u043C\u0443
    \u0446\u0432\u0435\u0442\u0443. \u041F\u0440\u0438\u0437\u043C\u0430 \u043D\u0435
    \"\u043E\u043A\u0440\u0430\u0448\u0438\u0432\u0430\u0435\u0442\" \u0441\u0432\u0435\u0442,
    \u0430 \u043B\u0438\u0448\u044C \u0440\u0430\u0437\u043B\u0430\u0433\u0430\u0435\u0442
    \u0435\u0433\u043E \u043D\u0430 \u0441\u043E\u0441\u0442\u0430\u0432\u043D\u044B\u0435
    \u0447\u0430\u0441\u0442\u0438. *   **\u041E\u0434\u043D\u043E\u0440\u043E\u0434\u043D\u044B\u0439
    \u0438 \u043D\u0435\u043E\u0434\u043D\u043E\u0440\u043E\u0434\u043D\u044B\u0439
    \u0441\u0432\u0435\u0442**: \u041E\u043D \u043E\u0442\u043A\u0440\u044B\u043B,
    \u0447\u0442\u043E \u0446\u0432\u0435\u0442 \u2014 \u044D\u0442\u043E \u043D\u0435\u043E\u0442\u044A\u0435\u043C\u043B\u0435\u043C\u043E\u0435
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u0442\u0438\u043F\u0430 \u043B\u0443\u0447\u0435\u0439. \u041B\u0443\u0447 \u0441
    \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u044C\u044E
    \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u044F\u0435\u043C\u043E\u0441\u0442\u0438
    \u0432\u0441\u0435\u0433\u0434\u0430 \u0438\u043C\u0435\u0435\u0442 \u043E\u0434\u0438\u043D
    \u0438 \u0442\u043E\u0442 \u0436\u0435 \u0446\u0432\u0435\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C
    \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u043C \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u0435\u043C
    \u0438\u043B\u0438 \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u0435\u043C.
    *   **\u0421\u043C\u0435\u0448\u0435\u043D\u0438\u0435 \u0446\u0432\u0435\u0442\u043E\u0432**:
    \u041D\u044C\u044E\u0442\u043E\u043D \u0442\u0430\u043A\u0436\u0435 \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043E\u0431\u0440\u0430\u0442\u043D\u044B\u043C \u0441\u043C\u0435\u0448\u0435\u043D\u0438\u0435\u043C
    \u0432\u0441\u0435\u0445 \u0446\u0432\u0435\u0442\u043E\u0432 \u0441\u043F\u0435\u043A\u0442\u0440\u0430
    \u043C\u043E\u0436\u043D\u043E \u0441\u043D\u043E\u0432\u0430 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0431\u0435\u043B\u044B\u0439 \u0441\u0432\u0435\u0442. *   **\u0411\u0435\u0437\u0436\u0430\u043B\u043E\u0441\u0442\u043D\u043E\u0435
    \u0441\u0430\u043C\u043E\u043F\u043E\u0437\u043D\u0430\u043D\u0438\u0435**: \u0412
    \u0441\u0432\u043E\u0438\u0445 \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0430\u0445
    \u041D\u044C\u044E\u0442\u043E\u043D \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442
    \u0448\u043E\u043A\u0438\u0440\u0443\u044E\u0449\u0438\u0435 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u044B
    \u043F\u043E \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E \u0437\u0440\u0435\u043D\u0438\u044F,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043E\u043D \u043D\u0430\u0436\u0438\u043C\u0430\u043B
    \u043D\u0430 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0433\u043B\u0430\u0437 \u0442\u043E\u043D\u043A\u043E\u0439 \u0438\u0433\u043B\u043E\u0439
    (\u0431\u043E\u0434\u043A\u0438\u043D\u043E\u043C), \u0447\u0442\u043E\u0431\u044B
    \u0443\u0432\u0438\u0434\u0435\u0442\u044C, \u043A\u0430\u043A \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435 \u0438\u0441\u043A\u0430\u0436\u0430\u0435\u0442
    \u0446\u0432\u0435\u0442\u043E\u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u0435. 
    ### \U0001F9EA \u0422\u0430\u0439\u043D\u044B\u0439 \u043C\u0438\u0440: \u0410\u043B\u0445\u0438\u043C\u0438\u044F
    \u0438 \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044F  \u0412\u0430\u0436\u043D\u043E
    \u043F\u043E\u043D\u0438\u043C\u0430\u0442\u044C, \u0447\u0442\u043E \u0434\u043B\u044F
    \u0441\u0430\u043C\u043E\u0433\u043E \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u043D\u0435 \u0431\u044B\u043B\u043E \u0447\u0435\u0442\u043A\u043E\u0439 \u0433\u0440\u0430\u043D\u0438\u0446\u044B
    \u043C\u0435\u0436\u0434\u0443 \u0444\u0438\u0437\u0438\u043A\u043E\u0439, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u0438 \u0442\u0435\u043C, \u0447\u0442\u043E \u043C\u044B \u0441\u0435\u0433\u043E\u0434\u043D\u044F
    \u043D\u0430\u0437\u0432\u0430\u043B\u0438 \u0431\u044B \u044D\u0437\u043E\u0442\u0435\u0440\u0438\u043A\u043E\u0439.
    \u041E\u0433\u0440\u043E\u043C\u043D\u0430\u044F \u0447\u0430\u0441\u0442\u044C
    \u0435\u0433\u043E \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0435\u0439 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    **\u0430\u043B\u0445\u0438\u043C\u0438\u0438** \u0438 **\u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0438\u044E**. 
    *   **\u0410\u043B\u0445\u0438\u043C\u0438\u044F**: \u041E\u043D \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B
    \u0431\u0435\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0435 \u043E\u043F\u044B\u0442\u044B
    \u0441 \u043C\u0435\u0442\u0430\u043B\u043B\u0430\u043C\u0438, \u0438\u0441\u043A\u0430\u043B
    \"\u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0439 \u043A\u0430\u043C\u0435\u043D\u044C\"
    \u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u044B \u0442\u0440\u0430\u043D\u0441\u043C\u0443\u0442\u0430\u0446\u0438\u0438
    \u0432\u0435\u0449\u0435\u0441\u0442\u0432. *   **\u0411\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0438\u0435**:
    \u041D\u044C\u044E\u0442\u043E\u043D \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u0438\u0437\u0443\u0447\u0430\u043B \u0411\u0438\u0431\u043B\u0438\u044E, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u043A\u043D\u0438\u0433\u0443 \u043F\u0440\u043E\u0440\u043E\u043A\u0430 \u0414\u0430\u043D\u0438\u0438\u043B\u0430,
    \u043F\u044B\u0442\u0430\u044F\u0441\u044C \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u044C
    \u0434\u0430\u0442\u0443 \u043A\u043E\u043D\u0446\u0430 \u0441\u0432\u0435\u0442\u0430
    \u0438 \u043F\u043E\u043D\u044F\u0442\u044C \u0441\u043A\u0440\u044B\u0442\u044B\u0439
    \u0441\u043C\u044B\u0441\u043B \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0418\u0441\u0430\u0430\u043A\u0430 \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0433\u0435\u043D\u0438\u044F,
    \u0441\u043E\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E \u043F\u043E\u0436\u0435\u0440\u0442\u0432\u043E\u0432\u0430\u0432\u0448\u0435\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0438\u043C \u0442\u0435\u043F\u043B\u043E\u043C
    \u0440\u0430\u0434\u0438 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E\u0433\u043E
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044F. \u041E\u043D \u0431\u044B\u043B
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u043E\u044F\u043B\u0441\u044F \u0431\u043B\u0438\u0437\u043E\u0441\u0442\u0438,
    \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u044B
    (\u043D\u043E \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E \u0438\u0445
    \u043F\u0440\u043E\u0432\u043E\u0446\u0438\u0440\u043E\u0432\u0430\u043B) \u0438
    \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0434\u043D\u0435\u0439 \u0445\u0440\u0430\u043D\u0438\u043B
    \u0434\u0435\u0432\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C,
    \u0441\u0447\u0438\u0442\u0430\u044F \u043F\u043B\u043E\u0442\u0441\u043A\u0438\u0435
    \u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F \u043F\u043E\u043C\u0435\u0445\u043E\u0439
    \u0434\u043B\u044F \u0443\u043C\u0430.  \u041D\u0438\u0436\u0435 \u2014 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F
    \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044F \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u043E\u0433\u043E \u043F\u0443\u0442\u0438,
    \u043E\u0442 \u043A\u043E\u043B\u044B\u0431\u0435\u043B\u0438 \u0434\u043E \u043C\u043E\u0433\u0438\u043B\u044B,
    \u0441 \u0430\u043A\u0446\u0435\u043D\u0442\u043E\u043C \u043D\u0430 \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u0435\u0442\u0430\u043B\u0438 \u0438 \u0432\u0437\u0430\u0438\u043C\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F. 
    ---  ### \U0001F476 \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    (1642)  \u0418\u0441\u0430\u0430\u043A \u041D\u044C\u044E\u0442\u043E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    **25 \u0434\u0435\u043A\u0430\u0431\u0440\u044F 1642 \u0433\u043E\u0434\u0430**
    (\u043F\u043E \u044E\u043B\u0438\u0430\u043D\u0441\u043A\u043E\u043C\u0443 \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044E,
    \u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u0432\u0448\u0435\u043C\u0443
    \u0442\u043E\u0433\u0434\u0430 \u0432 \u0410\u043D\u0433\u043B\u0438\u0438) \u0432
    \u043F\u043E\u043C\u0435\u0441\u0442\u044C\u0435 \u0412\u0443\u043B\u0441\u0442\u043E\u0440\u043F,
    \u0433\u0440\u0430\u0444\u0441\u0442\u0432\u043E \u041B\u0438\u043D\u043A\u043E\u043B\u044C\u043D\u0448\u0438\u0440.
    \u042D\u0442\u043E\u0442 \u0434\u0435\u043D\u044C \u0431\u044B\u043B \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u043D
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0433\u043E:
    \u043E\u043D \u0441\u0447\u0438\u0442\u0430\u043B \u0441\u0435\u0431\u044F \xAB\u0440\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u0435\u043D\u0441\u043A\u0438\u043C
    \u0434\u0438\u0442\u0435\u043C\xBB, \u0447\u0442\u043E \u043F\u043E\u0437\u0436\u0435
    \u043F\u043E\u0434\u043F\u0438\u0442\u044B\u0432\u0430\u043B\u043E \u0435\u0433\u043E
    \u043C\u0435\u0441\u0441\u0438\u0430\u043D\u0441\u043A\u0438\u0435 \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F
    \u043E \u0431\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
    \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0438. 
    - **\u0413\u0435\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u043E\u043D**: \u041E\u043D \u0431\u044B\u043B \u043F\u043E\u0442\u043E\u043C\u043A\u043E\u043C
    \u0437\u0430\u0436\u0438\u0442\u043E\u0447\u043D\u044B\u0445, \u043D\u043E \u043D\u0435
    \u0437\u043D\u0430\u0442\u043D\u044B\u0445 \u0439\u043E\u043C\u0435\u043D\u043E\u0432
    (\u0441\u0432\u043E\u0431\u043E\u0434\u043D\u044B\u0445 \u043A\u0440\u0435\u0441\u0442\u044C\u044F\u043D).
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u0418\u0441\u0430\u0430\u043A \u041D\u044C\u044E\u0442\u043E\u043D-\u0441\u0442\u0430\u0440\u0448\u0438\u0439,
    \u0431\u044B\u043B \u043D\u0435\u0433\u0440\u0430\u043C\u043E\u0442\u043D\u044B\u043C,
    \u043D\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0444\u0435\u0440\u043C\u0435\u0440\u043E\u043C, \u0432\u043B\u0430\u0434\u0435\u0432\u0448\u0438\u043C
    \u043E\u0432\u0446\u0430\u043C\u0438 \u0438 \u0437\u0435\u043C\u043B\u0435\u0439. 
    - **\u041E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F**: \u041C\u0430\u043B\u044C\u0447\u0438\u043A
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u043F\u0440\u0435\u0436\u0434\u0435\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C
    \u0438 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043A\u0440\u043E\u0448\u0435\u0447\u043D\u044B\u043C,
    \u0447\u0442\u043E, \u043F\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435,
    \u043C\u043E\u0433 \u043F\u043E\u043C\u0435\u0441\u0442\u0438\u0442\u044C\u0441\u044F
    \u0432 \u043A\u0432\u0430\u0440\u0442\u043E\u0432\u0443\u044E \u043A\u0440\u0443\u0436\u043A\u0443
    (\u043E\u043A\u043E\u043B\u043E 1,1 \u043B\u0438\u0442\u0440\u0430). \u0414\u0432\u0435
    \u0442\u0435\u0442\u0443\u0448\u043A\u0438, \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u0432\u0448\u0438\u0435
    \u043F\u0440\u0438 \u0440\u043E\u0434\u0430\u0445, \u043F\u043E\u0441\u043B\u0430\u043B\u0438
    \u0437\u0430 \u043B\u0435\u043A\u0430\u0440\u0441\u0442\u0432\u0430\u043C\u0438,
    \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u044B\u0435, \u0447\u0442\u043E \u043E\u043D
    \u0443\u043C\u0440\u0435\u0442, \u043D\u043E \u043E\u043D \u0432\u044B\u0436\u0438\u043B.
    - **\u041A\u0440\u0435\u0449\u0435\u043D\u0438\u0435**: \u0415\u0433\u043E \u043A\u0440\u0435\u0441\u0442\u0438\u043B\u0438
    \u0432 \u043C\u0435\u0441\u0442\u043D\u043E\u0439 \u0446\u0435\u0440\u043A\u0432\u0438
    \u0421\u0432\u044F\u0442\u043E\u0433\u043E \u0422\u0440\u043E\u0438\u0446\u044B.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u043F\u043E\u0437\u0436\u0435,
    \u0441\u0442\u0430\u0432 \u0432\u0437\u0440\u043E\u0441\u043B\u044B\u043C, \u041D\u044C\u044E\u0442\u043E\u043D
    \u0431\u0443\u0434\u0435\u0442 \u044F\u0440\u043E\u0441\u0442\u043D\u043E \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u044C
    \u0434\u043E\u0433\u043C\u0430\u0442 \u043E \u0421\u0432\u044F\u0442\u043E\u0439
    \u0422\u0440\u043E\u0438\u0446\u0435, \u0441\u0447\u0438\u0442\u0430\u044F \u0435\u0433\u043E
    \u044F\u0437\u044B\u0447\u0435\u0441\u043A\u0438\u043C \u043D\u043E\u0432\u043E\u0432\u0432\u0435\u0434\u0435\u043D\u0438\u0435\u043C. 
    ---  ### \U0001F9D2 \u0422\u0440\u0430\u0432\u043C\u0430 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
    \u0438 \u0440\u0430\u0437\u0440\u044B\u0432 \u0441 \u043C\u0430\u0442\u0435\u0440\u044C\u044E
    (1645\u20131655)  \u041A\u043E\u0433\u0434\u0430 \u0418\u0441\u0430\u0430\u043A\u0443
    \u0431\u044B\u043B\u043E 3 \u0433\u043E\u0434\u0430, \u0435\u0433\u043E \u043C\u0430\u0442\u044C,
    \u0410\u043D\u043D\u0430 \u042D\u0439\u0441\u043A\u043E\u0443, \u0432\u044B\u0448\u043B\u0430
    \u0432\u0442\u043E\u0440\u043E\u0439 \u0440\u0430\u0437 \u0437\u0430\u043C\u0443\u0436
    \u0437\u0430 63-\u043B\u0435\u0442\u043D\u0435\u0433\u043E \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430
    \u0412\u0430\u0440\u043D\u0430\u0432\u0443 \u0421\u043C\u0438\u0442\u0430 (Barna-bas
    Smith). \u042D\u0442\u043E \u0431\u044B\u043B \u0431\u0440\u0430\u043A \u043F\u043E
    \u0440\u0430\u0441\u0447\u0435\u0442\u0443 \u0440\u0430\u0434\u0438 \u0434\u0435\u043D\u0435\u0433. 
    - **\u041F\u0440\u0435\u0434\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E**:
    \u041C\u0430\u043B\u044C\u0447\u0438\u043A\u0430 \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438
    \u043D\u0430 \u043F\u043E\u043F\u0435\u0447\u0435\u043D\u0438\u0438 \u0431\u0430\u0431\u0443\u0448\u043A\u0438
    \u041C\u0430\u0440\u0434\u0436\u0435\u0440\u0438 \u042D\u0439\u0441\u043A\u043E\u0443.
    \u041D\u044C\u044E\u0442\u043E\u043D \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0437\u0430\u043F\u043E\u043C\u043D\u0438\u043B \u043C\u043E\u043C\u0435\u043D\u0442,
    \u043A\u043E\u0433\u0434\u0430 \u043C\u0430\u0442\u044C \u0443\u0435\u0445\u0430\u043B\u0430
    \u0432 \u043A\u0430\u0440\u0435\u0442\u0435 \u0441\u043E \u0441\u0432\u043E\u0438\u043C
    \u043D\u043E\u0432\u044B\u043C \u043C\u0443\u0436\u0435\u043C. \u041E\u043D \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E
    \u043F\u043E\u043A\u043B\u044F\u043B\u0441\u044F \u043E\u0442\u043E\u043C\u0441\u0442\u0438\u0442\u044C
    \u043E\u0442\u0447\u0438\u043C\u0443. - **\u0414\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E**:
    \u0412 \u0441\u0432\u043E\u0435\u0439 \u0442\u0435\u0442\u0440\u0430\u0434\u0438
    \u0434\u043B\u044F \xAB\u0433\u0440\u0435\u0445\u043E\u0432\xBB (\u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u0432\u0435\u043B \u0432 \u044E\u043D\u043E\u0441\u0442\u0438),
    \u043F\u0443\u043D\u043A\u0442 \u211613 \u0433\u043B\u0430\u0441\u0438\u0442:
    *\xAB\u0423\u0433\u0440\u043E\u0436\u0430\u043B \u043E\u0442\u0446\u0443 \u0438
    \u043C\u0430\u0442\u0435\u0440\u0438 \u0421\u043C\u0438\u0442\u0443 \u0441\u0436\u0435\u0447\u044C
    \u0438\u0445 \u0438 \u0434\u043E\u043C \u043D\u0430\u0434 \u043D\u0438\u043C\u0438\xBB*. 
    - **\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u0440\u0438**:
    \u0412 1656 \u0433\u043E\u0434\u0443 \u0412\u0430\u0440\u043D\u0430\u0432\u0430
    \u0421\u043C\u0438\u0442 \u0443\u043C\u0435\u0440, \u0438 \u0410\u043D\u043D\u0430
    \u0432\u0435\u0440\u043D\u0443\u043B\u0430\u0441\u044C \u0432 \u0412\u0443\u043B\u0441\u0442\u043E\u0440\u043F
    \u0441 \u0442\u0440\u0435\u043C\u044F \u0434\u0435\u0442\u044C\u043C\u0438 \u043E\u0442
    \u0432\u0442\u043E\u0440\u043E\u0433\u043E \u0431\u0440\u0430\u043A\u0430 (\u0431\u0440\u0430\u0442\u044C\u044F\u043C\u0438
    \u0438 \u0441\u0435\u0441\u0442\u0440\u043E\u0439 \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u043F\u043E \u043C\u0430\u0442\u0435\u0440\u0438). \u041D\u044C\u044E\u0442\u043E\u043D,
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443 \u0431\u044B\u043B\u043E 14,
    \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B \u0441\u0432\u043E\u0434\u043D\u044B\u0445
    \u0431\u0440\u0430\u0442\u0430 \u0438 \u0441\u0435\u0441\u0442\u0440\u0443, \u0438
    \u044D\u0442\u043E \u043E\u0442\u0447\u0443\u0436\u0434\u0435\u043D\u0438\u0435
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C \u043D\u0430
    \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C. \u0410\u043D\u043D\u0430 \u0442\u0430\u043A
    \u0438 \u043D\u0435 \u0441\u043C\u043E\u0433\u043B\u0430 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u0441 \u0418\u0441\u0430\u0430\u043A\u043E\u043C \u044D\u043C\u043E\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u043A\u043E\u043D\u0442\u0430\u043A\u0442 \u2014 \u043E\u043D \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B
    \u0435\u0451 \u043A\u0430\u043A \u0447\u0443\u0436\u0430\u0447\u043A\u0443. 
    ---  ### \U0001F393 \u0423\u0447\u0451\u0431\u0430: \u041E\u0442 \u0441\u0430\u0431\u0441\u0430\u0439\u0437\u0435\u0440\u0430
    \u0434\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 (1661\u20131669) 
    **\u0428\u043A\u043E\u043B\u0430 \u0432 \u0413\u0440\u0430\u043D\u0442\u0435\u043C\u0435
    (1655\u20131661)** \u0416\u0438\u0432\u044F \u0443 \u0430\u043F\u0442\u0435\u043A\u0430\u0440\u044F
    \u041A\u043B\u0430\u0440\u043A\u0430, \u041D\u044C\u044E\u0442\u043E\u043D \u043D\u0430\u0447\u0430\u043B
    \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u0442\u044C \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u044B\u0439
    \u0442\u0430\u043B\u0430\u043D\u0442: \u043C\u0430\u0441\u0442\u0435\u0440\u0438\u043B
    \u0432\u0435\u0442\u0440\u044F\u043D\u044B\u0435 \u043C\u0435\u043B\u044C\u043D\u0438\u0446\u044B,
    \u0432\u043E\u0434\u044F\u043D\u044B\u0435 \u0447\u0430\u0441\u044B \u0438 \u0434\u0430\u0436\u0435
    \u043B\u0435\u0442\u0430\u044E\u0449\u0438\u0435 \u0444\u043E\u043D\u0430\u0440\u0438\u043A\u0438
    (\u0431\u0443\u043C\u0430\u0436\u043D\u044B\u0435 \u0437\u043C\u0435\u0438 \u0441
    \u043F\u043E\u0434\u0441\u0432\u0435\u0442\u043A\u043E\u0439). \u0423\u0447\u0438\u0442\u0435\u043B\u044F
    \u043E\u0442\u043C\u0435\u0447\u0430\u043B\u0438 \u0435\u0433\u043E \xAB\u0437\u043B\u043E\u0431\u043D\u0443\u044E
    \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0435\u043D\u043D\u043E\u0441\u0442\u044C\xBB.
    \u041E\u043D \u0431\u044B\u043B \u0437\u0430\u043C\u043A\u043D\u0443\u0442, \u0434\u0440\u0430\u0447\u043B\u0438\u0432,
    \u043D\u043E \u0440\u0430\u0437\u0433\u0440\u043E\u043C\u0438\u043B \u043C\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    \u0445\u0443\u043B\u0438\u0433\u0430\u043D\u0430 \u0432 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439
    \u0434\u0443\u044D\u043B\u0438, \u043F\u043E\u0441\u043B\u0435 \u0447\u0435\u0433\u043E
    \u0441\u0442\u0430\u043B \u043F\u0435\u0440\u0432\u044B\u043C \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C. 
    **\u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436, \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436
    (1661)** \u0412 18 \u043B\u0435\u0442 \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u043D\u043E
    \u043D\u0435 \u043A\u0430\u043A \u0434\u0432\u043E\u0440\u044F\u043D\u0438\u043D,
    \u0430 \u043A\u0430\u043A **\xAB\u0441\u0430\u0431\u0441\u0430\u0439\u0437\u0435\u0440\xBB
    (subsizar)** \u2014 \u0441\u0430\u043C\u044B\u0439 \u043D\u0438\u0437\u043A\u0438\u0439
    \u0441\u0442\u0430\u0442\u0443\u0441.   - *\u0411\u044B\u0442*: \u041E\u043D
    \u043F\u0440\u0438\u0441\u043B\u0443\u0436\u0438\u0432\u0430\u043B \u0431\u043E\u0433\u0430\u0442\u044B\u043C
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430\u043C: \u0447\u0438\u0441\u0442\u0438\u043B
    \u0438\u043C \u043E\u0431\u0443\u0432\u044C, \u0432\u044B\u043D\u043E\u0441\u0438\u043B
    \u043D\u043E\u0447\u043D\u044B\u0435 \u0433\u043E\u0440\u0448\u043A\u0438 \u0438
    \u043F\u0440\u0438\u0441\u043B\u0443\u0436\u0438\u0432\u0430\u043B \u0437\u0430
    \u0441\u0442\u043E\u043B\u043E\u043C, \u0447\u0442\u043E\u0431\u044B \u043E\u043F\u043B\u0430\u0442\u0438\u0442\u044C
    \u0441\u0432\u043E\u0451 \u043F\u0438\u0442\u0430\u043D\u0438\u0435. - *\u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440*:
    \u0421\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A\u0438 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \u043A\u0430\u043A \xAB\u0443\u0433\u0440\u044E\u043C\u043E\u0433\u043E
    \u0438 \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E\xBB,
    \u043E\u043D \u043D\u0435 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u043F\u043E\u043F\u043E\u0439\u043A\u0430\u0445, \u0430 \u0432 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u0440\u0438\u0441\u043E\u0432\u0430\u043B \u0443\u0433\u043B\u0435\u043C
    \u043D\u0430 \u0441\u0442\u0435\u043D\u0430\u0445 \u043A\u043E\u043C\u043D\u0430\u0442\u044B
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442\u044B \u0443\u0447\u0435\u043D\u044B\u0445
    \u0438 \u0434\u0435\u043C\u043E\u043D\u043E\u0432.  **\u041A\u0430\u0440\u044C\u0435\u0440\u043D\u044B\u0439
    \u0440\u044B\u0432\u043E\u043A (1667\u20131669)**:  \u041A\u043E\u0433\u0434\u0430
    \u0432 1667 \u0433\u043E\u0434\u0443 \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435
    \u043E\u0442\u043A\u0440\u044B\u043B\u0438\u0441\u044C \u043D\u043E\u0432\u044B\u0435
    \u0432\u0430\u043A\u0430\u043D\u0441\u0438\u0438, \u041D\u044C\u044E\u0442\u043E\u043D
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u043F\u0440\u043E\u0442\u0435\u043A\u0446\u0438\u0438
    \u0441\u0432\u043E\u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u0430
    **\u0418\u0441\u0430\u0430\u043A\u0430 \u0411\u0430\u0440\u0440\u043E\u0443**
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u043C\u043B\u0430\u0434\u0448\u0435\u0433\u043E \u0444\u0435\u043B\u043B\u043E\u0443
    (\u0447\u043B\u0435\u043D\u0430 \u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430).
    \u0410 \u0432 1669 \u0433\u043E\u0434\u0443 \u0411\u0430\u0440\u0440\u043E\u0443,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u0438\u0434\u0435\u043B \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0443\u0447\u0435\u043D\u0438\u043A\u0430, \u0434\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u043E
    \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u043E\u0442 \u0441\u0432\u043E\u0435\u0439
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0439 **\u041B\u0443\u043A\u0430\u0441\u043E\u0432\u0441\u043A\u043E\u0439
    \u043A\u0430\u0444\u0435\u0434\u0440\u044B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438**
    \u0432 \u043F\u043E\u043B\u044C\u0437\u0443 26-\u043B\u0435\u0442\u043D\u0435\u0433\u043E
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430. \u0411\u0430\u0440\u0440\u043E\u0443
    \u0441\u043A\u0430\u0437\u0430\u043B: *\xAB\u042F \u0443\u0441\u0442\u0443\u043F\u0430\u044E
    \u043C\u0435\u0441\u0442\u043E \u0442\u043E\u043C\u0443, \u043A\u0442\u043E \u0441\u0438\u043B\u044C\u043D\u0435\u0435
    \u043C\u0435\u043D\u044F\xBB*. \u042D\u0442\u043E \u0431\u044B\u043B \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0432 \u0436\u0438\u0437\u043D\u0438
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u043E\u043D \u0431\u044B\u043B \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0435
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u0435\u043D.  ---  ### \U0001F4BC
    \u0420\u0430\u0431\u043E\u0442\u0430: \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0438 \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A \u041C\u043E\u043D\u0435\u0442\u043D\u043E\u0433\u043E
    \u0434\u0432\u043E\u0440\u0430  **\u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 (1669\u20131696)** \u041E\u043A\u043E\u043B\u043E
    30 \u043B\u0435\u0442 \u041D\u044C\u044E\u0442\u043E\u043D \u0447\u0438\u0442\u0430\u043B
    \u043B\u0435\u043A\u0446\u0438\u0438 \u043F\u043E \u043E\u043F\u0442\u0438\u043A\u0435
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u043D\u043E
    \u0435\u0433\u043E \u043B\u0435\u043A\u0446\u0438\u0438 \u0431\u044B\u043B\u0438
    \u0443\u0436\u0430\u0441\u043D\u043E \u0441\u043A\u0443\u0447\u043D\u044B\u043C\u0438.
    \u0421\u0442\u0443\u0434\u0435\u043D\u0442\u044B \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u043B\u0438
    \u0435\u0433\u043E, \u0438 \u0447\u0430\u0441\u0442\u043E \u043E\u043D \u0447\u0438\u0442\u0430\u043B
    \u043F\u0435\u0440\u0435\u0434 \u043F\u0443\u0441\u0442\u044B\u043C\u0438 \u0441\u043A\u0430\u043C\u044C\u044F\u043C\u0438.
    \u042D\u0442\u043E \u0435\u0433\u043E \u043D\u0435 \u0440\u0430\u0441\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u043B\u043E
    \u2014 \u043E\u043D \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0443\u0448\u0435\u043B
    \u0432 \u0441\u0432\u043E\u0438 \u043B\u0438\u0447\u043D\u044B\u0435 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F. 
    **\u0420\u0430\u0431\u043E\u0442\u0430 \u043D\u0430 \u041C\u043E\u043D\u0435\u0442\u043D\u043E\u043C
    \u0434\u0432\u043E\u0440\u0435 (\u0441 1696)** \u042D\u0442\u043E \u0431\u044B\u043B
    \u043A\u0440\u0443\u0442\u043E\u0439 \u043F\u043E\u0432\u043E\u0440\u043E\u0442.
    \u0412 1696 \u0433\u043E\u0434\u0443 \u043B\u043E\u0440\u0434 \u0413\u0430\u043B\u0438\u0444\u0430\u043A\u0441,
    \u0434\u0440\u0443\u0433 \u041D\u044C\u044E\u0442\u043E\u043D\u0430, \u0434\u043E\u0431\u0438\u043B\u0441\u044F
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    **\u0441\u043C\u043E\u0442\u0440\u0438\u0442\u0435\u043B\u0435\u043C \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043C\u043E\u043D\u0435\u0442\u043D\u043E\u0433\u043E \u0434\u0432\u043E\u0440\u0430**
    (Warden of the Mint).   - *\u0421\u0443\u0442\u044C \u0440\u0430\u0431\u043E\u0442\u044B*:
    \u0424\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E \u2014 \u043D\u0430\u0434\u0437\u043E\u0440
    \u0437\u0430 \u043F\u0435\u0440\u0435\u0447\u0435\u043A\u0430\u043D\u043A\u043E\u0439
    \u043C\u043E\u043D\u0435\u0442\u044B, \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u2014 \u043E\u0445\u043E\u0442\u0430 \u043D\u0430 \u0444\u0430\u043B\u044C\u0448\u0438\u0432\u043E\u043C\u043E\u043D\u0435\u0442\u0447\u0438\u043A\u043E\u0432. 
    - *\u0416\u0435\u0441\u0442\u043E\u043A\u043E\u0441\u0442\u044C*: \u041D\u044C\u044E\u0442\u043E\u043D
    \u043F\u043E\u0434\u043E\u0448\u0435\u043B \u043A \u044D\u0442\u043E\u043C\u0443
    \u0441 \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u043F\u0435\u0434\u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u044C\u044E.
    \u041E\u043D \u043B\u0438\u0447\u043D\u043E \u0434\u043E\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u043B
    \u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043D\u0438\u043A\u043E\u0432, \u0432\u043D\u0435\u0434\u0440\u044F\u043B
    \u0430\u0433\u0435\u043D\u0442\u043E\u0432 \u0432 \u043B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0435
    \u043F\u043E\u0434\u043F\u043E\u043B\u044C\u0435 \u0438 \u0441\u043E\u0431\u0438\u0440\u0430\u043B
    \u0434\u043E\u0441\u044C\u0435. \u041E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u043D\u0430 \u0432\u0438\u0441\u0435\u043B\u0438\u0446\u0443 \u0431\u043E\u043B\u0435\u0435
    20 \u0447\u0435\u043B\u043E\u0432\u0435\u043A. \u0412 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u043E\u043D \u043B\u0438\u0447\u043D\u043E \u0434\u043E\u0431\u0438\u043B\u0441\u044F
    \u043A\u0430\u0437\u043D\u0438 \u0441\u0430\u043C\u043E\u0433\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    \u0444\u0430\u043B\u044C\u0448\u0438\u0432\u043E\u043C\u043E\u043D\u0435\u0442\u0447\u0438\u043A\u0430
    \u0410\u0439\u0437\u0435\u043A\u0430 (\u0423\u0438\u043B\u044C\u044F\u043C\u0430)
    \u0427\u0430\u043B\u043E\u043D\u043E\u0440\u0430, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u044E\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u043B\u043E\u0432\u0443\u0448\u043A\u0438. 
    - *\u0414\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C*: \u0412 1699 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441\u0442\u0430\u043B **\u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u041C\u043E\u043D\u0435\u0442\u043D\u043E\u0433\u043E \u0434\u0432\u043E\u0440\u0430**
    (Master of the Mint) \u2014 \u044D\u0442\u043E \u0434\u0430\u0432\u0430\u043B\u043E
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u0438\u0435
    (\u043E\u043A\u043E\u043B\u043E 2000 \u0444\u0443\u043D\u0442\u043E\u0432 \u0432
    \u0433\u043E\u0434), \u0438 \u041D\u044C\u044E\u0442\u043E\u043D \u0441\u0442\u0430\u043B
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u043D\u044B\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C.
    \u041D\u0430 \u044D\u0442\u043E\u0439 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438
    \u043E\u043D \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u0432\u0435\u043B
    \u0437\u043E\u043B\u043E\u0442\u043E\u0439 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442
    \u0432 \u0410\u043D\u0433\u043B\u0438\u0438.  ---  ### \U0001F621 \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438:
    \u041F\u0430\u0440\u0430\u043D\u043E\u0439\u044F \u0438 \u0432\u043E\u0439\u043D\u044B 
    \u041D\u044C\u044E\u0442\u043E\u043D \u0431\u044B\u043B \u043D\u0435\u0432\u044B\u043D\u043E\u0441\u0438\u043C
    \u0432 \u043E\u0431\u0449\u0435\u043D\u0438\u0438. \u041E\u043D \u0441\u0442\u0440\u0430\u0434\u0430\u043B
    \u043C\u0430\u043D\u0438\u0435\u0439 \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F:
    \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C, \u0447\u0442\u043E \u0432\u0441\u0435
    \u0432\u043E\u043A\u0440\u0443\u0433 \u0445\u043E\u0442\u044F\u0442 \u0443\u043A\u0440\u0430\u0441\u0442\u044C
    \u0435\u0433\u043E \u0438\u0434\u0435\u0438.  **\u0412\u043E\u0439\u043D\u0430
    \u0441 \u0420\u043E\u0431\u0435\u0440\u0442\u043E\u043C \u0413\u0443\u043A\u043E\u043C
    (1672\u20131703)** \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u0441\u0430\u043C\u0430\u044F
    \u044F\u0440\u043E\u0441\u0442\u043D\u0430\u044F \u0431\u0438\u0442\u0432\u0430.
    \u0413\u0443\u043A \u0431\u044B\u043B \u043A\u0443\u0440\u0430\u0442\u043E\u0440\u043E\u043C
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u043E\u0432
    \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430
    \u0438 \u0438\u043C\u0435\u043B \u0430\u0432\u0442\u043E\u0440\u0438\u0442\u0435\u0442. 
    - *\u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u043E \u0441\u0432\u0435\u0442\u0435*:
    \u041A\u043E\u0433\u0434\u0430 \u041D\u044C\u044E\u0442\u043E\u043D \u0432 1672
    \u0433\u043E\u0434\u0443 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B
    \u0441\u0432\u043E\u044E \u0442\u0435\u043E\u0440\u0438\u044E \u0446\u0432\u0435\u0442\u0430,
    \u0413\u0443\u043A \u0432\u044B\u0441\u043C\u0435\u044F\u043B \u0435\u0451 \u0438
    \u0437\u0430\u044F\u0432\u0438\u043B, \u0447\u0442\u043E \u0441\u0430\u043C \u043F\u0440\u0438\u0448\u0435\u043B
    \u043A \u0442\u0435\u043C \u0436\u0435 \u0432\u044B\u0432\u043E\u0434\u0430\u043C
    \u0440\u0430\u043D\u044C\u0448\u0435.  - *\u041B\u0438\u0447\u043D\u0430\u044F
    \u043D\u0435\u043F\u0440\u0438\u044F\u0437\u043D\u044C*: \u0413\u0443\u043A \u0431\u044B\u043B
    \u0433\u043E\u0440\u0431\u0430\u0442\u044B\u043C \u0438 \u043D\u0435\u0432\u044B\u0441\u043E\u043A\u0438\u043C,
    \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u0440\u0435\u0437\u0438\u0440\u0430\u043B
    \u0435\u0433\u043E \u0437\u0430 \u0432\u043D\u0435\u0448\u043D\u043E\u0441\u0442\u044C.
    \u041F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E \u043A\u0430\u043A \u0413\u0443\u043A
    \u043E\u0431\u0432\u0438\u043D\u0438\u043B \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u0432 \u043F\u043B\u0430\u0433\u0438\u0430\u0442\u0435 \u0437\u0430\u043A\u043E\u043D\u0430
    \u043E\u0431\u0440\u0430\u0442\u043D\u044B\u0445 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432
    (\u0447\u0442\u043E \u0431\u044B\u043B\u043E \u043E\u0442\u0447\u0430\u0441\u0442\u0438
    \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E, \u0442\u0430\u043A
    \u043A\u0430\u043A \u0413\u0443\u043A \u0432\u044B\u0441\u043A\u0430\u0437\u0430\u043B
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443 \u0440\u0430\u043D\u044C\u0448\u0435),
    \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u0440\u0438\u0448\u0435\u043B \u0432
    \u044F\u0440\u043E\u0441\u0442\u044C \u0438 \u0443\u0433\u0440\u043E\u0436\u0430\u043B
    \u0441\u043E\u0432\u0441\u0435\u043C \u0443\u0439\u0442\u0438 \u0438\u0437 \u043D\u0430\u0443\u043A\u0438.
    \u041E\u043D \u0432\u044B\u0447\u0435\u0440\u043A\u043D\u0443\u043B \u0432\u0441\u0435
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F \u0413\u0443\u043A\u0430
    \u0438\u0437 \u0441\u0432\u043E\u0438\u0445 \xAB\u041D\u0430\u0447\u0430\u043B\xBB.
    - *\u0417\u043B\u043E\u0440\u0430\u0434\u0441\u0442\u0432\u043E*: \u041A\u043E\u0433\u0434\u0430
    \u0432 1703 \u0433\u043E\u0434\u0443 \u0413\u0443\u043A \u0443\u043C\u0435\u0440,
    \u041D\u044C\u044E\u0442\u043E\u043D, \u0441\u0442\u0430\u0432 \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430,
    \u043F\u0440\u0438\u043A\u0430\u0437\u0430\u043B \u0443\u0431\u0440\u0430\u0442\u044C
    \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439 \u043F\u0440\u0438\u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0439
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442 \u0413\u0443\u043A\u0430 \u0438\u0437
    \u0437\u0430\u043B\u0430 \u0437\u0430\u0441\u0435\u0434\u0430\u043D\u0438\u0439.
    \u041F\u043E\u0440\u0442\u0440\u0435\u0442 \u0431\u0435\u0441\u0441\u043B\u0435\u0434\u043D\u043E
    \u0438\u0441\u0447\u0435\u0437, \u0438 \u043C\u044B \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440 \u043D\u0435 \u0437\u043D\u0430\u0435\u043C, \u043A\u0430\u043A
    \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u043B \u0413\u0443\u043A.  **\u0412\u043E\u0439\u043D\u0430
    \u0441 \u0413\u043E\u0442\u0444\u0440\u0438\u0434\u043E\u043C \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0435\u043C
    (\u0441 1699 \u0438 \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438)** \u0421\u043F\u043E\u0440
    \u043E \u0442\u043E\u043C, \u043A\u0442\u043E \u043F\u0435\u0440\u0432\u044B\u043C
    \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435,
    \u043F\u0435\u0440\u0435\u0440\u043E\u0441 \u0432 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u043A\u0430\u043D\u0434\u0430\u043B \u043C\u0435\u0436\u0434\u0443 \u0410\u043D\u0433\u043B\u0438\u0435\u0439
    \u0438 \u0415\u0432\u0440\u043E\u043F\u043E\u0439. \u041D\u044C\u044E\u0442\u043E\u043D
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u0443\u043A\u0440\u0430\u043B \u0435\u0433\u043E \u0438\u0434\u0435\u0438, \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u0432
    \u0435\u0433\u043E \u0447\u0435\u0440\u043D\u043E\u0432\u0438\u043A\u0438 \u0432
    1676 \u0433\u043E\u0434\u0443.  - *\u0413\u0440\u044F\u0437\u043D\u044B\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B*: \u0411\u0443\u0434\u0443\u0447\u0438 \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430,
    \u041D\u044C\u044E\u0442\u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \xAB\u043A\u043E\u043C\u0438\u0442\u0435\u0442
    \u043F\u043E \u0440\u0430\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044E\xBB,
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u044B\u0435
    \u0440\u0435\u0446\u0435\u043D\u0437\u0438\u0438 \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u044B
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430 \u0438 \u0441\u0430\u043C \u0436\u0435
    \u0438\u0445 \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u043B \u043A\u0430\u043A
    \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430. \u041B\u0435\u0439\u0431\u043D\u0438\u0446
    \u0443\u043C\u0435\u0440 \u0432 1716 \u0433\u043E\u0434\u0443 \u0432 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438,
    \u043F\u043E\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C \u0432 \u044D\u0442\u043E\u0439
    \u0442\u0440\u0430\u0432\u043B\u0435.  **\u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0434\u0440\u0443\u0433 \u2014 \u042D\u0434\u043C\u0443\u043D\u0434 \u0413\u0430\u043B\u043B\u0435\u0439**
    \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C, \u0432 \u0447\u0435\u0441\u0442\u044C
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043D\u0430\u0437\u0432\u0430\u043B\u0438
    \u043A\u043E\u043C\u0435\u0442\u0443, \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0445, \u043A\u043E\u0433\u043E
    \u041D\u044C\u044E\u0442\u043E\u043D \u0443\u0432\u0430\u0436\u0430\u043B. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0413\u0430\u043B\u043B\u0435\u0439 \u0443\u0433\u043E\u0432\u043E\u0440\u0438\u043B
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C
    \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB \u0438 \u0441\u0430\u043C \u043E\u043F\u043B\u0430\u0442\u0438\u043B
    \u0438\u0445 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044E \u0438\u0437
    \u0441\u0432\u043E\u0435\u0433\u043E \u043A\u0430\u0440\u043C\u0430\u043D\u0430,
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u0443 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u043D\u0435 \u0431\u044B\u043B\u043E
    \u0434\u0435\u043D\u0435\u0433.  ---  ### \U0001F9E0 \u041F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043A\u0440\u0438\u0437\u0438\u0441 (1693)  \u041D\u0430 \u043F\u0438\u043A\u0435
    \u0441\u043B\u0430\u0432\u044B \u0443 \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u0441\u043B\u0443\u0447\u0438\u043B\u0441\u044F \u043D\u0435\u0440\u0432\u043D\u044B\u0439
    \u0441\u0440\u044B\u0432. \u041E\u043D \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B
    \u0441\u043F\u0430\u0442\u044C, \u0443 \u043D\u0435\u0433\u043E \u043D\u0430\u0447\u0430\u043B\u0438\u0441\u044C
    \u0433\u0430\u043B\u043B\u044E\u0446\u0438\u043D\u0430\u0446\u0438\u0438.  -
    *\u0421\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430*:
    \u041E\u043D \u043F\u0438\u0441\u0430\u043B \u0431\u0435\u0437\u0443\u043C\u043D\u044B\u0435
    \u043F\u0438\u0441\u044C\u043C\u0430 \u0434\u0440\u0443\u0437\u044C\u044F\u043C:
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0443 \u041B\u043E\u043A\u043A\u0443
    \u043E\u043D \u043E\u0431\u0432\u0438\u043D\u0438\u043B \u0432 \u0442\u043E\u043C,
    \u0447\u0442\u043E \u0442\u043E\u0442 \xAB\u0445\u043E\u0442\u0435\u043B \u0437\u0430\u043F\u0443\u0442\u0430\u0442\u044C
    \u0435\u0433\u043E \u0441 \u0436\u0435\u043D\u0449\u0438\u043D\u0430\u043C\u0438\xBB;
    \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u044E \u041F\u0435\u043F\u0438\u0441\u0443
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B, \u0447\u0442\u043E \u041F\u0435\u043F\u0438\u0441
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \xAB\u0437\u0430\u0433\u043E\u0432\u043E\u0440\u0449\u0438\u043A\u0438\xBB
    \u043F\u044B\u0442\u0430\u044E\u0442\u0441\u044F \u0435\u0433\u043E \u0443\u0431\u0438\u0442\u044C. 
    - *\u041F\u0440\u0438\u0447\u0438\u043D\u044B*: \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u044E\u0442 \u044D\u0442\u043E \u0441
    \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C \u0440\u0442\u0443\u0442\u044C\u044E
    (\u0438\u0437-\u0437\u0430 \u0430\u043B\u0445\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u043F\u044B\u0442\u043E\u0432) \u0438 \u0441 \u0432\u044B\u0433\u043E\u0440\u0430\u043D\u0438\u0435\u043C
    \u043E\u0442 30-\u043B\u0435\u0442\u043D\u0435\u0433\u043E \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0435\u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u0438\u044F. 
    - *\u0412\u044B\u0445\u043E\u0434*: \u041E\u043D \u0432\u044B\u0436\u0438\u043B.
    \u0412\u044B\u0437\u0434\u043E\u0440\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E, \u043A\u043E\u0433\u0434\u0430
    \u043E\u043D \u0441\u043C\u0435\u043D\u0438\u043B \u043E\u0431\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0443
    \u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u041B\u043E\u043D\u0434\u043E\u043D
    \u043D\u0430 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0432 \u041C\u043E\u043D\u0435\u0442\u043D\u043E\u043C
    \u0434\u0432\u043E\u0440\u0435 \u2014 \u0440\u0443\u0442\u0438\u043D\u043D\u0430\u044F
    \u0431\u044E\u0440\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0443\u0441\u043F\u043E\u043A\u043E\u0438\u043B\u0430
    \u0435\u0433\u043E \u0431\u043E\u043B\u044C\u043D\u043E\u0439 \u0440\u0430\u0437\u0443\u043C. 
    ---  ### \U0001F494 \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C:
    \u041E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u043E \u043A\u0430\u043A
    \u0432\u044B\u0431\u043E\u0440  \u041D\u044C\u044E\u0442\u043E\u043D \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0431\u044B\u043B \u0436\u0435\u043D\u0430\u0442 \u0438, \u043F\u043E
    \u0432\u0441\u0435\u043C \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0434\u0430\u043D\u043D\u044B\u043C, \u043D\u0435 \u0438\u043C\u0435\u043B \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0432\u044F\u0437\u0435\u0439 \u043D\u0438 \u0441 \u0436\u0435\u043D\u0449\u0438\u043D\u0430\u043C\u0438,
    \u043D\u0438 \u0441 \u043C\u0443\u0436\u0447\u0438\u043D\u0430\u043C\u0438. 
    - *\u0414\u0440\u0443\u0436\u0431\u0430 \u0441 \u0424\u0430\u0442\u0438\u043E
    \u0434\u0435 \u0414\u044E\u0439\u0435*: \u0412 1690-\u0445 \u0433\u043E\u0434\u0430\u0445
    \u0443 \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u0430 \u044D\u043C\u043E\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430\u044F,
    \u043F\u043E\u0447\u0442\u0438 \u0438\u0441\u0442\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u044C
    \u043A \u043C\u043E\u043B\u043E\u0434\u043E\u043C\u0443 \u0448\u0432\u0435\u0439\u0446\u0430\u0440\u0441\u043A\u043E\u043C\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u041D\u0438\u043A\u043E\u043B\u044F
    \u0424\u0430\u0442\u0438\u043E \u0434\u0435 \u0414\u044E\u0439\u0435 (\u0435\u043C\u0443
    \u0431\u044B\u043B\u043E 24, \u041D\u044C\u044E\u0442\u043E\u043D\u0443 \u2014
    50). \u041E\u043D\u0438 \u0436\u0438\u043B\u0438 \u0432 \u043E\u0434\u043D\u043E\u0439
    \u043A\u043E\u043C\u043D\u0430\u0442\u0435, \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B\u0438
    \u0434\u043D\u0438 \u0437\u0430 \u0430\u043B\u0445\u0438\u043C\u0438\u0435\u0439.
    \u0424\u0430\u0442\u0438\u043E \u0441\u043F\u0430\u0441 \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u043E\u0442 \u0431\u0435\u0441\u0441\u043E\u043D\u043D\u0438\u0446\u044B, \u0447\u0438\u0442\u0430\u044F
    \u0435\u043C\u0443 \u0432\u0441\u043B\u0443\u0445 \u043F\u043E \u043D\u043E\u0447\u0430\u043C.
    \u041D\u043E \u043A\u043E\u0433\u0434\u0430 \u0424\u0430\u0442\u0438\u043E \u0432\u043D\u0435\u0437\u0430\u043F\u043D\u043E
    \u0443\u0435\u0445\u0430\u043B, \u041D\u044C\u044E\u0442\u043E\u043D \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u044F\u043B
    \u044D\u0442\u043E \u043A\u0430\u043A \u043F\u0440\u0435\u0434\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E.
    \u041F\u043E\u0437\u0436\u0435 \u0424\u0430\u0442\u0438\u043E \u0431\u044B\u043B
    \u043E\u0431\u0432\u0438\u043D\u0435\u043D \u0432 \u0435\u0440\u0435\u0441\u0438
    \u0438 \u0431\u0435\u0436\u0430\u043B \u0438\u0437 \u0410\u043D\u0433\u043B\u0438\u0438.
    \u042D\u0442\u0430 \u0434\u0443\u0448\u0435\u0432\u043D\u0430\u044F \u043F\u043E\u0442\u0435\u0440\u044F
    \u0443\u0441\u0443\u0433\u0443\u0431\u0438\u043B\u0430 \u0435\u0433\u043E \u043A\u0440\u0438\u0437\u0438\u0441
    1693 \u0433\u043E\u0434\u0430. - *\u0422\u0435\u0442\u044F \u0438 \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u0446\u0430*:
    \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439 \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D \u043B\u044E\u0431\u0438\u043B,
    \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u0446\u0430
    \u041A\u044D\u0442\u0440\u0438\u043D \u0411\u0430\u0440\u0442\u043E\u043D (\u0434\u043E\u0447\u044C
    \u0435\u0433\u043E \u0441\u0432\u043E\u0434\u043D\u043E\u0439 \u0441\u0435\u0441\u0442\u0440\u044B).
    \u041E\u043D\u0430 \u0436\u0438\u043B\u0430 \u0432 \u0435\u0433\u043E \u043B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u043C
    \u0434\u043E\u043C\u0435 \u0438 \u0431\u044B\u043B\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439
    \u043A\u0440\u0430\u0441\u0430\u0432\u0438\u0446\u0435\u0439. \u0412 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435
    \u0445\u043E\u0434\u0438\u043B\u0438 \u0441\u043B\u0443\u0445\u0438, \u0447\u0442\u043E
    \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043B\u044E\u0431\u043E\u0432\u043D\u0438\u0446\u0435\u0439
    \u043B\u043E\u0440\u0434\u0430 \u0413\u0430\u043B\u0438\u0444\u0430\u043A\u0441\u0430,
    \u043D\u043E \u041D\u044C\u044E\u0442\u043E\u043D \u0437\u0430\u043A\u0440\u044B\u0432\u0430\u043B
    \u043D\u0430 \u044D\u0442\u043E \u0433\u043B\u0430\u0437\u0430, \u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443
    \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u0451 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0430\u043B
    \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u043E\u0432.  ---  ### \u26B0\uFE0F
    \u0421\u043C\u0435\u0440\u0442\u044C \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B (1725\u20131727)  \u0412 1725 \u0433\u043E\u0434\u0443
    \u0443 \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u043D\u0430\u0447\u0430\u043B\u0438\u0441\u044C
    \u0441\u0438\u043B\u044C\u043D\u044B\u0435 \u0431\u043E\u043B\u0438 \u043E\u0442
    \u043C\u043E\u0447\u0435\u043A\u0430\u043C\u0435\u043D\u043D\u043E\u0439 \u0431\u043E\u043B\u0435\u0437\u043D\u0438
    (\u043A\u0430\u043C\u043D\u0438 \u0432 \u043F\u043E\u0447\u043A\u0430\u0445).
    \u041E\u043D \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B \u0435\u0441\u0442\u044C
    \u0442\u0432\u0435\u0440\u0434\u0443\u044E \u043F\u0438\u0449\u0443.  - **\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0434\u043D\u0438**: \u041E\u043D \u0443\u043C\u0435\u0440 **20 \u043C\u0430\u0440\u0442\u0430
    1727 \u0433\u043E\u0434\u0430** (\u043F\u043E \u0441\u0442\u0430\u0440\u043E\u043C\u0443
    \u0441\u0442\u0438\u043B\u044E) \u0432 \u0441\u0432\u043E\u0435\u043C \u0434\u043E\u043C\u0435
    \u0432 \u041A\u0435\u043D\u0441\u0438\u043D\u0433\u0442\u043E\u043D\u0435 \u043D\u0430
    \u0440\u0443\u043A\u0430\u0445 \u0443 \u0441\u0432\u043E\u0435\u0439 \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u0446\u044B
    \u041A\u044D\u0442\u0440\u0438\u043D \u0438 \u0432\u0440\u0430\u0447\u0430. \u041F\u043E
    \u0441\u043B\u043E\u0432\u0430\u043C \u043E\u0447\u0435\u0432\u0438\u0434\u0446\u0435\u0432,
    \u043F\u0435\u0440\u0435\u0434 \u0441\u043C\u0435\u0440\u0442\u044C\u044E \u043E\u043D
    \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u043F\u0440\u0438\u043D\u044F\u0442\u044C
    \u0441\u0432\u044F\u0442\u043E\u0435 \u043F\u0440\u0438\u0447\u0430\u0441\u0442\u0438\u0435
    \u043E\u0442 \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430 (\u0447\u0442\u043E
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442 \u0435\u0433\u043E
    \u0430\u043D\u0442\u0438\u0442\u0440\u0438\u043D\u0438\u0442\u0430\u0440\u043D\u044B\u0435
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B), \u043D\u043E \u0442\u0435\u043B\u043E
    \u0431\u044B\u043B\u043E \u0432\u044B\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043E
    \u0441 \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u043F\u043E\u043C\u043F\u043E\u0439.
    - **\u041F\u043E\u0445\u043E\u0440\u043E\u043D\u044B**: \u0412\u043F\u0435\u0440\u0432\u044B\u0435
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u0410\u043D\u0433\u043B\u0438\u0438
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0438\u043B\u0438
    \u0432 **\u0412\u0435\u0441\u0442\u043C\u0438\u043D\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u043C
    \u0430\u0431\u0431\u0430\u0442\u0441\u0442\u0432\u0435** \u0441 \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    \u043F\u043E\u0447\u0435\u0441\u0442\u044F\u043C\u0438. \u0413\u0440\u043E\u0431
    \u043D\u0435\u0441\u043B\u0438 \u043B\u043E\u0440\u0434\u044B-\u043A\u0430\u043D\u0446\u043B\u0435\u0440
    \u0438 \u0433\u0435\u0440\u0446\u043E\u0433\u0438. \u0415\u0433\u043E \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u044F
    \u0433\u043B\u0430\u0441\u0438\u0442: *\xAB\u0414\u0430 \u0440\u0430\u0434\u0443\u044E\u0442\u0441\u044F
    \u0441\u043C\u0435\u0440\u0442\u043D\u044B\u0435, \u0447\u0442\u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E
    \u0442\u0430\u043A\u043E\u0435 \u0443\u043A\u0440\u0430\u0448\u0435\u043D\u0438\u0435
    \u0440\u043E\u0434\u0430 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E\xBB*.
    - **\u0421\u0443\u0434\u044C\u0431\u0430 \u0442\u0435\u043B\u0430**: \u0412 1731
    \u0433\u043E\u0434\u0443, \u0447\u0435\u0440\u0435\u0437 4 \u0433\u043E\u0434\u0430
    \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438, \u0435\u0433\u043E
    \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u0446\u0430 \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0430\u0441\u044C
    \u043E\u0442\u043A\u0440\u044B\u0442\u044C \u0433\u0440\u043E\u0431, \u043D\u043E
    \u0442\u0435\u043B\u043E \u0443\u0436\u0435 \u0440\u0430\u0437\u043B\u043E\u0436\u0438\u043B\u043E\u0441\u044C.
    \u0421\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u0440\u044F\u0434\u044C \u0440\u044B\u0436\u0435\u0432\u0430\u0442\u044B\u0445
    \u0432\u043E\u043B\u043E\u0441, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u0437\u0436\u0435
    \u0431\u044B\u043B\u0430 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0430
    \u043D\u0430 \u043F\u0440\u0435\u0434\u043C\u0435\u0442 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u044F
    \u0440\u0442\u0443\u0442\u0438 (\u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u043E). 
    **\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441 \u041D\u044C\u044E\u0442\u043E\u043D\u0430**:
    \u041E\u043D \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C \u0438\u0441\u043A\u0430\u043B
    \u0411\u043E\u0433\u0430 \u0447\u0435\u0440\u0435\u0437 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u043D\u043E \u043F\u0440\u043E\u0436\u0438\u043B \u0436\u0438\u0437\u043D\u044C,
    \u043F\u043E\u043B\u043D\u0443\u044E \u043D\u0435\u043D\u0430\u0432\u0438\u0441\u0442\u0438,
    \u0441\u0442\u0440\u0430\u0445\u0430 \u0438 \u0445\u043E\u043B\u043E\u0434\u043D\u043E\u0433\u043E
    \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u0430. \u041E\u043D
    \u0441\u043E\u0437\u0434\u0430\u043B \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443
    \u043D\u0435\u0431\u0435\u0441, \u043D\u043E \u043D\u0435 \u0441\u043C\u043E\u0433
    \u043D\u0430\u043B\u0430\u0434\u0438\u0442\u044C \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439 \u0434\u0443\u0448\u0438."
  personalLifeEn: 
  shortBioRu: "\u0418\u0441\u0430\u0430\u043A \u041D\u044C\u044E\u0442\u043E\u043D
    \u2014 \u043E\u0434\u043D\u0430 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0438 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u044B\u0445
    \u0444\u0438\u0433\u0443\u0440 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430\u0443\u043A\u0438. \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C
    \u0431\u044B\u043B\u0430 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0443\u0442\u0435\u043C
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E,
    \u043D\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445
    \u043B\u0438\u0447\u043D\u044B\u0445 \u0442\u0440\u0430\u0432\u043C, \u043E\u0434\u0435\u0440\u0436\u0438\u043C\u043E\u0441\u0442\u0438
    \u0442\u0430\u0439\u043D\u044B\u043C\u0438 \u0437\u043D\u0430\u043D\u0438\u044F\u043C\u0438
    \u0438 \u043D\u0435\u043F\u0440\u0435\u043A\u043B\u043E\u043D\u043D\u043E\u0439
    \u0431\u043E\u0440\u044C\u0431\u044B \u0437\u0430 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435. 
    ### \u23F3 \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u044E\u043D\u043E\u0441\u0442\u044C:
    \u0422\u0440\u0430\u0432\u043C\u0430 \u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0430  \u0411\u0443\u0434\u0443\u0449\u0438\u0439
    \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u0443\u0447\u0435\u043D\u044B\u0439
    \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u043D\u0430 \u0441\u0432\u0435\u0442
    \u0432 \u043A\u0430\u043D\u0443\u043D \u0420\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u0430
    1642 \u0433\u043E\u0434\u0430 (25 \u0434\u0435\u043A\u0430\u0431\u0440\u044F
    \u043F\u043E \u0441\u0442\u0430\u0440\u043E\u043C\u0443 \u0441\u0442\u0438\u043B\u044E,
    \u0438\u043B\u0438 4 \u044F\u043D\u0432\u0430\u0440\u044F 1643 \u043F\u043E \u043D\u043E\u0432\u043E\u043C\u0443)
    \u0432 \u043F\u043E\u043C\u0435\u0441\u0442\u044C\u0435 \u0412\u0443\u043B\u0441\u0442\u043E\u0440\u043F,
    \u0433\u0440\u0430\u0444\u0441\u0442\u0432\u043E \u041B\u0438\u043D\u043A\u043E\u043B\u044C\u043D\u0448\u0438\u0440,
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u043D\u0435\u0431\u043E\u0433\u0430\u0442\u043E\u0433\u043E
    \u0444\u0435\u0440\u043C\u0435\u0440\u0430. \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u0442\u0430\u043A\u0436\u0435 \u0418\u0441\u0430\u0430\u043A \u041D\u044C\u044E\u0442\u043E\u043D,
    \u0443\u043C\u0435\u0440 \u0437\u0430 \u0442\u0440\u0438 \u043C\u0435\u0441\u044F\u0446\u0430
    \u0434\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0441\u044B\u043D\u0430.
    \u041C\u0430\u043B\u044C\u0447\u0438\u043A \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0445\u0438\u043B\u044B\u043C
    \u0438 \u043A\u0440\u043E\u0448\u0435\u0447\u043D\u044B\u043C, \u0447\u0442\u043E,
    \u043F\u043E \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0441\u043B\u043E\u0432\u0430\u043C, \xAB\u043F\u043E\u043C\u0435\u0441\u0442\u0438\u043B\u0441\u044F
    \u0431\u044B \u0432 \u043F\u0438\u0432\u043D\u0443\u044E \u043A\u0440\u0443\u0436\u043A\u0443\xBB;
    \u043D\u0438\u043A\u0442\u043E \u043D\u0435 \u0432\u0435\u0440\u0438\u043B, \u0447\u0442\u043E
    \u043E\u043D \u0432\u044B\u0436\u0438\u0432\u0435\u0442.  **\u0413\u043B\u0430\u0432\u043D\u044B\u043C
    \u0441\u043E\u0431\u044B\u0442\u0438\u0435\u043C, \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u0432\u0448\u0438\u043C
    \u0435\u0433\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440, \u0441\u0442\u0430\u043B
    \u043F\u043E\u0432\u0442\u043E\u0440\u043D\u044B\u0439 \u0431\u0440\u0430\u043A
    \u043C\u0430\u0442\u0435\u0440\u0438.** \u041A\u043E\u0433\u0434\u0430 \u0418\u0441\u0430\u0430\u043A\u0443
    \u0431\u044B\u043B\u043E \u0442\u0440\u0438 \u0433\u043E\u0434\u0430, \u0435\u0433\u043E
    \u043C\u0430\u0442\u044C, \u0410\u043D\u043D\u0430 \u042D\u0439\u0441\u043A\u043E\u0443,
    \u0432\u044B\u0448\u043B\u0430 \u0437\u0430\u043C\u0443\u0436 \u0437\u0430 \u0431\u043E\u0433\u0430\u0442\u043E\u0433\u043E
    \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430 \u0412\u0430\u0440\u043D\u0430\u0432\u0443
    \u0421\u043C\u0438\u0442\u0430 \u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u043A \u043D\u0435\u043C\u0443, \u043E\u0441\u0442\u0430\u0432\u0438\u0432 \u0441\u044B\u043D\u0430
    \u043D\u0430 \u043F\u043E\u043F\u0435\u0447\u0435\u043D\u0438\u0435 \u0431\u0430\u0431\u0443\u0448\u043A\u0438.
    \u042D\u0442\u0430 \xAB\u0438\u0437\u043C\u0435\u043D\u0430\xBB \u043D\u0430\u043D\u0435\u0441\u043B\u0430
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0443 \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E
    \u0434\u0443\u0448\u0435\u0432\u043D\u0443\u044E \u0440\u0430\u043D\u0443. \u0411\u0443\u0434\u0443\u0447\u0438
    \u0443\u0436\u0435 \u0432\u0437\u0440\u043E\u0441\u043B\u044B\u043C, \u041D\u044C\u044E\u0442\u043E\u043D
    \u0432\u043A\u043B\u044E\u0447\u0438\u043B \u0432 \u0441\u043F\u0438\u0441\u043E\u043A
    \u0441\u0432\u043E\u0438\u0445 \u0433\u0440\u0435\u0445\u043E\u0432 \u0434\u0435\u0442\u0441\u043A\u0443\u044E
    \u0443\u0433\u0440\u043E\u0437\u0443: *\xAB\u0423\u0433\u0440\u043E\u0436\u0430\u043B
    \u043E\u0442\u0446\u0443 \u0438 \u043C\u0430\u0442\u0435\u0440\u0438 \u0421\u043C\u0438\u0442\u0443
    \u0441\u0436\u0435\u0447\u044C \u0438\u0445 \u0438 \u0434\u043E\u043C \u043D\u0430\u0434
    \u043D\u0438\u043C\u0438\xBB*. \u041F\u043E \u043C\u043D\u0435\u043D\u0438\u044E
    \u043C\u043D\u043E\u0433\u0438\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432,
    \u0438\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u043E \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u043D\u0438\u0435
    \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0435\u0442 \u0435\u0433\u043E \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u043D\u043D\u0443\u044E
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0441\u0442\u044C, \u043C\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u043D\u043E\u0441\u0442\u044C,
    \u043F\u0440\u043E\u044F\u0432\u0438\u0432\u0448\u0438\u0435\u0441\u044F \u0432
    \u0431\u0443\u0434\u0443\u0449\u0435\u043C.  **\u0428\u043A\u043E\u043B\u044C\u043D\u044B\u0435
    \u0433\u043E\u0434\u044B \u043F\u0440\u043E\u0448\u043B\u0438 \u0432 \u0413\u0440\u0430\u043D\u0442\u0435\u043C\u0435**,
    \u0433\u0434\u0435 \u043E\u043D \u0436\u0438\u043B \u0432 \u0441\u0435\u043C\u044C\u0435
    \u043C\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u0430\u043F\u0442\u0435\u043A\u0430\u0440\u044F
    \u041A\u043B\u0430\u0440\u043A\u0430. \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0441\u0442\u0430\u043B \u0441\u0443\u0434\u044C\u0431\u043E\u043D\u043E\u0441\u043D\u044B\u043C:
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435 \u0445\u0438\u043C\u0438\u0435\u0439
    \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u0430\u043C\u0438, \u0430
    \u0442\u0430\u043A\u0436\u0435 \u043F\u0435\u0440\u0432\u044B\u0439 \u043E\u043F\u044B\u0442
    \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430.
    \u041E\u043D \u0441 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435\u043C
    \u043C\u0430\u0441\u0442\u0435\u0440\u0438\u043B \u043C\u043E\u0434\u0435\u043B\u0438
    \u0432\u0435\u0442\u0440\u044F\u043D\u044B\u0445 \u043C\u0435\u043B\u044C\u043D\u0438\u0446,
    \u0432\u043E\u0434\u044F\u043D\u044B\u0435 \u0438 \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0435
    \u0447\u0430\u0441\u044B \u0438 \u0434\u0430\u0436\u0435 \u0441\u043E\u0437\u0434\u0430\u043B
    \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437 \u0432\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434\u0430. 
    \u0412 \u0448\u043A\u043E\u043B\u0435 \u0418\u0441\u0430\u0430\u043A \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u0443\u0447\u0438\u043B\u0441\u044F \u043F\u043B\u043E\u0445\u043E \u0438 \u0431\u044B\u043B
    \u043C\u0438\u0448\u0435\u043D\u044C\u044E \u0434\u043B\u044F \u043D\u0430\u0441\u043C\u0435\u0448\u0435\u043A.
    \u041D\u043E \u043E\u0434\u043D\u0430\u0436\u0434\u044B, \u043F\u043E\u0441\u043B\u0435
    \u0436\u0435\u0441\u0442\u043E\u043A\u043E\u0439 \u0434\u0440\u0430\u043A\u0438,
    \u043E\u043D \u0440\u0435\u0448\u0438\u043B \u0432\u0437\u044F\u0442\u044C \u0440\u0435\u0432\u0430\u043D\u0448
    \u043D\u0435 \u0441\u0438\u043B\u043E\u0439, \u0430 \u0443\u043C\u043E\u043C
    \u0438 \u0432\u0441\u043A\u043E\u0440\u0435 \u0441\u0442\u0430\u043B \u043B\u0443\u0447\u0448\u0438\u043C
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043C\u0430\u0442\u044C \u0432\u0438\u0434\u0435\u043B\u0430 \u0435\u0433\u043E
    \u043D\u0430\u0441\u043B\u0435\u0434\u043D\u0438\u043A\u043E\u043C \u0444\u0435\u0440\u043C\u044B
    \u0438 \u0432 15 \u043B\u0435\u0442 \u0437\u0430\u0431\u0440\u0430\u043B\u0430
    \u0438\u0437 \u0448\u043A\u043E\u043B\u044B. \u041A \u0441\u0447\u0430\u0441\u0442\u044C\u044E
    \u0434\u043B\u044F \u043D\u0430\u0443\u043A\u0438, \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0442\u044C
    \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u043E\u043C \u041D\u044C\u044E\u0442\u043E\u043D
    \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u043D\u0435\u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D: \u043E\u043D \u0437\u0430\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043B
    \u0434\u0435\u043B\u0430 \u0438 \u0447\u0438\u0442\u0430\u043B \u043A\u043D\u0438\u0433\u0438,
    \u0443\u043A\u0440\u044B\u0432\u0448\u0438\u0441\u044C \u0432 \u0442\u0435\u043D\u0438
    \u0434\u0435\u0440\u0435\u0432\u044C\u0435\u0432. \u0414\u044F\u0434\u044F \u0438
    \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0439 \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u0443\u0431\u0435\u0434\u0438\u043B\u0438 \u0410\u043D\u043D\u0443 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442\u044C
    \u0441\u044B\u043D\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435. 
    ### \U0001F393 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436 \u0438 \u043F\u0435\u0440\u0432\u044B\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F  \u0412 1661 \u0433\u043E\u0434\u0443
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 18 \u043B\u0435\u0442
    \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430. \u0418\u0437-\u0437\u0430
    \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0433\u043E \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u043E\u0433\u043E
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u043E\u043D \u043D\u0430\u0447\u0430\u043B
    \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435 \u0432 \u0441\u0442\u0430\u0442\u0443\u0441\u0435
    **\xAB\u0441\u0430\u0431\u0441\u0430\u0439\u0437\u0435\u0440\u0430\xBB** \u2014
    \u0431\u0435\u0434\u043D\u043E\u0433\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0438\u0441\u043B\u0443\u0436\u0438\u0432\u0430\u043B
    \u0431\u043E\u043B\u0435\u0435 \u0431\u043E\u0433\u0430\u0442\u044B\u043C \u0442\u043E\u0432\u0430\u0440\u0438\u0449\u0430\u043C,
    \u0447\u0442\u043E\u0431\u044B \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u043D\u0430 \u0443\u0447\u0435\u0431\u0443.  \u0412 \u043F\u0435\u0440\u0432\u044B\u0435
    \u0433\u043E\u0434\u044B \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435
    \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0441\u0442\u0430\u043B \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0418\u0441\u0430\u0430\u043A
    \u0411\u0430\u0440\u0440\u043E\u0443. \u041D\u044C\u044E\u0442\u043E\u043D \u0441
    \u0436\u0430\u0434\u043D\u043E\u0441\u0442\u044C\u044E \u043D\u0430\u0431\u0440\u043E\u0441\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435 \xAB\u043D\u043E\u0432\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438\xBB: \u0440\u0430\u0431\u043E\u0442
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430, \u0413\u0430\u0441\u0441\u0435\u043D\u0434\u0438,
    \u0411\u043E\u0439\u043B\u044F \u0438 \u041A\u0435\u043F\u043B\u0435\u0440\u0430.
    \u0412 \u0441\u0432\u043E\u0438\u0445 \u043B\u0438\u0447\u043D\u044B\u0445 \u0437\u0430\u043F\u0438\u0441\u044F\u0445
    **\xABQuaestiones Quaedam Philosophicae\xBB** (\xAB\u041E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0435
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435 \u0432\u043E\u043F\u0440\u043E\u0441\u044B\xBB)
    \u043E\u043D \u0443\u0436\u0435 \u043E\u0442\u043E\u0448\u0435\u043B \u043E\u0442
    \u0441\u0445\u043E\u043B\u0430\u0441\u0442\u0438\u043A\u0438 \u0410\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u044F
    \u0438 \u043D\u0430\u0447\u0430\u043B \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435 \u0438\u0434\u0435\u0438. 
    **\u0427\u0443\u043C\u043D\u044B\u0435 \u0433\u043E\u0434\u044B (1665\u20131667)
    \u0441\u0442\u0430\u043B\u0438 \u0441\u0430\u043C\u044B\u043C \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u043C
    \u043F\u0435\u0440\u0438\u043E\u0434\u043E\u043C \u0432 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.**
    \u0418\u0437-\u0437\u0430 \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u0438 \u0447\u0443\u043C\u044B
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436 \u0431\u044B\u043B \u0437\u0430\u043A\u0440\u044B\u0442,
    \u0438 \u041D\u044C\u044E\u0442\u043E\u043D \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u0440\u043E\u0434\u043D\u043E\u0439 \u0412\u0443\u043B\u0441\u0442\u043E\u0440\u043F.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C, \u0432 \u0443\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u0438,
    \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E \u0442\u043E, \u0447\u0442\u043E
    \u043F\u043E\u0437\u0436\u0435 \u043D\u0430\u0437\u043E\u0432\u0443\u0442 \u0435\u0433\u043E
    **\xABannus mirabilis\xBB (\u0433\u043E\u0434\u043E\u043C \u0447\u0443\u0434\u0435\u0441)**: 
    *   \u0412 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u043E\u043D
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F (\u0441\u043E\u0437\u0434\u0430\u0432
    \xAB\u043C\u0435\u0442\u043E\u0434 \u0444\u043B\u044E\u043A\u0441\u0438\u0439\xBB)
    \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0431\u0438\u043D\u043E\u043C
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430. *   \u0412 \u043E\u043F\u0442\u0438\u043A\u0435
    \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u044B \u0441
    \u043F\u0440\u0438\u0437\u043C\u0430\u043C\u0438, \u0434\u043E\u043A\u0430\u0437\u0430\u0432,
    \u0447\u0442\u043E \u0431\u0435\u043B\u044B\u0439 \u0441\u0432\u0435\u0442 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0441\u043C\u0435\u0441\u044C\u044E \u0446\u0432\u0435\u0442\u043E\u0432. *  
    \u0412 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435 \u043E\u043D \u0432\u044B\u0432\u0435\u043B
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0446\u0435\u043D\u0442\u0440\u043E\u0431\u0435\u0436\u043D\u043E\u0439
    \u0441\u0438\u043B\u044B \u0438 \u043F\u0440\u0438\u0448\u0435\u043B \u043A \u0434\u043E\u0433\u0430\u0434\u043A\u0435
    \u043E \u0437\u0430\u043A\u043E\u043D\u0435 \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0433\u043E
    \u0442\u044F\u0433\u043E\u0442\u0435\u043D\u0438\u044F, \u0445\u043E\u0442\u044F
    \u0442\u043E\u0433\u0434\u0430 \u043D\u0435 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0435\u0451.  ### \U0001F3C6 \u0417\u0432\u0435\u0437\u0434\u043D\u044B\u0439
    \u0447\u0430\u0441: \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440, \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB
    \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435  \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436, \u041D\u044C\u044E\u0442\u043E\u043D
    \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043F\u043E\u0448\u0435\u043B
    \u0432\u0432\u0435\u0440\u0445 \u043F\u043E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u0435\u0441\u0442\u043D\u0438\u0446\u0435. \u0412 1667 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441\u0442\u0430\u043B \u0447\u043B\u0435\u043D\u043E\u043C \u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430,
    \u0432 1668 \u2014 \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u043E\u043C, \u0430
    \u0432 1669 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    26 \u043B\u0435\u0442, **\u043F\u043E\u043B\u0443\u0447\u0438\u043B \u041B\u0443\u043A\u0430\u0441\u043E\u0432\u0441\u043A\u0443\u044E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0443\u0440\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438**,
    \u0441\u043C\u0435\u043D\u0438\u0432 \u043D\u0430 \u044D\u0442\u043E\u043C \u043F\u043E\u0441\u0442\u0443
    \u0441\u0432\u043E\u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044F
    \u0418\u0441\u0430\u0430\u043A\u0430 \u0411\u0430\u0440\u0440\u043E\u0443. \u042D\u0442\u043E
    \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u043B\u043E \u0435\u0433\u043E
    \u043E\u0442 \u043E\u0431\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u0438
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0442\u044C \u0441\u0430\u043D \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430,
    \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u043A\u0440\u0438\u0442\u0438\u0447\u043D\u043E,
    \u0442\u0430\u043A \u043A\u0430\u043A \u041D\u044C\u044E\u0442\u043E\u043D \u0442\u0430\u0439\u043D\u043E
    \u043F\u0440\u0438\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0441\u044F
    \u0435\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0430\u0440\u0438\u0430\u043D\u0441\u0442\u0432\u0430,
    \u043E\u0442\u0440\u0438\u0446\u0430\u044E\u0449\u0435\u0433\u043E \u0422\u0440\u043E\u0438\u0446\u0443. 
    \u0412 1672 \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F
    \u043F\u0435\u0440\u0432\u043E\u0433\u043E \u0432 \u043C\u0438\u0440\u0435 \u0437\u0435\u0440\u043A\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u0430-\u0440\u0435\u0444\u043B\u0435\u043A\u0442\u043E\u0440\u0430,
    \u043E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044F \u0441\u0432\u0435\u0442\u0430
    \u0441\u0440\u0430\u0437\u0443 \u0432\u044B\u0437\u0432\u0430\u043B\u0430 \u043E\u0441\u0442\u0440\u0443\u044E
    \u043F\u043E\u043B\u0435\u043C\u0438\u043A\u0443 \u0441 \u0420\u043E\u0431\u0435\u0440\u0442\u043E\u043C
    \u0413\u0443\u043A\u043E\u043C, \u0447\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B\u043E
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u043A\u0440\u0430\u0439\u043D\u0435
    \u043D\u0435\u043B\u044E\u0434\u0438\u043C\u044B\u043C \u0438 \u043C\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C.
    \u041F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0439 \u0442\u0440\u0430\u0432\u043B\u0438
    \u043E\u043D \u043D\u0430\u0434\u043E\u043B\u0433\u043E \u0437\u0430\u043C\u043A\u043D\u0443\u043B\u0441\u044F
    \u0438 \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u0438 \u0440\u0430\u0431\u043E\u0442\u044B.  **\u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u0432\u0441\u0435\u0439 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438,
    \xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043D\u0430\u0447\u0430\u043B\u0430 \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438\xBB (Philosophi\xE6 Naturalis
    Principia Mathematica), \u0431\u044B\u043B \u0441\u043E\u0437\u0434\u0430\u043D
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u043D\u0430\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430 \u042D\u0434\u043C\u0443\u043D\u0434\u0430
    \u0413\u0430\u043B\u043B\u0435\u044F**. \u0412 1684 \u0433\u043E\u0434\u0443
    \u0413\u0430\u043B\u043B\u0435\u0439 \u043F\u0440\u0438\u0448\u0435\u043B \u043A
    \u041D\u044C\u044E\u0442\u043E\u043D\u0443 \u0441 \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u043C
    \u043E \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438 \u0442\u0435\u043B
    \u043F\u043E\u0434 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435\u043C \u0446\u0435\u043D\u0442\u0440\u043E\u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0441\u0438\u043B\u044B, \u0438 \u041D\u044C\u044E\u0442\u043E\u043D \u043E\u0442\u0432\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u0443\u0436\u0435 \u0432\u044B\u0432\u0435\u043B \u044D\u0442\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435, \u043D\u043E \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u0440\u0430\u0441\u0447\u0435\u0442\u044B. \u041F\u043E\u0434 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C
    \u0413\u0430\u043B\u043B\u0435\u044F \u043E\u043D \u0437\u0430\u043D\u043E\u0432\u043E
    \u043F\u0440\u043E\u0432\u0435\u043B \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0438 \u0432 1687 \u0433\u043E\u0434\u0443 \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB
    \u0431\u044B\u043B\u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u044B
    \u043D\u0430 \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430 \u0413\u0430\u043B\u043B\u0435\u044F.
    \u042D\u0442\u0430 \u043A\u043D\u0438\u0433\u0430 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0430
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438 \u0438 \u0441\u0442\u0430\u043B\u0430
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C \u043D\u0430\u0443\u0447\u043D\u044B\u043C
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435\u043C
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438.  ### \U0001F3DB\uFE0F \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434: \u041C\u043E\u043D\u0435\u0442\u043D\u044B\u0439
    \u0434\u0432\u043E\u0440, \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u0430 \u0438
    \u0441\u043F\u043E\u0440\u044B  \u0412 1689 \u0433\u043E\u0434\u0443 \u041D\u044C\u044E\u0442\u043E\u043D
    \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C
    \u043F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442\u0430 \u043E\u0442 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0430\u044F \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C \u0432 1696 \u0433\u043E\u0434\u0443,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C **\u0441\u043C\u043E\u0442\u0440\u0438\u0442\u0435\u043B\u044F
    \u041C\u043E\u043D\u0435\u0442\u043D\u043E\u0433\u043E \u0434\u0432\u043E\u0440\u0430**,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0438 \u0435\u0433\u043E \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u0430.
    \u041D\u0430 \u044D\u0442\u043E\u043C \u043F\u043E\u0441\u0442\u0443 \u043E\u043D
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B \u0441\u0435\u0431\u044F \u043A\u0430\u043A
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0439 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440,
    \u043F\u0440\u043E\u0432\u0435\u043B \u0434\u0435\u043D\u0435\u0436\u043D\u0443\u044E
    \u0440\u0435\u0444\u043E\u0440\u043C\u0443 \u0438 \u043B\u0438\u0447\u043D\u043E
    \u0431\u043E\u0440\u043E\u043B\u0441\u044F \u0441 \u0444\u0430\u043B\u044C\u0448\u0438\u0432\u043E\u043C\u043E\u043D\u0435\u0442\u0447\u0438\u043A\u0430\u043C\u0438. 
    \u0412 1703 \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0441\u0432\u043E\u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E
    \u0432\u0440\u0430\u0433\u0430 \u0420\u043E\u0431\u0435\u0440\u0442\u0430 \u0413\u0443\u043A\u0430,
    \u041D\u044C\u044E\u0442\u043E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D
    **\u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430** \u0438 \u0431\u0435\u0441\u0441\u043C\u0435\u043D\u043D\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B \u044D\u0442\u043E\u0442 \u043F\u043E\u0441\u0442
    \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0436\u0438\u0437\u043D\u0438. \u0412
    1705 \u0433\u043E\u0434\u0443 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0430
    \u0410\u043D\u043D\u0430 \u0432\u043E\u0437\u0432\u0435\u043B\u0430 \u0435\u0433\u043E
    \u0432 \u0440\u044B\u0446\u0430\u0440\u0441\u043A\u043E\u0435 \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u043E. 
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u0431\u044B\u043B\u0438
    \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u044B \u043E\u0436\u0435\u0441\u0442\u043E\u0447\u0435\u043D\u043D\u044B\u043C
    **\u0441\u043F\u043E\u0440\u043E\u043C \u0441 \u0413\u043E\u0442\u0444\u0440\u0438\u0434\u043E\u043C
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0435\u043C** \u043E \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0435
    \u0432 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430. \u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441
    \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0441\u044F \u0432 \u0442\u043E\u043C,
    \u0447\u0442\u043E \u041D\u044C\u044E\u0442\u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435 \u0440\u0430\u043D\u044C\u0448\u0435,
    \u043D\u043E \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u043F\u043E\u0437\u0436\u0435 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430.
    \u041D\u044C\u044E\u0442\u043E\u043D, \u043E\u0431\u043B\u0430\u0434\u0430\u0432\u0448\u0438\u0439
    \u0442\u044F\u0436\u0435\u043B\u044B\u043C \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u0435
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0433\u043B\u0430\u0432\u044B
    \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430,
    \u0447\u0442\u043E\u0431\u044B \u043E\u0431\u0432\u0438\u043D\u0438\u0442\u044C
    \u043E\u043F\u043F\u043E\u043D\u0435\u043D\u0442\u0430 \u0432 \u043F\u043B\u0430\u0433\u0438\u0430\u0442\u0435. 
    ### \U0001F52E \u0422\u0430\u0439\u043D\u044B\u0439 \u043C\u0438\u0440: \u0410\u043B\u0445\u0438\u043C\u0438\u044F
    \u0438 \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044F  \u041F\u043E\u043C\u0438\u043C\u043E
    \u0444\u0438\u0437\u0438\u043A\u0438 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u044B
    \u0441\u0432\u043E\u0438\u0445 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0435\u0439
    \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    **\u0430\u043B\u0445\u0438\u043C\u0438\u0438, \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0438\u044E
    \u0438 \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u0438**. \u041E\u043D
    \u0438\u0441\u043A\u0430\u043B \xAB\u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0439
    \u043A\u0430\u043C\u0435\u043D\u044C\xBB \u0438 \u043F\u0438\u0441\u0430\u043B
    \u0442\u043E\u043B\u043A\u043E\u0432\u0430\u043D\u0438\u044F \u043A \u0431\u0438\u0431\u043B\u0435\u0439\u0441\u043A\u0438\u043C
    \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u0430\u043C, \u043F\u044B\u0442\u0430\u044F\u0441\u044C
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u044C \u0434\u0430\u0442\u0443
    \u0410\u043F\u043E\u043A\u0430\u043B\u0438\u043F\u0441\u0438\u0441\u0430. \u042D\u0442\u043E
    \u0431\u044B\u043B\u0430 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0440\u0438\u0445\u043E\u0442\u044C
    \u2014 \u0432 XVII \u0432\u0435\u043A\u0435 \u0430\u043B\u0445\u0438\u043C\u0438\u044F
    \u0441\u0447\u0438\u0442\u0430\u043B\u0430\u0441\u044C \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u043E\u0439
    \u043D\u0430\u0443\u043A\u043E\u0439, \u0438 \u041D\u044C\u044E\u0442\u043E\u043D
    \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043D\u0430\u0439\u0442\u0438 \u0441\u043A\u0440\u044B\u0442\u044B\u0435
    \u0441\u0438\u043B\u044B \u043F\u0440\u0438\u0440\u043E\u0434\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0435 \u043C\u043E\u0433\u043B\u0430 \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u044C
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430.  \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u0430\u043D\u0430\u043B\u0438\u0437 \u0435\u0433\u043E \u0432\u043E\u043B\u043E\u0441,
    \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u043D\u044B\u0439 \u0441\u043F\u0443\u0441\u0442\u044F
    \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F, \u043F\u043E\u043A\u0430\u0437\u0430\u043B
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435
    \u0440\u0442\u0443\u0442\u0438, \u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0438\u0445
    \u0430\u043B\u0445\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043E\u043F\u044B\u0442\u043E\u0432.
    \u042D\u0442\u043E \u043C\u043E\u0433\u043B\u043E \u043F\u043E\u0432\u043B\u0438\u044F\u0442\u044C
    \u043D\u0430 \u0435\u0433\u043E \u043D\u0435\u0440\u0432\u043D\u044B\u0435 \u0441\u0440\u044B\u0432\u044B
    \u0438 \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0441\u0442\u0438 \u0432 \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0438
    \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438.  \u0423\u043C\u0435\u0440 \u0441\u044D\u0440
    \u0418\u0441\u0430\u0430\u043A \u041D\u044C\u044E\u0442\u043E\u043D \u0432 1727
    \u0433\u043E\u0434\u0443 \u0432 \u041A\u0435\u043D\u0441\u0438\u043D\u0433\u0442\u043E\u043D\u0435
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 84 \u043B\u0435\u0442
    \u0438 \u0431\u044B\u043B \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u0432 \u0412\u0435\u0441\u0442\u043C\u0438\u043D\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u043C
    \u0430\u0431\u0431\u0430\u0442\u0441\u0442\u0432\u0435, \u0441\u0442\u0430\u0432
    \u043F\u0435\u0440\u0432\u044B\u043C \u0443\u0447\u0435\u043D\u044B\u043C, \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D\u043D\u044B\u043C
    \u0442\u0430\u043A\u043E\u0439 \u0447\u0435\u0441\u0442\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0418\u0441\u0430\u0430\u043A\u0430
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u2014 \u044D\u0442\u043E \u043D\u0435
    \u0441\u0443\u0445\u0430\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0444\u043E\u0440\u043C\u0443\u043B,
    \u0430 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439 \u0442\u0440\u0438\u043B\u043B\u0435\u0440
    \u0441 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u043C\u0438 \u0434\u0435\u0442\u0435\u043A\u0442\u0438\u0432\u0430,
    \u0447\u0435\u0440\u043D\u043E\u0439 \u043C\u0430\u0433\u0438\u0438, \u0441\u0443\u043C\u0430\u0441\u0448\u0435\u0441\u0442\u0432\u0438\u044F
    \u0438 \u0433\u0438\u0433\u0430\u043D\u0442\u0441\u043A\u043E\u0433\u043E \u044D\u0433\u043E.
    \u0417\u0430 \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0433\u0435\u043D\u0438\u044F \u0441\u043A\u0440\u044B\u0432\u0430\u043B\u0441\u044F
    \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u0439,
    \u043C\u0441\u0442\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439, \u043E\u0434\u0435\u0440\u0436\u0438\u043C\u044B\u0439
    \u0438 \u043E\u0447\u0435\u043D\u044C \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0439
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A.  \u041D\u0438\u0436\u0435 \u2014
    \u043A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u044F \u0441\u0430\u043C\u044B\u0445
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u0445, \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0445
    \u0438 \u0448\u043E\u043A\u0438\u0440\u0443\u044E\u0449\u0438\u0445 \u0444\u0430\u043A\u0442\u043E\u0432
    \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438,
    \u0440\u0430\u0437\u0431\u0438\u0442\u0430\u044F \u043F\u043E \u0442\u0435\u043C\u0430\u043C. 
    ---  ### \U0001F34F 1. \u042F\u0431\u043B\u043E\u043A\u043E: \u041F\u0440\u0430\u0432\u0434\u0430
    \u0438 \u0432\u044B\u043C\u044B\u0441\u0435\u043B  \u0418\u0441\u0442\u043E\u0440\u0438\u044F
    \u043E \u043F\u0430\u0434\u0430\u044E\u0449\u0435\u043C \u044F\u0431\u043B\u043E\u043A\u0435
    \u2014 \u0441\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430 \u0432 \u043D\u0430\u0443\u043A\u0435,
    \u043D\u043E \u043F\u0440\u0430\u0432\u0434\u0430 \u0432 \u043D\u0435\u0439 \u043B\u0438\u0448\u044C
    \u043D\u0430\u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443.  - **\u0414\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435**:
    \u0421\u0430\u043C \u041D\u044C\u044E\u0442\u043E\u043D \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B
    \u044D\u0442\u0443 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u0432 \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0438
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u043C \u0434\u043E\u0432\u0435\u0440\u0435\u043D\u043D\u044B\u043C
    \u043B\u0438\u0446\u0430\u043C, \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0423\u0438\u043B\u044C\u044F\u043C\u0430
    \u0421\u0442\u044C\u044E\u043A\u043B\u0438 (\u043E\u043D \u0437\u0430\u043F\u0438\u0441\u0430\u043B
    \u044D\u0442\u043E \u0432 \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0435 \u0432
    1726 \u0433\u043E\u0434\u0443) \u0438 \u0412\u043E\u043B\u044C\u0442\u0435\u0440\u0430
    (\u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u043B\u0430
    \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u0446\u0430 \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u041A\u044D\u0442\u0440\u0438\u043D).  - **\u0421\u0443\u0442\u044C \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u044F**:
    \u042F\u0431\u043B\u043E\u043A\u043E **\u043D\u0435 \u0443\u043F\u0430\u043B\u043E
    \u0435\u043C\u0443 \u043D\u0430 \u0433\u043E\u043B\u043E\u0432\u0443**. \u041D\u044C\u044E\u0442\u043E\u043D
    \u0441\u0438\u0434\u0435\u043B \u0443 \u043A\u0430\u043C\u0438\u043D\u0430 \u0438\u043B\u0438
    \u0432 \u0441\u0430\u0434\u0443, \u0443\u0432\u0438\u0434\u0435\u043B \u043F\u0430\u0434\u0430\u044E\u0449\u0435\u0435
    \u044F\u0431\u043B\u043E\u043A\u043E \u0438 \u0437\u0430\u0434\u0430\u043B\u0441\u044F
    \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u043C: *\xAB\u041F\u043E\u0447\u0435\u043C\u0443
    \u043E\u043D\u043E \u043F\u0430\u0434\u0430\u0435\u0442 \u0441\u0442\u0440\u043E\u0433\u043E
    \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u043E, \u0430 \u043D\u0435
    \u043F\u043E\u0434 \u0443\u0433\u043B\u043E\u043C \u0438\u043B\u0438 \u0432\u0432\u0435\u0440\u0445?\xBB*.
    \u042D\u0442\u043E \u043D\u0430\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u043E
    \u0435\u0433\u043E \u043D\u0430 \u043C\u044B\u0441\u043B\u044C, \u0447\u0442\u043E
    \u0417\u0435\u043C\u043B\u044F \u043F\u0440\u0438\u0442\u044F\u0433\u0438\u0432\u0430\u0435\u0442
    \u044F\u0431\u043B\u043E\u043A\u043E, \u0438 \u044D\u0442\u0430 \u0436\u0435
    \u0441\u0438\u043B\u0430, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442
    \u041B\u0443\u043D\u0443 \u043D\u0430 \u043E\u0440\u0431\u0438\u0442\u0435. 
    - **\u041A\u0443\u0440\u044C\u0435\u0437**: \u041D\u044C\u044E\u0442\u043E\u043D
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u044F\u0431\u043B\u043E\u043A\u043E
    \u043D\u0435 \u0434\u043B\u044F \u0444\u0438\u0437\u0438\u043A\u0438, \u0430
    \u0434\u043B\u044F \u043E\u043F\u0442\u0438\u043A\u0438. \u041E\u043D \u043F\u0438\u0441\u0430\u043B,
    \u0447\u0442\u043E \u0447\u0430\u0441\u0442\u043E \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B
    \u044F\u0431\u043B\u043E\u043A\u0438 \u043D\u0430 \u0441\u043E\u043B\u043D\u0446\u0435,
    \u0447\u0442\u043E\u0431\u044B \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u043F\u0435\u0440\u0435\u043B\u0438\u0432\u044B
    \u0446\u0432\u0435\u0442\u043E\u0432 \u043D\u0430 \u0438\u0445 \u043A\u043E\u0436\u0438\u0446\u0435. 
    ---  ### \U0001F525 2. \u041C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439
    \u043F\u0438\u0440\u043E\u043C\u0430\u043D \u0438 \u0441\u043F\u0438\u0441\u043E\u043A
    \u0433\u0440\u0435\u0445\u043E\u0432  \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    19 \u043B\u0435\u0442, \u0431\u0443\u0434\u0443\u0447\u0438 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C,
    \u041D\u044C\u044E\u0442\u043E\u043D \u0437\u0430\u0432\u0435\u043B \u0442\u0435\u0442\u0440\u0430\u0434\u044C,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u043B
    **\u0432\u0441\u0435 \u0441\u0432\u043E\u0438 \u0433\u0440\u0435\u0445\u0438**,
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u044B\u0435 \u0437\u0430
    \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C (\u0432\u0441\u0435\u0433\u043E
    \u043E\u043A\u043E\u043B\u043E 58 \u043F\u0443\u043D\u043A\u0442\u043E\u0432).
    \u042D\u0442\u043E\u0442 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442 \u2014
    \u043A\u043B\u044E\u0447 \u043A \u0435\u0433\u043E \u043F\u0441\u0438\u0445\u043E\u0437\u0443. 
    - *\u0421\u0430\u043C\u044B\u0435 \u0434\u0438\u043A\u0438\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F*:   
    - *\xAB\u0423\u0433\u0440\u043E\u0436\u0430\u043B \u043E\u0442\u0446\u0443 \u0438
    \u043C\u0430\u0442\u0435\u0440\u0438 \u0421\u043C\u0438\u0442\u0443 \u0441\u0436\u0435\u0447\u044C
    \u0438\u0445 \u0438 \u0434\u043E\u043C \u043D\u0430\u0434 \u043D\u0438\u043C\u0438\xBB*
    (\u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 3 \u043B\u0435\u0442).  
    - *\xAB\u0416\u0435\u043B\u0430\u043B \u0441\u043C\u0435\u0440\u0442\u0438 \u043C\u0430\u0442\u0435\u0440\u0438,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D\u0430 \u043F\u0438\u043B\u0430 \u043F\u0438\u0432\u043E\xBB*.  
    - *\xAB\u0411\u0438\u043B \u043C\u043E\u044E \u0441\u0435\u0441\u0442\u0440\u0443\xBB*.  
    - *\xAB\u0415\u043B \u044F\u0431\u043B\u043E\u043A\u043E \u0432 \u0446\u0435\u0440\u043A\u0432\u0438\xBB*
    (\u0434\u043B\u044F \u043F\u0443\u0440\u0438\u0442\u0430\u043D\u0438\u043D\u0430
    \u044D\u0442\u043E \u0431\u044B\u043B\u043E \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E\u0435
    \u043A\u043E\u0449\u0443\u043D\u0441\u0442\u0432\u043E). - *\u041E\u0434\u0435\u0440\u0436\u0438\u043C\u043E\u0441\u0442\u044C
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u043E\u0439*: \u041E\u043D
    \u043D\u0430\u043A\u0430\u0437\u044B\u0432\u0430\u043B \u0441\u0435\u0431\u044F
    \u0437\u0430 \xAB\u043D\u0435\u0447\u0438\u0441\u0442\u044B\u0435 \u043C\u044B\u0441\u043B\u0438\xBB
    \u0438 \xAB\u043B\u0435\u043D\u044C\xBB, \u043D\u043E \u043F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u043B \u0442\u0443\u0434\u0430
    \u0436\u0435 \u0441\u0432\u043E\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u044F, \u0441\u0447\u0438\u0442\u0430\u044F,
    \u0447\u0442\u043E \u0411\u043E\u0433 \u0434\u0430\u0435\u0442 \u0435\u043C\u0443
    \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0438 \u0437\u0430 \u0445\u043E\u0440\u043E\u0448\u0435\u0435
    \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435.  ---  ### \U0001F441\uFE0F
    3. \u042D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u044B \u043D\u0430\u0434
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u0437\u0440\u0435\u043D\u0438\u0435\u043C
    (\u0421\u0430\u0434\u043E\u043C\u0430\u0437\u043E\u0445\u0438\u0437\u043C \u0440\u0430\u0434\u0438
    \u043D\u0430\u0443\u043A\u0438)  \u041D\u044C\u044E\u0442\u043E\u043D \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u043B
    \u0437\u0430 \u043F\u0440\u0438\u0440\u043E\u0434\u043E\u0439 \u2014 \u043E\u043D
    \u043F\u044B\u0442\u0430\u043B \u0441\u0435\u0431\u044F, \u0447\u0442\u043E\u0431\u044B
    \u043F\u043E\u043D\u044F\u0442\u044C \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E
    \u0433\u043B\u0430\u0437\u0430. \u0415\u0433\u043E \u0437\u0430\u043F\u0438\u0441\u0438
    \u043F\u043E \u043E\u043F\u0442\u0438\u043A\u0435 \u0447\u0438\u0442\u0430\u0442\u044C
    \u0436\u0443\u0442\u043A\u043E.  - **\u0418\u0433\u043B\u0430 \u0411\u043E\u0434\u043A\u0438\u043D\u0430**:
    \u041D\u044C\u044E\u0442\u043E\u043D \u0432\u0437\u044F\u043B \u0442\u043E\u043D\u043A\u0443\u044E
    \u043C\u0435\u0442\u0430\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0438\u0433\u043B\u0443 (\u0431\u043E\u0434\u043A\u0438\u043D) \u0438 **\u0437\u0430\u0441\u0443\u043D\u0443\u043B
    \u0435\u0451 \u043C\u0435\u0436\u0434\u0443 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0433\u043B\u0430\u0437\u043D\u044B\u043C \u044F\u0431\u043B\u043E\u043A\u043E\u043C
    \u0438 \u043A\u043E\u0441\u0442\u044C\u044E \u0433\u043B\u0430\u0437\u043D\u0438\u0446\u044B**,
    \u043D\u0430\u0434\u0430\u0432\u043B\u0438\u0432\u0430\u044F \u043D\u0430 \u0437\u0430\u0434\u043D\u044E\u044E
    \u0441\u0442\u0435\u043D\u043A\u0443 \u0433\u043B\u0430\u0437\u0430. \u0417\u0430\u0442\u0435\u043C
    \u043E\u043D \u0432\u0440\u0430\u0449\u0430\u043B \u0438\u0433\u043B\u0443 \u0438
    \u0441\u043C\u043E\u0442\u0440\u0435\u043B, \u043A\u0430\u043A \u043C\u0435\u043D\u044F\u044E\u0442\u0441\u044F
    \u0446\u0432\u0435\u0442\u043D\u044B\u0435 \u043A\u0440\u0443\u0433\u0438 \u043F\u0435\u0440\u0435\u0434
    \u0433\u043B\u0430\u0437\u0430\u043C\u0438. \u041E\u043D \u0434\u0435\u043B\u0430\u043B
    \u044D\u0442\u043E \u043D\u0435 \u0440\u0430\u0437, \u0430 \u0434\u0435\u0441\u044F\u0442\u043A\u0438
    \u0440\u0430\u0437, \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u043E \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044F
    \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u044E\u0449\u0438\u0435 \u0440\u0430\u0434\u0443\u0436\u043D\u044B\u0435
    \u0441\u043F\u0438\u0440\u0430\u043B\u0438. - **\u042D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442
    \u0441 \u0441\u043E\u043B\u044F\u0440\u0438\u0435\u043C**: \u041E\u043D \u043F\u043E\u0434\u043E\u043B\u0433\u0443
    \u0441\u043C\u043E\u0442\u0440\u0435\u043B \u043D\u0430 \u0421\u043E\u043B\u043D\u0446\u0435
    \u0447\u0435\u0440\u0435\u0437 \u0437\u0435\u0440\u043A\u0430\u043B\u043E, \u0447\u0442\u043E\u0431\u044B
    \u0437\u0430\u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u044B\u0435 \u043E\u0431\u0440\u0430\u0437\u044B
    \u043D\u0430 \u0441\u0435\u0442\u0447\u0430\u0442\u043A\u0435, \u0447\u0442\u043E
    \u043F\u043E\u0437\u0436\u0435 \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A
    \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0441\u043B\u0435\u043F\u043E\u0442\u0435.
    \u0415\u043C\u0443 \u043F\u043E\u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u043E\u0441\u044C
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0434\u043D\u0435\u0439,
    \u0447\u0442\u043E\u0431\u044B \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u0437\u0440\u0435\u043D\u0438\u0435, \u043D\u043E \u043E\u043D \u043D\u0435
    \u0436\u0430\u043B\u0435\u043B \u043E\u0431 \u044D\u0442\u043E\u043C, \u0442\u0430\u043A
    \u043A\u0430\u043A \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u0430\u043D\u043D\u044B\u0435
    \u043E \u043F\u0440\u0438\u0440\u043E\u0434\u0435 \u0446\u0432\u0435\u0442\u043E\u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u044F. 
    ---  ### \U0001F52C 4. \u0410\u043B\u0445\u0438\u043C\u0438\u043A-\u043E\u0442\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C 
    \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u043E\u0442\u0440\u0430\u0442\u0438\u043B
    \u0431\u043E\u043B\u044C\u0448\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0438 \u0431\u0443\u043C\u0430\u0433\u0438 \u043D\u0430 \u0430\u043B\u0445\u0438\u043C\u0438\u044E,
    \u0447\u0435\u043C \u043D\u0430 \u0444\u0438\u0437\u0438\u043A\u0443 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0432\u0437\u044F\u0442\u044B\u0435. \u0415\u0433\u043E
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u043F\u043E \u0445\u0438\u043C\u0438\u0438 \u043F\u0440\u0435\u0432\u044B\u0448\u0430\u0435\u0442
    **\u043C\u0438\u043B\u043B\u0438\u043E\u043D \u0441\u043B\u043E\u0432**.  - **\u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0439
    \u043A\u0430\u043C\u0435\u043D\u044C**: \u041E\u043D \u0438\u0441\u043A\u0430\u043B
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \xAB\u041C\u0435\u0440\u043A\u0443\u0440\u0438\u044F
    \u043C\u0443\u0434\u0440\u0435\u0446\u043E\u0432\xBB \u2014 \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0430,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u0435\u0442
    \u0441\u0432\u0438\u043D\u0435\u0446 \u0432 \u0437\u043E\u043B\u043E\u0442\u043E
    \u0438 \u0434\u0430\u0440\u0443\u0435\u0442 \u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u0438\u0435.
    - **\u0421\u043C\u0435\u0440\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u043A\u043E\u043A\u0442\u0435\u0439\u043B\u044C**:
    \u041D\u044C\u044E\u0442\u043E\u043D \u0433\u043B\u043E\u0442\u0430\u043B \u0438
    \u0432\u0434\u044B\u0445\u0430\u043B \u043F\u0430\u0440\u044B \u0440\u0442\u0443\u0442\u0438,
    \u0441\u0443\u0440\u044C\u043C\u044B \u0438 \u043C\u044B\u0448\u044C\u044F\u043A\u0430.
    \u0412 1970-\u0445 \u0433\u043E\u0434\u0430\u0445 \u0443\u0447\u0435\u043D\u044B\u0435
    \u043F\u0440\u043E\u0430\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u043F\u0440\u044F\u0434\u044C \u0435\u0433\u043E \u0432\u043E\u043B\u043E\u0441
    \u0438 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B\u0438 \u0432 \u043D\u0435\u0439
    \u043A\u043E\u043D\u0446\u0435\u043D\u0442\u0440\u0430\u0446\u0438\u044E \u0440\u0442\u0443\u0442\u0438,
    \u043F\u0440\u0435\u0432\u044B\u0448\u0430\u044E\u0449\u0443\u044E \u043D\u043E\u0440\u043C\u0443
    \u0432 **15\u201320 \u0440\u0430\u0437**! \u042D\u0442\u043E \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0435\u0442
    \u0435\u0433\u043E \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u044B \u0431\u0435\u0437\u0443\u043C\u0438\u044F
    (\u043F\u0430\u0440\u0430\u043D\u043E\u0439\u044F, \u043F\u043E\u0442\u0435\u0440\u044F
    \u043F\u0430\u043C\u044F\u0442\u0438) \u0432 1693 \u0433\u043E\u0434\u0443. -
    **\u0428\u0438\u0444\u0440\u044B**: \u0411\u043E\u044F\u0441\u044C \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u0438
    (\u0437\u0430\u043D\u044F\u0442\u0438\u044F \u0430\u043B\u0445\u0438\u043C\u0438\u0435\u0439
    \u0432 \u0410\u043D\u0433\u043B\u0438\u0438 \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u0437\u0430\u043A\u043E\u043D\u043E\u043C), \u041D\u044C\u044E\u0442\u043E\u043D
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u043B \u0441\u0432\u043E\u0438
    \u0440\u0435\u0446\u0435\u043F\u0442\u044B \u043D\u0430 \u043B\u0430\u0442\u044B\u043D\u0438,
    \u0430 \u0438\u043D\u043E\u0433\u0434\u0430 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043D\u043D\u044B\u0439 \u0438\u043C
    \u0430\u043B\u0444\u0430\u0432\u0438\u0442, \u0447\u0442\u043E\u0431\u044B \u043D\u0438\u043A\u0442\u043E
    \u043D\u0435 \u043F\u043E\u043D\u044F\u043B, \u0447\u0435\u043C \u043E\u043D
    \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442\u0441\u044F.  ---  ### \U0001F575\uFE0F
    5. \u041E\u0445\u043E\u0442\u043D\u0438\u043A \u043D\u0430 \u0444\u0430\u043B\u044C\u0448\u0438\u0432\u043E\u043C\u043E\u043D\u0435\u0442\u0447\u0438\u043A\u043E\u0432:
    \u0421\u0443\u0434\u044C\u044F, \u043F\u0440\u0438\u0441\u044F\u0436\u043D\u044B\u0439
    \u0438 \u043F\u0430\u043B\u0430\u0447  \u0420\u0430\u0431\u043E\u0442\u0430 \u043D\u0430
    \u041C\u043E\u043D\u0435\u0442\u043D\u043E\u043C \u0434\u0432\u043E\u0440\u0435
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u0441\u043A\u0443\u0447\u043D\u0430\u044F
    \u0431\u044E\u0440\u043E\u043A\u0440\u0430\u0442\u0438\u044F. \u042D\u0442\u043E
    \u0431\u044B\u043B \u043A\u0440\u0438\u043C\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0431\u043E\u0435\u0432\u0438\u043A \u0441 \u0443\u0447\u0430\u0441\u0442\u0438\u0435\u043C
    \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u0444\u0438\u0437\u0438\u043A\u0430. 
    - **\u041E\u043F\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430**:
    \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u0435\u0440\u0435\u043E\u0434\u0435\u0432\u0430\u043B\u0441\u044F
    \u0432 \u043F\u0440\u043E\u0441\u0442\u0443\u044E \u043E\u0434\u0435\u0436\u0434\u0443
    \u0438 \u043B\u0438\u0447\u043D\u043E \u0445\u043E\u0434\u0438\u043B \u043F\u043E
    \u043B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u0438\u043C \u0442\u0430\u0432\u0435\u0440\u043D\u0430\u043C
    \u0438 \u0442\u0440\u0443\u0449\u043E\u0431\u0430\u043C, \u0432\u044B\u0434\u0430\u0432\u0430\u044F
    \u0441\u0435\u0431\u044F \u0437\u0430 \u043F\u044C\u044F\u043D\u043E\u0433\u043E
    \u0438\u0440\u043B\u0430\u043D\u0434\u0441\u043A\u043E\u0433\u043E \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0430,
    \u0447\u0442\u043E\u0431\u044B \u043A\u0443\u043F\u0438\u0442\u044C \u043F\u043E\u0434\u0434\u0435\u043B\u044C\u043D\u044B\u0435
    \u043C\u043E\u043D\u0435\u0442\u044B \u0438 \u0432\u044B\u0439\u0442\u0438 \u043D\u0430
    \u0441\u043B\u0435\u0434 \u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043D\u0438\u043A\u043E\u0432.
    - **\u041A\u0430\u0437\u043D\u044C \u0427\u0430\u043B\u043E\u043D\u043E\u0440\u0430**:
    \u0421\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0444\u0430\u043B\u044C\u0448\u0438\u0432\u043E\u043C\u043E\u043D\u0435\u0442\u0447\u0438\u043A
    \u0410\u043D\u0433\u043B\u0438\u0438, \u0423\u0438\u043B\u044C\u044F\u043C \u0427\u0430\u043B\u043E\u043D\u043E\u0440,
    \u0431\u044B\u043B \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u044B\u043C
    \u0438 \u043D\u0430\u0433\u043B\u044B\u043C. \u041E\u043D \u0431\u0440\u043E\u0441\u0438\u043B
    \u0432\u044B\u0437\u043E\u0432 \u041D\u044C\u044E\u0442\u043E\u043D\u0443 \u043E\u0442\u043A\u0440\u044B\u0442\u043E.
    \u041D\u044C\u044E\u0442\u043E\u043D 2 \u0433\u043E\u0434\u0430 \u0441\u043E\u0431\u0438\u0440\u0430\u043B
    \u043D\u0430 \u043D\u0435\u0433\u043E \u0434\u043E\u0441\u044C\u0435, \u0430
    \u0437\u0430\u0442\u0435\u043C \u043B\u0438\u0447\u043D\u043E \u0441\u0442\u0440\u043E\u0438\u043B
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0432 \u0441\u0443\u0434\u0435. \u0427\u0430\u043B\u043E\u043D\u043E\u0440\u0430
    \u043F\u043E\u0432\u0435\u0441\u0438\u043B\u0438, \u043D\u043E \u041D\u044C\u044E\u0442\u043E\u043D
    \u0434\u043E\u0431\u0438\u043B\u0441\u044F, \u0447\u0442\u043E\u0431\u044B \u043F\u0435\u0440\u0435\u0434
    \u043A\u0430\u0437\u043D\u044C\u044E \u0435\u0433\u043E \u043F\u0440\u043E\u0432\u0435\u0437\u043B\u0438
    \u043F\u043E \u0433\u043E\u0440\u043E\u0434\u0443 \u0432 \u0442\u0435\u043B\u0435\u0436\u043A\u0435
    \u0441 \u043F\u0435\u0442\u043B\u0435\u0439 \u043D\u0430 \u0448\u0435\u0435 \u0438
    \u043F\u044B\u0442\u0430\u043B\u0438 (\u044D\u0442\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u043E\u0441\u044C
    \xAB\u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\u043E\u043C \u0437\u0430
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0438\u0437\u043C\u0435\u043D\u0443\xBB).  - **\u041C\u0435\u0442\u043E\u0434\u044B
    \u0434\u043E\u043F\u0440\u043E\u0441\u0430**: \u041D\u044C\u044E\u0442\u043E\u043D
    \u0437\u0430\u043F\u0443\u0433\u0438\u0432\u0430\u043B \u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043D\u0438\u043A\u043E\u0432,
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044F, \u0447\u0442\u043E \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442
    \xAB\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E\xBB \u0432 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u0432\u0435\u0441\u0430 \u0440\u0430\u0441\u043F\u043B\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u0441\u0435\u0440\u0435\u0431\u0440\u0430, \u0438 \u043B\u044E\u0431\u043E\u0439
    \u043E\u0431\u043C\u0430\u043D \u043E\u043D \u0440\u0430\u0441\u043A\u0440\u043E\u0435\u0442
    \u0434\u043E \u0434\u043E\u043B\u0435\u0439 \u0433\u0440\u0430\u043C\u043C\u0430. 
    ---  ### \U0001F4CF 6. \u0413\u0440\u0430\u0444\u043E\u043C\u0430\u043D \u0438
    \u044D\u0433\u043E\u0438\u0441\u0442: \u041A\u0440\u0438\u0432\u043E\u0435 \u0437\u0435\u0440\u043A\u0430\u043B\u043E
    \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u0438  - **\xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB
    \u2014 \u0445\u0438\u0442\u0440\u043E\u0441\u0442\u044C \u0441 \u043C\u0430\u0441\u0441\u043E\u0439**:
    \u0412 \u0441\u0432\u043E\u0438\u0445 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445
    \xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0447\u0430\u043B\u0430\u0445\xBB \u041D\u044C\u044E\u0442\u043E\u043D
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u0438\u0437\u043B\u043E\u0436\u0438\u043B
    \u0432\u0441\u0435 \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0441\u0442\u0438\u043B\u0435 (\u043A\u0430\u043A \u0434\u0440\u0435\u0432\u043D\u0438\u0435
    \u0433\u0440\u0435\u043A\u0438), \u0445\u043E\u0442\u044F \u0441\u0430\u043C
    \u0434\u043B\u044F \u0440\u0430\u0441\u0447\u0435\u0442\u043E\u0432 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u043C\u0435\u0442\u043E\u0434 \u0444\u043B\u044E\u043A\u0441\u0438\u0439
    (\u0430\u043D\u0430\u043B\u0438\u0437). \u0417\u0430\u0447\u0435\u043C? \u0427\u0442\u043E\u0431\u044B
    \u043D\u0438\u043A\u0442\u043E \u043D\u0435 \u043F\u043E\u043D\u044F\u043B, \u043A\u0430\u043A
    \u043E\u043D \u043F\u0440\u0438\u0448\u0435\u043B \u043A \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0443.
    \u041E\u043D \u043F\u0438\u0441\u0430\u043B: *\xAB\u0427\u0442\u043E\u0431\u044B
    \u0438\u0437\u0431\u0435\u0436\u0430\u0442\u044C \u043F\u0440\u0438\u0434\u0438\u0440\u043E\u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u044F \u0438\u0437\u043B\u043E\u0436\u0443
    \u0432\u0441\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\xBB*,
    \u043D\u043E \u043D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435
    \u043E\u043D \u0445\u043E\u0442\u0435\u043B, \u0447\u0442\u043E\u0431\u044B \u043A\u043E\u043D\u043A\u0443\u0440\u0435\u043D\u0442\u044B
    \u043D\u0435 \u0443\u043A\u0440\u0430\u043B\u0438 \u0435\u0433\u043E \u043C\u0435\u0442\u043E\u0434.
    - **\u0414\u043B\u0438\u043D\u043D\u044B\u0439 \u043D\u043E\u0441 \u0438 \u043E\u0431\u0438\u0434\u044B**:
    \u041D\u044C\u044E\u0442\u043E\u043D \u0431\u044B\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043E\u0431\u0438\u0434\u0447\u0438\u0432. \u041E\u043D \u043C\u043E\u0433 \u0433\u043E\u0434\u0430\u043C\u0438
    \u043D\u0435 \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u0442\u044C
    \u0441 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0441\u043C\u0435\u043B \u0443\u0441\u043E\u043C\u043D\u0438\u0442\u044C\u0441\u044F
    \u0432 \u0435\u0433\u043E \u0440\u0430\u0441\u0447\u0435\u0442\u0430\u0445. \u041F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0413\u0443\u043A\u0430 (\u0441\u0432\u043E\u0435\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E \u0432\u0440\u0430\u0433\u0430)
    \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u0440\u0438\u043A\u0430\u0437\u0430\u043B
    \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u0442\u044C \u0435\u0433\u043E
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442 \u0432 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u043C
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435. \u0414\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440 \u043C\u044B \u043D\u0435 \u0437\u043D\u0430\u0435\u043C,
    \u043A\u0430\u043A \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u043B \u0420\u043E\u0431\u0435\u0440\u0442
    \u0413\u0443\u043A \u2014 \u044D\u0442\u043E \u043C\u0435\u0441\u0442\u044C,
    \u043F\u0440\u043E\u0434\u043B\u0438\u0432\u0448\u0430\u044F\u0441\u044F \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F. 
    ---  ### \U0001F37A 7. \u0411\u044B\u0442\u043E\u0432\u044B\u0435 \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0441\u0442\u0438 
    - **\u0411\u0435\u0437\u0440\u0430\u0437\u043B\u0438\u0447\u0438\u0435 \u043A
    \u0435\u0434\u0435**: \u0420\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0441\u0442\u044C
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u0432\u043E\u0448\u043B\u0430 \u0432
    \u043B\u0435\u0433\u0435\u043D\u0434\u044B. \u041E\u0434\u043D\u0430\u0436\u0434\u044B,
    \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u044F\u044F \u043D\u0430\u0434 \u0437\u0430\u0434\u0430\u0447\u0435\u0439,
    \u043E\u043D \u0441\u0432\u0430\u0440\u0438\u043B **\u043A\u0430\u0440\u043C\u0430\u043D\u043D\u044B\u0435
    \u0447\u0430\u0441\u044B \u0432\u043C\u0435\u0441\u0442\u043E \u044F\u0439\u0446\u0430**,
    \u0434\u0435\u0440\u0436\u0430 \u0438\u0445 \u0432 \u043A\u0438\u043F\u044F\u0449\u0435\u0439
    \u0432\u043E\u0434\u0435 \u0438 \u0441 \u0443\u0434\u0438\u0432\u043B\u0435\u043D\u0438\u0435\u043C
    \u0433\u043B\u044F\u0434\u044F \u043D\u0430 \xAB\u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0435
    \u044F\u0439\u0446\u043E\xBB. \u0412 \u0434\u0440\u0443\u0433\u043E\u0439 \u0440\u0430\u0437,
    \u043A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E \u043F\u043E\u0437\u0432\u0430\u043B\u0438
    \u043E\u0431\u0435\u0434\u0430\u0442\u044C, \u043E\u043D \u0432\u044B\u0448\u0435\u043B
    \u0438\u0437 \u043A\u043E\u043C\u043D\u0430\u0442\u044B, \u043D\u043E, \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u043D\u044B\u0439
    \u043C\u044B\u0441\u043B\u044C\u044E, \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0438, \u043D\u0435 \u0434\u043E\u0439\u0434\u044F \u0434\u043E \u0441\u0442\u043E\u043B\u043E\u0432\u043E\u0439,
    \u0441\u0435\u043B \u0437\u0430 \u0440\u0430\u0431\u043E\u0447\u0438\u0439 \u0441\u0442\u043E\u043B,
    \u0437\u0430\u0431\u044B\u0432 \u043F\u043E\u0435\u0441\u0442\u044C. - **\u041F\u0443\u0441\u0442\u043E\u0439
    \u043B\u0435\u043A\u0446\u0438\u043E\u043D\u043D\u044B\u0439 \u0437\u0430\u043B**:
    \u0421\u0442\u0430\u0432 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C,
    \u041D\u044C\u044E\u0442\u043E\u043D \u0447\u0430\u0441\u0442\u043E \u0447\u0438\u0442\u0430\u043B
    \u043B\u0435\u043A\u0446\u0438\u0438 \u043F\u0435\u0440\u0435\u0434 **\u043F\u0443\u0441\u0442\u044B\u043C\u0438
    \u0441\u043A\u0430\u043C\u044C\u044F\u043C\u0438**. \u0421\u0442\u0443\u0434\u0435\u043D\u0442\u044B
    \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u043B\u0438 \u0435\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0438 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B\u0438 \u0445\u043E\u0434\u0438\u0442\u044C.
    \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u0443\u0441\u0442\u0430\u0432\u0443,
    \u043E\u043D \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u043B \u0447\u0438\u0442\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u044E \u0445\u043E\u0442\u044F \u0431\u044B \u0440\u0430\u0437
    \u0432 \u043D\u0435\u0434\u0435\u043B\u044E, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \u043E\u043D \u0432\u0445\u043E\u0434\u0438\u043B \u0432 \u043F\u0443\u0441\u0442\u0443\u044E
    \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u044E, \u043E\u0431\u0440\u0430\u0449\u0430\u043B\u0441\u044F
    \u043A \u0441\u0442\u0435\u043D\u0430\u043C \u0438 \u0443\u0445\u043E\u0434\u0438\u043B.
    \u042D\u0442\u043E \u0435\u0433\u043E \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u043D\u0435 \u0441\u043C\u0443\u0449\u0430\u043B\u043E.  ---  ### \U0001F52E
    8. \u0422\u0435\u043E\u043B\u043E\u0433-\u0435\u0440\u0435\u0442\u0438\u043A
    \u0438 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C
    \u043A\u043E\u043D\u0446\u0430 \u0441\u0432\u0435\u0442\u0430  \u041D\u044C\u044E\u0442\u043E\u043D
    \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0432\u0435\u0440\u0443\u044E\u0449\u0438\u043C,
    \u043D\u043E \u0435\u0433\u043E \u0432\u0435\u0440\u0430 \u0431\u044B\u043B\u0430
    \u0435\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439.  - **\u0410\u043D\u0442\u0438\u0442\u0440\u0438\u043D\u0438\u0442\u0430\u0440\u0438\u0439**:
    \u041E\u043D \u043E\u0442\u0440\u0438\u0446\u0430\u043B \u0434\u043E\u0433\u043C\u0430\u0442
    \u043E \u0421\u0432\u044F\u0442\u043E\u0439 \u0422\u0440\u043E\u0438\u0446\u0435,
    \u0441\u0447\u0438\u0442\u0430\u044F, \u0447\u0442\u043E \u044D\u0442\u043E \u043F\u043E\u0437\u0434\u043D\u0435\u0439\u0448\u0430\u044F
    \u0432\u044B\u0434\u0443\u043C\u043A\u0430 \u0440\u0438\u043C\u0441\u043A\u0438\u0445
    \u043F\u0430\u043F. \u041E\u043D \u0442\u0430\u0439\u043D\u043E \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0442\u0440\u0443\u0434, \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0449\u0438\u0439,
    \u0447\u0442\u043E \u0432 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u0411\u0438\u0431\u043B\u0438\u0438 \u043D\u0435\u0442 \u0441\u043B\u043E\u0432\u0430
    \xAB\u0422\u0440\u043E\u0438\u0446\u0430\xBB. \u041F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F
    \u044D\u0442\u0438\u0445 \u0442\u0440\u0443\u0434\u043E\u0432 \u0431\u044B\u043B\u0430
    \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u0430 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F.
    - **\u0420\u0430\u0441\u0447\u0435\u0442\u044B \u0410\u043F\u043E\u043A\u0430\u043B\u0438\u043F\u0441\u0438\u0441\u0430**:
    \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u0433\u043E\u0434\u044B \u0440\u0430\u0441\u0448\u0438\u0444\u0440\u043E\u0432\u043A\u0435
    \u041A\u043D\u0438\u0433\u0438 \u043F\u0440\u043E\u0440\u043E\u043A\u0430 \u0414\u0430\u043D\u0438\u0438\u043B\u0430
    \u0438 \u041E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u0438\u044F \u0418\u043E\u0430\u043D\u043D\u0430
    \u0411\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0430. \u041E\u043D \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B,
    \u0447\u0442\u043E \u043A\u043E\u043D\u0435\u0446 \u0441\u0432\u0435\u0442\u0430
    \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u0442 **\u043D\u0435 \u0440\u0430\u043D\u0435\u0435
    2060 \u0433\u043E\u0434\u0430**. \u041E\u043D \u043F\u0438\u0441\u0430\u043B:
    *\xAB\u042F \u0433\u043E\u0432\u043E\u0440\u044E \u044D\u0442\u043E \u043D\u0435
    \u0434\u043B\u044F \u0442\u043E\u0433\u043E, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u0432\u0440\u0435\u043C\u044F, \u0430 \u0447\u0442\u043E\u0431\u044B \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u044C
    \u043B\u0436\u0438\u0432\u044B\u0435 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u044F
    \u0444\u0430\u043D\u0430\u0442\u0438\u043A\u043E\u0432\xBB*. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0432\u044B\u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u0418\u0435\u0440\u0443\u0441\u0430\u043B\u0438\u043C\u0441\u043A\u0438\u0439
    \u0445\u0440\u0430\u043C \u0432 \u0434\u0440\u0435\u0432\u043D\u043E\u0441\u0442\u0438
    \u0438\u043C\u0435\u043B \u0442\u043E\u0447\u043D\u044B\u0435 \u0440\u0430\u0437\u043C\u0435\u0440\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043A\u043E\u0434\u0438\u0440\u0443\u044E\u0442
    \u0437\u0430\u043A\u043E\u043D\u044B \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439. 
    ---  ### \U0001F3AD 9. \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u0440\u043E\u0442\u0438\u0432
    \u043C\u043E\u0440\u044F\u043A\u043E\u0432 \u0438 \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB
    \u043A\u0430\u043A \u044F\u0434  \u041F\u043E\u0441\u043B\u0435 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438
    \xAB\u041D\u0430\u0447\u0430\u043B\xBB \u0432\u0441\u0435 \u0434\u0443\u043C\u0430\u043B\u0438,
    \u0447\u0442\u043E \u043A\u043D\u0438\u0433\u0430 \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E
    \u043F\u043E\u043C\u043E\u0433\u043B\u0430 \u043C\u043E\u0440\u0435\u043F\u043B\u0430\u0432\u0430\u0442\u0435\u043B\u044F\u043C.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0441\u0430\u043C \u041D\u044C\u044E\u0442\u043E\u043D
    \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0441\u044F \u043A \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043E\u043B\u044C\u0437\u0435 \u043F\u0440\u043E\u0445\u043B\u0430\u0434\u043D\u043E. 
    - *\u0421\u043B\u0443\u0447\u0430\u0439 \u0441 \u0413\u0430\u043B\u043B\u0435\u0435\u043C*:
    \u041A\u043E\u0433\u0434\u0430 \u042D\u0434\u043C\u0443\u043D\u0434 \u0413\u0430\u043B\u043B\u0435\u0439
    \u0441\u043F\u0440\u043E\u0441\u0438\u043B \u041D\u044C\u044E\u0442\u043E\u043D\u0430,
    \u043A\u0430\u043A \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u044B \u0434\u043E\u043B\u0436\u043D\u044B
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044E
    \u0442\u044F\u0433\u043E\u0442\u0435\u043D\u0438\u044F \u0434\u043B\u044F \u043D\u0430\u0432\u0438\u0433\u0430\u0446\u0438\u0438,
    \u041D\u044C\u044E\u0442\u043E\u043D \u043E\u0442\u0432\u0435\u0442\u0438\u043B
    \u0441 \u043F\u0440\u0435\u0437\u0440\u0435\u043D\u0438\u0435\u043C: *\xAB\u042F
    \u0441\u043E\u0437\u0434\u0430\u044E \u0443\u0447\u0435\u043D\u0438\u044F \u0434\u043B\u044F
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u0432, \u0430 \u043D\u0435 \u0434\u043B\u044F
    \u043C\u043E\u0440\u044F\u043A\u043E\u0432\xBB*. \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B
    \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u0443\u044E \u043D\u0430\u0443\u043A\u0443
    \u043D\u0438\u0436\u0435 \u0441\u0432\u043E\u0435\u0433\u043E \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u0430. 
    ---  ### \U0001FAA6 10. \u0421\u043C\u0435\u0440\u0442\u044C \u0438 \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u0439
    \u043A\u0443\u0440\u044C\u0435\u0437  - **\u041D\u0435\u043F\u0440\u0438\u043D\u044F\u0442\u0438\u0435
    \u043F\u0440\u0438\u0447\u0430\u0441\u0442\u0438\u044F**: \u0423\u043C\u0438\u0440\u0430\u044F
    \u0432 \u043C\u0430\u0440\u0442\u0435 1727 \u0433\u043E\u0434\u0430, \u041D\u044C\u044E\u0442\u043E\u043D
    \u043D\u0430\u043E\u0442\u0440\u0435\u0437 \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u0441\u043E\u0431\u043E\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    (\u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0433\u043E \u043F\u0440\u0438\u0447\u0430\u0441\u0442\u0438\u044F).
    \u0421\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u043B,
    \u043D\u043E \u041D\u044C\u044E\u0442\u043E\u043D \u043E\u0442\u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u043A \u0441\u0442\u0435\u043D\u0435. \u0414\u043B\u044F \u0432\u0438\u043A\u0442\u043E\u0440\u0438\u0430\u043D\u0441\u043A\u043E\u0439
    \u0410\u043D\u0433\u043B\u0438\u0438 \u044D\u0442\u043E \u0431\u044B\u043B\u043E
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u044C\u043D\u043E,
    \u0447\u0442\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u044B \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0435
    \u0441\u043A\u0440\u044B\u0432\u0430\u043B\u0438 \u044D\u0442\u043E\u0442 \u0444\u0430\u043A\u0442.
    - **\u0413\u0434\u0435 \u0435\u0433\u043E \u043C\u043E\u0437\u0433?**: \u0412\u0441\u043A\u0440\u044B\u0442\u0438\u0435
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u043E, \u0447\u0442\u043E \u0443 \u043D\u0435\u0433\u043E
    \u0432 \u043F\u043E\u0447\u043A\u0430\u0445 \u0431\u044B\u043B\u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435
    \u043A\u0430\u043C\u043D\u0438 (\u0440\u0430\u0437\u043C\u0435\u0440\u043E\u043C
    \u0441 \u043B\u0435\u0441\u043D\u043E\u0439 \u043E\u0440\u0435\u0445), \u0430
    \u0432 \u043C\u043E\u0437\u0433\u0435 \u2014 \u0441\u043B\u0435\u0434\u044B \u0441\u0438\u043B\u044C\u043D\u043E\u0433\u043E
    \u0441\u043A\u043B\u0435\u0440\u043E\u0437\u0430. \u041E\u0434\u043D\u0430\u043A\u043E
    **\u043D\u0438 \u0435\u0433\u043E \u043C\u043E\u0437\u0433, \u043D\u0438 \u0441\u0435\u0440\u0434\u0446\u0435
    \u043D\u0435 \u0431\u044B\u043B\u0438 \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u044B**
    \u2014 \u0438\u0445 \u043F\u0440\u043E\u0441\u0442\u043E \u0432\u044B\u0431\u0440\u043E\u0441\u0438\u043B\u0438
    \u043F\u0440\u0438 \u0431\u0430\u043B\u044C\u0437\u0430\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438,
    \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043C\u043E\u0437\u0433\u0430
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0437\u0436\u0435 \u0443\u043A\u0440\u0430\u043B\u0438. - **\u041A\u043E\u0441\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043E\u0431\u043C\u0430\u043D**: \u0413\u0440\u043E\u0431\u043E\u0432\u0449\u0438\u043A\u0438,
    \u0433\u043E\u0442\u043E\u0432\u044F \u0442\u0435\u043B\u043E \u043A \u0432\u044B\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044E
    \u0432 \u0412\u0435\u0441\u0442\u043C\u0438\u043D\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u043C
    \u0430\u0431\u0431\u0430\u0442\u0441\u0442\u0432\u0435, \u043F\u043E\u043D\u044F\u043B\u0438,
    \u0447\u0442\u043E \u043B\u0438\u0446\u043E \u0441\u0438\u043B\u044C\u043D\u043E
    \u0440\u0430\u0437\u043B\u043E\u0436\u0438\u043B\u043E\u0441\u044C. \u041E\u043D\u0438
    \u043D\u0430\u0434\u0435\u043B\u0438 \u043D\u0430 \u0442\u0440\u0443\u043F **\u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u0443\u044E
    \u0432\u043E\u0441\u043A\u043E\u0432\u0443\u044E \u043C\u0430\u0441\u043A\u0443**,
    \u0440\u0430\u0441\u043A\u0440\u0430\u0441\u0438\u043B\u0438 \u0435\u0451 \u0440\u0443\u043C\u044F\u043D\u0430\u043C\u0438,
    \u0438 \u0432 \u0442\u0430\u043A\u043E\u043C \xAB\u043F\u0440\u0438\u0447\u0435\u0441\u0430\u043D\u043D\u043E\u043C\xBB
    \u0432\u0438\u0434\u0435 \u041D\u044C\u044E\u0442\u043E\u043D \u043B\u0435\u0436\u0430\u043B
    \u0432 \u0433\u0440\u043E\u0431\u0443, \u043F\u043E\u043A\u0430 \u0442\u043E\u043B\u043F\u044B
    \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B\u0438 \u043C\u0438\u043C\u043E,
    \u0434\u0443\u043C\u0430\u044F, \u0447\u0442\u043E \u0432\u0438\u0434\u044F\u0442
    \u0436\u0438\u0432\u043E\u0433\u043E \u0433\u0435\u043D\u0438\u044F.  ---  ###
    \U0001F4DC \u0411\u043E\u043D\u0443\u0441: \u0421\u0430\u043C\u044B\u0439 \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0439
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442  \u041D\u044C\u044E\u0442\u043E\u043D
    \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
    \u0447\u0442\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0435
    \u0437\u0440\u0435\u043D\u0438\u0435 \u0441\u0432\u044F\u0437\u0430\u043D\u043E
    \u0441 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C \u043D\u0430 \u0433\u043B\u0430\u0437\u043D\u044B\u0435
    \u044F\u0431\u043B\u043E\u043A\u0438. \u041D\u043E \u043E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043E\u043D \u0440\u0435\u0448\u0438\u043B \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C,
    \u043C\u043E\u0433\u0443\u0442 \u043B\u0438 **\u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u044B\u0435
    \u0437\u0432\u0443\u043A\u0438** \u0432\u044B\u0437\u044B\u0432\u0430\u0442\u044C
    \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u044F \u0432 \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0438
    \u0433\u043B\u0430\u0437\u0430. \u041E\u043D \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u043B
    \u0441\u043B\u0443\u0433\u0443 \u0438\u0433\u0440\u0430\u0442\u044C \u043D\u0430
    \u0441\u043A\u0440\u0438\u043F\u043A\u0435, \u043F\u043E\u043A\u0430 \u0441\u0430\u043C
    \u0441\u043C\u043E\u0442\u0440\u0435\u043B \u0432 \u0437\u0435\u0440\u043A\u0430\u043B\u043E,
    \u043F\u044B\u0442\u0430\u044F\u0441\u044C \u0437\u0430\u043C\u0435\u0442\u0438\u0442\u044C,
    \u043A\u0430\u043A \u0432\u0438\u0431\u0440\u0438\u0440\u0443\u0435\u0442 \u0435\u0433\u043E
    \u0437\u0440\u0430\u0447\u043E\u043A. \u0415\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E,
    \u043E\u043D \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u0437\u0430\u043C\u0435\u0442\u0438\u043B,
    \u043D\u043E \u0437\u0430\u043A\u043B\u044E\u0447\u0438\u043B, \u0447\u0442\u043E
    \xAB\u0437\u0432\u0443\u043A \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0441\u043B\u0430\u0431
    \u0434\u043B\u044F \u0441\u0435\u0442\u0447\u0430\u0442\u043A\u0438\xBB.  \u0418\u0441\u0430\u0430\u043A
    \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u0440\u043E\u0436\u0438\u043B \u0436\u0438\u0437\u043D\u044C,
    \u043F\u043E\u043B\u043D\u0443\u044E \u0431\u0435\u0437\u0443\u043C\u043D\u044B\u0445
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0439: \u043E\u043D
    \u0431\u044B\u043B \u043F\u0443\u0440\u0438\u0442\u0430\u043D\u0438\u043D\u043E\u043C
    \u0438 \u043C\u0438\u0441\u0442\u0438\u043A\u043E\u043C, \u0430\u0441\u043A\u0435\u0442\u043E\u043C
    \u0438 \u043C\u0441\u0442\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C \u0438\u043D\u0442\u0440\u0438\u0433\u0430\u043D\u043E\u043C,
    \u0433\u0435\u043D\u0438\u0435\u043C \u0438 \u0431\u0435\u0437\u0443\u043C\u0446\u0435\u043C.
    \u0418 \u0438\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u043E\u0442 \u043A\u043E\u043A\u0442\u0435\u0439\u043B\u044C
    \u0441\u0434\u0435\u043B\u0430\u043B \u0435\u0433\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443\u043B
    \u043C\u0438\u0440."
