  wikiTitleRu: "\u0413\u0430\u0443\u0441\u0441, \u041A\u0430\u0440\u043B \u0424\u0440\u0438\u0434\u0440\u0438\u0445"
  wikidataId: Q6722
  fullNameRu: "\u0413\u0430\u0443\u0441\u0441, \u041A\u0430\u0440\u043B \u0424\u0440\u0438\u0434\u0440\u0438\u0445"
  fullNameEn: Carl Friedrich Gauss
  birthDate: "30 \u0430\u043F\u0440\u0435\u043B\u044F 1777"
  deathDate: "23 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 1855"
  countryKeys:
