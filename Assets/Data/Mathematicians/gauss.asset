  achievementsRu: "\u0415\u0441\u043B\u0438 \u0436\u0438\u0437\u043D\u044C \u0413\u0430\u0443\u0441\u0441\u0430
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0441\u0430\u043C\u043E\u0443\u0447\u043A\u0438, \u043F\u043E\u043B\u0443\u0447\u0438\u0432\u0448\u0435\u0433\u043E
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435, \u0442\u043E \u0435\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u2014 \u044D\u0442\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0441\u0442\u043E\u0438\u0442
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F \u0442\u043E\u0447\u043D\u0430\u044F
    \u043D\u0430\u0443\u043A\u0430. \u0423\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0413\u0430\u0443\u0441\u0441\u0430 \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E
    \u043E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0435\u0448\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438;
    \u043E\u043D \u043A\u0430\u0436\u0434\u044B\u0439 \u0440\u0430\u0437 **\u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u043B
    \u043D\u043E\u0432\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442** \u0434\u043B\u044F \u0438\u0445
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F.  \u0427\u0442\u043E\u0431\u044B \u043E\u0445\u0432\u0430\u0442\u0438\u0442\u044C
    \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u0441\u0438\u0441\u0442\u0435\u043C\u043D\u043E,
    \u0440\u0430\u0437\u043E\u0431\u044C\u0435\u043C \u0435\u0433\u043E \u043D\u0430
    \u043F\u044F\u0442\u044C \u0433\u0438\u0433\u0430\u043D\u0442\u0441\u043A\u0438\u0445
    \u0431\u043B\u043E\u043A\u043E\u0432: **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B**, **\u0410\u043B\u0433\u0435\u0431\u0440\u0430
    \u0438 \u0430\u043D\u0430\u043B\u0438\u0437**, **\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F**,
    **\u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F \u0438 \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u044F**,
    \u0430 \u0442\u0430\u043A\u0436\u0435 **\u0424\u0438\u0437\u0438\u043A\u0430**. 
    \u041D\u0438\u0436\u0435 \u043F\u0440\u0438\u0432\u0435\u0434\u0435\u043D \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0441\u043F\u0438\u0441\u043E\u043A \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439 \u0441 \u043F\u043E\u044F\u0441\u043D\u0435\u043D\u0438\u044F\u043C\u0438
    \u0438\u0445 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0441\u0442\u0438. 
    ### 1. \u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B (\xAB\u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB) \u0413\u0430\u0443\u0441\u0441
    \u0441\u0447\u0438\u0442\u0430\u043B \u0442\u0435\u043E\u0440\u0438\u044E \u0447\u0438\u0441\u0435\u043B
    \xAB\u0446\u0430\u0440\u0438\u0446\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB.
    \u0415\u0433\u043E \u0442\u0440\u0443\u0434 *\xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\xBB*
    (1801) \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0432 \u044D\u0442\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043F\u0435\u0440\u0435\u0432\u043E\u0440\u043E\u0442,
    \u0441\u0440\u0430\u0432\u043D\u0438\u043C\u044B\u0439 \u0441 \xAB\u041D\u0430\u0447\u0430\u043B\u0430\u043C\u0438\xBB
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430.  *   **\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430
    \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 (Modular arithmetic):**
    \u0413\u0430\u0443\u0441\u0441 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u0432\u0432\u0435\u043B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E
    \u0437\u0430\u043F\u0438\u0441\u044C \u0434\u043B\u044F \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u043F\u043E \u043C\u043E\u0434\u0443\u043B\u044E (\\( a \\equiv b \\pmod{m}
    \\)). \u042D\u0442\u043E \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u043E
    \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0435 \u0444\u0430\u043A\u0442\u044B
    \u043E \u0434\u0435\u043B\u0438\u043C\u043E\u0441\u0442\u0438 \u0432 \u0441\u0442\u0440\u043E\u0433\u0443\u044E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u0435\u0439\u0447\u0430\u0441 \u043B\u0435\u0436\u0438\u0442 \u0432 \u043E\u0441\u043D\u043E\u0432\u0435
    \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u0438
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u044B\u0445 \u043D\u0430\u0443\u043A.
    *   **\u041A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0439
    \u0437\u0430\u043A\u043E\u043D \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438:**
    \u0413\u0430\u0443\u0441\u0441 \u0434\u0430\u043B \u043F\u0435\u0440\u0432\u043E\u0435
    \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u044D\u0442\u043E\u0439 \xAB\u0437\u043E\u043B\u043E\u0442\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B\xBB
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B (\u0440\u0430\u043D\u0435\u0435
    \u0435\u0451 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u042D\u0439\u043B\u0435\u0440, \u0430 \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C).
    \u0413\u0430\u0443\u0441\u0441 \u0431\u044B\u043B \u0442\u0430\u043A \u043F\u043E\u0440\u0430\u0436\u0435\u043D
    \u043A\u0440\u0430\u0441\u043E\u0442\u043E\u0439 \u044D\u0442\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B,
    \u0447\u0442\u043E \u0437\u0430 \u0441\u0432\u043E\u044E \u0436\u0438\u0437\u043D\u044C
    \u043D\u0430\u0448\u0435\u043B **\u0448\u0435\u0441\u0442\u044C \u0440\u0430\u0437\u043D\u044B\u0445**
    \u0435\u0451 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432,
    \u043A\u0430\u0436\u0434\u043E\u0435 \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u043B\u043E \u043D\u043E\u0432\u044B\u0435
    \u0432\u0435\u0442\u0432\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0431\u0438\u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0445
    \u0432\u044B\u0447\u0435\u0442\u043E\u0432:** \u0412 \u044D\u0442\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 \u043E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u0440\u043E\u0434\u0432\u0438\u043D\u0443\u043B \u0442\u0435\u043E\u0440\u0438\u044E
    \u0447\u0438\u0441\u0435\u043B, \u043D\u043E \u0438 \u043E\u0442\u043A\u0440\u044B\u043B
    \u043F\u0443\u0442\u044C \u043A **\u0430\u043B\u0433\u0435\u0431\u0440\u0435
    \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B**
    (\u0433\u0430\u0443\u0441\u0441\u043E\u0432\u044B \u0446\u0435\u043B\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430 \\( a + bi \\)), \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0441\u043E\u0437\u0434\u0430\u0432 \u043E\u0441\u043D\u043E\u0432\u044B \u0442\u0435\u043E\u0440\u0438\u0438
    \u043A\u043E\u043B\u0435\u0446. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u043B\u0430\u0445:**
    \u0425\u043E\u0442\u044F \u043E\u043D \u043D\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0435\u0451 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E (\u044D\u0442\u043E
    \u0441\u0434\u0435\u043B\u0430\u043B\u0438 \u043F\u043E\u0437\u0436\u0435 \u0427\u0435\u0431\u044B\u0448\u0451\u0432
    \u0438 \u0410\u0434\u0430\u043C\u0430\u0440), \u0413\u0430\u0443\u0441\u0441
    \u044D\u043C\u043F\u0438\u0440\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u044B\u0432\u0435\u043B
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B (\\(
    \\pi(x) \\sim x / \\ln x \\)) \u0438 \u0443\u043A\u0430\u0437\u0430\u043B \u043F\u0443\u0442\u0438
    \u043A \u0435\u0451 \u0441\u0442\u0440\u043E\u0433\u043E\u043C\u0443 \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044E. 
    ---  ### 2. \u0410\u043B\u0433\u0435\u0431\u0440\u0430 \u0438 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0417\u0434\u0435\u0441\u044C \u0413\u0430\u0443\u0441\u0441
    \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B \u043A\u0430\u043A \xAB\u0445\u0438\u0440\u0443\u0440\u0433\xBB
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0443\u0441\u0442\u0440\u0430\u043D\u044F\u044F
    \u043D\u0435\u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u0438, \u043D\u0430\u043A\u043E\u043F\u043B\u0435\u043D\u043D\u044B\u0435
    \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u0438 \u042D\u0439\u043B\u0435\u0440\u0430.  *   **\u041E\u0441\u043D\u043E\u0432\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u0430\u043B\u0433\u0435\u0431\u0440\u044B:**
    \u0412 \u0441\u0432\u043E\u0435\u0439 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u043E\u0439
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438 (1799) \u0413\u0430\u0443\u0441\u0441
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E *\u043B\u044E\u0431\u043E\u0435
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \u0438\u043C\u0435\u0435\u0442
    \u0445\u043E\u0442\u044F \u0431\u044B \u043E\u0434\u0438\u043D \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u0439
    \u043A\u043E\u0440\u0435\u043D\u044C*. \u042D\u0442\u043E \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C
    \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u043E \u043F\u043E\u043D\u044F\u0442\u043D\u044B\u043C,
    \u043D\u043E \u0441\u0442\u0440\u043E\u0433\u043E\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043D\u0435 \u0431\u044B\u043B\u043E. \u0413\u0430\u0443\u0441\u0441 \u0434\u0430\u043B
    **\u0447\u0435\u0442\u044B\u0440\u0435** \u0440\u0430\u0437\u043D\u044B\u0445
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438 \u0436\u0438\u0437\u043D\u0438,
    \u043F\u0440\u0438\u0447\u0435\u043C \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435
    \u0431\u044B\u043B\u043E \u0447\u0438\u0441\u0442\u043E \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0438 \u043D\u0435 \u043E\u043F\u0438\u0440\u0430\u043B\u043E\u0441\u044C \u043D\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E. *   **\u041C\u0435\u0442\u043E\u0434
    \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0438\u0445 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432:**
    \u0425\u043E\u0442\u044F \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434 \u043F\u0435\u0440\u0432\u044B\u043C,
    \u0413\u0430\u0443\u0441\u0441 \u0437\u0430\u044F\u0432\u0438\u043B \u043E \u0441\u0432\u043E\u0435\u043C
    \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0435 (\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0435\u0449\u0435 \u0432 1794 \u0433\u043E\u0434\u0443).
    \u0421\u0443\u0442\u044C: \u0434\u043B\u044F \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043D\u0430\u0438\u043B\u0443\u0447\u0448\u0438\u0445 \u043F\u0430\u0440\u0430\u043C\u0435\u0442\u0440\u043E\u0432
    \u043C\u043E\u0434\u0435\u043B\u0438 \u043D\u0443\u0436\u043D\u043E \u043C\u0438\u043D\u0438\u043C\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0441\u0443\u043C\u043C\u0443 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432
    \u043E\u0448\u0438\u0431\u043E\u043A. \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    **\u0437\u043E\u043B\u043E\u0442\u044B\u043C \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043E\u043C**
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438, \u044D\u043A\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u043A\u0438
    \u0438 \u043C\u0430\u0448\u0438\u043D\u043D\u043E\u0433\u043E \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u044F.
    *   **\u0410\u043B\u0433\u043E\u0440\u0438\u0442\u043C \u0431\u044B\u0441\u0442\u0440\u043E\u0433\u043E
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0424\u0443\u0440\u044C\u0435 (\u0411\u041F\u0424):** \u0417\u0430\u0434\u043E\u043B\u0433\u043E
    \u0434\u043E \u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u044F \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u0432
    \u0413\u0430\u0443\u0441\u0441 \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    \u0434\u043B\u044F \u0431\u044B\u0441\u0442\u0440\u043E\u0433\u043E \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u043E\u0432
    \u0440\u044F\u0434\u043E\u0432 \u0424\u0443\u0440\u044C\u0435. \u042D\u0442\u043E\u0442
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C \u0431\u044B\u043B \u043F\u0435\u0440\u0435\u043E\u0442\u043A\u0440\u044B\u0442
    \u0432 XX \u0432\u0435\u043A\u0435 \u041A\u0443\u043B\u0438 \u0438 \u0422\u044C\u044E\u043A\u0438
    \u0438 \u0441\u0442\u0430\u043B \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0439
    \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0438 \u0441\u0438\u0433\u043D\u0430\u043B\u043E\u0432
    (\u0441\u0436\u0430\u0442\u0438\u0435 JPEG, MP3, \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442-\u0441\u0432\u044F\u0437\u044C).
    *   **\u0413\u0438\u043F\u0435\u0440\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0440\u044F\u0434:** \u0413\u0430\u0443\u0441\u0441 \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u044D\u0442\u043E\u0442
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0439 \u0440\u044F\u0434
    (\\( {}_2F_1 \\)), \u0441\u043E\u0437\u0434\u0430\u0432 \u0442\u0435\u043E\u0440\u0438\u044E,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u043B\u0430
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0432 \u0435\u0434\u0438\u043D\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443.  ---  ### 3. \u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    (\u041E\u0442 \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u043A \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u044B\u043C
    \u043C\u0438\u0440\u0430\u043C \u0438 \u043A\u0440\u0438\u0432\u0438\u0437\u043D\u0435)
    \u042D\u0442\u043E \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0441\u0434\u0435\u043B\u0430\u043B\u043E \u0413\u0430\u0443\u0441\u0441\u0430
    \u043F\u0440\u0435\u0434\u0442\u0435\u0447\u0435\u0439 \u0444\u0438\u0437\u0438\u043A\u0438
    XX \u0432\u0435\u043A\u0430 (\u041E\u0431\u0449\u0435\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438). 
    *   **\u041F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E\u0433\u043E
    17-\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430:** \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u044E\u043D\u043E\u0433\u043E \u0413\u0430\u0443\u0441\u0441\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B\u043E, \u0447\u0442\u043E \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0435
    \\( n \\)-\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0438 \u043C\u043E\u0436\u043D\u043E
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C \u0446\u0438\u0440\u043A\u0443\u043B\u0435\u043C
    \u0438 \u043B\u0438\u043D\u0435\u0439\u043A\u043E\u0439, \u0435\u0441\u043B\u0438
    \\( n \\) \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0447\u0438\u0441\u043B\u043E\u043C
    \u0424\u0435\u0440\u043C\u0430. \u042D\u0442\u043E \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0440\u0435\u0448\u0438\u043B\u043E \u0432\u043E\u043F\u0440\u043E\u0441, \u043C\u0443\u0447\u0438\u0432\u0448\u0438\u0439
    \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.
    *   **\xAB\u0412\u044B\u0434\u0430\u044E\u0449\u0430\u044F\u0441\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430\xBB
    (Theorema Egregium):** \u0412 \u0440\u0430\u0431\u043E\u0442\u0435 \u043E \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044F\u0445
    (1827) \u0413\u0430\u0443\u0441\u0441 \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E *\u0433\u0430\u0443\u0441\u0441\u043E\u0432\u0430 \u043A\u0440\u0438\u0432\u0438\u0437\u043D\u0430*
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0435\u0451 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u043C \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C
    \u0438 \u043D\u0435 \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F \u043F\u0440\u0438
    \u0438\u0437\u0433\u0438\u0431\u0435 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0435\u0441\u043B\u0438 \u0441\u0432\u0435\u0440\u043D\u0443\u0442\u044C \u043B\u0438\u0441\u0442
    \u0431\u0443\u043C\u0430\u0433\u0438 \u0432 \u0446\u0438\u043B\u0438\u043D\u0434\u0440,
    \u0443\u0433\u043B\u044B \u0438 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    \u043F\u043E \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F \u043F\u0440\u0435\u0436\u043D\u0438\u043C\u0438,
    \u043D\u043E \u0435\u0441\u043B\u0438 \u0441\u043E\u0433\u043D\u0443\u0442\u044C
    \u0441\u0444\u0435\u0440\u0443 \u2014 \u043C\u0435\u043D\u044F\u044E\u0442\u0441\u044F).
    \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C
    \u043A\u0430\u043C\u043D\u0435\u043C **\u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438**. *   **\u041D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:** \u0413\u0430\u0443\u0441\u0441
    \u043F\u0440\u0438\u0448\u0435\u043B \u043A \u0438\u0434\u0435\u0435, \u0447\u0442\u043E
    \u0447\u0435\u0440\u0435\u0437 \u0442\u043E\u0447\u043A\u0443 \u043C\u043E\u0436\u043D\u043E
    \u043F\u0440\u043E\u0432\u0435\u0441\u0442\u0438 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E
    \u043C\u043D\u043E\u0433\u043E \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u044F\u043C\u044B\u0445, \u0438 \u0434\u0430\u0436\u0435 \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u043B
    \u0443\u0433\u043B\u044B \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430 \u0432
    \u0433\u043E\u0440\u0430\u0445, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C,
    \u0438\u0441\u043A\u0440\u0438\u0432\u043B\u0435\u043D\u043E \u043B\u0438 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439. **\u041E\u043D \u0431\u043E\u044F\u043B\u0441\u044F
    \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C \u044D\u0442\u043E**,
    \u043E\u043F\u0430\u0441\u0430\u044F\u0441\u044C \xAB\u043A\u0440\u0438\u043A\u0430
    \u0431\u0435\u043E\u0442\u0438\u0439\u0446\u0435\u0432\xBB (\u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u043E\u0432),
    \u043D\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u0435\u0433\u043E \u0438\u0434\u0435\u0438
    \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u043B\u0438 \u043F\u043E\u0447\u0432\u0443
    \u0434\u043B\u044F \u0420\u0438\u043C\u0430\u043D\u0430 \u0438, \u0447\u0435\u0440\u0435\u0437
    60 \u043B\u0435\u0442, \u0434\u043B\u044F \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430.
    *   **\u0413\u0430\u0443\u0441\u0441\u043E\u0432\u0430 \u043A\u0440\u0438\u0432\u0438\u0437\u043D\u0430
    \u0438 \u043F\u0435\u0440\u0432\u0430\u044F \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u0430\u044F
    \u0444\u043E\u0440\u043C\u0430:** \u0412\u0432\u0435\u043B \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F \u0434\u043B\u0438\u043D
    \u0438 \u0443\u0433\u043B\u043E\u0432 \u043D\u0430 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u043B\u044C\u043D\u044B\u0445
    \u0438\u0441\u043A\u0440\u0438\u0432\u043B\u0435\u043D\u043D\u044B\u0445 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044F\u0445,
    \u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043F\u0440\u044F\u043C\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430-\u0432\u0440\u0435\u043C\u0435\u043D\u0438. 
    ---  ### 4. \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F \u0438
    \u0413\u0435\u043E\u0434\u0435\u0437\u0438\u044F (\u0422\u043E\u0447\u043D\u043E\u0441\u0442\u044C
    \u0434\u043E \u043C\u0438\u043B\u043B\u0438\u043C\u0435\u0442\u0440\u0430) \u0413\u0430\u0443\u0441\u0441
    \u043F\u0440\u0438\u0432\u043D\u0435\u0441 \u0432 \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043D\u0430\u0443\u043A\u0438 \u043C\u0435\u0442\u043E\u0434\u044B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438.  *   **\u0420\u0430\u0441\u0447\u0435\u0442
    \u043E\u0440\u0431\u0438\u0442\u044B \u0426\u0435\u0440\u0435\u0440\u044B (1801):**
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \xAB\u0437\u0432\u0435\u0437\u0434\u043D\u044B\u0439
    \u0447\u0430\u0441\xBB. \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u043C\u0435\u0442\u043E\u0434 \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0438\u0445
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432 \u0438 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u0443\u044E
    \u0442\u0435\u0445\u043D\u0438\u043A\u0443 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u0435\u0447\u0435\u043D\u0438\u0439
    \u043F\u043E \u0442\u0440\u0435\u043C \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F\u043C,
    \u043E\u043D \u0441 \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E \u043D\u0430\u0448\u0435\u043B
    \u043F\u043E\u0442\u0435\u0440\u044F\u043D\u043D\u0443\u044E \u043A\u0430\u0440\u043B\u0438\u043A\u043E\u0432\u0443\u044E
    \u043F\u043B\u0430\u043D\u0435\u0442\u0443. \u042D\u0442\u043E \u043F\u0440\u043E\u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u043E
    \u043C\u043E\u0449\u044C \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u0445
    \u0442\u0435\u043B (1809):** \u041C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u044F,
    \u0433\u0434\u0435 \u043E\u043D \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u043E
    \u043E\u043F\u0438\u0441\u0430\u043B, \u043A\u0430\u043A \u0443\u0447\u0438\u0442\u044B\u0432\u0430\u0442\u044C
    \u0432\u043E\u0437\u043C\u0443\u0449\u0435\u043D\u0438\u044F \u043F\u043B\u0430\u043D\u0435\u0442
    (\u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u042E\u043F\u0438\u0442\u0435\u0440\u0430
    \u0438 \u0421\u0430\u0442\u0443\u0440\u043D\u0430). \u0424\u043E\u0440\u043C\u0443\u043B\u044B
    \u0413\u0430\u0443\u0441\u0441\u0430 \u0434\u043B\u044F \u043E\u0440\u0431\u0438\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430\u043C\u0438 \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440. *   **\u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0441\u043A\u0430\u044F
    \u0442\u0440\u0438\u0430\u043D\u0433\u0443\u043B\u044F\u0446\u0438\u044F (1818\u20131832):**
    \u0420\u0443\u043A\u043E\u0432\u043E\u0434\u044F \u0441\u044A\u0435\u043C\u043A\u043E\u0439
    \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u0438, \u0413\u0430\u0443\u0441\u0441
    \u0438\u0437\u043E\u0431\u0440\u0435\u043B **\u0433\u0435\u043B\u0438\u043E\u0442\u0440\u043E\u043F**
    (\u043F\u0440\u0438\u0431\u043E\u0440, \u043E\u0442\u0440\u0430\u0436\u0430\u044E\u0449\u0438\u0439
    \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0439 \u0441\u0432\u0435\u0442
    \u043D\u0430 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F \u0434\u043E
    100 \u043A\u043C \u0434\u043B\u044F \u0441\u0432\u0435\u0440\u0445\u0442\u043E\u0447\u043D\u043E\u0439
    \u0444\u0438\u043A\u0441\u0430\u0446\u0438\u0438 \u0442\u043E\u0447\u0435\u043A).
    \u0427\u0442\u043E\u0431\u044B \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435 \u043C\u0430\u0441\u0441\u0438\u0432\u044B
    \u0434\u0430\u043D\u043D\u044B\u0445, \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u043D\u043E\u0432\u044B\u0435 \u043C\u0435\u0442\u043E\u0434\u044B \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439.
    *   **\u041A\u0430\u0440\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u043E\u0435\u043A\u0446\u0438\u0438:** \u0412\u043F\u0435\u0440\u0432\u044B\u0435
    \u0440\u0435\u0448\u0438\u043B \u0437\u0430\u0434\u0430\u0447\u0443 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F
    \u0438\u0441\u043A\u0440\u0438\u0432\u043B\u0435\u043D\u043D\u043E\u0439 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    \u0417\u0435\u043C\u043B\u0438 \u043D\u0430 \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u044C,
    \u043C\u0438\u043D\u0438\u043C\u0438\u0437\u0438\u0440\u0443\u044F \u0438\u0441\u043A\u0430\u0436\u0435\u043D\u0438\u044F
    \u0443\u0433\u043B\u043E\u0432 (\u043A\u043E\u043D\u0444\u043E\u0440\u043C\u043D\u0430\u044F
    \u043F\u0440\u043E\u0435\u043A\u0446\u0438\u044F \u0413\u0430\u0443\u0441\u0441\u0430
    \u2014 \u041A\u0440\u044E\u0433\u0435\u0440\u0430), \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u0432
    \u0442\u043E\u043F\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0430\u0440\u0442\u0430\u0445 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440. 
    ---  ### 5. \u0424\u0438\u0437\u0438\u043A\u0430 \u0438 \u041C\u0430\u0433\u043D\u0435\u0442\u0438\u0437\u043C
    (\u042D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u0442\u043E\u0440
    \u0438 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A) \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    20 \u043B\u0435\u0442 \u0436\u0438\u0437\u043D\u0438 \u0413\u0430\u0443\u0441\u0441
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043E\u0442\u043E\u0448\u0435\u043B
    \u043E\u0442 \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u0437\u0430\u043D\u044F\u043B\u0441\u044F \u0442\u043E\u0447\u043D\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u043E\u0439.  *   **\u0417\u0430\u043A\u043E\u043D
    \u0413\u0430\u0443\u0441\u0441\u0430 (\u042D\u043B\u0435\u043A\u0442\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0430):**
    \u041E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0437\u0430\u043A\u043E\u043D, \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u044E\u0449\u0438\u0439
    \u043F\u043E\u0442\u043E\u043A \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u043E\u043B\u044F \u0447\u0435\u0440\u0435\u0437 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u0443\u044E
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C \u0441 \u0437\u0430\u0440\u044F\u0434\u043E\u043C
    \u0432\u043D\u0443\u0442\u0440\u0438. \u042D\u0442\u043E \u043E\u0434\u043D\u043E
    \u0438\u0437 \u0447\u0435\u0442\u044B\u0440\u0435\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u041C\u0430\u043A\u0441\u0432\u0435\u043B\u043B\u0430, \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0449\u0438\u0445
    \u0432\u0441\u0451 \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0438 \u043C\u0430\u0433\u043D\u0435\u0442\u0438\u0437\u043C. (\u041D\u0430
    \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435 \u044D\u0442\u043E \u0447\u0430\u0441\u0442\u043D\u044B\u0439
    \u0441\u043B\u0443\u0447\u0430\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u041E\u0441\u0442\u0440\u043E\u0433\u0440\u0430\u0434\u0441\u043A\u043E\u0433\u043E-\u0413\u0430\u0443\u0441\u0441\u0430).
    *   **\u0415\u0434\u0438\u043D\u0438\u0446\u044B \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F:**
    \u0412\u0432\u0435\u043B \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u044B\u0435
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u0435\u0434\u0438\u043D\u0438\u0446.
    \u041F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0438\u0437\u043C\u0435\u0440\u044F\u0442\u044C
    \u043C\u0430\u0433\u043D\u0438\u0442\u043D\u043E\u0435 \u043F\u043E\u043B\u0435
    \u0432 \u0435\u0434\u0438\u043D\u0438\u0446\u0430\u0445 **\u0413\u0430\u0443\u0441\u0441
    (\u0413\u0441)** (\u0432 \u0441\u0438\u0441\u0442\u0435\u043C\u0435 \u0421\u0413\u0421).
    *   **\u041F\u0435\u0440\u0432\u044B\u0439 \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043C\u0430\u0433\u043D\u0438\u0442\u043D\u044B\u0439
    \u0442\u0435\u043B\u0435\u0433\u0440\u0430\u0444 (1833):** \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0412\u0435\u0431\u0435\u0440\u043E\u043C \u0413\u0430\u0443\u0441\u0441
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B \u043F\u0435\u0440\u0432\u0443\u044E
    \u0432 \u043C\u0438\u0440\u0435 \u043B\u0438\u043D\u0438\u044E \u0441\u0432\u044F\u0437\u0438
    \u0434\u043B\u0438\u043D\u043E\u0439 \u043E\u043A\u043E\u043B\u043E 1,5 \u043A\u043C
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u043E\u043D\u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438
    **\u0431\u0438\u043D\u0430\u0440\u043D\u044B\u0439 \u043A\u043E\u0434**, \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u043D\u044B\u0439
    \u0441\u0430\u043C\u0438\u043C \u0413\u0430\u0443\u0441\u0441\u043E\u043C (\u0437\u0430
    5 \u043B\u0435\u0442 \u0434\u043E \u0430\u0437\u0431\u0443\u043A\u0438 \u041C\u043E\u0440\u0437\u0435).
    *   **\u041C\u0430\u0433\u043D\u0438\u0442\u043D\u0430\u044F \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u044F:**
    \u0413\u0430\u0443\u0441\u0441 \u043E\u0441\u043D\u043E\u0432\u0430\u043B \u0441\u0435\u0442\u044C
    \u0441\u0442\u0430\u043D\u0446\u0438\u0439 \u0434\u043B\u044F \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F \u0437\u0430 \u043C\u0430\u0433\u043D\u0438\u0442\u043D\u044B\u043C\u0438
    \u0431\u0443\u0440\u044F\u043C\u0438 (\u0432\u043C\u0435\u0441\u0442\u0435 \u0441
    \u0412\u0435\u0431\u0435\u0440\u043E\u043C). \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E, \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0449\u0443\u044E
    \u043C\u0430\u0433\u043D\u0438\u0442\u043D\u043E\u0435 \u043F\u043E\u043B\u0435
    \u0417\u0435\u043C\u043B\u0438 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    (\u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437). *   **\u041E\u043F\u0442\u0438\u043A\u0430:**
    \u0417\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043F\u0442\u0438\u043A\u043E\u0439, \u0432\u044B\u0432\u0435\u043B \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u0434\u043B\u044F \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043E\u0432
    (\u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 \u0434\u043B\u044F
    \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u043E\u0432), \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u0438\u043D\u0438\u043C\u0438\u0437\u0438\u0440\u0443\u044E\u0442 \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0438 \u0445\u0440\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0430\u0431\u0435\u0440\u0440\u0430\u0446\u0438\u0438.  ---  ### 6. \xAB\u0413\u0430\u0443\u0441\u0441\u043E\u0432\u044B
    \u0448\u0442\u0443\u043A\u0438\xBB: \u0411\u0440\u0435\u043D\u0434\u044B \u0433\u0435\u043D\u0438\u044F
    \u041F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432 \u043A\u0430\u0436\u0434\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043D\u0430\u0443\u043A\u0438 \u0435\u0441\u0442\u044C
    \u043E\u0431\u044A\u0435\u043A\u0442, \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u044B\u0439
    \u0435\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C. \u0412\u043E\u0442 \u043F\u0435\u0440\u0435\u0447\u0435\u043D\u044C
    \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0445 \xAB\u0431\u0440\u0435\u043D\u0434\u043E\u0432\xBB,
    \u043F\u043E\u043C\u0438\u043C\u043E \u043F\u0435\u0440\u0435\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u043E\u0433\u043E: 
    *   **\u0420\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0413\u0430\u0443\u0441\u0441\u0430 (\u041D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0435
    \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435):**
    \xAB\u041A\u043E\u043B\u043E\u043A\u043E\u043B\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u0430\u044F
    \u043A\u0440\u0438\u0432\u0430\u044F\xBB, \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0449\u0430\u044F
    \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0445 \u0432\u0435\u043B\u0438\u0447\u0438\u043D.
    \u041A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0439 \u043A\u0430\u043C\u0435\u043D\u044C
    \u0432\u0441\u0435\u0439 \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438.
    *   **\u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B \u0413\u0430\u0443\u0441\u0441\u0430:**
    \u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B
    \\( \\int_{-\\infty}^{\\infty} e^{-x^2} dx = \\sqrt{\\pi} \\), \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0449\u0438\u0439\u0441\u044F
    \u0432 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435.
    *   **\u041C\u0430\u0442\u0440\u0438\u0446\u0430 \u0413\u0430\u0443\u0441\u0441\u0430:**
    \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u0432
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. *   **\u041C\u0435\u0442\u043E\u0434
    \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F \u0413\u0430\u0443\u0441\u0441\u0430
    (\u0413\u0430\u0443\u0441\u0441\u043E\u0432\u043E \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435):**
    \u0421\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0439 \u043C\u0435\u0442\u043E\u0434
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0441\u0438\u0441\u0442\u0435\u043C
    \u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439,
    \u0438\u0437\u0443\u0447\u0430\u0435\u043C\u044B\u0439 \u0432 \u0448\u043A\u043E\u043B\u0430\u0445
    \u0438 \u0432\u0443\u0437\u0430\u0445. *   **\u0421\u0433\u043B\u0430\u0436\u0438\u0432\u0430\u043D\u0438\u0435
    \u0413\u0430\u0443\u0441\u0441\u0430:** \u0422\u0435\u0445\u043D\u0438\u043A\u0430
    \u0440\u0430\u0437\u043C\u044B\u0442\u0438\u044F \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439
    \u0432 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u043E\u0439
    \u0433\u0440\u0430\u0444\u0438\u043A\u0435.  ---  ### \u0418\u0442\u043E\u0433:
    \u041F\u043E\u0447\u0435\u043C\u0443 \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u0443\u043D\u0438\u043A\u0430\u043B\u0435\u043D? \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u0438\u043B\u0438 \u042D\u0439\u043B\u0435\u0440\u0430,
    \u0413\u0430\u0443\u0441\u0441 \u0431\u044B\u043B **\u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u044B\u043C
    \u043F\u0435\u0440\u0444\u0435\u043A\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u043E\u043C**.
    \u041E\u043D \u043D\u0435 \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0447\u0435\u0440\u043D\u043E\u0432\u0438\u043A\u0438. \u041E\u043D \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043B\u0438\u0448\u044C \u0442\u0435 \u0440\u0430\u0431\u043E\u0442\u044B, \u0432
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0434\u043E\u0432\u0435\u043B \u043A\u0430\u0436\u0434\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u0434\u043E \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u043E\u0439
    \u044F\u0441\u043D\u043E\u0441\u0442\u0438.  \u0418\u043D\u043E\u0433\u0434\u0430
    \u0448\u0443\u0442\u044F\u0442, \u0447\u0442\u043E \xAB\u0435\u0441\u043B\u0438
    \u0432 \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u0435
    \u0413\u0430\u0443\u0441\u0441\u0430 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u044E\u0442\u0441\u044F
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F, \u0437\u043D\u0430\u0447\u0438\u0442,
    \u043E\u043D \u043F\u0440\u043E\u0432\u0435\u043B \u0438\u0445 \u0442\u0440\u0438
    \u0440\u0430\u0437\u0430, \u0441\u0442\u0435\u0440 \u0432\u0441\u0435 \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u0447\u043D\u044B\u0435
    \u0432\u044B\u043A\u043B\u0430\u0434\u043A\u0438 \u0438 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0430\u043C\u044B\u0439 \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0439
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\xBB. \u0418\u0437-\u0437\u0430
    \u044D\u0442\u043E\u0433\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u0447\u0430\u0441\u0442\u043E \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u043B\u0438,
    \u043A\u0430\u043A \u043E\u043D \u043F\u0440\u0438\u0448\u0435\u043B \u043A \u0441\u0432\u043E\u0438\u043C
    \u0432\u044B\u0432\u043E\u0434\u0430\u043C (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438, \u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0438
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0435\u0449\u0435 \u043D\u0438\u043A\u0442\u043E
    \u043D\u0435 \u0437\u043D\u0430\u043B).  \u0415\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u2014 \u044D\u0442\u043E \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F.
    \u042D\u0442\u043E **\u043C\u0435\u0442\u043E\u0434\u043E\u043B\u043E\u0433\u0438\u044F
    \u043D\u0430\u0443\u043A\u0438**: \u043E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u043A\u0430\u043A \u0441\u0432\u044F\u0437\u0430\u0442\u044C \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u0443\u044E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0443 \u0441 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F\u043C\u0438, \u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0438\u0441\u043A\u0440\u0438\u0432\u043B\u0435\u043D\u043D\u044B\u0445
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432 \u2014 \u0441
    \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u043C \u043C\u0430\u0433\u043D\u0435\u0442\u0438\u0437\u043C\u043E\u043C
    \u0417\u0435\u043C\u043B\u0438. \u0411\u0435\u0437 \u0413\u0430\u0443\u0441\u0441\u0430
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B \u043D\u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u043A\u043E\u0441\u043C\u043E\u043B\u043E\u0433\u0438\u044F, \u043D\u0438 \u0433\u0435\u043E\u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B (\u0413\u0418\u0421/\u043D\u0430\u0432\u0438\u0433\u0430\u0442\u043E\u0440\u044B),
    \u043D\u0438 \u0431\u043E\u043B\u044C\u0448\u0438\u0435 \u0434\u0430\u043D\u043D\u044B\u0435."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u041A\u0430\u0440\u043B\u0430 \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430
    \u0413\u0430\u0443\u0441\u0441\u0430 \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F,
    \u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u0438\u0440\u0443\u044E\u0449\u0430\u044F
    \u0441 \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0439 \u044F\u0441\u043D\u043E\u0441\u0442\u044C\u044E
    \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u043E\u0440\u043C\u0443\u043B. \u0415\u0441\u043B\u0438 \u0435\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B \u2014
    \u044D\u0442\u043E \u0442\u043E\u0440\u0436\u0435\u0441\u0442\u0432\u043E \u043F\u043E\u0440\u044F\u0434\u043A\u0430,
    \u0442\u043E \u0435\u0433\u043E \u0447\u0430\u0441\u0442\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u0430 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0437\u043C\u0430,
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0439, \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u0432 \u0438 \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u0445
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u043E\u0432. \u0413\u0430\u0443\u0441\u0441
    \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u043C,
    \u044D\u043C\u043E\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E \u0441\u0434\u0435\u0440\u0436\u0430\u043D\u043D\u044B\u043C
    \u043D\u0430 \u043F\u0443\u0431\u043B\u0438\u043A\u0435, \u043D\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u0440\u0430\u043D\u0438\u043C\u044B\u043C \u0438 \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u044B\u043C
    \u0432 \u043B\u0438\u0447\u043D\u044B\u0445 \u043F\u0438\u0441\u044C\u043C\u0430\u0445. 
    \u0427\u0442\u043E\u0431\u044B \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u043F\u043E\u043B\u043D\u0443\u044E \u043A\u0430\u0440\u0442\u0438\u043D\u0443,
    \u0440\u0430\u0437\u0431\u0435\u0440\u0435\u043C \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u043F\u043E \u043F\u0435\u0440\u0438\u043E\u0434\u0430\u043C:
    **\u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u044F\u043C\u0438**,
    **\u043F\u0435\u0440\u0432\u0430\u044F \u0431\u043E\u043B\u044C\u0448\u0430\u044F
    \u043B\u044E\u0431\u043E\u0432\u044C \u0438 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0431\u0440\u0430\u043A**, **\u0432\u0442\u043E\u0440\u043E\u0439 \u0431\u0440\u0430\u043A
    \u043F\u043E \u0440\u0430\u0441\u0447\u0435\u0442\u0443**, **\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0434\u0435\u0442\u044C\u043C\u0438** \u0438 **\u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440
    \u0432 \u0431\u044B\u0442\u0443**.  ---  ### 1. \u0420\u043E\u0434\u0438\u0442\u0435\u043B\u0438
    \u0438 \u0434\u0435\u0442\u0441\u0442\u0432\u043E: \u0425\u043E\u043B\u043E\u0434\u043D\u044B\u0439
    \u043E\u0442\u0435\u0446 \u0438 \u043B\u044E\u0431\u044F\u0449\u0430\u044F \u043C\u0430\u0442\u044C 
    \u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440 \u0413\u0430\u0443\u0441\u0441\u0430
    \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u0441\u044F
    \u043F\u043E\u0434 \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C \u043F\u043E\u043B\u044F\u0440\u043D\u043E
    \u0440\u0430\u0437\u043D\u044B\u0445 \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u0439. 
    *   **\u041E\u0442\u0435\u0446, \u0413\u0435\u0431\u0445\u0430\u0440\u0434 \u0414\u0438\u0442\u0440\u0438\u0445
    \u0413\u0430\u0443\u0441\u0441 (1744\u20131808):** \u0411\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0441\u0443\u0440\u043E\u0432\u044B\u043C, \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u044B\u043C
    \u0438 \u043D\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u043D\u044B\u043C.
    \u0420\u0430\u0431\u043E\u0442\u0430\u043B \u0432\u043E\u0434\u043E\u043F\u0440\u043E\u0432\u043E\u0434\u0447\u0438\u043A\u043E\u043C,
    \u0441\u0430\u0434\u043E\u0432\u043D\u0438\u043A\u043E\u043C, \u043C\u044F\u0441\u043D\u0438\u043A\u043E\u043C,
    \u043A\u0430\u043C\u0435\u043D\u0449\u0438\u043A\u043E\u043C. \u041E\u043D \u0431\u044B\u043B
    \u043F\u0435\u0440\u0444\u0435\u043A\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u043E\u043C
    \u0432 \u0440\u0430\u0431\u043E\u0442\u0435, \u043D\u043E \u0432 \u0441\u0435\u043C\u044C\u0435
    \u0446\u0430\u0440\u0438\u043B\u0430 \u0436\u0435\u043B\u0435\u0437\u043D\u0430\u044F
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0430. \u041E\u0442\u0435\u0446
    \u0441\u043A\u0435\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0441\u044F
    \u043A \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044E \u0441\u044B\u043D\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439, \u0441\u0447\u0438\u0442\u0430\u044F,
    \u0447\u0442\u043E \u0442\u043E\u043C\u0443 \u043B\u0443\u0447\u0448\u0435 \u043E\u0441\u0432\u043E\u0438\u0442\u044C
    \u0440\u0435\u043C\u0435\u0441\u043B\u043E, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043F\u0440\u0438\u043D\u043E\u0441\u0438\u0442 \u0434\u0435\u043D\u044C\u0433\u0438.
    \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u0447\u0442\u043E \u0413\u0435\u0431\u0445\u0430\u0440\u0434
    \u0437\u0430\u043F\u0440\u0435\u0449\u0430\u043B \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u043C\u0443
    \u041A\u0430\u0440\u043B\u0443 \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
    \u043D\u0430 \u0441\u0432\u043E\u0438 \u0440\u0430\u0441\u0447\u0435\u0442\u044B,
    \u043D\u043E \u043C\u0430\u043B\u044C\u0447\u0438\u043A \u0442\u0430\u0439\u043A\u043E\u043C
    \u043F\u043E\u0434\u0433\u043B\u044F\u0434\u044B\u0432\u0430\u043B \u0438 \u043F\u043E\u043F\u0440\u0430\u0432\u043B\u044F\u043B
    \u043E\u0448\u0438\u0431\u043A\u0438 \u043E\u0442\u0446\u0430 \u0432 \u0441\u0447\u0435\u0442\u0430\u0445.
    \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0431\u044B\u043B\u0438
    \u043D\u0430\u0442\u044F\u043D\u0443\u0442\u044B\u043C\u0438: \u0413\u0430\u0443\u0441\u0441
    \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0433\u043E\u0432\u043E\u0440\u0438\u043B
    \u043E\u0431 \u043E\u0442\u0446\u0435 \u0441 \u0442\u0435\u043F\u043B\u043E\u0442\u043E\u0439,
    \u0430 \u043A\u043E\u0433\u0434\u0430 \u0442\u043E\u0442 \u0443\u043C\u0435\u0440
    (\u0432 1808 \u0433\u043E\u0434\u0443), \u0413\u0430\u0443\u0441\u0441 \u043D\u0435
    \u043F\u043E\u0435\u0445\u0430\u043B \u043D\u0430 \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u044B,
    \u0441\u043E\u0441\u043B\u0430\u0432\u0448\u0438\u0441\u044C \u043D\u0430 \u0437\u0430\u043D\u044F\u0442\u043E\u0441\u0442\u044C
    (\u0445\u043E\u0442\u044F \u043F\u043E\u0437\u0436\u0435 \u0432 \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043B, \u0447\u0442\u043E \u044D\u0442\u043E
    \u0431\u044B\u043B\u043E \u0436\u0435\u0441\u0442\u043E\u043A\u043E). *   **\u041C\u0430\u0442\u044C,
    \u0414\u043E\u0440\u043E\u0442\u0435\u044F \u0411\u0435\u043D\u0446\u0435 (1743\u20131839):**
    \u0411\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u043E\u0439 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C\u044E
    \u043C\u0443\u0436\u0443. \u041F\u043E\u0447\u0442\u0438 \u043D\u0435\u0433\u0440\u0430\u043C\u043E\u0442\u043D\u0430\u044F
    (\u043D\u0435 \u0443\u043C\u0435\u043B\u0430 \u043F\u0438\u0441\u0430\u0442\u044C,
    \u0447\u0438\u0442\u0430\u043B\u0430 \u0441 \u0442\u0440\u0443\u0434\u043E\u043C),
    \u043D\u043E \u043E\u0431\u043B\u0430\u0434\u0430\u043B\u0430 \u0436\u0438\u0432\u044B\u043C
    \u0443\u043C\u043E\u043C, \u044E\u043C\u043E\u0440\u043E\u043C \u0438 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0435\u0439. \u0418\u043C\u0435\u043D\u043D\u043E
    \u043E\u043D\u0430 \u0440\u0430\u0437\u0433\u043B\u044F\u0434\u0435\u043B\u0430
    \u0433\u0435\u043D\u0438\u0439 \u0432 \u0441\u044B\u043D\u0435 \u0438 \u0434\u043E
    \u0441\u0430\u043C\u043E\u0439 \u0441\u043C\u0435\u0440\u0442\u0438 \u0431\u044B\u043B\u0430
    \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u043E\u043F\u043E\u0440\u043E\u0439.
    \u0414\u043E\u0440\u043E\u0442\u0435\u044F \u0436\u0438\u043B\u0430 \u0441 \u0413\u0430\u0443\u0441\u0441\u043E\u043C
    \u0434\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439 \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0438
    (\u0443\u043C\u0435\u0440\u043B\u0430 \u0432 96 \u043B\u0435\u0442). \u0413\u0430\u0443\u0441\u0441
    \u043E\u0431\u043E\u0436\u0430\u043B \u043C\u0430\u0442\u044C; \u043E\u043D \u043D\u043E\u0441\u0438\u043B
    \u0435\u0451 \u043D\u0430 \u0440\u0443\u043A\u0430\u0445 \u043F\u043E \u043A\u043E\u043C\u043D\u0430\u0442\u0435,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D\u0430 \u0443\u0436\u0435 \u043D\u0435
    \u043C\u043E\u0433\u043B\u0430 \u0445\u043E\u0434\u0438\u0442\u044C, \u0438 \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u043B
    \u043F\u043E\u0434 \u0435\u0451 \u0434\u0438\u043A\u0442\u043E\u0432\u043A\u0443
    \u043F\u0438\u0441\u044C\u043C\u0430. \u041F\u043E\u0441\u043B\u0435 \u0435\u0451
    \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B:
    \xAB\u041C\u0438\u0440 \u043E\u043F\u0443\u0441\u0442\u0435\u043B \u0434\u043B\u044F
    \u043C\u0435\u043D\u044F\xBB.  ---  ### 2. \u041F\u0435\u0440\u0432\u0430\u044F
    \u043B\u044E\u0431\u043E\u0432\u044C: \u0418\u043E\u0433\u0430\u043D\u043D\u0430
    \u041E\u0441\u0442\u0445\u043E\u0444\u0444 (\u0422\u0440\u0430\u0433\u0435\u0434\u0438\u044F
    1809 \u0433\u043E\u0434\u0430)  \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u0441\u0430\u043C\u0430\u044F
    \u044F\u0440\u043A\u0430\u044F \u0438 \u0441\u0430\u043C\u0430\u044F \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u043D\u043D\u0430\u044F
    \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0430 \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438.  *   **\u0417\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E:**
    \u0413\u0430\u0443\u0441\u0441 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u0418\u043E\u0433\u0430\u043D\u043D\u043E\u0439 (\u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445 \u2014 \u0419\u043E\u0445\u0430\u043D\u043D\u0430)
    \u041E\u0441\u0442\u0445\u043E\u0444\u0444 \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435
    \u0432 \u043A\u043E\u043D\u0446\u0435 1790-\u0445 \u0433\u043E\u0434\u043E\u0432.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0434\u043E\u0447\u0435\u0440\u044C\u044E
    \u043A\u043E\u0436\u0435\u0432\u043D\u0438\u043A\u0430, \u0438\u0437\u044F\u0449\u043D\u043E\u0439,
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u043D\u043E\u0439 \u0438
    \u0436\u0438\u0432\u043E\u0439 \u0434\u0435\u0432\u0443\u0448\u043A\u043E\u0439.
    *   **\u0414\u043E\u043B\u0433\u0430\u044F \u043F\u043E\u043C\u043E\u043B\u0432\u043A\u0430:**
    \u0418\u0437-\u0437\u0430 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u043E\u0439
    \u043D\u0435\u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0413\u0430\u0443\u0441\u0441\u0430 (\u043E\u043D \u0435\u0449\u0435 \u043D\u0435
    \u0438\u043C\u0435\u043B \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B) \u043E\u043D\u0438 \u043D\u0435 \u043C\u043E\u0433\u043B\u0438
    \u043F\u043E\u0436\u0435\u043D\u0438\u0442\u044C\u0441\u044F \u0434\u043E\u043B\u0433\u0438\u0435
    \u0433\u043E\u0434\u044B. \u0413\u0430\u0443\u0441\u0441 \u0431\u043E\u0433\u043E\u0442\u0432\u043E\u0440\u0438\u043B
    \u0418\u043E\u0433\u0430\u043D\u043D\u0443. \u0412 \u0435\u0433\u043E \u043F\u0438\u0441\u044C\u043C\u0430\u0445
    \u044D\u0442\u043E\u0433\u043E \u043F\u0435\u0440\u0438\u043E\u0434\u0430 \u043E\u043D\u0430
    \u0444\u0438\u0433\u0443\u0440\u0438\u0440\u0443\u0435\u0442 \u043A\u0430\u043A
    \xAB\u043C\u043E\u044F \u0437\u0432\u0435\u0437\u0434\u0430\xBB \u0438 \xAB\u043C\u043E\u0435
    \u0432\u0441\u0451\xBB. \u041E\u043D \u043F\u0438\u0441\u0430\u043B: \xAB\u0415\u0451
    \u043B\u044E\u0431\u043E\u0432\u044C \u043D\u0430\u043F\u043E\u043B\u043D\u0438\u043B\u0430
    \u043C\u043E\u044E \u0436\u0438\u0437\u043D\u044C \u0441\u043C\u044B\u0441\u043B\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043D\u0435 \u043C\u043E\u0433\u043B\u0438
    \u0434\u0430\u0442\u044C \u0434\u0430\u0436\u0435 \u0441\u0430\u043C\u044B\u0435
    \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0435 \u0442\u0435\u043E\u0440\u0435\u043C\u044B\xBB.
    *   **\u0411\u0440\u0430\u043A:** \u041E\u043D\u0438 \u043F\u043E\u0436\u0435\u043D\u0438\u043B\u0438\u0441\u044C
    9 \u043E\u043A\u0442\u044F\u0431\u0440\u044F 1805 \u0433\u043E\u0434\u0430. \u042D\u0442\u043E\u0442
    \u0431\u0440\u0430\u043A \u0431\u044B\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C, \u0445\u043E\u0442\u044F
    \u0438 \u043D\u0435\u0434\u043E\u043B\u0433\u0438\u043C. \u0423 \u043D\u0438\u0445
    \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0442\u0440\u043E\u0435 \u0434\u0435\u0442\u0435\u0439:    
    *   **\u0418\u043E\u0441\u0438\u0444** (1806\u20131873) \u2014 \u043D\u0430\u0437\u0432\u0430\u043D
    \u0432 \u0447\u0435\u0441\u0442\u044C \u043E\u0442\u0446\u0430 \u0413\u0430\u0443\u0441\u0441\u0430?
    \u041D\u0435\u0442, \u0432 \u0447\u0435\u0441\u0442\u044C \u0434\u0440\u0443\u0433\u0430
    \u0441\u0435\u043C\u044C\u0438.     *   **\u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u0438\u043D\u0430
    (\u041C\u0438\u043D\u043D\u0430)** (1808\u20131840) \u2014 \u043B\u044E\u0431\u0438\u043C\u0430\u044F
    \u0434\u043E\u0447\u044C \u0413\u0430\u0443\u0441\u0441\u0430, \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u0430\u044F
    \u0432 \u0447\u0435\u0441\u0442\u044C \u0441\u0435\u0441\u0442\u0440\u044B \u0418\u043E\u0433\u0430\u043D\u043D\u044B
    (\u041C\u0438\u043D\u044B \u0412\u0430\u043B\u044C\u0434\u0435\u043A, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u043E\u0437\u0436\u0435 \u0441\u0442\u0430\u043D\u0435\u0442 \u0435\u0433\u043E
    \u0432\u0442\u043E\u0440\u043E\u0439 \u0436\u0435\u043D\u043E\u0439).     *  
    **\u041B\u044E\u0434\u0432\u0438\u0433** (1809) \u2014 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0434\u043D\u0435\u0439 \u043F\u043E\u0441\u043B\u0435 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438. 
    **\u0422\u0440\u0430\u0433\u0435\u0434\u0438\u044F:** \u0412 1809 \u0433\u043E\u0434\u0443,
    \u043F\u043E\u0441\u043B\u0435 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E \u0440\u0435\u0431\u0435\u043D\u043A\u0430,
    \u0418\u043E\u0433\u0430\u043D\u043D\u0430 \u0442\u044F\u0436\u0435\u043B\u043E
    \u0437\u0430\u0431\u043E\u043B\u0435\u043B\u0430 (\u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043F\u043E\u0441\u043B\u0435\u0440\u043E\u0434\u043E\u0432\u043E\u0439 \u0441\u0435\u043F\u0441\u0438\u0441
    \u0438\u043B\u0438 \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437).
    \u0413\u0430\u0443\u0441\u0441 \u0431\u044B\u043B \u0432 \u043E\u0442\u0447\u0430\u044F\u043D\u0438\u0438.
    \u041E\u043D \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435 \u043E\u0442\u0445\u043E\u0434\u0438\u043B \u043E\u0442 \u0435\u0451
    \u043F\u043E\u0441\u0442\u0435\u043B\u0438. 11 \u043E\u043A\u0442\u044F\u0431\u0440\u044F
    1809 \u0433\u043E\u0434\u0430 \u0418\u043E\u0433\u0430\u043D\u043D\u0430 \u0443\u043C\u0435\u0440\u043B\u0430
    \u0443 \u043D\u0435\u0433\u043E \u043D\u0430 \u0440\u0443\u043A\u0430\u0445.
    \u0421\u043F\u0443\u0441\u0442\u044F \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043D\u0435\u0434\u0435\u043B\u044C, \u0432 \u0434\u0435\u043A\u0430\u0431\u0440\u0435,
    \u0443\u043C\u0435\u0440 \u0438 \u043D\u043E\u0432\u043E\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u044B\u0439
    \u041B\u044E\u0434\u0432\u0438\u0433.  \u0414\u043B\u044F \u0413\u0430\u0443\u0441\u0441\u0430
    \u044D\u0442\u043E \u0431\u044B\u043B \u0441\u043E\u043A\u0440\u0443\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0443\u0434\u0430\u0440. \u041E\u043D \u0432\u043F\u0430\u043B \u0432 \u0442\u044F\u0436\u0435\u043B\u0443\u044E
    \u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u044E, \u0434\u043B\u0438\u0432\u0448\u0443\u044E\u0441\u044F
    \u043F\u043E\u0447\u0442\u0438 \u0434\u0432\u0430 \u0433\u043E\u0434\u0430. \u0412
    \u043F\u0438\u0441\u044C\u043C\u0435 \u0434\u0440\u0443\u0433\u0443 \u043E\u043D
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B: *\xAB\u041C\u043E\u0439 \u0434\u043E\u043C
    \u2014 \u044D\u0442\u043E \u043C\u043E\u0433\u0438\u043B\u0430. \u0412\u0441\u0451,
    \u0447\u0442\u043E \u044F \u043B\u044E\u0431\u0438\u043B, \u043E\u0442\u043D\u044F\u0442\u043E
    \u0443 \u043C\u0435\u043D\u044F. \u0422\u0435\u043F\u0435\u0440\u044C \u043C\u043E\u044F
    \u0436\u0438\u0437\u043D\u044C \u2014 \u043B\u0438\u0448\u044C \u0442\u0443\u043F\u043E\u0435
    \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u0435 \u0434\u043E\u043B\u0433\u0430
    \u043F\u0435\u0440\u0435\u0434 \u043D\u0430\u0443\u043A\u043E\u0439, \u0447\u0442\u043E\u0431\u044B
    \u043D\u0435 \u0441\u043E\u0439\u0442\u0438 \u0441 \u0443\u043C\u0430\xBB*. \u041E\u043D
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u0440\u0430\u0431\u043E\u0442\u044B \u0438 \u0434\u043E\u043B\u0433\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u043D\u0435 \u043C\u043E\u0433 \u043F\u0438\u0441\u0430\u0442\u044C
    \u043F\u0438\u0441\u044C\u043C\u0430 \u0431\u0435\u0437 \u0441\u043B\u0435\u0437. 
    ---  ### 3. \u0412\u0442\u043E\u0440\u043E\u0439 \u0431\u0440\u0430\u043A: \u041C\u0438\u043D\u0430
    \u0412\u0430\u043B\u044C\u0434\u0435\u043A (\u0411\u0440\u0430\u043A \u043F\u043E
    \u0440\u0430\u0441\u0447\u0435\u0442\u0443 \u0438 \u0434\u043E\u043B\u0433\u0443) 
    \u0427\u0435\u0440\u0435\u0437 \u0433\u043E\u0434 \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0418\u043E\u0433\u0430\u043D\u043D\u044B,
    \u043E\u0441\u0442\u0430\u0432\u0448\u0438\u0441\u044C \u0441 \u0434\u0432\u0443\u043C\u044F
    \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u043C\u0438 \u0434\u0435\u0442\u044C\u043C\u0438
    \u0438 \u0431\u043E\u043B\u044C\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u0440\u044C\u044E,
    \u0413\u0430\u0443\u0441\u0441 \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E
    \u043D\u0435 \u0441\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0441 \u0431\u044B\u0442\u043E\u043C.  *   **\u0412\u044B\u0431\u043E\u0440:**
    \u041E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u041C\u0438\u043D\u043D\u0435
    \u0412\u0430\u043B\u044C\u0434\u0435\u043A** (\u0432 \u0434\u0435\u0432\u0438\u0447\u0435\u0441\u0442\u0432\u0435
    \u041E\u0441\u0442\u0445\u043E\u0444\u0444) \u2014 \u0440\u043E\u0434\u043D\u043E\u0439
    \u0441\u0435\u0441\u0442\u0440\u0435 \u0441\u0432\u043E\u0435\u0439 \u043F\u043E\u043A\u043E\u0439\u043D\u043E\u0439
    \u0436\u0435\u043D\u044B. \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0440\u0430\u0433\u043C\u0430\u0442\u0438\u0447\u043D\u044B\u0439,
    \u0430 \u043D\u0435 \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0448\u0430\u0433. *   **\u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F:**
    \u0412\u0435\u043D\u0447\u0430\u043D\u0438\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u043E\u0441\u044C
    4 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1810 \u0433\u043E\u0434\u0430. \u041C\u0438\u043D\u043D\u0430
    \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u043E\u0439 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C\u044E
    \u0418\u043E\u0433\u0430\u043D\u043D\u044B: \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u0430\u044F,
    \u0432\u043E\u043B\u0435\u0432\u0430\u044F, \u043D\u043E \u043C\u0435\u043D\u0435\u0435
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E
    \u0440\u0430\u0437\u0432\u0438\u0442\u0430\u044F. \u0413\u0430\u0443\u0441\u0441
    \u043D\u0435 \u0438\u0441\u043F\u044B\u0442\u044B\u0432\u0430\u043B \u043A \u043D\u0435\u0439
    \u0442\u043E\u0439 \u0441\u0442\u0440\u0430\u0441\u0442\u0438, \u0447\u0442\u043E
    \u043A \u043F\u0435\u0440\u0432\u043E\u0439 \u0436\u0435\u043D\u0435. \u0412
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435 \u0441 \u0434\u0440\u0443\u0437\u044C\u044F\u043C\u0438
    \u043E\u043D \u043E\u0442\u0437\u044B\u0432\u0430\u043B\u0441\u044F \u043E \u0431\u0440\u0430\u043A\u0435
    \u043A\u0430\u043A \u043E \xAB\u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u043C
    \u0441\u043E\u044E\u0437\u0435\xBB \u0438 \xAB\u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u043D\u043E\u043C
    \u0440\u0435\u0448\u0435\u043D\u0438\u0438\xBB. *   **\u0414\u0435\u0442\u0438:**
    \u0412 \u044D\u0442\u043E\u043C \u0431\u0440\u0430\u043A\u0435 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C
    \u0435\u0449\u0435 \u0442\u0440\u043E\u0435 \u0434\u0435\u0442\u0435\u0439:    
    *   **\u042D\u0436\u0435\u043D** (1811\u20131896) \u2014 \u043F\u043E\u0437\u0436\u0435
    \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043B \u0432 \u0421\u0428\u0410.    
    *   **\u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C** (1813\u20131879)
    \u2014 \u0442\u043E\u0436\u0435 \u0443\u0435\u0445\u0430\u043B \u0432 \u0410\u043C\u0435\u0440\u0438\u043A\u0443.    
    *   **\u0422\u0435\u0440\u0435\u0437\u0430** (1816\u20131864) \u2014 \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C
    \u0441 \u043E\u0442\u0446\u043E\u043C \u0438 \u0432\u0435\u043B\u0430 \u0435\u0433\u043E
    \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u043E \u0434\u043E \u0441\u0430\u043C\u043E\u0439
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438. *   **\u0425\u043E\u043B\u043E\u0434\u043D\u043E\u0441\u0442\u044C:**
    \u0411\u0440\u0430\u043A \u0441 \u041C\u0438\u043D\u043E\u0439 \u0431\u044B\u043B
    \u043D\u0435\u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C. \u041E\u043D\u0438
    \u0436\u0438\u043B\u0438 \u043A\u0430\u043A \u0441\u043E\u0441\u0435\u0434\u0438,
    \u0430 \u043D\u0435 \u043A\u0430\u043A \u0441\u0443\u043F\u0440\u0443\u0433\u0438.
    \u041C\u0438\u043D\u043D\u0430 \u0440\u0435\u0432\u043D\u043E\u0432\u0430\u043B\u0430
    \u0413\u0430\u0443\u0441\u0441\u0430 \u043A \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u043A \u043F\u043E\u043A\u043E\u0439\u043D\u043E\u0439 \u0441\u0435\u0441\u0442\u0440\u0435.
    \u0413\u0430\u0443\u0441\u0441 \u0436\u0435, \u0441\u043E \u0441\u0432\u043E\u0435\u0439
    \u0441\u0442\u043E\u0440\u043E\u043D\u044B, \u0441\u0447\u0438\u0442\u0430\u043B
    \u0436\u0435\u043D\u0443 \u043D\u0435\u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0439
    \u043F\u043E\u043D\u044F\u0442\u044C \u0435\u0433\u043E \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0439
    \u043C\u0438\u0440. \u0412 1831 \u0433\u043E\u0434\u0443 \u041C\u0438\u043D\u043D\u0430
    \u0442\u044F\u0436\u0435\u043B\u043E \u0437\u0430\u0431\u043E\u043B\u0435\u043B\u0430
    (\u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437\u043E\u043C \u0438
    \u043D\u0435\u0440\u0432\u043D\u044B\u043C \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E\u043C)
    \u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0434\u043E
    \u0441\u0432\u043E\u0435\u0439 \u0441\u043C\u0435\u0440\u0442\u0438 \u0432 1839
    \u0433\u043E\u0434\u0443 \u0431\u044B\u043B\u0430 \u043F\u0440\u0438\u043A\u043E\u0432\u0430\u043D\u0430
    \u043A \u043F\u043E\u0441\u0442\u0435\u043B\u0438. \u0413\u0430\u0443\u0441\u0441
    \u0443\u0445\u0430\u0436\u0438\u0432\u0430\u043B \u0437\u0430 \u043D\u0435\u0439,
    \u043D\u043E \u0434\u0435\u043B\u0430\u043B \u044D\u0442\u043E \u0441\u043A\u043E\u0440\u0435\u0435
    \u0438\u0437 \u0447\u0443\u0432\u0441\u0442\u0432\u0430 \u0434\u043E\u043B\u0433\u0430,
    \u0447\u0435\u043C \u0438\u0437 \u043B\u044E\u0431\u0432\u0438. \u0412 \u043F\u0438\u0441\u044C\u043C\u0430\u0445
    \u044D\u0442\u043E\u0433\u043E \u043F\u0435\u0440\u0438\u043E\u0434\u0430 \u043E\u043D
    \u0436\u0430\u043B\u0443\u0435\u0442\u0441\u044F \u043D\u0430 \xAB\u0442\u044F\u0436\u0435\u043B\u044B\u0439
    \u043A\u0440\u0435\u0441\u0442\xBB \u0438 \xAB\u0432\u0435\u0447\u043D\u044B\u0435
    \u0441\u0442\u0435\u043D\u0430\u043D\u0438\u044F\xBB \u0432 \u0434\u043E\u043C\u0435. 
    ---  ### 4. \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0434\u0435\u0442\u044C\u043C\u0438:
    \u0416\u0435\u0441\u0442\u043A\u0438\u0439 \u043E\u0442\u0435\u0446  \u0413\u0430\u0443\u0441\u0441
    \u0431\u044B\u043B \u0441\u043B\u043E\u0436\u043D\u044B\u043C, \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0438 \u0447\u0430\u0441\u0442\u043E \u043D\u0435\u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u044B\u043C
    \u043E\u0442\u0446\u043E\u043C.  *   **\u0421\u044B\u043D\u043E\u0432\u044C\u044F:**
    \u041E\u043D \u0445\u043E\u0442\u0435\u043B, \u0447\u0442\u043E\u0431\u044B \u0432\u0441\u0435
    \u0435\u0433\u043E \u0441\u044B\u043D\u043E\u0432\u044C\u044F \u043F\u043E\u0448\u043B\u0438
    \u043F\u043E \u0435\u0433\u043E \u0441\u0442\u043E\u043F\u0430\u043C \u0438 \u0441\u0442\u0430\u043B\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438 \u0438\u043B\u0438
    \u0443\u0447\u0435\u043D\u044B\u043C\u0438. \u041D\u043E \u043D\u0438 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u043D\u0438\u0445 \u043D\u0435 \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u0413\u0430\u0443\u0441\u0441 \u0431\u044B\u043B \u0436\u0435\u0441\u0442\u043E\u043A
    \u0432 \u0441\u0432\u043E\u0438\u0445 \u043E\u0446\u0435\u043D\u043A\u0430\u0445.
    \u041E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0441\u044B\u043D\u043E\u0432\u0435\u0439
    \xAB\u0442\u0443\u043F\u0438\u0446\u0430\u043C\u0438\xBB \u0432 \u043B\u0438\u0447\u043D\u044B\u0445
    \u043F\u0438\u0441\u044C\u043C\u0430\u0445 \u0438 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E
    \u0443\u043D\u0438\u0436\u0430\u043B \u0438\u0445 \u0437\u0430 \u043D\u0435\u0443\u0441\u043F\u0435\u0445\u0438
    \u0432 \u0443\u0447\u0435\u0431\u0435. *   **\u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442
    \u0441 \u0441\u044B\u043D\u043E\u0432\u044C\u044F\u043C\u0438:** \u0418\u0437-\u0437\u0430
    \u0436\u0435\u0441\u0442\u043A\u043E\u0433\u043E \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0432\u0441\u0435 \u0442\u0440\u043E\u0435 \u0441\u044B\u043D\u043E\u0432\u0435\u0439
    (\u0418\u043E\u0441\u0438\u0444, \u042D\u0436\u0435\u043D \u0438 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C)
    \u0432\u043E\u0437\u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443. \u042D\u0436\u0435\u043D
    \u0438 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C, \u043A\u0430\u043A
    \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043E\u0441\u0442\u0438\u0433\u043B\u0438
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E\u043B\u0435\u0442\u0438\u044F,
    \u0441\u0431\u0435\u0436\u0430\u043B\u0438 \u043E\u0442 \u043E\u0442\u0446\u0430
    \u0432 \u0410\u043C\u0435\u0440\u0438\u043A\u0443 (\u043E\u0431\u0430 \u0441\u0442\u0430\u043B\u0438
    \u0432\u043F\u043E\u043B\u043D\u0435 \u0443\u0441\u043F\u0435\u0448\u043D\u044B\u043C\u0438
    \u0431\u0438\u0437\u043D\u0435\u0441\u043C\u0435\u043D\u0430\u043C\u0438). \u0413\u0430\u0443\u0441\u0441
    \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u043E\u0441\u043A\u043E\u0440\u0431\u043B\u0435\u043D
    \u0438\u0445 \u0443\u0445\u043E\u0434\u043E\u043C \u0438 \u0437\u0430\u043F\u0440\u0435\u0442\u0438\u043B
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0442\u044C \u0438\u0445 \u0438\u043C\u0435\u043D\u0430
    \u0432 \u0441\u0432\u043E\u0435\u043C \u0434\u043E\u043C\u0435. \u0421 \u0418\u043E\u0441\u0438\u0444\u043E\u043C
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0442\u043E\u0436\u0435
    \u0431\u044B\u043B\u0438 \u043D\u0430\u0442\u044F\u043D\u0443\u0442\u044B\u043C\u0438,
    \u0445\u043E\u0442\u044F \u043E\u043D \u043E\u0441\u0442\u0430\u043B\u0441\u044F
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u0438 \u0441\u043B\u0443\u0436\u0438\u043B
    \u0432 \u0430\u0440\u043C\u0438\u0438. *   **\u041B\u044E\u0431\u0438\u043C\u044B\u0439
    \u0432\u043D\u0443\u043A:** \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C,
    \u043A\u043E\u0433\u043E \u0413\u0430\u0443\u0441\u0441 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043B\u044E\u0431\u0438\u043B \u0441\u0440\u0435\u0434\u0438 \u043C\u043B\u0430\u0434\u0448\u0435\u0433\u043E
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F, \u0431\u044B\u043B \u0432\u043D\u0443\u043A
    (\u0441\u044B\u043D \u042D\u0436\u0435\u043D\u0430), \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0442\u0430\u043A\u0436\u0435 \u043D\u0430\u0437\u0432\u0430\u043B\u0438 \u041A\u0430\u0440\u043B\u043E\u043C.
    \u0413\u0430\u0443\u0441\u0441 \u0442\u0430\u0439\u043D\u043E \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0441\u044F
    \u0441 \u043D\u0438\u043C \u0447\u0435\u0440\u0435\u0437 \u043F\u043E\u0441\u0440\u0435\u0434\u043D\u0438\u043A\u043E\u0432,
    \u043D\u043E \u0442\u0430\u043A \u0438 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u0438\u043B
    \u0441\u0432\u043E\u0435\u0433\u043E \u0441\u044B\u043D\u0430.  *   **\u0414\u043E\u0447\u0435\u0440\u0438:**
    \u0421 \u0434\u043E\u0447\u0435\u0440\u044F\u043C\u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0431\u044B\u043B\u0438 \u0442\u0435\u043F\u043B\u0435\u0435, \u043D\u043E \u0442\u043E\u0436\u0435
    \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u044B.     *   **\u041C\u0438\u043D\u043D\u0430**
    (\u043E\u0442 \u043F\u0435\u0440\u0432\u043E\u0433\u043E \u0431\u0440\u0430\u043A\u0430)
    \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u043B\u044E\u0431\u0438\u043C\u0438\u0446\u0435\u0439.
    \u041E\u043D\u0430 \u043E\u0431\u043B\u0430\u0434\u0430\u043B\u0430 \u0436\u0438\u0432\u044B\u043C
    \u0443\u043C\u043E\u043C \u0438 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u043D\u0430\u0443\u043A\u043E\u0439. \u041D\u043E \u043E\u043D\u0430 \u0441\u0442\u0440\u0430\u0434\u0430\u043B\u0430
    \u043E\u0442 \u0442\u044F\u0436\u0435\u043B\u043E\u0439 \u0431\u043E\u043B\u0435\u0437\u043D\u0438
    (\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043F\u043E\u0440\u043E\u043A\u0430
    \u0441\u0435\u0440\u0434\u0446\u0430 \u0438\u043B\u0438 \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437\u0430)
    \u0438 \u0443\u043C\u0435\u0440\u043B\u0430 \u0432 1840 \u0433\u043E\u0434\u0443
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 32 \u043B\u0435\u0442,
    \u0437\u0430 \u0433\u043E\u0434 \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    \u043C\u0430\u0447\u0435\u0445\u0438. \u0415\u0451 \u0441\u043C\u0435\u0440\u0442\u044C
    \u0441\u0442\u0430\u043B\u0430 \u0432\u0442\u043E\u0440\u044B\u043C \u0442\u044F\u0436\u0435\u043B\u0435\u0439\u0448\u0438\u043C
    \u0443\u0434\u0430\u0440\u043E\u043C \u0432 \u0436\u0438\u0437\u043D\u0438 \u0413\u0430\u0443\u0441\u0441\u0430.
    \u041E\u043D \u0431\u044B\u043B \u0431\u0435\u0437\u0443\u0442\u0435\u0448\u0435\u043D.    
    *   **\u0422\u0435\u0440\u0435\u0437\u0430** (\u043E\u0442 \u0432\u0442\u043E\u0440\u043E\u0433\u043E
    \u0431\u0440\u0430\u043A\u0430) \u0441\u0442\u0430\u043B\u0430 \xAB\u0430\u043D\u0433\u0435\u043B\u043E\u043C-\u0445\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u0435\u043C\xBB
    \u0441\u0442\u0430\u0440\u0435\u044E\u0449\u0435\u0433\u043E \u0413\u0430\u0443\u0441\u0441\u0430.
    \u041E\u043D\u0430 \u0432\u0435\u043B\u0430 \u0435\u0433\u043E \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u043E,
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B\u0430 \u0433\u043E\u0441\u0442\u0435\u0439,
    \u0437\u0430\u0431\u043E\u0442\u0438\u043B\u0430\u0441\u044C \u043E \u043D\u0435\u043C,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u043E\u0441\u043B\u0435\u043F \u043D\u0430
    \u043E\u0434\u0438\u043D \u0433\u043B\u0430\u0437 \u0432 \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0438.
    \u041E\u043D\u0430 \u043F\u043E\u0436\u0435\u0440\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u044C\u044E \u0440\u0430\u0434\u0438
    \u043E\u0442\u0446\u0430, \u0442\u0430\u043A \u0438 \u043D\u0435 \u0432\u044B\u0439\u0434\u044F
    \u0437\u0430\u043C\u0443\u0436, \u0447\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B\u043E
    \u0435\u0451 \u0432 \u0433\u043B\u0430\u0437\u0430\u0445 \u0413\u0430\u0443\u0441\u0441\u0430
    \xAB\u0441\u043F\u0430\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0435\u0439\xBB
    \u0435\u0433\u043E \u0434\u043E\u043C\u0430.  ---  ### 5. \u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440,
    \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0438 \u0438 \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u0435 
    *   **\u0418\u043D\u0442\u0440\u043E\u0432\u0435\u0440\u0442 \u0438 \u043C\u0438\u0437\u0430\u043D\u0442\u0440\u043E\u043F:**
    \u0413\u0430\u0443\u0441\u0441 \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B
    \u0441\u0432\u0435\u0442\u0441\u043A\u0438\u0435 \u0440\u0430\u0443\u0442\u044B
    \u0438 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u044B\u0435 \u043B\u0435\u043A\u0446\u0438\u0438.
    \u041E\u043D \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u043B
    \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u043E \u0432 \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u0435
    \u0438\u043B\u0438 \u0432 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u043A\u043E\u0433\u0434\u0430 \u043E\u043D
    \u043D\u0430\u0445\u043E\u0434\u0438\u043B \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E
    \u0440\u0430\u0432\u043D\u043E\u0433\u043E \u0441\u043E\u0431\u0435\u0441\u0435\u0434\u043D\u0438\u043A\u0430
    (\u043A\u0430\u043A \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440 \u0444\u043E\u043D
    \u0413\u0443\u043C\u0431\u043E\u043B\u044C\u0434\u0442 \u0438\u043B\u0438 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C
    \u0412\u0435\u0431\u0435\u0440), \u043E\u043D \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0441\u044F
    \u043E\u0436\u0438\u0432\u043B\u0435\u043D\u043D\u044B\u043C, \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u044B\u043C
    \u0438 \u0449\u0435\u0434\u0440\u044B\u043C \u043D\u0430 \u0438\u0434\u0435\u0438.
    *   **\u0414\u0440\u0443\u0436\u0431\u0430 \u0441 \u0412\u0435\u0431\u0435\u0440\u043E\u043C:**
    \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \u0441 \u0444\u0438\u0437\u0438\u043A\u043E\u043C \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u043E\u043C
    \u0412\u0435\u0431\u0435\u0440\u043E\u043C (\u0441 1831 \u0433\u043E\u0434\u0430)
    \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0439
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u0442\u0440\u0430\u0434\u043E\u0439 \u0432 \u043F\u043E\u0437\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B. \u0412\u0435\u0431\u0435\u0440 \u0431\u044B\u043B \u043C\u043E\u043B\u043E\u0436\u0435
    \u0438 \u0442\u0435\u0440\u043F\u0435\u043B\u0438\u0432\u043E \u0441\u043D\u043E\u0441\u0438\u043B
    \u0432\u0441\u043F\u044B\u043B\u044C\u0447\u0438\u0432\u043E\u0441\u0442\u044C
    \u0413\u0430\u0443\u0441\u0441\u0430. \u041E\u043D\u0438 \u0432\u043C\u0435\u0441\u0442\u0435
    \u0438\u0433\u0440\u0430\u043B\u0438 \u043D\u0430 \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430\u0445 (\u0413\u0430\u0443\u0441\u0441
    \u043B\u044E\u0431\u0438\u043B \u0444\u043E\u0440\u0442\u0435\u043F\u0438\u0430\u043D\u043E)
    \u0438 \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u043B\u0438 \u0444\u0438\u0437\u0438\u043A\u0443.
    *   **\u041D\u0435\u0432\u0440\u043E\u0437\u044B \u0438 \u0441\u0442\u0440\u0430\u0445\u0438:**
    \u0413\u0430\u0443\u0441\u0441 \u043F\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438
    \u0431\u043E\u044F\u043B\u0441\u044F \u043F\u043E\u0445\u043E\u0440\u043E\u043D
    \u0438 \u043A\u043B\u0430\u0434\u0431\u0438\u0449. \u041E\u043D \u0437\u0430\u043F\u0440\u0435\u0449\u0430\u043B
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0442\u044C \u0441\u043B\u043E\u0432\u043E
    \xAB\u0441\u043C\u0435\u0440\u0442\u044C\xBB \u0432 \u0441\u0432\u043E\u0435\u043C
    \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0438. \u0412 \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0438
    \u043E\u043D \u0441\u0442\u0440\u0430\u0434\u0430\u043B \u0438\u043F\u043E\u0445\u043E\u043D\u0434\u0440\u0438\u0435\u0439
    \u0438 \u043E\u0431\u0441\u0435\u0441\u0441\u0438\u0432\u043D\u043E-\u043A\u043E\u043C\u043F\u0443\u043B\u044C\u0441\u0438\u0432\u043D\u044B\u043C\u0438
    \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430\u043C\u0438:
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E \u043F\u0435\u0440\u0435\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u043B
    \u0448\u0430\u0433\u0438, \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u043B \u0437\u0430\u043C\u043A\u0438
    \u0438 \u0441\u043B\u0435\u0434\u0438\u043B \u0437\u0430 \u0447\u0438\u0441\u0442\u043E\u0442\u043E\u0439
    \u0440\u0443\u043A. *   **\u041F\u043E\u043B\u0438\u0442\u0438\u043A\u0430:**
    \u041E\u043D \u0431\u044B\u043B \u043B\u0438\u0431\u0435\u0440\u0430\u043B\u043E\u043C,
    \u043D\u043E \u043A\u0440\u0430\u0439\u043D\u0435 \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u044B\u043C.
    \u041D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D\u0430
    (\u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043A\u043A\u0443\u043F\u0438\u0440\u043E\u0432\u0430\u043B
    \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440) \u0438 \u0432\u043E\u0439\u043D\u0443.
    \u0412 1813 \u0433\u043E\u0434\u0443, \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0432\u043E\u0439\u043D, \u043E\u043D \u0441\u043F\u0440\u044F\u0442\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0441\u0431\u0435\u0440\u0435\u0436\u0435\u043D\u0438\u044F
    \u0432 \u043F\u043E\u0434\u0432\u0430\u043B\u0435 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438
    \u0438 \u0441\u0438\u0434\u0435\u043B \u0441 \u043F\u0438\u0441\u0442\u043E\u043B\u0435\u0442\u043E\u043C
    \u043D\u0430\u0433\u043E\u0442\u043E\u0432\u0435, \u043E\u043F\u0430\u0441\u0430\u044F\u0441\u044C
    \u043C\u0430\u0440\u043E\u0434\u0435\u0440\u043E\u0432. *   **\u0424\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u0430\u044F
    \u0441\u043A\u0443\u043F\u043E\u0441\u0442\u044C:** \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0432\u044B\u0441\u043E\u043A\u0438\u0439 \u0441\u0442\u0430\u0442\u0443\u0441,
    \u0413\u0430\u0443\u0441\u0441 \u0431\u044B\u043B \u043A\u0440\u0430\u0439\u043D\u0435
    \u0431\u0435\u0440\u0435\u0436\u043B\u0438\u0432. \u041E\u043D \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043B
    \u043D\u0430 \u043E\u0434\u0435\u0436\u0434\u0435, \u0435\u0434\u0435 \u0438
    \u043E\u0442\u043E\u043F\u043B\u0435\u043D\u0438\u0438, \u0447\u0430\u0441\u0442\u043E
    \u0441\u0438\u0434\u0435\u043B \u0432 \u043F\u0430\u043B\u044C\u0442\u043E \u0438
    \u0448\u0430\u0440\u0444\u0435 \u0432 \u043D\u0435\u0442\u043E\u043F\u043B\u0435\u043D\u043E\u0439
    \u043A\u043E\u043C\u043D\u0430\u0442\u0435. \u042D\u0442\u0430 \u0447\u0435\u0440\u0442\u0430,
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0430
    \u043E\u0442 \u043E\u0442\u0446\u0430 \u0438 \u043F\u043E\u0434\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0430
    \u0434\u0435\u0442\u0441\u043A\u043E\u0439 \u043D\u0443\u0436\u0434\u043E\u0439. 
    ---  ### 6. \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0443\u0445\u043E\u0434 \u0438\u0437 \u0436\u0438\u0437\u043D\u0438 
    \u0412 1848 \u0433\u043E\u0434\u0443 \u0443 \u0413\u0430\u0443\u0441\u0441\u0430
    \u0440\u0435\u0437\u043A\u043E \u0443\u0445\u0443\u0434\u0448\u0438\u043B\u043E\u0441\u044C
    \u0437\u0440\u0435\u043D\u0438\u0435. \u041A 1854 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043E\u0441\u043B\u0435\u043F
    \u043D\u0430 \u043B\u0435\u0432\u044B\u0439 \u0433\u043B\u0430\u0437, \u043D\u043E
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B \u0438 \u043B\u0443\u043F\u0443. 
    \u0417\u0434\u043E\u0440\u043E\u0432\u044C\u0435 \u043F\u043E\u0434\u043A\u043E\u0441\u0438\u043B\u0430
    \u0431\u0435\u0441\u0441\u043E\u043D\u043D\u0438\u0446\u0430, \u043F\u043E\u0434\u0430\u0433\u0440\u0430
    \u0438 \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u0430\u044F \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C.
    \u041E\u043D \u0443\u043C\u0435\u0440 \u0440\u0430\u043D\u043E \u0443\u0442\u0440\u043E\u043C
    23 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 1855 \u0433\u043E\u0434\u0430 \u0432
    \u0441\u0432\u043E\u0435\u043C \u043A\u0440\u0435\u0441\u043B\u0435, \u0432\u043E
    \u0441\u043D\u0435. \u0421 \u043D\u0438\u043C \u0432 \u043A\u043E\u043C\u043D\u0430\u0442\u0435
    \u0431\u044B\u043B\u0438 \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043E\u0447\u044C
    \u0422\u0435\u0440\u0435\u0437\u0430 \u0438 \u0432\u0435\u0440\u043D\u044B\u0439
    \u0441\u043B\u0443\u0433\u0430.  \u041D\u0430 \u0435\u0433\u043E \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u043D\u043E\u043C
    \u043A\u0430\u043C\u043D\u0435 \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u0430
    \u0437\u043E\u043B\u043E\u0442\u0430\u044F \u043F\u0435\u043D\u0442\u0430\u0433\u0440\u0430\u043C\u043C\u0430
    \u2014 \u0441\u0438\u043C\u0432\u043E\u043B \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E
    \u044E\u043D\u043E\u0448\u0435\u0441\u043A\u043E\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    (\u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435 17-\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430),
    \u0445\u043E\u0442\u044F \u043E\u043D \u0437\u0430\u0432\u0435\u0449\u0430\u043B
    \u0432\u044B\u0441\u0435\u0447\u044C \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u0440\u043E\u0441\u0442\u0443\u044E
    \u0437\u0432\u0435\u0437\u0434\u0443.  **\u0418\u0442\u043E\u0433:** \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0413\u0430\u0443\u0441\u0441\u0430 \u0431\u044B\u043B\u0430
    \u0442\u0440\u0430\u0433\u0438\u043A\u043E\u043C\u0438\u0447\u043D\u043E\u0439:
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0439 \u0443\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u0438\u0434\u0435\u043B \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0443
    \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439, \u043D\u0435 \u043C\u043E\u0433
    \u043D\u0430\u0432\u0435\u0441\u0442\u0438 \u043F\u043E\u0440\u044F\u0434\u043E\u043A
    \u0432 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C \u0434\u043E\u043C\u0435.
    \u041E\u043D \u043F\u0435\u0440\u0435\u0436\u0438\u043B \u0441\u043C\u0435\u0440\u0442\u044C
    \u043F\u0435\u0440\u0432\u043E\u0439 \u0436\u0435\u043D\u044B \u0438 \u043B\u044E\u0431\u0438\u043C\u043E\u0439
    \u0434\u043E\u0447\u0435\u0440\u0438, \u043F\u043E\u0441\u0441\u043E\u0440\u0438\u043B\u0441\u044F
    \u0441 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    \u0434\u0435\u0442\u044C\u043C\u0438, \u0436\u0438\u043B \u0432 \u0445\u043E\u043B\u043E\u0434\u043D\u043E\u043C
    \u0431\u0440\u0430\u043A\u0435 \u0441 \u043D\u0435\u043B\u044E\u0431\u0438\u043C\u043E\u0439
    \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439 \u0438 \u0443\u043C\u0435\u0440
    \u0432 \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u0438 \u043B\u0438\u0448\u044C
    \u043E\u0434\u043D\u043E\u0439 \u043F\u0440\u0435\u0434\u0430\u043D\u043D\u043E\u0439
    \u0434\u043E\u0447\u0435\u0440\u0438, \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u043E\u0436\u0435\u0440\u0442\u0432\u043E\u0432\u0430\u0432\u0448\u0435\u0439
    \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u044C\u044E \u0440\u0430\u0434\u0438
    \u0435\u0433\u043E \u043A\u043E\u043C\u0444\u043E\u0440\u0442\u0430."
  personalLifeEn: 
  shortBioRu: "**\u0418\u043E\u0433\u0430\u043D\u043D \u041A\u0430\u0440\u043B \u0424\u0440\u0438\u0434\u0440\u0438\u0445
    \u0413\u0430\u0443\u0441\u0441** (1777\u20131855) \u2014 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C,
    \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0441\u0442 \u0438 \u0444\u0438\u0437\u0438\u043A,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0435\u0449\u0435 \u043F\u0440\u0438
    \u0436\u0438\u0437\u043D\u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043B\u0438
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0438 \u0443\u0434\u043E\u0441\u0442\u043E\u0438\u043B\u0438 \u0442\u0438\u0442\u0443\u043B\u0430
    \xABPrinceps Mathematicorum\xBB (\u041A\u043D\u044F\u0437\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432).
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0433\u0435\u043D\u0438\u044F, \u0440\u043E\u0434\u0438\u0432\u0448\u0435\u0433\u043E\u0441\u044F
    \u0432 \u0431\u0435\u0434\u043D\u043E\u0439 \u0441\u0435\u043C\u044C\u0435 \u0438
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0441\u0432\u043E\u0435\u043C\u0443
    \u0442\u0430\u043B\u0430\u043D\u0442\u0443 \u0438 \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
    \u0441\u0443\u043C\u0435\u0432\u0448\u0435\u0433\u043E \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u0442\u044C
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0432\u043E \u043C\u043D\u043E\u0433\u0438\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445 \u043D\u0430\u0443\u043A\u0438. 
    ### \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B \u0438 \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435
    (1777\u20131798)  **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0434\u0435\u0442\u0441\u0442\u0432\u043E** \u0413\u0430\u0443\u0441\u0441
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 30 \u0430\u043F\u0440\u0435\u043B\u044F
    1777 \u0433\u043E\u0434\u0430 \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435,
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u043D\u0435\u0431\u043E\u0433\u0430\u0442\u044B\u0445
    \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u0439. \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u0413\u0435\u0431\u0445\u0430\u0440\u0434 \u0414\u0438\u0442\u0440\u0438\u0445
    \u0413\u0430\u0443\u0441\u0441, \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043C\u044F\u0441\u043D\u0438\u043A\u043E\u043C,
    \u0441\u0430\u0434\u043E\u0432\u043D\u0438\u043A\u043E\u043C, \u043A\u0430\u043C\u0435\u043D\u0449\u0438\u043A\u043E\u043C
    \u0438 \u043A\u0430\u0437\u043D\u0430\u0447\u0435\u0435\u043C. \u041C\u0430\u0442\u044C,
    \u0414\u043E\u0440\u043E\u0442\u0435\u044F \u0411\u0435\u043D\u0446\u0435, \u0431\u044B\u043B\u0430
    \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u043A\u0430\u043C\u0435\u043D\u043E\u0442\u0435\u0441\u0430
    \u0438, \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043E\u0442\u0446\u0430,
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0447\u0442\u0438 \u043D\u0435\u0433\u0440\u0430\u043C\u043E\u0442\u043D\u043E\u0439,
    \u043D\u043E \u0441\u043B\u0430\u0432\u0438\u043B\u0430\u0441\u044C \u0443\u043C\u043E\u043C
    \u0438 \u0441\u0438\u043B\u044C\u043D\u044B\u043C \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C.
    \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0413\u0430\u0443\u0441\u0441\u0430
    \u0441 \u043C\u0430\u0442\u0435\u0440\u044C\u044E \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0438\u0441\u044C
    \u043E\u0447\u0435\u043D\u044C \u0442\u0435\u043F\u043B\u044B\u043C\u0438 \u043D\u0430
    \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438 \u0432\u0441\u0435\u0439
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.  **\u0412\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434**
    \u0421\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u0413\u0430\u0443\u0441\u0441\u0430
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0440\u0430\u043D\u043E. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F \u043B\u0435\u0433\u0435\u043D\u0434\u0430,
    \u0447\u0442\u043E \u0432 \u0442\u0440\u0435\u0445\u043B\u0435\u0442\u043D\u0435\u043C
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u043E\u043D \u0437\u0430\u043C\u0435\u0442\u0438\u043B
    \u043E\u0448\u0438\u0431\u043A\u0443 \u0432 \u0440\u0430\u0441\u0447\u0435\u0442\u0430\u0445
    \u0441\u0432\u043E\u0435\u0433\u043E \u043E\u0442\u0446\u0430. \u0412 \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435, \u043A\u043E\u0433\u0434\u0430 \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432
    \u0441\u043B\u043E\u0436\u0438\u0442\u044C \u0447\u0438\u0441\u043B\u0430 \u043E\u0442
    1 \u0434\u043E 100, \u044E\u043D\u044B\u0439 \u0413\u0430\u0443\u0441\u0441 \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E
    \u0434\u0430\u043B \u043E\u0442\u0432\u0435\u0442 \u2014 5050. \u0412\u043C\u0435\u0441\u0442\u043E
    \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0442\u044C
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043E\u043D \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u043C\u043E\u0436\u043D\u043E
    \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C \u0447\u0438\u0441\u043B\u0430
    \u0432 50 \u043F\u0430\u0440: 1+100, 2+99 \u0438 \u0442.\u0434., \u043A\u0430\u0436\u0434\u0430\u044F
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0434\u0430\u0435\u0442
    101.  **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0438
    \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E**
    \u0423\u0447\u0438\u0442\u0435\u043B\u044F \u0438 \u0435\u0433\u043E \u043C\u0430\u0442\u044C
    \u043E\u0431\u0440\u0430\u0442\u0438\u043B\u0438 \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435
    \u043D\u0430 \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0434\u0430\u0440 \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430. \u0412 1791
    \u0433\u043E\u0434\u0443 \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B\u0438
    \u0433\u0435\u0440\u0446\u043E\u0433\u0443 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0441\u043A\u043E\u043C\u0443,
    \u041A\u0430\u0440\u043B\u0443 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u0443
    \u0424\u0435\u0440\u0434\u0438\u043D\u0430\u043D\u0434\u0443, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D,
    \u0447\u0442\u043E \u0432\u0437\u044F\u043B \u043D\u0430 \u0441\u0435\u0431\u044F
    \u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u0435\u0433\u043E \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F.
    \u0421 1792 \u043F\u043E 1795 \u0433\u043E\u0434 \u0413\u0430\u0443\u0441\u0441
    \u0443\u0447\u0438\u043B\u0441\u044F \u0432 Collegium Carolinum \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435,
    \u0430 \u0437\u0430\u0442\u0435\u043C, \u0441 1795 \u043F\u043E 1798 \u0433\u043E\u0434,
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. \u0412
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u043E\u043D
    \u0441\u043B\u0443\u0448\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438 \u043F\u043E
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0444\u0438\u043B\u043E\u043B\u043E\u0433\u0438\u0438
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u043D\u043E
    \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435,
    \u0441\u0434\u0435\u043B\u0430\u043D\u043D\u043E\u0435 \u0438\u043C \u0432 18
    \u043B\u0435\u0442, \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u043E
    \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u0439
    \u043F\u0443\u0442\u044C: \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438 \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E\u0433\u043E 17-\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0446\u0438\u0440\u043A\u0443\u043B\u044F
    \u0438 \u043B\u0438\u043D\u0435\u0439\u043A\u0438. \u042D\u0442\u043E \u0431\u044B\u043B\u043E
    \u043F\u0435\u0440\u0432\u043E\u0435 \u043A\u0440\u0443\u043F\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0432 \u044D\u0442\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D
    \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u0438, \u0438 \u043F\u043E\u0441\u043B\u0435
    \u043D\u0435\u0433\u043E \u0413\u0430\u0443\u0441\u0441 \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0432\u044B\u0431\u0440\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443. 
    ### \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 (1798\u20131807)  \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C
    \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433, \u0413\u0430\u0443\u0441\u0441
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E \u043E\u0442 \u0433\u0435\u0440\u0446\u043E\u0433\u0430,
    \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0435\u043C\u0443
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F \u043D\u0430\u0443\u043A\u043E\u0439,
    \u043D\u0435 \u0438\u043C\u0435\u044F \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438. \u0412 1799 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0425\u0435\u043B\u044C\u043C\u0448\u0442\u0435\u0434\u0442\u0430, \u0437\u0430\u0449\u0438\u0442\u0438\u0432
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u043E\u0441\u044C \u043F\u0435\u0440\u0432\u043E\u0435
    \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B.  **\xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\xBB
    \u0438 \u043C\u0438\u0440\u043E\u0432\u0430\u044F \u0441\u043B\u0430\u0432\u0430**
    \u0412 1801 \u0433\u043E\u0434\u0443 \u0432\u044B\u0448\u043B\u043E \u0435\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435, *Disquisitiones
    Arithmeticae* (\xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\xBB).
    \u042D\u0442\u0430 \u043A\u043D\u0438\u0433\u0430 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0430
    \u043E\u0441\u043D\u043E\u0432\u044B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B, \u0432\u0432\u0435\u0434\u044F,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \u043C\u043E\u0434\u0443\u043B\u044C\u043D\u043E\u0439 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438. 
    **\u0422\u0440\u0438\u0443\u043C\u0444 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430**
    \u041D\u0430\u0441\u0442\u043E\u044F\u0449\u0443\u044E \u043C\u0438\u0440\u043E\u0432\u0443\u044E
    \u0441\u043B\u0430\u0432\u0443 \u0413\u0430\u0443\u0441\u0441\u0443 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430
    \u043D\u0435 \u0447\u0438\u0441\u0442\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430,
    \u0430 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F. \u0412 \u044F\u043D\u0432\u0430\u0440\u0435
    1801 \u0433\u043E\u0434\u0430 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u0439
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435
    \u041F\u044C\u044F\u0446\u0446\u0438 \u043E\u0442\u043A\u0440\u044B\u043B \u043A\u0430\u0440\u043B\u0438\u043A\u043E\u0432\u0443\u044E
    \u043F\u043B\u0430\u043D\u0435\u0442\u0443 \u0426\u0435\u0440\u0435\u0440\u0443,
    \u043D\u043E \u0432\u0441\u043A\u043E\u0440\u0435 \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u0435\u0435 \u0438\u0437 \u0432\u0438\u0434\u0443. \u041C\u043D\u043E\u0433\u0438\u0435
    \u0443\u0447\u0435\u043D\u044B\u0435 \u043F\u044B\u0442\u0430\u043B\u0438\u0441\u044C
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u0442\u044C \u0435\u0435
    \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u0435 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435,
    \u043D\u043E \u0431\u0435\u0437\u0443\u0441\u043F\u0435\u0448\u043D\u043E. \u0413\u0430\u0443\u0441\u0441,
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443 \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E
    24 \u0433\u043E\u0434\u0430, \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B
    \u0441\u0432\u043E\u0439 \u043D\u043E\u0432\u044B\u0439 \u043C\u0435\u0442\u043E\u0434
    \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0438\u0445 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432
    \u0434\u043B\u044F \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0438 \u0441\u043A\u0443\u0434\u043D\u044B\u0445
    \u0434\u0430\u043D\u043D\u044B\u0445 \u0438 \u0441 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u043B
    \u043E\u0440\u0431\u0438\u0442\u0443 \u0426\u0435\u0440\u0435\u0440\u044B. \u0412
    \u0434\u0435\u043A\u0430\u0431\u0440\u0435 1801 \u0433\u043E\u0434\u0430 \u0435\u0435
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B\u0438 \u0438\u043C\u0435\u043D\u043D\u043E
    \u0442\u0430\u043C, \u0433\u0434\u0435 \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043B.
    \u042D\u0442\u043E\u0442 \u0442\u0440\u0438\u0443\u043C\u0444 \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E
    \u0441\u0434\u0435\u043B\u0430\u043B \u0413\u0430\u0443\u0441\u0441\u0430 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u043C
    \u0438 \u0443\u043A\u0440\u0435\u043F\u0438\u043B \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438.  ### \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 (1807\u20131855)  \u0412
    1807 \u0433\u043E\u0434\u0443 \u0413\u0430\u0443\u0441\u0441 \u043F\u0440\u0438\u043D\u044F\u043B
    \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435 \u0441\u0442\u0430\u0442\u044C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u0438 \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u0433\u0434\u0435
    \u0438 \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0434\u043E
    \u043A\u043E\u043D\u0446\u0430 \u0436\u0438\u0437\u043D\u0438.  **\u041B\u0438\u0447\u043D\u044B\u0435
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438** \u0412 1805 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u0418\u043E\u0433\u0430\u043D\u043D\u0435
    \u041E\u0441\u0442\u0445\u043E\u0444\u0444, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u0442\u0430\u043B\u0430 \u0435\u0433\u043E \u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u043B\u044E\u0431\u043E\u0432\u044C\u044E. \u0423 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C
    \u0442\u0440\u043E\u0435 \u0434\u0435\u0442\u0435\u0439, \u043D\u043E \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0435
    \u0441\u0447\u0430\u0441\u0442\u044C\u0435 \u0431\u044B\u043B\u043E \u043D\u0435\u0434\u043E\u043B\u0433\u0438\u043C.
    \u0412 1809 \u0433\u043E\u0434\u0443 \u0418\u043E\u0433\u0430\u043D\u043D\u0430
    \u0443\u043C\u0435\u0440\u043B\u0430 \u0432\u0441\u043A\u043E\u0440\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0440\u043E\u0434\u043E\u0432, \u0430 \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043C\u0435\u0441\u044F\u0446\u0435\u0432 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0438 \u043D\u043E\u0432\u043E\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u044B\u0439
    \u0441\u044B\u043D. \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0442\u044F\u0436\u0435\u043B\u044B\u043C
    \u0443\u0434\u0430\u0440\u043E\u043C \u0434\u043B\u044F \u0443\u0447\u0435\u043D\u043E\u0433\u043E.
    \u0412 1810 \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439 \u0440\u0430\u0437 \u2014 \u043D\u0430
    \u041C\u0438\u043D\u0435 \u0412\u0430\u043B\u044C\u0434\u0435\u043A, \u043B\u0443\u0447\u0448\u0435\u0439
    \u043F\u043E\u0434\u0440\u0443\u0433\u0435 \u0418\u043E\u0433\u0430\u043D\u043D\u044B.
    \u0412 \u044D\u0442\u043E\u043C \u0431\u0440\u0430\u043A\u0435 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C
    \u0435\u0449\u0435 \u0442\u0440\u043E\u0435 \u0434\u0435\u0442\u0435\u0439, \u043D\u043E,
    \u043F\u043E \u043E\u0442\u0437\u044B\u0432\u0430\u043C, \u043E\u043D \u0431\u044B\u043B
    \u043D\u0435 \u0442\u0430\u043A\u0438\u043C \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C. 
    **\u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u0432\u0435\u0445\u0438 \u0432
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435**  *   **\u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F:**
    \u0412 1809 \u0433\u043E\u0434\u0443 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 *Theoria motus corporum coelestium* (\xAB\u0422\u0435\u043E\u0440\u0438\u044F
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u0445
    \u0442\u0435\u043B\xBB), \u0433\u0434\u0435 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E
    \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u0441\u0432\u043E\u0439 \u043C\u0435\u0442\u043E\u0434
    \u0440\u0430\u0441\u0447\u0435\u0442\u0430 \u043E\u0440\u0431\u0438\u0442. *  
    **\u0413\u0435\u043E\u0434\u0435\u0437\u0438\u044F:** \u0421 1818 \u043F\u043E
    1832 \u0433\u043E\u0434 \u0413\u0430\u0443\u0441\u0441 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u043B
    \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u043D\u043E\u0439 \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u044A\u0435\u043C\u043A\u043E\u0439 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u0442\u0432\u0430
    \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440. \u0414\u043B\u044F \u044D\u0442\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B \u043E\u043D \u0438\u0437\u043E\u0431\u0440\u0451\u043B
    **\u0433\u0435\u043B\u0438\u043E\u0442\u0440\u043E\u043F** \u2014 \u043F\u0440\u0438\u0431\u043E\u0440
    \u0434\u043B\u044F \u0442\u043E\u0447\u043D\u043E\u0439 \u0432\u0438\u0434\u0438\u043C\u043E\u0441\u0442\u0438
    \u043D\u0430 \u0431\u043E\u043B\u044C\u0448\u0438\u0445 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F\u0445.
    \u0417\u0430\u043D\u044F\u0442\u0438\u044F \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0435\u0439
    \u043F\u0440\u0438\u0432\u0435\u043B\u0438 \u0435\u0433\u043E \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0439\u0441\u044F \u0440\u0430\u0431\u043E\u0442\u044B
    \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u2014 *Disquisitiones
    generales circa superficies curvas* (\xAB\u041E\u0431\u0449\u0438\u0435 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u043E \u043A\u0440\u0438\u0432\u044B\u0445 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044F\u0445\xBB,
    1827). \u0412 \u043D\u0435\u0439 \u043E\u043D \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    **\u0433\u0430\u0443\u0441\u0441\u043E\u0432\u043E\u0439 \u043A\u0440\u0438\u0432\u0438\u0437\u043D\u044B**
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0441\u0432\u043E\u044E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    **Theorema Egregium** (\u0412\u044B\u0434\u0430\u044E\u0449\u0443\u044E\u0441\u044F
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443), \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442, \u0447\u0442\u043E
    \u043A\u0440\u0438\u0432\u0438\u0437\u043D\u0430 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    \u043D\u0435 \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F \u043F\u0440\u0438
    \u0435\u0435 \u0438\u0437\u0433\u0438\u0431\u0430\u043D\u0438\u0438 \u0431\u0435\u0437
    \u0440\u0430\u0441\u0442\u044F\u0436\u0435\u043D\u0438\u044F. *   **\u0424\u0438\u0437\u0438\u043A\u0430
    \u0438 \u043C\u0430\u0433\u043D\u0435\u0442\u0438\u0437\u043C:** \u0412 1830-\u0445
    \u0433\u043E\u0434\u0430\u0445 \u0413\u0430\u0443\u0441\u0441 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u043C\u043E\u043B\u043E\u0434\u044B\u043C \u0444\u0438\u0437\u0438\u043A\u043E\u043C
    **\u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u043E\u043C \u0412\u0435\u0431\u0435\u0440\u043E\u043C**
    \u043D\u0430\u0447\u0430\u043B \u0438\u043D\u0442\u0435\u043D\u0441\u0438\u0432\u043D\u044B\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F \u0437\u0435\u043C\u043D\u043E\u0433\u043E
    \u043C\u0430\u0433\u043D\u0435\u0442\u0438\u0437\u043C\u0430. \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u043C\u0430\u0433\u043D\u0438\u0442\u043D\u043E\u0433\u043E
    \u043F\u043E\u043B\u044F \u0417\u0435\u043C\u043B\u0438 \u0438 \u0432 1833 \u0433\u043E\u0434\u0443
    \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u043F\u0435\u0440\u0432\u044B\u0439
    \u0432 \u043C\u0438\u0440\u0435 **\u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043C\u0430\u0433\u043D\u0438\u0442\u043D\u044B\u0439
    \u0442\u0435\u043B\u0435\u0433\u0440\u0430\u0444**, \u0441\u043E\u0435\u0434\u0438\u043D\u0438\u0432\u0448\u0438\u0439
    \u0438\u0445 \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u0438
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435. \u041E\u043D\u0438
    \u0442\u0430\u043A\u0436\u0435 \u0441\u043E\u0437\u0434\u0430\u043B\u0438 \u043C\u0430\u0433\u043D\u0438\u0442\u043E\u043C\u0435\u0442\u0440
    \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F \u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u043C\u0430\u0433\u043D\u0438\u0442\u043D\u043E\u0433\u043E \u043F\u043E\u043B\u044F.
    *   **\u041D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:**
    \u041D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438 \u0432\u0441\u0435\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0413\u0430\u0443\u0441\u0441 \u0431\u044B\u043B
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D \u0432 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0438
    \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u043D\u043E \u0431\u043E\u044F\u043B\u0441\u044F \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u0438 \u0438\u0434\u0435\u0438, \u043E\u043F\u0430\u0441\u0430\u044F\u0441\u044C
    \xAB\u043A\u0440\u0438\u043A\u0430 \u0431\u0435\u043E\u0442\u0438\u0439\u0446\u0435\u0432\xBB,
    \u043A\u0430\u043A \u043E\u043D \u043F\u0438\u0441\u0430\u043B. \u041A\u043E\u0433\u0434\u0430
    \u043E\u043D \u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u0440\u0430\u0431\u043E\u0442\u0430\u043C\u0438 \u042F\u043D\u043E\u0448\u0430
    \u0411\u043E\u0439\u044F\u0438 \u0438 \u041D\u0438\u043A\u043E\u043B\u0430\u044F
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E, \u043E\u043D
    \u043F\u0440\u0438\u0437\u043D\u0430\u043B \u0438\u0445, \u043D\u043E \u043E\u0442\u043C\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u0441\u0430\u043C \u043F\u0440\u0438\u0448\u0435\u043B \u043A
    \u0442\u0435\u043C \u0436\u0435 \u0432\u044B\u0432\u043E\u0434\u0430\u043C \u043D\u0430\u043C\u043D\u043E\u0433\u043E
    \u0440\u0430\u043D\u044C\u0448\u0435.  ### \u041B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043A\u043E\u043D\u0447\u0438\u043D\u0430  \u0413\u0430\u0443\u0441\u0441
    \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0441\u043B\u043E\u0436\u043D\u044B\u043C:
    \u043E\u043D \u043D\u0435 \u043B\u044E\u0431\u0438\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0443\u044E
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0438
    \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u043B \u0443\u0435\u0434\u0438\u043D\u0435\u043D\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E \u0443 \u043D\u0435\u0433\u043E
    \u0431\u044B\u043B\u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u0443\u0447\u0435\u043D\u0438\u043A\u0438, \u0442\u0430\u043A\u0438\u0435 \u043A\u0430\u043A
    \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434 \u0420\u0438\u043C\u0430\u043D
    \u0438 \u0420\u0438\u0445\u0430\u0440\u0434 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434.
    \u041E\u043D \u0431\u044B\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043D \u043A
    \u0441\u0435\u0431\u0435 \u0438 \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0449\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u0440\u043E\u0432\u0435\u0440\u0435\u043D\u043D\u044B\u0435 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B,
    \u0438\u0437-\u0437\u0430 \u0447\u0435\u0433\u043E \u043C\u043D\u043E\u0433\u0438\u0435
    \u0435\u0433\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0431\u044B\u0441\u0442\u0440\u043E\u0435 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0424\u0443\u0440\u044C\u0435) \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C
    \u043D\u0435\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u043C\u0438
    \u0438 \u0431\u044B\u043B\u0438 \u043F\u0435\u0440\u0435\u043E\u0442\u043A\u0440\u044B\u0442\u044B
    \u043F\u043E\u0437\u0436\u0435.  \u041A\u0430\u0440\u043B \u0424\u0440\u0438\u0434\u0440\u0438\u0445
    \u0413\u0430\u0443\u0441\u0441 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    23 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 1855 \u0433\u043E\u0434\u0430 \u0432
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    77 \u043B\u0435\u0442 \u043E\u0442 \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u043E\u0439
    \u0438 \u043B\u0435\u0433\u043E\u0447\u043D\u043E\u0439 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438.
    \u041E\u043D \u0431\u044B\u043B \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u043D\u0430 \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435 \u0410\u043B\u044C\u0431\u0430\u043D\u0438
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435.  \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0413\u0430\u0443\u0441\u0441\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u043E:
    \u0435\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C \u043D\u0430\u0437\u0432\u0430\u043D\u044B
    \u0441\u043E\u0442\u043D\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043F\u043E\u043D\u044F\u0442\u0438\u0439,
    \u0435\u0434\u0438\u043D\u0438\u0446 \u0438 \u0442\u0435\u043E\u0440\u0435\u043C.
    \u041F\u043E \u0448\u0438\u0440\u043E\u0442\u0435 \u0438 \u0433\u043B\u0443\u0431\u0438\u043D\u0435
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434\u0430 \u0432
    \u043D\u0430\u0443\u043A\u0443 \u0435\u0433\u043E \u0441\u0442\u0430\u0432\u044F\u0442
    \u0432 \u043E\u0434\u0438\u043D \u0440\u044F\u0434 \u0441 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u043E\u043C
    \u0438 \u041D\u044C\u044E\u0442\u043E\u043D\u043E\u043C."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u041A\u0430\u0440\u043B\u0430
    \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430 \u0413\u0430\u0443\u0441\u0441\u0430
    \u043F\u043E\u043B\u043D\u0430 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u043E\u0432:
    \u0433\u0435\u043D\u0438\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u0438\u0434\u0435\u043B
    \u0437\u0430\u043A\u043E\u043D\u044B \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439,
    \u043D\u043E \u043D\u0435 \u043C\u043E\u0433 \u043D\u0430\u0439\u0442\u0438 \u043E\u0431\u0449\u0438\u0439
    \u044F\u0437\u044B\u043A \u0441 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    \u0434\u0435\u0442\u044C\u043C\u0438; \u043F\u0435\u0440\u0444\u0435\u043A\u0446\u0438\u043E\u043D\u0438\u0441\u0442,
    \u0431\u043E\u044F\u0432\u0448\u0438\u0439\u0441\u044F \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u0447\u0435\u0440\u043D\u043E\u0432\u0438\u043A\u0438, \u043D\u043E \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C \u0441\u0434\u0435\u043B\u0430\u0432\u0448\u0438\u0439
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u0432\u043F\u0435\u0440\u0435\u0434.   \u0427\u0442\u043E\u0431\u044B \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u044D\u0442\u043E \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u044F \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u043B
    \u0444\u0430\u043A\u0442\u044B \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0439: **\u0434\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u0447\u0443\u0434\u0430\u0447\u0435\u0441\u0442\u0432\u0430**, **\u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u043A\u0443\u0440\u044C\u0435\u0437\u044B**, **\u0431\u044B\u0442\u043E\u0432\u044B\u0435
    \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0441\u0442\u0438**, **\u0432\u0437\u0430\u0438\u043C\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438** \u0438 **\u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u0435
    \u0437\u0430\u0433\u0430\u0434\u043A\u0438**.  ---  ### 1. \u0414\u0435\u0442\u0441\u0442\u0432\u043E:
    \u0413\u0435\u043D\u0438\u0439 \u0432 \u043A\u043E\u043B\u044B\u0431\u0435\u043B\u0438 
    - **\u041F\u043E\u043F\u0440\u0430\u0432\u043A\u0430 \u043E\u0442\u0446\u0443
    \u0432 3 \u0433\u043E\u0434\u0430:** \u0421\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430 \u0433\u043B\u0430\u0441\u0438\u0442,
    \u0447\u0442\u043E \u043A\u043E\u0433\u0434\u0430 \u043E\u0442\u0435\u0446 \u0413\u0435\u0431\u0445\u0430\u0440\u0434
    \u043F\u043E\u0434\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u043B \u0437\u0430\u0440\u043F\u043B\u0430\u0442\u0443
    \u0440\u0430\u0431\u043E\u0447\u0438\u043C, \u0442\u0440\u0435\u0445\u043B\u0435\u0442\u043D\u0438\u0439
    \u041A\u0430\u0440\u043B, \u0441\u0438\u0434\u044F \u043D\u0430 \u043F\u043E\u043B\u0443
    \u0438 \u0438\u0433\u0440\u0430\u044F, \u0432\u0434\u0440\u0443\u0433 \u0437\u0430\u044F\u0432\u0438\u043B:
    \xAB\u041F\u0430\u043F\u0430, \u0440\u0430\u0441\u0447\u0435\u0442 \u043D\u0435\u0432\u0435\u0440\u0435\u043D,
    \u0442\u0430\u043C \u0434\u043E\u043B\u0436\u043D\u043E \u0431\u044B\u0442\u044C
    \u0431\u043E\u043B\u044C\u0448\u0435\xBB. \u041E\u0442\u0435\u0446 \u043F\u0435\u0440\u0435\u0441\u0447\u0438\u0442\u0430\u043B
    \u0438, \u043A \u0441\u0432\u043E\u0435\u043C\u0443 \u0438\u0437\u0443\u043C\u043B\u0435\u043D\u0438\u044E,
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B \u043E\u0448\u0438\u0431\u043A\u0443.
    \u0413\u0430\u0443\u0441\u0441 \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C
    \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B \u044D\u0442\u043E\u0442
    \u044D\u043F\u0438\u0437\u043E\u0434 \u043A\u0430\u043A \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u043E\u043D \u0443\u043C\u0435\u043B
    \u0441\u0447\u0438\u0442\u0430\u0442\u044C \u0440\u0430\u043D\u044C\u0448\u0435,
    \u0447\u0435\u043C \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C. - **\u0421\u043F\u0430\u0441\u0435\u043D\u0438\u0435
    \u043E\u0442 \u043D\u0438\u0449\u0435\u0442\u044B \u0447\u0435\u0440\u0435\u0437
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443:** \u0423\u0447\u0438\u0442\u0435\u043B\u044C
    \u0413\u0430\u0443\u0441\u0441\u0430 \u0432 \u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435, \u0411\u044E\u0442\u0442\u043D\u0435\u0440, \u043E\u0434\u043D\u0430\u0436\u0434\u044B
    \u0434\u0430\u043B \u0437\u0430\u0434\u0430\u0447\u0443 \u0441\u043B\u043E\u0436\u0438\u0442\u044C
    \u0447\u0438\u0441\u043B\u0430 \u043E\u0442 1 \u0434\u043E 100, \u0447\u0442\u043E\u0431\u044B
    \u0437\u0430\u043D\u044F\u0442\u044C \u043A\u043B\u0430\u0441\u0441 \u043D\u0430
    \u043F\u0430\u0440\u0443 \u0447\u0430\u0441\u043E\u0432. \u0413\u0430\u0443\u0441\u0441
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043E\u0442\u0432\u0435\u0442 \u043D\u0430
    \u0433\u0440\u0438\u0444\u0435\u043B\u044C\u043D\u043E\u0439 \u0434\u043E\u0441\u043A\u0435
    **\u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E**. \u0411\u044E\u0442\u0442\u043D\u0435\u0440,
    \u043F\u043E\u0440\u0430\u0436\u0435\u043D\u043D\u044B\u0439, \u0432\u043E\u0441\u043A\u043B\u0438\u043A\u043D\u0443\u043B:
    \xAB\u0418\u0437 \u044D\u0442\u043E\u0433\u043E \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430
    \u043D\u0435 \u0432\u044B\u0439\u0434\u0435\u0442 \u043E\u0431\u044B\u0447\u043D\u044B\u0439
    \u043C\u044F\u0441\u043D\u0438\u043A!\xBB \u0418\u043C\u0435\u043D\u043D\u043E
    \u0411\u044E\u0442\u0442\u043D\u0435\u0440 \u0438 \u0435\u0433\u043E \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442
    \u0411\u0430\u0440\u0442\u0435\u043B\u044C\u0441 \u0443\u0431\u0435\u0434\u0438\u043B\u0438
    \u0433\u0435\u0440\u0446\u043E\u0433\u0430 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0441\u043A\u043E\u0433\u043E
    \u043E\u043F\u043B\u0430\u0442\u0438\u0442\u044C \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435
    \u0413\u0430\u0443\u0441\u0441\u0430. \u0415\u0441\u043B\u0438 \u0431\u044B \u043D\u0435
    \u044D\u0442\u0430 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u0430\u044F \u0437\u0430\u0434\u0430\u0447\u0430,
    \u0413\u0430\u0443\u0441\u0441, \u0441\u043A\u043E\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043E,
    \u0441\u0442\u0430\u043B \u0431\u044B \u043A\u0430\u043C\u0435\u043D\u0449\u0438\u043A\u043E\u043C,
    \u043A\u0430\u043A \u0435\u0433\u043E \u0434\u0435\u0434. - **\u042F\u0437\u044B\u043A\u043E\u0432\u043E\u0439
    \u0442\u0430\u043B\u0430\u043D\u0442:** \u0412 \u0434\u0435\u0442\u0441\u0442\u0432\u0435
    \u0413\u0430\u0443\u0441\u0441 \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B
    \u043D\u0435 \u043C\u0435\u043D\u044C\u0448\u0438\u0439 \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u0444\u0438\u043B\u043E\u043B\u043E\u0433\u0438\u0438, \u0447\u0435\u043C
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u041F\u043E\u0441\u0442\u0443\u043F\u0438\u0432
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u043E\u043D
    \u0434\u043E\u043B\u0433\u043E \u043A\u043E\u043B\u0435\u0431\u0430\u043B\u0441\u044F
    \u043C\u0435\u0436\u0434\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u0438 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u044F\u0437\u044B\u043A\u0430\u043C\u0438 (\u043B\u0430\u0442\u044B\u043D\u044C\u044E
    \u0438 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u043C). \u0414\u0430\u0436\u0435
    \u0441\u0442\u0430\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u043E\u043D \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E \u0447\u0438\u0442\u0430\u043B
    \u0434\u0440\u0435\u0432\u043D\u0438\u0445 \u0430\u0432\u0442\u043E\u0440\u043E\u0432
    \u0432 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u0435 \u0438 \u0432\u0435\u043B
    \u0441\u0432\u043E\u0438 \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0438 \u043D\u0430
    \u043B\u0430\u0442\u044B\u043D\u0438 \u2014 \u043E\u0442\u0447\u0430\u0441\u0442\u0438
    \u0447\u0442\u043E\u0431\u044B \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u043D\u0435
    \u043C\u043E\u0433\u043B\u0438 \u0435\u0433\u043E \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u044C. 
    ---  ### 2. \u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u043A\u0443\u0440\u044C\u0435\u0437\u044B:
    \u041E\u043F\u0435\u0440\u0435\u0436\u0430\u044F \u0432\u0440\u0435\u043C\u044F
    \u043D\u0430 \u0432\u0435\u043A\u0430  - **\u041F\u0440\u0435\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0432 \xAB\u041A\u043D\u044F\u0437\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432\xBB:**
    \u0425\u043E\u0442\u044F \u043C\u044B \u0437\u043D\u0430\u0435\u043C \u0435\u0433\u043E
    \u043A\u0430\u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430,
    \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u0430\u044F \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u0430\u044F
    \u0441\u043B\u0430\u0432\u0430 \u0431\u044B\u043B\u0430... **\u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439**.
    \u041A\u043E\u0433\u0434\u0430 \u043E\u043D \u043F\u0435\u0440\u0435\u0441\u0447\u0438\u0442\u0430\u043B
    \u043E\u0440\u0431\u0438\u0442\u0443 \u0426\u0435\u0440\u0435\u0440\u044B, \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C \u0416\u043E\u0437\u0435\u0444
    \u041B\u0430\u043B\u0430\u043D\u0434 \u0432\u043E\u0441\u043A\u043B\u0438\u043A\u043D\u0443\u043B:
    \xAB\u042D\u0442\u043E\u0442 \u043D\u0435\u043C\u0435\u0446 \u043D\u0430\u0448\u0435\u043B
    \u043F\u043B\u0430\u043D\u0435\u0442\u0443, \u0441\u0438\u0434\u044F \u0432 \u043A\u0440\u0435\u0441\u043B\u0435,
    \u043D\u0435 \u0433\u043B\u044F\u0434\u044F \u0432 \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F!\xBB
    \u0418\u043C\u0435\u043D\u043D\u043E \u0437\u0430 \u044D\u0442\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u0435\u0433\u043E \u043F\u0440\u043E\u0437\u0432\u0430\u043B\u0438 *Princeps
    Mathematicorum*, \u0445\u043E\u0442\u044F \u0442\u0438\u0442\u0443\u043B \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0441\u044F
    \u043A\u043E \u0432\u0441\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    - **\u0428\u0438\u0444\u0440 \u0434\u043B\u044F \u0432\u043E\u0435\u043D\u043D\u044B\u0445:**
    \u0413\u0430\u0443\u0441\u0441 \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u0430\u0440\u0430\u043D\u043E\u0438\u0434\u0430\u043B\u0435\u043D \u0432
    \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u0445 \u043F\u0440\u0438\u0432\u0430\u0442\u043D\u043E\u0441\u0442\u0438,
    \u0447\u0442\u043E \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0441\u043B\u043E\u0436\u043D\u044B\u0439 \u0448\u0438\u0444\u0440 \u0434\u043B\u044F
    \u043B\u0438\u0447\u043D\u043E\u0439 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0438
    \u0441 \u0434\u0440\u0443\u0437\u044C\u044F\u043C\u0438. \u0410 \u0432 1810-\u0445
    \u0433\u043E\u0434\u0430\u0445 \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u043B
    \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
    \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0430 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
    \u0435\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u044B \u0448\u0438\u0444\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0434\u043B\u044F \u0432\u043E\u0435\u043D\u043D\u043E\u0439 \u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0446\u0438\u0438,
    \u043D\u043E \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u0438 \u0441\u043E\u0447\u043B\u0438
    \u0435\u0433\u043E \u0438\u0434\u0435\u0438 \xAB\u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0441\u043B\u043E\u0436\u043D\u044B\u043C\u0438 \u0434\u043B\u044F \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F\xBB.
    - **\u0410\u043B\u0433\u043E\u0440\u0438\u0442\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0430\u0448\u043B\u0438 \u0447\u0435\u0440\u0435\u0437 150 \u043B\u0435\u0442:**
    \u0412 1805 \u0433\u043E\u0434\u0443 \u0413\u0430\u0443\u0441\u0441 \u0438\u0437\u043E\u0431\u0440\u0435\u043B
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C **\u0411\u044B\u0441\u0442\u0440\u043E\u0433\u043E
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0424\u0443\u0440\u044C\u0435 (\u0411\u041F\u0424)**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u0432 \u0440\u0430\u0437\u044B
    \u0443\u0441\u043A\u043E\u0440\u0438\u0442\u044C \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0443
    \u0441\u0438\u0433\u043D\u0430\u043B\u043E\u0432. \u041E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0434\u043B\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0441\u0447\u0435\u0442\u043E\u0432, \u043D\u043E \u043F\u043E\u0441\u0447\u0438\u0442\u0430\u043B
    \u044D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0442\u0440\u0438\u0432\u0438\u0430\u043B\u044C\u043D\u044B\u043C \u0438 \u043D\u0435
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B. \u041A\u043E\u0433\u0434\u0430
    \u0432 1965 \u0433\u043E\u0434\u0443 \u041A\u0443\u043B\u0438 \u0438 \u0422\u044C\u044E\u043A\u0438
    \xAB\u043F\u0435\u0440\u0435\u043E\u0442\u043A\u0440\u044B\u043B\u0438\xBB \u0411\u041F\u0424,
    \u044D\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u043E \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0439 \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0435
    (\u0431\u0435\u0437 \u044D\u0442\u043E\u0433\u043E \u043D\u0435 \u0431\u044B\u043B\u043E
    \u0431\u044B JPEG, MP3 \u0438 \u0441\u043E\u0442\u043E\u0432\u043E\u0439 \u0441\u0432\u044F\u0437\u0438).
    \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043D\u0430\u0448\u043B\u0438
    \u0437\u0430\u043F\u0438\u0441\u0438 \u0413\u0430\u0443\u0441\u0441\u0430 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u043F\u0443\u0441\u0442\u044F \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F.
    - **\u0422\u0430\u0439\u043D\u0430 \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438:** \u0413\u0430\u0443\u0441\u0441
    \u0437\u043D\u0430\u043B \u043E \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0443\u0436\u0435 \u0432 1810-\u0445 \u0433\u043E\u0434\u0430\u0445, \u043D\u043E
    **\u0438\u0441\u043F\u0443\u0433\u0430\u043B\u0441\u044F \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C**.
    \u041E\u043D \u043F\u0438\u0441\u0430\u043B \u0434\u0440\u0443\u0433\u0443 \u0411\u0435\u0441\u0441\u0435\u043B\u044E:
    \xAB\u042F \u0431\u043E\u044E\u0441\u044C \u043A\u0440\u0438\u043A\u0430 \u0431\u0435\u043E\u0442\u0438\u0439\u0446\u0435\u0432\xBB
    (\u0442\u0430\u043A \u0434\u0440\u0435\u0432\u043D\u0438\u0435 \u0433\u0440\u0435\u043A\u0438
    \u043F\u0440\u0435\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    \u0433\u043B\u0443\u043F\u0446\u043E\u0432). \u041A\u043E\u0433\u0434\u0430 \u043C\u043E\u043B\u043E\u0434\u043E\u0439
    \u0432\u0435\u043D\u0433\u0440 \u042F\u043D\u043E\u0448 \u0411\u043E\u0439\u044F\u0438
    \u0432 1830-\u0445 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u0440\u0430\u0431\u043E\u0442\u0443 \u043F\u043E \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0413\u0430\u0443\u0441\u0441
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0435\u043C\u0443: \xAB\u0425\u0432\u0430\u043B\u0438\u0442\u044C
    \u044D\u0442\u0443 \u0440\u0430\u0431\u043E\u0442\u0443 \u2014 \u0437\u043D\u0430\u0447\u0438\u0442
    \u0445\u0432\u0430\u043B\u0438\u0442\u044C \u0441\u0435\u0431\u044F \u0441\u0430\u043C\u043E\u0433\u043E,
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u044F \u043F\u0440\u0438\u0448\u0435\u043B
    \u043A \u0442\u043E\u043C\u0443 \u0436\u0435 30 \u043B\u0435\u0442 \u043D\u0430\u0437\u0430\u0434\xBB.
    \u0411\u043E\u0439\u044F\u0438 \u0431\u044B\u043B \u0440\u0430\u0437\u0434\u0430\u0432\u043B\u0435\u043D
    \u0438 \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432.  ---  ### 3. \u0411\u044B\u0442\u043E\u0432\u044B\u0435
    \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0441\u0442\u0438 \u0438 \u0447\u0443\u0434\u0430\u0447\u0435\u0441\u0442\u0432\u0430
    (\u0418\u043F\u043E\u0445\u043E\u043D\u0434\u0440\u0438\u044F)  - **\u041F\u0430\u0440\u0430\u043D\u043E\u0439\u044F
    \u043F\u043E \u043F\u043E\u0432\u043E\u0434\u0443 \u0437\u0443\u0431\u043D\u043E\u0439
    \u0431\u043E\u043B\u0438:** \u0413\u0430\u0443\u0441\u0441 \u043F\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438
    \u0431\u043E\u044F\u043B\u0441\u044F \u0441\u0442\u043E\u043C\u0430\u0442\u043E\u043B\u043E\u0433\u043E\u0432.
    \u0423 \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u0438 \u0443\u0436\u0430\u0441\u043D\u044B\u0435
    \u0437\u0443\u0431\u044B, \u0438 \u043A\u043E\u0433\u0434\u0430 \u043E\u043D\u0438
    \u043D\u0430\u0447\u0438\u043D\u0430\u043B\u0438 \u0431\u043E\u043B\u0435\u0442\u044C,
    \u043E\u043D \u043D\u0435 \u0448\u0435\u043B \u043A \u0432\u0440\u0430\u0447\u0443,
    \u0430 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u043B **\u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u0440\u0430\u0441\u0447\u0435\u0442\u0430
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0431\u043E\u043B\u0438**. \u041E\u043D
    \u043D\u043E\u0441\u0438\u043B \u0441 \u0441\u043E\u0431\u043E\u0439 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0443\u044E
    \u0437\u0430\u043F\u0438\u0441\u043D\u0443\u044E \u043A\u043D\u0438\u0436\u043A\u0443,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u043B,
    \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0438\u043D\u0443\u0442 \u0434\u043B\u0438\u0442\u0441\u044F
    \u043F\u0440\u0438\u0441\u0442\u0443\u043F, \u0438 \u0432\u044B\u0432\u043E\u0434\u0438\u043B
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \xAB\u043F\u0435\u0440\u0438\u043E\u0434\u0438\u0447\u043D\u043E\u0441\u0442\u0438\xBB
    \u0437\u0443\u0431\u043D\u043E\u0439 \u0431\u043E\u043B\u0438, \u043F\u044B\u0442\u0430\u044F\u0441\u044C
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u0442\u044C \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
    \u043F\u0440\u0438\u0441\u0442\u0443\u043F, \u0447\u0442\u043E\u0431\u044B \u0437\u0430\u0440\u0430\u043D\u0435\u0435
    \u0432\u044B\u043F\u0438\u0442\u044C \u043E\u043F\u0438\u0439. - **\u0422\u0435\u0440\u043C\u043E\u043C\u0435\u0442\u0440
    \u0432 \u0434\u043E\u043C\u0435:** \u0413\u0430\u0443\u0441\u0441 \u043D\u0435
    \u0432\u044B\u043D\u043E\u0441\u0438\u043B \u0441\u043A\u0432\u043E\u0437\u043D\u044F\u043A\u043E\u0432.
    \u0423 \u0441\u0435\u0431\u044F \u0432 \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u0435
    \u043E\u043D \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B
    \u0442\u0435\u043C\u043F\u0435\u0440\u0430\u0442\u0443\u0440\u0443 \u043D\u0435
    \u0432\u044B\u0448\u0435 14\xB0C \u0437\u0438\u043C\u043E\u0439, \u043D\u043E
    \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B
    \u0445\u043E\u043B\u043E\u0434\u043D\u044B\u0435 \u043D\u043E\u0433\u0438. \u041E\u043D
    \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B \u0441\u0438\u0441\u0442\u0435\u043C\u0443:
    \u0441\u0438\u0434\u0435\u0442\u044C \u0437\u0430 \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u044B\u043C
    \u0441\u0442\u043E\u043B\u043E\u043C \u0441 \u043D\u043E\u0433\u0430\u043C\u0438,
    \u0437\u0430\u043A\u0443\u0442\u0430\u043D\u043D\u044B\u043C\u0438 \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0441\u043B\u043E\u0435\u0432 \u0448\u0435\u0440\u0441\u0442\u044F\u043D\u044B\u0445
    \u043E\u0434\u0435\u044F\u043B, \u0438 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u043D\u043E\u0441\u0438\u0442\u044C \u043C\u0435\u0445\u043E\u0432\u0443\u044E
    \u0448\u0430\u043F\u043A\u0443 \u0432 \u043F\u043E\u043C\u0435\u0449\u0435\u043D\u0438\u0438.
    \u0421\u0442\u0443\u0434\u0435\u043D\u0442\u044B \u043F\u0440\u043E\u0437\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \xAB\u043C\u0435\u0434\u0432\u0435\u0434\u0435\u043C \u0432
    \u0431\u0435\u0440\u043B\u043E\u0433\u0435\xBB. - **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043F\u0435\u0440\u0435\u0434 \u0441\u043D\u043E\u043C:** \u0427\u0442\u043E\u0431\u044B
    \u0443\u0441\u043D\u0443\u0442\u044C, \u0413\u0430\u0443\u0441\u0441 \u043D\u0435
    \u0447\u0438\u0442\u0430\u043B \u0440\u043E\u043C\u0430\u043D\u043E\u0432, \u0430
    \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u043B \u0432 \u0443\u043C\u0435 **\u043F\u0440\u043E\u0441\u0442\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430** \u0438\u043B\u0438 \u043F\u044B\u0442\u0430\u043B\u0441\u044F
    \u043C\u044B\u0441\u043B\u0435\u043D\u043D\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u0442\u0443 \u0438\u043B\u0438 \u0438\u043D\u0443\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443.
    \u0412 \u043F\u0438\u0441\u044C\u043C\u0435 \u0434\u0440\u0443\u0433\u0443 \u043E\u043D
    \u043F\u0440\u0438\u0437\u043D\u0430\u043B\u0441\u044F, \u0447\u0442\u043E \u043D\u043E\u0447\u044C\u044E
    \u0432 \u043F\u043E\u043B\u0443\u0434\u0440\u0435\u043C\u0435 \u0435\u043C\u0443
    \u0447\u0430\u0441\u0442\u043E \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0437\u0430\u0434\u0430\u0447, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u043D\u0435\u043C \u043E\u043D \u043D\u0435 \u043C\u043E\u0433 \u043E\u0441\u0438\u043B\u0438\u0442\u044C.
    - **\u041F\u0440\u0438\u0432\u044B\u0447\u043A\u0430 \u043A \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0439
    \u043F\u0438\u0449\u0435:** \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u0443\u044E \u0437\u0430\u0440\u043F\u043B\u0430\u0442\u0443
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430, \u0413\u0430\u0443\u0441\u0441
    \u043F\u0438\u0442\u0430\u043B\u0441\u044F \u043A\u0430\u043A \u0431\u0435\u0434\u043D\u044F\u043A.
    \u041E\u043D \u043C\u043E\u0433 \u0435\u0441\u0442\u044C \u043E\u0434\u0438\u043D
    \u0438 \u0442\u043E\u0442 \u0436\u0435 \u0441\u0443\u043F \u0438\u0437 \u043A\u0430\u0440\u0442\u043E\u0444\u0435\u043B\u044F
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0434\u043D\u0435\u0439
    \u043F\u043E\u0434\u0440\u044F\u0434, \u0441\u0447\u0438\u0442\u0430\u044F, \u0447\u0442\u043E
    \u0442\u0440\u0430\u0442\u0438\u0442\u044C \u0434\u0435\u043D\u044C\u0433\u0438
    \u043D\u0430 \u0434\u0435\u043B\u0438\u043A\u0430\u0442\u0435\u0441\u044B \u2014
    \u044D\u0442\u043E \xAB\u0440\u0430\u0441\u0442\u043E\u0447\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E,
    \u043E\u0441\u043A\u043E\u0440\u0431\u043B\u044F\u044E\u0449\u0435\u0435 \u0440\u0430\u0437\u0443\u043C\xBB.
    \u041A\u043E\u043B\u043B\u0435\u0433\u0438 \u0448\u0443\u0442\u0438\u043B\u0438,
    \u0447\u0442\u043E \u0413\u0430\u0443\u0441\u0441 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0442
    \u043D\u0430 \u0435\u0434\u0435, \u0447\u0442\u043E\u0431\u044B \u043A\u0443\u043F\u0438\u0442\u044C
    \u043D\u043E\u0432\u044B\u0439 \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F. 
    ---  ### 4. \u0412\u0437\u0430\u0438\u043C\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438:
    \xAB\u042F \u2014 \u0433\u043E\u0440\u0430, \u043E\u043D\u0438 \u2014 \u0432\u0435\u0442\u0435\u0440\xBB 
    - **\u041D\u0435\u043D\u0430\u0432\u0438\u0441\u0442\u044C \u043A \xAB\u0431\u0435\u0441\u043F\u043E\u043B\u0435\u0437\u043D\u043E\u0439\xBB
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435:** \u0413\u0430\u0443\u0441\u0441 \u0431\u044B\u043B
    \u0443\u0436\u0430\u0441\u043D\u044B\u043C \u043B\u0435\u043A\u0442\u043E\u0440\u043E\u043C.
    \u041E\u043D \u0447\u0438\u0442\u0430\u043B \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B
    \u043C\u043E\u043D\u043E\u0442\u043E\u043D\u043D\u044B\u043C \u0433\u043E\u043B\u043E\u0441\u043E\u043C,
    \u0447\u0430\u0441\u0442\u043E \u0431\u0443\u0431\u043D\u0438\u043B \u0441\u0435\u0431\u0435
    \u043F\u043E\u0434 \u043D\u043E\u0441 \u0438 \u0434\u0435\u043B\u0430\u043B \u043E\u0448\u0438\u0431\u043A\u0438
    \u043D\u0430 \u0434\u043E\u0441\u043A\u0435. \u041E\u0434\u043D\u0430\u043A\u043E,
    \u0435\u0441\u043B\u0438 \u0432 \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u0438
    \u0441\u0438\u0434\u0435\u043B \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u0439
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043C\u043E\u043B\u043E\u0434\u043E\u0439 \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434
    \u0420\u0438\u043C\u0430\u043D), \u0413\u0430\u0443\u0441\u0441 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0436\u0430\u043B\u0441\u044F,
    \u043D\u0430\u0447\u0438\u043D\u0430\u043B \u0431\u043B\u0435\u0441\u0442\u0435\u0442\u044C
    \u0433\u043B\u0430\u0437\u0430\u043C\u0438 \u0438 \u0447\u0438\u0442\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0442\u0430\u043A \u0441\u043B\u043E\u0436\u043D\u043E,
    \u0447\u0442\u043E \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B
    \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u043B\u0438.
    \u0418\u0437-\u0437\u0430 \u044D\u0442\u043E\u0433\u043E \u0435\u0433\u043E \u043A\u0443\u0440\u0441
    \u0441\u043B\u0443\u0448\u0430\u043B\u0438 \u0435\u0434\u0438\u043D\u0438\u0446\u044B.
    - **\u0412\u043E\u0439\u043D\u0430 \u0441 \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D\u043E\u043C:**
    \u0413\u0430\u0443\u0441\u0441 \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u043E\u0432 \u043F\u043E\u0441\u043B\u0435
    \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u0432 1806 \u0433\u043E\u0434\u0443
    \u0432\u043E\u0439\u0441\u043A\u0430 \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D\u0430
    \u043E\u043A\u043A\u0443\u043F\u0438\u0440\u043E\u0432\u0430\u043B\u0438 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433
    \u0438 \u0443\u0431\u0438\u043B\u0438 \u0435\u0433\u043E \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044F,
    \u0433\u0435\u0440\u0446\u043E\u0433\u0430. \u0413\u0430\u0443\u0441\u0441 \u0432\u043F\u0430\u043B
    \u0432 \u044F\u0440\u043E\u0441\u0442\u044C, \u043A\u043E\u0433\u0434\u0430 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440 \u043F\u0440\u0438\u0441\u043B\u0430\u043B
    \u0435\u043C\u0443 \u043B\u0435\u0441\u0442\u043D\u043E\u0435 \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u0442\u044C \u0432 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E. \u0413\u0430\u0443\u0441\u0441
    \u043E\u0442\u0432\u0435\u0442\u0438\u043B \u0432\u0435\u0436\u043B\u0438\u0432\u044B\u043C,
    \u043D\u043E \u043B\u0435\u0434\u044F\u043D\u044B\u043C \u043E\u0442\u043A\u0430\u0437\u043E\u043C,
    \u0430 \u0432 \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0435 \u043D\u0430\u043F\u0438\u0441\u0430\u043B:
    *\xAB\u041F\u0443\u0441\u0442\u044C \u043A\u043E\u0440\u0441\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u0439
    \u0432\u044B\u0441\u043A\u043E\u0447\u043A\u0430 \u0443\u043C\u0440\u0435\u0442
    \u0432 \u0441\u043D\u0435\u0433\u0430\u0445 \u0420\u043E\u0441\u0441\u0438\u0438\xBB*
    (\u044D\u0442\u043E \u043E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u043E\u043C).
    - **\u0421\u043E\u043F\u0435\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u043E\u043C:** \u0410\u0434\u0440\u0438\u0435\u043D-\u041C\u0430\u0440\u0438
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u0438 \u0413\u0430\u0443\u0441\u0441
    \u043F\u043E\u0447\u0442\u0438 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u043E\u0442\u043A\u0440\u044B\u043B\u0438 **\u041C\u0435\u0442\u043E\u0434 \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0438\u0445
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432**. \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0435\u0433\u043E
    \u043F\u0435\u0440\u0432\u044B\u043C, \u043D\u043E \u0413\u0430\u0443\u0441\u0441
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0432 \u043F\u0440\u0435\u0434\u0438\u0441\u043B\u043E\u0432\u0438\u0438
    \u043A \u0441\u0432\u043E\u0435\u0439 \u043A\u043D\u0438\u0433\u0435, \u0447\u0442\u043E
    \xAB\u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u044D\u0442\u043E\u0442
    \u043C\u0435\u0442\u043E\u0434 \u0435\u0449\u0435 \u0432 1794 \u0433\u043E\u0434\u0443\xBB.
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u0431\u044B\u043B \u0432\u0437\u0431\u0435\u0448\u0435\u043D
    \u0438 \u043E\u0431\u0432\u0438\u043D\u0438\u043B \u0413\u0430\u0443\u0441\u0441\u0430
    \u0432 \u043F\u043B\u0430\u0433\u0438\u0430\u0442\u0435, \u043D\u0430 \u0447\u0442\u043E
    \u0413\u0430\u0443\u0441\u0441 \u043E\u0442\u0432\u0435\u0442\u0438\u043B: *\xAB\u0415\u0441\u043B\u0438
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C, \u0447\u0442\u043E \u043C\u043E\u0438
    \u0440\u0430\u0441\u0447\u0435\u0442\u044B \u0426\u0435\u0440\u0435\u0440\u044B
    \u0431\u044B\u043B\u0438 \u0441\u0434\u0435\u043B\u0430\u043D\u044B \u043F\u043E\u0437\u0436\u0435,
    \u043F\u0443\u0441\u0442\u044C \u0437\u0430\u043C\u043E\u043B\u0447\u0438\u0442\xBB*.
    \u041E\u043D\u0438 \u0442\u0430\u043A \u0438 \u043D\u0435 \u043F\u043E\u043C\u0438\u0440\u0438\u043B\u0438\u0441\u044C,
    \u0445\u043E\u0442\u044F \u0413\u0430\u0443\u0441\u0441 \u0431\u044B\u043B \u043F\u0440\u0430\u0432
    \u2014 \u0435\u0433\u043E \u0441\u0442\u0430\u0440\u044B\u0435 \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0438
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B\u0438 \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442.
    - **\u0414\u0440\u0443\u0436\u0431\u0430 \u0441 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u043C
    \u0413\u0443\u043C\u0431\u043E\u043B\u044C\u0434\u0442\u043E\u043C:** \u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A
    \u0413\u0443\u043C\u0431\u043E\u043B\u044C\u0434\u0442 \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0445, \u043A\u0442\u043E
    \u043C\u043E\u0433 \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
    \u0413\u0430\u0443\u0441\u0441\u0430. \u041A\u043E\u0433\u0434\u0430 \u0413\u0443\u043C\u0431\u043E\u043B\u044C\u0434\u0442
    \u043F\u0440\u0438\u0435\u0437\u0436\u0430\u043B \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D,
    \u043E\u043D\u0438 \u0437\u0430\u043F\u0438\u0440\u0430\u043B\u0438\u0441\u044C
    \u0432 \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u0435 \u043D\u0430 12 \u0447\u0430\u0441\u043E\u0432,
    \u043F\u0438\u043B\u0438 \u043A\u043E\u0444\u0435 \u0438 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438
    \u043E \u043C\u0430\u0433\u043D\u0435\u0442\u0438\u0437\u043C\u0435 \u0417\u0435\u043C\u043B\u0438.
    \u0413\u0443\u043C\u0431\u043E\u043B\u044C\u0434\u0442 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0443\u0432\u0430\u0436\u0430\u043B \u0413\u0430\u0443\u0441\u0441\u0430, \u0447\u0442\u043E
    \u043F\u0440\u043E\u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0435\u0433\u043E \u043C\u0430\u0433\u043D\u0438\u0442\u043D\u043E\u0439 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438
    \u0438\u0437 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u043A\u0430\u0440\u043C\u0430\u043D\u0430.  ---  ### 5. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u044E\u043C\u043E\u0440 \u0438 \u0430\u0444\u043E\u0440\u0438\u0437\u043C\u044B 
    - **\xAB\u041C\u0430\u043B\u043E, \u043D\u043E \u0433\u0440\u044F\u0437\u043D\u043E\xBB:**
    \u041D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441, \u043F\u043E\u0447\u0435\u043C\u0443
    \u043E\u043D \u043F\u0443\u0431\u043B\u0438\u043A\u0443\u0435\u0442 \u0442\u0430\u043A
    \u043C\u0430\u043B\u043E \u0440\u0430\u0431\u043E\u0442 (\u043F\u043E \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044E
    \u0441 \u042D\u0439\u043B\u0435\u0440\u043E\u043C, \u0443 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0442\u044B\u0441\u044F\u0447\u0438 \u0441\u0442\u0440\u0430\u043D\u0438\u0446),
    \u0413\u0430\u0443\u0441\u0441 \u043E\u0442\u0432\u0435\u0442\u0438\u043B: *\xAB\u041A\u043E\u0433\u0434\u0430
    \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C \u0437\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u0435\u0442
    \u0434\u043E\u043C, \u043E\u043D \u043D\u0435 \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    \u0432 \u043D\u0435\u043C \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043B\u0435\u0441\u0430 \u0438 \u043A\u0443\u0447\u0443 \u043C\u0443\u0441\u043E\u0440\u0430.
    \u042F \u0443\u0431\u0438\u0440\u0430\u044E \u0437\u0430 \u0441\u043E\u0431\u043E\u0439\xBB.*
    - **\u0422\u0435\u043E\u0440\u0438\u044F \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0432 \u0448\u0443\u0442\u043A\u0443:** \u041A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E
    \u0441\u043F\u0440\u043E\u0441\u0438\u043B\u0438, \u0447\u0442\u043E \u0431\u044B
    \u043E\u043D \u0434\u0435\u043B\u0430\u043B, \u0435\u0441\u043B\u0438 \u0431\u044B
    \u043D\u0430\u0448\u0435\u043B \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B \u0447\u0435\u0440\u0435\u0437 10 \u043B\u0435\u0442,
    \u043E\u043D \u0441\u043A\u0430\u0437\u0430\u043B: *\xAB\u042F \u0431\u044B \u0437\u0430\u043F\u0435\u0440
    \u0435\u0433\u043E \u0432 \u0441\u0435\u0439\u0444 \u043D\u0430 10 \u043B\u0435\u0442
    \u0438 \u043D\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B, \u043F\u043E\u0442\u043E\u043C\u0443
    \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u0442\u044C \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u043E\u0439
    \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E, \u0430 \u043D\u0435 \u0447\u0435\u0440\u0435\u0437
    \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u0435\xBB.* - **\u041E
    \xAB\u0433\u043B\u0443\u043F\u044B\u0445\xBB \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u0445:**
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u043D\u0435\u043A\u0438\u0439 \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A
    \u0441\u043F\u0440\u043E\u0441\u0438\u043B \u0413\u0430\u0443\u0441\u0441\u0430,
    \u0435\u0441\u0442\u044C \u043B\u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043F\u043E\u043B\u044C\u0437\u0430 \u043E\u0442 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B. \u0413\u0430\u0443\u0441\u0441 \u043E\u0442\u0432\u0435\u0442\u0438\u043B:
    *\xAB\u042D\u0442\u043E \u0446\u0430\u0440\u0438\u0446\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0415\u0441\u043B\u0438 \u0432\u0430\u043C \u043D\u0443\u0436\u043D\u0430 \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0430,
    \u0438\u0434\u0438\u0442\u0435 \u0432 \u043A\u0443\u0437\u043D\u0438\u0446\u0443\xBB*. 
    ---  ### 6. \u041F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u0435 \u0437\u0430\u0433\u0430\u0434\u043A\u0438
    \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u044B  - **\u0417\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0435
    \u0438 \u0432\u043E\u0441\u043A\u043E\u0432\u044B\u0435 \u0441\u043B\u0435\u043F\u043A\u0438:**
    \u0413\u0430\u0443\u0441\u0441 \u0437\u0430\u0432\u0435\u0449\u0430\u043B, \u0447\u0442\u043E\u0431\u044B
    \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    \u0441 \u0435\u0433\u043E \u043B\u0438\u0446\u0430 \u0438 \u0440\u0443\u043A
    \u0441\u043D\u044F\u043B\u0438 \u0433\u0438\u043F\u0441\u043E\u0432\u044B\u0435
    \u043C\u0430\u0441\u043A\u0438 (\u044D\u0442\u043E \u0431\u044B\u043B\u0430 \u043C\u043E\u0434\u0430
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438). \u041E\u0434\u043D\u0430\u043A\u043E
    \u0441\u043B\u0443\u0433\u0430, \u0431\u043E\u044F\u0441\u044C, \u0447\u0442\u043E
    \u0443\u0447\u0435\u043D\u044B\u0439 \u043C\u043E\u0436\u0435\u0442 \u043F\u0440\u043E\u0441\u043D\u0443\u0442\u044C\u0441\u044F,
    \u043A\u043E\u0433\u0434\u0430 \u0431\u0443\u0434\u0443\u0442 \u0437\u0430\u043B\u0438\u0432\u0430\u0442\u044C
    \u0433\u0438\u043F\u0441, \u043D\u0430\u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443
    \u0438\u0441\u043F\u043E\u0440\u0442\u0438\u043B \u043C\u0430\u0441\u043A\u0443.
    \u0412 \u0438\u0442\u043E\u0433\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0441\u044F
    \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u043B\u0435\u043F\u043E\u043A \u043F\u0440\u0430\u0432\u043E\u0439
    \u0440\u0443\u043A\u0438 \u0441 \u0432\u0435\u0447\u043D\u044B\u043C \u043F\u0435\u0440\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0435\u0439\u0447\u0430\u0441
    \u0445\u0440\u0430\u043D\u0438\u0442\u0441\u044F \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435.
    - **\u041C\u043E\u0437\u0433 \u0413\u0430\u0443\u0441\u0441\u0430:** \u0415\u0433\u043E
    \u043C\u043E\u0437\u0433 \u0431\u044B\u043B \u0438\u0437\u0432\u043B\u0435\u0447\u0435\u043D
    \u043F\u0440\u0438 \u0432\u0441\u043A\u0440\u044B\u0442\u0438\u0438 \u0438 \u0432\u0435\u0441\u0438\u043B
    **1492 \u0433\u0440\u0430\u043C\u043C\u0430** \u2014 \u044D\u0442\u043E \u0431\u044B\u043B
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0442\u044F\u0436\u0435\u043B\u044B\u0445
    \u043C\u043E\u0437\u0433\u043E\u0432 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438,
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043F\u0440\u0435\u0432\u044B\u0448\u0430\u044E\u0449\u0438\u0439
    \u0441\u0440\u0435\u0434\u043D\u0438\u0439 \u0432\u0435\u0441 (\u043E\u043A\u043E\u043B\u043E
    1350 \u0433). \u041E\u0434\u043D\u0430\u043A\u043E, \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u043C\u043E\u0437\u0433\u0430 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430,
    \u043C\u043E\u0437\u0433 \u0413\u0430\u0443\u0441\u0441\u0430 \u043D\u0435 \u0431\u044B\u043B
    \u0442\u0449\u0430\u0442\u0435\u043B\u044C\u043D\u043E \u0438\u0437\u0443\u0447\u0435\u043D
    \u2014 \u0435\u0433\u043E \u0434\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F
    \u0445\u0440\u0430\u043D\u0438\u043B\u0438 \u0432 \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u043D\u0435,
    \u0438 \u0442\u043E\u043B\u044C\u043A\u043E \u0432 1998 \u0433\u043E\u0434\u0443
    \u0443\u0447\u0435\u043D\u044B\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043B\u0438,
    \u0447\u0442\u043E \u0443 \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u0430 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E
    \u0440\u0430\u0437\u0432\u0438\u0442\u0430\u044F \u0438\u0437\u0432\u0438\u043B\u0438\u043D\u0430,
    \u043E\u0442\u0432\u0435\u0447\u0430\u044E\u0449\u0430\u044F \u0437\u0430 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0435. - **\u041A\u043B\u0430\u0434\u0431\u0438\u0449\u0435\u043D\u0441\u043A\u043E\u0435
    \u043F\u0440\u043E\u043A\u043B\u044F\u0442\u0438\u0435:** \u041D\u0430 \u043C\u043E\u0433\u0438\u043B\u0435
    \u0413\u0430\u0443\u0441\u0441\u0430 \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435
    \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u0430 \u043D\u0435 \u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u0438 \u043D\u0435 \u043F\u043E\u0440\u0442\u0440\u0435\u0442, \u0430 **\u0437\u043E\u043B\u043E\u0442\u0430\u044F
    \u043F\u044F\u0442\u0438\u043A\u043E\u043D\u0435\u0447\u043D\u0430\u044F \u0437\u0432\u0435\u0437\u0434\u0430
    (\u043F\u0435\u043D\u0442\u0430\u0433\u0440\u0430\u043C\u043C\u0430)**. \u041D\u043E
    \u0441\u0430\u043C\u043E\u0435 \u0437\u0430\u0431\u0430\u0432\u043D\u043E\u0435,
    \u0447\u0442\u043E \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u0438, \u0443\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0432\u0448\u0438\u0435
    \u043F\u0430\u043C\u044F\u0442\u043D\u0438\u043A, \u043F\u0435\u0440\u0435\u043F\u0443\u0442\u0430\u043B\u0438
    \u0447\u0435\u0440\u0442\u0435\u0436 \u0438 \u0432\u044B\u0441\u0435\u043A\u043B\u0438
    **\u043F\u044F\u0442\u0438\u0443\u0433\u043E\u043B\u044C\u043D\u0443\u044E \u043F\u0440\u0438\u0437\u043C\u0443**,
    \u0430 \u043D\u0435 \u043F\u043B\u043E\u0441\u043A\u0443\u044E \u0437\u0432\u0435\u0437\u0434\u0443.
    \u0413\u0430\u0443\u0441\u0441, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0438
    \u0436\u0438\u0437\u043D\u0438 \u0432\u044B\u0441\u043C\u0435\u0438\u0432\u0430\u043B
    \u043E\u0448\u0438\u0431\u043A\u0438 \u0432 \u0440\u0430\u0441\u0447\u0435\u0442\u0430\u0445,
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0431\u044B \u0432 \u0433\u0440\u043E\u0431\u0443, \u0443\u0432\u0438\u0434\u0435\u0432
    \u044D\u0442\u0443 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043D\u0435\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C. \u041E\u0448\u0438\u0431\u043A\u0443
    \u0438\u0441\u043F\u0440\u0430\u0432\u0438\u043B\u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432 2014 \u0433\u043E\u0434\u0443, \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0432
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0439 \u0431\u0430\u0440\u0435\u043B\u044C\u0435\u0444.
    - **\u0427\u0438\u0441\u043B\u043E \u042D\u0439\u043B\u0435\u0440\u0430 \u0432
    \u043F\u043E\u043C\u043E\u0449\u044C:** \u0413\u0430\u0443\u0441\u0441 \u0442\u0435\u0440\u043F\u0435\u0442\u044C
    \u043D\u0435 \u043C\u043E\u0433, \u043A\u043E\u0433\u0434\u0430 \u043A\u0442\u043E-\u0442\u043E
    \u0442\u0440\u0430\u0442\u0438\u043B \u0435\u0433\u043E \u0432\u0440\u0435\u043C\u044F.
    \u0415\u0441\u043B\u0438 \u043A \u043D\u0435\u043C\u0443 \u0432\u0445\u043E\u0434\u0438\u043B
    \u043F\u043E\u0441\u0435\u0442\u0438\u0442\u0435\u043B\u044C \u0441 \u0433\u043B\u0443\u043F\u044B\u043C
    \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u043C, \u0413\u0430\u0443\u0441\u0441
    \u043E\u0442\u0440\u044B\u0432\u0430\u043B \u0432\u0437\u0433\u043B\u044F\u0434
    \u043E\u0442 \u0431\u0443\u043C\u0430\u0433 \u0438 \u0433\u043E\u0432\u043E\u0440\u0438\u043B:
    *\xAB\u0423 \u0432\u0430\u0441 \u0435\u0441\u0442\u044C \u0440\u043E\u0432\u043D\u043E
    e \u043C\u0438\u043D\u0443\u0442\xBB* (\u0442\u043E \u0435\u0441\u0442\u044C
    2,718 \u043C\u0438\u043D\u0443\u0442), \u043F\u043E\u0441\u043B\u0435 \u0447\u0435\u0433\u043E
    \u043C\u043E\u043B\u0447\u0430 \u0436\u0434\u0430\u043B, \u043F\u043E\u043A\u0430
    \u0441\u0442\u0440\u0435\u043B\u043A\u0430 \u0447\u0430\u0441\u043E\u0432 \u043D\u0435
    \u0434\u043E\u0441\u0442\u0438\u0433\u043D\u0435\u0442 \u044D\u0442\u043E\u0433\u043E
    \u043F\u0440\u0435\u0434\u0435\u043B\u0430, \u0438 \u0432\u044B\u043F\u0440\u043E\u0432\u0430\u0436\u0438\u0432\u0430\u043B
    \u0433\u043E\u0441\u0442\u044F.  ---  ### \u0418\u0442\u043E\u0433\u043E\u0432\u0430\u044F
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0430
    (\u0432 \u0446\u0438\u0444\u0440\u0430\u0445 \u0438 \u0444\u0430\u043A\u0442\u0430\u0445) 
    - \u0417\u0430 \u0441\u0432\u043E\u044E \u0436\u0438\u0437\u043D\u044C \u0413\u0430\u0443\u0441\u0441
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0432\u0441\u0435\u0433\u043E
    **155 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0440\u0430\u0431\u043E\u0442**
    (\u044D\u0442\u043E \u0432 5 \u0440\u0430\u0437 \u043C\u0435\u043D\u044C\u0448\u0435,
    \u0447\u0435\u043C \u0443 \u042D\u0439\u043B\u0435\u0440\u0430), \u043D\u043E
    \u043A\u0430\u0436\u0434\u0430\u044F \u0438\u0437 \u043D\u0438\u0445 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u043B\u0430
    \u043D\u043E\u0432\u0443\u044E \u043E\u0431\u043B\u0430\u0441\u0442\u044C. -
    \u041E\u043D \u043B\u0438\u0447\u043D\u043E \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B
    **\u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0442\u044B\u0441\u044F\u0447
    \u043E\u0440\u0431\u0438\u0442** \u0430\u0441\u0442\u0435\u0440\u043E\u0438\u0434\u043E\u0432
    \u0438 \u043A\u043E\u043C\u0435\u0442, \u0434\u0435\u043B\u0430\u044F \u044D\u0442\u043E
    \u0434\u043B\u044F \xAB\u043E\u0442\u0434\u044B\u0445\u0430\xBB \u043E\u0442
    \u0441\u043B\u043E\u0436\u043D\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.
    - \u041E\u043D \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u0441\u0432\u043E\u0439
    **\u0434\u043D\u0435\u0432\u043D\u0438\u043A**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u0435\u043B \u043D\u0430 \u043B\u0430\u0442\u044B\u043D\u0438 \u0441 1796
    \u043F\u043E 1814 \u0433\u043E\u0434. \u0412 \u043D\u0435\u043C \u0431\u044B\u043B\u043E
    \u0432\u0441\u0435\u0433\u043E **147 \u0437\u0430\u043F\u0438\u0441\u0435\u0439**,
    \u043A\u0430\u0436\u0434\u0430\u044F \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0430 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0435\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435. \u041A\u043E\u0433\u0434\u0430
    \u044D\u0442\u043E\u0442 \u0434\u043D\u0435\u0432\u043D\u0438\u043A \u043D\u0430\u0448\u043B\u0438
    \u0432 1898 \u0433\u043E\u0434\u0443, \u0443\u0447\u0435\u043D\u044B\u0435 \u0430\u0445\u043D\u0443\u043B\u0438:
    \u0413\u0430\u0443\u0441\u0441 \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    XIX \u0432\u0435\u043A\u0430, \u043D\u043E \u043F\u0440\u043E\u0441\u0442\u043E
    \u0437\u0430\u043F\u0438\u0441\u0430\u043B \u044D\u0442\u043E \u043A\u0430\u043A
    \u0437\u0430\u043C\u0435\u0442\u043A\u0438 \u043D\u0430 \u043F\u043E\u043B\u044F\u0445,
    \u0447\u0442\u043E\u0431\u044B \u043D\u0435 \u0442\u0440\u0430\u0442\u0438\u0442\u044C
    \u0432\u0440\u0435\u043C\u044F \u043D\u0430 \u043E\u0444\u043E\u0440\u043C\u043B\u0435\u043D\u0438\u0435
    \u0441\u0442\u0430\u0442\u0435\u0439."
