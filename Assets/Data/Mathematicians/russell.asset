  achievementsRu: "\u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0411\u0435\u0440\u0442\u0440\u0430\u043D\u0430
    \u0420\u0430\u0441\u0441\u0435\u043B\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u043E
    \u0438 \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442 \u0431\u043E\u043B\u0435\u0435
    70 \u043A\u043D\u0438\u0433 \u0438 \u043E\u043A\u043E\u043B\u043E 2000 \u0441\u0442\u0430\u0442\u0435\u0439.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043B\u0435\u0436\u0430\u0442 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043B\u043E\u0433\u0438\u043A\u0438 \u0438 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043D\u043E \u043E\u043D
    \u0442\u0430\u043A\u0436\u0435 \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0441\u043B\u0435\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u044F,
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u044F\u0437\u044B\u043A\u0430
    \u0438 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438. \u0412\u0430\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439. 
    ### \U0001F4D0 \u041B\u043E\u0433\u0438\u043A\u0430 \u0438 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438  \u042D\u0442\u043E
    \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u0430\u044F \u0438 \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0447\u0430\u0441\u0442\u044C \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044F
    \u0420\u0430\u0441\u0441\u0435\u043B\u0430. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0430\u0437\u0432\u0438\u043B\u0430
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0435 \u0438\u0434\u0435\u0438,
    \u043D\u043E \u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0430
    \u043F\u0443\u0442\u0438 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438 \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u0432\u043F\u0435\u0440\u0435\u0434.  *   **\u041F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430
    \u043B\u043E\u0433\u0438\u0446\u0438\u0437\u043C\u0430:** \u0420\u0430\u0441\u0441\u0435\u043B
    \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B \u0430\u043C\u0431\u0438\u0446\u0438\u043E\u0437\u043D\u0443\u044E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443, \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0432\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u0432\u044B\u0432\u0435\u0434\u0435\u043D\u0430
    \u0438\u0437 \u0447\u0438\u0441\u0442\u043E \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u043E\u0432. \u0412\u043C\u0435\u0441\u0442\u0435
    \u0441 \u0410\u043B\u044C\u0444\u0440\u0435\u0434\u043E\u043C \u041D\u043E\u0440\u0442\u043E\u043C
    \u0423\u0430\u0439\u0442\u0445\u0435\u0434\u043E\u043C \u043E\u043D \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u044F\u043B
    \u043F\u043E\u043F\u044B\u0442\u043A\u0443 \u0440\u0435\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u0442\u044C
    \u044D\u0442\u0443 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443 \u0432
    \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u043C
    \u0442\u0440\u0435\u0445\u0442\u043E\u043C\u043D\u043E\u043C \u0442\u0440\u0443\u0434\u0435
    **\xABPrincipia Mathematica\xBB (1910\u20131913)**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u043A\u043B\u044E\u0447\u0435\u0432\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u043E\u0439
    \u0434\u043B\u044F \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F \u0432\u0441\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438. *   **\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441
    \u0420\u0430\u0441\u0441\u0435\u043B\u0430:** \u0412 1901 \u0433\u043E\u0434\u0443,
    \u0440\u0430\u0431\u043E\u0442\u0430\u044F \u043D\u0430\u0434 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432, \u0420\u0430\u0441\u0441\u0435\u043B
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u043E\u0441\u0438\u0442 \u0435\u0433\u043E \u0438\u043C\u044F. \u041E\u043D
    \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u0435\u0442 \u043F\u0440\u0438 \u0440\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0435\u043D\u0438\u0438
    \xAB\u043A\u043B\u0430\u0441\u0441\u0430 \u0432\u0441\u0435\u0445 \u043A\u043B\u0430\u0441\u0441\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0435 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0447\u043B\u0435\u043D\u0430\u043C\u0438 \u0441\u0430\u043C\u0438\u0445 \u0441\u0435\u0431\u044F\xBB:
    \u043C\u043E\u0436\u043D\u043E \u043B\u0438 \u0441\u0447\u0438\u0442\u0430\u0442\u044C
    \u044D\u0442\u043E\u0442 \u043A\u043B\u0430\u0441\u0441 \u0447\u043B\u0435\u043D\u043E\u043C
    \u0441\u0430\u043C\u043E\u0433\u043E \u0441\u0435\u0431\u044F? \u041E\u0442\u0432\u0435\u0442\u044B
    \xAB\u0434\u0430\xBB \u0438 \xAB\u043D\u0435\u0442\xBB \u0432 \u0440\u0430\u0432\u043D\u043E\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u043F\u0440\u0438\u0432\u043E\u0434\u044F\u0442
    \u043A \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u044E.
    \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0432\u0441\u043A\u0440\u044B\u043B\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0432 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0442\u0438\u043F\u043E\u0432:** \u0427\u0442\u043E\u0431\u044B \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u0442\u044C
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u043D\u044B\u0439 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441,
    \u0420\u0430\u0441\u0441\u0435\u043B \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u0442\u0438\u043F\u043E\u0432. \u0421\u0443\u0442\u044C
    \u0435\u0451 \u0432 \u0438\u0435\u0440\u0430\u0440\u0445\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u0438 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u043D\u044F\u0442\u0438\u0439: \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    (\u0438\u043B\u0438 \u043A\u043B\u0430\u0441\u0441) \u0432\u0441\u0435\u0433\u0434\u0430
    \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442 \u043A \u0431\u043E\u043B\u0435\u0435
    \u0432\u044B\u0441\u043E\u043A\u043E\u043C\u0443 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0442\u0438\u043F\u0443, \u0447\u0435\u043C \u0435\u0433\u043E \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u044B.
    \u042D\u0442\u043E \u043F\u0440\u0435\u0434\u043E\u0442\u0432\u0440\u0430\u0449\u0430\u0435\u0442
    \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438, \u043F\u0440\u0438\u0432\u043E\u0434\u044F\u0449\u0438\u0435
    \u043A \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0443 \u0441\u0430\u043C\u043E\u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u043D\u043E\u0441\u0442\u0438.
    \u0420\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u043D\u044B\u0439 \u0432\u0430\u0440\u0438\u0430\u043D\u0442
    \u044D\u0442\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438 \u043B\u0451\u0433
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \xABPrincipia Mathematica\xBB.  ###
    \U0001F5E3\uFE0F \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F \u044F\u0437\u044B\u043A\u0430
    \u0438 \u0442\u0435\u043E\u0440\u0438\u044F \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u044F 
    \u0420\u0430\u0441\u0441\u0435\u043B \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B
    \u043B\u043E\u0433\u0438\u043A\u0443 \u043A\u0430\u043A \xAB\u0441\u0443\u0449\u043D\u043E\u0441\u0442\u044C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438\xBB \u0438 \u0441\u0447\u0438\u0442\u0430\u043B,
    \u0447\u0442\u043E \u0437\u0430\u0434\u0430\u0447\u0430 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u2014 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0430\u043D\u0430\u043B\u0438\u0437
    \u044F\u0437\u044B\u043A\u0430 \u0434\u043B\u044F \u043F\u0440\u043E\u044F\u0441\u043D\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0431\u044B\u043B\u0430
    \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u043E\u0439.  *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0434\u0435\u0441\u043A\u0440\u0438\u043F\u0446\u0438\u0439 (1905):** \u042D\u0442\u043E
    \u0435\u0433\u043E \u0441\u0430\u043C\u0430\u044F \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u0438 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u0430\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0430\u044F
    \u0441\u0442\u0430\u0442\u044C\u044F. \u0420\u0430\u0441\u0441\u0435\u043B \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0435
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \xAB\u043D\u044B\u043D\u0435\u0448\u043D\u0438\u0439 \u043A\u043E\u0440\u043E\u043B\u044C
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438\xBB) \u043D\u0435 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0438\u043C\u0435\u043D\u0430\u043C\u0438 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438,
    \u0430 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0442
    \u0441\u043E\u0431\u043E\u0439 \u0441\u043A\u0440\u044B\u0442\u044B\u0435 \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438.
    \u042D\u0442\u043E\u0442 \u0430\u043D\u0430\u043B\u0438\u0437 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B
    \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u0442\u044C \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \xAB\u043D\u0435\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432\xBB (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435 \xAB\u043D\u044B\u043D\u0435\u0448\u043D\u0438\u0439
    \u043A\u043E\u0440\u043E\u043B\u044C \u0424\u0440\u0430\u043D\u0446\u0438\u0438
    \u043B\u044B\u0441\xBB \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u0451\u0442
    \u0431\u044B\u0442\u044C \u0431\u0435\u0441\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u043D\u044B\u043C
    \u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u043F\u0440\u043E\u0441\u0442\u043E
    \u043B\u043E\u0436\u043D\u044B\u043C) \u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E\u0441\u0442\u044C \u043E\u043D\u0442\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0431\u044B\u0442\u0438\u044F \u0411\u043E\u0433\u0430. *   **\u041B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u0442\u043E\u043C\u0438\u0437\u043C:** \u0412\u043C\u0435\u0441\u0442\u0435
    \u0441\u043E \u0441\u0432\u043E\u0438\u043C \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C
    \u041B\u044E\u0434\u0432\u0438\u0433\u043E\u043C \u0412\u0438\u0442\u0433\u0435\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C
    \u0420\u0430\u0441\u0441\u0435\u043B \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044E \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u0442\u043E\u043C\u0438\u0437\u043C\u0430. \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u0435\u0439, \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435 \u043C\u0435\u0436\u0434\u0443
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u043E\u0439 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u043E\u0439 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E\u0433\u043E \u044F\u0437\u044B\u043A\u0430.
    \u041F\u0440\u043E\u0441\u0442\u0435\u0439\u0448\u0438\u0435 \xAB\u0430\u0442\u043E\u043C\u0430\u0440\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B\xBB (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \xAB\u044D\u0442\u043E \u0431\u0435\u043B\u043E\u0435\xBB) \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442\u0441\u044F
    \xAB\u0430\u0442\u043E\u043C\u0430\u0440\u043D\u044B\u043C\u0438 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F\u043C\u0438\xBB,
    \u0430 \u0431\u043E\u043B\u0435\u0435 \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \xAB\u043C\u043E\u043B\u0435\u043A\u0443\u043B\u044F\u0440\u043D\u044B\u0435
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F\xBB \u0441\u0442\u0440\u043E\u044F\u0442\u0441\u044F
    \u0438\u0437 \u043D\u0438\u0445 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u0432\u044F\u0437\u043E\u043A.
    *   **\u0414\u0432\u0430 \u0432\u0438\u0434\u0430 \u0437\u043D\u0430\u043D\u0438\u044F:**
    \u0420\u0430\u0441\u0441\u0435\u043B \u043F\u0440\u043E\u0432\u0451\u043B \u0432\u0430\u0436\u043D\u043E\u0435
    \u0433\u043D\u043E\u0441\u0435\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0440\u0430\u0437\u043B\u0438\u0447\u0438\u0435 \u043C\u0435\u0436\u0434\u0443
    **\xAB\u0437\u043D\u0430\u043D\u0438\u0435\u043C-\u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E\u043C\xBB**
    (\u043D\u0435\u043F\u043E\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u0435 \u0447\u0443\u0432\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0434\u0430\u043D\u043D\u044B\u0445 \u0438 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u0438\u0439)
    \u0438 **\xAB\u0437\u043D\u0430\u043D\u0438\u0435\u043C \u043F\u043E \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044E\xBB**
    (\u0432\u0441\u0451 \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0435 \u0437\u043D\u0430\u043D\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043C\u044B \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u043C
    \u043E\u043F\u043E\u0441\u0440\u0435\u0434\u043E\u0432\u0430\u043D\u043D\u043E,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0437\u043D\u0430\u043D\u0438\u0435
    \u043E \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u043C \u043C\u0438\u0440\u0435
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0445 \u043B\u044E\u0434\u044F\u0445).
    \u0418\u043C\u0435\u043D\u0430, \u043F\u043E \u0420\u0430\u0441\u0441\u0435\u043B\u0443,
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u044E\u0442\u0441\u044F \u0442\u043E\u043B\u044C\u043A\u043E
    \u043A \u0442\u043E\u043C\u0443, \u0441 \u0447\u0435\u043C \u043C\u044B \u043D\u0435\u043F\u043E\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u0437\u043D\u0430\u043A\u043E\u043C\u044B.  ### \U0001F30C \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F
    \u043D\u0430\u0443\u043A\u0438 \u0438 \u0441\u043E\u0437\u043D\u0430\u043D\u0438\u044F 
    \u0420\u0430\u0441\u0441\u0435\u043B \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0441\u044F
    \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u043C\u0438 \u043F\u0440\u0438\u0440\u043E\u0434\u044B
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0441\u043E\u0437\u043D\u0430\u043D\u0438\u044F, \u0447\u0430\u0441\u0442\u043E
    \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u044F \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u0438\u043D\u0442\u0435\u0437\u044B.  *   **\xAB\u041D\u0435\u0439\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0439
    \u043C\u043E\u043D\u0438\u0437\u043C\xBB:** \u0412 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    1920-\u0445 \u0433\u043E\u0434\u043E\u0432 (\xAB\u0410\u043D\u0430\u043B\u0438\u0437
    \u0441\u043E\u0437\u043D\u0430\u043D\u0438\u044F\xBB, \xAB\u0410\u043D\u0430\u043B\u0438\u0437
    \u043C\u0430\u0442\u0435\u0440\u0438\u0438\xBB) \u0420\u0430\u0441\u0441\u0435\u043B
    \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044E,
    \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043C\u0438\u0440 \u0432 \u0441\u0432\u043E\u0435\u0439 \u043E\u0441\u043D\u043E\u0432\u0435
    \u0441\u043E\u0441\u0442\u043E\u0438\u0442 \u043D\u0435 \u0438\u0437 \u043C\u0430\u0442\u0435\u0440\u0438\u0438
    \u0438 \u043D\u0435 \u0438\u0437 \u0434\u0443\u0445\u0430, \u0430 \u0438\u0437
    \u043D\u0435\u043A\u043E\u0435\u0433\u043E \xAB\u043D\u0435\u0439\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0430\xBB. \u0415\u0433\u043E \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u044B
    (\u043E\u0449\u0443\u0449\u0435\u043D\u0438\u044F \u0438\u043B\u0438 \u043F\u0435\u0440\u0446\u0435\u043F\u0442\u044B)
    \u043C\u043E\u0433\u0443\u0442 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C\u0441\u044F
    \u043B\u0438\u0431\u043E \u043F\u0441\u0438\u0445\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438,
    \u043B\u0438\u0431\u043E \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0434\u0430\u043D\u043D\u044B\u043C\u0438 \u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u0438
    \u043E\u0442 \u0442\u043E\u0433\u043E, \u0432 \u043A\u0430\u043A\u0438\u0435
    \u043F\u0440\u0438\u0447\u0438\u043D\u043D\u044B\u0435 \u0441\u0432\u044F\u0437\u0438
    \u043E\u043D\u0438 \u0432\u043A\u043B\u044E\u0447\u0435\u043D\u044B. \u0422\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0444\u0438\u0437\u0438\u043A\u0430
    \u0438 \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u044F \u0438\u0437\u0443\u0447\u0430\u044E\u0442
    \u043E\u0434\u043D\u043E \u0438 \u0442\u043E \u0436\u0435, \u043D\u043E \u0441
    \u0440\u0430\u0437\u043D\u044B\u0445 \u0441\u0442\u043E\u0440\u043E\u043D. *  
    **\u0421\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430\u043B\u0438\u0437\u043C
    \u0432 \u043D\u0430\u0443\u043A\u0435:** \u0420\u0430\u0441\u0441\u0435\u043B
    \u043F\u0440\u0438\u0448\u0451\u043B \u043A \u0432\u044B\u0432\u043E\u0434\u0443,
    \u0447\u0442\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u0435
    \u0434\u0430\u0451\u0442 \u043D\u0430\u043C \u0437\u043D\u0430\u043D\u0438\u0435
    \u043D\u0435 \u043E \u0441\u0443\u0449\u043D\u043E\u0441\u0442\u0438 \u0432\u0435\u0449\u0435\u0439,
    \u0430 \u043B\u0438\u0448\u044C \u043E\u0431 \u0438\u0445 **\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0435**. \u042D\u0442\u043E
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435, \u0440\u0430\u0437\u0432\u0438\u0442\u043E\u0435
    \u0432 \u0440\u0430\u0431\u043E\u0442\u0435 \xAB\u0427\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u0435, \u0435\u0433\u043E \u0441\u0444\u0435\u0440\u0430
    \u0438 \u0433\u0440\u0430\u043D\u0438\u0446\u044B\xBB (1948), \u043F\u0435\u0440\u0435\u043A\u043B\u0438\u043A\u0430\u0435\u0442\u0441\u044F
    \u0441 \u0438\u0434\u0435\u044F\u043C\u0438 \u041A\u0430\u043D\u0442\u0430 \u0438
    \u043E\u043A\u0430\u0437\u0430\u043B\u043E \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u043F\u043E\u0437\u0438\u0442\u0438\u0432\u0438\u0437\u043C
    \u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435 \u0434\u0435\u0431\u0430\u0442\u044B
    \u043E \u043D\u0430\u0443\u0447\u043D\u043E\u043C \u0440\u0435\u0430\u043B\u0438\u0437\u043C\u0435. 
    ### \u270D\uFE0F \u041F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u044B\u0435
    \u0438 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u043E-\u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0440\u0443\u0434\u044B  \u0420\u0430\u0441\u0441\u0435\u043B \u0431\u044B\u043B
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u043C, \u043D\u043E \u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C
    \u0438 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0434\u0435\u044F\u0442\u0435\u043B\u0435\u043C. \u0417\u0430 \u044D\u0442\u0438
    \u0440\u0430\u0431\u043E\u0442\u044B \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    \u043F\u043E \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0435 \u0432
    1950 \u0433\u043E\u0434\u0443.  *   **\xAB\u0418\u0441\u0442\u043E\u0440\u0438\u044F
    \u0437\u0430\u043F\u0430\u0434\u043D\u043E\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438\xBB
    (1945):** \u042D\u0442\u0430 \u0442\u0440\u0451\u0445\u0442\u043E\u043C\u043D\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430
    \u0420\u0430\u0441\u0441\u0435\u043B\u0443 \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u0443\u044E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C \u0438 \u0441\u0442\u0430\u043B\u0430
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u044B\u0445
    \u043A\u043D\u0438\u0433 \u043F\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438,
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0445 \u0432 XX \u0432\u0435\u043A\u0435.
    *   **\u0421\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u0430\u044F \u043A\u0440\u0438\u0442\u0438\u043A\u0430:**
    \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0440\u0430\u0431\u043E\u0442 \u043D\u0430 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0442\u0435\u043C\u044B: \u043E \u0431\u0440\u0430\u043A\u0435 \u0438 \u043C\u043E\u0440\u0430\u043B\u0438
    (\xAB\u0411\u0440\u0430\u043A \u0438 \u043C\u043E\u0440\u0430\u043B\u044C\xBB,
    1929), \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0438, \u0440\u0435\u043B\u0438\u0433\u0438\u0438
    (\xAB\u041F\u043E\u0447\u0435\u043C\u0443 \u044F \u043D\u0435 \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0438\u043D\xBB,
    1927), \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0432\u043B\u0430\u0441\u0442\u0438 (\xAB\u0412\u043B\u0430\u0441\u0442\u044C\xBB,
    1938) \u0438 \u0441\u0432\u043E\u0431\u043E\u0434\u0435. *   **\xAB\u0410\u0432\u0442\u043E\u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F\xBB
    (1967\u20131969):** \u0412 \u0442\u0440\u0451\u0445 \u0442\u043E\u043C\u0430\u0445,
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0432 \u043A\u043E\u043D\u0446\u0435 \u0436\u0438\u0437\u043D\u0438, \u0420\u0430\u0441\u0441\u0435\u043B
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u043F\u0438\u0441\u0430\u043B
    \u0441\u0432\u043E\u044E \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C, \u043D\u043E \u0438 \u0434\u0430\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0441\u0430\u043C\u043E\u0430\u043D\u0430\u043B\u0438\u0437 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F."
  achievementsEn: 
  personalLifeRu: "\u0416\u0438\u0437\u043D\u044C \u0411\u0435\u0440\u0442\u0440\u0430\u043D\u0430
    \u0420\u0430\u0441\u0441\u0435\u043B\u0430 \u2014 \u044D\u0442\u043E \u043F\u043E\u0447\u0442\u0438
    \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0435, \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u043E\u0435
    \u0433\u043E\u043B\u043E\u0432\u043E\u043A\u0440\u0443\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0432\u0437\u043B\u0435\u0442\u0430\u043C\u0438, \u0431\u0443\u0440\u043D\u044B\u043C\u0438
    \u043B\u0438\u0447\u043D\u044B\u043C\u0438 \u0434\u0440\u0430\u043C\u0430\u043C\u0438
    \u0438 \u0431\u0435\u0441\u043A\u043E\u043C\u043F\u0440\u043E\u043C\u0438\u0441\u0441\u043D\u043E\u0439
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439 \u0431\u043E\u0440\u044C\u0431\u043E\u0439.
    \u041F\u0443\u0442\u044C \u043E\u0442 \u043E\u0434\u0438\u043D\u043E\u043A\u043E\u0433\u043E
    \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u0430 \u0434\u043E
    \u0441\u043E\u0432\u0435\u0441\u0442\u0438 \u0437\u0430\u043F\u0430\u0434\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430 \u0431\u044B\u043B \u0442\u0435\u0440\u043D\u0438\u0441\u0442
    \u0438 \u043F\u043E\u043B\u043E\u043D \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u043E\u0432. 
    ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B,
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u0441\u0435\u043C\u044C\u044F 
    \u0411\u0435\u0440\u0442\u0440\u0430\u043D \u0410\u0440\u0442\u0443\u0440 \u0423\u0438\u043B\u044C\u044F\u043C
    \u0420\u0430\u0441\u0441\u0435\u043B \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    18 \u043C\u0430\u044F 1872 \u0433\u043E\u0434\u0430 \u0432 \u0420\u0435\u0439\u0432\u0435\u043D\u0441\u043A\u0440\u043E\u0444\u0442\u0435,
    \u0423\u044D\u043B\u044C\u0441, \u0432 \u043E\u0434\u043D\u043E\u0439 \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0435\u043C\u0435\u0439 \u0411\u0440\u0438\u0442\u0430\u043D\u0438\u0438.
    \u0415\u0433\u043E \u0434\u0435\u0434, \u043B\u043E\u0440\u0434 \u0414\u0436\u043E\u043D
    \u0420\u0430\u0441\u0441\u0435\u043B, \u0434\u0432\u0430\u0436\u0434\u044B \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u043F\u043E\u0441\u0442 \u043F\u0440\u0435\u043C\u044C\u0435\u0440-\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430.
    \u041E\u0442\u0435\u0446, \u0432\u0438\u043A\u043E\u043D\u0442 \u042D\u043C\u0431\u0435\u0440\u043B\u0438,
    \u0438 \u043C\u0430\u0442\u044C, \u041A\u044D\u0442\u0440\u0438\u043D \u041B\u0443\u0438\u0437\u0430,
    \u0431\u044B\u043B\u0438 \u043B\u044E\u0434\u044C\u043C\u0438 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0445
    \u0434\u043B\u044F \u0432\u0438\u043A\u0442\u043E\u0440\u0438\u0430\u043D\u0441\u043A\u043E\u0439
    \u044D\u043F\u043E\u0445\u0438 \u0432\u0437\u0433\u043B\u044F\u0434\u043E\u0432,
    \u0447\u0442\u043E \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043E\u0442\u0440\u0430\u0437\u0438\u043B\u043E\u0441\u044C \u0438 \u043D\u0430
    \u0441\u0443\u0434\u044C\u0431\u0435 \u0441\u044B\u043D\u0430.  \u0421\u0447\u0430\u0441\u0442\u044C\u0435
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u0431\u044B\u043B\u043E \u043D\u0435\u0434\u043E\u043B\u0433\u0438\u043C.
    \u0412 1874 \u0433\u043E\u0434\u0443 \u043E\u0442 \u0434\u0438\u0444\u0442\u0435\u0440\u0438\u0438
    \u0443\u043C\u0435\u0440\u043B\u0438 \u043C\u0430\u0442\u044C \u0438 \u0441\u0442\u0430\u0440\u0448\u0430\u044F
    \u0441\u0435\u0441\u0442\u0440\u0430 \u0411\u0435\u0440\u0442\u0440\u0430\u043D\u0430,
    \u0430 \u0432 1876 \u0433\u043E\u0434\u0443 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0438 \u043E\u0442\u0435\u0446. \u041E\u0441\u0438\u0440\u043E\u0442\u0435\u0432
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u0447\u0435\u0442\u044B\u0440\u0435\u0445
    \u043B\u0435\u0442, \u0411\u0435\u0440\u0442\u0440\u0430\u043D \u0438 \u0435\u0433\u043E
    \u0441\u0442\u0430\u0440\u0448\u0438\u0439 \u0431\u0440\u0430\u0442 \u0424\u0440\u044D\u043D\u043A
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C \u0432 \u0446\u0435\u043D\u0442\u0440\u0435
    \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0433\u043E \u0441\u043F\u043E\u0440\u0430.
    \u0418\u0445 \u043E\u0442\u0435\u0446 \u0432 \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0438
    \u043D\u0430\u0437\u043D\u0430\u0447\u0438\u043B \u043E\u043F\u0435\u043A\u0443\u043D\u0430\u043C\u0438
    \u0434\u0432\u0443\u0445 \u0430\u0442\u0435\u0438\u0441\u0442\u043E\u0432, \u0447\u0442\u043E
    \u043F\u043E \u0442\u0435\u043C \u0432\u0440\u0435\u043C\u0435\u043D\u0430\u043C
    \u0431\u044B\u043B\u043E \u043D\u0435\u043C\u044B\u0441\u043B\u0438\u043C\u043E.
    \u0412\u043B\u0430\u0441\u0442\u0438 \u043E\u0441\u043F\u043E\u0440\u0438\u043B\u0438
    \u0432\u043E\u043B\u044E, \u0438 \u0431\u0430\u0431\u0443\u0448\u043A\u0430,
    \u0433\u0440\u0430\u0444\u0438\u043D\u044F \u0420\u0430\u0441\u0441\u0435\u043B,
    \u0434\u043E\u0431\u0438\u043B\u0430\u0441\u044C \u043E\u043F\u0435\u043A\u0438
    \u043D\u0430\u0434 \u0432\u043D\u0443\u043A\u0430\u043C\u0438. \u041E\u043D\u0430
    \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u0430 \u0411\u0435\u0440\u0442\u0440\u0430\u043D\u0430
    \u0432 \u0441\u0442\u0440\u043E\u0433\u043E\u0439 \u043F\u0443\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u043E\u0439
    \u043C\u043E\u0440\u0430\u043B\u0438, \u043F\u043E\u0441\u0435\u043B\u0438\u0432
    \u0435\u0433\u043E \u0432 \u041F\u0435\u043C\u0431\u0440\u043E\u043A-\u041B\u043E\u0434\u0436
    \u0432 \u0420\u0438\u0447\u043C\u043E\u043D\u0434-\u043F\u0430\u0440\u043A\u0435. 
    \u041E\u0434\u0438\u043D\u043E\u043A\u043E\u0435 \u0434\u0435\u0442\u0441\u0442\u0432\u043E
    \u0432 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438 \u043E\u0442 \u0441\u0432\u0435\u0440\u0441\u0442\u043D\u0438\u043A\u043E\u0432
    \u043D\u0430\u043B\u043E\u0436\u0438\u043B\u043E \u043E\u0442\u043F\u0435\u0447\u0430\u0442\u043E\u043A
    \u043D\u0430 \u0435\u0433\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440;
    \u043F\u043E\u0437\u0436\u0435 \u043E\u043D \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B\u0441\u044F,
    \u0447\u0442\u043E \u0432 \u044E\u043D\u043E\u0441\u0442\u0438 \u0435\u0433\u043E
    \u0447\u0430\u0441\u0442\u043E \u043F\u043E\u0441\u0435\u0449\u0430\u043B\u0438
    \u043C\u044B\u0441\u043B\u0438 \u043E \u0441\u0430\u043C\u043E\u0443\u0431\u0438\u0439\u0441\u0442\u0432\u0435.
    \u0421\u043F\u0430\u0441\u0435\u043D\u0438\u0435\u043C \u0434\u043B\u044F \u043D\u0435\u0433\u043E
    \u0441\u0442\u0430\u043B\u0438 \u043A\u043D\u0438\u0433\u0438 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430.
    \u0412 11 \u043B\u0435\u0442 \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E
    \u0441 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439 \u0415\u0432\u043A\u043B\u0438\u0434\u0430
    \u043E\u043D \u0441\u0440\u0430\u0432\u043D\u0438\u043B \u0441 \"\u043F\u0435\u0440\u0432\u043E\u0439
    \u043B\u044E\u0431\u043E\u0432\u044C\u044E\" \u2014 \u044D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u043B\u043E
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u043C\u0438\u0440 \u0431\u0435\u0441\u0441\u043F\u043E\u0440\u043D\u044B\u0445
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u043D\u044B\u0445 \u0438\u0441\u0442\u0438\u043D. 
    ### \U0001F393 \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u0448\u0430\u0433\u0438 \u0432 \u043D\u0430\u0443\u043A\u0435 
    \u0412 1890 \u0433\u043E\u0434\u0443 \u0420\u0430\u0441\u0441\u0435\u043B \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430, \u0433\u0434\u0435
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u0441\u0435\u0431\u044F. \u0412 1893 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0432\u044B\u0441\u0448\u0438\u0439 \u0431\u0430\u043B\u043B \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u0430 \u0432 1894 \u0433\u043E\u0434\u0443 \u2014 \u043F\u043E \u043C\u043E\u0440\u0430\u043B\u044C\u043D\u044B\u043C
    \u043D\u0430\u0443\u043A\u0430\u043C (\u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438).
    \u0412 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435 \u043E\u043D \u0432\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u044D\u043B\u0438\u0442\u043D\u043E\u0435 \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u043E\u043D\u043D\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E \"\u0410\u043F\u043E\u0441\u0442\u043E\u043B\u044B\",
    \u0433\u0434\u0435 \u0437\u0430\u0432\u044F\u0437\u0430\u043B\u0438\u0441\u044C
    \u0435\u0433\u043E \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0435 \u0434\u0440\u0443\u0436\u0435\u0441\u043A\u0438\u0435
    \u0438 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u0432\u044F\u0437\u0438 \u0441 \u0414\u0436\u043E\u0440\u0434\u0436\u0435\u043C
    \u041C\u0443\u0440\u043E\u043C \u0438 \u0410\u043B\u044C\u0444\u0440\u0435\u0434\u043E\u043C
    \u041D\u043E\u0440\u0442\u043E\u043C \u0423\u0430\u0439\u0442\u0445\u0435\u0434\u043E\u043C. 
    \u0415\u0433\u043E \u043F\u0435\u0440\u0432\u043E\u0439 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u043E\u0439 \u0441\u0442\u0430\u043B\u0430 \u043A\u043D\u0438\u0433\u0430
    \"\u0413\u0435\u0440\u043C\u0430\u043D\u0441\u043A\u0430\u044F \u0441\u043E\u0446\u0438\u0430\u043B-\u0434\u0435\u043C\u043E\u043A\u0440\u0430\u0442\u0438\u044F\"
    (1896), \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u0430\u044F \u043D\u0430
    \u043F\u043E\u0435\u0437\u0434\u043A\u0435 \u0432 \u0411\u0435\u0440\u043B\u0438\u043D.
    \u0412 1895 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E \u0432 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0435,
    \u0437\u0430\u0449\u0438\u0442\u0438\u0432 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u043F\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.  ### \U0001F494
    \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u0438 \u0431\u0443\u0440\u043D\u044B\u0435
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F  \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0420\u0430\u0441\u0441\u0435\u043B\u0430 \u0431\u044B\u043B\u0430
    \u0441\u0442\u043E\u043B\u044C \u0436\u0435 \u0441\u043B\u043E\u0436\u043D\u043E\u0439
    \u0438 \u043D\u0435\u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439,
    \u043A\u0430\u043A \u0438 \u0435\u0433\u043E \u0432\u0437\u0433\u043B\u044F\u0434\u044B. 
    *   **\u041F\u0435\u0440\u0432\u044B\u0439 \u0431\u0440\u0430\u043A \u0441 \u042D\u043B\u0438\u0441:**
    \u0412 \u0434\u0435\u043A\u0430\u0431\u0440\u0435 1894 \u0433\u043E\u0434\u0430
    \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0439
    \u043A\u0432\u0430\u043A\u0435\u0440\u0448\u0435 \u042D\u043B\u0438\u0441 \u041F\u0438\u0440\u0441\u043E\u043B\u043B
    \u0421\u043C\u0438\u0442, \u0441 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0431\u044B\u043B
    \u0437\u043D\u0430\u043A\u043E\u043C \u0441 17 \u043B\u0435\u0442. \u042D\u0442\u043E\u0442
    \u0431\u0440\u0430\u043A \u043F\u0440\u043E\u0434\u043B\u0438\u043B\u0441\u044F
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E \u0434\u043E 1921 \u0433\u043E\u0434\u0430,
    \u043E\u0434\u043D\u0430\u043A\u043E \u0432 1901 \u0433\u043E\u0434\u0443 \u0420\u0430\u0441\u0441\u0435\u043B
    \u043E\u0441\u043E\u0437\u043D\u0430\u043B, \u0447\u0442\u043E \u0431\u043E\u043B\u044C\u0448\u0435
    \u043D\u0435 \u043B\u044E\u0431\u0438\u0442 \u0436\u0435\u043D\u0443. \u041F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0447\u0442\u043E \u0440\u0430\u0437\u0440\u044B\u0432 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u0435\u043B
    \u0432 \u043C\u043E\u043C\u0435\u043D\u0442, \u043A\u043E\u0433\u0434\u0430 \u043E\u043D,
    \u043A\u0430\u0442\u0430\u044F\u0441\u044C \u043D\u0430 \u0432\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434\u0435,
    \u0432\u0434\u0440\u0443\u0433 \u043F\u043E\u043D\u044F\u043B \u044D\u0442\u043E.
    \u041E\u043D\u0438 \u0440\u0430\u0437\u0432\u0435\u043B\u0438\u0441\u044C \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432 1921 \u0433\u043E\u0434\u0443, \u0447\u0442\u043E\u0431\u044B \u0420\u0430\u0441\u0441\u0435\u043B
    \u043C\u043E\u0433 \u0436\u0435\u043D\u0438\u0442\u044C\u0441\u044F \u043D\u0430
    \u0414\u043E\u0440\u0435 \u0411\u043B\u044D\u043A. *   **\u0412\u0442\u043E\u0440\u043E\u0439
    \u0431\u0440\u0430\u043A \u0441 \u0414\u043E\u0440\u043E\u0439 \u0438 \u0448\u043A\u043E\u043B\u0430
    \"\u0411\u0438\u043A\u043E\u043D-\u0425\u0438\u043B\u043B\":** \u0414\u043E\u0440\u0430
    \u0411\u043B\u044D\u043A \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0435\u0439
    \u0438 \u0441\u043E\u0440\u0430\u0442\u043D\u0438\u0446\u0435\u0439. \u041F\u043E\u0436\u0435\u043D\u0438\u0432\u0448\u0438\u0441\u044C
    \u0432 1921 \u0433\u043E\u0434\u0443, \u043E\u043D\u0438 \u0432\u043C\u0435\u0441\u0442\u0435
    \u043E\u0441\u043D\u043E\u0432\u0430\u043B\u0438 \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441\u0438\u0432\u043D\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \"\u0411\u0438\u043A\u043E\u043D-\u0425\u0438\u043B\u043B\"
    \u0432 1927 \u0433\u043E\u0434\u0443, \u0433\u0434\u0435 \u043F\u044B\u0442\u0430\u043B\u0438\u0441\u044C
    \u0432\u043E\u043F\u043B\u043E\u0442\u0438\u0442\u044C \u0441\u0432\u043E\u0438
    \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0434\u0435\u0430\u043B\u044B. \u0412 \u044D\u0442\u043E\u043C \u0431\u0440\u0430\u043A\u0435
    \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C \u0434\u0432\u043E\u0435 \u0434\u0435\u0442\u0435\u0439:
    \u0414\u0436\u043E\u043D \u041A\u043E\u043D\u0440\u0430\u0434 (1921) \u0438 \u041A\u044D\u0442\u0440\u0438\u043D
    \u0414\u0436\u0435\u0439\u043D (1923). \u041E\u0434\u043D\u0430\u043A\u043E \u0431\u0440\u0430\u043A
    \u0440\u0430\u0441\u043F\u0430\u043B\u0441\u044F \u0432 1935 \u0433\u043E\u0434\u0443.
    *   **\u0422\u0440\u0435\u0442\u0438\u0439 \u0431\u0440\u0430\u043A \u0441 \u041F\u0430\u0442\u0440\u0438\u0446\u0438\u0435\u0439:**
    \u0412 1936 \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u041F\u0430\u0442\u0440\u0438\u0446\u0438\u0438 \"\u041F\u0438\u0442\u0435\u0440\"
    \u0421\u043F\u0435\u043D\u0441, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0440\u043E\u0434\u0438\u043B\u0430
    \u0435\u043C\u0443 \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E \u0441\u044B\u043D\u0430,
    \u041A\u043E\u043D\u0440\u0430\u0434\u0430 \u0421\u0435\u0431\u0430\u0441\u0442\u044C\u044F\u043D\u0430
    \u0420\u043E\u0431\u0435\u0440\u0442\u0430. \u042D\u0442\u043E\u0442 \u0431\u0440\u0430\u043A
    \u0442\u0430\u043A\u0436\u0435 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B\u0441\u044F
    \u0440\u0430\u0437\u0432\u043E\u0434\u043E\u043C \u0432 1952 \u0433\u043E\u0434\u0443.
    *   **\u0427\u0435\u0442\u0432\u0435\u0440\u0442\u044B\u0439 \u0431\u0440\u0430\u043A
    \u0441 \u042D\u0434\u0438\u0442:** \u0412 1952 \u0433\u043E\u0434\u0443, \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 80 \u043B\u0435\u0442, \u0420\u0430\u0441\u0441\u0435\u043B
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u0432 \u0447\u0435\u0442\u0432\u0435\u0440\u0442\u044B\u0439
    \u0440\u0430\u0437 \u2014 \u043D\u0430 \u042D\u0434\u0438\u0442 \u0424\u0438\u043D\u0447.
    \u042D\u0442\u043E\u0442 \u0441\u043E\u044E\u0437 \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C \u0438 \u043F\u0440\u043E\u0434\u043B\u0438\u043B\u0441\u044F
    \u0434\u043E \u0441\u0430\u043C\u043E\u0439 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438. 
    \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441\u043E \u0441\u0442\u0430\u0440\u0448\u0438\u043C
    \u0441\u044B\u043D\u043E\u043C \u0414\u0436\u043E\u043D\u043E\u043C \u0441\u0442\u0430\u043B\u0438
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0442\u0440\u0430\u043D\u0438\u0446 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.
    \u0420\u0430\u0441\u0441\u0435\u043B \u0432\u043E\u0437\u043B\u0430\u0433\u0430\u043B
    \u043D\u0430 \u043D\u0435\u0433\u043E \u0431\u043E\u043B\u044C\u0448\u0438\u0435
    \u043D\u0430\u0434\u0435\u0436\u0434\u044B, \u043D\u043E \u0443 \u0414\u0436\u043E\u043D\u0430
    \u0440\u0430\u0437\u0432\u0438\u043B\u0430\u0441\u044C \u0448\u0438\u0437\u043E\u0444\u0440\u0435\u043D\u0438\u044F,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0434\u043B\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430
    \u0442\u044F\u0436\u0435\u043B\u0435\u0439\u0448\u0438\u043C \u0443\u0434\u0430\u0440\u043E\u043C. 
    ### \U0001F9D1\u200D\U0001F3EB \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430, \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u044B
    \u0438 \u043F\u043E\u0435\u0437\u0434\u043A\u0438  \u0420\u0430\u0441\u0441\u0435\u043B
    \u043D\u0435\u043E\u0434\u043D\u043E\u043A\u0440\u0430\u0442\u043D\u043E \u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F
    \u0432 \u0446\u0435\u043D\u0442\u0440\u0435 \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u0442\u043E\u0438\u043B\u0438
    \u0435\u043C\u0443 \u043C\u0435\u0441\u0442\u0430 \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0445
    \u0443\u0447\u0435\u0431\u043D\u044B\u0445 \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u044F\u0445. 
    *   **\u0423\u0432\u043E\u043B\u044C\u043D\u0435\u043D\u0438\u0435 \u0438\u0437
    \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430:**
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u041F\u0435\u0440\u0432\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B \u0420\u0430\u0441\u0441\u0435\u043B,
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u0439 \u043F\u0430\u0446\u0438\u0444\u0438\u0441\u0442,
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B
    \u043F\u0440\u043E\u0442\u0438\u0432 \u043F\u0440\u0438\u0437\u044B\u0432\u0430.
    \u0412 1916 \u0433\u043E\u0434\u0443 \u0437\u0430 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044E
    \u0430\u043D\u0442\u0438\u0432\u043E\u0435\u043D\u043D\u044B\u0445 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432
    \u043E\u043D \u0431\u044B\u043B \u043E\u0448\u0442\u0440\u0430\u0444\u043E\u0432\u0430\u043D
    \u0438 \u0443\u0432\u043E\u043B\u0435\u043D \u0438\u0437 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430.
    *   **\u0422\u044E\u0440\u0435\u043C\u043D\u043E\u0435 \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435:**
    \u0412 1918 \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\u0435\u043D
    \u043A \u0448\u0435\u0441\u0442\u0438 \u043C\u0435\u0441\u044F\u0446\u0430\u043C
    \u0442\u044E\u0440\u044C\u043C\u044B \u0437\u0430 \u0441\u0442\u0430\u0442\u044C\u044E,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439, \u043F\u043E \u043C\u043D\u0435\u043D\u0438\u044E
    \u0432\u043B\u0430\u0441\u0442\u0435\u0439, \u043E\u0441\u043A\u043E\u0440\u0431\u043B\u044F\u043B
    \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0443\u044E \u0430\u0440\u043C\u0438\u044E.
    \u0421\u0432\u043E\u0435 \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435
    \u043E\u043D \u0441 \u043F\u043E\u043B\u044C\u0437\u043E\u0439 \u043F\u0440\u043E\u0432\u0435\u043B,
    \u043D\u0430\u043F\u0438\u0441\u0430\u0432 \u043A\u043D\u0438\u0433\u0443 \"\u0412\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E\". *   **\u041F\u043E\u0435\u0437\u0434\u043A\u0430
    \u0432 \u0420\u043E\u0441\u0441\u0438\u044E \u0438 \u041A\u0438\u0442\u0430\u0439:**
    \u0412 1920 \u0433\u043E\u0434\u0443 \u0420\u0430\u0441\u0441\u0435\u043B \u043F\u043E\u0441\u0435\u0442\u0438\u043B
    \u0421\u043E\u0432\u0435\u0442\u0441\u043A\u0443\u044E \u0420\u043E\u0441\u0441\u0438\u044E
    \u0432 \u0441\u043E\u0441\u0442\u0430\u0432\u0435 \u0434\u0435\u043B\u0435\u0433\u0430\u0446\u0438\u0438,
    \u0433\u0434\u0435 \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B\u0441\u044F
    \u0441 \u041B\u0435\u043D\u0438\u043D\u044B\u043C \u0438 \u0422\u0440\u043E\u0446\u043A\u0438\u043C.
    \u0423\u0432\u0438\u0434\u0435\u043D\u043D\u043E\u0435 \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u0435\u0433\u043E \u043A \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u043C\u0443
    \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u044E
    \u0432 \u0431\u043E\u043B\u044C\u0448\u0435\u0432\u0438\u0437\u043C\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043D \u0441\u0440\u0430\u0432\u043D\u0438\u043B \u0441 \u043D\u043E\u0432\u043E\u0439
    \u0440\u0435\u043B\u0438\u0433\u0438\u0435\u0439. \u0417\u0430\u0442\u0435\u043C
    \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432
    \u041A\u0438\u0442\u0430\u0439, \u0433\u0434\u0435 \u043F\u043E\u0447\u0442\u0438
    \u0433\u043E\u0434 \u0447\u0438\u0442\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438
    \u0432 \u041F\u0435\u043A\u0438\u043D\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435.
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u044D\u0442\u043E\u0439 \u043F\u043E\u0435\u0437\u0434\u043A\u0438
    \u043E\u043D \u0442\u044F\u0436\u0435\u043B\u043E \u043F\u0435\u0440\u0435\u0431\u043E\u043B\u0435\u043B
    \u043F\u043D\u0435\u0432\u043C\u043E\u043D\u0438\u0435\u0439. *   **\u0421\u043A\u0430\u043D\u0434\u0430\u043B
    \u0432 \u0421\u0428\u0410:** \u0412 \u043A\u043E\u043D\u0446\u0435 1930-\u0445
    \u2014 \u043D\u0430\u0447\u0430\u043B\u0435 1940-\u0445 \u0433\u043E\u0434\u043E\u0432
    \u0420\u0430\u0441\u0441\u0435\u043B \u0447\u0438\u0442\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\u0445
    \u0427\u0438\u043A\u0430\u0433\u043E \u0438 \u041A\u0430\u043B\u0438\u0444\u043E\u0440\u043D\u0438\u0438.
    \u0412 1940 \u0433\u043E\u0434\u0443 \u0435\u0433\u043E \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0432 \u0421\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436
    \u041D\u044C\u044E-\u0419\u043E\u0440\u043A\u0430 \u0431\u044B\u043B\u043E \u0430\u043D\u043D\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043E
    \u043F\u043E\u0441\u043B\u0435 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u043E\u0432 \u0438\u0437-\u0437\u0430
    \u0435\u0433\u043E \u043B\u0438\u0431\u0435\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0432\u0437\u0433\u043B\u044F\u0434\u043E\u0432 \u043D\u0430 \u043C\u043E\u0440\u0430\u043B\u044C
    \u0438 \u0440\u0435\u043B\u0438\u0433\u0438\u044E.  ### \U0001F468\u200D\U0001F52C
    \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438
    \u0443\u0447\u0435\u043D\u044B\u043C\u0438  \u0420\u0430\u0441\u0441\u0435\u043B
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C\u0438 \u0443\u043C\u0430\u043C\u0438
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438,
    \u0438 \u044D\u0442\u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0447\u0430\u0441\u0442\u043E \u0431\u044B\u043B\u0438 \u0441\u043B\u043E\u0436\u043D\u044B\u043C\u0438
    \u0438 \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C\u0438. 
    *   **\u0421\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u0423\u0430\u0439\u0442\u0445\u0435\u0434\u043E\u043C:** \u0418\u0445
    \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \u043D\u0430\u0434 **\"Principia Mathematica\"** (1910-1913) \u0441\u0442\u0430\u043B\u0430
    \u0432\u0435\u0440\u0448\u0438\u043D\u043E\u0439 \u0438\u0445 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0430.
    \u041E\u0434\u043D\u0430\u043A\u043E \u043F\u043E\u0437\u0436\u0435 \u0438\u0445
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u0440\u0430\u0437\u043E\u0448\u043B\u0438\u0441\u044C.
    *   **\u0414\u0440\u0443\u0436\u0431\u0430 \u0438 \u0441\u043E\u043F\u0435\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u0412\u0438\u0442\u0433\u0435\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C:**
    \u0420\u0430\u0441\u0441\u0435\u043B \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u041B\u044E\u0434\u0432\u0438\u0433\u0430 \u0412\u0438\u0442\u0433\u0435\u043D\u0448\u0442\u0435\u0439\u043D\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0438\u0435\u0445\u0430\u043B
    \u043A \u043D\u0435\u043C\u0443 \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436
    \u0432 1911 \u0433\u043E\u0434\u0443. \u0418\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0431\u044B\u043B\u0438 \u0431\u0443\u0440\u043D\u044B\u043C\u0438: \u0420\u0430\u0441\u0441\u0435\u043B
    \u0432\u0438\u0434\u0435\u043B \u0432 \u0412\u0438\u0442\u0433\u0435\u043D\u0448\u0442\u0435\u0439\u043D\u0435
    \u0433\u0435\u043D\u0438\u044F, \u043D\u043E \u0442\u043E\u0442 \u0447\u0430\u0441\u0442\u043E
    \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B \u0438 \u043E\u0441\u043F\u0430\u0440\u0438\u0432\u0430\u043B
    \u0438\u0434\u0435\u0438 \u0443\u0447\u0438\u0442\u0435\u043B\u044F. \u0418\u0445
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u043D\u0430 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E
    \u0432 \u0438\u0442\u043E\u0433\u0435 \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u043E
    \u0440\u0430\u0437\u043E\u0448\u043B\u0438\u0441\u044C. *   **\u0414\u0438\u0430\u043B\u043E\u0433
    \u0441 \u0424\u0440\u0435\u0433\u0435:** \u041E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u0432,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0438\u0434\u0435\u0438 \u043B\u043E\u0433\u0438\u0446\u0438\u0437\u043C\u0430
    \u0443\u0436\u0435 \u0432\u044B\u0441\u043A\u0430\u0437\u0430\u043D\u044B \u0413\u043E\u0442\u043B\u043E\u0431\u043E\u043C
    \u0424\u0440\u0435\u0433\u0435, \u0420\u0430\u0441\u0441\u0435\u043B \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E
    \u0432\u0441\u0442\u0443\u043F\u0438\u043B \u0441 \u043D\u0438\u043C \u0432 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443.
    \u0415\u0433\u043E \u043F\u0438\u0441\u044C\u043C\u043E \u0424\u0440\u0435\u0433\u0435
    \u0441 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435\u043C \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430,
    \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u043E\u0433\u043E \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0438\u043C\u0435\u043D\u0435\u043C \u0420\u0430\u0441\u0441\u0435\u043B\u0430,
    \u0441\u0442\u0430\u043B\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u043C.
    \u0424\u0440\u0435\u0433\u0435 \u0441 \u0433\u043E\u0440\u0435\u0447\u044C\u044E
    \u043E\u0442\u0432\u0435\u0442\u0438\u043B: \"\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430
    \u043F\u043E\u0448\u0430\u0442\u043D\u0443\u043B\u0430\u0441\u044C\". *   **\u0418\u0434\u0435\u0439\u043D\u044B\u0435
    \u0441\u043F\u043E\u0440\u044B:** \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0432\u0435\u043B \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u0435
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435 \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0438
    \u0441 \u041C\u0443\u0440\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0441\u0447\u0438\u0442\u0430\u043B \u0441\u0432\u043E\u0438\u043C \u0438\u0434\u0435\u0439\u043D\u044B\u043C
    \u0441\u043E\u0440\u0430\u0442\u043D\u0438\u043A\u043E\u043C, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0441 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u043C\u0438
    \u043F\u0440\u0430\u0433\u043C\u0430\u0442\u0438\u0441\u0442\u0430\u043C\u0438,
    \u0442\u0430\u043A\u0438\u043C\u0438 \u043A\u0430\u043A \u0423\u0438\u043B\u044C\u044F\u043C
    \u0414\u0436\u0435\u0439\u043C\u0441 \u0438 \u0414\u0436\u043E\u043D \u0414\u044C\u044E\u0438. 
    ### \U0001F54A\uFE0F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0441\u043C\u0435\u0440\u0442\u044C  \u041F\u043E\u0441\u043B\u0435 \u0412\u0442\u043E\u0440\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B \u0420\u0430\u0441\u0441\u0435\u043B
    \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0433\u043E\u043B\u043E\u0441\u043E\u0432, \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u044F
    \u0437\u0430 \u044F\u0434\u0435\u0440\u043D\u043E\u0435 \u0440\u0430\u0437\u043E\u0440\u0443\u0436\u0435\u043D\u0438\u0435
    \u0438 \u043C\u0438\u0440 \u0432\u043E \u0432\u0441\u0435\u043C \u043C\u0438\u0440\u0435.
    \u0412 1949 \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B \u043D\u0430\u0433\u0440\u0430\u0436\u0434\u0435\u043D
    \u041E\u0440\u0434\u0435\u043D\u043E\u043C \u0417\u0430\u0441\u043B\u0443\u0433,
    \u0430 \u0432 1950 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E
    \u043F\u043E \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0435. \u0412
    1955 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043C\u0430\u043D\u0438\u0444\u0435\u0441\u0442 \u0420\u0430\u0441\u0441\u0435\u043B\u0430\u2014\u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430,
    \u0430 \u0432 1958 \u0433\u043E\u0434\u0443 \u0441\u0442\u0430\u043B \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u041A\u0430\u043C\u043F\u0430\u043D\u0438\u0438 \u0437\u0430 \u044F\u0434\u0435\u0440\u043D\u043E\u0435
    \u0440\u0430\u0437\u043E\u0440\u0443\u0436\u0435\u043D\u0438\u0435. \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    89 \u043B\u0435\u0442, \u0432 1961 \u0433\u043E\u0434\u0443, \u043E\u043D \u0441\u043D\u043E\u0432\u0430
    \u043F\u0440\u043E\u0432\u0435\u043B \u043D\u0435\u0434\u0435\u043B\u044E \u0432
    \u0442\u044E\u0440\u044C\u043C\u0435 \u0437\u0430 \u0443\u0447\u0430\u0441\u0442\u0438\u0435
    \u0432 \u0430\u043D\u0442\u0438\u0432\u043E\u0435\u043D\u043D\u043E\u0439 \u0430\u043A\u0446\u0438\u0438. 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043F\u0440\u0435\u043A\u043B\u043E\u043D\u043D\u044B\u0439
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442, \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B
    \u0430\u043A\u0442\u0438\u0432\u043D\u0443\u044E \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C.
    \u0412 1967 \u0433\u043E\u0434\u0443 \u043D\u0430\u0447\u0430\u043B \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044E
    \u0442\u0440\u0435\u0445\u0442\u043E\u043C\u043D\u043E\u0439 \u0430\u0432\u0442\u043E\u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438.
    \u0411\u0435\u0440\u0442\u0440\u0430\u043D \u0420\u0430\u0441\u0441\u0435\u043B
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u043E\u0442 \u0433\u0440\u0438\u043F\u043F\u0430
    2 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 1970 \u0433\u043E\u0434\u0430 \u0432
    \u0441\u0432\u043E\u0435\u043C \u0434\u043E\u043C\u0435 \u0432 \u0423\u044D\u043B\u044C\u0441\u0435,
    \u043D\u0435 \u0434\u043E\u0436\u0438\u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043C\u0435\u0441\u044F\u0446\u0435\u0432 \u0434\u043E \u0441\u0432\u043E\u0435\u0433\u043E
    98-\u043B\u0435\u0442\u0438\u044F."
  personalLifeEn: 
  shortBioRu: "\u0411\u0435\u0440\u0442\u0440\u0430\u043D \u0420\u0430\u0441\u0441\u0435\u043B
    (1872\u20131970) \u043F\u0440\u043E\u0436\u0438\u043B \u043F\u043E\u0447\u0442\u0438
    \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0435, \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u043E\u0435
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F\u043C\u0438 \u0432 \u043B\u043E\u0433\u0438\u043A\u0435
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438, \u0431\u0443\u0440\u043D\u044B\u043C\u0438
    \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043A\u0430\u043C\u043F\u0430\u043D\u0438\u044F\u043C\u0438 \u0438 \u043B\u0438\u0447\u043D\u044B\u043C\u0438
    \u0434\u0440\u0430\u043C\u0430\u043C\u0438. \u041E\u0434\u0438\u043D \u0438\u0437
    \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438, \u043E\u043D \u0431\u044B\u043B
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u0438
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C \u043C\u044B\u0441\u043B\u0438\u0442\u0435\u043B\u0435\u043C,
    \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u0438 \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u044B\u043C \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0434\u0435\u044F\u0442\u0435\u043B\u0435\u043C, \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u0435\u043C
    \u0441\u0430\u043C\u044B\u0445 \u0431\u0443\u0440\u043D\u044B\u0445 \u0441\u043E\u0431\u044B\u0442\u0438\u0439
    XX \u0432\u0435\u043A\u0430. \u0415\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0432\u043E\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043E\u0442 \u0432\u0438\u043A\u0442\u043E\u0440\u0438\u0430\u043D\u0441\u043A\u043E\u0439
    \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u0438\u0438 \u043A
    \u0440\u043E\u043B\u0438 \u0441\u043E\u0432\u0435\u0441\u0442\u0438 \u0437\u0430\u043F\u0430\u0434\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430.  ### \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438
    \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435 
    \u0420\u0430\u0441\u0441\u0435\u043B \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    18 \u043C\u0430\u044F 1872 \u0433\u043E\u0434\u0430 \u0432 \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0435\u043C\u044C\u0435 \u0432 \u0423\u044D\u043B\u044C\u0441\u0435. \u0415\u0433\u043E
    \u0434\u0435\u0434, \u043B\u043E\u0440\u0434 \u0414\u0436\u043E\u043D \u0420\u0430\u0441\u0441\u0435\u043B,
    \u0434\u0432\u0430\u0436\u0434\u044B \u0431\u044B\u043B \u043F\u0440\u0435\u043C\u044C\u0435\u0440-\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u043E\u043C
    \u0412\u0435\u043B\u0438\u043A\u043E\u0431\u0440\u0438\u0442\u0430\u043D\u0438\u0438.
    \u0415\u0433\u043E \u043A\u0440\u0451\u0441\u0442\u043D\u044B\u043C \u043E\u0442\u0446\u043E\u043C
    \u0431\u044B\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444 \u0414\u0436\u043E\u043D \u0421\u0442\u044E\u0430\u0440\u0442
    \u041C\u0438\u043B\u043B\u044C, \u0447\u044C\u0438 \u0438\u0434\u0435\u0438 \u0441\u0438\u043B\u044C\u043D\u043E
    \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0438 \u043D\u0430 \u043D\u0435\u0433\u043E
    \u0432 \u044E\u043D\u043E\u0441\u0442\u0438. \u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0420\u0430\u0441\u0441\u0435\u043B\u0430 \u0431\u044B\u043B\u0438
    \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u044B \u0447\u0435\u0440\u0435\u0434\u043E\u0439
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0439: \u0432 1874 \u0433\u043E\u0434\u0443
    \u043E\u0442 \u0434\u0438\u0444\u0442\u0435\u0440\u0438\u0438 \u0443\u043C\u0435\u0440\u043B\u0438
    \u0435\u0433\u043E \u043C\u0430\u0442\u044C \u0438 \u0441\u0435\u0441\u0442\u0440\u0430,
    \u0430 \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0430 \u0433\u043E\u0434\u0430,
    \u0432 1876-\u043C, \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u043E\u0442\u0435\u0446.
    \u041E\u0441\u0438\u0440\u043E\u0442\u0435\u0432 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u0447\u0435\u0442\u044B\u0440\u0451\u0445 \u043B\u0435\u0442, \u0411\u0435\u0440\u0442\u0440\u0430\u043D
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441\u043E \u0441\u0442\u0430\u0440\u0448\u0438\u043C
    \u0431\u0440\u0430\u0442\u043E\u043C \u0424\u0440\u044D\u043D\u043A\u043E\u043C
    \u0431\u044B\u043B \u043E\u0442\u0434\u0430\u043D \u043D\u0430 \u043F\u043E\u043F\u0435\u0447\u0435\u043D\u0438\u0435
    \u0441\u0432\u043E\u0435\u0439 \u0431\u0430\u0431\u0443\u0448\u043A\u0435, \u043B\u0435\u0434\u0438
    \u0420\u0430\u0441\u0441\u0435\u043B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u043C\u043E\u0433\u043B\u0430 \u043E\u0441\u043F\u043E\u0440\u0438\u0442\u044C
    \u0432\u043E\u043B\u044E \u043E\u0442\u0446\u0430, \u0436\u0435\u043B\u0430\u0432\u0448\u0435\u0433\u043E
    \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u0442\u044C \u0441\u044B\u043D\u0430
    \u0430\u0433\u043D\u043E\u0441\u0442\u0438\u043A\u043E\u043C. \u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0435\u0433\u043E \u043F\u0440\u043E\u0448\u043B\u043E \u0432 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438
    \u043E\u0442 \u0441\u0432\u0435\u0440\u0441\u0442\u043D\u0438\u043A\u043E\u0432,
    \u0438 \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u0447\u0430\u0441\u0442\u044C
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043E\u043D \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B
    \u0437\u0430 \u043A\u043D\u0438\u0433\u0430\u043C\u0438. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0442\u043E\u0433\u0434\u0430, \u0432 11 \u043B\u0435\u0442, \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435
    \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u043E \u043D\u0430 \u043D\u0435\u0433\u043E
    \u043D\u0435\u0438\u0437\u0433\u043B\u0430\u0434\u0438\u043C\u043E\u0435 \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u0438\u0435,
    \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u0432 \u0441\u0442\u0440\u0430\u0441\u0442\u044C
    \u043A \u0442\u043E\u0447\u043D\u043E\u043C\u0443 \u0437\u043D\u0430\u043D\u0438\u044E,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D \u043F\u0440\u043E\u043D\u0451\u0441
    \u0447\u0435\u0440\u0435\u0437 \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C. 
    ### \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0438
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0435
    \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435  \u0412 1890
    \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435 \u0434\u043E\u043C\u0430\u0448\u043D\u0435\u0433\u043E
    \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u044F, \u0420\u0430\u0441\u0441\u0435\u043B
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430. \u041E\u043D
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0435\u0433\u043E, \u043F\u043E\u043B\u0443\u0447\u0438\u0432 \u0432\u044B\u0441\u0448\u0438\u0435
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 (1893),
    \u0430 \u0437\u0430\u0442\u0435\u043C \u043F\u043E \u043C\u043E\u0440\u0430\u043B\u044C\u043D\u044B\u043C
    \u043D\u0430\u0443\u043A\u0430\u043C (\u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F)
    \u0432 1894 \u0433\u043E\u0434\u0443. \u0412 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435
    \u043E\u043D \u0432\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0442\u0430\u0439\u043D\u043E\u0435
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E \xAB\u0410\u043F\u043E\u0441\u0442\u043E\u043B\u044B\xBB,
    \u0433\u0434\u0435 \u0437\u0430\u0432\u044F\u0437\u0430\u043B \u0434\u0440\u0443\u0436\u0431\u0443
    \u0441 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u043C \u0414\u0436\u043E\u0440\u0434\u0436\u0435\u043C
    \u041C\u0443\u0440\u043E\u043C \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0410\u043B\u044C\u0444\u0440\u0435\u0434\u043E\u043C \u0423\u0430\u0439\u0442\u0445\u0435\u0434\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u044B\u0433\u0440\u0430\u043B\u0438
    \u043A\u043B\u044E\u0447\u0435\u0432\u0443\u044E \u0440\u043E\u043B\u044C \u0432
    \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439
    \u044D\u0432\u043E\u043B\u044E\u0446\u0438\u0438.  \u0412 \u0434\u0435\u043A\u0430\u0431\u0440\u0435
    1894 \u0433\u043E\u0434\u0430 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0410\u043B\u0438\u0441 \u041F\u0438\u0440\u0441\u043E\u043B\u043B
    \u0421\u043C\u0438\u0442, \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0439
    \u043A\u0432\u0430\u043A\u0435\u0440\u0448\u0435. \u041C\u043E\u043B\u043E\u0434\u043E\u0436\u0451\u043D\u044B
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0438\u0441\u044C \u0432 \u0411\u0435\u0440\u043B\u0438\u043D,
    \u0433\u0434\u0435 \u0420\u0430\u0441\u0441\u0435\u043B \u0438\u0437\u0443\u0447\u0430\u043B
    \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0443 \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u0443.
    \u0415\u0433\u043E \u0440\u0430\u043D\u043D\u0438\u0435 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u0431\u044B\u043B\u0438 \u0431\u043B\u0438\u0437\u043A\u0438
    \u043A \u043D\u0435\u043E\u0433\u0435\u0433\u0435\u043B\u044C\u044F\u043D\u0441\u0442\u0432\u0443,
    \u0438 \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u0430\u044F \u043A\u043D\u0438\u0433\u0430
    \xAB\u041E\u0447\u0435\u0440\u043A \u043E \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F\u0445
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB (1897) \u0431\u044B\u043B\u0430
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u0430 \u0432 \u044D\u0442\u043E\u043C
    \u0434\u0443\u0445\u0435. \u041E\u0434\u043D\u0430\u043A\u043E \u043F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u043C
    \u0441\u0442\u0430\u043B 1898 \u0433\u043E\u0434, \u043A\u043E\u0433\u0434\u0430
    \u043F\u043E\u0434 \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C \u041C\u0443\u0440\u0430
    \u0420\u0430\u0441\u0441\u0435\u043B \u0440\u0435\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u043E\u0440\u0432\u0430\u043B \u0441 \u0438\u0434\u0435\u0430\u043B\u0438\u0437\u043C\u043E\u043C
    \u041A\u0430\u043D\u0442\u0430 \u0438 \u0413\u0435\u0433\u0435\u043B\u044F, \u043F\u0435\u0440\u0435\u0439\u0434\u044F
    \u043D\u0430 \u043F\u043E\u0437\u0438\u0446\u0438\u0438 \u0440\u0435\u0430\u043B\u0438\u0437\u043C\u0430
    \u0438 \u044D\u043C\u043F\u0438\u0440\u0438\u0437\u043C\u0430. \u041E\u043D \u043F\u0440\u0438\u0448\u0451\u043B
    \u043A \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044E, \u0447\u0442\u043E
    \u043C\u0435\u0442\u043E\u0434\u043E\u043C \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u0442\u044C \u0430\u043D\u0430\u043B\u0438\u0437,
    \u0430 \u043D\u0435 \u0441\u0438\u043D\u0442\u0435\u0437.  ### \u041B\u043E\u0433\u0438\u043A\u0430
    \u0438 \xABPrincipia Mathematica\xBB  \u0412\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u0451\u043D\u043D\u044B\u0439
    \u0440\u0430\u0431\u043E\u0442\u0430\u043C\u0438 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435
    \u041F\u0435\u0430\u043D\u043E, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043E\u043D \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B \u043D\u0430 \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u0432 1900 \u0433\u043E\u0434\u0443,
    \u0420\u0430\u0441\u0441\u0435\u043B \u043D\u0430\u0447\u0430\u043B \u0440\u0435\u0430\u043B\u0438\u0437\u043E\u0432\u044B\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u044E \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u0443\u044E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443 **\u043B\u043E\u0433\u0438\u0446\u0438\u0437\u043C\u0430**
    \u2014 \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u0432\u0441\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043A \u043B\u043E\u0433\u0438\u043A\u0435.
    \u0412 1903 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \xAB\u041F\u0440\u0438\u043D\u0446\u0438\u043F\u044B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB,
    \u0433\u0434\u0435 \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u044D\u0442\u0443
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044E.  \u041E\u0434\u043D\u0430\u043A\u043E
    \u0432 \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443, \u0440\u0430\u0431\u043E\u0442\u0430\u044F
    \u043D\u0430\u0434 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432,
    \u043E\u043D \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    **\u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441 \u0420\u0430\u0441\u0441\u0435\u043B\u0430**.
    \u0421\u0443\u0442\u044C \u0435\u0433\u043E \u0432 \u0432\u043E\u043F\u0440\u043E\u0441\u0435:
    \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442 \u043B\u0438
    \u043A\u043B\u0430\u0441\u0441 \u0432\u0441\u0435\u0445 \u043A\u043B\u0430\u0441\u0441\u043E\u0432,
    \u043D\u0435 \u044F\u0432\u043B\u044F\u044E\u0449\u0438\u0445\u0441\u044F \u0447\u043B\u0435\u043D\u0430\u043C\u0438
    \u0441\u0430\u043C\u0438\u0445 \u0441\u0435\u0431\u044F, \u0441\u0430\u043C\u043E\u043C\u0443
    \u0441\u0435\u0431\u0435? \u041B\u044E\u0431\u043E\u0439 \u043E\u0442\u0432\u0435\u0442
    \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u0442 \u043A \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u044E.
    \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043F\u043E\u0442\u0440\u044F\u0441\u043B\u043E
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u041D\u0435\u043C\u0435\u0446\u043A\u0438\u0439 \u043B\u043E\u0433\u0438\u043A
    \u0413\u043E\u0442\u043B\u043E\u0431 \u0424\u0440\u0435\u0433\u0435, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u043F\u0438\u0441\u044C\u043C\u043E \u043E\u0442 \u0420\u0430\u0441\u0441\u0435\u043B\u0430,
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B, \u0447\u0442\u043E \xAB\u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430
    \u043F\u043E\u0448\u0430\u0442\u043D\u0443\u043B\u0430\u0441\u044C\xBB.  \u0427\u0442\u043E\u0431\u044B
    \u043F\u0440\u0435\u043E\u0434\u043E\u043B\u0435\u0442\u044C \u044D\u0442\u043E\u0442
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441, \u0420\u0430\u0441\u0441\u0435\u043B
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B **\u0442\u0435\u043E\u0440\u0438\u044E
    \u0442\u0438\u043F\u043E\u0432** \u2014 \u0438\u0435\u0440\u0430\u0440\u0445\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443, \u0433\u0434\u0435 \u043A\u0430\u0436\u0434\u043E\u0435
    \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043D\u0438\u0435 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0441\u044F
    \u043A \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u043E\u043C\u0443
    \u0443\u0440\u043E\u0432\u043D\u044E, \u0447\u0442\u043E \u043F\u0440\u0435\u0434\u043E\u0442\u0432\u0440\u0430\u0449\u0430\u0435\u0442
    \u0441\u0430\u043C\u043E\u043E\u0442\u043D\u0435\u0441\u0435\u043D\u0438\u0435.
    \u0412\u043C\u0435\u0441\u0442\u0435 \u0441 \u0410\u043B\u044C\u0444\u0440\u0435\u0434\u043E\u043C
    \u0423\u0430\u0439\u0442\u0445\u0435\u0434\u043E\u043C \u043E\u043D \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u044D\u0442\u043E\u043C\u0443 \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0438\u0439
    \u0442\u0440\u0443\u0434, \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0441\u0442\u0430\u043B\u043E
    \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0442\u0440\u0451\u0445\u0442\u043E\u043C\u043D\u043E\u0435 \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0435
    **\xABPrincipia Mathematica\xBB** (1910\u20131913). \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430,
    \u0445\u043E\u0442\u044C \u0438 \u043D\u0435 \u0441\u043C\u043E\u0433\u043B\u0430
    \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u0442\u044C
    \u0437\u0430\u0434\u0443\u043C\u0430\u043D\u043D\u043E\u0435 (\u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u0413\u0451\u0434\u0435\u043B\u044F
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0430 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0442\u0430\u043A\u043E\u0433\u043E \u043F\u043E\u0434\u0445\u043E\u0434\u0430),
    \u0441\u0442\u0430\u043B\u0430 \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C
    \u043A\u0430\u043C\u043D\u0435\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438 \u0438 \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043C\u0443\u0436\u0435\u0441\u0442\u0432\u0430.  \u0412 \u044D\u0442\u043E\u0442
    \u0436\u0435 \u043F\u0435\u0440\u0438\u043E\u0434 \u0420\u0430\u0441\u0441\u0435\u043B
    \u0441\u043E\u0437\u0434\u0430\u0451\u0442 **\u0442\u0435\u043E\u0440\u0438\u044E
    \u0434\u0435\u0441\u043A\u0440\u0438\u043F\u0446\u0438\u0439** (1905), \u0441\u0442\u0430\u0432\u0448\u0443\u044E
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u043C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0433\u043E \u0430\u043D\u0430\u043B\u0438\u0437\u0430.
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0435
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F (\xAB\u043D\u044B\u043D\u0435\u0448\u043D\u0438\u0439
    \u043A\u043E\u0440\u043E\u043B\u044C \u0424\u0440\u0430\u043D\u0446\u0438\u0438\xBB)
    \u043D\u0435 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F \u0438\u043C\u0435\u043D\u0430\u043C\u0438,
    \u0430 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0442
    \u0441\u043E\u0431\u043E\u0439 \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438, \u0447\u0442\u043E
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u0442\u044C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
    \u043D\u0435\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432.  ### \u041E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C, \u0442\u044E\u0440\u044C\u043C\u044B
    \u0438 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F  \u0421
    \u043D\u0430\u0447\u0430\u043B\u043E\u043C \u041F\u0435\u0440\u0432\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B \u0420\u0430\u0441\u0441\u0435\u043B,
    \u0443\u0431\u0435\u0436\u0434\u0451\u043D\u043D\u044B\u0439 \u043F\u0430\u0446\u0438\u0444\u0438\u0441\u0442,
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0432\u043A\u043B\u044E\u0447\u0438\u043B\u0441\u044F
    \u0432 \u0430\u043D\u0442\u0438\u0432\u043E\u0435\u043D\u043D\u0443\u044E \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C.
    \u0412 1916 \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B \u0443\u0432\u043E\u043B\u0435\u043D
    \u0438\u0437 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430
    \u0437\u0430 \u0432\u044B\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0442\u0438\u0432 \u043A\u043E\u043D\u0441\u043A\u0440\u0438\u043F\u0446\u0438\u0438
    (\u043F\u0440\u0438\u043D\u0443\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u0440\u0438\u0437\u044B\u0432\u0430) \u0438 \u043E\u0448\u0442\u0440\u0430\u0444\u043E\u0432\u0430\u043D
    \u043D\u0430 110 \u0444\u0443\u043D\u0442\u043E\u0432. \u0412 1918 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0431\u044B\u043B \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\u0451\u043D
    \u043A \u0448\u0435\u0441\u0442\u0438 \u043C\u0435\u0441\u044F\u0446\u0430\u043C
    \u0442\u044E\u0440\u0435\u043C\u043D\u043E\u0433\u043E \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F
    \u0437\u0430 \u0441\u0442\u0430\u0442\u044C\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F,
    \u043F\u043E \u043C\u043D\u0435\u043D\u0438\u044E \u0432\u043B\u0430\u0441\u0442\u0435\u0439,
    \u043E\u0441\u043A\u043E\u0440\u0431\u043B\u044F\u043B\u0430 \u0441\u043E\u044E\u0437\u043D\u044B\u0435
    \u0441 \u0421\u0428\u0410 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F.
    \u0421\u0432\u043E\u0451 \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435
    \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0434\u043B\u044F \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u0438\u044F \u043A\u043D\u0438\u0433\u0438
    \xAB\u0412\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E\xBB (1919).  \u041F\u043E\u0441\u043B\u0435
    \u0432\u043E\u0439\u043D\u044B \u0420\u0430\u0441\u0441\u0435\u043B \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u0421\u043E\u0432\u0435\u0442\u0441\u043A\u0443\u044E \u0420\u043E\u0441\u0441\u0438\u044E
    (1920), \u0433\u0434\u0435 \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B\u0441\u044F
    \u0441 \u041B\u0435\u043D\u0438\u043D\u044B\u043C. \u0423\u0432\u0438\u0434\u0435\u043D\u043D\u043E\u0435
    \u0435\u0433\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043B\u043E:
    \u043E\u043D \u0431\u044B\u043B \u043F\u043E\u0442\u0440\u044F\u0441\u0451\u043D
    \u0436\u0435\u0441\u0442\u043E\u043A\u043E\u0441\u0442\u044C\u044E \u0438 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435\u043C
    \u0441\u0432\u043E\u0431\u043E\u0434\u044B \u0432 \u0431\u043E\u043B\u044C\u0448\u0435\u0432\u0438\u0441\u0442\u0441\u043A\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435, \u043D\u0430\u0437\u0432\u0430\u0432
    \u0435\u0451 \u0444\u043E\u0440\u043C\u043E\u0439 \u0444\u0430\u043D\u0430\u0442\u0438\u0447\u043D\u043E\u0439
    \u0440\u0435\u043B\u0438\u0433\u0438\u0438. \u0412 \u0442\u043E\u043C \u0436\u0435
    \u0433\u043E\u0434\u0443 \u043E\u043D \u0443\u0435\u0445\u0430\u043B \u0432 \u041A\u0438\u0442\u0430\u0439
    \u0447\u0438\u0442\u0430\u0442\u044C \u043B\u0435\u043A\u0446\u0438\u0438 \u0432
    \u041F\u0435\u043A\u0438\u043D\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u0433\u0434\u0435 \u043F\u0440\u043E\u0432\u0451\u043B \u043F\u043E\u0447\u0442\u0438
    \u0433\u043E\u0434, \u0438\u0437\u0443\u0447\u0430\u044F \u044D\u0442\u0443 \u0434\u0440\u0435\u0432\u043D\u044E\u044E
    \u0446\u0438\u0432\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u044E.  ### \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0438 \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B  \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0420\u0430\u0441\u0441\u0435\u043B\u0430 \u0431\u044B\u043B\u0430 \u0431\u0443\u0440\u043D\u043E\u0439
    \u0438 \u043D\u0435\u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439.
    \u041E\u043D \u0440\u0430\u0437\u0432\u0435\u043B\u0441\u044F \u0441 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0436\u0435\u043D\u043E\u0439 \u0432 1921 \u0433\u043E\u0434\u0443 \u0438 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0414\u043E\u0440\u0435 \u0411\u043B\u044D\u043A. \u0423 \u043D\u0438\u0445
    \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0434\u0432\u043E\u0435 \u0434\u0435\u0442\u0435\u0439.
    \u0412\u043C\u0435\u0441\u0442\u0435 \u0441 \u0414\u043E\u0440\u043E\u0439 \u043E\u043D
    \u043E\u0441\u043D\u043E\u0432\u0430\u043B \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441\u0438\u0432\u043D\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \xAB\u0411\u0438\u043A\u043E\u043D-\u0425\u0438\u043B\u043B\xBB,
    \u0433\u0434\u0435 \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0432\u043E\u043F\u043B\u043E\u0442\u0438\u0442\u044C
    \u0441\u0432\u043E\u0438 \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0434\u0435\u0438. \u0415\u0433\u043E \u0431\u0440\u0430\u043A \u0441
    \u0414\u043E\u0440\u043E\u0439 \u0440\u0430\u0441\u043F\u0430\u043B\u0441\u044F
    \u0432 1935 \u0433\u043E\u0434\u0443, \u0438 \u0432 1936 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u041F\u0430\u0442\u0440\u0438\u0446\u0438\u0438
    \u0421\u043F\u0435\u043D\u0441, \u0440\u043E\u0434\u0438\u0432\u0448\u0435\u0439
    \u0435\u043C\u0443 \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E \u0441\u044B\u043D\u0430.
    \u041F\u043E\u0441\u043B\u0435 \u043F\u0435\u0440\u0435\u0435\u0437\u0434\u0430
    \u0432 \u0421\u0428\u0410 \u0432 \u043A\u043E\u043D\u0446\u0435 1930-\u0445 \u0433\u043E\u0434\u043E\u0432
    \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0430\u0441\u044C
    \u0441 \u0430\u0431\u0441\u0443\u0440\u0434\u043D\u044B\u043C \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u043E\u043C:
    \u0432 1940 \u0433\u043E\u0434\u0443 \u0438\u0437-\u0437\u0430 \u0435\u0433\u043E
    \u043B\u0438\u0431\u0435\u0440\u0430\u043B\u044C\u043D\u044B\u0445 \u0432\u0437\u0433\u043B\u044F\u0434\u043E\u0432
    \u043D\u0430 \u043C\u043E\u0440\u0430\u043B\u044C \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u0439
    \u0441\u0443\u0434 \u041D\u044C\u044E-\u0419\u043E\u0440\u043A\u0430 \u043E\u0442\u043C\u0435\u043D\u0438\u043B
    \u0435\u0433\u043E \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u043D\u0430 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0432 \u0421\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0435.
    \u0412 1952 \u0433\u043E\u0434\u0443, \u0443\u0436\u0435 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    80 \u043B\u0435\u0442, \u043E\u043D \u0432\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0441\u0432\u043E\u0439 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439,
    \u0447\u0435\u0442\u0432\u0451\u0440\u0442\u044B\u0439 \u0431\u0440\u0430\u043A
    \u0441 \u042D\u0434\u0438\u0442 \u0424\u0438\u043D\u0447, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u0440\u0438\u043D\u0451\u0441 \u0435\u043C\u0443 \u0441\u0447\u0430\u0441\u0442\u044C\u0435. 
    \u0412 1931 \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0431\u0440\u0430\u0442\u0430, \u0420\u0430\u0441\u0441\u0435\u043B \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0442\u0438\u0442\u0443\u043B \u0438 \u0441\u0442\u0430\u043B 3-\u043C \u0433\u0440\u0430\u0444\u043E\u043C
    \u0420\u0430\u0441\u0441\u0435\u043B\u043E\u043C.  ### \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F
    \u0431\u043E\u0440\u044C\u0431\u0430 \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u041F\u043E\u0441\u043B\u0435 \u0412\u0442\u043E\u0440\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u0420\u0430\u0441\u0441\u0435\u043B \u0441\u0442\u0430\u043B
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0433\u043E\u043B\u043E\u0441\u043E\u0432 \u0432 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438
    \u0437\u0430 \u044F\u0434\u0435\u0440\u043D\u043E\u0435 \u0440\u0430\u0437\u043E\u0440\u0443\u0436\u0435\u043D\u0438\u0435.
    \u0412 1955 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043C\u0430\u043D\u0438\u0444\u0435\u0441\u0442 \u0420\u0430\u0441\u0441\u0435\u043B\u0430\u2014\u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430,
    \u0430 \u0432 1957 \u0433\u043E\u0434\u0443 \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0438\u043D\u0438\u0446\u0438\u0430\u0442\u043E\u0440\u043E\u0432
    \u041F\u0430\u0433\u0443\u043E\u0448\u0441\u043A\u043E\u0433\u043E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u0443\u0447\u0451\u043D\u044B\u0445 \u0437\u0430 \u043C\u0438\u0440. \u041E\u043D
    \u0431\u044B\u043B \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u041A\u0430\u043C\u043F\u0430\u043D\u0438\u0438 \u0437\u0430 \u044F\u0434\u0435\u0440\u043D\u043E\u0435
    \u0440\u0430\u0437\u043E\u0440\u0443\u0436\u0435\u043D\u0438\u0435 (1958\u20131963)
    \u0438 \u0434\u0430\u0436\u0435 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    89 \u043B\u0435\u0442 \u0432 1961 \u0433\u043E\u0434\u0443 \u0441\u043D\u043E\u0432\u0430
    \u043F\u0440\u043E\u0432\u0451\u043B \u043D\u0435\u0434\u0435\u043B\u044E \u0432
    \u0442\u044E\u0440\u044C\u043C\u0435 \u0437\u0430 \u0443\u0447\u0430\u0441\u0442\u0438\u0435
    \u0432 \u0430\u043D\u0442\u0438\u0432\u043E\u0435\u043D\u043D\u043E\u0439 \u0430\u043A\u0446\u0438\u0438
    \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430. \u0412 \u043A\u043E\u043D\u0446\u0435
    1960-\u0445 \u0433\u043E\u0434\u043E\u0432 \u043E\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \u0422\u0440\u0438\u0431\u0443\u043D\u0430\u043B \u0420\u0430\u0441\u0441\u0435\u043B\u0430
    \u0434\u043B\u044F \u0440\u0430\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432\u043E\u0435\u043D\u043D\u044B\u0445 \u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0439
    \u0421\u0428\u0410 \u0432\u043E \u0412\u044C\u0435\u0442\u043D\u0430\u043C\u0435. 
    \u0420\u0430\u0441\u0441\u0435\u043B \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u043D\u0430\u0433\u0440\u0430\u0434:
    \u0432 1949 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B \u043A\u0430\u0432\u0430\u043B\u0435\u0440\u043E\u043C
    \u041E\u0440\u0434\u0435\u043D\u0430 \u0417\u0430\u0441\u043B\u0443\u0433, \u0430
    \u0432 1950 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E
    \u043F\u043E \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0435 \xAB\u0437\u0430
    \u0437\u0430\u0449\u0438\u0442\u0443 \u0433\u0443\u043C\u0430\u043D\u0438\u0442\u0430\u0440\u043D\u044B\u0445
    \u0438\u0434\u0435\u0430\u043B\u043E\u0432 \u0438 \u0441\u0432\u043E\u0431\u043E\u0434\u044B
    \u043C\u044B\u0441\u043B\u0438\xBB. \u041E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u043E\u0442 \u0431\u0440\u043E\u043D\u0445\u0438\u0442\u0430 2 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    1970 \u0433\u043E\u0434\u0430 \u0432 \u0423\u044D\u043B\u044C\u0441\u0435, \u043D\u0435
    \u0434\u043E\u0436\u0438\u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043C\u0435\u0441\u044F\u0446\u0435\u0432 \u0434\u043E \u0441\u0432\u043E\u0435\u0433\u043E
    98-\u043B\u0435\u0442\u0438\u044F."
  shortBioEn: 
  interestingFactsRu: "\u0411\u0435\u0440\u0442\u0440\u0430\u043D \u0420\u0430\u0441\u0441\u0435\u043B
    \u2014 \u0444\u0438\u0433\u0443\u0440\u0430, \u0432\u043E\u043A\u0440\u0443\u0433
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0432\u0441\u0435\u0433\u0434\u0430
    \u043A\u0438\u043F\u0435\u043B\u0438 \u0441\u0442\u0440\u0430\u0441\u0442\u0438,
    \u0438 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u043F\u043E\u043B\u043D\u0430
    \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445, \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0445
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u043D\u044B\u0445 \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u0435\u043B\u0430\u044E\u0442
    \u0435\u0433\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0432\u0435\u043B\u0438\u043A\u0438\u043C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u043C, \u043D\u043E \u0438 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0436\u0438\u0432\u044B\u043C \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435\u043C.
    \u0412\u043E\u0442 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u0430\u043C\u044B\u0445
    \u044F\u0440\u043A\u0438\u0445 \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u0438 \u043A\u0443\u0440\u044C\u0451\u0437\u043E\u0432
    \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438. 
    ### \u2615 \u041B\u0435\u0433\u0435\u043D\u0434\u0430 \u043E \xAB\u0427\u0430\u0439\u043D\u0438\u043A\u0435
    \u0420\u0430\u0441\u0441\u0435\u043B\u0430\xBB (\u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0447\u0430\u0441\u0442\u043E \u043F\u0435\u0440\u0435\u0432\u0438\u0440\u0430\u044E\u0442) 
    \u042D\u0442\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u044B\u0439
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0439
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442 \u0420\u0430\u0441\u0441\u0435\u043B\u0430
    \u0438 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A \u043C\u0430\u0441\u0441\u044B
    \u0430\u043D\u0435\u043A\u0434\u043E\u0442\u043E\u0432. \u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0432 1952 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u043C\u044B\u0441\u043B\u0435\u043D\u043D\u044B\u0439 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442:
    \u0435\u0441\u043B\u0438 \u044F \u0437\u0430\u044F\u0432\u043B\u044E, \u0447\u0442\u043E
    \u043C\u0435\u0436\u0434\u0443 \u0417\u0435\u043C\u043B\u0435\u0439 \u0438 \u041C\u0430\u0440\u0441\u043E\u043C
    \u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F \u0444\u0430\u0440\u0444\u043E\u0440\u043E\u0432\u044B\u0439
    \u0447\u0430\u0439\u043D\u0438\u043A, \u0442\u043E \u043D\u0435 \u0431\u0443\u0434\u0443
    \u043E\u0431\u044F\u0437\u0430\u043D \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u044D\u0442\u043E, \u043F\u043E\u043A\u0430 \u0432\u044B \u043D\u0435 \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0435\u0442\u0435.
    \u042D\u0442\u0438\u043C \u043E\u043D \u0445\u043E\u0442\u0435\u043B \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
    \u0447\u0442\u043E \u0431\u0440\u0435\u043C\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043B\u0435\u0436\u0438\u0442 \u043D\u0430 \u0442\u043E\u043C, \u043A\u0442\u043E
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u0447\u0435\u0433\u043E-\u0442\u043E (\u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435
    \u0411\u043E\u0433\u0430).  **\u041A\u0443\u0440\u044C\u0451\u0437:** \u0412
    \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442\u0435 \u0438 \u0443\u0441\u0442\u043D\u044B\u0445
    \u0431\u0430\u0439\u043A\u0430\u0445 \u044D\u0442\u043E\u0442 \u0443\u043C\u043D\u044B\u0439
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u0441\u044F
    \u0432 \u0430\u0431\u0441\u0443\u0440\u0434\u043D\u0443\u044E \u0438\u0441\u0442\u043E\u0440\u0438\u044E
    \u043E \u0442\u043E\u043C, \u043A\u0430\u043A \u0420\u0430\u0441\u0441\u0435\u043B
    \u043F\u0440\u0438\u0448\u0451\u043B \u0432 \u0446\u0435\u0440\u043A\u043E\u0432\u044C,
    \u0443\u0434\u0430\u0440\u0438\u043B \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430
    \u0447\u0430\u0439\u043D\u0438\u043A\u043E\u043C \u043F\u043E \u0433\u043E\u043B\u043E\u0432\u0435
    \u0438 \u0443\u0431\u0435\u0436\u0430\u043B, \"\u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044F\"
    \u0442\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0441\u0432\u043E\u0451
    \u043F\u0440\u0430\u0432\u043E \u043D\u0435 \u0432\u0435\u0440\u0438\u0442\u044C
    \u0432 \u0411\u043E\u0433\u0430. \u042D\u0442\u043E, \u043A\u043E\u043D\u0435\u0447\u043D\u043E,
    \u0432\u044B\u043C\u044B\u0441\u0435\u043B, \u043D\u043E \u044F\u0440\u043A\u043E
    \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u0443\u044E\u0449\u0438\u0439,
    \u043A\u0430\u043A \u0435\u0433\u043E \u043E\u0431\u0440\u0430\u0437 \"\u0445\u0443\u043B\u0438\u0433\u0430\u043D\u0430
    \u043E\u0442 \u043B\u043E\u0433\u0438\u043A\u0438\" \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u0430\u043B
    \u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0435 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u043E. 
    ### \U0001F525 \u0422\u044E\u0440\u0435\u043C\u043D\u044B\u0439 \u044E\u043C\u043E\u0440 
    \u0420\u0430\u0441\u0441\u0435\u043B \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0451\u043D\u043D\u044B\u043C
    \u043F\u0430\u0446\u0438\u0444\u0438\u0441\u0442\u043E\u043C \u0438 \u043D\u0435
    \u0440\u0430\u0437 \u0441\u0438\u0434\u0435\u043B \u0432 \u0442\u044E\u0440\u044C\u043C\u0435
    \u0437\u0430 \u0441\u0432\u043E\u0438 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F.
    \u0412 1918 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043F\u0430\u043B
    \u0432 \u0442\u044E\u0440\u044C\u043C\u0443 \u043D\u0430 \u0448\u0435\u0441\u0442\u044C
    \u043C\u0435\u0441\u044F\u0446\u0435\u0432 \u0438 \u0432 \u0441\u0432\u043E\u0438\u0445
    \u043C\u0435\u043C\u0443\u0430\u0440\u0430\u0445 \u0441 \u044E\u043C\u043E\u0440\u043E\u043C
    \u043E\u043F\u0438\u0441\u0430\u043B \u043C\u043E\u043C\u0435\u043D\u0442 \u0432\u0441\u0442\u0440\u0435\u0447\u0438
    \u0441 \u043D\u0430\u0434\u0437\u0438\u0440\u0430\u0442\u0435\u043B\u0435\u043C:
    > \"\u042F \u0431\u044B\u043B \u043E\u0447\u0435\u043D\u044C \u043E\u0431\u043E\u0434\u0440\u0451\u043D
    \u043F\u043E \u043F\u0440\u0438\u0431\u044B\u0442\u0438\u0438 \u0441\u0442\u043E\u0440\u043E\u0436\u0435\u043C
    \u0443 \u0432\u043E\u0440\u043E\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u043B \u0437\u0430\u043F\u0438\u0441\u0430\u0442\u044C
    \u043C\u043E\u0438 \u0434\u0430\u043D\u043D\u044B\u0435. \u041E\u043D \u0441\u043F\u0440\u043E\u0441\u0438\u043B
    \u043E \u043C\u043E\u0435\u0439 \u0440\u0435\u043B\u0438\u0433\u0438\u0438, \u0438
    \u044F \u043E\u0442\u0432\u0435\u0442\u0438\u043B: '\u0410\u0433\u043D\u043E\u0441\u0442\u0438\u043A'.
    \u041E\u043D \u0441\u043F\u0440\u043E\u0441\u0438\u043B, \u043A\u0430\u043A \u044D\u0442\u043E
    \u043F\u0438\u0448\u0435\u0442\u0441\u044F, \u0438 \u0437\u0430\u043C\u0435\u0442\u0438\u043B
    \u0441\u043E \u0432\u0437\u0434\u043E\u0445\u043E\u043C: '\u0427\u0442\u043E
    \u0436, \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u043C\u043D\u043E\u0433\u043E
    \u0440\u0435\u043B\u0438\u0433\u0438\u0439, \u043D\u043E, \u043F\u043E\u043B\u0430\u0433\u0430\u044E,
    \u0432\u0441\u0435 \u043E\u043D\u0438 \u043F\u043E\u043A\u043B\u043E\u043D\u044F\u044E\u0442\u0441\u044F
    \u043E\u0434\u043D\u043E\u043C\u0443 \u0438 \u0442\u043E\u043C\u0443 \u0436\u0435
    \u0411\u043E\u0433\u0443'. \u042D\u0442\u043E \u0437\u0430\u043C\u0435\u0447\u0430\u043D\u0438\u0435
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u043E \u043C\u043E\u0451
    \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435 \u043E\u043A\u043E\u043B\u043E
    \u043D\u0435\u0434\u0435\u043B\u0438\".  \u042D\u0442\u043E\u0442 \u044D\u043F\u0438\u0437\u043E\u0434
    \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u0435\u0433\u043E \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u0438\u0435 \u0438
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C
    \u043A\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u0434\u0430\u0436\u0435
    \u0432 \u0441\u0430\u043C\u044B\u0445 \u043C\u0440\u0430\u0447\u043D\u044B\u0445
    \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u0445. 
    ### \U0001F9E0 \u041A\u0430\u043A \u0442\u0430\u0431\u0430\u043A \u043F\u043E\u043C\u043E\u0433
    \u0441\u0442\u0430\u0442\u044C \u0433\u0435\u0433\u0435\u043B\u044C\u044F\u043D\u0446\u0435\u043C...
    \u0438 \u0431\u0440\u043E\u0441\u0438\u0442\u044C \u0435\u0433\u043E  \u0412
    \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438 \u0420\u0430\u0441\u0441\u0435\u043B
    \u043F\u0435\u0440\u0435\u0436\u0438\u043B \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u0439
    \u043A\u0440\u0438\u0437\u0438\u0441. \u041F\u043E\u0434 \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C
    \u0441\u0432\u043E\u0435\u0433\u043E \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0433\u043E
    \u0434\u0440\u0443\u0433\u0430, \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430-\u0433\u0435\u0433\u0435\u043B\u044C\u044F\u043D\u0446\u0430
    \u041C\u0430\u043A\u0442\u0430\u0433\u0433\u0430\u0440\u0442\u0430, \u043E\u043D
    \u0443\u0432\u043B\u0451\u043A\u0441\u044F \u0438\u0434\u0435\u0430\u043B\u0438\u0437\u043C\u043E\u043C.
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u043A\u0443\u043F\u0438\u0442\u044C \u0431\u0430\u043D\u043A\u0443 \u0442\u0430\u0431\u0430\u043A\u0430
    \u0438 \u043D\u0430 \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u043C \u043F\u0443\u0442\u0438
    \u043F\u043E \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u041B\u0435\u0439\u043D
    \u0432\u043D\u0435\u0437\u0430\u043F\u043D\u043E, \u043F\u043E\u0434\u0431\u0440\u043E\u0441\u0438\u0432
    \u0435\u0451 \u0432 \u0432\u043E\u0437\u0434\u0443\u0445, \u0432\u043E\u0441\u043A\u043B\u0438\u043A\u043D\u0443\u043B:
    **\"\u0412\u0435\u043B\u0438\u043A\u0438\u0439 \u0411\u043E\u0436\u0435 \u0432
    \u0441\u0430\u043F\u043E\u0433\u0430\u0445! \u041E\u043D\u0442\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442 \u0432\u0435\u0440\u0435\u043D!\"**.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442
    \u043E\u043D \u043E\u0441\u043E\u0437\u043D\u0430\u043B, \u0447\u0442\u043E \u0441\u0442\u0430\u043B
    \u0433\u0435\u0433\u0435\u043B\u044C\u044F\u043D\u0446\u0435\u043C.  **\u0418\u0440\u043E\u043D\u0438\u044F:**
    \u041F\u043E\u0437\u0436\u0435 \u043E\u043D \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u044D\u0442\u0438\u0445 \u0432\u0437\u0433\u043B\u044F\u0434\u043E\u0432
    \u0438 \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432 \u0438\u0434\u0435\u0430\u043B\u0438\u0437\u043C\u0430.
    \u0410 \u0447\u0442\u043E \u043A\u0430\u0441\u0430\u0435\u0442\u0441\u044F \u0442\u0430\u0431\u0430\u043A\u0430
    \u2014 \u043E\u043D \u043A\u0443\u0440\u0438\u043B \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C,
    \u0438 \u043E\u0434\u043D\u0430\u0436\u0434\u044B, \u0432 1948 \u0433\u043E\u0434\u0443,
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0430\u0432\u0438\u0430\u043F\u0435\u0440\u0435\u043B\u0451\u0442\u0430,
    \u043E\u043D \u043F\u043E\u0448\u0451\u043B \u0432 \u0442\u0443\u0430\u043B\u0435\u0442
    \u043F\u043E\u043A\u0443\u0440\u0438\u0442\u044C, \u0438 \u0432 \u0442\u043E\u0442
    \u043C\u043E\u043C\u0435\u043D\u0442, \u043A\u043E\u0433\u0434\u0430 \u043E\u043D
    \u0431\u044B\u043B \u0442\u0430\u043C, \u0441\u0430\u043C\u043E\u043B\u0451\u0442
    \u0440\u0443\u0445\u043D\u0443\u043B \u0432 \u043C\u043E\u0440\u0435. \u041E\u043D
    \u0432\u044B\u0436\u0438\u043B, \u0430 cigarette \u0441\u043F\u0430\u0441\u043B\u0430
    \u0435\u043C\u0443 \u0436\u0438\u0437\u043D\u044C.  ### \U0001F393 \u0427\u0443\u0434\u043D\u043E\u0439
    \u0440\u0435\u0431\u0451\u043D\u043E\u043A \u0438 \u0441\u0442\u0440\u043E\u0433\u0430\u044F
    \u0431\u0430\u0431\u0443\u0448\u043A\u0430  \u0412\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u043D\u044B\u0439
    \u0431\u0430\u0431\u0443\u0448\u043A\u043E\u0439 \u0432 \u0441\u0442\u0440\u043E\u0433\u0438\u0445
    \u043F\u0443\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u0438\u0445 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u044F\u0445,
    \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439 \u0411\u0435\u0440\u0442\u0440\u0430\u043D
    \u0443\u0436\u0435 \u0442\u043E\u0433\u0434\u0430 \u043F\u043E\u0440\u0430\u0436\u0430\u043B
    \u0432\u0441\u0435\u0445 \u0441\u0432\u043E\u0435\u0439 \u043B\u044E\u0431\u043E\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E.
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u043E\u043D \u0441\u043F\u0440\u043E\u0441\u0438\u043B
    \u0441\u0432\u043E\u044E \u0442\u0451\u0442\u044E: \"\u0422\u0451\u0442\u044F,
    \u0430 \u043C\u043E\u0440\u0441\u043A\u0438\u0435 \u0443\u0442\u043E\u0447\u043A\u0438
    \u0434\u0443\u043C\u0430\u044E\u0442?\". \u041D\u0430 \u043D\u0435\u0434\u043E\u0443\u043C\u0451\u043D\u043D\u044B\u0439
    \u043E\u0442\u0432\u0435\u0442 \"\u041D\u0435 \u0437\u043D\u0430\u044E\", \u043E\u043D
    \u043F\u0430\u0440\u0438\u0440\u043E\u0432\u0430\u043B: \"\u0422\u043E\u0433\u0434\u0430
    \u0442\u044B \u0434\u043E\u043B\u0436\u043D\u0430 \u044D\u0442\u043E \u0443\u0437\u043D\u0430\u0442\u044C!\". 
    \u0411\u0430\u0431\u0443\u0448\u043A\u0430 \u0431\u044B\u043B\u0430 \u0434\u043B\u044F
    \u043D\u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435, \u043D\u043E \u043A 14 \u0433\u043E\u0434\u0430\u043C
    \u043E\u043D \u0443\u0436\u0435 \u0441\u0442\u0430\u043B \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C
    \u0435\u0451 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u0443\u044E
    \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0443\u0442\u043E\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439, \u0430
    \u0435\u0451 \u043F\u0443\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u0443\u044E
    \u043C\u043E\u0440\u0430\u043B\u044C \u2014 \u0447\u0440\u0435\u0437\u043C\u0435\u0440\u043D\u043E\u0439.
    \u0427\u0442\u043E\u0431\u044B \u0432\u0435\u0441\u0442\u0438 \u0434\u043D\u0435\u0432\u043D\u0438\u043A
    \u0432 \u0442\u0430\u0439\u043D\u0435 \u043E\u0442 \u0432\u0441\u0435\u0445,
    \u043E\u043D \u043F\u0438\u0441\u0430\u043B \u0435\u0433\u043E \u043D\u0430 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435.  ### \U0001F4EC \u041E\u0442\u0432\u0435\u0442\u044B
    \u043D\u0430 \u0441\u043E\u0442\u043D\u0438 \u043F\u0438\u0441\u0435\u043C  \u0420\u0430\u0441\u0441\u0435\u043B
    \u0431\u044B\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0435\u043D, \u0438 \u0443 \u043D\u0435\u0433\u043E
    \u0431\u044B\u043B\u0430 \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0430 \u043B\u0438\u0447\u043D\u043E
    \u043E\u0442\u0432\u0435\u0447\u0430\u0442\u044C \u043D\u0430 \u043F\u0438\u0441\u044C\u043C\u0430.
    \u0423\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E
    \u0432 \u043F\u0438\u043A \u0441\u0432\u043E\u0435\u0439 \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0430\u043B \u0434\u043E 100 \u043F\u0438\u0441\u0435\u043C
    \u0432 \u0434\u0435\u043D\u044C. \u041E\u043D \u0437\u0430\u0432\u043E\u0434\u0438\u043B
    \u043B\u0438\u0447\u043D\u0443\u044E \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443
    \u0434\u0430\u0436\u0435 \u0441 \u0434\u0435\u0442\u044C\u043C\u0438. \u041E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043E\u043D \u043F\u043E\u0437\u0434\u0440\u0430\u0432\u0438\u043B \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0443\u044E
    \u0434\u0435\u0432\u043E\u0447\u043A\u0443 \u0441 \u0434\u043D\u0451\u043C \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u043B
    \u0441 \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C,
    \u0430 \u0434\u0440\u0443\u0433\u043E\u0439 \u043E\u0434\u0438\u043D\u043E\u043A\u043E\u0439
    \u0434\u0435\u0432\u043E\u0447\u043A\u0435 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0441\u0442\u0430\u0442\u044C \u0434\u0440\u0443\u0437\u044C\u044F\u043C\u0438
    \u043F\u043E \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435 \u0441\u043E
    \u0441\u0432\u043E\u0435\u0439 \u0432\u043D\u0443\u0447\u043A\u043E\u0439.  ###
    \U0001F3A5 \u041C\u0435\u0442\u0430\u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0435\u043A\u0434\u043E\u0442 \u043F\u0440\u043E \u0430\u0434  \u0425\u043E\u0434\u0438\u043B
    \u0430\u043D\u0435\u043A\u0434\u043E\u0442, \u0447\u0442\u043E \u043A\u043E\u0433\u0434\u0430
    \u0420\u0430\u0441\u0441\u0435\u043B \u0443\u043C\u0435\u0440 \u0438 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u043B
    \u043F\u0435\u0440\u0435\u0434 \u0411\u043E\u0433\u043E\u043C, \u0412\u0441\u0435\u0432\u044B\u0448\u043D\u0438\u0439
    \u0441\u043A\u0430\u0437\u0430\u043B \u0435\u043C\u0443: \"\u0422\u044B \u0431\u044B\u043B
    \u0447\u0435\u0441\u0442\u043D\u044B\u043C \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u043E\u043C,
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u044F \u043E\u0442\u0432\u0435\u0447\u0443
    \u043D\u0430 \u0442\u0440\u0438 \u0442\u0432\u043E\u0438\u0445 \u0432\u043E\u043F\u0440\u043E\u0441\u0430,
    \u043F\u0440\u0435\u0436\u0434\u0435 \u0447\u0435\u043C \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C
    \u0442\u0435\u0431\u044F \u0432 \u0430\u0434\". \u0420\u0430\u0441\u0441\u0435\u043B
    \u0441\u0440\u0430\u0437\u0443 \u043D\u0430\u0447\u0430\u043B \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0443
    \u043D\u0430 \u0432\u0441\u0435\u043C\u043E\u0433\u0443\u0449\u0435\u0441\u0442\u0432\u043E
    \u0438 \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u043A\u0430\u043C\u0435\u043D\u044C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0411\u043E\u0433 \u0441\u0430\u043C \u043D\u0435 \u0441\u043C\u043E\u0436\u0435\u0442
    \u043F\u043E\u0434\u043D\u044F\u0442\u044C. \u041A\u043E\u0433\u0434\u0430 \u0411\u043E\u0433
    \u043E\u0442\u0432\u0435\u0442\u0438\u043B \u0443\u0442\u0432\u0435\u0440\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0420\u0430\u0441\u0441\u0435\u043B \u0441 \u0432\u043E\u0441\u0442\u043E\u0440\u0433\u043E\u043C
    \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u043F\u043E\u0439\u043C\u0430\u043B
    \u0435\u0433\u043E \u0432 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441. \u041E\u0434\u043D\u0430\u043A\u043E,
    \u043F\u043E \u0438\u0440\u043E\u043D\u0438\u0438 \u0441\u0443\u0434\u044C\u0431\u044B,
    \u0438\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u043F\u044B\u0442\u0430\u0435\u0442\u0441\u044F
    \u0437\u0430\u0433\u043E\u043D\u044F\u0442\u044C \u0412\u0441\u0435\u0432\u044B\u0448\u043D\u0435\u0433\u043E
    \u0432 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0440\u0430\u043C\u043A\u0438,
    \u0438 \u0435\u0441\u0442\u044C \u0435\u0433\u043E \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u0434. \u041E\u0442\u043B\u0438\u0447\u043D\u0430\u044F \u0448\u0443\u0442\u043A\u0430,
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0449\u0430\u044F, \u043A\u0430\u043A
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438 \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B\u0438
    \u0435\u0433\u043E \u043E\u0434\u0435\u0440\u0436\u0438\u043C\u043E\u0441\u0442\u044C
    \u043B\u043E\u0433\u0438\u043A\u043E\u0439.  \u041A\u0430\u043A \u0432\u0438\u0434\u0438\u0442\u0435,
    \u0420\u0430\u0441\u0441\u0435\u043B \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0441\u0443\u0445\u0438\u043C \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u043C,
    \u0430 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C \u044E\u043C\u043E\u0440\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0443\u043C\u0435\u043B \u043F\u043E\u0441\u043C\u0435\u044F\u0442\u044C\u0441\u044F
    \u0438 \u043D\u0430\u0434 \u0441\u043E\u0431\u043E\u0439, \u0438 \u043D\u0430\u0434
    \u0441\u0430\u043C\u043E\u0439, \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C
    \u0431\u044B, \u0441\u043B\u043E\u0436\u043D\u043E\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0439
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u043E\u0439."
