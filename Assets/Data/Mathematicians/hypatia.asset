  achievementsRu: "\u0425\u043E\u0442\u044F \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B \u0413\u0438\u043F\u0430\u0442\u0438\u0438 \u043F\u043E\u0447\u0442\u0438
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0443\u0442\u0435\u0440\u044F\u043D\u044B,
    \u043C\u044B \u043C\u043E\u0436\u0435\u043C \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u043A\u0440\u0443\u0433 \u0435\u0451 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432 \u0438 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u043D\u0430\u0443\u043A\u0443. \u0415\u0451 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0431\u044B\u043B\u0430 \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0435\u043D\u0430
    \u043D\u0430 \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0438 \u0438
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044F \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u0438. 
    ### \U0001F4DA \u0413\u043B\u0430\u0432\u043D\u044B\u0435 \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B  \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u0432\u0438\u0437\u0430\u043D\u0442\u0438\u0439\u0441\u043A\u043E\u0439 \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0438
    X \u0432\u0435\u043A\u0430 \xAB\u0421\u0443\u0434\u0430\xBB, \u0413\u0438\u043F\u0430\u0442\u0438\u044F
    \u0431\u044B\u043B\u0430 \u0430\u0432\u0442\u043E\u0440\u043E\u043C \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0435\u0432
    \u043A \u0442\u0440\u0435\u043C \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C
    \u0440\u0430\u0431\u043E\u0442\u0430\u043C, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043A\u0430\u043D\u043E\u043D:  1.  **\u041A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0439
    \u043A \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0435\xBB \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E:**
    \u0412\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0435\u0451 \u0441\u0430\u043C\u0430\u044F
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430. \u0422\u0440\u0443\u0434 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u0431\u044B\u043B \u043F\u043E\u0441\u0432\u044F\u0449\u0451\u043D \u0440\u0435\u0448\u0435\u043D\u0438\u044E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0438 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u044B.
    \u041A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0439 \u0413\u0438\u043F\u0430\u0442\u0438\u0438,
    \u0441\u043E\u0441\u0442\u043E\u044F\u0432\u0448\u0438\u0439 \u0438\u0437 13
    \u043A\u043D\u0438\u0433, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0441\u044F
    \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E \u0432 \u0432\u0438\u0434\u0435
    \u0432\u0441\u0442\u0430\u0432\u043E\u043A (\u0438\u043D\u0442\u0435\u0440\u043F\u043E\u043B\u044F\u0446\u0438\u0439)
    \u0432 \u0441\u0430\u043C \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0435\u043A\u0441\u0442. 2.  **\u041A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0439
    \u043A \xAB\u041A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u0441\u0435\u0447\u0435\u043D\u0438\u044F\u043C\xBB
    \u0410\u043F\u043E\u043B\u043B\u043E\u043D\u0438\u044F \u041F\u0435\u0440\u0433\u0441\u043A\u043E\u0433\u043E:**
    \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u0410\u043F\u043E\u043B\u043B\u043E\u043D\u0438\u044F
    \u0431\u044B\u043B\u0430 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u043C
    \u0442\u0440\u0443\u0434\u043E\u043C \u043F\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0432\u0432\u043E\u0434\u0438\u043B\u0438\u0441\u044C
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F \u044D\u043B\u043B\u0438\u043F\u0441\u0430,
    \u043F\u0430\u0440\u0430\u0431\u043E\u043B\u044B \u0438 \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u044B.
    \u0413\u0438\u043F\u0430\u0442\u0438\u044F \u0441\u0434\u0435\u043B\u0430\u043B\u0430
    \u044D\u0442\u043E\u0442 \u0441\u043B\u043E\u0436\u043D\u044B\u0439 \u0442\u0440\u0443\u0434
    \u0431\u043E\u043B\u0435\u0435 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u043C
    \u0434\u043B\u044F \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F, \u0442\u0435\u043C
    \u0441\u0430\u043C\u044B\u043C \u0432\u043D\u0435\u0441\u044F \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0435\u0433\u043E \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0435.
    3.  **\xAB\u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043A\u0430\u043D\u043E\u043D\xBB:** \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0431\u044B\u043B \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0439
    \u043A \u0442\u0440\u0435\u0442\u044C\u0435\u0439 \u043A\u043D\u0438\u0433\u0435
    \xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u044F\xBB \u041A\u043B\u0430\u0432\u0434\u0438\u044F
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u043F\u0435\u0440\u0435\u0441\u043C\u043E\u0442\u0440\u0435\u043D\u043D\u0430\u044F
    \u0432\u0435\u0440\u0441\u0438\u044F \u0447\u0430\u0441\u0442\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0435\u0451 \u043E\u0442\u0446\u0430.  \u0422\u0430\u043A\u0436\u0435 \u0447\u0430\u0441\u0442\u043E
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E
    \u043E\u043D\u0430 \u043F\u043E\u043C\u043E\u0433\u0430\u043B\u0430 \u0441\u0432\u043E\u0435\u043C\u0443
    \u043E\u0442\u0446\u0443 \u0422\u0435\u043E\u043D\u0443 \u0432 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0435
    \u0435\u0433\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u044F \u043A \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0443\xBB
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F.  ### \U0001F4A1 \u0418\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F
    \u0438 \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F 
    \u0421 \u0413\u0438\u043F\u0430\u0442\u0438\u0435\u0439 \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u044E\u0442
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0438\u043B\u0438 \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u0432\u0430\u0436\u043D\u044B\u0445
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432: 
    *   **\u0410\u0441\u0442\u0440\u043E\u043B\u044F\u0431\u0438\u044F:** \u041F\u0440\u0438\u0431\u043E\u0440
    \u0434\u043B\u044F \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u0445
    \u0442\u0435\u043B. \u0425\u043E\u0442\u044F \u043E\u043D\u0430 \u043D\u0435
    \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u0435\u043C,
    \u0435\u0451 \u0443\u0447\u0435\u043D\u0438\u043A \u0421\u0438\u043D\u0435\u0437\u0438\u0439
    \u043E\u0431\u0440\u0430\u0449\u0430\u043B\u0441\u044F \u043A \u043D\u0435\u0439
    \u0437\u0430 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0432 \u0435\u0433\u043E
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438, \u0447\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u043E \u0435\u0451 \u0432\u044B\u0441\u043E\u043A\u043E\u043C \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u0435
    \u0432 \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438
    \u043F\u043E\u0434\u043E\u0431\u043D\u044B\u0445 \u043F\u0440\u0438\u0431\u043E\u0440\u043E\u0432.
    *   **\u041F\u043B\u0430\u043D\u0438\u0441\u0444\u0435\u0440\u0430:** \u041F\u043B\u043E\u0441\u043A\u0430\u044F
    \u043F\u043E\u0434\u0432\u0438\u0436\u043D\u0430\u044F \u043A\u0430\u0440\u0442\u0430
    \u043D\u0435\u0431\u0430. \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u0430\u044F \u043F\u0440\u0438
    \u0435\u0451 \u0443\u0447\u0430\u0441\u0442\u0438\u0438 \u043F\u043B\u0430\u043D\u0438\u0441\u0444\u0435\u0440\u0430
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u0432\u043F\u043B\u043E\u0442\u044C \u0434\u043E XVII \u0432\u0435\u043A\u0430
    \u0438 \u0434\u0430\u0436\u0435 \u0431\u044B\u043B\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0443. *   **\u0410\u0440\u0435\u043E\u043C\u0435\u0442\u0440
    (\u0433\u0438\u0434\u0440\u043E\u0441\u043A\u043E\u043F):** \u041F\u0440\u0438\u0431\u043E\u0440
    \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F \u043F\u043B\u043E\u0442\u043D\u043E\u0441\u0442\u0438
    \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0435\u0439. \u0415\u0451 \u0443\u0447\u0435\u043D\u0438\u043A
    \u0421\u0438\u043D\u0435\u0437\u0438\u0439 \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u043E\u0441\u0438\u043B
    \u0435\u0451 \u043F\u043E\u043C\u043E\u0449\u0438 \u0432 \u0435\u0433\u043E \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438. 
    ### \U0001F9E0 \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0430\u044F
    \u0438 \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C 
    \u0413\u043B\u0430\u0432\u043D\u044B\u043C \u043F\u0440\u0438\u0437\u0432\u0430\u043D\u0438\u0435\u043C
    \u0413\u0438\u043F\u0430\u0442\u0438\u0438 \u0431\u044B\u043B\u043E \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0441\u0445\u043E\u043B\u0430\u0440\u0445\u043E\u043C
    (\u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C)
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u044B,
    \u0433\u0434\u0435 \u0447\u0438\u0442\u0430\u043B\u0430 \u043B\u0435\u043A\u0446\u0438\u0438
    \u043F\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 (\u041F\u043B\u0430\u0442\u043E\u043D
    \u0438 \u0410\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u044C), \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438. \u0415\u0451
    \u0448\u043A\u043E\u043B\u0430 \u0431\u044B\u043B\u0430 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u0430
    \u0442\u0435\u043C, \u0447\u0442\u043E \u0432 \u043D\u0435\u0439 \u043E\u0431\u0443\u0447\u0430\u043B\u0438\u0441\u044C
    \u043A\u0430\u043A \u044F\u0437\u044B\u0447\u043D\u0438\u043A\u0438, \u0442\u0430\u043A
    \u0438 \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0435, \u0438 \u043E\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0437\u043E\u043D\u043E\u0439 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439
    \u0438 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0439 \u0442\u0435\u0440\u043F\u0438\u043C\u043E\u0441\u0442\u0438.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0443\u0447\u0451\u043D\u044B\u043C, \u043D\u043E \u0438 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u0434\u0435\u044F\u0442\u0435\u043B\u0435\u043C,
    \u0447\u044C\u0438\u043C \u043C\u043D\u0435\u043D\u0438\u0435\u043C \u0434\u043E\u0440\u043E\u0436\u0438\u043B\u0438
    \u043F\u0435\u0440\u0432\u044B\u0435 \u043B\u0438\u0446\u0430 \u0433\u043E\u0440\u043E\u0434\u0430. 
    \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0413\u0438\u043F\u0430\u0442\u0438\u0438 \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F
    \u043D\u0435 \u0432 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438 \u043D\u043E\u0432\u044B\u0445
    \u0442\u0435\u043E\u0440\u0438\u0439, \u0430 \u0432 \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0438
    \u0438 \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0435 \u0433\u0438\u0433\u0430\u043D\u0442\u0441\u043A\u043E\u0433\u043E
    \u043F\u043B\u0430\u0441\u0442\u0430 \u0437\u043D\u0430\u043D\u0438\u0439. \u041E\u043D\u0430
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u043C
    \u043C\u0430\u044F\u043A\u043E\u043C \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438 \u0438 \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0437\u043C\u0430,
    \u0438 \u0435\u0451 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0438\u0431\u0435\u043B\u044C \u0441\u0442\u0430\u043B\u0430 \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C
    \u043A\u043E\u043D\u0446\u0430 \u0446\u0435\u043B\u043E\u0439 \u044D\u043F\u043E\u0445\u0438."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C,
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u043F\u0443\u0442\u044C
    \u0432 \u043D\u0430\u0443\u043A\u0435 \u0413\u0438\u043F\u0430\u0442\u0438\u0438
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F, \u043F\u043E\u043B\u043D\u0430\u044F
    \u0431\u0435\u043B\u044B\u0445 \u043F\u044F\u0442\u0435\u043D, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043F\u044B\u0442\u0430\u044E\u0442\u0441\u044F
    \u0437\u0430\u043F\u043E\u043B\u043D\u0438\u0442\u044C \u043F\u043E \u043A\u0440\u0443\u043F\u0438\u0446\u0430\u043C.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0434\u0430\u0436\u0435 \u0442\u043E \u043D\u0435\u043C\u043D\u043E\u0433\u043E\u0435,
    \u0447\u0442\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u0440\u0438\u0441\u0443\u0435\u0442
    \u043E\u0431\u0440\u0430\u0437 \u043D\u0435\u043E\u0431\u044B\u043A\u043D\u043E\u0432\u0435\u043D\u043D\u043E\u0439
    \u0436\u0435\u043D\u0449\u0438\u043D\u044B, \u0436\u0438\u0432\u0448\u0435\u0439
    \u043D\u0430 \u0441\u0442\u044B\u043A\u0435 \u044D\u043F\u043E\u0445.  ### \U0001F476
    \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u0441\u0435\u043C\u044C\u044F 
    \u0422\u043E\u0447\u043D\u0430\u044F \u0434\u0430\u0442\u0430 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0413\u0438\u043F\u0430\u0442\u0438\u0438 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430,
    \u0438 \u044D\u0442\u043E \u043E\u0434\u043D\u0430 \u0438\u0437 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u0437\u0430\u0433\u0430\u0434\u043E\u043A \u0435\u0451 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438.
    \u0411\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0443\u0447\u0451\u043D\u044B\u0445 \u0441\u0445\u043E\u0434\u044F\u0442\u0441\u044F
    \u0432\u043E \u043C\u043D\u0435\u043D\u0438\u0438, \u0447\u0442\u043E \u043E\u043D\u0430
    \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u0432 **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438
    \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0439** \u0432 \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043A\u0435
    \u043C\u0435\u0436\u0434\u0443 **355 \u0438 370 \u0433\u043E\u0434\u0430\u043C\u0438**
    \u043D\u0430\u0448\u0435\u0439 \u044D\u0440\u044B. \u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0438
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u0440\u0430\u0437\u043D\u044B\u0435
    \u0434\u0430\u0442\u044B: \u043E\u0434\u043D\u0438 \u0441\u043A\u043B\u043E\u043D\u044F\u044E\u0442\u0441\u044F
    \u043A 370 \u0433\u043E\u0434\u0443, \u0434\u0440\u0443\u0433\u0438\u0435, \u043A\u0430\u043A
    \u041C\u0430\u0440\u0438\u044F \u0414\u0437\u0435\u043B\u044C\u0441\u043A\u0430,
    \u2014 \u043A 355 \u0433\u043E\u0434\u0443.  \u0415\u0451 \u043E\u0442\u0446\u043E\u043C
    \u0431\u044B\u043B **\u0422\u0435\u043E\u043D \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0438\u0439**
    \u2014 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A,
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u041C\u0443\u0441\u0435\u0439\u043E\u043D\u0430. \u0422\u0435\u043E\u043D \u0434\u0430\u043B
    \u0434\u043E\u0447\u0435\u0440\u0438 \u0438\u043C\u044F **\xAB\u0413\u0438\u043F\u0430\u0442\u0438\u044F\xBB**,
    \u0447\u0442\u043E \u0432 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0435 \u0441
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442
    **\xAB\u0432\u044B\u0441\u0448\u0430\u044F\xBB**, \u0447\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u043E \u0435\u0433\u043E \u0431\u043E\u043B\u044C\u0448\u0438\u0445 \u043D\u0430\u0434\u0435\u0436\u0434\u0430\u0445
    \u043D\u0430 \u043D\u0435\u0451.  \u0418\u043C\u044F \u0435\u0451 \u043C\u0430\u0442\u0435\u0440\u0438,
    \u043A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E, \u043D\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043B\u0438\u0448\u044C \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435,
    \u0447\u0442\u043E \u043E\u043D\u0430 \u0443\u043C\u0435\u0440\u043B\u0430 \u043F\u0440\u0438
    \u0440\u043E\u0434\u0430\u0445 \u0438\u043B\u0438 \u043A\u043E\u0433\u0434\u0430
    \u0413\u0438\u043F\u0430\u0442\u0438\u044F \u0431\u044B\u043B\u0430 \u0435\u0449\u0451
    \u0441\u043E\u0432\u0441\u0435\u043C \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u0439.
    \u0422\u0430\u043A\u0436\u0435 \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043E \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0445
    \u0431\u0440\u0430\u0442\u044C\u044F\u0445 \u0438 \u0441\u0451\u0441\u0442\u0440\u0430\u0445
    \u0413\u0438\u043F\u0430\u0442\u0438\u0438.  ### \U0001F4D6 \u0423\u0447\u0451\u0431\u0430
    \u0438 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u043A\u0430\u043A \u0443\u0447\u0451\u043D\u043E\u0433\u043E  \u0412\u0441\u0451
    \u0441\u0432\u043E\u0451 \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0413\u0438\u043F\u0430\u0442\u0438\u044F
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u043E\u0442\u0446\u0430. \u0422\u0435\u043E\u043D \u043E\u0431\u0443\u0447\u0438\u043B
    \u0435\u0451 \u0432 \u0434\u0443\u0445\u0435 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0439 **\u043F\u0430\u0439\u0434\u0435\u0439\u0438**
    \u2014 \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0432\u043A\u043B\u044E\u0447\u0430\u043B\u0430
    \u0432 \u0441\u0435\u0431\u044F \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E,
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0443, \u043D\u0430\u0443\u043A\u0443,
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E \u0438 \u0440\u0438\u0442\u043E\u0440\u0438\u043A\u0443. 
    *   **\u0410\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0430 \u0443\u0447\u0451\u0431\u044B:**
    \u041E\u0431\u0443\u0447\u0435\u043D\u0438\u0435, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B\u043E \u0432 \u0441\u0442\u0435\u043D\u0430\u0445
    \u041C\u0443\u0441\u0435\u0439\u043E\u043D\u0430, \u0433\u0434\u0435 \u0422\u0435\u043E\u043D,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0435\u0433\u043E \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C,
    \u0438\u043C\u0435\u043B \u0434\u043E\u0441\u0442\u0443\u043F \u043A \u0431\u043E\u0433\u0430\u0442\u0435\u0439\u0448\u0438\u043C
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u0430\u043C.
    \u0413\u0438\u043F\u0430\u0442\u0438\u044F \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
    \u0432\u043F\u0438\u0442\u0430\u043B\u0430 \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0443
    \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0439 \u043D\u0430\u0443\u043A\u0438
    \u0438 \u043E\u0431\u0449\u0430\u043B\u0430\u0441\u044C \u0441 \u0432\u0435\u0434\u0443\u0449\u0438\u043C\u0438
    \u0443\u043C\u0430\u043C\u0438 \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0440\u0438\u043C\u0441\u043A\u0438\u0445,
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0445 \u0438 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u0438\u0445
    \u0443\u0447\u0451\u043D\u044B\u0445. *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F:** \u0422\u0435\u043E\u043D
    \u0434\u0430\u043B \u0413\u0438\u043F\u0430\u0442\u0438\u0438 \u043E\u0431\u0448\u0438\u0440\u043D\u043E\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435, \u0438 \u043E\u043D\u0430
    \u0431\u044B\u0441\u0442\u0440\u043E \u043F\u0440\u0435\u0432\u0437\u043E\u0448\u043B\u0430
    \u0441\u0432\u043E\u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044F,
    \u0447\u0442\u043E \u043E\u0442\u043C\u0435\u0447\u0430\u0435\u0442 \u0434\u0430\u0436\u0435
    \u0432\u0438\u0437\u0430\u043D\u0442\u0438\u0439\u0441\u043A\u0438\u0439 \u0441\u043B\u043E\u0432\u0430\u0440\u044C
    \xAB\u0421\u0443\u0434\u0430\xBB. \u041E\u0434\u043D\u0430\u043A\u043E, \u043A\u0442\u043E
    \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u0431\u0443\u0447\u0438\u043B \u0435\u0451
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u043D\u0435\u043E\u043F\u043B\u0430\u0442\u043E\u043D\u0438\u0437\u043C\u0430
    \u2014 \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F \u0437\u0430\u0433\u0430\u0434\u043A\u043E\u0439.
    \u0411\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0442, \u0447\u0442\u043E \u044D\u0442\u043E
    \u0431\u044B\u043B \u043D\u0435 \u0435\u0451 \u043E\u0442\u0435\u0446, \u0430
    \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \u0434\u0440\u0443\u0433\u043E\u0439,
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043D\u0430\u043C
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A. *   **\u041B\u0435\u0433\u0435\u043D\u0434\u044B
    \u043E\u0431 \u0443\u0447\u0451\u0431\u0435:** \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043D\u0435\u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0451\u043D\u043D\u043E\u0435
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0435 \u0432 \u0441\u043B\u043E\u0432\u0430\u0440\u0435
    \xAB\u0421\u0443\u0434\u0430\xBB \u043E \u0442\u043E\u043C, \u0447\u0442\u043E
    \u0413\u0438\u043F\u0430\u0442\u0438\u044F \u0443\u0447\u0438\u043B\u0430\u0441\u044C
    \u0432 \u0410\u0444\u0438\u043D\u0430\u0445, \u043D\u043E \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432 \u043E\u0442\u0432\u0435\u0440\u0433\u0430\u044E\u0442
    \u044D\u0442\u0443 \u0432\u0435\u0440\u0441\u0438\u044E, \u0441\u0447\u0438\u0442\u0430\u044F
    \u0435\u0451 \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E\u0439.  ### \U0001F4BC
    \u041D\u0430\u0443\u0447\u043D\u0430\u044F \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430  \u041A\u0430\u0440\u044C\u0435\u0440\u0430
    \u0413\u0438\u043F\u0430\u0442\u0438\u0438 \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C
    \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E \u0432 **400 \u0433\u043E\u0434\u0443**,
    \u043A\u043E\u0433\u0434\u0430 \u0435\u0451 \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B\u0438
    \u0447\u0438\u0442\u0430\u0442\u044C \u043B\u0435\u043A\u0446\u0438\u0438 \u0432
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443. \u041E\u043D\u0430 \u0437\u0430\u043D\u044F\u043B\u0430
    \u043E\u0434\u043D\u0443 \u0438\u0437 \u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u043A\u0430\u0444\u0435\u0434\u0440 \u2014 \u043A\u0430\u0444\u0435\u0434\u0440\u0443
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438.  *   **\u041F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435:**
    \u0415\u0451 \u043B\u0435\u043A\u0446\u0438\u0438 \u0431\u044B\u043B\u0438 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u044B
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u041F\u043B\u0430\u0442\u043E\u043D\u0430
    \u0438 \u0410\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u044F, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C, \u0430 **\u0441\u0445\u043E\u043B\u0430\u0440\u0445\u043E\u043C**
    (\u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C)
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0439 \u0448\u043A\u043E\u043B\u044B,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u043B\u0430\u0432\u0438\u043B\u0430\u0441\u044C
    \u0441\u0432\u043E\u0435\u0439 \u0432\u0435\u0440\u043E\u0442\u0435\u0440\u043F\u0438\u043C\u043E\u0441\u0442\u044C\u044E:
    \u0441\u0440\u0435\u0434\u0438 \u0435\u0451 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432
    \u0431\u044B\u043B\u0438 \u043A\u0430\u043A \u044F\u0437\u044B\u0447\u043D\u0438\u043A\u0438,
    \u0442\u0430\u043A \u0438 \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0435,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E
    \u0435\u043F\u0438\u0441\u043A\u043E\u043F\u0430 \u041F\u0442\u043E\u043B\u0435\u043C\u0430\u0438\u0434\u044B
    \u0421\u0438\u043D\u0435\u0437\u0438\u044F. *   **\u041D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430:** \u041E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u043E\u043C,
    \u043D\u043E \u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u044B\u043C \u0443\u0447\u0451\u043D\u044B\u043C.
    \u0412\u043C\u0435\u0441\u0442\u0435 \u0441 \u043E\u0442\u0446\u043E\u043C \u043E\u043D\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430 \u043D\u0430\u0434 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u044F\u043C\u0438
    \u043A \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0443\xBB \u041A\u043B\u0430\u0432\u0434\u0438\u044F
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F. \u0422\u0430\u043A\u0436\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u0447\u0442\u043E \u043E\u043D\u0430
    \u0441\u043E\u0437\u0434\u0430\u043B\u0430 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0438
    \u043A \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C
    \u0442\u0440\u0443\u0434\u0430\u043C \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u0438 \u0410\u043F\u043E\u043B\u043B\u043E\u043D\u0438\u044F \u041F\u0435\u0440\u0433\u0441\u043A\u043E\u0433\u043E,
    \u0445\u043E\u0442\u044F \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044B
    \u044D\u0442\u0438\u0445 \u0440\u0430\u0431\u043E\u0442 \u043D\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0441\u044C. 
    ### \U0001F494 \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C 
    \u0412 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u043C \u043C\u0438\u0440\u0435,
    \u0433\u0434\u0435 \u0436\u0435\u043D\u0449\u0438\u043D\u044B \u0438\u0437 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0441\u0435\u043C\u0435\u0439 \u0447\u0430\u0441\u0442\u043E \u0432\u044B\u0445\u043E\u0434\u0438\u043B\u0438
    \u0437\u0430\u043C\u0443\u0436 \u0434\u043B\u044F \u0443\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0438\u044F
    \u0434\u0438\u043D\u0430\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0432\u044F\u0437\u0435\u0439, \u0413\u0438\u043F\u0430\u0442\u0438\u044F
    \u043F\u043E\u0448\u043B\u0430 \u0438\u043D\u044B\u043C \u043F\u0443\u0442\u0451\u043C.
    \u0412\u0441\u0435 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438 \u0441\u0445\u043E\u0434\u044F\u0442\u0441\u044F
    \u043D\u0430 \u0442\u043E\u043C, \u0447\u0442\u043E **\u0413\u0438\u043F\u0430\u0442\u0438\u044F
    \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0431\u044B\u043B\u0430
    \u0437\u0430\u043C\u0443\u0436\u0435\u043C** \u0438 \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B\u0430
    \u0441\u0432\u043E\u044E \u0436\u0438\u0437\u043D\u044C \u043D\u0430\u0443\u043A\u0435.
    \u041F\u0440\u0435\u0434\u043F\u043E\u043B\u0430\u0433\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u0422\u0435\u043E\u043D, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0438 \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B
    \u0432\u0430\u0440\u0438\u0430\u043D\u0442\u044B \u0431\u0440\u0430\u043A\u0430
    \u0434\u043B\u044F \u0434\u043E\u0447\u0435\u0440\u0438, \u0447\u0442\u043E\u0431\u044B
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C \u0441\u0432\u043E\u044E
    \u0448\u043A\u043E\u043B\u0443, \u043D\u043E \u0413\u0438\u043F\u0430\u0442\u0438\u044F
    \u043E\u0442\u0434\u0430\u043B\u0430 \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0442\u0435\u043D\u0438\u0435
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u0438 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\u043C. 
    \u0415\u0451 \u0436\u0438\u0437\u043D\u044C, \u043F\u043E\u043B\u043D\u0430\u044F
    \u0441\u0430\u043C\u043E\u043E\u0442\u0432\u0435\u0440\u0436\u0435\u043D\u043D\u043E\u0433\u043E
    \u0441\u043B\u0443\u0436\u0435\u043D\u0438\u044F \u0437\u043D\u0430\u043D\u0438\u044E
    \u0438 \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0434\u043B\u044F \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0441\u0432\u043E\u0431\u043E\u0434\u044B, \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0431\u043E\u0440\u0432\u0430\u043B\u0430\u0441\u044C \u0432 \u043C\u0430\u0440\u0442\u0435
    415 \u0433\u043E\u0434\u0430, \u0441\u0442\u0430\u0432 \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C
    \u0433\u0438\u0431\u0435\u043B\u0438 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438."
  personalLifeEn: 
  shortBioRu: "\u0413\u0438\u043F\u0430\u0442\u0438\u044F \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0430\u044F
    \u2014 \u0444\u0438\u0433\u0443\u0440\u0430, \u0441\u0442\u043E\u044F\u0449\u0430\u044F
    \u043D\u0430 \u043F\u0435\u0440\u0435\u043B\u043E\u043C\u0435 \u044D\u043F\u043E\u0445.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u0443\u0447\u0451\u043D\u044B\u043C, \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u043C
    \u0438 \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u043E\u043C, \u0447\u044C\u044F
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0433\u0438\u0431\u0435\u043B\u044C
    \u0441\u0442\u0430\u043B\u0430 \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0430 \u043C\u0435\u0436\u0434\u0443
    \u0443\u0445\u043E\u0434\u044F\u0449\u0438\u043C \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u043C
    \u0437\u043D\u0430\u043D\u0438\u0435\u043C \u0438 \u043D\u0430\u0440\u043E\u0436\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u043C \u0434\u043E\u0433\u043C\u0430\u0442\u0438\u0437\u043C\u043E\u043C.
    \u042F \u043F\u043E\u0441\u0442\u0430\u0440\u0430\u043B\u0441\u044F \u0441\u043E\u0431\u0440\u0430\u0442\u044C
    \u0434\u043B\u044F \u0432\u0430\u0441 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0443\u044E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E,
    \u043E\u043F\u0438\u0440\u0430\u044F\u0441\u044C \u043D\u0430 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438. 
    ### \U0001F4DC \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B  \u0413\u0438\u043F\u0430\u0442\u0438\u044F
    \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438
    \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043C\u0435\u0436\u0434\u0443 355 \u0438 370 \u0433\u043E\u0434\u0430\u043C\u0438
    \u043D\u0430\u0448\u0435\u0439 \u044D\u0440\u044B. \u041E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u0434\u043E\u0447\u0435\u0440\u044C\u044E **\u0422\u0435\u043E\u043D\u0430 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u043E\u043C,
    \u043D\u043E \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u043C \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u041C\u0443\u0441\u0435\u0439\u043E\u043D\u0430 \u2014 \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0446\u0435\u043D\u0442\u0440\u0430 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430.  *   **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:**
    \u0421\u0432\u043E\u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u0437\u043D\u0430\u043D\u0438\u044F
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438 \u0413\u0438\u043F\u0430\u0442\u0438\u044F
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 \u043E\u0442 \u043E\u0442\u0446\u0430.
    \u0422\u0435\u043E\u043D, \u0432\u0438\u0434\u044F \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u0434\u043E\u0447\u0435\u0440\u0438,
    \u0434\u0430\u043B \u0435\u0439 \u0438\u043C\u044F, \u043E\u0437\u043D\u0430\u0447\u0430\u044E\u0449\u0435\u0435
    \xAB\u0432\u044B\u0441\u0448\u0430\u044F\xBB, \u0438 \u0434\u0430\u043B \u0432\u0441\u0435\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0435\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0432\u043A\u043B\u044E\u0447\u0430\u043B\u043E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u043E\u0447\u043D\u044B\u0435 \u043D\u0430\u0443\u043A\u0438, \u043D\u043E
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E, \u0438 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0443.
    \u0418\u043C\u044F \u0435\u0451 \u043C\u0430\u0442\u0435\u0440\u0438 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E.
    *   **\u0410\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0430 \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438:**
    \u0413\u043E\u0440\u043E\u0434 \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F
    \u0431\u044B\u043B \u043F\u043B\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u043C
