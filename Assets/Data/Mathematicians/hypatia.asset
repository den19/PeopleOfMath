    \u043F\u0435\u0440\u0432\u044B\u043C \u043B\u0438\u0446\u0430\u043C, \u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044F
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u043C\u0443\u043D\u0438\u0446\u0438\u043F\u0430\u043B\u044C\u043D\u043E\u0435
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435.  ### \U0001F4DA
    \u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E, \u043D\u0438 \u043E\u0434\u043D\u043E
    \u0438\u0437 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0445
