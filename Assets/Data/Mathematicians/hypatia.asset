    \u2014 \u0432\u0430\u0436\u043D\u044B\u0439 \u044F\u0437\u044B\u0447\u0435\u0441\u043A\u0438\u0439
    \u0445\u0440\u0430\u043C \u0438 \u0444\u0438\u043B\u0438\u0430\u043B \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0438. \u042D\u0442\u043E
    \u0441\u043E\u0431\u044B\u0442\u0438\u0435, \u043F\u043E\u0442\u0440\u044F\u0441\u0448\u0435\u0435
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u0443\u044E
    \u044D\u043B\u0438\u0442\u0443, \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E,
    \u043E\u043A\u0430\u0437\u0430\u043B\u043E \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u0438 \u043D\u0430 \u0413\u0438\u043F\u0430\u0442\u0438\u044E.  ### \U0001F9E0
    \u041D\u0430\u0443\u0447\u043D\u0430\u044F \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C  \u041F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u0442\u0446\u0430, \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E
    \u0441 **405 \u0433\u043E\u0434\u0430**, \u0413\u0438\u043F\u0430\u0442\u0438\u044F
    \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u0430 \u0435\u0433\u043E
