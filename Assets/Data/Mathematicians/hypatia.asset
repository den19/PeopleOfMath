    (\u0441\u0445\u043E\u043B\u0430\u0440\u0445\u043E\u043C). \u041E\u043D\u0430
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B\u0430 \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 \u043D\u0435\u043E\u043F\u043B\u0430\u0442\u043E\u043D\u0438\u0437\u043C\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u044B\u043B\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u043D\u0430 \u0432\u0435\u0441\u044C \u0433\u0440\u0435\u043A\u043E-\u0440\u0438\u043C\u0441\u043A\u0438\u0439
    \u043C\u0438\u0440.  *   **\u041F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435:**
    \u0413\u0438\u043F\u0430\u0442\u0438\u044F \u0447\u0438\u0442\u0430\u043B\u0430
    \u043B\u0435\u043A\u0446\u0438\u0438 \u043F\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    (\u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u041F\u043B\u0430\u0442\u043E\u043D\u0430
    \u0438 \u0410\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u044F), \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438. \u0415\u0451
    \u0448\u043A\u043E\u043B\u0430 \u0431\u044B\u043B\u0430 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u0430
    \u0434\u043B\u044F \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u2014 \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0437\u043E\u043D\u043E\u0439
    \u0432\u0435\u0440\u043E\u0442\u0435\u0440\u043F\u0438\u043C\u043E\u0441\u0442\u0438.
    \u0421\u0440\u0435\u0434\u0438 \u0435\u0451 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432
    \u0431\u044B\u043B\u0438 \u043A\u0430\u043A \u044F\u0437\u044B\u0447\u043D\u0438\u043A\u0438,
    \u0442\u0430\u043A \u0438 \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0435,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u044A\u0435\u0437\u0436\u0430\u043B\u0438\u0441\u044C
    \u043A \u043D\u0435\u0439 \u0441\u043E \u0432\u0441\u0435\u0433\u043E \u0421\u0440\u0435\u0434\u0438\u0437\u0435\u043C\u043D\u043E\u043C\u043E\u0440\u044C\u044F.
    *   **\u0421\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
