    \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0438 \u043A \u0442\u0440\u0443\u0434\u0430\u043C
    \u0432\u0435\u043B\u0438\u043A\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432:    
    *   **\xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430\xBB \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E:**
    \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0435\u0451 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0438
    \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0441\u044C
    \u043A\u0430\u043A \u0432\u0441\u0442\u0430\u0432\u043A\u0438 \u0432 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0435\u043A\u0441\u0442.     *   **\xAB\u041A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u0435\u0447\u0435\u043D\u0438\u044F\xBB \u0410\u043F\u043E\u043B\u043B\u043E\u043D\u0438\u044F
    \u041F\u0435\u0440\u0433\u0441\u043A\u043E\u0433\u043E**.     *   **\xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\xBB
    \u041A\u043B\u0430\u0432\u0434\u0438\u044F \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F:**
    \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E \u043E\u043D\u0430
    \u043F\u043E\u043C\u043E\u0433\u0430\u043B\u0430 \u043E\u0442\u0446\u0443 \u0432
    \u0440\u0430\u0431\u043E\u0442\u0435 \u043D\u0430\u0434 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u044F\u043C\u0438
    \u043A \u044D\u0442\u043E\u043C\u0443 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0442\u0440\u0443\u0434\u0443. *   **\u0418\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F:**
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0451\u043D\u043D\u043E\u0435
    \u043C\u043D\u0435\u043D\u0438\u0435, \u0413\u0438\u043F\u0430\u0442\u0438\u044F
    \u043D\u0435 \u0438\u0437\u043E\u0431\u0440\u0435\u043B\u0430 \u0430\u0441\u0442\u0440\u043E\u043B\u044F\u0431\u0438\u044E
    \u0438 \u0430\u0440\u0435\u043E\u043C\u0435\u0442\u0440 (\u043F\u0440\u0438\u0431\u043E\u0440\u044B
    \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F \u043F\u043B\u043E\u0442\u043D\u043E\u0441\u0442\u0438
    \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0435\u0439), \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0431\u044B\u043B\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B \u0438
    \u0434\u043E \u043D\u0435\u0451. \u041E\u0434\u043D\u0430\u043A\u043E \u043E\u043D\u0430,
    \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E, \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B\u0430
    \u0438 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u0438\u0445, \u043E \u0447\u0451\u043C \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443\u0435\u0442
    \u043F\u0440\u043E\u0441\u044C\u0431\u0430 \u0435\u0451 \u0443\u0447\u0435\u043D\u0438\u043A\u0430
    \u0421\u0438\u043D\u0435\u0437\u0438\u044F \u043F\u043E\u043C\u043E\u0447\u044C
    \u0432 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438 \u044D\u0442\u0438\u0445
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432. \u0421\u043E\u0437\u0434\u0430\u043D\u043D\u0430\u044F
    \u043F\u0440\u0438 \u0435\u0451 \u0443\u0447\u0430\u0441\u0442\u0438\u0438 \u043F\u043B\u0430\u043D\u0438\u0441\u0444\u0435\u0440\u0430
    (\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u0430\u044F \u043A\u0430\u0440\u0442\u0430
    \u043D\u0435\u0431\u0430) \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u0434\u043E XVII \u0432\u0435\u043A\u0430.  ### \u2694\uFE0F \u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442
    \u0438 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0433\u0438\u0431\u0435\u043B\u044C 
    \u0413\u0438\u0431\u0435\u043B\u044C \u0413\u0438\u043F\u0430\u0442\u0438\u0438
    \u0432 **\u043C\u0430\u0440\u0442\u0435 415 \u0433\u043E\u0434\u0430** \u0441\u0442\u0430\u043B\u0430
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u043E-\u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0433\u043E
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0430 \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438. 
    *   **\u041A\u0438\u0440\u0438\u043B\u043B \u0438 \u041E\u0440\u0435\u0441\u0442:**
    \u0412 412 \u0433\u043E\u0434\u0443 \u0435\u043F\u0438\u0441\u043A\u043E\u043F\u043E\u043C
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438 \u0441\u0442\u0430\u043B
    **\u041A\u0438\u0440\u0438\u043B\u043B**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u043E\u0436\u0435\u0441\u0442\u043E\u0447\u0451\u043D\u043D\u0443\u044E
    \u0431\u043E\u0440\u044C\u0431\u0443 \u0437\u0430 \u0432\u043B\u0430\u0441\u0442\u044C
    \u0441 \u043F\u0440\u0435\u0444\u0435\u043A\u0442\u043E\u043C \u041E\u0440\u0435\u0441\u0442\u043E\u043C.
    \u0413\u0438\u043F\u0430\u0442\u0438\u044F, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0434\u0440\u0443\u0433\u043E\u043C \u0438 \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u043E\u043C
    \u041E\u0440\u0435\u0441\u0442\u0430, \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C \u0432 \u0446\u0435\u043D\u0442\u0440\u0435
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044F.
    *   **\u041E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u044F \u0438 \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u043E:**
    \u0412\u0440\u0430\u0433\u0438 \u0413\u0438\u043F\u0430\u0442\u0438\u0438 \u0440\u0430\u0441\u043F\u0443\u0441\u0442\u0438\u043B\u0438
    \u0441\u043B\u0443\u0445\u0438, \u0447\u0442\u043E \u043E\u043D\u0430 \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442\u0441\u044F
    \u0447\u0451\u0440\u043D\u043E\u0439 \u043C\u0430\u0433\u0438\u0435\u0439 \u0438
    \u043F\u0440\u0435\u043F\u044F\u0442\u0441\u0442\u0432\u0443\u0435\u0442 \u043F\u0440\u0438\u043C\u0438\u0440\u0435\u043D\u0438\u044E
    \u041A\u0438\u0440\u0438\u043B\u043B\u0430 \u0438 \u041E\u0440\u0435\u0441\u0442\u0430.
    \u0422\u043E\u043B\u043F\u0430 \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0441\u043A\u0438\u0445
    \u0444\u0430\u043D\u0430\u0442\u0438\u043A\u043E\u0432 (\u043F\u0430\u0440\u0430\u0431\u043E\u043B\u0430\u043D\u043E\u0432)
    \u0432\u043E \u0433\u043B\u0430\u0432\u0435 \u0441 \u0447\u0442\u0435\u0446\u043E\u043C
    \u041F\u0435\u0442\u0440\u043E\u043C \u043D\u0430\u043F\u0430\u043B\u0430 \u043D\u0430
    \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0432\u0448\u0443\u044E\u0441\u044F
    \u0434\u043E\u043C\u043E\u0439 \u0413\u0438\u043F\u0430\u0442\u0438\u044E. *  
    **\u0416\u0435\u0441\u0442\u043E\u043A\u043E\u0441\u0442\u044C:** \u0415\u0451
    \u0432\u044B\u0442\u0430\u0449\u0438\u043B\u0438 \u0438\u0437 \u043F\u0430\u043B\u0430\u043D\u043A\u0438\u043D\u0430,
    \u0437\u0430\u0442\u0430\u0449\u0438\u043B\u0438 \u0432 \u0446\u0435\u0440\u043A\u043E\u0432\u044C,
    \u0441\u043E\u0440\u0432\u0430\u043B\u0438 \u043E\u0434\u0435\u0436\u0434\u0443
    \u0438 \u0437\u0432\u0435\u0440\u0441\u043A\u0438 \u0443\u0431\u0438\u043B\u0438,
    \u0441\u0434\u0438\u0440\u0430\u044F \u043F\u043B\u043E\u0442\u044C \u0441 \u043A\u043E\u0441\u0442\u0435\u0439
    \u043E\u0441\u0442\u0440\u044B\u043C\u0438 \u0447\u0435\u0440\u0435\u043F\u043A\u0430\u043C\u0438.
    \u0422\u0435\u043B\u043E \u0431\u044B\u043B\u043E \u0440\u0430\u0441\u0447\u043B\u0435\u043D\u0435\u043D\u043E
    \u0438 \u0441\u043E\u0436\u0436\u0435\u043D\u043E. *   **\u041F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u044F:**
    \u0423\u0431\u0438\u0439\u0441\u0442\u0432\u043E \u043F\u043E\u0442\u0440\u044F\u0441\u043B\u043E
    \u0438\u043C\u043F\u0435\u0440\u0438\u044E. \u0421 \u0433\u0438\u0431\u0435\u043B\u044C\u044E
    \u0413\u0438\u043F\u0430\u0442\u0438\u0438 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0443\u0447\u0451\u043D\u044B\u0435 \u043F\u043E\u043A\u0438\u043D\u0443\u043B\u0438
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u044E, \u0447\u0442\u043E
    \u043E\u0437\u043D\u0430\u043C\u0435\u043D\u043E\u0432\u0430\u043B\u043E \u043D\u0430\u0447\u0430\u043B\u043E
    \u0443\u043F\u0430\u0434\u043A\u0430 \u0433\u043E\u0440\u043E\u0434\u0430 \u043A\u0430\u043A
    \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u0446\u0435\u043D\u0442\u0440\u0430. \u0415\u043F\u0438\u0441\u043A\u043E\u043F
    \u041A\u0438\u0440\u0438\u043B\u043B, \u043F\u0440\u044F\u043C\u043E \u0438\u043B\u0438
    \u043A\u043E\u0441\u0432\u0435\u043D\u043D\u043E \u043F\u0440\u0438\u0447\u0430\u0441\u0442\u043D\u044B\u0439
    \u043A \u044D\u0442\u043E\u0439 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438,
    \u043F\u043E\u0437\u0436\u0435 \u0431\u044B\u043B \u043A\u0430\u043D\u043E\u043D\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D
    \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0441\u043A\u043E\u0439 \u0446\u0435\u0440\u043A\u043E\u0432\u044C\u044E. 
    ### \U0001F31F \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0438 \u043F\u0430\u043C\u044F\u0442\u044C 
    \u0413\u0438\u043F\u0430\u0442\u0438\u044F \u0441\u0442\u0430\u043B\u0430 \u043B\u0435\u0433\u0435\u043D\u0434\u043E\u0439.
    \u0412 \u044D\u043F\u043E\u0445\u0443 \u041F\u0440\u043E\u0441\u0432\u0435\u0449\u0435\u043D\u0438\u044F
    \u0435\u0451 \u043E\u0431\u0440\u0430\u0437 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u043A\u0430\u043A \u0441\u0438\u043C\u0432\u043E\u043B \u0431\u043E\u0440\u044C\u0431\u044B
    \u0441 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u043C \u0444\u0430\u043D\u0430\u0442\u0438\u0437\u043C\u043E\u043C.
    \u0415\u0451 \u0436\u0438\u0437\u043D\u0438 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u044B
    \u043A\u043D\u0438\u0433\u0438, \u043A\u0430\u0440\u0442\u0438\u043D\u044B (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043D\u0430 \u0444\u0440\u0435\u0441\u043A\u0435 \u0420\u0430\u0444\u0430\u044D\u043B\u044F
    \xAB\u0410\u0444\u0438\u043D\u0441\u043A\u0430\u044F \u0448\u043A\u043E\u043B\u0430\xBB),
    \u0441\u043A\u0443\u043B\u044C\u043F\u0442\u0443\u0440\u044B \u0438 \u0445\u0443\u0434\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0444\u0438\u043B\u044C\u043C **\xAB\u0410\u0433\u043E\u0440\u0430\xBB** (2009)
    \u0441 \u0420\u044D\u0439\u0447\u0435\u043B \u0412\u0430\u0439\u0441 \u0432 \u0433\u043B\u0430\u0432\u043D\u043E\u0439
    \u0440\u043E\u043B\u0438. \u0418\u043C\u0435\u043D\u0435\u043C \u0413\u0438\u043F\u0430\u0442\u0438\u0438
    \u043D\u0430\u0437\u0432\u0430\u043D\u044B \u043A\u0440\u0430\u0442\u0435\u0440
    \u043D\u0430 \u041B\u0443\u043D\u0435 \u0438 \u0430\u0441\u0442\u0435\u0440\u043E\u0438\u0434. 
    \u0413\u0438\u043F\u0430\u0442\u0438\u044F \u0431\u044B\u043B\u0430 \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \xAB\u043F\u0435\u0440\u0432\u043E\u0439
    \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C\xBB.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0432\u043E\u043F\u043B\u043E\u0449\u0435\u043D\u0438\u0435\u043C
    \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0433\u043E \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0437\u043C\u0430
    \u0438 \u0441\u0432\u043E\u0431\u043E\u0434\u044B \u043C\u044B\u0441\u043B\u0438,
    \u0438 \u0435\u0451 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u0443\u0434\u044C\u0431\u0430 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440
    \u0441\u043B\u0443\u0436\u0438\u0442 \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0435\u043C
    \u043E \u0445\u0440\u0443\u043F\u043A\u043E\u0441\u0442\u0438 \u0437\u043D\u0430\u043D\u0438\u044F
    \u043F\u0435\u0440\u0435\u0434 \u043B\u0438\u0446\u043E\u043C \u043D\u0435\u0442\u0435\u0440\u043F\u0438\u043C\u043E\u0441\u0442\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0413\u0438\u043F\u0430\u0442\u0438\u044F \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0430\u044F
    \u2014 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C, \u0432\u043E\u043A\u0440\u0443\u0433
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0437\u0430 16 \u0432\u0435\u043A\u043E\u0432
    \u0441\u043B\u043E\u0436\u0438\u043B\u043E\u0441\u044C \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u0439,
    \u043A\u0443\u0440\u044C\u0451\u0437\u043E\u0432 \u0438 \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u044B\u0445
    \u043C\u0438\u0444\u043E\u0432. \u0415\u0451 \u0436\u0438\u0437\u043D\u044C \u0438
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0441\u0443\u0434\u044C\u0431\u0430
    \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u0438 \u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043B\u0435\u0433\u0435\u043D\u0434, \u0447\u0442\u043E \u043F\u043E\u0440\u043E\u0439
    \u043E\u0442\u0434\u0435\u043B\u0438\u0442\u044C \u0444\u0430\u043A\u0442\u044B
    \u043E\u0442 \u0432\u044B\u043C\u044B\u0441\u043B\u0430 \u043E\u0447\u0435\u043D\u044C
    \u0441\u043B\u043E\u0436\u043D\u043E.  ### \U0001F3AD \u041E\u0442 \u0441\u0432\u044F\u0442\u043E\u0439
    \u0434\u043E \u0432\u0435\u0434\u044C\u043C\u044B: \u042D\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u043E\u0431\u0440\u0430\u0437\u0430 \u0413\u0438\u043F\u0430\u0442\u0438\u0438 
    \u041F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u044B\u0439 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442 \u043E \u0413\u0438\u043F\u0430\u0442\u0438\u0438 \u2014
    \u044D\u0442\u043E \u0442\u043E, \u043A\u0430\u043A \u0441\u0438\u043B\u044C\u043D\u043E
    \u043C\u0435\u043D\u044F\u043B\u043E\u0441\u044C \u0435\u0451 \u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u0435
    \u0432 \u0440\u0430\u0437\u043D\u044B\u0435 \u044D\u043F\u043E\u0445\u0438. \u041E\u043D\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C
    \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u044B\u043C \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043A\u0430\u0436\u0434\u0430\u044F
    \u044D\u043F\u043E\u0445\u0430 \"\u043F\u043E\u0434\u0433\u043E\u043D\u044F\u043B\u0430\"
    \u043F\u043E\u0434 \u0441\u0435\u0431\u044F:  *   **\u0410\u043D\u0442\u0438\u0447\u043D\u044B\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444:** \u0412 \u0441\u0432\u043E\u0451
    \u0432\u0440\u0435\u043C\u044F \u2014 \u0436\u0435\u043D\u0449\u0438\u043D\u0430-\u0443\u0447\u0451\u043D\u044B\u0439
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444-\u043D\u0435\u043E\u043F\u043B\u0430\u0442\u043E\u043D\u0438\u043A,
    \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0432\u0448\u0430\u044F\u0441\u044F
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435\u043C
    \u0434\u0430\u0436\u0435 \u0443 \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D.
    *   **\u0421\u0438\u043C\u0432\u043E\u043B \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0441\u0442\u0432\u0430:**
    \u0412 \u0421\u0440\u0435\u0434\u043D\u0438\u0435 \u0432\u0435\u043A\u0430 \u0434\u0435\u0442\u0430\u043B\u0438
    \u0435\u0451 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u0431\u044B\u043B\u0438
    \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u044B \u0441 \u0436\u0438\u0442\u0438\u0435\u043C
    \u0421\u0432\u044F\u0442\u043E\u0439 \u0415\u043A\u0430\u0442\u0435\u0440\u0438\u043D\u044B
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0439.
    *   **\u0410\u043D\u0442\u0438\u043A\u043B\u0435\u0440\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u0441\u0438\u043C\u0432\u043E\u043B:** \u0412 \u044D\u043F\u043E\u0445\u0443
    \u041F\u0440\u043E\u0441\u0432\u0435\u0449\u0435\u043D\u0438\u044F \u0412\u043E\u043B\u044C\u0442\u0435\u0440
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u043C\u044B\u0441\u043B\u0438\u0442\u0435\u043B\u0438
    \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u0438 \u0435\u0451 \u0432
    \u043C\u0443\u0447\u0435\u043D\u0438\u0446\u0443, \u043F\u0430\u0432\u0448\u0443\u044E
    \u0436\u0435\u0440\u0442\u0432\u043E\u0439 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0433\u043E
    \u0444\u0430\u043D\u0430\u0442\u0438\u0437\u043C\u0430. *   **\u041F\u0440\u0435\u0434\u0432\u0435\u0441\u0442\u043D\u0438\u0446\u0430
    \u0444\u0435\u043C\u0438\u043D\u0438\u0437\u043C\u0430:** \u0412 XIX \u0438 XX
    \u0432\u0435\u043A\u0430\u0445 \u0435\u0451 \u043E\u0431\u0440\u0430\u0437 \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438 \u043A\u0430\u043A
    \u0441\u0438\u043C\u0432\u043E\u043B \u0431\u043E\u0440\u044C\u0431\u044B \u0436\u0435\u043D\u0449\u0438\u043D
    \u0437\u0430 \u043F\u0440\u0430\u0432\u043E \u043D\u0430 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u043D\u0430\u0443\u043A\u0443.  ### \U0001F631 \u0421\u0430\u043C\u044B\u0439
    \u0448\u043E\u043A\u0438\u0440\u0443\u044E\u0449\u0438\u0439 \u043A\u0443\u0440\u044C\u0451\u0437:
    \u041C\u0435\u043D\u0441\u0442\u0440\u0443\u0430\u043B\u044C\u043D\u044B\u0435
    \u0442\u0440\u044F\u043F\u043A\u0438 \u0438 \u0432\u043B\u044E\u0431\u043B\u0451\u043D\u043D\u044B\u0439
    \u0443\u0447\u0435\u043D\u0438\u043A  \u041E\u0434\u0438\u043D \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u0438, \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E,
    \u0441\u0430\u043C\u044B\u0445 \u043F\u0438\u043A\u0430\u043D\u0442\u043D\u044B\u0445
    \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432 \u0438\u0437 \u0436\u0438\u0437\u043D\u0438
    \u0413\u0438\u043F\u0430\u0442\u0438\u0438 \u043E\u043F\u0438\u0441\u0430\u043D
    \u0432 \u0432\u0438\u0437\u0430\u043D\u0442\u0438\u0439\u0441\u043A\u043E\u043C
    \u0441\u043B\u043E\u0432\u0430\u0440\u0435 X \u0432\u0435\u043A\u0430. \u0412\u043E\u0442
    \u043A\u0430\u043A \u044D\u0442\u043E \u0431\u044B\u043B\u043E:  > \u041E\u0434\u0438\u043D
    \u0438\u0437 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432, \u043F\u044B\u043B\u0430\u044F
    \u0441\u0442\u0440\u0430\u0441\u0442\u044C\u044E \u043A \u0441\u0432\u043E\u0435\u0439
    \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E\u0439 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u0446\u0435,
    \u043D\u0435 \u0441\u043C\u043E\u0433 \u0441\u0434\u0435\u0440\u0436\u0430\u0442\u044C
    \u0447\u0443\u0432\u0441\u0442\u0432. \u0412 \u043E\u0442\u0432\u0435\u0442 \u0413\u0438\u043F\u0430\u0442\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0434\u0430\u043B\u0430 \u043E\u0431\u0435\u0442
    \u0431\u0435\u0437\u0431\u0440\u0430\u0447\u0438\u044F, \u0432\u0437\u044F\u043B\u0430
    \u0441\u0432\u043E\u044E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u043D\u0443\u044E
    \u043C\u0435\u043D\u0441\u0442\u0440\u0443\u0430\u043B\u044C\u043D\u0443\u044E
    \u0442\u043A\u0430\u043D\u044C \u0438, \u0431\u0440\u043E\u0441\u0438\u0432 \u0435\u0451
    \u043F\u0435\u0440\u0435\u0434 \u044E\u043D\u043E\u0448\u0435\u0439, \u0441\u043A\u0430\u0437\u0430\u043B\u0430:
    **\"\u0412\u043E\u0442 \u0447\u0442\u043E \u0442\u044B \u043D\u0430 \u0441\u0430\u043C\u043E\u043C
    \u0434\u0435\u043B\u0435 \u043B\u044E\u0431\u0438\u0448\u044C, \u044E\u043D\u043E\u0448\u0430,
    \u043D\u043E \u0442\u044B \u043B\u044E\u0431\u0438\u0448\u044C \u044D\u0442\u043E
    \u043D\u0435 \u0440\u0430\u0434\u0438 \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E\u0433\u043E\"**. 
    \u042D\u0442\u043E\u0442 \u0436\u0435\u0441\u0442, \u043F\u0440\u0438\u0437\u0432\u0430\u043D\u043D\u044B\u0439
    \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u0443\u0447\u0435\u043D\u0438\u043A\u0443
    \u0432\u0441\u044E \u0438\u043B\u043B\u044E\u0437\u043E\u0440\u043D\u043E\u0441\u0442\u044C
    \u0435\u0433\u043E \u043F\u043B\u043E\u0442\u0441\u043A\u043E\u0433\u043E \u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F,
    \u043E\u0442\u043B\u0438\u0447\u043D\u043E \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
    \u0435\u0451 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F: \u043D\u0443\u0436\u043D\u043E
    \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u044C\u0441\u044F \u043A \u0434\u0443\u0445\u043E\u0432\u043D\u043E\u043C\u0443
    \u0438 \u043E\u0442\u0440\u0435\u0448\u0430\u0442\u044C\u0441\u044F \u043E\u0442
    \u0442\u0435\u043B\u0435\u0441\u043D\u043E\u0433\u043E. \u0421\u0443\u0434\u044F
    \u043F\u043E \u0432\u0441\u0435\u043C\u0443, \u043C\u0435\u0442\u043E\u0434 \u0441\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u2014 \u044E\u043D\u043E\u0448\u0443 \"\u0441\u0442\u044B\u0434 \u0438 \u0438\u0437\u0443\u043C\u043B\u0435\u043D\u0438\u0435
    \u043E\u0442\u0432\u043B\u0435\u043A\u043B\u0438 \u043E\u0442 \u0432\u043E\u0436\u0434\u0435\u043B\u0435\u043D\u0438\u044F\"
    \u0438 \u043F\u0440\u0438\u0432\u0435\u043B\u0438 \u043A \u0441\u0434\u0435\u0440\u0436\u0430\u043D\u043D\u043E\u0441\u0442\u0438. 
    ### \U0001F9AA \"\u0423\u0441\u0442\u0440\u0438\u0447\u043D\u044B\u0435 \u0440\u0430\u043A\u0443\u0448\u043A\u0438\"?
    \u041D\u0435 \u0432\u0441\u0451 \u0442\u0430\u043A \u043F\u0440\u043E\u0441\u0442\u043E 
    \u041E\u0440\u0443\u0434\u0438\u0435 \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u0430
    \u0413\u0438\u043F\u0430\u0442\u0438\u0438 \u2014 \u043E\u0434\u0438\u043D \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u0437\u0430\u043F\u0443\u0442\u0430\u043D\u043D\u044B\u0445
    \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u0432. \u0412 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445
    \u0447\u0430\u0441\u0442\u043E \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u0435\u0451 \u0443\u0431\u0438\u043B\u0438, \u0441\u0434\u0438\u0440\u0430\u044F
    \u043F\u043B\u043E\u0442\u044C **\"\u043E\u0441\u0442\u0440\u0430\u043A\u0438\u0441
    \u0430\u043D\u0435\u0439\u043B\u043E\u043D\"**. \u0413\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0435
    \u0441\u043B\u043E\u0432\u043E `\u1F44\u03C3\u03C4\u03C1\u03B1\u03BA\u03BF\u03BD`
    (`ostrakon`) \u043C\u043E\u0436\u0435\u0442 \u043E\u0437\u043D\u0430\u0447\u0430\u0442\u044C
    \u043A\u0430\u043A **\u0447\u0435\u0440\u0435\u043F\u043E\u043A, \u0433\u043B\u0438\u043D\u044F\u043D\u0443\u044E
    \u0447\u0435\u0440\u0435\u043F\u0438\u0446\u0443**, \u0442\u0430\u043A \u0438
    **\u0443\u0441\u0442\u0440\u0438\u0447\u043D\u0443\u044E \u0440\u0430\u043A\u0443\u0448\u043A\u0443**. 
    *   **\u0412\u0435\u0440\u0441\u0438\u044F \u0441 \u0447\u0435\u0440\u0435\u043F\u0438\u0446\u0435\u0439:**
    \u0411\u043E\u043B\u0435\u0435 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0430,
    \u0442\u0430\u043A \u043A\u0430\u043A \u0447\u0435\u0440\u0435\u043F\u043A\u0438
    \u0431\u044B\u043B\u0438 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0451\u043D\u043D\u044B\u043C
    \u043F\u043E\u0434\u0440\u0443\u0447\u043D\u044B\u043C \u043E\u0440\u0443\u0434\u0438\u0435\u043C.
    *   **\u0412\u0435\u0440\u0441\u0438\u044F \u0441 \u0440\u0430\u043A\u0443\u0448\u043A\u0430\u043C\u0438:**
    \u042D\u0442\u0430 \u0432\u0435\u0440\u0441\u0438\u044F \u0431\u043E\u043B\u0435\u0435
    \u043A\u0438\u043D\u0435\u043C\u0430\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u043D\u0430
    \u0438 \u0436\u0438\u0432\u043E\u043F\u0438\u0441\u043D\u0430, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \u0447\u0430\u0441\u0442\u043E \u0446\u0438\u0442\u0438\u0440\u0443\u0435\u0442\u0441\u044F
    \u0432 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0435 \u0438 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435. 
    ### \u2699\uFE0F \u0418\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F:
    \u0427\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B\u0430 \u0413\u0438\u043F\u0430\u0442\u0438\u044F
    \u043D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435?  \u0415\u0439
    \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435
    \u043C\u043D\u043E\u0433\u0438\u0445 \u043F\u0440\u0438\u0431\u043E\u0440\u043E\u0432,
    \u043D\u043E \u0432\u0430\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u044F\u0442\u044C
    \u0444\u0430\u043A\u0442\u044B \u0438 \u043B\u0435\u0433\u0435\u043D\u0434\u044B: 
    *   **\u0410\u0441\u0442\u0440\u043E\u043B\u044F\u0431\u0438\u044F (\u041D\u0415
    \u0418\u0417\u041E\u0411\u0420\u0415\u041B\u0410):** \u042D\u0442\u043E \u0441\u0430\u043C\u044B\u0439
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u044B\u0439 \u043C\u0438\u0444.
    \u0410\u0441\u0442\u0440\u043E\u043B\u044F\u0431\u0438\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430\u043C\u0438 \u043F\u043E
    \u043C\u0435\u043D\u044C\u0448\u0435\u0439 \u043C\u0435\u0440\u0435 \u0437\u0430
    500 \u043B\u0435\u0442 \u0434\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0413\u0438\u043F\u0430\u0442\u0438\u0438. \u041E\u043D\u0430, \u0441\u043A\u043E\u0440\u0435\u0435
    \u0432\u0441\u0435\u0433\u043E, **\u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430**
    \u0435\u0451 \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044E
    \u0438 \u043D\u0430\u0443\u0447\u0438\u043B\u0430 \u0441\u0432\u043E\u0438\u0445
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0441 \u044D\u0442\u0438\u043C \u0441\u043B\u043E\u0436\u043D\u044B\u043C \u043F\u0440\u0438\u0431\u043E\u0440\u043E\u043C.
    *   **\u0410\u0440\u0435\u043E\u043C\u0435\u0442\u0440 (\u041D\u0415 \u0418\u0417\u041E\u0411\u0420\u0415\u041B\u0410):**
    \u041F\u0440\u0438\u0431\u043E\u0440 \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F
    \u043F\u043B\u043E\u0442\u043D\u043E\u0441\u0442\u0438 \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0435\u0439
    \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0438 \u0434\u043E
    \u043D\u0435\u0451. \u041E\u0434\u043D\u0430\u043A\u043E, \u043F\u043E \u043F\u0440\u043E\u0441\u044C\u0431\u0435
    \u0443\u0447\u0435\u043D\u0438\u043A\u0430 \u0421\u0438\u043D\u0435\u0437\u0438\u044F,
    \u043E\u043D\u0430 \u043F\u043E\u043C\u043E\u0433\u0430\u043B\u0430 \u0432 \u0435\u0433\u043E
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438, \u0447\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u043E \u0435\u0451 \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E\u043C
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u043E\u043C \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u0435. *   **\u041F\u043B\u0430\u043D\u0438\u0441\u0444\u0435\u0440\u0430
    (\u0412\u041E\u0417\u041C\u041E\u0416\u041D\u041E, \u0423\u0421\u041E\u0412\u0415\u0420\u0428\u0415\u041D\u0421\u0422\u0412\u041E\u0412\u0410\u041B\u0410):**
    \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E \u043E\u043D\u0430
    \u0441\u043E\u0437\u0434\u0430\u043B\u0430 \u043F\u043B\u043E\u0441\u043A\u0443\u044E
    \u043F\u043E\u0434\u0432\u0438\u0436\u043D\u0443\u044E \u043A\u0430\u0440\u0442\u0443
    \u043D\u0435\u0431\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u0432\u043F\u043B\u043E\u0442\u044C \u0434\u043E XVII \u0432\u0435\u043A\u0430. 
    ### \u2728 \u0421\u0430\u043C\u043E\u0435 \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u0437\u0430\u0431\u043B\u0443\u0436\u0434\u0435\u043D\u0438\u0435: \"\u041E\u043D\u0430
    \u0443\u043C\u0435\u0440\u043B\u0430 \u0437\u0430 \u043D\u0430\u0443\u043A\u0443\" 
    \u0415\u0451 \u0447\u0430\u0441\u0442\u043E \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0430\u044E\u0442
    \u043A\u0430\u043A \u043C\u0443\u0447\u0435\u043D\u0438\u0446\u0443 \u043D\u0430\u0443\u043A\u0438,
    \u043F\u043E\u0433\u0438\u0431\u0448\u0443\u044E \u043E\u0442 \u0440\u0443\u043A
    \u043C\u0440\u0430\u043A\u043E\u0431\u0435\u0441\u043E\u0432 \u0438\u0437-\u0437\u0430
    \u0441\u0432\u043E\u0438\u0445 \u0437\u043D\u0430\u043D\u0438\u0439. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432 \u0441\u0445\u043E\u0434\u044F\u0442\u0441\u044F
    \u0432\u043E \u043C\u043D\u0435\u043D\u0438\u0438, \u0447\u0442\u043E \u043F\u0440\u0438\u0447\u0438\u043D\u0430
    \u0435\u0451 \u0433\u0438\u0431\u0435\u043B\u0438 \u0431\u044B\u043B\u0430 **\u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439**: 
    *   \u042D\u0442\u043E \u0431\u044B\u043B \u0443\u0434\u0430\u0440 \u043F\u043E
    \u043F\u0440\u0435\u0444\u0435\u043A\u0442\u0443 \u041E\u0440\u0435\u0441\u0442\u0443,
    \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0413\u0438\u043F\u0430\u0442\u0438\u044F
    \u0431\u044B\u043B\u0430 \u0431\u043B\u0438\u0437\u043A\u0430, \u0430 \u043D\u0435
    \u0430\u043A\u0442 \u0431\u043E\u0440\u044C\u0431\u044B \u0441 \u043D\u0430\u0443\u043A\u043E\u0439.
    *   \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0443\u0431\u0438\u0442\u0430
    \u043D\u0435 \u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043A\u0430\u043A \u0443\u0447\u0451\u043D\u044B\u0439,
    \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043A\u0430\u043A \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0438\u0433\u0440\u043E\u043A
    \u0438 \u0441\u043E\u044E\u0437\u043D\u0438\u043A \u0432\u0440\u0430\u0433\u0430
    \u0435\u043F\u0438\u0441\u043A\u043E\u043F\u0430 \u041A\u0438\u0440\u0438\u043B\u043B\u0430. 
    ### \U0001F48E \u041A\u0440\u0430\u0442\u043A\u0438\u0439 \u0438\u0442\u043E\u0433:
    \u0416\u0438\u0437\u043D\u044C \u043A\u0430\u043A \u043B\u0435\u0433\u0435\u043D\u0434\u0430 
    \u0413\u0438\u043F\u0430\u0442\u0438\u044F \u0431\u044B\u043B\u0430, \u0431\u0435\u0437
    \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u044F, \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0439\u0441\u044F
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C\u044E. \u041E\u043D\u0430 \u0431\u044B\u043B\u0430
    **\u043F\u0435\u0440\u0432\u043E\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439
    \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C**,
    \u0432\u043D\u0435\u0441\u043B\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0435
    \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u0445 \u0437\u043D\u0430\u043D\u0438\u0439
    \u0438 \u0441\u0442\u0430\u043B\u0430 \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0432\u043E\u0431\u043E\u0434\u044B. \u0415\u0451 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0438\u0431\u0435\u043B\u044C, \u043A\u0430\u043A\u043E\u0439 \u0431\u044B
    \u043D\u0438 \u0431\u044B\u043B\u0430 \u0435\u0451 \u043F\u0440\u0438\u0447\u0438\u043D\u0430,
    \u043E\u0437\u043D\u0430\u043C\u0435\u043D\u043E\u0432\u0430\u043B\u0430 \u043A\u043E\u043D\u0435\u0446
    \u0446\u0435\u043B\u043E\u0439 \u044D\u043F\u043E\u0445\u0438. \u0418 \u0434\u0430\u0436\u0435
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F, \u0447\u0435\u0440\u0435\u0437 1600
    \u043B\u0435\u0442, \u043E\u043D\u0430 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442
    \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u0442\u044C \u0438 \u043F\u043E\u0440\u0430\u0436\u0430\u0442\u044C
    \u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435."
