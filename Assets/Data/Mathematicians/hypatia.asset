    \u043E\u043D \u043F\u0440\u043E\u0441\u0438\u043B \u0443 \u043D\u0435\u0451 \u0441\u043E\u0432\u0435\u0442\u0430
    \u043F\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0438 \u0434\u0430\u0436\u0435
    \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0441\u043A\u0438\u043C \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u043C.
    *   **\u041F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435:** \u0413\u0438\u043F\u0430\u0442\u0438\u044F
    \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0430\u0441\u044C \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C
    \u0430\u0432\u0442\u043E\u0440\u0438\u0442\u0435\u0442\u043E\u043C \u0432 \u0433\u043E\u0440\u043E\u0434\u0435.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0431\u043B\u0438\u0437\u043A\u0430
