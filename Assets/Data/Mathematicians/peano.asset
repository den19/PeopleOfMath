  shortBioEn: 
  interestingFactsRu: "\u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435 \u041F\u0435\u0430\u043D\u043E
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u043D\u043E
    \u0438 \u0432\u0435\u0441\u044C\u043C\u0430 \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0439
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C\u044E. \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C
    \u043F\u043E\u043B\u043D\u0430 \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u0435\u043B\u0430\u044E\u0442
    \u0435\u0433\u043E \u043E\u0431\u0440\u0430\u0437 \u0436\u0438\u0432\u044B\u043C
    \u0438 \u0437\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u044E\u0449\u0438\u043C\u0441\u044F.
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0438\u0437 \u043D\u0438\u0445.  ### \U0001F5E3\uFE0F \u041B\u0435\u043A\u0446\u0438\u0438
    \u043D\u0430 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435  \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0441\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u0443\u0440\u044C\u0435\u0437 \u0432 \u0436\u0438\u0437\u043D\u0438 \u041F\u0435\u0430\u043D\u043E
    \u0441\u0432\u044F\u0437\u0430\u043D \u0441 \u0435\u0433\u043E \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435\u043C
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u044F\u0437\u044B\u043A\u043E\u043C. \u0412 1903 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0441\u043E\u0437\u0434\u0430\u043B **\"\u041B\u0430\u0442\u0438\u043D\u043E
    \u0441\u0438\u043D\u0435 \u0444\u043B\u0435\u043A\u0441\u0438\u043E\u043D\u0435\"**
    (*Latino sine flexione* \u2014 \"\u043B\u0430\u0442\u044B\u043D\u044C \u0431\u0435\u0437
    \u0441\u043B\u043E\u0432\u043E\u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0439\")
    \u2014 \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u043D\u044B\u0439 \u0432\u0430\u0440\u0438\u0430\u043D\u0442
    \u043B\u0430\u0442\u044B\u043D\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u043B \u0441\u0442\u0430\u0442\u044C
    \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u043C
    \u044F\u0437\u044B\u043A\u043E\u043C \u043D\u0430\u0443\u043A\u0438. \u042D\u0442\u043E
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0440\u043E\u0435\u043A\u0442: \u041F\u0435\u0430\u043D\u043E \u0431\u044B\u043B
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0432\u043B\u0435\u0447\u0435\u043D,
    \u0447\u0442\u043E **\u043D\u0430\u0447\u0430\u043B \u0447\u0438\u0442\u0430\u0442\u044C
    \u0441\u0432\u043E\u0438 \u043B\u0435\u043A\u0446\u0438\u0438 \u0432 \u0422\u0443\u0440\u0438\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043D\u0430 \u044D\u0442\u043E\u043C \u044F\u0437\u044B\u043A\u0435**.  \u0415\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E,
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B, \u043D\u0435 \u0438\u0437\u0443\u0447\u0430\u0432\u0448\u0438\u0435
    \u0435\u0433\u043E \u0442\u0432\u043E\u0440\u0435\u043D\u0438\u0435, \u043D\u0438\u0447\u0435\u0433\u043E
    \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u043B\u0438. \u042D\u0442\u043E
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0442\u043E\u043C\u0443, \u0447\u0442\u043E
    \u043E\u043D, \u043D\u0435\u043A\u043E\u0433\u0434\u0430 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u044B\u0439
    \u043B\u0435\u043A\u0442\u043E\u0440, \u0441\u0442\u0430\u043B \u0438\u0437\u0433\u043E\u0435\u043C
    \u0432 \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u0438, \u0438 \u0435\u0433\u043E
    \u043F\u043E\u0441\u0435\u0449\u0430\u0435\u043C\u043E\u0441\u0442\u044C \u0440\u0435\u0437\u043A\u043E
    \u0443\u043F\u0430\u043B\u0430. \u0415\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u0442\u043E\u0436\u0435 \u043D\u0435 \u043E\u0446\u0435\u043D\u0438\u043B\u0438
    \u043D\u043E\u0432\u043E\u0432\u0432\u0435\u0434\u0435\u043D\u0438\u044F: \u043A\u043E\u0433\u0434\u0430
    \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0444\u0438\u043D\u0430\u043B\u044C\u043D\u043E\u0435, \u043F\u044F\u0442\u043E\u0435
    \u0438\u0437\u0434\u0430\u043D\u0438\u0435 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u043E\u0433\u043E \u0442\u0440\u0443\u0434\u0430
    \"\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\"
    \u0432 1908 \u0433\u043E\u0434\u0443, \u043E\u043D\u043E \u0431\u044B\u043B\u043E
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043E \u043D\u0430 \"\u043B\u0430\u0442\u0438\u043D\u043E
    \u0441\u0438\u043D\u0435 \u0444\u043B\u0435\u043A\u0441\u0438\u043E\u043D\u0435\"
    \u0438 \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435\u0437\u0430\u043C\u0435\u0447\u0435\u043D\u043D\u044B\u043C.  ###
    \U0001F4C9 \u0421\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C, \u0433\u0440\u0430\u043D\u0438\u0447\u0430\u0449\u0430\u044F
    \u0441 \u0433\u0440\u0443\u0431\u043E\u0441\u0442\u044C\u044E  \u041F\u0435\u0430\u043D\u043E
    \u0431\u044B\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0441\u0442\u0440\u043E\u0433 \u043A \u0447\u0443\u0436\u0438\u043C \u043E\u0448\u0438\u0431\u043A\u0430\u043C
    \u0438 \u043E\u0431\u043B\u0430\u0434\u0430\u043B \u0434\u0430\u0440\u043E\u043C
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F
    \u0438 \u043D\u0435\u0434\u043E\u0447\u0435\u0442\u044B \u0432 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    \u043A\u043E\u043B\u043B\u0435\u0433. \u0421\u043B\u0430\u0432\u0438\u043B\u0441\u044F
    \u043E\u043D \u0438 \u0441\u0432\u043E\u0438\u043C\u0438 \u044F\u0437\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0440\u0435\u0446\u0435\u043D\u0437\u0438\u044F\u043C\u0438. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0432 \u043E\u0442\u0437\u044B\u0432\u0435 \u043D\u0430 \u043A\u043D\u0438\u0433\u0443
    \u043E\u0434\u043D\u043E\u0433\u043E \u0438\u0437 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    \u043E\u043D \u0431\u0435\u0437 \u043E\u0431\u0438\u043D\u044F\u043A\u043E\u0432
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B, \u0447\u0442\u043E \u043C\u043E\u0436\u0435\u0442
    \"\u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E \u043F\u0435\u0440\u0435\u0447\u0438\u0441\u043B\u044F\u0442\u044C
    \u043D\u0435\u043B\u0435\u043F\u043E\u0441\u0442\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0430\u0433\u0440\u043E\u043C\u043E\u0437\u0434\u0438\u043B \u0430\u0432\u0442\u043E\u0440\",
    \u0438 \u0447\u0442\u043E \u044D\u0442\u0438 \u043E\u0448\u0438\u0431\u043A\u0438
    \u0438 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435 \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u0438
    \"\u043B\u0438\u0448\u0430\u044E\u0442 \u043A\u043D\u0438\u0433\u0443 \u0432\u0441\u044F\u043A\u043E\u0439
    \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u0438\". \u0422\u0430\u043A\u0430\u044F
    \u0431\u0435\u0437\u0430\u043F\u0435\u043B\u043B\u044F\u0446\u0438\u043E\u043D\u043D\u0430\u044F
    \u043C\u0430\u043D\u0435\u0440\u0430, \u043A\u043E\u043D\u0435\u0447\u043D\u043E,
    \u043D\u0435 \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u043B\u0430 \u0435\u043C\u0443
    \u0434\u0440\u0443\u0437\u0435\u0439, \u0438 \u043E\u043D \u043D\u0435\u0440\u0435\u0434\u043A\u043E
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u043E\u0432\u0430\u043B \u0441
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438. \u0418\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u043E \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435 \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0437\u043C\u043E\u043C
    \u0438 \u0436\u0435\u0441\u0442\u043A\u0438\u0439 \u0441\u0442\u0438\u043B\u044C
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u044F \u0441\u0442\u0430\u043B\u0438
    \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439 \u0435\u0433\u043E \u0443\u0432\u043E\u043B\u044C\u043D\u0435\u043D\u0438\u044F
    \u0438\u0437 \u0412\u043E\u0435\u043D\u043D\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u0432 1901 \u0433\u043E\u0434\u0443.  ### \U0001F5A8\uFE0F \u0421\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0442\u0438\u043F\u043E\u0433\u0440\u0430\u0444\u0438\u044F  \u0415\u0449\u0435
    \u043E\u0434\u0438\u043D \u044F\u0440\u043A\u0438\u0439 \u044D\u043F\u0438\u0437\u043E\u0434:
    \u0432 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043D\u0430\u0434 \"\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440\u043E\u043C\"
    \u041F\u0435\u0430\u043D\u043E \u043F\u0440\u0438\u0448\u0435\u043B \u0432 \u044F\u0440\u043E\u0441\u0442\u044C
    \u043E\u0442 \u0437\u0430\u0434\u0435\u0440\u0436\u0435\u043A \u0432 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0431\u044B\u043B\u0438 \u0432\u044B\u0437\u0432\u0430\u043D\u044B
    \u0435\u0433\u043E \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043F\u0435\u0447\u0430\u0442\u0430\u0442\u044C \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u0432 \u043E\u0434\u043D\u0443 \u0441\u0442\u0440\u043E\u043A\u0443, \u0447\u0442\u043E
    \u0431\u044B\u043B\u043E \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438
    \u0441\u043B\u043E\u0436\u043D\u043E. \u0412 \u0438\u0442\u043E\u0433\u0435,
    \u0447\u0442\u043E\u0431\u044B \u043D\u0435 \u0437\u0430\u0432\u0438\u0441\u0435\u0442\u044C
    \u043E\u0442 \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u0439, \u043E\u043D
    \u043F\u0440\u043E\u0441\u0442\u043E **\u043A\u0443\u043F\u0438\u043B \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u043F\u0435\u0447\u0430\u0442\u043D\u044B\u0439 \u0441\u0442\u0430\u043D\u043E\u043A**.
    \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0435\u043C\u0443
    \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C \u0441\u0432\u043E\u0438
    \u0440\u0430\u0431\u043E\u0442\u044B \u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441\u0432\u043E\u0435\u0439 \u0448\u043A\u043E\u043B\u044B \u0432 \u0442\u043E\u0447\u043D\u043E\u043C
    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0438 \u0441
    \u0435\u0433\u043E \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043D\u0438\u044F\u043C\u0438. 
    ### \U0001F9E0 \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u044D\u0433\u043E\u0438\u0441\u0442
    \u0438 \u043F\u0440\u0435\u0434\u043C\u0435\u0442 \u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u044F
    \u0420\u0430\u0441\u0441\u0435\u043B\u0430  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u044B \u0438 \u0441\u043B\u043E\u0436\u043D\u044B\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440, \u043C\u0430\u0441\u0448\u0442\u0430\u0431
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438 \u041F\u0435\u0430\u043D\u043E
    \u0431\u044B\u043B \u043E\u0447\u0435\u0432\u0438\u0434\u0435\u043D \u0434\u043B\u044F
    \u0432\u0441\u0435\u0445. \u0421\u0430\u043C **\u0411\u0435\u0440\u0442\u0440\u0430\u043D
    \u0420\u0430\u0441\u0441\u0435\u043B**, \u043E\u0434\u0438\u043D \u0438\u0437
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043B\u043E\u0433\u0438\u043A\u043E\u0432
    XX \u0432\u0435\u043A\u0430, \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E\u0440\u0430\u0436\u0435\u043D \u0435\u0433\u043E \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u043A\u043E\u0439,
    \u0447\u0442\u043E \u0432 1900 \u0433\u043E\u0434\u0443 \u043F\u0440\u0435\u0440\u0432\u0430\u043B
    \u0443\u0447\u0430\u0441\u0442\u0438\u0435 \u0432 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u043C
    \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435 \u0438 \u0443\u0435\u0445\u0430\u043B
    \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u044E, \u0447\u0442\u043E\u0431\u044B
    \"\u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E \u0438\u0437\u0443\u0447\u0438\u0442\u044C
    \u043A\u0430\u0436\u0434\u043E\u0435 \u0441\u043B\u043E\u0432\u043E, \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0435
    \u0438\u043C \u0438\u043B\u0438 \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C\u0438\".
    \u0420\u0430\u0441\u0441\u0435\u043B \u043F\u0440\u044F\u043C\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u043B,
