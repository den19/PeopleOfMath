  achievementsRu: "\u0414\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u0438
    \u0442\u0440\u0443\u0434\u044B \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435
    \u041F\u0435\u0430\u043D\u043E \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0442
    \u0448\u0438\u0440\u043E\u043A\u0438\u0439 \u0441\u043F\u0435\u043A\u0442\u0440:
    \u043E\u0442 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043E\u0441\u043D\u043E\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0434\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430 \u0434\u043B\u044F \u043D\u0430\u0443\u043A\u0438.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F, \u0430 \u0447\u0430\u0441\u0442\u0438
    \u0435\u0434\u0438\u043D\u043E\u0433\u043E, \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0435\u043A\u0442\u0430 \u043F\u043E \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u0438\u044E
    \u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u0438
    \u0432\u0441\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0420\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0438\u043C \u0438\u0445 \u0432
    \u0434\u0435\u0442\u0430\u043B\u044F\u0445.  ### \U0001F4DC \u0410\u043A\u0441\u0438\u043E\u043C\u044B
    \u041F\u0435\u0430\u043D\u043E: \u0417\u0430\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438
    (1889)  \u0421\u0430\u043C\u043E\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u041F\u0435\u0430\u043D\u043E
    \u2014 \u044D\u0442\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u0430\u043A\u0441\u0438\u043E\u043C
    \u0434\u043B\u044F \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u0432 \u0435\u0433\u043E \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u043E\u043C
    \u043F\u0430\u043C\u0444\u043B\u0435\u0442\u0435 *Arithmetices principia, nova
    methodo exposita* (\u041F\u0440\u0438\u043D\u0446\u0438\u043F\u044B \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438,
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0435 \u043D\u043E\u0432\u044B\u043C
    \u043C\u0435\u0442\u043E\u0434\u043E\u043C) \u0432 1889 \u0433\u043E\u0434\u0443. 
    \u041E\u043D \u0445\u043E\u0442\u0435\u043B \u0441\u0432\u0435\u0441\u0442\u0438
    \u0432\u0441\u044E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0443
    \u043A \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u043C \u0431\u0430\u0437\u043E\u0432\u044B\u043C,
    \u043D\u0435\u0434\u043E\u043A\u0430\u0437\u0443\u0435\u043C\u044B\u043C \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u044F\u043C,
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043C\u043E\u0436\u043D\u043E
    \u0431\u044B\u043B\u043E \u0431\u044B \u0441\u0442\u0440\u043E\u0433\u043E \u0432\u044B\u0432\u0435\u0441\u0442\u0438
    \u0432\u0441\u0435 \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435. \u042D\u0442\u0438
    \u0430\u043A\u0441\u0438\u043E\u043C\u044B \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u044E\u0442
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B (N) \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C:  1.  **\u0421\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u043D\u0430\u0447\u0430\u043B\u0430:** `1` (\u0438\u043B\u0438 `0` \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0432\u0430\u0440\u0438\u0430\u043D\u0442\u0430\u0445) \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u043C \u0447\u0438\u0441\u043B\u043E\u043C.
    \u042D\u0442\u043E \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u043D\u0435 \u043F\u0443\u0441\u0442\u043E. 2. 
    **\u0424\u0443\u043D\u043A\u0446\u0438\u044F \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F:**
    \u0414\u043B\u044F \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 `x` \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0440\u043E\u0432\u043D\u043E \u043E\u0434\u043D\u043E \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E `x'`, \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u043E\u0435
    \u0435\u0433\u043E *\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u043C* \u0438\u043B\u0438
    *\u043D\u0435\u043F\u043E\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C*
    (\u043F\u043E \u0441\u0443\u0442\u0438, `x + 1`). 3.  **\u0418\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435
    \u043D\u0430\u0447\u0430\u043B\u0430:** \u041D\u0438 \u0434\u043B\u044F \u043A\u0430\u043A\u043E\u0433\u043E
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0447\u0438\u0441\u043B\u0430
    `x` \u043D\u0435\u0432\u0435\u0440\u043D\u043E, \u0447\u0442\u043E `x' = 1`.
    \u0414\u0440\u0443\u0433\u0438\u043C\u0438 \u0441\u043B\u043E\u0432\u0430\u043C\u0438,
    `1` \u043D\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u043D\u0438\u043A\u0430\u043A\u043E\u0433\u043E \u0434\u0440\u0443\u0433\u043E\u0433\u043E
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0447\u0438\u0441\u043B\u0430.
    4.  **\u0418\u043D\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C
    \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F:** \u0415\u0441\u043B\u0438
    `x' = y'`, \u0442\u043E `x = y`. \u042D\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0443 \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u0447\u0438\u0441\u043B\u0430
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0434\u0438\u043D \xAB\u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\xBB,
    \u0438 \u0440\u0430\u0437\u043D\u044B\u0435 \u0447\u0438\u0441\u043B\u0430 \u043D\u0435
    \u043C\u043E\u0433\u0443\u0442 \u0438\u043C\u0435\u0442\u044C \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438 \u0442\u043E\u0433\u043E \u0436\u0435 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044F.
    5.  **\u0410\u043A\u0441\u0438\u043E\u043C\u0430 \u0438\u043D\u0434\u0443\u043A\u0446\u0438\u0438
    (\u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438\u043D\u0434\u0443\u043A\u0446\u0438\u0438):** \u0415\u0441\u043B\u0438
    \u043A\u0430\u043A\u043E\u0435-\u0442\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E
    \u0432\u0435\u0440\u043D\u043E \u0434\u043B\u044F `1`, \u0438 \u0438\u0437 \u0442\u043E\u0433\u043E,
    \u0447\u0442\u043E \u043E\u043D\u043E \u0432\u0435\u0440\u043D\u043E \u0434\u043B\u044F
    `x`, \u0441\u043B\u0435\u0434\u0443\u0435\u0442, \u0447\u0442\u043E \u043E\u043D\u043E
    \u0432\u0435\u0440\u043D\u043E \u0438 \u0434\u043B\u044F `x'`, \u0442\u043E \u044D\u0442\u043E
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u0432\u0435\u0440\u043D\u043E
    \u0434\u043B\u044F *\u0432\u0441\u0435\u0445* \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B.  \u041D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435
    \u044D\u0442\u0438\u0445 \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0438 \u0441\u0442\u0440\u043E\u0433\u0438\u0445
    \u043F\u0440\u0430\u0432\u0438\u043B \u043C\u043E\u0436\u043D\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438 \u0441\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u0438 \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u044F, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u0432\u0441\u0435 \u0438\u0445
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430, \u0442\u0430\u043A\u0438\u0435
    \u043A\u0430\u043A \u0430\u0441\u0441\u043E\u0446\u0438\u0430\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C.
    \u0421\u0438\u0441\u0442\u0435\u043C\u0430 \u041F\u0435\u0430\u043D\u043E \u0441\u0442\u0430\u043B\u0430
    \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C \u043A\u0430\u043C\u043D\u0435\u043C
    \u0434\u043B\u044F \u0432\u0441\u0435\u0439 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043E\u043A\u0430\u0437\u0430\u0432
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0442\u0430\u043A\u0438\u0445 \u043C\u044B\u0441\u043B\u0438\u0442\u0435\u043B\u0435\u0439,
    \u043A\u0430\u043A \u0411\u0435\u0440\u0442\u0440\u0430\u043D \u0420\u0430\u0441\u0441\u0435\u043B. 
    ### \U0001F300 \u041A\u0440\u0438\u0432\u0430\u044F \u041F\u0435\u0430\u043D\u043E:
    \u041F\u0435\u0440\u0432\u044B\u0439 \xAB\u0444\u0440\u0430\u043A\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u043C\u043E\u043D\u0441\u0442\u0440\xBB (1890)  \u0412 1890 \u0433\u043E\u0434\u0443
    \u041F\u0435\u0430\u043D\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B
    \u0441\u0435\u043D\u0441\u0430\u0446\u0438\u044E, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0432
    \u0440\u0430\u0431\u043E\u0442\u0443, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u0443\u044E
    \u043A\u0440\u0438\u0432\u0443\u044E, \u043F\u0440\u043E\u0445\u043E\u0434\u044F\u0449\u0443\u044E
    \u0447\u0435\u0440\u0435\u0437 \u043A\u0430\u0436\u0434\u0443\u044E \u0442\u043E\u0447\u043A\u0443
    \u0435\u0434\u0438\u043D\u0438\u0447\u043D\u043E\u0433\u043E \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430.
    \u0415\u0433\u043E \u0438\u0437\u044B\u0441\u043A\u0430\u043D\u0438\u044F \u0431\u044B\u043B\u0438
    \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u0435\u043D\u044B \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\u043C
    \u0413\u0435\u043E\u0440\u0433\u0430 \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    \u043E \u0440\u0430\u0432\u043D\u043E\u043C\u043E\u0449\u043D\u043E\u0441\u0442\u0438
    \u043E\u0442\u0440\u0435\u0437\u043A\u0430 \u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430
    (\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0438
    \u0431\u0438\u0435\u043A\u0446\u0438\u0438 \u043C\u0435\u0436\u0434\u0443 \u043D\u0438\u043C\u0438),
    \u043D\u043E \u041A\u0430\u043D\u0442\u043E\u0440\u043E\u0432\u043E \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0431\u044B\u043B\u043E \u0440\u0430\u0437\u0440\u044B\u0432\u043D\u044B\u043C. 
    \u041F\u0435\u0430\u043D\u043E \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0435 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0442\u0430\u043A\u0436\u0435 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0432
    \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u044B\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u043E \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438. \u0415\u0433\u043E
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044F \u0431\u044B\u043B\u0430
    \u0447\u0438\u0441\u0442\u043E \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u043E\u0439 \u043D\u0430 \u0442\u0440\u043E\u0438\u0447\u043D\u043E\u043C
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B, \u0438 \u043D\u0435 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0438\u0441\u0443\u043D\u043A\u043E\u0432. \u042D\u0442\u043E \u0431\u044B\u043B
    \u043F\u0435\u0440\u0432\u044B\u0439 \u043F\u0440\u0438\u043C\u0435\u0440 \u0442\u043E\u0433\u043E,
    \u0447\u0442\u043E \u043C\u044B \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C
    **\u043A\u0440\u0438\u0432\u043E\u0439, \u0437\u0430\u043F\u043E\u043B\u043D\u044F\u044E\u0449\u0435\u0439
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E** (space-filling
    curve).  \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430
    \u043A\u0440\u0438\u0432\u043E\u0439 \u041F\u0435\u0430\u043D\u043E: *   **\u041D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043D\u0438\u0433\u0434\u0435 \u043D\u0435 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0440\u0443\u0435\u043C\u043E\u0441\u0442\u044C:**
    \u0424\u0443\u043D\u043A\u0446\u0438\u0438, \u0437\u0430\u0434\u0430\u044E\u0449\u0438\u0435
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B \u0442\u043E\u0447\u0435\u043A
    \u043A\u0440\u0438\u0432\u043E\u0439, \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B,
    \u043D\u043E \u043D\u0435 \u0438\u043C\u0435\u044E\u0442 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u043E\u0439
    \u043D\u0438 \u0432 \u043E\u0434\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u0435.
    *   **\u0421\u0430\u043C\u043E\u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0435:**
    \u0427\u0442\u043E\u0431\u044B \u0437\u0430\u043F\u043E\u043B\u043D\u0438\u0442\u044C
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442, \u043A\u0440\u0438\u0432\u0430\u044F
    \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E \u0440\u0430\u0437 \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u0442\u044C
    \u0441\u0430\u043C\u0443 \u0441\u0435\u0431\u044F. *   **\u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435:** \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u043F\u043E\u0442\u0440\u044F\u0441\u043B\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0438\u0440. \u041E\u043D\u043E \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u043E,
    \u0447\u0442\u043E \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u044F \u0438 \u043D\u0430\u0433\u043B\u044F\u0434\u043D\u044B\u0435
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0431\u0440\u0430\u0437\u044B \u043C\u043E\u0433\u0443\u0442 \u0431\u044B\u0442\u044C
    \u043E\u0431\u043C\u0430\u043D\u0447\u0438\u0432\u044B, \u0438 \u0434\u043B\u044F
    \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u0442\u0430\u043A\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432 \u043D\u0443\u0436\u043D\u0430
    \u0441\u0442\u0440\u043E\u0433\u0430\u044F \u043B\u043E\u0433\u0438\u043A\u0430.
    \u041F\u043E \u0441\u043B\u043E\u0432\u0430\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0425\u0430\u043D\u0441\u0430 \u0425\u0430\u043D\u0430, \u044D\u0442\u043E \xAB\u043D\u0435
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043F\u043E\u0441\u0442\u0438\u0433\u043D\u0443\u0442\u043E
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0435\u0439; \u044D\u0442\u043E \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u043F\u043E\u043D\u044F\u0442\u043E \u0442\u043E\u043B\u044C\u043A\u043E
    \u0447\u0435\u0440\u0435\u0437 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437\xBB.  ### \U0001F4DA \xAB\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB: \u042D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u044F
    \u0432 \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u0445 (1891\u20131908)  \u041A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u0435\u0439
    \u0436\u0438\u0437\u043D\u0438 \u041F\u0435\u0430\u043D\u043E \u0441\u0442\u0430\u043B
    \u043F\u0440\u043E\u0435\u043A\u0442 **\xAB\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB** (*Formulario
    Mathematico*). \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u043F\u043E\u043F\u044B\u0442\u043A\u0430
    \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u0432\u0441\u0435\u043E\u0431\u044A\u0435\u043C\u043B\u044E\u0449\u0443\u044E
    \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u044E \u0432\u0441\u0435\u0439
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0437\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u0443\u044E \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043D\u0430 \u044F\u0437\u044B\u043A\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438, \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u043E\u043C
    \u041F\u0435\u0430\u043D\u043E. \u0420\u0430\u0431\u043E\u0442\u0430 \u043D\u0430\u0434
    \u043D\u0438\u043C \u0432\u0435\u043B\u0430\u0441\u044C \u0441 1891 \u043F\u043E
    1908 \u0433\u043E\u0434 \u0438 \u0432\u044B\u0448\u043B\u0430 \u0432 \u043F\u044F\u0442\u0438
    \u0438\u0437\u0434\u0430\u043D\u0438\u044F\u0445 (tomi).  #### \U0001F3AF \u0426\u0435\u043B\u044C
    \u0438 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430 \u043F\u0440\u043E\u0435\u043A\u0442\u0430 
    *   **\u0426\u0435\u043B\u044C:** \u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0432\u0441\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B, \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u0438 \u043C\u0435\u0442\u043E\u0434\u044B \u0432 \u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u043E
    \u0441\u0436\u0430\u0442\u043E\u0439, \u0442\u043E\u0447\u043D\u043E\u0439 \u0438
    \u0435\u0434\u0438\u043D\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u0435, \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0439
    \u043E\u0442 \u0434\u0432\u0443\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u043D\u043E\u0441\u0442\u0435\u0439
    \u043E\u0431\u044B\u0447\u043D\u043E\u0433\u043E \u044F\u0437\u044B\u043A\u0430.
    *   **\u0411\u0438\u0431\u043B\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u044C:** \xAB\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440\xBB
    \u043D\u0435 \u0431\u044B\u043B \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u0443\u0445\u0438\u043C
    \u0441\u043F\u0438\u0441\u043A\u043E\u043C \u0444\u043E\u0440\u043C\u0443\u043B.
    \u041E\u043D \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B \u0431\u043E\u0433\u0430\u0442\u044B\u0439
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0438
    \u0431\u0438\u0431\u043B\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B, \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u044F
    \u043F\u0435\u0440\u0432\u043E\u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438
    \u0438 \u0430\u0432\u0442\u043E\u0440\u043E\u0432 \u043C\u043D\u043E\u0433\u0438\u0445
    \u0442\u0435\u043E\u0440\u0435\u043C (\u043E\u0442 \u0415\u0432\u043A\u043B\u0438\u0434\u0430
    \u0438 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430 \u0434\u043E \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u0438 \u0413\u0430\u0443\u0441\u0441\u0430). \u0412 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F\u0445
    \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B\u0438\u0441\u044C \u043E\u0431\u0448\u0438\u0440\u043D\u044B\u0435
    \u0441\u043F\u0438\u0441\u043A\u0438 \u0438\u043C\u0435\u043D \u0438 \u0442\u0440\u0443\u0434\u043E\u0432,
    \u0441 \u0446\u0438\u0442\u0430\u0442\u0430\u043C\u0438 \u043D\u0430 \u044F\u0437\u044B\u043A\u0435
    \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u0430. *   **\u0421\u0438\u043C\u0432\u043E\u043B\u0438\u0437\u043C:**
    \u041F\u0435\u0430\u043D\u043E \u0432\u0432\u0435\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u044B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440: `\u2208` (\u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0443), `\u2283` (\u0432 \u0435\u0433\u043E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435 \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438\u043B\u0438 \u0432\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435), `\u222A`
    (\u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u0435 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432),
    `\u2229` (\u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432). \u0415\u0433\u043E \u043D\u043E\u0442\u0430\u0446\u0438\u044F
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0443\u0434\u0430\u0447\u043D\u043E\u0439, \u0447\u0442\u043E \u0431\u044B\u043B\u0430
    \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u044F\u0442\u0430 \u0438 \u0440\u0430\u0437\u0432\u0438\u0442\u0430
    \u0420\u0430\u0441\u0441\u0435\u043B\u043E\u043C \u0438 \u0423\u0430\u0439\u0442\u0445\u0435\u0434\u043E\u043C
    \u0432 \u0438\u0445 \xABPrincipia Mathematica\xBB.  #### \U0001F5E3\uFE0F \u042D\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u044F\u0437\u044B\u043A\u0430: \u043E\u0442 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E
    \u043A \xAB\u041B\u0430\u0442\u0438\u043D\u043E \u0441\u0438\u043D\u0435 \u0444\u043B\u0435\u043A\u0441\u0438\u043E\u043D\u0435\xBB 
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u0430 \u044D\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u044F\u0437\u044B\u043A\u0430, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043F\u0438\u0441\u0430\u043B\u0438\u0441\u044C \u043F\u043E\u044F\u0441\u043D\u0435\u043D\u0438\u044F
    \u043A \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u043C: *   \u041F\u0435\u0440\u0432\u044B\u0435
    \u0447\u0435\u0442\u044B\u0440\u0435 \u0438\u0437\u0434\u0430\u043D\u0438\u044F
    (I-IV \u0442\u043E\u043C\u0430, \u0441 1895 \u043F\u043E 1903 \u0433\u043E\u0434)
    \u0432\u044B\u0448\u043B\u0438 \u0441 \u043F\u043E\u044F\u0441\u043D\u0435\u043D\u0438\u044F\u043C\u0438
    \u043D\u0430 **\u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u043C**
    \u044F\u0437\u044B\u043A\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432
    \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u0431\u044B\u043B lingua franca
    \u043D\u0430\u0443\u043A\u0438. *   \u041F\u044F\u0442\u043E\u0435 \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435
    \u0438\u0437\u0434\u0430\u043D\u0438\u0435 (1908 \u0433\u043E\u0434) \u0431\u044B\u043B\u043E
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043E \u043D\u0430 \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043D\u043D\u043E\u043C
    \u041F\u0435\u0430\u043D\u043E \u044F\u0437\u044B\u043A\u0435 **\xAB\u041B\u0430\u0442\u0438\u043D\u043E
    \u0441\u0438\u043D\u0435 \u0444\u043B\u0435\u043A\u0441\u0438\u043E\u043D\u0435\xBB**
    (*Latino sine flexione* \u2014 \xAB\u043B\u0430\u0442\u044B\u043D\u044C \u0431\u0435\u0437
    \u0441\u043B\u043E\u0432\u043E\u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0439\xBB).
    \u042D\u0442\u043E \u0431\u044B\u043B \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u043D\u044B\u0439
    \u0432\u0430\u0440\u0438\u0430\u043D\u0442 \u043B\u0430\u0442\u044B\u043D\u0438,
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0431\u044B\u043B\u0438
    \u0443\u0431\u0440\u0430\u043D\u044B \u043F\u0430\u0434\u0435\u0436\u0438 \u0438
    \u0441\u043F\u0440\u044F\u0436\u0435\u043D\u0438\u044F, \u0447\u0442\u043E, \u043F\u043E
    \u0437\u0430\u043C\u044B\u0441\u043B\u0443 \u041F\u0435\u0430\u043D\u043E, \u0434\u043E\u043B\u0436\u043D\u043E
    \u0431\u044B\u043B\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u0435\u0433\u043E
    \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u043C \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u043C
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u044F\u0437\u044B\u043A\u043E\u043C.
    \u041E\u043D \u0442\u0430\u043A \u0432\u0435\u0440\u0438\u043B \u0432 \u044D\u0442\u043E\u0442
    \u043F\u0440\u043E\u0435\u043A\u0442, \u0447\u0442\u043E \u0434\u0430\u0436\u0435
    \u0441\u0432\u043E\u044E \u043B\u0435\u043A\u0446\u0438\u044E \u0432 1908 \u0433\u043E\u0434\u0443
    \u043D\u0430 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u043C
    \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0432 \u0420\u0438\u043C\u0435 \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043B
    \u043D\u0430 \u044D\u0442\u043E\u043C \u044F\u0437\u044B\u043A\u0435.  #### \U0001F91D
    \u0412\u043B\u0438\u044F\u043D\u0438\u0435 \u0438 \u043A\u0440\u0438\u0442\u0438\u043A\u0430 
    *   **\u0412\u043B\u0438\u044F\u043D\u0438\u0435:** \xAB\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440\xBB
    \u0438 \u0435\u0433\u043E \u0448\u043A\u043E\u043B\u0430 (\u0432 \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0432\u0445\u043E\u0434\u0438\u043B\u0438 \u0442\u0430\u043A\u0438\u0435 \u044F\u0440\u043A\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043A\u0430\u043A
    \u041C\u0430\u0440\u0438\u043E \u041F\u044C\u0435\u0440\u0438, \u0427\u0435\u0437\u0430\u0440\u0435
    \u0411\u0443\u0440\u0430\u043B\u0438-\u0424\u043E\u0440\u0442\u0438, \u0414\u0436\u043E\u0432\u0430\u043D\u043D\u0438
    \u0412\u0430\u0439\u043B\u0430\u0442\u0438) \u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0440\u0430\u043D\u043D\u044E\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043B\u043E\u0433\u0438\u043A\u0443. \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C
    \u0411\u0435\u0440\u0442\u0440\u0430\u043D \u0420\u0430\u0441\u0441\u0435\u043B
    \u0432 1900 \u0433\u043E\u0434\u0443 \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F \u0441
    \u0438\u0434\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0435\u0439 \u041F\u0435\u0430\u043D\u043E,
    \u0447\u0442\u043E \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u043E \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. *  
    **\u041A\u0440\u0438\u0442\u0438\u043A\u0430:** \u041F\u0440\u043E\u0435\u043A\u0442
    \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B \u0438 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u0443\u044E
    \u043A\u0440\u0438\u0442\u0438\u043A\u0443. \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0441\u0430\u0440\u043A\u0430\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0442\u0437\u044B\u0432\u0430\u043B\u0441\u044F \u043E \xAB\u0448\u043A\u043E\u043B\u0435
    \u041F\u0435\u0430\u043D\u043E\xBB, \u0441\u0447\u0438\u0442\u0430\u044F \u0438\u0445
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435 \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043C\u043E\u043C
    \u0438 \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u043C\u0438 \u0431\u0435\u0441\u043F\u043B\u043E\u0434\u043D\u044B\u043C.
    \u0415\u0433\u043E \u043A\u0440\u0438\u0442\u0438\u043A\u0430, \u0445\u043E\u0442\u044F
    \u0447\u0430\u0441\u0442\u043E \u0438 \u043D\u0435\u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u0430\u044F,
    \u043D\u0430\u043D\u0435\u0441\u043B\u0430 \u0443\u0440\u043E\u043D \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u0438
    \u0448\u043A\u043E\u043B\u044B \u0438 \u0437\u0430\u0442\u0440\u0443\u0434\u043D\u0438\u043B\u0430
    \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u0435
    \u0438\u0434\u0435\u0439 \u041F\u0435\u0430\u043D\u043E \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438.
    \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438,
    \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0412\u0438\u0442\u043E \u0412\u043E\u043B\u044C\u0442\u0435\u0440\u0440\u0430,
    \u0442\u043E\u0436\u0435 \u0441\u0447\u0438\u0442\u0430\u043B\u0438 \u044D\u0442\u0438
    \u0438\u0437\u044B\u0441\u043A\u0430\u043D\u0438\u044F \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u043C\u0438 \u0438
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u043C\u0438, \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u044F
    \u0438\u0445 \xAB\u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439\xBB \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    *   **\u0412\u043A\u043B\u0430\u0434 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E:**
    \u0412 \xAB\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440\u0435\xBB \u041F\u0435\u0430\u043D\u043E
    \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0434\u0430\u043B \u0441\u0442\u0440\u043E\u0433\u0438\u0439
    \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439 \u0430\u043D\u0430\u043B\u0438\u0437
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u0438,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 n-\u043C\u0435\u0440\u043D\u043E\u0433\u043E
    \u0432\u0435\u043A\u0442\u043E\u0440\u043D\u043E\u0433\u043E \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430,
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432
    \u0441\u0432\u043E\u0435 \u0432\u0440\u0435\u043C\u044F.  ### \U0001F48E \u0418\u0442\u043E\u0433 
    \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435 \u041F\u0435\u0430\u043D\u043E
    \u0431\u044B\u043B \u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u043D\u043E\u0432\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430. \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F
    \u043D\u0435 \u0432 \u0440\u0435\u0448\u0435\u043D\u0438\u0438 \u043A\u0430\u043A\u043E\u0439-\u0442\u043E
    \u043E\u0434\u043D\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0438, \u0430 \u0432
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432
    \u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430, \u043D\u0430
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0437\u0438\u0436\u0434\u0435\u0442\u0441\u044F
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430.
    \u0421\u0432\u043E\u0438\u043C\u0438 \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u043C\u0438
    \u043E\u043D \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043B
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0443, \u0441\u0432\u043E\u0435\u0439
    \u043A\u0440\u0438\u0432\u043E\u0439 \u2014 \u0440\u0430\u0437\u0434\u0432\u0438\u043D\u0443\u043B
    \u0433\u0440\u0430\u043D\u0438\u0446\u044B \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0438,
    \u0430 \u0441\u0432\u043E\u0438\u043C \xAB\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440\u043E\u043C\xBB
    \u2014 \u043F\u043E\u043A\u0430\u0437\u0430\u043B \u043F\u0443\u0442\u044C \u043A
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u0435\u0434\u0438\u043D\u043E\u0433\u043E,
    \u0441\u0442\u0440\u043E\u0433\u043E\u0433\u043E \u0438 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0437\u043D\u0430\u043D\u0438\u044F. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u043F\u0440\u044F\u043C\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u0448\u043A\u043E\u043B \u0420\u0430\u0441\u0441\u0435\u043B\u0430, \u0423\u0430\u0439\u0442\u0445\u0435\u0434\u0430
    \u0438, \u0432 \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u043C,
    \u0433\u0440\u0443\u043F\u043F\u044B \u0411\u0443\u0440\u0431\u0430\u043A\u0438."
  achievementsEn: 
  personalLifeRu: "\u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435 \u041F\u0435\u0430\u043D\u043E
    \u043F\u0440\u043E\u0436\u0438\u043B \u0434\u043E\u043B\u0433\u0443\u044E \u0438
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u0443\u044E \u0436\u0438\u0437\u043D\u044C,
    \u0446\u0435\u043B\u0438\u043A\u043E\u043C \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0443\u044E
    \u043D\u0430\u0443\u043A\u0435. \u0415\u0433\u043E \u043B\u0438\u0447\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u2014 \u044D\u0442\u043E \u043F\u0443\u0442\u044C
    \u043E\u0442 \u0441\u044B\u043D\u0430 \u0444\u0435\u0440\u043C\u0435\u0440\u0430
    \u0434\u043E \u043E\u0434\u043D\u043E\u0433\u043E \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A\u043E\u0432
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438, \u043F\u043E\u043B\u043D\u044B\u0439 \u043A\u0430\u043A
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F, \u0442\u0430\u043A \u0438
    \u043D\u0435\u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u0441\u043E
    \u0441\u0442\u043E\u0440\u043E\u043D\u044B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432. 
    ### \U0001F33E \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u0440\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B (1858\u20131876)  \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435
    \u041F\u0435\u0430\u043D\u043E \u0440\u043E\u0434\u0438\u043B\u0441\u044F 27
    \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1858 \u0433\u043E\u0434\u0430 \u043D\u0430
    \u0444\u0435\u0440\u043C\u0435 \u0422\u0435\u0442\u0442\u043E-\u0413\u0430\u043B\u0430\u043D\u0442
    \u0432 \u0421\u043F\u0438\u043D\u0435\u0442\u0442\u0435, \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u0434\u0435\u0440\u0435\u0432\u043D\u0435 \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E
    \u043E\u0442 \u0433\u043E\u0440\u043E\u0434\u0430 \u041A\u0443\u043D\u0435\u043E
    \u0432 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u043E\u043C \u0440\u0435\u0433\u0438\u043E\u043D\u0435
    \u041F\u044C\u0435\u043C\u043E\u043D\u0442. \u0415\u0433\u043E \u0441\u0435\u043C\u044C\u044F
    \u0431\u044B\u043B\u0430 \u0444\u0435\u0440\u043C\u0435\u0440\u0441\u043A\u043E\u0439.
    \u041D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0432 \u0434\u0435\u0440\u0435\u0432\u0435\u043D\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435, \u0430 \u0437\u0430\u0442\u0435\u043C \u0432
    \u0448\u043A\u043E\u043B\u0435 \u0432 \u041A\u0443\u043D\u0435\u043E, \u043A\u0443\u0434\u0430
    \u0435\u0436\u0435\u0434\u043D\u0435\u0432\u043D\u043E \u0445\u043E\u0434\u0438\u043B
    \u043F\u0435\u0448\u043A\u043E\u043C \u043E\u043A\u043E\u043B\u043E 5 \u043A\u0438\u043B\u043E\u043C\u0435\u0442\u0440\u043E\u0432. 
    \u041F\u0443\u0442\u044C \u043A \u043D\u0430\u0443\u043A\u0435 \u0435\u043C\u0443
    \u043E\u0442\u043A\u0440\u044B\u043B \u0435\u0433\u043E \u0434\u044F\u0434\u044F,
    \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A \u0438 \u044E\u0440\u0438\u0441\u0442,
    \u0436\u0438\u0432\u0448\u0438\u0439 \u0432 \u0422\u0443\u0440\u0438\u043D\u0435.
    \u0417\u0430\u043C\u0435\u0442\u0438\u0432 \u0442\u0430\u043B\u0430\u043D\u0442
    \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u043A\u0430, \u0432 1870 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0437\u0430\u0431\u0440\u0430\u043B \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435
    \u043A \u0441\u0435\u0431\u0435, \u0447\u0442\u043E\u0431\u044B \u0442\u043E\u0442
    \u043C\u043E\u0433 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0445\u043E\u0440\u043E\u0448\u0435\u0435
    \u0441\u0440\u0435\u0434\u043D\u0435\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435.
    \u041F\u0435\u0430\u043D\u043E \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u043B\u0438\u0446\u0435\u0439
    \u041A\u0430\u0432\u0443\u0440\u0430 \u0432 \u0422\u0443\u0440\u0438\u043D\u0435
    \u0438 \u0432 1876 \u0433\u043E\u0434\u0443 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0422\u0443\u0440\u0438\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442. 
    ### \U0001F393 \u0423\u0447\u0451\u0431\u0430 \u0438 \u043D\u0430\u0447\u0430\u043B\u043E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B (1876\u20131890)  \u0412 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u041F\u0435\u0430\u043D\u043E \u0438\u0437\u0443\u0447\u0430\u043B \"\u0447\u0438\u0441\u0442\u0443\u044E\"
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443, \u0432 \u0442\u043E
    \u0432\u0440\u0435\u043C\u044F \u043A\u0430\u043A \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
    \u0435\u0433\u043E \u0441\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A\u043E\u0432
    \u0432\u044B\u0431\u0438\u0440\u0430\u043B\u0438 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u043E\u0435
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435. \u0412 1880
    \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0441 \u043E\u0442\u043B\u0438\u0447\u0438\u0435\u043C. 
    \u0421\u0440\u0430\u0437\u0443 \u043F\u043E\u0441\u043B\u0435 \u0432\u044B\u043F\u0443\u0441\u043A\u0430
    \u043E\u043D \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u0440\u0430\u0431\u043E\u0442\u0430\u044F \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u043C
    \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u0443 **\u042D\u043D\u0440\u0438\u043A\u043E
    \u0414'\u041E\u0432\u0438\u0434\u0438\u043E**, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0443 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 **\u0410\u043D\u0434\u0436\u0435\u043B\u043E
    \u0414\u0436\u0435\u043D\u043E\u043A\u043A\u0438**. \u0418\u0437-\u0437\u0430
    \u0441\u043B\u0430\u0431\u043E\u0433\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F
    \u0414\u0436\u0435\u043D\u043E\u043A\u043A\u0438 \u041F\u0435\u0430\u043D\u043E
    \u0443\u0436\u0435 \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0430 \u0433\u043E\u0434\u0430
    \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043D\u0430\u0447\u0430\u043B
    \u0432\u0435\u0441\u0442\u0438 \u0435\u0433\u043E \u043A\u0443\u0440\u0441 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F. \u0412 1884 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u043F\u0435\u0440\u0432\u044B\u0439 \u043A\u0440\u0443\u043F\u043D\u044B\u0439
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u044B\u0448\u0435\u043B \u043F\u043E\u0434 \u0438\u043C\u0435\u043D\u0435\u043C
    \u0414\u0436\u0435\u043D\u043E\u043A\u043A\u0438, \u0445\u043E\u0442\u044F \u043F\u043E\u0447\u0442\u0438
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0431\u044B\u043B \u043D\u0430\u043F\u0438\u0441\u0430\u043D
    \u0441\u0430\u043C\u0438\u043C \u041F\u0435\u0430\u043D\u043E. \u0414\u0436\u0435\u043D\u043E\u043A\u043A\u0438
    \u0447\u0435\u0441\u0442\u043D\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u043B
    \u044D\u0442\u043E, \u043D\u0430\u0437\u0432\u0430\u0432 \u041F\u0435\u0430\u043D\u043E
    \"\u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F \u043C\u043E\u043B\u043E\u0434\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C\".  \u0412 1886 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C
    \u0438 \u0432 \u0422\u0443\u0440\u0438\u043D\u0441\u043A\u043E\u0439 \u0432\u043E\u0435\u043D\u043D\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438. \u0422\u0440\u0438 \u0433\u043E\u0434\u0430
    \u0441\u043F\u0443\u0441\u0442\u044F, \u0432 1889 \u0433\u043E\u0434\u0443, \u043E\u043D
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0437\u0432\u0430\u043D\u0438\u0435
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u043F\u0435\u0440\u0432\u043E\u0433\u043E
    \u043A\u043B\u0430\u0441\u0441\u0430 \u0432 \u044D\u0442\u043E\u043C \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0438.
    \u0412 1890 \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B, \u043D\u0430\u043A\u043E\u043D\u0435\u0446,
    \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D \u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0432 \u0422\u0443\u0440\u0438\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u0437\u0430\u043D\u044F\u0432
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F \u0414\u0436\u0435\u043D\u043E\u043A\u043A\u0438. 
    ### \U0001F468\u200D\U0001F469\u200D\U0001F466 \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C  \u0412 1887 \u0433\u043E\u0434\u0443 \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435
    \u041F\u0435\u0430\u043D\u043E \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430
    **\u041A\u0430\u0440\u043E\u043B\u0435 \u041A\u0440\u043E\u0437\u0438\u043E**
    (Carola Crosio). \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0434\u043E\u0447\u0435\u0440\u044C\u044E
    \u0442\u0443\u0440\u0438\u043D\u0441\u043A\u043E\u0433\u043E \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0430
    **\u041B\u0443\u0438\u0434\u0436\u0438 \u041A\u0440\u043E\u0437\u0438\u043E**,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u0441\u0432\u043E\u0435\u0439
    \u043A\u0430\u0440\u0442\u0438\u043D\u043E\u0439 \"\u041C\u0430\u0434\u043E\u043D\u043D\u0430
    \u0423\u0431\u0435\u0436\u0438\u0449\u0435 \u0413\u0440\u0435\u0448\u043D\u0438\u043A\u043E\u0432\".
    \u0421\u0432\u0435\u0434\u0435\u043D\u0438\u0439 \u043E \u0442\u043E\u043C, \u0431\u044B\u043B\u0438
    \u043B\u0438 \u0443 \u043F\u0430\u0440\u044B \u0434\u0435\u0442\u0438, \u0432
    \u043D\u0430\u0439\u0434\u0435\u043D\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445
    \u043D\u0435\u0442.  ### \U0001F52C \u0420\u0430\u0441\u0446\u0432\u0435\u0442
    \u0438 \u0432\u0437\u0430\u0438\u043C\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438 (1890-\u0435 \u2013
    1900-\u0435)  \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u0441\u0442\u0430\u043B
    \u0441\u0430\u043C\u044B\u043C \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C,
    \u043D\u043E \u0438 \u0441\u0430\u043C\u044B\u043C \u0441\u043B\u043E\u0436\u043D\u044B\u043C
    \u0432 \u0436\u0438\u0437\u043D\u0438 \u041F\u0435\u0430\u043D\u043E.  *   **\"\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440\"
    \u0438 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0441 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435\u043C:**
    \u0412 1891 \u0433\u043E\u0434\u0443 \u041F\u0435\u0430\u043D\u043E \u043D\u0430\u0447\u0430\u043B
    \u0441\u0432\u043E\u0439 \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u044B\u0439
    \u043F\u0440\u043E\u0435\u043A\u0442 \xAB\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB (Formulario
    Mathematico). \u041E\u043D \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D \u044D\u0442\u043E\u0439 \u0438\u0434\u0435\u0435\u0439,
    \u0447\u0442\u043E \u043D\u0430\u0447\u0430\u043B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
    \u0435\u0433\u043E \u0434\u043B\u044F \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u044F.
    \u042D\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\u0435:
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B \u043D\u0435 \u043C\u043E\u0433\u043B\u0438
    \u0443\u0441\u0432\u043E\u0438\u0442\u044C \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B,
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0439 \u043D\u0430 \u0441\u043B\u043E\u0436\u043D\u043E\u043C
    \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435. \u041F\u0435\u0430\u043D\u043E, \u043D\u0435\u043A\u043E\u0433\u0434\u0430
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u044B\u0439 \u043B\u0435\u043A\u0442\u043E\u0440,
    \u0441\u0442\u0430\u043B \u043D\u0435\u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u044B\u043C
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C. *   **\u0423\u0432\u043E\u043B\u044C\u043D\u0435\u043D\u0438\u0435
    \u0438\u0437 \u0412\u043E\u0435\u043D\u043D\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    (1901):** \u0415\u0433\u043E \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435
    \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0437\u043C\u043E\u043C \u0438 \"\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440\u043E\u043C\"
    \u0432 \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C \u0441\u0447\u0435\u0442\u0435
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0443\u0432\u043E\u043B\u044C\u043D\u0435\u043D\u0438\u044E
    \u0438\u0437 \u0412\u043E\u0435\u043D\u043D\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u0432 1901 \u0433\u043E\u0434\u0443, \u0442\u0430\u043A \u043A\u0430\u043A \u0435\u0433\u043E
    \u0441\u0442\u0438\u043B\u044C \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u044F
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043D\u0438\u044F\u043C. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043E\u043D \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B \u0441\u0432\u043E\u044E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435.
    *   **\u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438:**
    \u041F\u0435\u0430\u043D\u043E \u043E\u0431\u043B\u0430\u0434\u0430\u043B \u0440\u0435\u0434\u043A\u043E\u0441\u0442\u043D\u044B\u043C
    \u0434\u0430\u0440\u043E\u043C \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C
    \u043E\u0448\u0438\u0431\u043A\u0438 \u0438 \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F
    \u0432 \u0447\u0443\u0436\u0438\u0445 \u0442\u0435\u043E\u0440\u0435\u043C\u0430\u0445.
    \u042D\u0442\u0430 \u0435\u0433\u043E \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C
    \u0447\u0430\u0441\u0442\u043E \u0432\u044B\u0437\u044B\u0432\u0430\u043B\u0430
    \u0440\u0430\u0437\u0434\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \u043A\u043E\u043B\u043B\u0435\u0433.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0435\u0433\u043E \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442
    \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u041A\u043E\u0440\u0440\u0430\u0434\u043E
    \u0421\u0435\u0433\u0440\u0435 \u0432\u043E\u0437\u043D\u0438\u043A \u0438\u043C\u0435\u043D\u043D\u043E
    \u0438\u0437-\u0437\u0430 \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u041F\u0435\u0430\u043D\u043E
    \u0443\u043A\u0430\u0437\u0430\u043B \u043D\u0430 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043A\u0438
    \u0432 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0435. \u0422\u0430\u043A\u0436\u0435
    \u043E\u043D \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0438\u043C\u0438
    \u0440\u0435\u0437\u043A\u0438\u043C\u0438 \u0440\u0435\u0446\u0435\u043D\u0437\u0438\u044F\u043C\u0438,
    \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043D\u0430 \u043A\u043D\u0438\u0433\u0443
    \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435 \u0412\u0435\u0440\u043E\u043D\u0435\u0437\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435\u043C \"\u043D\u0435\u043B\u0435\u043F\u043E\u0441\u0442\u0435\u0439\". 
    ### \U0001F30D \u0422\u0440\u0438\u0443\u043C\u0444 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435
    \u0438 \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u0441 \u0420\u0430\u0441\u0441\u0435\u043B\u043E\u043C
    (1900)  \u041F\u043E\u0432\u043E\u0440\u043E\u0442\u043D\u044B\u043C \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C
    \u0432 \u0436\u0438\u0437\u043D\u0438 \u041F\u0435\u0430\u043D\u043E \u0441\u0442\u0430\u043B
    1900 \u0433\u043E\u0434, \u043A\u043E\u0433\u0434\u0430 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435
    \u043F\u0440\u043E\u0448\u043B\u0438 \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u044B
    \u043F\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430
    \u0435\u0433\u043E \u0441\u0443\u0434\u044C\u0431\u043E\u043D\u043E\u0441\u043D\u0430\u044F
    \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u0441 **\u0411\u0435\u0440\u0442\u0440\u0430\u043D\u0434\u043E\u043C
    \u0420\u0430\u0441\u0441\u0435\u043B\u043E\u043C**. \u0420\u0430\u0441\u0441\u0435\u043B
    \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0440\u0430\u0436\u0435\u043D
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438 \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u043C\u0438
    \u041F\u0435\u0430\u043D\u043E, \u0447\u0442\u043E \u043F\u0440\u0435\u0440\u0432\u0430\u043B
    \u0441\u0432\u043E\u0435 \u0443\u0447\u0430\u0441\u0442\u0438\u0435 \u0432 \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435
    \u0438 \u0443\u0435\u0445\u0430\u043B \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u044E,
    \u0447\u0442\u043E\u0431\u044B \"\u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E
    \u0438\u0437\u0443\u0447\u0438\u0442\u044C \u043A\u0430\u0436\u0434\u043E\u0435
    \u0441\u043B\u043E\u0432\u043E, \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0435
    \u0438\u043C \u0438\u043B\u0438 \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C\u0438\".
    \u042D\u0442\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0420\u0430\u0441\u0441\u0435\u043B\u0430.  
    ### \U0001F310 \u0423\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435 \u0438\u043D\u0442\u0435\u0440\u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u043A\u043E\u0439
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B 
    \u041F\u043E\u0441\u043B\u0435 1900 \u0433\u043E\u0434\u0430 \u041F\u0435\u0430\u043D\u043E
    \u0432\u0441\u0435 \u0431\u043E\u043B\u044C\u0448\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0443\u0434\u0435\u043B\u044F\u043B \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0433\u043E
    \u0432\u0441\u043F\u043E\u043C\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430 **\"\u041B\u0430\u0442\u0438\u043D\u043E \u0441\u0438\u043D\u0435
    \u0444\u043B\u0435\u043A\u0441\u0438\u043E\u043D\u0435\"** (\u043B\u0430\u0442\u044B\u043D\u044C
    \u0431\u0435\u0437 \u0441\u043B\u043E\u0432\u043E\u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0439).
    \u042D\u0442\u043E \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435 \u0431\u044B\u043B\u043E
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0438\u043B\u044C\u043D\u044B\u043C,
    \u0447\u0442\u043E \u0432 1908 \u0433\u043E\u0434\u0443 \u043E\u043D \u0434\u0430\u0436\u0435
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435
    \u0438\u0437\u0434\u0430\u043D\u0438\u0435 \u0441\u0432\u043E\u0435\u0433\u043E
    \"\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440\u0430\" \u043D\u0430 \u044D\u0442\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435.  \u0412 1910 \u0433\u043E\u0434\u0443 \u0443\u043C\u0435\u0440\u043B\u0430
    \u0435\u0433\u043E \u043C\u0430\u0442\u044C. \u0412 1925 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u0435\u0440\u0435\u0448\u0435\u043B \u043D\u0430 \u043A\u0430\u0444\u0435\u0434\u0440\u0443
    \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u043E\u043B\u044C\u0448\u0435 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u0435\u0433\u043E \u0442\u0435\u043A\u0443\u0449\u0438\u043C \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0430\u043C. 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438 \u0432 \u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0435
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B, \u041F\u0435\u0430\u043D\u043E \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B
    \u0448\u0438\u0440\u043E\u043A\u0438\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u044B. \u041E\u043D \u0431\u044B\u043B
    \u0437\u043D\u0430\u043A\u043E\u043C \u0441 \u043C\u043D\u043E\u0433\u0438\u043C\u0438
    \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u043C\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0424\u0435\u043B\u0438\u043A\u0441\u0430
    \u041A\u043B\u044F\u0439\u043D\u0430, \u0438 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0441\u044F
    \u0441 \u0413\u043E\u0442\u043B\u043E\u0431\u043E\u043C \u0424\u0440\u0435\u0433\u0435.
    \u0415\u0433\u043E \u0430\u0432\u0442\u043E\u0440\u0438\u0442\u0435\u0442 \u0431\u044B\u043B
    \u0432\u044B\u0441\u043E\u043A, \u0438 \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u043D\u0430\u0433\u0440\u0430\u0434,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0437\u0432\u0430\u043D\u0438\u0435
    \u0447\u043B\u0435\u043D\u0430-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u0430
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u0434\u0435\u0438 \u041B\u0438\u043D\u0447\u0435\u0438
    \u0432 1905 \u0433\u043E\u0434\u0443 \u2014 \u0432\u044B\u0441\u0448\u0435\u0439
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u043D\u0430\u0433\u0440\u0430\u0434\u044B
    \u0418\u0442\u0430\u043B\u0438\u0438.  ### \U0001F54A\uFE0F \u0421\u043C\u0435\u0440\u0442\u044C 
    \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435 \u041F\u0435\u0430\u043D\u043E
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u043E\u0442 \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u043E\u0433\u043E
    \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0430 20 \u0430\u043F\u0440\u0435\u043B\u044F
    1932 \u0433\u043E\u0434\u0430 \u0432 \u0422\u0443\u0440\u0438\u043D\u0435. \u041E\u043D
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0434\u043E \u0441\u0430\u043C\u043E\u0433\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0433\u043E
    \u0434\u043D\u044F."
  personalLifeEn: 
  shortBioRu: "\u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435 \u041F\u0435\u0430\u043D\u043E
    (1858\u20131932) \u2014 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u044B
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438 \u0438 \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u043A\u0438.
    \u041E\u043D \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u043A\u0430\u043A
    \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C \u0430\u043A\u0441\u0438\u043E\u043C
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B
    \u0438 \u0430\u0432\u0442\u043E\u0440 \xAB\u043A\u0440\u0438\u0432\u043E\u0439
    \u041F\u0435\u0430\u043D\u043E\xBB \u2014 \u043F\u0435\u0440\u0432\u043E\u0439
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0439 \u043A\u0440\u0438\u0432\u043E\u0439,
    \u0437\u0430\u043F\u043E\u043B\u043D\u044F\u044E\u0449\u0435\u0439 \u043A\u0432\u0430\u0434\u0440\u0430\u0442. 
    ### \U0001F5D3\uFE0F \u0414\u0435\u0442\u0430\u043B\u044C\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F 
    **\u0414\u0435\u0442\u0441\u0442\u0432\u043E, \u044E\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 (1858\u20131880)** 
    \u041F\u0435\u0430\u043D\u043E \u0440\u043E\u0434\u0438\u043B\u0441\u044F 27
    \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1858 \u0433\u043E\u0434\u0430 \u043D\u0430
    \u0444\u0435\u0440\u043C\u0435 \u0422\u0435\u0442\u0442\u043E-\u0413\u0430\u043B\u0430\u043D\u0442
    \u0432 \u0421\u043F\u0438\u043D\u0435\u0442\u0442\u0435, \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E
    \u043E\u0442 \u0433\u043E\u0440\u043E\u0434\u0430 \u041A\u0443\u043D\u0435\u043E
    \u0432 \u041F\u044C\u0435\u043C\u043E\u043D\u0442\u0435, \u0418\u0442\u0430\u043B\u0438\u044F.
    \u0415\u0433\u043E \u0441\u0435\u043C\u044C\u044F \u0431\u044B\u043B\u0430 \u0444\u0435\u0440\u043C\u0435\u0440\u0441\u043A\u043E\u0439.
    \u041D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0432 \u0434\u0435\u0440\u0435\u0432\u0435\u043D\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435, \u0430 \u0437\u0430\u0442\u0435\u043C \u0432
    \u0448\u043A\u043E\u043B\u0435 \u0432 \u041A\u0443\u043D\u0435\u043E, \u043A\u0443\u0434\u0430
    \u0435\u0436\u0435\u0434\u043D\u0435\u0432\u043D\u043E \u0445\u043E\u0434\u0438\u043B
    \u043F\u0435\u0448\u043A\u043E\u043C 5 \u043A\u043C.  \u0422\u0430\u043B\u0430\u043D\u0442
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430 \u0437\u0430\u043C\u0435\u0442\u0438\u043B
    \u0435\u0433\u043E \u0434\u044F\u0434\u044F, \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A
    \u0438 \u044E\u0440\u0438\u0441\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432 1870 \u0433\u043E\u0434\u0443 \u0437\u0430\u0431\u0440\u0430\u043B \u0435\u0433\u043E
    \u0432 \u0422\u0443\u0440\u0438\u043D \u0434\u043B\u044F \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F
    \u0441\u0440\u0435\u0434\u043D\u0435\u0433\u043E \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F.
    \u041F\u043E\u0441\u043B\u0435 \u043E\u043A\u043E\u043D\u0447\u0430\u043D\u0438\u044F
    \u043B\u0438\u0446\u0435\u044F \u041A\u0430\u0432\u0443\u0440\u0430 \u0432 1876
    \u0433\u043E\u0434\u0443 \u041F\u0435\u0430\u043D\u043E \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0422\u0443\u0440\u0438\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442.
    \u0412 1880 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0435\u0433\u043E \u0441 \u043E\u0442\u043B\u0438\u0447\u0438\u0435\u043C, \u0437\u0430\u0449\u0438\u0442\u0438\u0432
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.  **\u041D\u0430\u0447\u0430\u043B\u043E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B (1880\u20131890)**  \u0421\u0440\u0430\u0437\u0443
    \u043F\u043E\u0441\u043B\u0435 \u0432\u044B\u043F\u0443\u0441\u043A\u0430 \u041F\u0435\u0430\u043D\u043E
    \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0432 \u0422\u0443\u0440\u0438\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u0441\u0442\u0430\u0432
    \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u043C \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u042D\u043D\u0440\u0438\u043A\u043E \u0414'\u041E\u0432\u0438\u0434\u0438\u043E,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0410\u043D\u0434\u0436\u0435\u043B\u043E
    \u0414\u0436\u0435\u043D\u043E\u043A\u043A\u0438, \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u043A\u0430\u0444\u0435\u0434\u0440\u044B \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F. \u0418\u0437-\u0437\u0430
    \u0441\u043B\u0430\u0431\u043E\u0433\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F
    \u0414\u0436\u0435\u043D\u043E\u043A\u043A\u0438 \u041F\u0435\u0430\u043D\u043E
    \u0443\u0436\u0435 \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0430 \u0433\u043E\u0434\u0430
    \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043D\u0430\u0447\u0430\u043B
    \u0432\u0435\u0441\u0442\u0438 \u0435\u0433\u043E \u043A\u0443\u0440\u0441. 
    \u0412 1884 \u0433\u043E\u0434\u0443 \u043E\u043D \u0438\u0437\u0434\u0430\u043B
    \u0441\u0432\u043E\u0439 \u043F\u0435\u0440\u0432\u044B\u0439 \u043A\u0440\u0443\u043F\u043D\u044B\u0439
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u044B\u0448\u0435\u043B \u043F\u043E\u0434 \u0438\u043C\u0435\u043D\u0435\u043C
    \u0414\u0436\u0435\u043D\u043E\u043A\u043A\u0438. \u0412 1887 \u0433\u043E\u0434\u0443
    \u041F\u0435\u0430\u043D\u043E \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430
    \u041A\u0430\u0440\u043E\u043B\u0435 \u041A\u0440\u043E\u0437\u0438\u043E, \u0434\u043E\u0447\u0435\u0440\u0438
    \u0442\u0443\u0440\u0438\u043D\u0441\u043A\u043E\u0433\u043E \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0430
    \u041B\u0443\u0438\u0434\u0436\u0438 \u041A\u0440\u043E\u0437\u0438\u043E.  \u0412
    1886 \u0433\u043E\u0434\u0443 \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C
    \u0432 \u0422\u0443\u0440\u0438\u043D\u0441\u043A\u043E\u0439 \u0432\u043E\u0435\u043D\u043D\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438, \u0433\u0434\u0435 \u0432 1889
    \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0437\u0432\u0430\u043D\u0438\u0435
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u043F\u0435\u0440\u0432\u043E\u0433\u043E
    \u043A\u043B\u0430\u0441\u0441\u0430.  **\u041F\u0438\u043A \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438 (1890\u20131900)** 
    \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u0441\u0442\u0430\u043B
    \u0441\u0430\u043C\u044B\u043C \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C
    \u0432 \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0435: *   **\u0410\u043A\u0441\u0438\u043E\u043C\u044B
    \u041F\u0435\u0430\u043D\u043E (1889):** \u0412 \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u043E\u043C
    \u043F\u0430\u043C\u0444\u043B\u0435\u0442\u0435 \xABArithmetices principia,
    nova methodo exposita\xBB \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0430\u043A\u0441\u0438\u043E\u043C
    \u0434\u043B\u044F \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0442\u0435\u043F\u0435\u0440\u044C
    \u043D\u043E\u0441\u0438\u0442 \u0435\u0433\u043E \u0438\u043C\u044F. *   **\xAB\u041A\u0440\u0438\u0432\u0430\u044F
    \u041F\u0435\u0430\u043D\u043E\xBB (1890):** \u041E\u043D \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    \u043F\u0435\u0440\u0432\u044B\u0439 \u043F\u0440\u0438\u043C\u0435\u0440 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0439
    \u043A\u0440\u0438\u0432\u043E\u0439, \u043F\u0440\u043E\u0445\u043E\u0434\u044F\u0449\u0435\u0439
    \u0447\u0435\u0440\u0435\u0437 \u043A\u0430\u0436\u0434\u0443\u044E \u0442\u043E\u0447\u043A\u0443
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430, \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439 \u0441\u0435\u043D\u0441\u0430\u0446\u0438\u0435\u0439
    \u0438 \u043F\u0435\u0440\u0432\u044B\u043C \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u043C
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0441\u0435\u0439\u0447\u0430\u0441
    \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u043E\u043C.
    *   **\u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0443\u0440\u0430 (1890):**
    \u0412 \u0434\u0435\u043A\u0430\u0431\u0440\u0435 1890 \u0433\u043E\u0434\u0430
    \u041F\u0435\u0430\u043D\u043E \u0431\u044B\u043B \u043D\u0430\u043A\u043E\u043D\u0435\u0446
    \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0432 \u0422\u0443\u0440\u0438\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u0437\u0430\u043D\u044F\u0432
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F \u0414\u0436\u0435\u043D\u043E\u043A\u043A\u0438.
    *   **\u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u0436\u0443\u0440\u043D\u0430\u043B\u044B
    \u0438 \xAB\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440\xBB:** \u0412 1891
    \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \u0436\u0443\u0440\u043D\u0430\u043B `Rivista di Matematica`. \u0412 \u0442\u043E\u043C
    \u0436\u0435 \u0433\u043E\u0434\u0443 \u043E\u043D \u043D\u0430\u0447\u0430\u043B
    \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u044B\u0439 \u043F\u0440\u043E\u0435\u043A\u0442
    **\xAB\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB
    (Formulario Mathematico)** \u2014 \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u044E,
    \u0446\u0435\u043B\u044C\u044E \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0431\u044B\u043B\u043E
    \u0438\u0437\u043B\u043E\u0436\u0438\u0442\u044C \u0432\u0441\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043D\u0430 \u0435\u0433\u043E \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C \u044F\u0437\u044B\u043A\u0435. 
    **\u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438 \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E
    \u0441 \u0420\u0430\u0441\u0441\u0435\u043B\u043E\u043C (1900)**  \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u043C
    \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C \u0432 \u0436\u0438\u0437\u043D\u0438
    \u041F\u0435\u0430\u043D\u043E \u0441\u0442\u0430\u043B 1900 \u0433\u043E\u0434,
    \u043A\u043E\u0433\u0434\u0430 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u043F\u0440\u043E\u0448\u043B\u0438
    \u041F\u0435\u0440\u0432\u0430\u044F \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u0430\u044F
    \u043A\u043E\u043D\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u044F \u043F\u043E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u0438 \u0412\u0442\u043E\u0440\u043E\u0439
    \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u0439
    \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.
    \u041F\u0435\u0430\u043D\u043E \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u043C \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435
    \u0438 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0434\u043E\u043A\u043B\u0430\u0434
    \u043E \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u043E\u0441\u0442\u0438
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0439 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430
    \u0435\u0433\u043E \u0441\u0443\u0434\u044C\u0431\u043E\u043D\u043E\u0441\u043D\u0430\u044F
    \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u0441 **\u0411\u0435\u0440\u0442\u0440\u0430\u043D\u0434\u043E\u043C
    \u0420\u0430\u0441\u0441\u0435\u043B\u043E\u043C**. \u0420\u0430\u0441\u0441\u0435\u043B
    \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0440\u0430\u0436\u0435\u043D
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438 \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u043C\u0438
    \u041F\u0435\u0430\u043D\u043E, \u0447\u0442\u043E \u043F\u0440\u0435\u0440\u0432\u0430\u043B
    \u0441\u0432\u043E\u0435 \u0443\u0447\u0430\u0441\u0442\u0438\u0435 \u0432 \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435
    \u0438 \u0443\u0435\u0445\u0430\u043B \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u044E,
    \u0447\u0442\u043E\u0431\u044B \xAB\u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E
    \u0438\u0437\u0443\u0447\u0438\u0442\u044C \u043A\u0430\u0436\u0434\u043E\u0435
    \u0441\u043B\u043E\u0432\u043E, \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0435
    \u0438\u043C \u0438\u043B\u0438 \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C\u0438\xBB. 
    **\u0417\u0430\u043A\u0430\u0442 \u043A\u0430\u0440\u044C\u0435\u0440\u044B \u0438
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435 \u0438\u043D\u0442\u0435\u0440\u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u043A\u043E\u0439
    (1901\u20131932)**  \u041F\u043E\u0441\u043B\u0435 1900 \u0433\u043E\u0434\u0430
    \u0432 \u0436\u0438\u0437\u043D\u0438 \u041F\u0435\u0430\u043D\u043E \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0438
    \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u044F: *   **\u0423\u0432\u043E\u043B\u044C\u043D\u0435\u043D\u0438\u0435
    \u0438\u0437 \u0412\u043E\u0435\u043D\u043D\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    (1901):** \u0415\u0433\u043E \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0435\u043A\u0442\u043E\u043C \xAB\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440\u0430\xBB
    \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0441 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0435\u0433\u043E \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430 \u043F\u0440\u0438\u0432\u0435\u043B\u0438 \u043A
    \u0442\u043E\u043C\u0443, \u0447\u0442\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B
    \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B\u0438
    \u0435\u0433\u043E \u043F\u043E\u043D\u0438\u043C\u0430\u0442\u044C. \u042D\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439
    \u0435\u0433\u043E \u0443\u0432\u043E\u043B\u044C\u043D\u0435\u043D\u0438\u044F
    \u0438\u0437 \u0412\u043E\u0435\u043D\u043D\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438.
    *   **\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u044F\u0437\u044B\u043A \xAB\u041B\u0430\u0442\u0438\u043D\u043E \u0441\u0438\u043D\u0435
    \u0444\u043B\u0435\u043A\u0441\u0438\u043E\u043D\u0435\xBB (1903):** \u041F\u0435\u0430\u043D\u043E
    \u043E\u0431\u044A\u044F\u0432\u0438\u043B \u043E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438
    \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0433\u043E
    \u0432\u0441\u043F\u043E\u043C\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430, \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u043D\u043E\u0439
    \u0432\u0435\u0440\u0441\u0438\u0438 \u043B\u0430\u0442\u044B\u043D\u0438 \u0431\u0435\u0437
    \u0441\u043B\u043E\u0432\u043E\u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0439.
    \u0412 1908 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    `Academia pro Interlingua`, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u0438\u043D\u044F\u043B\u0430
    \u0435\u0433\u043E \u044F\u0437\u044B\u043A \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u0441\u0432\u043E\u0435\u0433\u043E \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0433\u043E.
    *   **\u0417\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0435 \xAB\u0424\u043E\u0440\u043C\u0443\u043B\u044F\u0440\u0430\xBB
    (1908):** \u0411\u044B\u043B\u043E \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043E
    \u043F\u044F\u0442\u043E\u0435 \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435
    \u0438\u0437\u0434\u0430\u043D\u0438\u0435, \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0435\u0435
    4200 \u0444\u043E\u0440\u043C\u0443\u043B \u0438 \u0442\u0435\u043E\u0440\u0435\u043C.
    \u041A \u0442\u043E\u043C\u0443 \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043F\u0440\u043E\u0435\u043A\u0442
    \u0443\u0436\u0435 \u0443\u0441\u0442\u0430\u0440\u0435\u043B, \u043D\u043E \u043E\u0441\u0442\u0430\u043B\u0441\u044F
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C \u0432\u043A\u043B\u0430\u0434\u043E\u043C
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    *   **\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B:**
    \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u043C\u0430\u0442\u0435\u0440\u0438
    \u0432 1910 \u0433\u043E\u0434\u0443 \u041F\u0435\u0430\u043D\u043E \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435.
    \u0412 1925 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0435\u0440\u0435\u0448\u0435\u043B
    \u043D\u0430 \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u043E\u043B\u044C\u0448\u0435 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0430\u043C. \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435
    \u041F\u0435\u0430\u043D\u043E \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u043E\u0442 \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u043E\u0433\u043E \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0430
    20 \u0430\u043F\u0440\u0435\u043B\u044F 1932 \u0433\u043E\u0434\u0430 \u0432
    \u0422\u0443\u0440\u0438\u043D\u0435, \u0437\u0430 \u0434\u0435\u043D\u044C \u0434\u043E
    \u0441\u0432\u043E\u0435\u0439 \u0441\u043C\u0435\u0440\u0442\u0438 \u0432\u0441\u0435
    \u0435\u0449\u0435 \u043F\u0440\u043E\u0432\u043E\u0434\u044F \u0437\u0430\u043D\u044F\u0442\u0438\u044F. 
    ### \U0001F3C6 \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0438 \u0432\u043A\u043B\u0430\u0434 \u0432 \u043D\u0430\u0443\u043A\u0443 
    | \u041E\u0431\u043B\u0430\u0441\u0442\u044C | \u0412\u043A\u043B\u0430\u0434
    | | :--- | :--- | | **\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430
    \u0438 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438**
    | \u0421\u043E\u0437\u0434\u0430\u043B **\u0430\u043A\u0441\u0438\u043E\u043C\u044B
    \u041F\u0435\u0430\u043D\u043E** \u2014 \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u0438\u0437 5 \u0430\u043A\u0441\u0438\u043E\u043C \u0434\u043B\u044F \u0441\u0442\u0440\u043E\u0433\u043E\u0433\u043E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0440\u044F\u0434\u0430 \u0447\u0438\u0441\u0435\u043B. | | **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437** | \u0414\u043E\u043A\u0430\u0437\u0430\u043B
    **\u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u041F\u0435\u0430\u043D\u043E** \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u043D\u0435 \u0432\u0441\u0435\u0433\u0434\u0430 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E.
    \u0412\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u0432\u0435\u043A\u0442\u043E\u0440\u0430
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430 \u0434\u043B\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430.
    | | **\u0422\u0435\u043E\u0440\u0438\u044F \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F** | \u041F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    **\xAB\u043A\u0440\u0438\u0432\u0443\u044E \u041F\u0435\u0430\u043D\u043E\xBB**
    \u2014 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0435 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u043E\u0442\u0440\u0435\u0437\u043A\u0430 \u043D\u0430 \u043A\u0432\u0430\u0434\u0440\u0430\u0442,
    \u0447\u0442\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043B\u043E \u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u043E
    \u0438\u0445 \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u0435\u0439 \u0438 \u0441\u0442\u0430\u043B\u043E
    \u043F\u0435\u0440\u0432\u044B\u043C \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u043C
    \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u0430. | | **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043B\u043E\u0433\u0438\u043A\u0430** | \u0412\u0432\u0435\u043B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
    \u0441\u0438\u043C\u0432\u043E\u043B\u044B \u0434\u043B\u044F \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0439
    \u043D\u0430\u0434 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430\u043C\u0438
    (\u222A \u0434\u043B\u044F \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F,
    \u2229 \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u044F)
    \u0438 \u0441\u043E\u0437\u0434\u0430\u043B \u043E\u0434\u043D\u0443 \u0438\u0437
