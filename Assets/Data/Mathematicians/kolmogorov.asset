    \u043F\u044F\u0442\u0438-\u0448\u0435\u0441\u0442\u0438 \u043B\u0435\u0442 \u043E\u043D
    \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u0442\u043A\u0440\u044B\u043B \u0437\u0430\u043A\u043E\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C
    \u0441\u0443\u043C\u043C\u044B \u043D\u0435\u0447\u0435\u0442\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B, \u0437\u0430\u043C\u0435\u0442\u0438\u0432, \u0447\u0442\u043E
    `1 = 1\xB2`, `1 + 3 = 2\xB2`, `1 + 3 + 5 = 3\xB2`. \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u0431\u044B\u043B\u043E \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043E
