    \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u044D\u043D\u0435\u0440\u0433\u0438\u0438, \u043F\u0440\u044F\u043C\u043E\u0442\u044B
    \u0438 \u0448\u0438\u0440\u043E\u0442\u044B \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432. 
    ### \U0001F4A1 \u041F\u0435\u0440\u0432\u043E\u0435 \xAB\u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\xBB
    \u0438 \u044E\u043D\u043E\u0448\u0435\u0441\u043A\u0438\u0439 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u0438\u0437\u043C 
    \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430
