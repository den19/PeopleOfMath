    \u043B\u0430\u0441\u0442\u043E\u0447\u043A\u0438\xBB, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0435\u0433\u043E \u0442\u0435\u0442\u044F \u0438\u0437\u0434\u0430\u0432\u0430\u043B\u0430
    \u0434\u043B\u044F \u0434\u0435\u0442\u0435\u0439 \u0432 \u0438\u043C\u0435\u043D\u0438\u0438. 
    \u0412 \u044E\u043D\u043E\u0441\u0442\u0438 \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B
    \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u043B\u0438\u0441\u044C
