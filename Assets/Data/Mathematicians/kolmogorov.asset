    \u0438 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u044B\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u043E\u0432 \u0438 \u0434\u0435\u0432\u043E\u0447\u0435\u043A.
    \u0422\u0430\u043C \u043E\u043D \u043F\u0440\u043E\u044F\u0432\u0438\u043B \u043D\u0435\u0434\u044E\u0436\u0438\u043D\u043D\u044B\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438: \"\u0443\u0447\u0438\u0442\u0435\u043B\u044F
    \u043D\u0435 \u0443\u0441\u043F\u0435\u0432\u0430\u043B\u0438 \u0435\u0433\u043E
    \u0443\u0447\u0438\u0442\u044C\", \u0430 \u0432\u044B\u0441\u0448\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u043E\u043D \u0438\u0437\u0443\u0447\u0430\u043B
    \u043F\u043E \u0441\u0442\u0430\u0442\u044C\u044F\u043C \u0438\u0437 \xAB\u042D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043B\u043E\u0432\u0430\u0440\u044F \u0411\u0440\u043E\u043A\u0433\u0430\u0443\u0437\u0430
    \u0438 \u0415\u0444\u0440\u043E\u043D\u0430\xBB. \u0412 17 \u043B\u0435\u0442
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u0443\u0436\u0435
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u0443\u044E
    \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    \u043F\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u0438, \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0443\u044E
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0430\u043D\u0430\u043B\u0438\u0437\u0443 \u043D\u043E\u0432\u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u0433\u043E
    \u0437\u0435\u043C\u043B\u0435\u0432\u043B\u0430\u0434\u0435\u043D\u0438\u044F. 
    \u0412 1920 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u043D\u0430
    \u0434\u0432\u0430 \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u044F: \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u2014 \u0432 \u041C\u043E\u0441\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u0438 \u043C\u0435\u0442\u0430\u043B\u043B\u0443\u0440\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u2014 \u0432 \u0425\u0438\u043C\u0438\u043A\u043E-\u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u0438\u043C. \u041C\u0435\u043D\u0434\u0435\u043B\u0435\u0435\u0432\u0430.
    \u041E\u0434\u043D\u0430\u043A\u043E \u043E\u0447\u0435\u043D\u044C \u0441\u043A\u043E\u0440\u043E
    \u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0432\u044B\u0431\u043E\u0440 \u0432 \u043F\u043E\u043B\u044C\u0437\u0443 \u041C\u0413\u0423,
    \u0438 \u0443\u0436\u0435 \u0432 \u043F\u0435\u0440\u0432\u044B\u0439 \u043C\u0435\u0441\u044F\u0446
    \u0441\u0434\u0430\u043B \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u044B \u0437\u0430
    \u0432\u0435\u0441\u044C \u043F\u0435\u0440\u0432\u044B\u0439 \u043A\u0443\u0440\u0441,
    \u043F\u0435\u0440\u0435\u0439\u0434\u044F \u043D\u0430 \u0432\u0442\u043E\u0440\u043E\u0439.
    \u0417\u0430 \u0443\u0441\u043F\u0435\u0445\u0438 \u0432 \u0443\u0447\u0435\u0431\u0435
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0440\u0430\u0432\u043E
    \u043D\u0430 16 \u043A\u0433 \u0445\u043B\u0435\u0431\u0430 \u0438 1 \u043A\u0433
    \u043C\u0430\u0441\u043B\u0430 \u0432 \u043C\u0435\u0441\u044F\u0446 \u2014 \u043F\u043E
    \u0442\u0435\u043C \u0433\u043E\u043B\u043E\u0434\u043D\u044B\u043C \u0432\u0440\u0435\u043C\u0435\u043D\u0430\u043C
    \u044D\u0442\u043E \u0431\u044B\u043B\u043E \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0431\u043B\u0430\u0433\u043E\u043F\u043E\u043B\u0443\u0447\u0438\u0435\u043C. 
    ### \U0001F468\u200D\U0001F3EB \u041F\u0443\u0442\u044C \u0432 \u043D\u0430\u0443\u043A\u0435
    \u0438 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u0438  \u041D\u0430
    \u0432\u0442\u043E\u0440\u043E\u043C \u043A\u0443\u0440\u0441\u0435 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u044F\u0440\u0447\u0430\u0439\u0448\u0438\u0445
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u041D\u0438\u043A\u043E\u043B\u0430\u044F
    \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447\u0430 \u041B\u0443\u0437\u0438\u043D\u0430.
    \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F: \u043D\u0430 \u043B\u0435\u043A\u0446\u0438\u0438
    \u041B\u0443\u0437\u0438\u043D \u0434\u043E\u043F\u0443\u0441\u0442\u0438\u043B
    \u043D\u0435\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C \u0432 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435,
    \u0438 \u043F\u0435\u0440\u0432\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u043F\u043E\u0434\u043D\u044F\u043B
    \u0440\u0443\u043A\u0443 \u0438 \u0437\u0430\u044F\u0432\u0438\u043B: \"\u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440,
    \u044D\u0442\u043E \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435
    \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E\". \u041F\u043E\u0440\u0430\u0436\u0435\u043D\u043D\u044B\u0439
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B
    \u0435\u0433\u043E \u043D\u0430 \u0441\u0432\u043E\u0439 \u0441\u0435\u043C\u0438\u043D\u0430\u0440.
    \u0412 1922 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    19 \u043B\u0435\u0442, \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0441\u0432\u043E\u0435 \u043F\u0435\u0440\u0432\u043E\u0435
    \u043C\u0438\u0440\u043E\u0432\u043E\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435,
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0432 \u043F\u0440\u0438\u043C\u0435\u0440
    \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u0443\u0435\u043C\u043E\u0439
    \u043F\u043E \u041B\u0435\u0431\u0435\u0433\u0443 \u0444\u0443\u043D\u043A\u0446\u0438\u0438,
    \u0440\u044F\u0434 \u0424\u0443\u0440\u044C\u0435 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0440\u0430\u0441\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u043F\u043E\u0447\u0442\u0438
    \u0432\u0441\u044E\u0434\u0443. \u042D\u0442\u043E \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u043E
    \u0435\u043C\u0443 \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u0443\u044E
    \u0441\u043B\u0430\u0432\u0443.  \u041E\u043A\u043E\u043D\u0447\u0438\u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u0432 1925 \u0433\u043E\u0434\u0443, \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u0443\u0440\u0443
    \u043A \u041B\u0443\u0437\u0438\u043D\u0443. \u041D\u0430\u0443\u0447\u043D\u0443\u044E
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u043E\u043D
    \u0443\u0441\u043F\u0435\u0448\u043D\u043E \u0441\u043E\u0447\u0435\u0442\u0430\u043B
    \u0441 \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439,
    \u0440\u0430\u0431\u043E\u0442\u0430\u044F \u0441 1922 \u043F\u043E 1925 \u0433\u043E\u0434
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0444\u0438\u0437\u0438\u043A\u0438
    \u0432 \u041F\u043E\u0442\u044B\u043B\u0438\u0445\u0438\u043D\u0441\u043A\u043E\u0439
    \u043E\u043F\u044B\u0442\u043D\u043E-\u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435, \u0447\u0442\u043E \u043E\u043A\u0430\u0437\u0430\u043B\u043E
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0435\u0433\u043E \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u043D\u0430
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435.  ### \U0001F30D
    \u0421\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435 \u0438 \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435  \u0412 1929 \u0433\u043E\u0434\u0443
    \u0432 \u0436\u0438\u0437\u043D\u0438 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430
    \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E \u0432\u0430\u0436\u043D\u043E\u0435
    \u0441\u043E\u0431\u044B\u0442\u0438\u0435, \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0432\u0448\u0435\u0435
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0435 \u0441\u0447\u0430\u0441\u0442\u044C\u0435
    \u043D\u0430 \u043F\u043E\u043B\u0432\u0435\u043A\u0430. \u041E\u043D \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043B
    \u043B\u043E\u0434\u043E\u0447\u043D\u043E\u0435 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435
    \u043F\u043E \u0412\u043E\u043B\u0433\u0435 \u0438 \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B
    \u0432 \u043F\u043E\u043F\u0443\u0442\u0447\u0438\u043A\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u041F\u0430\u0432\u043B\u0430 \u0421\u0435\u0440\u0433\u0435\u0435\u0432\u0438\u0447\u0430
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u0432\u0430. \u0421
    \u044D\u0442\u043E\u0439 \u043F\u043E\u0435\u0437\u0434\u043A\u0438 \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C
    \u0438\u0445 \u043D\u0435\u0440\u0430\u0437\u0440\u044B\u0432\u043D\u0430\u044F
    \u0438 \u0442\u0440\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0434\u0440\u0443\u0436\u0431\u0430, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0441\u0430\u043C \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u043E\u0441\u043D\u043E\u0432\u043E\u0439
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C
    \"\u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C \u043F\u0440\u0435\u0438\u0441\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u0441\u0447\u0430\u0441\u0442\u044C\u044F\".  \u0412 1930\u20131931 \u0433\u043E\u0434\u0430\u0445
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0441\u0432\u043E\u044E \u043F\u0435\u0440\u0432\u0443\u044E \u0437\u0430\u0433\u0440\u0430\u043D\u0438\u0447\u043D\u0443\u044E
    \u043F\u043E\u0435\u0437\u0434\u043A\u0443, \u043F\u043E\u0441\u0435\u0442\u0438\u0432
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0446\u0435\u043D\u0442\u0440\u044B \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435,
    \u041C\u044E\u043D\u0445\u0435\u043D\u0435 \u0438 \u041F\u0430\u0440\u0438\u0436\u0435,
    \u0433\u0434\u0435 \u043E\u0431\u0449\u0430\u043B\u0441\u044F \u0441 \u0414\u0430\u0432\u0438\u0434\u043E\u043C
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C, \u0420\u0438\u0445\u0430\u0440\u0434\u043E\u043C
    \u041A\u0443\u0440\u0430\u043D\u0442\u043E\u043C, \u041C\u043E\u0440\u0438\u0441\u043E\u043C
    \u0424\u0440\u0435\u0448\u0435 \u0438 \u0434\u0440\u0443\u0433\u0438\u043C\u0438
    \u0441\u0432\u0435\u0442\u0438\u043B\u0430\u043C\u0438 \u043D\u0430\u0443\u043A\u0438.
    \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C, \u043E\u043D \u0443\u0436\u0435
    \u0432 28 \u043B\u0435\u0442 \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u041C\u0413\u0423 , \u0430 \u0432 1935 \u0433\u043E\u0434\u0443 \u2014 \u0437\u0430\u0432\u0435\u0434\u0443\u044E\u0449\u0438\u043C
    \u043F\u0435\u0440\u0432\u043E\u0439 \u0432 \u0421\u0421\u0421\u0420 \u043A\u0430\u0444\u0435\u0434\u0440\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.
    \u0412 1939 \u0433\u043E\u0434\u0443, \u0432 35 \u043B\u0435\u0442, \u043E\u043D
    \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0447\u043B\u0435\u043D\u043E\u043C \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u0421\u0421\u0421\u0420.  ### \U0001F48D \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C: \u0431\u0440\u0430\u043A, \u0434\u0440\u0443\u0436\u0431\u0430
    \u0438 \u0441\u0435\u043C\u044C\u044F  \u0412 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u0435
    1942 \u0433\u043E\u0434\u0430, \u0432 \u0440\u0430\u0437\u0433\u0430\u0440 \u0412\u0435\u043B\u0438\u043A\u043E\u0439
    \u041E\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B, \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u0410\u043D\u043D\u0435
    \u0414\u043C\u0438\u0442\u0440\u0438\u0435\u0432\u043D\u0435 \u0415\u0433\u043E\u0440\u043E\u0432\u043E\u0439.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u043E\u0434\u043D\u043E\u043A\u043B\u0430\u0441\u0441\u043D\u0438\u0446\u0435\u0439
    \u043F\u043E \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0438 \u0420\u0435\u043F\u043C\u0430\u043D
    \u0438 \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0430, \u0447\u043B\u0435\u043D\u0430-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u0430
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A \u0414\u043C\u0438\u0442\u0440\u0438\u044F
    \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447\u0430 \u0415\u0433\u043E\u0440\u043E\u0432\u0430.
    \u0418\u0445 \u0431\u0440\u0430\u043A \u0434\u043B\u0438\u043B\u0441\u044F 45
    \u043B\u0435\u0442. \u0421\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0434\u0435\u0442\u0435\u0439 \u0443 \u043D\u0438\u0445 \u043D\u0435 \u0431\u044B\u043B\u043E,
    \u043D\u043E \u043E\u043D\u0438 \u0432\u043E\u0441\u043F\u0438\u0442\u044B\u0432\u0430\u043B\u0438
    \u043F\u0430\u0441\u044B\u043D\u043A\u0430 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430,
    \u041E. \u0421. \u0418\u0432\u0430\u0448\u0451\u0432\u0430-\u041C\u0443\u0441\u0430\u0442\u043E\u0432\u0430. 
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u0431\u044B\u043B
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u044D\u043F\u043E\u0445\u0438
    \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F: \u043E\u043D
    \u0445\u043E\u0434\u0438\u043B \u0432 \u043F\u043E\u0445\u043E\u0434\u044B, \u0441\u043F\u043B\u0430\u0432\u043B\u044F\u043B\u0441\u044F
    \u043D\u0430 \u0431\u0430\u0439\u0434\u0430\u0440\u043A\u0430\u0445, \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B
    \u043D\u0430 \u043B\u044B\u0436\u0430\u0445 \u043F\u043E 40-50 \u043A\u0438\u043B\u043E\u043C\u0435\u0442\u0440\u043E\u0432
    \u0438 \u0443\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u043B \u0437\u0430\u043F\u043B\u044B\u0432\u044B
    \u0432 \u043B\u0435\u0434\u044F\u043D\u043E\u0439 \u0432\u043E\u0434\u0435. 
    ### \U0001F468\u200D\U0001F3EB \u0423\u0447\u0451\u043D\u044B\u0439-\u043F\u0440\u043E\u0441\u0432\u0435\u0442\u0438\u0442\u0435\u043B\u044C:
    \u0448\u043A\u043E\u043B\u0430, \u043E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u044B
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B 
    \u041F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0431\u044B\u043B\u0430
    \u0434\u043B\u044F \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430
    \u043D\u0435 \u043C\u0435\u043D\u0435\u0435 \u0432\u0430\u0436\u043D\u0430, \u0447\u0435\u043C
    \u043D\u0430\u0443\u0447\u043D\u0430\u044F. \u0412 1963 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u0438\u043D\u0438\u0446\u0438\u0430\u0442\u043E\u0440\u043E\u0432 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B-\u0438\u043D\u0442\u0435\u0440\u043D\u0430\u0442\u0430
    \u211618 \u043F\u0440\u0438 \u041C\u0413\u0423 (\u043D\u044B\u043D\u0435 \u0421\u0423\u041D\u0426
    \u041C\u0413\u0423). \u041E\u043D \u043B\u0438\u0447\u043D\u043E \u0447\u0438\u0442\u0430\u043B
    \u0442\u0430\u043C \u043B\u0435\u043A\u0446\u0438\u0438, \u0432\u043E\u0434\u0438\u043B
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432 \u0432 \u043F\u043E\u0445\u043E\u0434\u044B
    \u0438 \u043C\u043D\u043E\u0433\u043E \u043B\u0435\u0442 \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u043B\u044F\u043B
    \u041F\u043E\u043F\u0435\u0447\u0438\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0439
    \u0441\u043E\u0432\u0435\u0442.  \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0436\u0438\u0437\u043D\u0438 \u0443 \u043D\u0435\u0433\u043E
    \u0440\u0430\u0437\u0432\u0438\u043B\u0430\u0441\u044C \u0431\u043E\u043B\u0435\u0437\u043D\u044C
    \u041F\u0430\u0440\u043A\u0438\u043D\u0441\u043E\u043D\u0430: \u043E\u043D \u043B\u0438\u0448\u0438\u043B\u0441\u044F
    \u0437\u0440\u0435\u043D\u0438\u044F, \u0440\u0435\u0447\u0438 \u0438 \u0431\u044B\u043B
    \u043E\u0431\u0435\u0437\u0434\u0432\u0438\u0436\u0435\u043D. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0434\u0430\u0436\u0435 \u0432 \u0442\u0430\u043A\u043E\u043C \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0438
    \u043E\u043D \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u043D\u044B\u043C
    \u0441\u0432\u043E\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C\u0438
    \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0431\u044B\u0442\u044C
    \u0434\u0443\u0445\u043E\u0432\u043D\u044B\u043C \u0446\u0435\u043D\u0442\u0440\u043E\u043C
    \u0441\u0432\u043E\u0435\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u044B.
    \u0410\u043D\u0434\u0440\u0435\u0439 \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u0443\u0448\u0435\u043B
    \u0438\u0437 \u0436\u0438\u0437\u043D\u0438 20 \u043E\u043A\u0442\u044F\u0431\u0440\u044F
    1987 \u0433\u043E\u0434\u0430 \u0432 \u041C\u043E\u0441\u043A\u0432\u0435, \u043E\u0441\u0442\u0430\u0432\u0438\u0432
    \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0438 \u0446\u0435\u043B\u0443\u044E
    \u043F\u043B\u0435\u044F\u0434\u0443 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432, \u0441\u0440\u0435\u0434\u0438
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0431\u043E\u043B\u0435\u0435 20
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u0432 \u0438 \u0447\u043B\u0435\u043D\u043E\u0432-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u0432."
  personalLifeEn: 
  shortBioRu: "\u0410\u043D\u0434\u0440\u0435\u0439 \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u2014 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    XX \u0432\u0435\u043A\u0430, \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0442 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0448\u0438\u0440\u043E\u043A\u0438\u0439 \u0441\u043F\u0435\u043A\u0442\u0440
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u043F\u0443\u0442\u044C \u043F\u043E\u043B\u043D\u044B \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0445
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043E\u0432 \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445
    \u043F\u0440\u043E\u0437\u0440\u0435\u043D\u0438\u0439.  ### \U0001F4DC \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B  \u0410\u043D\u0434\u0440\u0435\u0439
    \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    12 (25 \u043F\u043E \u043D\u043E\u0432\u043E\u043C\u0443 \u0441\u0442\u0438\u043B\u044E)
    \u0430\u043F\u0440\u0435\u043B\u044F 1903 \u0433\u043E\u0434\u0430 \u0432 \u0422\u0430\u043C\u0431\u043E\u0432\u0435.
    \u0415\u0433\u043E \u043C\u0430\u0442\u044C, \u041C\u0430\u0440\u0438\u044F \u042F\u043A\u043E\u0432\u043B\u0435\u0432\u043D\u0430
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430, tragically
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C \u043F\u0440\u0438
    \u0440\u043E\u0434\u0430\u0445. \u041E\u0442\u0435\u0446, \u041D\u0438\u043A\u043E\u043B\u0430\u0439
    \u041C\u0430\u0442\u0432\u0435\u0435\u0432\u0438\u0447 \u041A\u0430\u0442\u0430\u0435\u0432,
    \u0431\u044B\u043B \u0430\u0433\u0440\u043E\u043D\u043E\u043C\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0447\u0430\u0441\u0442\u043E \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0440\u0430\u0437\u044A\u0435\u0437\u0434\u0430\u0445 \u0438 \u043F\u043E\u0433\u0438\u0431
    \u0432 1919 \u0433\u043E\u0434\u0443 \u043D\u0430 \u042E\u0436\u043D\u043E\u043C
    \u0444\u0440\u043E\u043D\u0442\u0435 \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0413\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u043E\u0439 \u0432\u043E\u0439\u043D\u044B.
    \u0420\u043E\u0434\u0438\u0442\u0435\u043B\u0438 \u043D\u0435 \u0431\u044B\u043B\u0438
    \u0432\u0435\u043D\u0447\u0430\u043D\u044B, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430 \u043A\u0440\u0435\u0441\u0442\u0438\u043B
    \u0434\u044F\u0434\u044F, \u0437\u0430\u043F\u0438\u0441\u0430\u0432 \u0435\u0433\u043E
    \u043F\u043E\u0434 \u0441\u0432\u043E\u0435\u0439 \u0444\u0430\u043C\u0438\u043B\u0438\u0435\u0439
    \u2014 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432.  \u0412\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0435\u043C
    \u0410\u043D\u0434\u0440\u0435\u044F \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0430\u0441\u044C
    \u0441\u0435\u0441\u0442\u0440\u0430 \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u0440\u0438,
    \u0412\u0435\u0440\u0430 \u042F\u043A\u043E\u0432\u043B\u0435\u0432\u043D\u0430
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u043E\u0437\u0436\u0435 \u0443\u0441\u044B\u043D\u043E\u0432\u0438\u043B\u0430
    \u0435\u0433\u043E, \u0438 \u0441 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043E\u043D \u043F\u0440\u043E\u0436\u0438\u043B \u0434\u043E \u0441\u0430\u043C\u043E\u0439
    \u0435\u0451 \u0441\u043C\u0435\u0440\u0442\u0438 \u0432 1951 \u0433\u043E\u0434\u0443.
    \u0420\u0430\u043D\u043D\u0435\u0435 \u0434\u0435\u0442\u0441\u0442\u0432\u043E
    \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E \u0443\u0447\u0451\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0448\u043B\u043E \u0432 \u0440\u043E\u0434\u043E\u0432\u043E\u043C
    \u0438\u043C\u0435\u043D\u0438\u0438 \u0434\u0435\u0434\u0430 \u0432 \u0441\u0435\u043B\u0435
    \u0422\u0443\u043D\u043E\u0448\u043D\u0430 \u043F\u043E\u0434 \u042F\u0440\u043E\u0441\u043B\u0430\u0432\u043B\u0435\u043C.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C, \u0432 \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0435,
    \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u043E\u0439 \u0442\u0435\u0442\u0443\u0448\u043A\u0430\u043C\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0443\u0441\u0442\u0440\u043E\u0438\u043B\u0438
    \u0434\u043B\u044F \u043C\u0435\u0441\u0442\u043D\u044B\u0445 \u0434\u0435\u0442\u0435\u0439
    \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0443\u044E \u0448\u043A\u043E\u043B\u0443
    \u043F\u043E \u043D\u043E\u0432\u0435\u0439\u0448\u0438\u043C \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043C\u0435\u0442\u043E\u0434\u0438\u043A\u0430\u043C, \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u0435\u0433\u043E \u0440\u0430\u043D\u043D\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0434\u0430\u0440. \u0412 \u043F\u044F\u0442\u044C \u043B\u0435\u0442 \u043E\u043D
    \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B \u0437\u0430\u043A\u043E\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C
    \u0441\u0443\u043C\u043C\u044B \u043D\u0435\u0447\u0451\u0442\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B: 1 = 1\xB2, 1 + 3 = 2\xB2, 1 + 3 + 5 = 3\xB2 \u0438
    \u0442\u0430\u043A \u0434\u0430\u043B\u0435\u0435, \u0447\u0442\u043E \u0441\u0430\u043C
    \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u043D\u0430\u0437\u044B\u0432\u0430\u043B
    \u0441\u0432\u043E\u0435\u0439 \u043F\u0435\u0440\u0432\u043E\u0439 \xAB\u0440\u0430\u0434\u043E\u0441\u0442\u044C\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F\xBB.  ### \U0001F393 \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u043A\u0430\u043A \u0443\u0447\u0451\u043D\u043E\u0433\u043E  \u0412 1910 \u0433\u043E\u0434\u0443
    \u0412\u0435\u0440\u0430 \u042F\u043A\u043E\u0432\u043B\u0435\u0432\u043D\u0430
    \u043F\u0435\u0440\u0435\u0432\u0435\u0437\u043B\u0430 \u0410\u043D\u0434\u0440\u0435\u044F
    \u0432 \u041C\u043E\u0441\u043A\u0432\u0443, \u0433\u0434\u0435 \u043E\u043D
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0447\u0430\u0441\u0442\u043D\u0443\u044E
    \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u044E \u0415.\u0410. \u0420\u0435\u043F\u043C\u0430\u043D.
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0435
    \u0443\u0447\u0435\u0431\u043D\u043E\u0435 \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0435,
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043D\u043D\u043E\u0435
    \u043A\u0440\u0443\u0436\u043A\u043E\u043C \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439
    \u0438\u043D\u0442\u0435\u043B\u043B\u0438\u0433\u0435\u043D\u0446\u0438\u0438,
    \u0433\u0434\u0435 \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0438 \u0438 \u0434\u0435\u0432\u043E\u0447\u043A\u0438
    \u0443\u0447\u0438\u043B\u0438\u0441\u044C \u0432\u043C\u0435\u0441\u0442\u0435
    \u043F\u043E \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0435 \u043C\u0443\u0436\u0441\u043A\u043E\u0439
    \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0438. \u0413\u0438\u043C\u043D\u0430\u0437\u0438\u044F
    \u0434\u0430\u043B\u0430 \u0435\u043C\u0443 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u0440\u043E\u0447\u043D\u044B\u0435 \u0437\u043D\u0430\u043D\u0438\u044F,
    \u043D\u043E \u0438 \u0448\u0438\u0440\u043E\u0442\u0443 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432.
    \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0443\u0441\u043F\u0435\u0445\u0430\u043C
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u043E\u043D
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u044D\u0442\u0438\u043C
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u043C \u043D\u0430 \u043A\u043B\u0430\u0441\u0441
    \u0441\u0442\u0430\u0440\u0448\u0435, \u043E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u043B\u0438\u0441\u044C
    \u0442\u043E\u0447\u043D\u044B\u043C\u0438 \u043D\u0430\u0443\u043A\u0430\u043C\u0438.
    \u041E\u043D \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0441\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439, \u0441\u043E\u0446\u0438\u043E\u043B\u043E\u0433\u0438\u0435\u0439,
    \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0435\u0439 \u0438 \u0434\u0430\u0436\u0435
    \u043C\u0435\u0447\u0442\u0430\u043B \u0441\u0442\u0430\u0442\u044C \u043B\u0435\u0441\u043D\u0438\u0447\u0438\u043C.
    \u041F\u0435\u0440\u0432\u044B\u0439 \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u0434\u043E\u043A\u043B\u0430\u0434 17-\u043B\u0435\u0442\u043D\u0438\u0439
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u0441\u0434\u0435\u043B\u0430\u043B
    \u043D\u0435 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u0430 \u043D\u0430 \u0441\u0435\u043C\u0438\u043D\u0430\u0440\u0435 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0430
    \u0421.\u0412. \u0411\u0430\u0445\u0440\u0443\u0448\u0438\u043D\u0430, \u0433\u0434\u0435
    \u0432\u044B\u0441\u0442\u0443\u043F\u0438\u043B \u0441 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043F\u043E \u043D\u043E\u0432\u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u043C\u0443
    \u0437\u0435\u043C\u043B\u0435\u0432\u043B\u0430\u0434\u0435\u043D\u0438\u044E
    XV\u2013XVI \u0432\u0435\u043A\u043E\u0432, \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u0432
    \u0434\u043B\u044F \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B.  \u0412 1920 \u0433\u043E\u0434\u0443,
    \u0432 \u044D\u043F\u043E\u0445\u0443, \u043A\u043E\u0433\u0434\u0430 \u0432
    \u0432\u0443\u0437\u044B \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B\u0438
    \u0431\u0435\u0437 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u043E\u0432, \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u043D\u0430 \u0434\u0432\u0430 \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u044F:
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u2014 \u0432 \u041C\u043E\u0441\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u0438 \u043C\u0435\u0442\u0430\u043B\u043B\u0443\u0440\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u2014 \u0432 \u041C\u0435\u043D\u0434\u0435\u043B\u0435\u0435\u0432\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442. \u0423\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439 \u0432\u0441\u043A\u043E\u0440\u0435
    \u0432\u0437\u044F\u043B\u043E \u0432\u0435\u0440\u0445, \u0438 \u043E\u043D
    \u0446\u0435\u043B\u0438\u043A\u043E\u043C \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0443\u0447\u0451\u0431\u0435 \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. 
    \u0412 \u041C\u0413\u0423 \u0435\u043C\u0443 \u043F\u043E\u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u0438\u043B\u043E\u0441\u044C
    \u0443\u0447\u0438\u0442\u044C\u0441\u044F \u0443 \u0446\u0435\u043B\u043E\u0439
    \u043F\u043B\u0435\u044F\u0434\u044B \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u0432 \u0442\u043E\u043C
    \u0447\u0438\u0441\u043B\u0435 \u0443 \u041D.\u041D. \u041B\u0443\u0437\u0438\u043D\u0430,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u0441\u0447\u0438\u0442\u0430\u043B \u0441\u0432\u043E\u0438\u043C \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C. \u0423\u0436\u0435 \u0432 \u0441\u0442\u0443\u0434\u0435\u043D\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C,
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0432 \u0432 1922 \u0433\u043E\u0434\u0443
    \u043F\u0440\u0438\u043C\u0435\u0440 \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u0443\u0435\u043C\u043E\u0439
    \u043F\u043E \u041B\u0435\u0431\u0435\u0433\u0443 \u0444\u0443\u043D\u043A\u0446\u0438\u0438,
    \u0440\u044F\u0434 \u0424\u0443\u0440\u044C\u0435 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0440\u0430\u0441\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u043F\u043E\u0447\u0442\u0438
    \u0432\u0441\u044E\u0434\u0443.  \u041E\u043A\u043E\u043D\u0447\u0438\u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u0432 1925 \u0433\u043E\u0434\u0443 , \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u0443\u0440\u0443,
    \u0433\u0434\u0435 \u043D\u0430\u0447\u0430\u043B \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0430\u0442\u044C \u0441
    \u0410.\u042F. \u0425\u0438\u043D\u0447\u0438\u043D\u044B\u043C, \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u0432
    \u043C\u0435\u0442\u043E\u0434\u044B \u0442\u0435\u043E\u0440\u0438\u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u043A \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.
    \u042D\u0442\u043E \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043E\u0437\u043D\u0430\u043C\u0435\u043D\u043E\u0432\u0430\u043B\u043E \u043D\u0430\u0447\u0430\u043B\u043E
    \u043D\u043E\u0432\u043E\u0439 \u044D\u0440\u044B \u0432 \u044D\u0442\u043E\u0439
    \u043D\u0430\u0443\u043A\u0435.  ### \U0001F680 \u041D\u0430\u0443\u0447\u043D\u044B\u0439
    \u043F\u0443\u0442\u044C \u0438 \u043C\u0438\u0440\u043E\u0432\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u0412 1930\u20131931 \u0433\u043E\u0434\u0430\u0445 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u0441\u0442\u0430\u0436\u0438\u0440\u043E\u0432\u0430\u043B\u0441\u044F \u0432
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\u0445
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0430, \u041C\u044E\u043D\u0445\u0435\u043D\u0430
    \u0438 \u041F\u0430\u0440\u0438\u0436\u0430, \u0433\u0434\u0435 \u043E\u0431\u0449\u0430\u043B\u0441\u044F
    \u0441 \u0442\u0430\u043A\u0438\u043C\u0438 \u043A\u043E\u0440\u0438\u0444\u0435\u044F\u043C\u0438,
    \u043A\u0430\u043A \u0414. \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u0438
    \u0420. \u041A\u0443\u0440\u0430\u043D\u0442. \u0412 1931 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u041C\u0413\u0423 , \u0430 \u0432 1939 \u0433\u043E\u0434\u0443 \u2014 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u043C
    \u0410\u041D \u0421\u0421\u0421\u0420.  \u0412 1933 \u0433\u043E\u0434\u0443
    \u0443\u0432\u0438\u0434\u0435\u043B \u0441\u0432\u0435\u0442 \u0435\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434 \u2014 \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \xAB\u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u044F
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439\xBB,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435 \u044D\u0442\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438 \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u0435\u0440\u044B. \u042D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u0435\u043C
    \u0448\u0435\u0441\u0442\u043E\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430 , \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439, \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0432
    \u0435\u0451 \u0432 \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0443.  \u041D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430
    \u0431\u044B\u043B\u0438 \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435 \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0447\u043D\u044B.
    \u0412\u043E\u0442 \u043B\u0438\u0448\u044C \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438, \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u043D \u0432\u043D\u0451\u0441 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434: - **\u0422\u0435\u043E\u0440\u0438\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F:** \u0440\u0430\u0431\u043E\u0442\u044B
    \u043F\u043E \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0440\u044F\u0434\u0430\u043C, \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u0435\u0440\u044B,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    (\u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u0414\u0436.
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0435\u0440\u043E\u043C) \u0442\u0435\u043E\u0440\u0438\u0438
    \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0439. - **\u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430
    \u0438 \u0444\u0438\u0437\u0438\u043A\u0430:** \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043B\u043E\u043A\u0430\u043B\u044C\u043D\u043E-\u0438\u0437\u043E\u0442\u0440\u043E\u043F\u043D\u043E\u0439
    \u0442\u0443\u0440\u0431\u0443\u043B\u0435\u043D\u0442\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E \u0437\u0430\u043A\u043E\u043D\u0430
    \xAB\u0434\u0432\u0435 \u043F\u044F\u0442\u044B\u0445\xBB (\u0437\u0430\u043A\u043E\u043D
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430\u2013\u041E\u0431\u0443\u0445\u043E\u0432\u0430)
    \u0434\u043B\u044F \u0441\u043F\u0435\u043A\u0442\u0440\u0430 \u0442\u0443\u0440\u0431\u0443\u043B\u0435\u043D\u0442\u043D\u043E\u0441\u0442\u0438.
    - **\u0422\u0435\u043E\u0440\u0438\u044F \u0434\u0438\u043D\u0430\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C \u0438 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430:** \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0430
    \u043E\u0441\u043D\u043E\u0432 \u041A\u0410\u041C-\u0442\u0435\u043E\u0440\u0438\u0438
    (\u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430\u2013\u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430\u2013\u041C\u043E\u0437\u0435\u0440\u0430),
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u0412.\u0418. \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u043E\u043C
    13-\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u043E \u0441\u0443\u043F\u0435\u0440\u043F\u043E\u0437\u0438\u0446\u0438\u044F\u0445
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439.
    - **\u0422\u0435\u043E\u0440\u0438\u044F \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
    \u0438 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432:** \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0442\u0435\u043E\u0440\u0438\u0438 \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432, \u0447\u0442\u043E \u043D\u0430\u0448\u043B\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438.
    - **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043B\u043E\u0433\u0438\u043A\u0430 \u0438 \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u043A\u0430:**
    \u0432\u043D\u0451\u0441 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u0441\u043A\u0443\u044E
    \u043B\u043E\u0433\u0438\u043A\u0443 \u0438 \u0442\u0435\u043E\u0440\u0438\u044E
    \u043D\u0443\u043C\u0435\u0440\u0430\u0446\u0438\u0439, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u043A \u0430\u043D\u0430\u043B\u0438\u0437\u0443
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438 \u0440\u0435\u0447\u0438
    \u0438 \u0441\u0442\u0438\u0445\u043E\u0441\u043B\u043E\u0436\u0435\u043D\u0438\u044F. 
    ### \U0001F3C6 \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435, \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u043A\u0430
    \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0445 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043E\u0431\u0449\u0435\u0441\u0442\u0432,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0435
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0435 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E
    \u0438 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0443\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E
    \u043D\u0430\u0443\u043A. \u0415\u0433\u043E \u0437\u0430\u0441\u043B\u0443\u0433\u0438
    \u0431\u044B\u043B\u0438 \u043E\u0442\u043C\u0435\u0447\u0435\u043D\u044B \u0432\u044B\u0441\u0448\u0438\u043C\u0438
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    \u043D\u0430\u0433\u0440\u0430\u0434\u0430\u043C\u0438 \u0421\u0421\u0421\u0420:
    \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u0437\u0432\u0430\u043D\u0438\u044F \u0413\u0435\u0440\u043E\u044F \u0421\u043E\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0422\u0440\u0443\u0434\u0430, \u0441\u0435\u043C\u0438 \u043E\u0440\u0434\u0435\u043D\u043E\u0432
    \u041B\u0435\u043D\u0438\u043D\u0430, \u0430 \u0442\u0430\u043A\u0436\u0435 \u041B\u0435\u043D\u0438\u043D\u0441\u043A\u043E\u0439
    \u0438 \u0413\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0439.  \u041F\u043E\u043C\u0438\u043C\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B, \u043E\u043D \u0432\u043D\u0451\u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:
    - \u0411\u044B\u043B \u0438\u043D\u0438\u0446\u0438\u0430\u0442\u043E\u0440\u043E\u043C
    \u0438 \u0431\u0435\u0441\u0441\u043C\u0435\u043D\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u043F\u043E\u043F\u0435\u0447\u0438\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u0432\u0435\u0442\u0430 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B-\u0438\u043D\u0442\u0435\u0440\u043D\u0430\u0442\u0430
    \u211618 \u043F\u0440\u0438 \u041C\u0413\u0423 (\u043D\u044B\u043D\u0435 \u0421\u0423\u041D\u0426
    \u041C\u0413\u0423), \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u043E\u0439 \u0432
    1963 \u0433\u043E\u0434\u0443. - \u041E\u0441\u043D\u043E\u0432\u0430\u043B \u0438
    \u0431\u044B\u043B \u0437\u0430\u043C\u0435\u0441\u0442\u0438\u0442\u0435\u043B\u0435\u043C
    \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E \u0440\u0435\u0434\u0430\u043A\u0442\u043E\u0440\u0430
    \u043D\u0430\u0443\u0447\u043D\u043E-\u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0433\u043E
    \u0436\u0443\u0440\u043D\u0430\u043B\u0430 \u0434\u043B\u044F \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432
    \xAB\u041A\u0432\u0430\u043D\u0442\xBB. - \u0410\u0432\u0442\u043E\u0440 \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0445
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u0432 \u0438 \u0440\u0435\u0434\u0430\u043A\u0442\u043E\u0440
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432 \u0411\u043E\u043B\u044C\u0448\u043E\u0439
    \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0439 \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0438.
    - \u0421\u043E\u0437\u0434\u0430\u043B \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0443\u044E
    \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u0448\u043A\u043E\u043B\u0443, \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u0432
    \u043F\u043B\u0435\u044F\u0434\u0443 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0412.\u0418. \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430, \u0418.\u041C.
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430, \u042F.\u0413. \u0421\u0438\u043D\u0430\u044F
    \u0438 \u043C\u043D\u043E\u0433\u0438\u0445 \u0434\u0440\u0443\u0433\u0438\u0445. 
    \u0410\u043D\u0434\u0440\u0435\u0439 \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 \u041C\u043E\u0441\u043A\u0432\u0435 20 \u043E\u043A\u0442\u044F\u0431\u0440\u044F
    1987 \u0433\u043E\u0434\u0430, \u043E\u0441\u0442\u0430\u0432\u0438\u0432 \u043F\u043E\u0441\u043B\u0435
    \u0441\u0435\u0431\u044F \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435,
    \u0441\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043C\u043E\u0435 \u043F\u043E
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044E \u0441 \u0442\u0440\u0443\u0434\u0430\u043C\u0438
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u0443\u043C\u043E\u0432
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0430.
    \u0412 1994 \u0433\u043E\u0434\u0443 \u0420\u0410\u041D \u0443\u0447\u0440\u0435\u0434\u0438\u043B\u0430
    \u043F\u0440\u0435\u043C\u0438\u044E \u0435\u0433\u043E \u0438\u043C\u0435\u043D\u0438
    \u0437\u0430 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0410\u043D\u0434\u0440\u0435\u044F
    \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447\u0430 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430
    \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u0435\u043B\u0438\u043A\u0438\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u043F\u0440\u043E\u0437\u0440\u0435\u043D\u0438\u0439, \u043D\u043E \u0438 \u044F\u0440\u043A\u0438\u0445,
    \u0430 \u043F\u043E\u0440\u043E\u0439 \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0445
