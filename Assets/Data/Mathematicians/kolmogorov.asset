    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u044F \u043C\u0435\u0436\u0434\u0443
    \u0438\u043C\u0435\u043D\u0430\u043C\u0438 \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432
    \u0438 \u0441\u0430\u043C\u0438\u043C\u0438 \u043E\u0431\u044A\u0435\u043A\u0442\u0430\u043C\u0438. 
    ### \U0001F30D \u041C\u0435\u0436\u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0430\u0440\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u043A\u0430  \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u0432\u0441\u0435\u0433\u0434\u0430 \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043A \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u043C\u0443 \u043C\u0438\u0440\u0443.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u0437\u0430\u0442\u0440\u0430\u0433\u0438\u0432\u0430\u044E\u0442:
    *   **\u0411\u0438\u043E\u043B\u043E\u0433\u0438\u044E \u0438 \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u043A\u0443:**
    \u041E\u043D \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u043A \u0430\u043D\u0430\u043B\u0438\u0437\u0443
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438 \u0440\u0435\u0447\u0438
    \u0438 \u0441\u0442\u0438\u0445\u043E\u0441\u043B\u043E\u0436\u0435\u043D\u0438\u044F.
    *   **\u0422\u0435\u043E\u0440\u0438\u044E \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u044B
    \u0438 \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044C \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0430:**
    \u0415\u0433\u043E \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u0432 \u0432\u043E\u0435\u043D\u043D\u043E\u043C \u0434\u0435\u043B\u0435 \u0438
    \u043F\u0440\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u043E\u0441\u0442\u0438.
    *   **\u0418\u0441\u0442\u043E\u0440\u0438\u044E:** \u0415\u0433\u043E \u043F\u0435\u0440\u0432\u0430\u044F
    \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430,
    \u0441\u0434\u0435\u043B\u0430\u043D\u043D\u0430\u044F \u0432 17 \u043B\u0435\u0442,
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0430\u043D\u0430\u043B\u0438\u0437\u0443 \u043D\u043E\u0432\u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u0433\u043E
    \u0437\u0435\u043C\u043B\u0435\u0432\u043B\u0430\u0434\u0435\u043D\u0438\u044F. 
    \u041E\u0442\u0434\u0435\u043B\u044C\u043D\u043E\u0433\u043E \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F
    \u0437\u0430\u0441\u043B\u0443\u0436\u0438\u0432\u0430\u0435\u0442 \u0435\u0433\u043E
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435. \u041E\u043D
    \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0438 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u0442\u0435\u043B\u0435\u0439
    **\u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B-\u0438\u043D\u0442\u0435\u0440\u043D\u0430\u0442\u0430
    \u211618 \u043F\u0440\u0438 \u041C\u0413\u0423 (\u043D\u044B\u043D\u0435 \u0421\u0423\u041D\u0426
    \u041C\u0413\u0423)**, \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u043E\u0439
    \u0432 1963 \u0433\u043E\u0434\u0443. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0441\u0442\u043E\u044F\u043B \u0443 \u0438\u0441\u0442\u043E\u043A\u043E\u0432
    \u0436\u0443\u0440\u043D\u0430\u043B\u0430 \u0434\u043B\u044F \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432
    **\xAB\u041A\u0432\u0430\u043D\u0442\xBB** \u0438 \u0431\u044B\u043B \u0430\u0432\u0442\u043E\u0440\u043E\u043C
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u0432 \u0438 \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0442\u0430\u0442\u0435\u0439, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u0441\u0442\u0430\u0442\u044C\u0438
    **\xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\xBB** \u0432
    \u0411\u043E\u043B\u044C\u0448\u043E\u0439 \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0439
    \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0438.  \u0415\u0441\u043B\u0438
    \u0432\u044B \u0445\u043E\u0442\u0438\u0442\u0435 \u0433\u043B\u0443\u0431\u0436\u0435
    \u0438\u0437\u0443\u0447\u0438\u0442\u044C \u043A\u0430\u043A\u0443\u044E-\u043B\u0438\u0431\u043E
    \u0438\u0437 \u044D\u0442\u0438\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439
    \u0438\u043B\u0438 \u0443\u0437\u043D\u0430\u0442\u044C \u043E \u043A\u0430\u043A\u043E\u043C-\u0442\u043E
    \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u043C \u0442\u0440\u0443\u0434\u0435,
    \u0434\u0430\u0439\u0442\u0435 \u043C\u043D\u0435 \u0437\u043D\u0430\u0442\u044C."
  achievementsEn: 
  personalLifeRu: "\u0410\u043D\u0434\u0440\u0435\u0439 \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u043F\u0440\u043E\u0436\u0438\u043B
    \u0434\u043E\u043B\u0433\u0443\u044E \u0438 \u043D\u0435\u043E\u0431\u044B\u0447\u0430\u0439\u043D\u043E
    \u043D\u0430\u0441\u044B\u0449\u0435\u043D\u043D\u0443\u044E \u0436\u0438\u0437\u043D\u044C,
    \u0433\u0434\u0435 \u043B\u0438\u0447\u043D\u0430\u044F \u0441\u0443\u0434\u044C\u0431\u0430
    \u0442\u0435\u0441\u043D\u043E \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u043B\u0430\u0441\u044C
    \u0441 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u043C\u0438,
    \u0430 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438
    \u0431\u044B\u043B\u0438 \u0441\u0442\u043E\u043B\u044C \u0436\u0435 \u0433\u043B\u0443\u0431\u043E\u043A\u0438,
    \u043A\u0430\u043A \u0438 \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0434\u0435\u0438.  ### \U0001F476 \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435,
    \u0441\u0435\u043C\u044C\u044F \u0438 \u0434\u0435\u0442\u0441\u0442\u0432\u043E
    \u0432 \u0422\u0443\u043D\u043E\u0448\u043D\u0435  \u0410\u043D\u0434\u0440\u0435\u0439
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    25 \u0430\u043F\u0440\u0435\u043B\u044F 1903 \u0433\u043E\u0434\u0430 \u0432
    \u0422\u0430\u043C\u0431\u043E\u0432\u0435. \u0415\u0433\u043E \u043C\u0430\u0442\u044C,
    \u041C\u0430\u0440\u0438\u044F \u042F\u043A\u043E\u0432\u043B\u0435\u0432\u043D\u0430
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430, tragically
    tragically \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C \u043F\u0440\u0438
    \u0440\u043E\u0434\u0430\u0445. \u041E\u0442\u0435\u0446, \u041D\u0438\u043A\u043E\u043B\u0430\u0439
    \u041C\u0430\u0442\u0432\u0435\u0435\u0432\u0438\u0447 \u041A\u0430\u0442\u0430\u0435\u0432,
    \u0430\u0433\u0440\u043E\u043D\u043E\u043C \u043F\u043E \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044E,
    \u043D\u0435 \u0431\u044B\u043B \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u0436\u0435\u043D\u0430\u0442 \u043D\u0430 \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u0440\u0438
    \u0438 \u043F\u043E\u0433\u0438\u0431 \u0432 1919 \u0433\u043E\u0434\u0443 \u0432
    \u0413\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u043E\u0439 \u0432\u043E\u0439\u043D\u0435.
    \u041C\u0430\u043B\u044C\u0447\u0438\u043A\u0430 \u0443\u0441\u044B\u043D\u043E\u0432\u0438\u043B\u0430
    \u0435\u0433\u043E \u0442\u0435\u0442\u044F, \u0412\u0435\u0440\u0430 \u042F\u043A\u043E\u0432\u043B\u0435\u0432\u043D\u0430
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0438 \u0441\u0442\u0430\u043B\u0430 \u0435\u043C\u0443 \u0432\u0442\u043E\u0440\u043E\u0439
    \u043C\u0430\u0442\u0435\u0440\u044C\u044E.  \u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0410\u043D\u0434\u0440\u0435\u044F \u043F\u0440\u043E\u0448\u043B\u0438
    \u0432 \u0438\u043C\u0435\u043D\u0438\u0438 \u0434\u0435\u0434\u0430 \u0432 \u0441\u0435\u043B\u0435
    \u0422\u0443\u043D\u043E\u0448\u043D\u0430 \u043F\u043E\u0434 \u042F\u0440\u043E\u0441\u043B\u0430\u0432\u043B\u0435\u043C.
    \u0412\u0435\u0440\u0430 \u042F\u043A\u043E\u0432\u043B\u0435\u0432\u043D\u0430
    \u0443\u0441\u0442\u0440\u043E\u0438\u043B\u0430 \u0442\u0430\u043C \u0434\u043B\u044F
    \u043C\u0435\u0441\u0442\u043D\u044B\u0445 \u0434\u0435\u0442\u0435\u0439 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u043F\u043E \u043D\u043E\u0432\u0435\u0439\u0448\u0438\u043C
    \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043C\u0435\u0442\u043E\u0434\u0438\u043A\u0430\u043C \u0438 \u0434\u0430\u0436\u0435
    \u0438\u0437\u0434\u0430\u0432\u0430\u043B\u0430 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u043D\u044B\u0439
    \u0436\u0443\u0440\u043D\u0430\u043B \xAB\u0412\u0435\u0441\u0435\u043D\u043D\u0438\u0435
    \u043B\u0430\u0441\u0442\u043E\u0447\u043A\u0438\xBB. \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u043F\u044F\u0442\u0438 \u043B\u0435\u0442 \u0431\u0443\u0434\u0443\u0449\u0438\u0439
    \u0443\u0447\u0435\u043D\u044B\u0439 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0432 \u043D\u0435\u043C \u0441\u0432\u043E\u044E \u043F\u0435\u0440\u0432\u0443\u044E
    \"\u043D\u0430\u0443\u0447\u043D\u0443\u044E\" \u0440\u0430\u0431\u043E\u0442\u0443
    \u2014 \u043E\u043D \u0437\u0430\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E
    \u0441\u0443\u043C\u043C\u0430 \u043F\u0435\u0440\u0432\u044B\u0445 n \u043D\u0435\u0447\u0435\u0442\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u0434\u0430\u0435\u0442 n\xB2.  ### \U0001F393
    \u0423\u0447\u0451\u0431\u0430: \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u044F
