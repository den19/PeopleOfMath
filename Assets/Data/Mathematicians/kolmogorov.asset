  achievementsRu: "\u0410\u043D\u0434\u0440\u0435\u0439 \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043F\u043E \u0441\u0432\u043E\u0435\u043C\u0443 \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u0443
    \u0438 \u0433\u043B\u0443\u0431\u0438\u043D\u0435 \u0441\u0440\u0430\u0432\u043D\u0438\u043C\u043E
    \u0441 \u0442\u0440\u0443\u0434\u0430\u043C\u0438 \u041D\u044C\u044E\u0442\u043E\u043D\u0430,
    \u042D\u0439\u043B\u0435\u0440\u0430 \u0438\u043B\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u044C\u044E
    \u2014 \u043E\u043D \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B \u0442\u0435\u043E\u0440\u0438\u044E
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439, \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443,
    \u043B\u043E\u0433\u0438\u043A\u0443 \u0438 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0434\u0440\u0443\u0433\u0438\u0435 \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u044B,
    \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E \u0441\u043E\u0437\u0434\u0430\u0432
    \u043D\u043E\u0432\u044B\u0435 \u0440\u0430\u0437\u0434\u0435\u043B\u044B \u043D\u0430\u0443\u043A\u0438. 
    ### \U0001F3B2 \u0422\u0435\u043E\u0440\u0438\u044F \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439:
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430  \u0413\u043B\u0430\u0432\u043D\u044B\u043C
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u043F\u043E\u0434\u0432\u0438\u0433\u043E\u043C
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430, \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E,
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u044F
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439. 
    \u0412 1933 \u0433\u043E\u0434\u0443 \u0432\u044B\u0448\u043B\u0430 \u0435\u0433\u043E
    \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u044F **\xAB\u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439\xBB**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0430
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0432 \u044D\u0442\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438. \u0414\u043E \u044D\u0442\u043E\u0433\u043E
    \u0442\u0435\u043E\u0440\u0438\u044F \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439
    \u0431\u044B\u043B\u0430 \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435\u043C
    \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0445 \u043C\u0435\u0442\u043E\u0434\u043E\u0432.
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u0436\u0435, \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u0432
    \u043C\u043E\u0449\u043D\u044B\u0439 \u0430\u043F\u043F\u0430\u0440\u0430\u0442
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u0435\u0440\u044B, \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    \u0435\u0451 \u043A\u0430\u043A \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0443 \u043D\u0430\u0440\u0430\u0432\u043D\u0435
    \u0441 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439 \u0438\u043B\u0438
    \u0430\u043B\u0433\u0435\u0431\u0440\u043E\u0439. \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0447\u0430\u0441\u0442\u043E \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u043A\u0430\u043A \u0440\u0435\u0448\u0435\u043D\u0438\u0435 **\u0448\u0435\u0441\u0442\u043E\u0439
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430**,
    \u043A\u0430\u0441\u0430\u044E\u0449\u0435\u0439\u0441\u044F \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u0438
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D. 
    **\u0421\u0443\u0442\u044C \u0435\u0433\u043E \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u043A\u0438**
    \u043F\u0440\u043E\u0441\u0442\u0430 \u0438 \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u0430.
    \u041E\u043D \u0432\u0432\u0435\u043B \u0431\u0430\u0437\u043E\u0432\u0443\u044E
    \u0442\u0440\u043E\u0439\u043A\u0443 \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432:
    *   **\u041F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u044B\u0445 \u0441\u043E\u0431\u044B\u0442\u0438\u0439
    (\u03A9):** \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0432\u0441\u0435\u0445
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0445 \u0438\u0441\u0445\u043E\u0434\u043E\u0432
    \u043E\u043F\u044B\u0442\u0430. *   **\u0421\u0438\u0433\u043C\u0430-\u0430\u043B\u0433\u0435\u0431\u0440\u0430
    \u0441\u043E\u0431\u044B\u0442\u0438\u0439 (F):** \u0441\u0438\u0441\u0442\u0435\u043C\u0430
    \u0432\u0441\u0435\u0445 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0443\u044E\u0449\u0438\u0445
    \u043D\u0430\u0441 \u043F\u043E\u0434\u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    \u03A9 (\u0441\u043E\u0431\u044B\u0442\u0438\u0439), \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438
    \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u043A\u0430\u043A \u0441 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430\u043C\u0438.
    *   **\u0412\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u043D\u0430\u044F
    \u043C\u0435\u0440\u0430 (P):** \u0444\u0443\u043D\u043A\u0446\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043A\u0430\u0436\u0434\u043E\u043C\u0443 \u0441\u043E\u0431\u044B\u0442\u0438\u044E
    \u0438\u0437 F \u0441\u0442\u0430\u0432\u0438\u0442 \u0432 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435
    \u0447\u0438\u0441\u043B\u043E \u043E\u0442 0 \u0434\u043E 1, \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u044F\u044E\u0449\u0435\u0435
    \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u043C.  \u042D\u0442\u0430 \u0441\u0445\u0435\u043C\u0430,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F \u043A\u0430\u043A **\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u043D\u043E\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E `(\u03A9,
    F, P)`**, \u0441\u0442\u0430\u043B\u0430 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u043C
    \u044F\u0437\u044B\u043A\u043E\u043C \u0434\u043B\u044F \u0432\u0441\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.  \u041D\u043E
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u043B\u0441\u044F
    \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u043A\u043E\u0439. \u041E\u043D
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0442\u0435\u043E\u0440\u0438\u0438 **\u043C\u0430\u0440\u043A\u043E\u0432\u0441\u043A\u0438\u0445
    \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0445 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0432
    \u0441 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u043C \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C**.
    \u0412 \u0440\u0430\u0431\u043E\u0442\u0435 1931 \u0433\u043E\u0434\u0430 \u043E\u043D
    \u0432\u044B\u0432\u0435\u043B \u043F\u0440\u044F\u043C\u044B\u0435 \u0438 \u043E\u0431\u0440\u0430\u0442\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F (\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430\u2013\u0424\u043E\u043A\u043A\u0435\u0440\u0430\u2013\u041F\u043B\u0430\u043D\u043A\u0430),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442
    \u044D\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439
    \u0432 \u0442\u0430\u043A\u0438\u0445 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0430\u0445,
    \u0441\u043E\u0435\u0434\u0438\u043D\u0438\u0432 \u0438\u0434\u0435\u0438 \u0438\u0437
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0442\u0435\u043F\u043B\u043E\u0442\u044B,
    \u0431\u0440\u043E\u0443\u043D\u043E\u0432\u0441\u043A\u043E\u0433\u043E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u0438 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0445 \u0431\u043B\u0443\u0436\u0434\u0430\u043D\u0438\u0439.
    \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u043E\u0442\u043F\u0440\u0430\u0432\u043D\u043E\u0439
    \u0442\u043E\u0447\u043A\u043E\u0439 \u0434\u043B\u044F \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. 
    ### \U0001F30C \u041A\u0410\u041C-\u0442\u0435\u043E\u0440\u0438\u044F: \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u0432 \u043D\u0435\u0431\u0435\u0441\u043D\u043E\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435 
    \u0412\u0442\u043E\u0440\u044B\u043C, \u043D\u0435 \u043C\u0435\u043D\u0435\u0435
    \u0437\u043D\u0430\u0447\u0438\u043C\u044B\u043C \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u043C
    \u0441\u0442\u0430\u043B\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0434\u0438\u043D\u0430\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u0438\u0441\u0442\u0435\u043C,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F \u043A\u0430\u043A **\u041A\u0410\u041C-\u0442\u0435\u043E\u0440\u0438\u044F**
    (\u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u2013\u0410\u0440\u043D\u043E\u043B\u044C\u0434\u2013\u041C\u043E\u0437\u0435\u0440). 
    \u041F\u0440\u043E\u0431\u043B\u0435\u043C\u0430 \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438
    \u0421\u043E\u043B\u043D\u0435\u0447\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u043C\u0443\u0447\u0438\u043B\u0430 \u0443\u0447\u0435\u043D\u044B\u0445 \u0441\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D \u041D\u044C\u044E\u0442\u043E\u043D\u0430.
    \u041C\u043E\u0436\u043D\u043E \u043B\u0438 \u0431\u044B\u0442\u044C \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u044B\u043C,
    \u0447\u0442\u043E \u043F\u043B\u0430\u043D\u0435\u0442\u044B \u043D\u0435 \u0443\u043F\u0430\u0434\u0443\u0442
    \u043D\u0430 \u0421\u043E\u043B\u043D\u0446\u0435 \u0438\u043B\u0438 \u043D\u0435
    \u0431\u0443\u0434\u0443\u0442 \u0432\u044B\u0431\u0440\u043E\u0448\u0435\u043D\u044B
    \u0432 \u043A\u043E\u0441\u043C\u043E\u0441 \u0447\u0435\u0440\u0435\u0437 \u043C\u0438\u043B\u043B\u0438\u043E\u043D\u044B
    \u043B\u0435\u0442? \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u044D\u0442\u0430 \u0437\u0430\u0434\u0430\u0447\u0430 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0441\u043B\u043E\u0436\u043D\u0430.  \u0412 1954 \u0433\u043E\u0434\u0443 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0440\u043E\u0440\u044B\u0432.
    \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E
    \u043D\u043E\u0432\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0435\u0442\u043E\u0434, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C, \u0447\u0442\u043E \u0434\u043B\u044F
    **\u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u0430** \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0441\u043B\u043E\u0432\u0438\u0439 (\u0432 \u0441\u043C\u044B\u0441\u043B\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u0435\u0440\u044B) \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438
    \u0441\u0438\u0441\u0442\u0435\u043C, \u0431\u043B\u0438\u0437\u043A\u0438\u0445
    \u043A \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u0443\u0435\u043C\u044B\u043C
    (\u0442.\u0435. \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0440\u0435\u0448\u0430\u0435\u043C\u044B\u043C),
    \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u044B\u043C\u0438
    \u0438 \u043D\u0435 \u043F\u043E\u043A\u0438\u0434\u0430\u044E\u0442 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u043D\u0443\u044E \u043E\u0431\u043B\u0430\u0441\u0442\u044C
    \u0444\u0430\u0437\u043E\u0432\u043E\u0433\u043E \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430.
    \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u0434\u0430\u043B\u0430
    \u043D\u0430\u0434\u0435\u0436\u0434\u0443 \u043D\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \xAB\u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
    \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438\xBB, \u043A\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u043B
    \u0435\u0451 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435. \u0422\u0435\u043E\u0440\u0438\u044F
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0437\u0436\u0435 \u0434\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C \u0412.\u0418.
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u043E\u043C \u0438 \u042E. \u041C\u043E\u0437\u0435\u0440\u043E\u043C,
    \u0438 \u0442\u0435\u043F\u0435\u0440\u044C \u043D\u043E\u0441\u0438\u0442 \u0438\u0445
    \u043E\u0431\u0449\u0438\u0435 \u0438\u043C\u0435\u043D\u0430.  ### \U0001F30A
    \u0422\u0435\u043E\u0440\u0438\u044F \u0442\u0443\u0440\u0431\u0443\u043B\u0435\u043D\u0442\u043D\u043E\u0441\u0442\u0438:
    \u0437\u0430\u043A\u043E\u043D \xAB\u0434\u0432\u0435 \u043F\u044F\u0442\u044B\u0445\xBB 
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u0442\u0430\u043A\u0436\u0435
    \u0432\u043D\u0435\u0441 \u0440\u0435\u0448\u0430\u044E\u0449\u0438\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0444\u0438\u0437\u0438\u043A\u0443, \u0441\u043E\u0437\u0434\u0430\u0432
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u0442\u0443\u0440\u0431\u0443\u043B\u0435\u043D\u0442\u043D\u043E\u0441\u0442\u0438.
    \u0412 1941 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0440\u0430\u0431\u043E\u0442\u044B, \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0434\u0430\u043B \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435 \u043B\u043E\u043A\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B \u0442\u0443\u0440\u0431\u0443\u043B\u0435\u043D\u0442\u043D\u043E\u0433\u043E
    \u043F\u043E\u0442\u043E\u043A\u0430.  \u0415\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    **\u0437\u0430\u043A\u043E\u043D \xAB4/5\xBB** (\u0438\u043B\u0438 \xAB\u0434\u0432\u0435
    \u043F\u044F\u0442\u044B\u0445\xBB) \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0434\u043B\u044F \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u043D\u043E\u0433\u043E \u043C\u043E\u043C\u0435\u043D\u0442\u0430
    \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438 \u0432 \u0438\u0437\u043E\u0442\u0440\u043E\u043F\u043D\u043E\u0439
    \u0442\u0443\u0440\u0431\u0443\u043B\u0435\u043D\u0442\u043D\u043E\u0441\u0442\u0438
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u0430\u044F
    \u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u044C, \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u043C\u0430\u044F
    \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E
    \u0434\u0438\u0441\u0441\u0438\u043F\u0430\u0446\u0438\u0438 \u044D\u043D\u0435\u0440\u0433\u0438\u0438.
    \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u0439 \u0438
    \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0439 \u0442\u043E\u0447\u043D\u044B\u0439
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0442\u0443\u0440\u0431\u0443\u043B\u0435\u043D\u0442\u043D\u043E\u0441\u0442\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440
    \u043B\u0435\u0436\u0438\u0442 \u0432 \u043E\u0441\u043D\u043E\u0432\u0435 \u043C\u043D\u043E\u0433\u0438\u0445
    \u043C\u043E\u0434\u0435\u043B\u0435\u0439.  ### \U0001F9E0 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043B\u043E\u0433\u0438\u043A\u0430, \u0442\u0435\u043E\u0440\u0438\u044F \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
    \u0438 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u044B  \u041A\u0440\u0443\u0433
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430
    \u043F\u0440\u043E\u0441\u0442\u0438\u0440\u0430\u043B\u0441\u044F \u0434\u0430\u043B\u0435\u043A\u043E
    \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u044B \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043B\u043E\u0433\u0438\u043A\u0430:** \u0415\u0449\u0451 \u0432 1925 \u0433\u043E\u0434\u0443,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C,
    \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0440\u0430\u0431\u043E\u0442\u0443, \u0433\u0434\u0435 \u0434\u0430\u043B \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u0441\u043A\u0443\u044E
    \u0438\u043D\u0442\u0435\u0440\u043F\u0440\u0435\u0442\u0430\u0446\u0438\u044E
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043B\u043E\u0433\u0438\u043A\u0438
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0441\u0442\u044C
    \u043E\u0434\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043F\u043E
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044E \u043A \u0434\u0440\u0443\u0433\u043E\u0439,
    \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u0432 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0413\u0451\u0434\u0435\u043B\u044F.
    \u041F\u043E\u0437\u0436\u0435 \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0438\u043D\u0442\u0435\u0440\u043F\u0440\u0435\u0442\u0430\u0446\u0438\u044E
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438 \u043A\u0430\u043A \xAB\u043B\u043E\u0433\u0438\u043A\u0438
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0437\u0430\u0434\u0430\u0447\xBB,
    \u0432\u0432\u0435\u0434\u044F \u0432 \u0434\u0438\u0441\u043A\u0443\u0440\u0441
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
    (\u0437\u0430\u0434\u0430\u0447\u0438). *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438:** \u0412 1960-\u0445
    \u0433\u043E\u0434\u0430\u0445 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    **\u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438**,
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u0432 \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 **\u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u043E\u0431\u044A\u0435\u043A\u0442\u0430** (\u043A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0441\u043A\u0430\u044F
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C). \u042D\u0442\u043E \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438, \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0435
    \u0434\u043B\u044F \u0435\u0433\u043E \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    (\u0442.\u0435. \u0434\u043B\u0438\u043D\u0430 \u043A\u0440\u0430\u0442\u0447\u0430\u0439\u0448\u0435\u0439
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043C\u043E\u0436\u0435\u0442 \u044D\u0442\u043E\u0442 \u043E\u0431\u044A\u0435\u043A\u0442
    \u0432\u043E\u0441\u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0441\u0442\u0438).
    \u042D\u0442\u0430 \u0442\u0435\u043E\u0440\u0438\u044F \u043D\u0430\u0448\u043B\u0430
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0432 \u0441\u0430\u043C\u044B\u0445
    \u0440\u0430\u0437\u043D\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445
    \u2014 \u043E\u0442 \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
    \u0434\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u043D\u0443\u043C\u0435\u0440\u0430\u0446\u0438\u0439:** \u0412 1954 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0442\u0435\u043E\u0440\u0438\u0438 \u043D\u0443\u043C\u0435\u0440\u0430\u0446\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u043B\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
