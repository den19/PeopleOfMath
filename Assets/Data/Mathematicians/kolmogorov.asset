  id: kolmogorov
  wikiTitleRu: "\u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432, \u0410\u043D\u0434\u0440\u0435\u0439"
  wikidataId: Q153224
  fullNameRu: "\u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432, \u0410\u043D\u0434\u0440\u0435\u0439
    \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447"
  fullNameEn: 
  birthDate: 
