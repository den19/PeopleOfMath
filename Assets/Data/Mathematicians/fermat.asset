  achievementsRu: "\u0425\u043E\u0442\u044F \u0432 \u043F\u0440\u043E\u0448\u043B\u043E\u043C
    \u043E\u0442\u0432\u0435\u0442\u0435 \u043C\u044B \u0443\u0436\u0435 \u043A\u043E\u0441\u043D\u0443\u043B\u0438\u0441\u044C
    \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0445 \u0432\u0435\u0445, \u0437\u0434\u0435\u0441\u044C
    \u044F \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044E **\u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439,
    \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439
    \u0438 \u0441\u0442\u0440\u043E\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u043E\u0431\u0437\u043E\u0440** \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439
    \u041F\u044C\u0435\u0440\u0430 \u0424\u0435\u0440\u043C\u0430. \u0415\u0433\u043E
    \u0432\u043A\u043B\u0430\u0434 \u0443\u043D\u0438\u043A\u0430\u043B\u0435\u043D
    \u0442\u0435\u043C, \u0447\u0442\u043E \u043E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0441\u0440\u0430\u0437\u0443 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432 \u0432\u044B\u0441\u0448\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0447\u0430\u0441\u0442\u043E
    \u043E\u043F\u0435\u0440\u0435\u0436\u0430\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F. 
    \u0412\u043E\u0442 \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F,
    \u0440\u0430\u0437\u0431\u0438\u0442\u044B\u0435 \u043F\u043E \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C
    \u043D\u0430\u0443\u043A\u0438 \u0441 \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u044B\u043C
    \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u0435\u043C \u0441\u0443\u0442\u0438
    \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u0430. 
    ### 1. \u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B (\u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434) \u0424\u0435\u0440\u043C\u0430 \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \xAB\u043E\u0442\u0446\u043E\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B\xBB. \u041E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0440\u0435\u0448\u0430\u043B \u0437\u0430\u0434\u0430\u0447\u0438, \u0430 \u0441\u043E\u0437\u0434\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434\u043E\u043B\u043E\u0433\u0438\u044E \u0434\u043B\u044F
    \u0438\u0445 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430. 
    *   **\u0412\u0435\u043B\u0438\u043A\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0424\u0435\u0440\u043C\u0430 (\u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F):**     
    *   *\u0421\u0443\u0442\u044C:* \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
    \u0447\u0442\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \\(
    a^n + b^n = c^n \\) \u043D\u0435 \u0438\u043C\u0435\u0435\u0442 \u043D\u0435\u043D\u0443\u043B\u0435\u0432\u044B\u0445
    \u0446\u0435\u043B\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u043F\u0440\u0438 \\( n > 2 \\).    
    *   *\u0414\u0435\u0442\u0430\u043B\u0438:* \u0424\u0435\u0440\u043C\u0430 \u0437\u0430\u043F\u0438\u0441\u0430\u043B
    \u044D\u0442\u043E \u043D\u0430 \u043F\u043E\u043B\u044F\u0445 \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\xBB
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u0441 \u043F\u043E\u043C\u0435\u0442\u043A\u043E\u0439,
    \u0447\u0442\u043E \u043D\u0430\u0448\u0435\u043B \xAB\u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435
    \u0447\u0443\u0434\u0435\u0441\u043D\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\xBB.
    \u042D\u0442\u043E \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435
    \u0441\u0442\u0438\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B\u043E
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B \u043D\u0430
    350 \u043B\u0435\u0442. \u0414\u043E\u043A\u0430\u0437\u0430\u043D\u043E \u042D\u043D\u0434\u0440\u044E
    \u0423\u0430\u0439\u043B\u0441\u043E\u043C \u0432 1994 \u0433\u043E\u0434\u0443
    \u0441 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0438\u0432\u044B\u0445 \u0438 \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u044B\u0445
    \u0444\u043E\u0440\u043C (\u0442\u043E\u0433\u043E, \u0447\u0435\u0433\u043E
    \u0432 XVII \u0432\u0435\u043A\u0435 \u043D\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E).
    \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u0441\u0447\u0438\u0442\u0430\u044E\u0442, \u0447\u0442\u043E \u0441\u0430\u043C
    \u0424\u0435\u0440\u043C\u0430 \u043C\u043E\u0433 \u0438\u043C\u0435\u0442\u044C
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043B\u044F \\( n=4 \\), \u043D\u043E
    \u043E\u0448\u0438\u0431\u0441\u044F \u0432 \u043E\u0431\u0449\u0435\u043C \u0441\u043B\u0443\u0447\u0430\u0435.
    *   **\u041C\u0430\u043B\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0424\u0435\u0440\u043C\u0430:**     *   *\u0421\u0443\u0442\u044C:* \u0415\u0441\u043B\u0438
    \\( p \\) \u2014 \u043F\u0440\u043E\u0441\u0442\u043E\u0435 \u0447\u0438\u0441\u043B\u043E,
    \u0430 \\( a \\) \u2014 \u0446\u0435\u043B\u043E\u0435 \u0447\u0438\u0441\u043B\u043E,
    \u043D\u0435 \u0434\u0435\u043B\u044F\u0449\u0435\u0435\u0441\u044F \u043D\u0430
    \\( p \\), \u0442\u043E \\( a^{p-1} \\equiv 1 \\pmod{p} \\).     *   *\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435:*
    \u042D\u0442\u043E \u043E\u0441\u043D\u043E\u0432\u0430 \u0434\u043B\u044F \u0442\u0435\u0441\u0442\u043E\u0432
    \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u0443 \u0447\u0438\u0441\u0435\u043B
    (\u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438, \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043B\u0438 \u0447\u0438\u0441\u043B\u043E \u043F\u0440\u043E\u0441\u0442\u044B\u043C)
    \u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u0441 \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u043C \u043A\u043B\u044E\u0447\u043E\u043C
    (\u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C RSA). \u0424\u0435\u0440\u043C\u0430
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u0435\u0451
    \u0434\u043B\u044F \u0444\u0430\u043A\u0442\u043E\u0440\u0438\u0437\u0430\u0446\u0438\u0438
    \u0431\u043E\u043B\u044C\u0448\u0438\u0445 \u0447\u0438\u0441\u0435\u043B. *  
    **\u041C\u0435\u0442\u043E\u0434 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E
    \u0441\u043F\u0443\u0441\u043A\u0430:**     *   *\u0421\u0443\u0442\u044C:* \u042D\u0442\u043E
    \u043C\u043E\u0449\u043D\u044B\u0439 \u043C\u0435\u0442\u043E\u0434 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043E\u0442 \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u043E\u0433\u043E. \u0424\u0435\u0440\u043C\u0430
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B, \u0447\u0442\u043E \u0435\u0441\u043B\u0438
    \u0434\u043B\u044F \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0446\u0435\u043B\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u043E\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435, \u0442\u043E \u0432\u0441\u0435\u0433\u0434\u0430
    \u043C\u043E\u0436\u043D\u043E \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C
    **\u043C\u0435\u043D\u044C\u0448\u0435\u0435** \u0446\u0435\u043B\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u043E\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435. \u041F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E \u0443\u043C\u0435\u043D\u044C\u0448\u0430\u0442\u044C
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0435 \u0447\u0438\u0441\u043B\u0430
    \u043D\u0435\u043B\u044C\u0437\u044F, \u043F\u0440\u0438\u0445\u043E\u0434\u0438\u043C
    \u043A \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u044E.    
    *   *\u041F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435:* \u0421 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u044D\u0442\u043E\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u0430 \u043E\u043D
    \u0441\u0442\u0440\u043E\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E **\u043F\u043B\u043E\u0449\u0430\u0434\u044C \u043F\u0440\u044F\u043C\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430 \u0441
    \u0446\u0435\u043B\u044B\u043C\u0438 \u0441\u0442\u043E\u0440\u043E\u043D\u0430\u043C\u0438
    \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u043C**
    (\u043E\u0442\u0441\u044E\u0434\u0430 \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u0430
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \\( n=4 \\) \u0432 \u0412\u0435\u043B\u0438\u043A\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u0435).
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E \u0441\u0443\u043C\u043C\u0435
    \u0434\u0432\u0443\u0445 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432:**    
    *   *\u0421\u0443\u0442\u044C:* \u041F\u0440\u043E\u0441\u0442\u043E\u0435 \u0447\u0438\u0441\u043B\u043E
    \\( p \\) \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043C\u043E
    \u0432 \u0432\u0438\u0434\u0435 \u0441\u0443\u043C\u043C\u044B \u0434\u0432\u0443\u0445
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432 \\( p = x^2 + y^2 \\)
    \u0442\u043E\u0433\u0434\u0430 \u0438 \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u043E\u0433\u0434\u0430,
    \u043A\u043E\u0433\u0434\u0430 \\( p = 2 \\) \u0438\u043B\u0438 \\( p \\equiv
    1 \\pmod{4} \\).     *   *\u0414\u0435\u0442\u0430\u043B\u0438:* \u042D\u0442\u043E
    \u0431\u044B\u043B\u043E \u043F\u0435\u0440\u0432\u043E\u0435 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u043C\u0438
    \u0444\u043E\u0440\u043C\u0430\u043C\u0438. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0424\u0435\u0440\u043C\u0430 \u043E \u043C\u043D\u043E\u0433\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u043B\u0430\u0445 (\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430):**
    \u041E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E
    \u043B\u044E\u0431\u043E\u0435 \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0441\u0443\u043C\u043C\u043E\u0439 \u043D\u0435 \u0431\u043E\u043B\u0435\u0435
    \\( n \\) \\( n \\)-\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043B\u044E\u0431\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E \u2014 \u0441\u0443\u043C\u043C\u0430 \u043D\u0435
    \u0431\u043E\u043B\u0435\u0435 4 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432,
    \u043D\u0435 \u0431\u043E\u043B\u0435\u0435 5 \u043F\u044F\u0442\u0438\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u0438 \u0442.\u0434.). \u042D\u0442\u043E \u043F\u043E\u0437\u0436\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u041A\u043E\u0448\u0438.  ---  ### 2. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 (\u0418\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E \u043C\u0430\u043B\u044B\u0445)
    \u0424\u0435\u0440\u043C\u0430 \u0431\u044B\u043B \u043F\u0440\u044F\u043C\u044B\u043C
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u043C
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u0438 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430.
    \u041E\u043D \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0441\u043E\u0437\u0434\u0430\u043B
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0445 \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u0432
    \u0437\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u0439
    \u0434\u043E \u043D\u0438\u0445.  *   **\u041C\u0435\u0442\u043E\u0434 \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C\u043E\u0432, \u043C\u0438\u043D\u0438\u043C\u0443\u043C\u043E\u0432
    \u0438 \u043A\u0430\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445 (\u0414\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435):**    
    *   *\u0421\u0443\u0442\u044C:* \u0424\u0435\u0440\u043C\u0430 \u0432\u0432\u0435\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \xAB\u043F\u0440\u0438\u0440\u0430\u0449\u0435\u043D\u0438\u044F\xBB
    (\u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0438\u043C \u0435\u0433\u043E \\(
    e \\)). \u0427\u0442\u043E\u0431\u044B \u043D\u0430\u0439\u0442\u0438 \u044D\u043A\u0441\u0442\u0440\u0435\u043C\u0443\u043C
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438 \\( f(x) \\), \u043E\u043D \u043F\u0440\u0438\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u043B
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u0438
    \u0432 \u0442\u043E\u0447\u043A\u0430\u0445 \\( x \\) \u0438 \\( x+e \\), \u0434\u0435\u043B\u0438\u043B
    \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u044C \u043D\u0430 \\( e \\), \u0430
    \u0437\u0430\u0442\u0435\u043C **\u043F\u0440\u0438\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u043B
    \\( e \\) \u043A \u043D\u0443\u043B\u044E**.     *   *\u041F\u0440\u0438\u043C\u0435\u0440:*
    \u0414\u043B\u044F \\( f(x) = x^2 \\): \\( (x+e)^2 = x^2 \\Rightarrow 2xe + e^2
    = 0 \\Rightarrow e(2x+e)=0 \\). \u0421\u043E\u043A\u0440\u0430\u0449\u0430\u044F
    \u043D\u0430 \\( e \\) \u0438 \u043E\u0442\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u044F
    \u0435\u0433\u043E (\u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u044B\u0439
    \u043F\u0435\u0440\u0435\u0445\u043E\u0434), \u043F\u043E\u043B\u0443\u0447\u0430\u043B
    \\( 2x=0 \\).     *   *\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435:* \u042D\u0442\u043E
    \u0431\u044B\u043B\u043E \u0442\u043E\u0447\u043D\u043E\u0435 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u043E\u0439. \u041D\u044C\u044E\u0442\u043E\u043D
    \u043F\u0440\u044F\u043C\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B,
    \u0447\u0442\u043E \u043E\u043F\u0438\u0440\u0430\u043B\u0441\u044F \u043D\u0430
    \xAB\u043C\u0435\u0442\u043E\u0434 \u0424\u0435\u0440\u043C\u0430 \u0434\u043B\u044F
    \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u043A\u0430\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445\xBB.
    *   **\u041A\u0432\u0430\u0434\u0440\u0430\u0442\u0443\u0440\u044B (\u0418\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435):**    
    *   *\u0421\u0443\u0442\u044C:* \u0424\u0435\u0440\u043C\u0430 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043E\u0431\u0449\u0438\u0439 \u043C\u0435\u0442\u043E\u0434 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u043F\u043B\u043E\u0449\u0430\u0434\u0435\u0439 \u043F\u043E\u0434 \u043A\u0440\u0438\u0432\u044B\u043C\u0438
    \u0432\u0438\u0434\u0430 \\( y = x^n \\), \u0433\u0434\u0435 \\( n \\) \u2014
    \u043B\u044E\u0431\u043E\u0435 \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E (\u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0434\u0440\u043E\u0431\u043D\u044B\u0435
    \u0438 \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435,
    \u043A\u0440\u043E\u043C\u0435 -1).     *   *\u0414\u0435\u0442\u0430\u043B\u0438:*
    \u041E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441\u0438\u044E \u0434\u043B\u044F
    \u0440\u0430\u0437\u0431\u0438\u0435\u043D\u0438\u044F \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u0430
    \u043D\u0430 \u043D\u0435\u0440\u0430\u0432\u043D\u044B\u0435 \u0447\u0430\u0441\u0442\u0438
    (\u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043C\u0435\u0442\u043E\u0434\u0430
    \u043D\u0435\u0434\u0435\u043B\u0438\u043C\u044B\u0445 \u041A\u0430\u0432\u0430\u043B\u044C\u0435\u0440\u0438),
    \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0435\u043C\u0443
    \u0442\u043E\u0447\u043D\u043E \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u044C
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B \\( \\int_0^a x^n dx = \\frac{a^{n+1}}{n+1}
    \\). \u042D\u0442\u043E \u0431\u044B\u043B \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0439
    \u0448\u0430\u0433 \u043A \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E.  ---  ### 3. \u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u0424\u0435\u0440\u043C\u0430
    \u0441\u043E\u0437\u0434\u0430\u043B \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u0441
    \u0414\u0435\u043A\u0430\u0440\u0442\u043E\u043C, \u043D\u043E \u0435\u0433\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434 \u0431\u044B\u043B \u0431\u043E\u043B\u0435\u0435
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u043D\u044B\u043C \u0438
    \u0443\u0434\u043E\u0431\u043D\u044B\u043C \u0434\u043B\u044F \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B.  *   **\xAB\u0412\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0432 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435 \u043F\u043B\u043E\u0441\u043A\u0438\u0445
    \u0438 \u0442\u0435\u043B\u0435\u0441\u043D\u044B\u0445 \u043C\u0435\u0441\u0442\xBB
    (1636):**     *   *\u0421\u0443\u0442\u044C:* \u0424\u0435\u0440\u043C\u0430
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B \u043F\u0440\u0430\u0432\u0438\u043B\u043E:
    **\u043B\u044E\u0431\u043E\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u0441 \u0434\u0432\u0443\u043C\u044F \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C\u0438
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u0442 \u043A\u0440\u0438\u0432\u0443\u044E
    \u043D\u0430 \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438**. \u041E\u043D
    \u0432\u0432\u0435\u043B \u043F\u0440\u044F\u043C\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0435
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B (\u043F\u0440\u0430\u0432\u0434\u0430,
    \u043E\u0441\u044C \u0443 \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u0430 \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439,
    \u0430 \u043D\u0435 \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439,
    \u043A\u0430\u043A \u0441\u0435\u0439\u0447\u0430\u0441).     *   *\u041A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044F:*
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0432\u0441\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0432\u0438\u0434\u0430
    \\( Ax + By = C \\) \u2014 \u044D\u0442\u043E \u043F\u0440\u044F\u043C\u044B\u0435,
    \u0430 \u0432\u0441\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u0432\u0438\u0434\u0430 \\( x^2 = py \\), \\( xy = c \\) \u0438 \\( x^2 \\pm
    y^2 = r^2 \\) \u2014 \u044D\u0442\u043E \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u0435\u0447\u0435\u043D\u0438\u044F (\u043F\u0430\u0440\u0430\u0431\u043E\u043B\u044B,
    \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u044B \u0438 \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u0438/\u044D\u043B\u043B\u0438\u043F\u0441\u044B).
    \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0440\u0435\u0448\u0430\u0442\u044C
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0447\u0438\u0441\u0442\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438. 
    ---  ### 4. \u0422\u0435\u043E\u0440\u0438\u044F \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439
    (\u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u041F\u0430\u0441\u043A\u0430\u043B\u0435\u043C)
    \u0412 1654 \u0433\u043E\u0434\u0443 \u0432 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435
    \u0441 \u0411\u043B\u0435\u0437\u043E\u043C \u041F\u0430\u0441\u043A\u0430\u043B\u0435\u043C
    \u0424\u0435\u0440\u043C\u0430 \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u0441\u0442\u0440\u043E\u0433\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0441\u043D\u043E\u0432\u044B \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439. 
    *   **\u0417\u0430\u0434\u0430\u0447\u0430 \u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0435
    \u0441\u0442\u0430\u0432\u043E\u043A (Problem of Points):**     *   *\u0423\u0441\u043B\u043E\u0432\u0438\u0435:*
    \u0414\u0432\u0430 \u0438\u0433\u0440\u043E\u043A\u0430 \u0438\u0433\u0440\u0430\u044E\u0442
    \u0432 \u043A\u043E\u0441\u0442\u0438. \u0418\u0433\u0440\u0430 \u043F\u0440\u0435\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u0434\u043E\u0441\u0440\u043E\u0447\u043D\u043E, \u043A\u043E\u0433\u0434\u0430
    \u043E\u0434\u043D\u043E\u043C\u0443 \u0438\u0437 \u0438\u0433\u0440\u043E\u043A\u043E\u0432
    \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442 \\( n \\) \u043F\u043E\u0431\u0435\u0434,
    \u0430 \u0434\u0440\u0443\u0433\u043E\u043C\u0443 \\( m \\). \u041A\u0430\u043A
    \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u0431\u0430\u043D\u043A?     *   *\u0420\u0435\u0448\u0435\u043D\u0438\u0435
    \u0424\u0435\u0440\u043C\u0430:* \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u041F\u0430\u0441\u043A\u0430\u043B\u044F, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0432\u0448\u0435\u0433\u043E
    \u0440\u0435\u043A\u0443\u0440\u0440\u0435\u043D\u0442\u043D\u044B\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F,
    \u0424\u0435\u0440\u043C\u0430 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B
    **\u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0443**.
    \u041E\u043D \u043F\u043E\u0434\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u043B
    \u0432\u0441\u0435 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0435 \u0438\u0441\u0445\u043E\u0434\u044B
    \u0433\u0438\u043F\u043E\u0442\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0435\u043D\u0438\u044F \u0438\u0433\u0440\u044B
    (\u043F\u0435\u0440\u0435\u0431\u0438\u0440\u0430\u043B \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0446\u0438\u0438)
    \u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u043B \u0434\u043E\u043B\u044E
    \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u0438\u0433\u0440\u043E\u043A\u0430
    \u043A\u0430\u043A \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435 \u0431\u043B\u0430\u0433\u043E\u043F\u0440\u0438\u044F\u0442\u043D\u044B\u0445
    \u0438\u0441\u0445\u043E\u0434\u043E\u0432 \u043A \u043E\u0431\u0449\u0435\u043C\u0443
    \u0447\u0438\u0441\u043B\u0443. \u042D\u0442\u043E \u0432\u0432\u0435\u043B\u043E
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0436\u0438\u0434\u0430\u043D\u0438\u044F**.  ---  ### 5. \u0424\u0438\u0437\u0438\u043A\u0430
    (\u041F\u0440\u0438\u043D\u0446\u0438\u043F \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438) \u0424\u0435\u0440\u043C\u0430 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0432 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043F\u0442\u0438\u043A\u0435, \u043E\u0442\u043A\u0430\u0437\u0430\u0432\u0448\u0438\u0441\u044C
    \u043E\u0442 \u043C\u0435\u0445\u0430\u043D\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u0439 \u0414\u0435\u043A\u0430\u0440\u0442\u0430. 
    *   **\u041F\u0440\u0438\u043D\u0446\u0438\u043F \u0424\u0435\u0440\u043C\u0430
    (1662):**     *   *\u0421\u0443\u0442\u044C:* \u0421\u0432\u0435\u0442 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u0435\u0442\u0441\u044F
    \u043C\u0435\u0436\u0434\u0443 \u0434\u0432\u0443\u043C\u044F \u0442\u043E\u0447\u043A\u0430\u043C\u0438
    \u043F\u043E \u043F\u0443\u0442\u0438, \u0434\u043B\u044F \u043F\u0440\u043E\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F
    **\u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0435 \u0432\u0440\u0435\u043C\u044F**.    
    *   *\u041E\u043F\u0440\u043E\u0432\u0435\u0440\u0436\u0435\u043D\u0438\u0435
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430:* \u0414\u0435\u043A\u0430\u0440\u0442
    \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C
    \u0441\u0432\u0435\u0442\u0430 \u0432 \u043F\u043B\u043E\u0442\u043D\u043E\u0439
    \u0441\u0440\u0435\u0434\u0435 \u0432\u044B\u0448\u0435. \u0424\u0435\u0440\u043C\u0430,
    \u0438\u0441\u0445\u043E\u0434\u044F \u0438\u0437 \u0441\u0432\u043E\u0435\u0433\u043E
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0441\u0442\u0440\u043E\u0433\u043E \u0432\u044B\u0432\u0435\u043B \u0437\u0430\u043A\u043E\u043D
    \u0421\u043D\u0435\u043B\u043B\u0438\u0443\u0441\u0430 (\u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u044F)
    \u0438 \u043F\u0440\u0438\u0448\u0435\u043B \u043A \u0432\u044B\u0432\u043E\u0434\u0443,
    \u0447\u0442\u043E **\u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C \u0441\u0432\u0435\u0442\u0430
    \u0432 \u0431\u043E\u043B\u0435\u0435 \u043F\u043B\u043E\u0442\u043D\u043E\u0439
    \u0441\u0440\u0435\u0434\u0435 \u043D\u0438\u0436\u0435**, \u0447\u0442\u043E
    \u043E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C \u0432\u0435\u0440\u043D\u044B\u043C.    
    *   *\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435:* \u042D\u0442\u043E\u0442
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043F\u043E\u0437\u0436\u0435 \u0441\u0442\u0430\u043B
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0432 \u0444\u0438\u0437\u0438\u043A\u0435
    (\u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0433\u043E
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430). 
    ---  ### 6. \u041C\u0435\u0442\u043E\u0434\u044B \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0434\u043B\u0438\u043D \u043A\u0440\u0438\u0432\u044B\u0445 (\u0421\u043F\u0440\u044F\u043C\u043B\u0435\u043D\u0438\u0435)
    \u0424\u0435\u0440\u043C\u0430 \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u043D\u0430\u0448\u0435\u043B \u0442\u043E\u0447\u043D\u0443\u044E \u0434\u043B\u0438\u043D\u0443
    \u0434\u0443\u0433\u0438 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043A\u0440\u0438\u0432\u044B\u0445.  *   \u041E\u043D \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B
    \u0434\u043B\u0438\u043D\u0443 \u0434\u0443\u0433\u0438 \u043F\u043E\u043B\u0443\u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u0430\u0440\u0430\u0431\u043E\u043B\u044B \\( y = x^{3/2} \\). \u0414\u043B\u044F
    \u044D\u0442\u043E\u0433\u043E \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434 \u0441\u0443\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E \u043C\u0430\u043B\u044B\u0445
    \u043E\u0442\u0440\u0435\u0437\u043A\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E \u0441\u0443\u0442\u0438 \u044D\u043A\u0432\u0438\u0432\u0430\u043B\u0435\u043D\u0442\u0435\u043D
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0444\u043E\u0440\u043C\u0443\u043B\u0435
    \u0434\u043B\u0438\u043D\u044B \u0434\u0443\u0433\u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430
    \\( \\int \\sqrt{1+(y')^2} dx \\). \u042D\u0442\u043E \u0431\u044B\u043B \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0440\u0430\u043D\u043D\u0438\u0445 \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u0432
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439.  ---  ### \u0418\u0442\u043E\u0433\u043E\u0432\u043E\u0435
    \u0440\u0435\u0437\u044E\u043C\u0435 \u0432\u043A\u043B\u0430\u0434\u0430  |
    \u041E\u0431\u043B\u0430\u0441\u0442\u044C \u043D\u0430\u0443\u043A\u0438 | \u041A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 | \u0412\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0431\u0443\u0434\u0443\u0449\u0435\u0435 | | :--- | :--- | :---
    | | **\u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B** |
    \u0412\u0435\u043B\u0438\u043A\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430,
    \u041C\u0430\u043B\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430, \u043C\u0435\u0442\u043E\u0434
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E \u0441\u043F\u0443\u0441\u043A\u0430.
    | \u0421\u043E\u0437\u0434\u0430\u043B \u0447\u0438\u0441\u0442\u0443\u044E \u0442\u0435\u043E\u0440\u0438\u044E
    \u0447\u0438\u0441\u0435\u043B \u043A\u0430\u043A \u043D\u0430\u0443\u043A\u0443;
    \u0434\u0430\u043B \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B
    \u0434\u043B\u044F \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    (RSA). | | **\u0414\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435** | \u041C\u0435\u0442\u043E\u0434
    \u043A\u0430\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u0438 \u044D\u043A\u0441\u0442\u0440\u0435\u043C\u0443\u043C\u043E\u0432
    \u0447\u0435\u0440\u0435\u0437 \u043F\u0440\u0438\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u043D\u0438\u0435
    \u043F\u0440\u0438\u0440\u0430\u0449\u0435\u043D\u0438\u044F \u043A \u043D\u0443\u043B\u044E.
    | \u041F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u043E\u0439; \u043F\u043E\u0432\u043B\u0438\u044F\u043B
    \u043D\u0430 \u041D\u044C\u044E\u0442\u043E\u043D\u0430. | | **\u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0435
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435** | \u041A\u0432\u0430\u0434\u0440\u0430\u0442\u0443\u0440\u0430
    \u043F\u0430\u0440\u0430\u0431\u043E\u043B \u043B\u044E\u0431\u043E\u0433\u043E
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u043E\u0440\u044F\u0434\u043A\u0430. | \u0420\u0435\u0448\u0438\u043B
    \u0437\u0430\u0434\u0430\u0447\u0443, \u043D\u0435\u043F\u043E\u0434\u0432\u043B\u0430\u0441\u0442\u043D\u0443\u044E
    \u0433\u0440\u0435\u043A\u0430\u043C; \u0434\u0430\u043B \u0444\u043E\u0440\u043C\u0443\u043B\u0443
    \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E\u0439 \u0444\u0443\u043D\u043A\u0446\u0438\u0438.
    | | **\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F** | \u041E\u0442\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u043B\u0435\u043D\u0438\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0441 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043C\u0435\u0441\u0442\u0430\u043C\u0438 \u0442\u043E\u0447\u0435\u043A. |
    \u0421\u0432\u044F\u0437\u0430\u043B \u0430\u043B\u0433\u0435\u0431\u0440\u0443
    \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E, \u0447\u0442\u043E
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0440\u0435\u0448\u0430\u0442\u044C
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0447\u0435\u0440\u0442\u0435\u0436\u0435\u0439
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F\u043C\u0438. | |
    **\u0424\u0438\u0437\u0438\u043A\u0430 (\u041E\u043F\u0442\u0438\u043A\u0430)**
    | \u041F\u0440\u0438\u043D\u0446\u0438\u043F \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 + \u0432\u044B\u0432\u043E\u0434 \u0437\u0430\u043A\u043E\u043D\u0430
    \u0421\u043D\u0435\u043B\u043B\u0438\u0443\u0441\u0430. | \u041E\u0441\u043D\u043E\u0432\u0430
    \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F; \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435
    \u043A\u043E\u0440\u043F\u0443\u0441\u043A\u0443\u043B\u044F\u0440\u043D\u043E-\u0432\u043E\u043B\u043D\u043E\u0432\u043E\u0433\u043E
    \u0434\u0443\u0430\u043B\u0438\u0437\u043C\u0430 \u0432 \u0431\u0443\u0434\u0443\u0449\u0435\u043C.
    | | **\u0412\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u044C** |
