    \u0440\u0430\u0441\u0447\u0435\u0442 \u0448\u0430\u043D\u0441\u043E\u0432 \u043F\u0440\u0438
    \u0434\u043E\u0441\u0440\u043E\u0447\u043D\u043E\u043C \u043F\u0440\u0435\u0440\u044B\u0432\u0430\u043D\u0438\u0438
    \u0438\u0433\u0440\u044B. | \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u043D\u043E\u0439
    \u0431\u0430\u0437\u044B \u0434\u043B\u044F \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u0433\u0440. |  **\u0412\u0430\u0436\u043D\u043E\u0435
    \u0437\u0430\u043C\u0435\u0447\u0430\u043D\u0438\u0435:** \u0424\u0435\u0440\u043C\u0430
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u0438
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430.
    \u041E\u043D \u043F\u043E\u0441\u044B\u043B\u0430\u043B \u043B\u0438\u0448\u044C
    **\u0437\u0430\u0434\u0430\u0447\u0438** \u0438 **\u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B**
    \u0441\u0432\u043E\u0438\u043C \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C
    (\u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u0432 \u043F\u0438\u0441\u044C\u043C\u0430\u0445
    \u043A \u0420\u043E\u0431\u0435\u0440\u0432\u0430\u043B\u044E \u0438 \u041C\u0435\u0440\u0441\u0435\u043D\u043D\u0443),
    \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u044F \u0438\u0445. \u0418\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u0430 \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0430 \xAB\u0431\u0440\u043E\u0441\u0430\u0442\u044C
    \u0432\u044B\u0437\u043E\u0432\xBB \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430\u043C
    \u0441\u0434\u0435\u043B\u0430\u043B\u0430 \u0435\u0433\u043E \u0441\u0430\u043C\u044B\u043C
    \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u044B\u043C \u0433\u0435\u043D\u0438\u0435\u043C
    XVII \u0432\u0435\u043A\u0430."
  achievementsEn: 
  personalLifeRu: "\u0412\u043D\u0435\u0448\u043D\u0435 \u0436\u0438\u0437\u043D\u044C
    \u041F\u044C\u0435\u0440\u0430 \u0424\u0435\u0440\u043C\u0430, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u0432\u0435\u043B \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u0447\u0430\u0441\u0442\u044C
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u0431\u044B\u043B\u0430 \u0431\u044B
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0441\u043A\u0443\u0447\u043D\u0430
    \u0434\u043B\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0430, \u0435\u0441\u043B\u0438
    \u0431\u044B \u043D\u0435 \u0435\u0433\u043E \u0442\u0430\u0439\u043D\u0430\u044F,
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u0430\u044F \u0441\u0442\u0440\u0430\u0441\u0442\u044C.
    \u041E\u043D \u0431\u044B\u043B \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \"\u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0434\u0432\u0443\u0445
    \u0436\u0438\u0437\u043D\u0435\u0439\": \u0434\u043D\u0435\u043C \u2014 \u0434\u043E\u0431\u0440\u043E\u0441\u043E\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u044E\u0440\u0438\u0441\u0442, \u043D\u043E\u0447\u044C\u044E \u0438 \u0432
    \u0447\u0430\u0441\u044B \u0434\u043E\u0441\u0443\u0433\u0430 \u2014 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u0443\u043C\u043E\u0432
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    \u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439 \u043F\u043E\u0440\u0442\u0440\u0435\u0442
    \u0435\u0433\u043E \"\u0437\u0435\u043C\u043D\u043E\u0439\" \u0436\u0438\u0437\u043D\u0438. 
    ### \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435, \u0421\u0435\u043C\u044C\u044F
    \u0438 \u0417\u0430\u0433\u0430\u0434\u043A\u0430 \u0414\u0430\u0442\u044B  \u041F\u044C\u0435\u0440
    \u0424\u0435\u0440\u043C\u0430 \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0432
    \u0431\u043E\u0433\u0430\u0442\u043E\u0439 \u0441\u0435\u043C\u044C\u0435 \u0432
    \u0433\u0430\u0441\u043A\u043E\u043D\u0441\u043A\u043E\u043C \u0433\u043E\u0440\u043E\u0434\u043A\u0435
    \u0411\u043E\u043C\u043E\u043D-\u0434\u0435-\u041B\u043E\u043C\u0430\u043D\u044C
    \u043D\u0430 \u044E\u0433\u0435 \u0424\u0440\u0430\u043D\u0446\u0438\u0438. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0442\u043E\u0447\u043D\u0430\u044F \u0434\u0430\u0442\u0430 \u0435\u0433\u043E
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440 \u0432\u044B\u0437\u044B\u0432\u0430\u0435\u0442 \u0441\u043F\u043E\u0440\u044B
    \u0443 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432. \u0422\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u043E
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 17 \u0430\u0432\u0433\u0443\u0441\u0442\u0430
    1601 \u0433\u043E\u0434\u0430, \u043E\u043F\u0438\u0440\u0430\u044F\u0441\u044C
    \u043D\u0430 \u0437\u0430\u043F\u0438\u0441\u044C \u043E \u043A\u0440\u0435\u0449\u0435\u043D\u0438\u0438.
    \u041D\u043E \u0435\u0441\u0442\u044C \u0438 \u0434\u0440\u0443\u0433\u0430\u044F
    \u0432\u0435\u0440\u0441\u0438\u044F: \u043D\u0430 \u0435\u0433\u043E \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u0438
    \u0443\u043A\u0430\u0437\u0430\u043D\u043E, \u0447\u0442\u043E \u043E\u043D \u0443\u043C\u0435\u0440
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 57 \u043B\u0435\u0442,
    \u0447\u0442\u043E \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u0442 \u0434\u0430\u0442\u0443
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u043D\u0430 1607 \u0438\u043B\u0438
    \u0434\u0430\u0436\u0435 1608 \u0433\u043E\u0434. \u041F\u0443\u0442\u0430\u043D\u0438\u0446\u0443
    \u0432\u043D\u043E\u0441\u0438\u0442 \u0442\u043E\u0442 \u0444\u0430\u043A\u0442,
    \u0447\u0442\u043E \u0435\u0433\u043E \u043E\u0442\u0435\u0446, \u0414\u043E\u043C\u0438\u043D\u0438\u043A
    \u0424\u0435\u0440\u043C\u0430 (\u0431\u043E\u0433\u0430\u0442\u044B\u0439 \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446
    \u043A\u043E\u0436\u0435\u0439 \u0438 \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u0439
    \u043A\u043E\u043D\u0441\u0443\u043B), \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u0434\u0432\u0430\u0436\u0434\u044B, \u0438, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0440\u0435\u0431\u0435\u043D\u043E\u043A
    \u043F\u043E \u0438\u043C\u0435\u043D\u0438 \u041F\u044C\u0435\u0440 \u0443\u043C\u0435\u0440,
    \u0430 \u0438\u043C\u044F \u0431\u044B\u043B\u043E \u0434\u0430\u043D\u043E \u0432\u0442\u043E\u0440\u043E\u043C\u0443
    \u0441\u044B\u043D\u0443 \u043E\u0442 \u0434\u0440\u0443\u0433\u043E\u0439 \u043C\u0430\u0442\u0435\u0440\u0438. 
    \u041C\u0430\u0442\u0435\u0440\u044C\u044E \u041F\u044C\u0435\u0440\u0430 \u0431\u044B\u043B\u0430
    \u041A\u043B\u0435\u0440 \u0434\u0435 \u041B\u043E\u043D\u0433. \u0412 \u0441\u0435\u043C\u044C\u0435,
    \u043A\u0440\u043E\u043C\u0435 \u043D\u0435\u0433\u043E, \u0431\u044B\u043B\u043E
    \u0435\u0449\u0435 \u0442\u0440\u043E\u0435 \u0434\u0435\u0442\u0435\u0439. \u0424\u0435\u0440\u043C\u0430
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0445\u043E\u0440\u043E\u0448\u0435\u0435
    \u0433\u0443\u043C\u0430\u043D\u0438\u0442\u0430\u0440\u043D\u043E\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:
    \u043E\u043D \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u0437\u043D\u0430\u043B
    \u043B\u0430\u0442\u044B\u043D\u044C, \u0434\u0440\u0435\u0432\u043D\u0435\u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0439,
    \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u0439 \u0438 \u0438\u0441\u043F\u0430\u043D\u0441\u043A\u0438\u0439
    \u044F\u0437\u044B\u043A\u0438, \u043F\u0438\u0441\u0430\u043B \u0441\u0442\u0438\u0445\u0438
    \u0438 \u0441\u0447\u0438\u0442\u0430\u043B\u0441\u044F \u0442\u043E\u043D\u043A\u0438\u043C
    \u0437\u043D\u0430\u0442\u043E\u043A\u043E\u043C \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0439
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u044B, \u043A \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u043E\u0431\u0440\u0430\u0449\u0430\u043B\u0438\u0441\u044C \u0437\u0430 \u0441\u043E\u0432\u0435\u0442\u043E\u043C
    \u043F\u0440\u0438 \u0438\u0437\u0434\u0430\u043D\u0438\u0438 \u043A\u043B\u0430\u0441\u0441\u0438\u043A\u043E\u0432. 
    ### \u0411\u0440\u0430\u043A \u0438 \u0414\u0435\u0442\u0438  \u0412 1631 \u0433\u043E\u0434\u0443,
    \u0432 \u0433\u043E\u0434 \u043D\u0430\u0447\u0430\u043B\u0430 \u0441\u0432\u043E\u0435\u0439
    \u044E\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u044B,
    \u0424\u0435\u0440\u043C\u0430 \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430
    \u041B\u0443\u0438\u0437\u0435 \u0434\u0435 \u041B\u043E\u043D\u0433 (Louise
    de Long), \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u0438\u0445\u043E\u0434\u0438\u043B\u0430\u0441\u044C
    \u0435\u043C\u0443 \u0434\u0430\u043B\u044C\u043D\u0435\u0439 \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u0446\u0435\u0439
    \u043F\u043E \u043C\u0430\u0442\u0435\u0440\u0438\u043D\u0441\u043A\u043E\u0439
    \u043B\u0438\u043D\u0438\u0438. \u0418\u0445 \u0431\u0440\u0430\u043A \u0431\u044B\u043B,
    \u043F\u043E \u0432\u0441\u0435\u0439 \u0432\u0438\u0434\u0438\u043C\u043E\u0441\u0442\u0438,
    \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u044B\u043C \u0438 \u0431\u043B\u0430\u0433\u043E\u043F\u043E\u043B\u0443\u0447\u043D\u044B\u043C,
    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u043C
    \u0435\u0433\u043E \u0440\u0430\u0437\u043C\u0435\u0440\u0435\u043D\u043D\u043E\u043C\u0443
    \u043E\u0431\u0440\u0430\u0437\u0443 \u0436\u0438\u0437\u043D\u0438.  \u0423
    \u041F\u044C\u0435\u0440\u0430 \u0438 \u041B\u0443\u0438\u0437\u044B \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C
    **\u043F\u044F\u0442\u0435\u0440\u043E \u0434\u0435\u0442\u0435\u0439**, \u0445\u043E\u0442\u044F
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u044E\u0442 \u0441\u0435\u043C\u044C
    \u0438\u043B\u0438 \u0432\u043E\u0441\u0435\u043C\u044C. \u041D\u0430\u0438\u0431\u043E\u043B\u0435\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C \u0438\u0437 \u043D\u0438\u0445
    \u0431\u044B\u043B \u0441\u0442\u0430\u0440\u0448\u0438\u0439 \u0441\u044B\u043D,
    **\u041A\u043B\u0435\u043C\u0430\u043D-\u0421\u0430\u043C\u044E\u044D\u043B\u044C
    (Cl\xE9ment-Samuel)**. \u0418\u043C\u0435\u043D\u043D\u043E \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0435\u043C\u0443 \u043C\u044B \u0437\u043D\u0430\u0435\u043C \u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F\u0445 \u0424\u0435\u0440\u043C\u0430:
    \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u0442\u0446\u0430
    \u0421\u0430\u043C\u044E\u044D\u043B\u044C \u0441\u043E\u0431\u0440\u0430\u043B
    \u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0435\u0433\u043E
    \u043F\u0438\u0441\u044C\u043C\u0430 \u0438 \u0437\u0430\u043C\u0435\u0442\u043A\u0438,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0437\u0430\u043F\u0438\u0441\u044C \u043D\u0430 \u043F\u043E\u043B\u044F\u0445
    \"\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\" \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u043E \u0412\u0435\u043B\u0438\u043A\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u0435. 
    ### \u041A\u0430\u0440\u044C\u0435\u0440\u0430 \u042E\u0440\u0438\u0441\u0442\u0430
    \u0438 \"\u0412\u0442\u043E\u0440\u0430\u044F\" \u0416\u0438\u0437\u043D\u044C 
    \u0424\u0435\u0440\u043C\u0430 \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430 \u043F\u0440\u0430\u0432\u0430
    \u0432 \u041E\u0440\u043B\u0435\u0430\u043D\u0435 \u0438 \u0432 1631 \u0433\u043E\u0434\u0443
    \u0432\u044B\u043A\u0443\u043F\u0438\u043B \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u0430
    (conseiller) \u0432 \u041F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442\u0435
    \u0422\u0443\u043B\u0443\u0437\u044B \u2014 \u043E\u0434\u043D\u043E\u043C \u0438\u0437
    \u0432\u044B\u0441\u0448\u0438\u0445 \u0441\u0443\u0434\u043E\u0432 \u0424\u0440\u0430\u043D\u0446\u0438\u0438.
    \u042D\u0442\u0430 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0434\u0430\u0432\u0430\u043B\u0430
    \u0435\u043C\u0443 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043E\u0445\u043E\u0434
    \u0438 \u0441\u0442\u0430\u0442\u0443\u0441, \u043D\u043E \u0438 \u043F\u0440\u0430\u0432\u043E
    \u0434\u043E\u0431\u0430\u0432\u0438\u0442\u044C \u043A \u0444\u0430\u043C\u0438\u043B\u0438\u0438
    \u0434\u0432\u043E\u0440\u044F\u043D\u0441\u043A\u0443\u044E \u0447\u0430\u0441\u0442\u0438\u0446\u0443
    \"\u0434\u0435\", \u0441\u0442\u0430\u0432 **\u041F\u044C\u0435\u0440\u043E\u043C
    \u0434\u0435 \u0424\u0435\u0440\u043C\u0430**.  \u041E\u043D \u0431\u044B\u043B
    \u043E\u0431\u0440\u0430\u0437\u0446\u043E\u0432\u044B\u043C \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u043E\u043C:
    \u0434\u043E\u0431\u0440\u043E\u0441\u043E\u0432\u0435\u0441\u0442\u043D\u044B\u043C,
    \u0430\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u044B\u043C \u0438 \u0447\u0435\u0441\u0442\u043D\u044B\u043C.
    \u042D\u0442\u043E \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u043B\u043E
    \u0435\u043C\u0443 \u043A\u0430\u0440\u044C\u0435\u0440\u043D\u044B\u0439 \u0440\u043E\u0441\u0442:
    \u0432 1638 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B \u0447\u043B\u0435\u043D\u043E\u043C
    \u0443\u0433\u043E\u043B\u043E\u0432\u043D\u043E\u0433\u043E \u0441\u0443\u0434\u0430,
    \u0430 \u0432 1648-\u043C \u2014 \u0447\u043B\u0435\u043D\u043E\u043C \u041F\u0430\u043B\u0430\u0442\u044B
    \u044D\u0434\u0438\u043A\u0442\u043E\u0432 \u0432 \u0433\u043E\u0440\u043E\u0434\u0435
    \u041A\u0430\u0441\u0442\u0440. \u0414\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442
    \u0435\u0433\u043E \u043A\u0430\u043A \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u043D\u043E\u0433\u043E,
    \u043D\u043E \"\u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0433\u043E
    \u0438 \u043F\u043E\u0433\u043B\u043E\u0449\u0435\u043D\u043D\u043E\u0433\u043E
    \u0441\u0432\u043E\u0438\u043C\u0438 \u043C\u044B\u0441\u043B\u044F\u043C\u0438\"
    \u0441\u0443\u0434\u044C\u044E.  \u0412\u0441\u044F \u0435\u0433\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u043F\u0440\u043E\u0448\u043B\u0430 \u0432 \u043F\u0440\u043E\u0432\u0438\u043D\u0446\u0438\u0438.
    \u041E\u043D \u043F\u043E\u0447\u0442\u0438 \u043D\u0435 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    (\u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435 \u0434\u0430\u043B\u044C\u043D\u0435\u0435
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u043E\u0441\u044C
    \u0432 1654 \u0433\u043E\u0434\u0443), \u0440\u0435\u0434\u043A\u043E \u043F\u043E\u043A\u0438\u0434\u0430\u043B
    \u0422\u0443\u043B\u0443\u0437\u0443 \u0438 \u0435\u0435 \u043E\u043A\u0440\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0431\u044B\u043B
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435, \u0446\u0435\u043D\u0442\u0440\u0435
    \u0442\u043E\u0433\u0434\u0430\u0448\u043D\u0435\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438. \u0418\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u0430
    \u0440\u0430\u0437\u043C\u0435\u0440\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0430 \u0435\u043C\u0443 \u0432\u0435\u0447\u0435\u0440\u0430
    \u0438 \u0432\u044B\u0445\u043E\u0434\u043D\u044B\u0435 \u0434\u043B\u044F \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F \u0436\u0438\u0437\u043D\u0438
    \u2014 \u0437\u0430\u043D\u044F\u0442\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439. 
    ### \u0411\u043E\u043B\u0435\u0437\u043D\u044C, \u0421\u043C\u0435\u0440\u0442\u044C
    \u0438 \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  \u0412 1652 \u0433\u043E\u0434\u0443
    \u043D\u0430 \u0424\u0440\u0430\u043D\u0446\u0438\u044E \u043E\u0431\u0440\u0443\u0448\u0438\u043B\u0430\u0441\u044C
    \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u044F \u0447\u0443\u043C\u044B. \u0424\u0435\u0440\u043C\u0430
    \u0437\u0430\u0440\u0430\u0437\u0438\u043B\u0441\u044F, \u043D\u043E, \u0432
    \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445
    \u043A\u043E\u043B\u043B\u0435\u0433-\u0441\u0443\u0434\u0435\u0439, \u0447\u0443\u0434\u043E\u043C
    \u0432\u044B\u0436\u0438\u043B. \u0415\u0433\u043E \u0432\u044B\u0437\u0434\u043E\u0440\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0441\u043C\u0435\u0440\u0442\u0435\u0439
    \u0432 \u0441\u0443\u0434\u0435 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438
    \u0435\u043C\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u0432\u044B\u0441\u0448\u0435\u0433\u043E \u0441\u0443\u0434\u044C\u0438 \u041F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442\u0430. 
    \u041F\u044C\u0435\u0440 \u0434\u0435 \u0424\u0435\u0440\u043C\u0430 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    12 \u044F\u043D\u0432\u0430\u0440\u044F 1665 \u0433\u043E\u0434\u0430 \u0432
    \u0433\u043E\u0440\u043E\u0434\u0435 \u041A\u0430\u0441\u0442\u0440, \u0432\u043E
    \u0432\u0440\u0435\u043C\u044F \u043E\u0447\u0435\u0440\u0435\u0434\u043D\u043E\u0439
    \u0432\u044B\u0435\u0437\u0434\u043D\u043E\u0439 \u0441\u0435\u0441\u0441\u0438\u0438
    \u0441\u0443\u0434\u0430. \u0415\u0433\u043E \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0438\u043B\u0438
    \u0432 \u041A\u0430\u0441\u0442\u0440\u0435, \u043D\u043E \u043F\u043E\u0437\u0436\u0435
    \u043F\u0440\u0430\u0445 \u043F\u0435\u0440\u0435\u043D\u0435\u0441\u043B\u0438
    \u0432 \u0441\u0435\u043C\u0435\u0439\u043D\u0443\u044E \u0443\u0441\u044B\u043F\u0430\u043B\u044C\u043D\u0438\u0446\u0443
    \u0432 \u0422\u0443\u043B\u0443\u0437\u0435. \u0412\u043E \u0432\u0440\u0435\u043C\u044F
    \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438
    \u0435\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u0430 \u0431\u044B\u043B\u0430
    \u0443\u0442\u0435\u0440\u044F\u043D\u0430.  \u041F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0435
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435 \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u043E\u0432,
    \u0438\u0437\u0434\u0430\u043D\u043D\u043E\u0435 \u0441\u044B\u043D\u043E\u043C,
    \u043F\u043E\u0442\u0440\u044F\u0441\u043B\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u043C\u0438\u0440: \u0432\u044B\u044F\u0441\u043D\u0438\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u0439 \u043F\u0440\u043E\u0432\u0438\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u044E\u0440\u0438\u0441\u0442 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B, \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438 \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E \u043C\u0430\u043B\u044B\u0445,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0432\u043C\u0435\u0441\u0442\u0435 \u0441
    \u041F\u0430\u0441\u043A\u0430\u043B\u0435\u043C \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.
    \u0415\u0433\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438 \u0424\u0435\u0440\u043C\u0430
    \u043A\u0430\u043A \u043F\u0440\u0438\u0432\u0435\u0442\u043B\u0438\u0432\u043E\u0433\u043E,
    \u0443\u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0448\u0435\u043D\u043D\u043E\u0433\u043E
    \u0438 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E \u044D\u0440\u0443\u0434\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432 \u043E\u0434\u043D\u043E\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0435
    \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u0438\u043B \u0434\u043E\u0431\u0440\u043E\u0441\u043E\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u0430 \u0438 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430-\u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044F."
  personalLifeEn: 
  shortBioRu: "\u041F\u044C\u0435\u0440 \u0424\u0435\u0440\u043C\u0430 \u2014 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438, \u0445\u043E\u0442\u044F \u043F\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u0438 \u043E\u043D \u0431\u044B\u043B
    \u044E\u0440\u0438\u0441\u0442\u043E\u043C \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u043D\u0430\u0443\u043A\u043E\u0439 \u0432 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F. \u041E\u043D \u0441\u0442\u043E\u044F\u043B \u0443
    \u0438\u0441\u0442\u043E\u043A\u043E\u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B, \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439. 
    \u0412\u043E\u0442 \u0435\u0433\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F.  ### \u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 (1601-1631) 
    \u041F\u044C\u0435\u0440 \u0424\u0435\u0440\u043C\u0430 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    17 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1601 \u0433\u043E\u0434\u0430 \u0432
    \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u043C \u0433\u043E\u0440\u043E\u0434\u043A\u0435
    \u0411\u043E\u043C\u043E\u043D-\u0434\u0435-\u041B\u043E\u043C\u0430\u043D\u044C
    \u043D\u0430 \u044E\u0433\u0435 \u0424\u0440\u0430\u043D\u0446\u0438\u0438. \u0415\u0433\u043E
    \u043E\u0442\u0435\u0446, \u0414\u043E\u043C\u0438\u043D\u0438\u043A \u0424\u0435\u0440\u043C\u0430,
    \u0431\u044B\u043B \u0437\u0430\u0436\u0438\u0442\u043E\u0447\u043D\u044B\u043C
    \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0435\u043C \u043A\u043E\u0436\u0435\u0439
    \u0438 \u0432\u0442\u043E\u0440\u044B\u043C \u043A\u043E\u043D\u0441\u0443\u043B\u043E\u043C
    (\u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u043E\u043C \u043C\u044D\u0440\u0430)
    \u0433\u043E\u0440\u043E\u0434\u0430. \u041C\u0430\u0442\u044C, \u041A\u043B\u0435\u0440
    \u0434\u0435 \u041B\u043E\u043D\u0433, \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0430
    \u0438\u0437 \u0441\u0435\u043C\u044C\u0438 \u044E\u0440\u0438\u0441\u0442\u043E\u0432.
    \u041C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0437\u0430\u043F\u0438\u0441\u044C
    \u043E \u0435\u0433\u043E \u043A\u0440\u0435\u0449\u0435\u043D\u0438\u0438 \u0434\u0430\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0430
    20 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1601 \u0433\u043E\u0434\u0430. 
    \u041E \u0440\u0430\u043D\u043D\u0438\u0445 \u0433\u043E\u0434\u0430\u0445 \u0424\u0435\u0440\u043C\u0430
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043D\u0435\u043C\u043D\u043E\u0433\u043E.
    \u041F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0432 \u043C\u0435\u0441\u0442\u043D\u043E\u043C
    \u0444\u0440\u0430\u043D\u0446\u0438\u0441\u043A\u0430\u043D\u0441\u043A\u043E\u043C
    \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u0435. \u041F\u043E\u0437\u0436\u0435
    \u043E\u043D \u0443\u0447\u0438\u043B\u0441\u044F \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0422\u0443\u043B\u0443\u0437\u044B, \u0430 \u0437\u0430\u0442\u0435\u043C \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u0411\u043E\u0440\u0434\u043E, \u0433\u0434\u0435 \u0432 \u043A\u043E\u043D\u0446\u0435
    1620-\u0445 \u0433\u043E\u0434\u043E\u0432 \u043D\u0430\u0447\u0430\u043B \u0441\u0432\u043E\u0438
    \u043F\u0435\u0440\u0432\u044B\u0435 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F. \u0412
    1629 \u0433\u043E\u0434\u0443 \u043E\u043D \u0443\u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043D\u0430\u0434 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435\u043C
    \u0443\u0442\u0435\u0440\u044F\u043D\u043D\u043E\u0433\u043E \u0442\u0440\u0443\u0434\u0430
    \u0410\u043F\u043E\u043B\u043B\u043E\u043D\u0438\u044F \u041F\u0435\u0440\u0433\u0441\u043A\u043E\u0433\u043E
    \xAB\u041E \u043F\u043B\u043E\u0441\u043A\u0438\u0445 \u043C\u0435\u0441\u0442\u0430\u0445\xBB
    \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434 \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C\u043E\u0432 \u0438 \u043C\u0438\u043D\u0438\u043C\u0443\u043C\u043E\u0432. 
    \u041F\u043E\u0441\u043B\u0435 \u0411\u043E\u0440\u0434\u043E \u0424\u0435\u0440\u043C\u0430
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432 \u041E\u0440\u043B\u0435\u0430\u043D,
    \u0433\u0434\u0435 \u0438\u0437\u0443\u0447\u0430\u043B \u043F\u0440\u0430\u0432\u043E
    \u0438 \u0432 1631 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430.
    \u0412 \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043A\u0443\u043F\u0438\u043B \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u0430 \u043F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442\u0430
    (\u0441\u0443\u0434\u0430) \u0432 \u0422\u0443\u043B\u0443\u0437\u0435 \u0438
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u044D\u0442\u043E\u0442
    \u0433\u043E\u0440\u043E\u0434. \u041F\u043E\u043B\u0443\u0447\u0438\u0432 \u044D\u0442\u0443
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C, \u043E\u043D \u0441\u0442\u0430\u043B
    \u0438\u043C\u0435\u0442\u044C \u043F\u0440\u0430\u0432\u043E \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C
    \u0438\u043C\u044F \u0441 \u041F\u044C\u0435\u0440 \u0424\u0435\u0440\u043C\u0430
    \u043D\u0430 \u041F\u044C\u0435\u0440 \u0434\u0435 \u0424\u0435\u0440\u043C\u0430. 
    ### \u041A\u0430\u0440\u044C\u0435\u0440\u0430 \u044E\u0440\u0438\u0441\u0442\u0430
    \u0438 \u0436\u0438\u0437\u043D\u044C \u0432 \u0422\u0443\u043B\u0443\u0437\u0435 
    \u0421 1631 \u0433\u043E\u0434\u0430 \u0438 \u0434\u043E \u0441\u0430\u043C\u043E\u0439
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0424\u0435\u0440\u043C\u0430 \u0441\u043B\u0443\u0436\u0438\u043B
    \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u043E\u043C \u043F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442\u0430
    \u0432 \u0422\u0443\u043B\u0443\u0437\u0435. \u041E\u043D \u0431\u044B\u043B
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u043A\u0430\u043A \u0434\u043E\u0431\u0440\u043E\u0441\u043E\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0438 \u0443\u043C\u0435\u043B\u044B\u0439 \u044E\u0440\u0438\u0441\u0442, \u043E\u0434\u0438\u043D
    \u0438\u0437 \u043B\u0443\u0447\u0448\u0438\u0445 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u041E\u043D \u043F\u0440\u043E\u0434\u0432\u0438\u0433\u0430\u043B\u0441\u044F
    \u043F\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u043D\u043E\u0439 \u043B\u0435\u0441\u0442\u043D\u0438\u0446\u0435:
    \u0432 1634 \u0433\u043E\u0434\u0443 \u0441\u0442\u0430\u043B \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u043E\u043C,
    \u0432 1638 \u0433\u043E\u0434\u0443 \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u0432 \u0443\u0433\u043E\u043B\u043E\u0432\u043D\u044B\u0439 \u0441\u0443\u0434,
    \u0430 \u0432 1652 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0432\u044B\u0441\u0448\u0435\u0433\u043E
    \u0443\u0440\u043E\u0432\u043D\u044F \u0432 \u0441\u0443\u0434\u0435.  \u0412
    1631 \u0433\u043E\u0434\u0443 \u0424\u0435\u0440\u043C\u0430 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0441\u0432\u043E\u0435\u0439 \u0434\u0430\u043B\u044C\u043D\u0435\u0439
    \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u0446\u0435 \u041B\u0443\u0438\u0437\u0435
    \u0434\u0435 \u041B\u043E\u043D\u0433. \u0423 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C
    \u043F\u044F\u0442\u0435\u0440\u043E \u0434\u0435\u0442\u0435\u0439, \u0441\u0442\u0430\u0440\u0448\u0435\u0433\u043E
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0437\u0432\u0430\u043B\u0438
    \u0421\u0430\u043C\u044E\u044D\u043B\u044C. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0421\u0430\u043C\u044E\u044D\u043B\u044C \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u043E\u0442\u0446\u0430 \u0441\u043E\u0431\u0440\u0430\u043B \u0438 \u0438\u0437\u0434\u0430\u043B
    \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0440\u0443\u0434\u044B \u0432 1679 \u0433\u043E\u0434\u0443.  \u0412
    1650-\u0445 \u0433\u043E\u0434\u0430\u0445 \u0424\u0435\u0440\u043C\u0430 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E
    \u043F\u0435\u0440\u0435\u0431\u043E\u043B\u0435\u043B \u0447\u0443\u043C\u043E\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0432\u0438\u0440\u0435\u043F\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u0432 \u0440\u0435\u0433\u0438\u043E\u043D\u0435. \u0411\u043E\u043B\u0435\u0437\u043D\u044C
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u044F\u0436\u0435\u043B\u043E\u0439, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0441\u043C\u0435\u0440\u0442\u044C \u0434\u0430\u0436\u0435 \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E
    \u0441\u043E\u043E\u0431\u0449\u0438\u043B\u0438 \u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435, \u043E\u0434\u043D\u0430\u043A\u043E
    \u043E\u043D \u0432\u044B\u0436\u0438\u043B.  ### \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u0438 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430 
    \u041F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u0424\u0435\u0440\u043C\u0430
    \u043F\u043E\u0447\u0442\u0438 \u043D\u0435 \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0440\u0430\u0431\u043E\u0442\u044B. \u041E \u0435\u0433\u043E
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u043C\u0438\u0440 \u0443\u0437\u043D\u0430\u0432\u0430\u043B \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0447\u0435\u0440\u0435\u0437 \u043E\u0431\u0448\u0438\u0440\u043D\u0443\u044E
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443 \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438
    \u0443\u0447\u0435\u043D\u044B\u043C\u0438, \u0442\u0430\u043A\u0438\u043C\u0438
    \u043A\u0430\u043A \u0420\u0435\u043D\u0435 \u0414\u0435\u043A\u0430\u0440\u0442,
    \u0411\u043B\u0435\u0437 \u041F\u0430\u0441\u043A\u0430\u043B\u044C, \u0425\u0440\u0438\u0441\u0442\u0438\u0430\u043D
    \u0413\u044E\u0439\u0433\u0435\u043D\u0441, \u042D\u0432\u0430\u043D\u0434\u0436\u0435\u043B\u0438\u0441\u0442\u0430
    \u0422\u043E\u0440\u0440\u0438\u0447\u0435\u043B\u043B\u0438 \u0438 \u0434\u0440\u0443\u0433\u0438\u0435.
    \u041F\u043E\u0441\u0440\u0435\u0434\u043D\u0438\u043A\u043E\u043C \u0432 \u044D\u0442\u043E\u0439
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435 \u0447\u0430\u0441\u0442\u043E
    \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B \u0430\u0431\u0431\u0430\u0442
    \u041C\u0430\u0440\u0435\u043D \u041C\u0435\u0440\u0441\u0435\u043D\u043D, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u043E\u0431\u0438\u0440\u0430\u043B \u0438 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u043B
    \u043F\u0438\u0441\u044C\u043C\u0430 \u0441\u0440\u0435\u0434\u0438 \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.  *   **\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:** \u041D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E
    \u043E\u0442 \u0414\u0435\u043A\u0430\u0440\u0442\u0430, \u0424\u0435\u0440\u043C\u0430
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u0412 \u0441\u0432\u043E\u0435\u043C
    \u0442\u0440\u0443\u0434\u0435 \xAB\u0412\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0432 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435 \u043F\u043B\u043E\u0441\u043A\u0438\u0445
    \u0438 \u0442\u0435\u043B\u0435\u0441\u043D\u044B\u0445 \u043C\u0435\u0441\u0442\xBB
    (\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E)
    \u043E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u043A\u0430\u043A \u0441
    \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u043C\u043E\u0436\u043D\u043E \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C
    \u043A\u0440\u0438\u0432\u044B\u0435 \u043B\u0438\u043D\u0438\u0438. \u041E\u043D
    \u0434\u0430\u043B \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u043F\u0440\u044F\u043C\u043E\u0439
    \u0438 \u043A\u0440\u0438\u0432\u044B\u0445 \u0432\u0442\u043E\u0440\u043E\u0433\u043E
    \u043F\u043E\u0440\u044F\u0434\u043A\u0430, \u0434\u043E\u043A\u0430\u0437\u0430\u0432,
    \u0447\u0442\u043E \u0432\u0441\u0435 \u043E\u043D\u0438 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438 \u0441\u0435\u0447\u0435\u043D\u0438\u044F\u043C\u0438.
    *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437:** \u0424\u0435\u0440\u043C\u0430 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434 \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C\u043E\u0432 \u0438 \u043C\u0438\u043D\u0438\u043C\u0443\u043C\u043E\u0432
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043C\u0435\u0442\u043E\u0434 \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u043A\u0430\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u043A \u043A\u0440\u0438\u0432\u044B\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u043F\u043E \u0441\u0443\u0442\u0438,
    \u0431\u044B\u043B \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u043C
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F. \u0415\u0433\u043E
    \u043C\u0435\u0442\u043E\u0434 \"\u0430\u0434\u0435\u043A\u0432\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438\"
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0435 \u0441\u0442\u0435\u043F\u0435\u043D\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0434\u043B\u044F \u043B\u044E\u0431\u044B\u0445
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u0435\u0439.
    \u0418\u0441\u0430\u0430\u043A \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u043E\u0437\u0436\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435 \u0438\u0434\u0435\u0438
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    \u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0438 \u0438\u0437 \"\u043C\u0435\u0442\u043E\u0434\u0430
    \u0424\u0435\u0440\u043C\u0430 \u0434\u043B\u044F \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u043A\u0430\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445\". \u041A\u0440\u043E\u043C\u0435
    \u0442\u043E\u0433\u043E, \u0424\u0435\u0440\u043C\u0430 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043E\u0431\u0449\u0435\u0435 \u043F\u0440\u0430\u0432\u0438\u043B\u043E \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0441\u0442\u0435\u043F\u0435\u043D\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439,
    \u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0432\u0430\u0436\u043D\u043E\u0439
    \u0447\u0430\u0441\u0442\u044C\u044E \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439:** \u0412
    1654 \u0433\u043E\u0434\u0443 \u0432 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435
    \u0441 \u0411\u043B\u0435\u0437\u043E\u043C \u041F\u0430\u0441\u043A\u0430\u043B\u0435\u043C
    \u0424\u0435\u0440\u043C\u0430 \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.
    \u041E\u043D\u0438 \u0440\u0435\u0448\u0430\u043B\u0438 \u0437\u0430\u0434\u0430\u0447\u0438,
    \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0435 \u0441 \u0430\u0437\u0430\u0440\u0442\u043D\u044B\u043C\u0438
    \u0438\u0433\u0440\u0430\u043C\u0438, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \"\u0437\u0430\u0434\u0430\u0447\u0443 \u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0435
    \u0441\u0442\u0430\u0432\u043E\u043A\". \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u044D\u0442\u043E\u043C\u0443 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0443
    \u0438\u0445 \u0441\u0447\u0438\u0442\u0430\u044E\u0442 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u044F\u043C\u0438
    \u044D\u0442\u043E\u0439 \u043D\u0430\u0443\u043A\u0438.  ### \u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u0412\u0435\u043B\u0438\u043A\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0438 \u0442\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B  \u0424\u0435\u0440\u043C\u0430
    \u043F\u043E \u043F\u0440\u0430\u0432\u0443 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A\u043E\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B. \u0411\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
    \u0435\u0433\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439 \u0432 \u044D\u0442\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0431\u044B\u043B\u0438 \u0437\u0430\u043F\u0438\u0441\u0430\u043D\u044B
    \u043D\u0430 \u043F\u043E\u043B\u044F\u0445 \u0435\u0433\u043E \u044D\u043A\u0437\u0435\u043C\u043F\u043B\u044F\u0440\u0430
    \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\xBB \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430. 
    *   **\u0412\u0435\u043B\u0438\u043A\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0424\u0435\u0440\u043C\u0430:** \u0421\u0430\u043C\u043E\u0435 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435
    \u0435\u0433\u043E \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435:
    **`x\u207F + y\u207F = z\u207F` \u043D\u0435 \u0438\u043C\u0435\u0435\u0442 \u0446\u0435\u043B\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u043F\u0440\u0438 `n > 2`**. \u0420\u044F\u0434\u043E\u043C
    \u0441 \u044D\u0442\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0435\u0439 \u043E\u043D
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B: \"\u042F \u043D\u0430\u0448\u0435\u043B
    \u044D\u0442\u043E\u043C\u0443 \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435
    \u0437\u0430\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E,
    \u043D\u043E \u043F\u043E\u043B\u044F \u043A\u043D\u0438\u0433\u0438 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0443\u0437\u043A\u0438 \u0434\u043B\u044F \u043D\u0435\u0433\u043E\". \u042D\u0442\u0430
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C
    \u043D\u0435\u0434\u043E\u043A\u0430\u0437\u0430\u043D\u043D\u043E\u0439 \u0431\u043E\u043B\u0435\u0435
    350 \u043B\u0435\u0442 \u0438 \u0431\u044B\u043B\u0430 \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u0430 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432 1994 \u0433\u043E\u0434\u0443 \u042D\u043D\u0434\u0440\u044E \u0423\u0430\u0439\u043B\u0441\u043E\u043C.
    *   **\u041C\u0430\u043B\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0424\u0435\u0440\u043C\u0430:** \u0412 1640 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0432\u0430\u0436\u043D\u0443\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443:
    \u0435\u0441\u043B\u0438 `p` \u2014 \u043F\u0440\u043E\u0441\u0442\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E, \u0430 `a` \u2014 \u043B\u044E\u0431\u043E\u0435
    \u0446\u0435\u043B\u043E\u0435 \u0447\u0438\u0441\u043B\u043E, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043D\u0435 \u0434\u0435\u043B\u0438\u0442\u0441\u044F \u043D\u0430 `p`, \u0442\u043E
    `a\u1D56\u207B\xB9 \u2014 1` \u0434\u0435\u043B\u0438\u0442\u0441\u044F \u043D\u0430
    `p`. \u042D\u0442\u0430 \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u0441\u0442\u0430\u043B\u0430
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u0432\u0441\u0435\u0439 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B. *   **\u041C\u0435\u0442\u043E\u0434
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E \u0441\u043F\u0443\u0441\u043A\u0430:**
    \u0424\u0435\u0440\u043C\u0430 \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u043C\u043E\u0449\u043D\u044B\u0439
    \u043C\u0435\u0442\u043E\u0434 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B
    \"\u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u043C \u0441\u043F\u0443\u0441\u043A\u043E\u043C\".
    \u042D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u0434\u043B\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043C\u043D\u043E\u0433\u0438\u0445 \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0435\u043C,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u0442\u043E\u0433\u043E,
    \u0447\u0442\u043E \u043F\u043B\u043E\u0449\u0430\u0434\u044C \u043F\u0440\u044F\u043C\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430 \u0441
    \u0446\u0435\u043B\u044B\u043C\u0438 \u0441\u0442\u043E\u0440\u043E\u043D\u0430\u043C\u0438
    \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u043C. 
    ### \u041F\u0440\u0438\u043D\u0446\u0438\u043F \u0424\u0435\u0440\u043C\u0430
    \u0432 \u0444\u0438\u0437\u0438\u043A\u0435  \u0424\u0435\u0440\u043C\u0430 \u0442\u0430\u043A\u0436\u0435
    \u0432\u043D\u0435\u0441 \u0432\u043A\u043B\u0430\u0434 \u0432 \u0444\u0438\u0437\u0438\u043A\u0443.
    \u0412 1657 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    **\u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438** \u0434\u043B\u044F \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \u0441\u0432\u0435\u0442\u0430. \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u044D\u0442\u043E\u043C\u0443 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0443,
    \u0441\u0432\u0435\u0442 \u0432\u0441\u0435\u0433\u0434\u0430 \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F
    \u043F\u043E \u043F\u0443\u0442\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u0421 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u044D\u0442\u043E\u0433\u043E \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430
    \u0424\u0435\u0440\u043C\u0430 \u0441\u043C\u043E\u0433 \u0432\u044B\u0432\u0435\u0441\u0442\u0438
    \u0437\u0430\u043A\u043E\u043D \u0421\u043D\u0435\u043B\u043B\u0438\u0443\u0441\u0430
    \u0434\u043B\u044F \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u044F
    \u0441\u0432\u0435\u0442\u0430, \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u0435\u0433\u043E \u043A \u0441\u043F\u043E\u0440\u0443 \u0441 \u0414\u0435\u043A\u0430\u0440\u0442\u043E\u043C
    \u043F\u043E \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u043C \u043E\u043F\u0442\u0438\u043A\u0438. 
    ### \u0421\u043C\u0435\u0440\u0442\u044C \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u041F\u044C\u0435\u0440 \u0434\u0435 \u0424\u0435\u0440\u043C\u0430 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    12 \u044F\u043D\u0432\u0430\u0440\u044F 1665 \u0433\u043E\u0434\u0430 \u0432
    \u0433\u043E\u0440\u043E\u0434\u0435 \u041A\u0430\u0441\u0442\u0440. \u041F\u043E\u0441\u043B\u0435
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u0435\u0433\u043E \u0441\u044B\u043D
    \u0421\u0430\u043C\u044E\u044D\u043B\u044C \u0432 1679 \u0433\u043E\u0434\u0443
    \u0438\u0437\u0434\u0430\u043B \u0441\u0431\u043E\u0440\u043D\u0438\u043A \u0435\u0433\u043E
    \u0442\u0440\u0443\u0434\u043E\u0432 \u043F\u043E\u0434 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435\u043C
    \"\u0420\u0430\u0437\u043D\u044B\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u044F\" (Varia opera mathematica),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B
    \u043C\u0438\u0440\u0443 \u043F\u043E \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u0443
    \u043E\u0446\u0435\u043D\u0438\u0442\u044C \u043C\u0430\u0441\u0448\u0442\u0430\u0431
    \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u044F.  \u0424\u0435\u0440\u043C\u0430,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u043F\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u0438
    \u044E\u0440\u0438\u0441\u0442\u043E\u043C, \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 XVII \u0432\u0435\u043A\u0430.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u0441\u0442\u0430\u043B\u0438
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u043C\u043D\u043E\u0433\u0438\u0445 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D. \u0412 \u0422\u0443\u043B\u0443\u0437\u0435
    \u0435\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C \u043D\u0430\u0437\u0432\u0430\u043D
    \u0441\u0442\u0430\u0440\u0435\u0439\u0448\u0438\u0439 \u0438 \u0441\u0430\u043C\u044B\u0439
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439 \u043B\u0438\u0446\u0435\u0439,
    \u0430 \u0434\u043E\u043C, \u0433\u0434\u0435 \u043E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F,
    \u043D\u044B\u043D\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043C\u0443\u0437\u0435\u0435\u043C."
  shortBioEn: 
  interestingFactsRu: "\u041F\u044C\u0435\u0440 \u0434\u0435 \u0424\u0435\u0440\u043C\u0430
    \u2014 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C, \u043E\u043A\u0443\u0442\u0430\u043D\u043D\u0430\u044F
    \u043E\u0440\u0435\u043E\u043B\u043E\u043C \u0442\u0430\u0439\u043D, \u043E\u0448\u0438\u0431\u043E\u043A,
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0445 \u043F\u0440\u043E\u0437\u0440\u0435\u043D\u0438\u0439
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u043B\u0430\u0431\u043E\u0441\u0442\u0435\u0439. \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C
    \u2014 \u044D\u0442\u043E \u0441\u043F\u043B\u043E\u0448\u043D\u043E\u0439 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441.
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0435,
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435 \u0438 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u0438 \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u0435\u0433\u043E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043A\u0430\u043A
    \u0433\u0435\u043D\u0438\u044F, \u043D\u043E \u0438 \u043A\u0430\u043A \u0436\u0438\u0432\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430.  ### 1. \xAB\u0412\u0435\u043B\u0438\u043A\u0438\u0439
    \u041C\u043E\u043B\u0447\u0443\u043D\xBB: \u043F\u043E\u0447\u0435\u043C\u0443
    \u043E\u043D \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u042D\u0442\u043E \u0441\u0430\u043C\u044B\u0439 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043D\u0430\u0443\u043A\u0438.
    \u041F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u0424\u0435\u0440\u043C\u0430
    \u043D\u0435 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    **\u043D\u0438 \u043E\u0434\u043D\u043E\u0439** \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E\u0434 \u0441\u0432\u043E\u0438\u043C
    \u0438\u043C\u0435\u043D\u0435\u043C (\u043B\u0438\u0448\u044C \u043F\u0430\u0440\u0443
    \u0441\u0442\u0430\u0442\u0435\u0439 \u043F\u043E \u043E\u043F\u0442\u0438\u043A\u0435). 
    *   **\u041F\u0440\u0438\u0447\u0438\u043D\u0430:** \u041E\u043D \u043D\u0435
    \u0431\u044B\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C \u0438 \u043D\u0435 \u043D\u0443\u0436\u0434\u0430\u043B\u0441\u044F
    \u0432 \u0434\u0435\u043D\u044C\u0433\u0430\u0445 \u0438\u043B\u0438 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0432\u0430\u043D\u0438\u044F\u0445. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0431\u044B\u043B\u0430 \u0434\u043B\u044F \u043D\u0435\u0433\u043E \xAB\u0445\u043E\u0431\u0431\u0438\xBB
    \u0438 \u0444\u043E\u0440\u043C\u043E\u0439 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0434\u043E\u0441\u0443\u0433\u0430. *   **\u0421\u043F\u043E\u0440\u0442\u0438\u0432\u043D\u044B\u0439
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441:** \u0424\u0435\u0440\u043C\u0430
    \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043A\u0430\u043A \u0438\u0433\u0440\u0443. \u041E\u043D \u0447\u0430\u0441\u0442\u043E
    \u043F\u043E\u0441\u044B\u043B\u0430\u043B \u043F\u0438\u0441\u044C\u043C\u0430
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C (\u041C\u0435\u0440\u0441\u0435\u043D\u043D\u0443,
    \u0420\u043E\u0431\u0435\u0440\u0432\u0430\u043B\u044E, \u041F\u0430\u0441\u043A\u0430\u043B\u044E),
    \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0434\u0430\u0432\u0430\u043B
    \u043D\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u044F, \u0430 **\u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043E\u0442\u0432\u0435\u0442\u044B** \u0438\u043B\u0438 \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0438
    \u0437\u0430\u0434\u0430\u0447, \u0441\u043B\u043E\u0432\u043D\u043E \u0431\u0440\u043E\u0441\u0430\u044F
    \u0432\u044B\u0437\u043E\u0432: \xAB\u0410 \u0441\u043B\u0430\u0431\u043E \u0432\u0430\u043C
    \u043D\u0430\u0439\u0442\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E?\xBB
    \u041E\u043D \u043D\u0430\u0441\u043B\u0430\u0436\u0434\u0430\u043B\u0441\u044F
    \u0442\u0435\u043C, \u0447\u0442\u043E \u0435\u0433\u043E \u0437\u0430\u0434\u0430\u0447\u0438
    \u043D\u0438\u043A\u0442\u043E \u043D\u0435 \u043C\u043E\u0433 \u0440\u0435\u0448\u0438\u0442\u044C
    \u0433\u043E\u0434\u0430\u043C\u0438. *   **\u0418\u0440\u043E\u043D\u0438\u044F
    \u0441\u0443\u0434\u044C\u0431\u044B:** \u0415\u0441\u043B\u0438 \u0431\u044B
    \u0435\u0433\u043E \u0441\u044B\u043D \u0421\u0430\u043C\u044E\u044D\u043B\u044C
    \u043D\u0435 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u043F\u0438\u0441\u044C\u043C\u0430 \u0438 \u0437\u0430\u043C\u0435\u0442\u043A\u0438
    \u0432 1679 \u0433\u043E\u0434\u0443, \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u043E
    \u043C\u043E\u0433\u043B\u043E \u0431\u044B \u043F\u043E\u0442\u0435\u0440\u044F\u0442\u044C
    \u0446\u0435\u043B\u044B\u0439 \u043F\u043B\u0430\u0441\u0442 \u0432\u0435\u043B\u0438\u043A\u0438\u0445
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439 \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F. 
    ### 2. \u0412\u0435\u043B\u0438\u043A\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0438 \xAB\u0421\u0430\u043C\u044B\u0439 \u0434\u0435\u0440\u0437\u043A\u0438\u0439
    \u0440\u043E\u0437\u044B\u0433\u0440\u044B\u0448\xBB \u0412 1637 \u0433\u043E\u0434\u0443
    \u0424\u0435\u0440\u043C\u0430 \u0437\u0430\u043F\u0438\u0441\u0430\u043B \u043D\u0430
    \u043F\u043E\u043B\u044F\u0445 \u043A\u043D\u0438\u0433\u0438 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0444\u0440\u0430\u0437\u0443:
    *\xAB\u042F \u043D\u0430\u0448\u0435\u043B \u044D\u0442\u043E\u043C\u0443 \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435
    \u0437\u0430\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E,
    \u043D\u043E \u043F\u043E\u043B\u044F \u043A\u043D\u0438\u0433\u0438 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0443\u0437\u043A\u0438 \u0434\u043B\u044F \u043D\u0435\u0433\u043E\xBB*. *  
    **\u041C\u0438\u0441\u0442\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044F \u0438\u043B\u0438
    \u043E\u0448\u0438\u0431\u043A\u0430?** \u0411\u043E\u043B\u0435\u0435 350 \u043B\u0435\u0442
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043B\u043E\u043C\u0430\u043B\u0438
    \u0433\u043E\u043B\u043E\u0432\u0443, \u043F\u044B\u0442\u0430\u044F\u0441\u044C
    \u043D\u0430\u0439\u0442\u0438 \u044D\u0442\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E.
    \u0412 1994 \u0433\u043E\u0434\u0443 \u0423\u0430\u0439\u043B\u0441 \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442 (\u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u0440\u0438\u0432\u044B\u0435 \u0438 \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u044B\u0435
    \u0444\u043E\u0440\u043C\u044B), \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    **\u043D\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E**
    \u0432 XVII \u0432\u0435\u043A\u0435. *   **\u0412\u044B\u0432\u043E\u0434 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432:**
    \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u043D\u0430\u0443\u043A\u0438 \u0441\u043E\u0448\u043B\u0438\u0441\u044C \u0432\u043E
    \u043C\u043D\u0435\u043D\u0438\u0438, \u0447\u0442\u043E \u0424\u0435\u0440\u043C\u0430
    **\u043E\u0448\u0438\u0431\u0430\u043B\u0441\u044F**. \u0412\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u043E\u043D \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u0441\u0432\u043E\u0439
    \u043C\u0435\u0442\u043E\u0434 \xAB\u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E
    \u0441\u043F\u0443\u0441\u043A\u0430\xBB \u0434\u043B\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430,
    \u043D\u043E \u044D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043B\u044F \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \\( n=4 \\). \u0420\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0438\u0432
    \u0435\u0433\u043E \u043D\u0430 \u0432\u0441\u0435 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0432 \u0443\u043C\u0435, \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u043E\u0448\u0438\u0431\u043A\u0443.
    \u0422\u0430\u043A \u0447\u0442\u043E \u043D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438
    350 \u043B\u0435\u0442 \u043C\u0438\u0440 \u043F\u044B\u0442\u0430\u043B\u0441\u044F
    \u043D\u0430\u0439\u0442\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E, \u0447\u0435\u0433\u043E \u0443 \u0424\u0435\u0440\u043C\u0430
    \u043F\u043E\u043F\u0440\u043E\u0441\u0442\u0443 \u043D\u0435 \u0431\u044B\u043B\u043E!
    \u042D\u0442\u043E \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0430\u044F
    \xAB\u0448\u0443\u0442\u043A\u0430\xBB \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  ### 3. \xAB\u0422\u0435\u043B\u0435\u043F\u043E\u0440\u0442\xBB
    \u0438\u0434\u0435\u0439: \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430
    \u0447\u0435\u0440\u0435\u0437 \u043E\u043A\u0435\u0430\u043D \u0412 1640-\u0445
    \u0433\u043E\u0434\u0430\u0445 \u0443 \u0424\u0435\u0440\u043C\u0430 \u0431\u044B\u043B
    \u044D\u043F\u0438\u0441\u0442\u043E\u043B\u044F\u0440\u043D\u044B\u0439 \u0441\u043F\u043E\u0440
    \u0441 \u0420\u0435\u043D\u0435 \u0414\u0435\u043A\u0430\u0440\u0442\u043E\u043C
    \u043F\u043E \u043F\u043E\u0432\u043E\u0434\u0443 \u043E\u043F\u0442\u0438\u043A\u0438
    \u0438 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.  *   \u0414\u0435\u043A\u0430\u0440\u0442
    \u0432\u044B\u0441\u043E\u043A\u043E\u043C\u0435\u0440\u043D\u043E \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0441\u044F
    \u043A \u0424\u0435\u0440\u043C\u0430, \u043D\u0430\u0437\u044B\u0432\u0430\u044F
    \u0435\u0433\u043E \xAB\u0430\u0434\u0432\u043E\u043A\u0430\u0442\u043E\u043C\xBB
    (\u0432 \u0443\u043D\u0438\u0447\u0438\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u043C
    \u0441\u043C\u044B\u0441\u043B\u0435) \u0438 \xAB\u0445\u0432\u0430\u0441\u0442\u0443\u043D\u043E\u043C\xBB.
    *   \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u0414\u0435\u043A\u0430\u0440\u0442
    \u043F\u0440\u0438\u0441\u043B\u0430\u043B \u0424\u0435\u0440\u043C\u0430 \u0437\u0430\u0434\u0430\u0447\u0443
    \u043D\u0430 \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u043A\u0430\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043A \u0441\u043B\u043E\u0436\u043D\u043E\u0439 \u043A\u0440\u0438\u0432\u043E\u0439,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u044B\u043C,
    \u0447\u0442\u043E \u0442\u043E\u0442 \u043D\u0435 \u0441\u043F\u0440\u0430\u0432\u0438\u0442\u0441\u044F.
    \u0424\u0435\u0440\u043C\u0430 \u0432 \u043E\u0442\u0432\u0435\u0442\u043D\u043E\u043C
    \u043F\u0438\u0441\u044C\u043C\u0435 \u0440\u0435\u0448\u0438\u043B \u0437\u0430\u0434\u0430\u0447\u0443
    \u0437\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u0442\u0440\u043E\u043A.
    \u0414\u0435\u043A\u0430\u0440\u0442, \u0432\u0437\u0431\u0435\u0448\u0435\u043D\u043D\u044B\u0439,
    \u0437\u0430\u044F\u0432\u0438\u043B, \u0447\u0442\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0424\u0435\u0440\u043C\u0430 \u2014 \u044D\u0442\u043E \xAB\u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0441\u0442\u044C\xBB
    \u0438 \xAB\u0438\u0433\u0440\u0430 \u0443\u043C\u0430, \u043B\u0438\u0448\u0435\u043D\u043D\u0430\u044F
    \u0441\u043C\u044B\u0441\u043B\u0430\xBB. \u041F\u043E\u0437\u0436\u0435 \u0432\u044B\u044F\u0441\u043D\u0438\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u0424\u0435\u0440\u043C\u0430 \u0431\u044B\u043B \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E
    \u043F\u0440\u0430\u0432, \u0430 \u0414\u0435\u043A\u0430\u0440\u0442 \u043E\u0448\u0438\u0431\u0430\u043B\u0441\u044F
    \u0432 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438 \u043A\u0430\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439. 
    ### 4. \u0414\u0432\u043E\u0439\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0447\u0443\u043C\u044B \u0412 1652
    \u0433\u043E\u0434\u0443 \u0422\u0443\u043B\u0443\u0437\u0443 \u043F\u043E\u0440\u0430\u0437\u0438\u043B\u0430
    \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u044F \u0447\u0443\u043C\u044B. \u0412\u044B\u0436\u0438\u0432\u0430\u0435\u043C\u043E\u0441\u0442\u044C
    \u0431\u044B\u043B\u0430 \u043A\u0440\u0430\u0439\u043D\u0435 \u043D\u0438\u0437\u043A\u043E\u0439,
    \u0438 \u043F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442 (\u0441\u0443\u0434)
    \u043F\u043E\u0442\u0435\u0440\u044F\u043B \u043C\u043D\u043E\u0433\u043E \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u0432.
    *   \u0424\u0435\u0440\u043C\u0430 \u0437\u0430\u0440\u0430\u0437\u0438\u043B\u0441\u044F
    \u0438 \u0431\u044B\u043B \u043F\u0440\u0438 \u0441\u043C\u0435\u0440\u0442\u0438.
    \u0415\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0416\u0430\u043D\u0430 \u0434\u0435 \u0411\u043E\u043A\u043A\u0430\u0440\u0430,
    \u043E\u0431\u044A\u044F\u0432\u0438\u043B\u0438 \u0435\u0433\u043E \u0443\u043C\u0435\u0440\u0448\u0438\u043C
    \u0438 \u0434\u0430\u0436\u0435 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0430\u043D\u0435\u0433\u0438\u0440\u0438\u043A \u0432 \u0435\u0433\u043E
    \u0447\u0435\u0441\u0442\u044C. *   \u041E\u0434\u043D\u0430\u043A\u043E \u0424\u0435\u0440\u043C\u0430
    \u0432\u044B\u0436\u0438\u043B. \u041E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u0432,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0441\u0447\u0438\u0442\u0430\u044E\u0442
    \u043F\u043E\u043A\u043E\u0439\u043D\u0438\u043A\u043E\u043C, \u043E\u043D, \u043E\u0431\u043B\u0430\u0434\u0430\u044F
    \u0441\u0432\u043E\u0435\u043E\u0431\u0440\u0430\u0437\u043D\u044B\u043C \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C
    \u044E\u043C\u043E\u0440\u0430, \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043F\u0438\u0441\u044C\u043C\u043E
    \u0411\u043E\u043A\u043A\u0430\u0440\u0443 \u0441\u043E \u0441\u043B\u043E\u0432\u0430\u043C\u0438:
    *\xAB\u042F \u0436\u0438\u0432 \u0438 \u0437\u0434\u043E\u0440\u043E\u0432, \u0432\u043E\u043F\u0440\u0435\u043A\u0438
    \u0432\u0430\u0448\u0438\u043C \u043D\u0435\u043A\u0440\u043E\u043B\u043E\u0433\u0430\u043C.
    \u0421\u043C\u0435\u0440\u0442\u044C \u043D\u0435 \u043F\u043E\u0436\u0435\u043B\u0430\u043B\u0430
    \u043D\u0430\u0440\u0443\u0448\u0438\u0442\u044C \u043C\u043E\u0439 \u0434\u043E\u0441\u0443\u0433\xBB*.
    *   \u0411\u043E\u043B\u0435\u0437\u043D\u044C \u0438 \u0441\u043C\u0435\u0440\u0442\u044C
    \u043A\u043E\u043B\u043B\u0435\u0433 \u043F\u0440\u0438\u0432\u0435\u043B\u0438
    \u043A \u0442\u043E\u043C\u0443, \u0447\u0442\u043E \u0432 1653 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u0438\u0435
    \u043F\u043E \u0441\u043B\u0443\u0436\u0431\u0435, \u0441\u0442\u0430\u0432 \u0441\u0443\u0434\u044C\u0435\u0439
    \u0432\u044B\u0441\u0448\u0435\u0433\u043E \u0440\u0430\u043D\u0433\u0430.  ###
    5. \xAB\u041D\u0435\u0443\u0434\u043E\u0431\u043D\u044B\u0439\xBB \u043F\u0440\u0430\u0437\u0434\u043D\u0438\u043A
    \u0412 1660 \u0433\u043E\u0434\u0443, \u043F\u043E \u0441\u043B\u0443\u0447\u0430\u044E
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0434\u043E\u0444\u0438\u043D\u0430
    (\u043D\u0430\u0441\u043B\u0435\u0434\u043D\u0438\u043A\u0430 \u043F\u0440\u0435\u0441\u0442\u043E\u043B\u0430),
    \u0432 \u0422\u0443\u043B\u0443\u0437\u0435 \u0443\u0441\u0442\u0440\u043E\u0438\u043B\u0438
    \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u044B\u0439 \u0444\u0435\u0439\u0435\u0440\u0432\u0435\u0440\u043A
    \u0438 \u043A\u0430\u0440\u043D\u0430\u0432\u0430\u043B. \u0412\u0441\u0435 \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u0438
    \u043E\u0431\u044F\u0437\u0430\u043D\u044B \u0431\u044B\u043B\u0438 \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C. 
    *   \u0424\u0435\u0440\u043C\u0430 \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B
    \u0448\u0443\u043C\u043D\u044B\u0435 \u0441\u0431\u043E\u0440\u0438\u0449\u0430
    \u0438 \u0441\u0432\u0435\u0442\u0441\u043A\u0443\u044E \u0441\u0443\u0435\u0442\u0443.
    \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0440\u0430\u043F\u043E\u0440\u0442,
    \u0447\u0442\u043E \u0431\u043E\u043B\u0435\u043D, \u0430 \u0441\u0430\u043C
    \u0432 \u044D\u0442\u043E \u0432\u0440\u0435\u043C\u044F \u0441\u0438\u0434\u0435\u043B
    \u0434\u043E\u043C\u0430 \u0438... \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u043B
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044B. *   \u0421\u043E\u0441\u0435\u0434\u0438
    \u0434\u043E\u043D\u0435\u0441\u043B\u0438 \u043D\u0430 \u043D\u0435\u0433\u043E,
    \u0438 \u0435\u0433\u043E \u043E\u0448\u0442\u0440\u0430\u0444\u043E\u0432\u0430\u043B\u0438
    \u0437\u0430 \u043F\u0440\u043E\u0433\u0443\u043B \u0441\u043B\u0443\u0436\u0431\u044B.
    \u041E\u043D \u0441 \u044E\u043C\u043E\u0440\u043E\u043C \u0437\u0430\u043F\u043B\u0430\u0442\u0438\u043B
    \u0448\u0442\u0440\u0430\u0444, \u043E\u0442\u043C\u0435\u0442\u0438\u0432 \u0432
    \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0435, \u0447\u0442\u043E \xAB\u044D\u0442\u043E
    \u0431\u044B\u043B\u043E \u0434\u0435\u0448\u0435\u0432\u043B\u0435, \u0447\u0435\u043C
    \u0442\u0440\u0430\u0442\u0438\u0442\u044C \u0432\u0435\u0447\u0435\u0440 \u0432
    \u0442\u043E\u043B\u043F\u0435\xBB.  ### 6. \u041F\u043E\u0447\u0435\u043C\u0443
    \u043E\u043D \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u0437\u043D\u0430\u043B
    \u0434\u0440\u0435\u0432\u043D\u0435\u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0439?
    \u0424\u0435\u0440\u043C\u0430 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0437\u043D\u0430\u043B \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0439
    \u2014 \u043E\u043D \u0431\u044B\u043B \u0444\u0438\u043B\u043E\u043B\u043E\u0433\u043E\u043C-\u043A\u043B\u0430\u0441\u0441\u0438\u043A\u043E\u043C.
    \u0415\u0433\u043E \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0430\u043B\u0438
    \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0442\u0438\u043F\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u043F\u0440\u0438
    \u0438\u0437\u0434\u0430\u043D\u0438\u0438 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0442\u0435\u043A\u0441\u0442\u043E\u0432 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430
    \u0438 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430. *   \u0418\u043C\u0435\u043D\u043D\u043E
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u044D\u0442\u043E\u043C\u0443
    \u043E\u043D \u0447\u0438\u0442\u0430\u043B \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0443\xBB
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u0432 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u0435.
    \u0410\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u0435 \u0438 \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u0438\u0435
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u044B \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0431\u044B\u043B\u0438 \u043F\u043E\u043B\u043D\u044B \u043E\u0448\u0438\u0431\u043E\u043A.
    \u0415\u0441\u043B\u0438 \u0431\u044B \u0424\u0435\u0440\u043C\u0430 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u043F\u043B\u043E\u0445\u0438\u043C \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u043E\u043C,
    \u043E\u043D, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u0431\u044B \u043D\u0435 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u0412\u0435\u043B\u0438\u043A\u0443\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443,
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u0432 \u043F\u043B\u043E\u0445\u0438\u0445
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0430\u0445 \u0443\u0441\u043B\u043E\u0432\u0438\u044F
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0431\u044B\u043B\u0438 \u0438\u0441\u043A\u0430\u0436\u0435\u043D\u044B. 
    ### 7. \xAB\u0427\u0438\u0441\u043B\u0430 \u0424\u0435\u0440\u043C\u0430\xBB
    \u0438 \u043E\u0448\u0438\u0431\u043A\u0430 \u0432 \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u0435
    \u0424\u0435\u0440\u043C\u0430 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u043B,
    \u0447\u0442\u043E \u0432\u0441\u0435 \u0447\u0438\u0441\u043B\u0430 \u0432\u0438\u0434\u0430
    \\( F_n = 2^{2^n} + 1 \\) \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F \u043F\u0440\u043E\u0441\u0442\u044B\u043C\u0438
    (\u043D\u0435\u0434\u0435\u043B\u0438\u043C\u044B\u043C\u0438).  *   \u0414\u043B\u044F
    \\( n=0,1,2,3,4 \\) \u044D\u0442\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0442\u0430\u043A (3, 5, 17, 257, 65537). \u0424\u0435\u0440\u043C\u0430 \u0431\u044B\u043B
    \u0443\u0432\u0435\u0440\u0435\u043D, \u0447\u0442\u043E \u044D\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    \u0434\u043B\u044F \u0432\u0441\u0435\u0445 \\( n \\). *   \u0427\u0435\u0440\u0435\u0437
    100 \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u042D\u0439\u043B\u0435\u0440 \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u043B
    \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0435 \u0447\u0438\u0441\u043B\u043E
    \\( F_5 \\) \u0438 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B, \u0447\u0442\u043E
    \u043E\u043D\u043E \u0434\u0435\u043B\u0438\u0442\u0441\u044F \u043D\u0430 641.
    \u0424\u0435\u0440\u043C\u0430 \u043E\u0448\u0438\u0431\u0441\u044F! \u042D\u0442\u043E
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0440\u0435\u0434\u043A\u0438\u0445 \u0441\u043B\u0443\u0447\u0430\u0435\u0432,
    \u043A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u044F
    \u043F\u043E\u0434\u0432\u0435\u043B\u0430 \u0435\u0433\u043E \u0432 \u0447\u0438\u0441\u043B\u0430\u0445,
    \u043D\u043E \u0441\u0430\u043C \u0444\u0430\u043A\u0442 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u044D\u0442\u0438\u0445 \u0447\u0438\u0441\u0435\u043B \u0441\u0435\u0439\u0447\u0430\u0441
    \u043B\u0435\u0436\u0438\u0442 \u0432 \u043E\u0441\u043D\u043E\u0432\u0435 \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0445 \u043C\u043D\u043E\u0433\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0446\u0438\u0440\u043A\u0443\u043B\u044F
    \u0438 \u043B\u0438\u043D\u0435\u0439\u043A\u0438.  ### 8. \u0421\u043C\u0435\u0440\u0442\u044C
    \u0432 \u0441\u0443\u0434\u0435\u0439\u0441\u043A\u043E\u043C \u043A\u0440\u0435\u0441\u043B\u0435
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u0430
    \u0443\u0447\u0435\u043D\u044B\u0445, \u0443\u043C\u0435\u0440\u0448\u0438\u0445
    \u0432 \u0442\u0438\u0448\u0438\u043D\u0435 \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u043E\u0432,
    \u0424\u0435\u0440\u043C\u0430 \u0443\u0448\u0435\u043B \u0438\u0437 \u0436\u0438\u0437\u043D\u0438
    \u043F\u0440\u044F\u043C\u043E \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0440\u0430\u0431\u043E\u0442\u044B. 
    *   \u0412 \u044F\u043D\u0432\u0430\u0440\u0435 1665 \u0433\u043E\u0434\u0430
    \u043E\u043D \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0441\u044F \u0432 \u043A\u043E\u043C\u0430\u043D\u0434\u0438\u0440\u043E\u0432\u043A\u0435
    \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u041A\u0430\u0441\u0442\u0440, \u0433\u0434\u0435
    \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B\u0430 \u0441\u0443\u0434\u0435\u0431\u043D\u0430\u044F
    \u0441\u0435\u0441\u0441\u0438\u044F. \u0412 \u043F\u0435\u0440\u0435\u0440\u044B\u0432\u0435
    \u043C\u0435\u0436\u0434\u0443 \u0437\u0430\u0441\u0435\u0434\u0430\u043D\u0438\u044F\u043C\u0438
    \u043E\u043D \u043F\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u0435\u0431\u044F \u043F\u043B\u043E\u0445\u043E (\u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0443 \u043D\u0435\u0433\u043E \u0441\u043B\u0443\u0447\u0438\u043B\u0441\u044F
    \u0438\u043D\u0441\u0443\u043B\u044C\u0442). \u041E\u043D \u0443\u043F\u0430\u043B
    \u043F\u0440\u044F\u043C\u043E \u0432 \u043C\u0430\u043D\u0442\u0438\u0438 \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u0430.
    *   \u0415\u0433\u043E \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0438\u043B\u0438
    \u0441\u043A\u0440\u043E\u043C\u043D\u043E, \u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0447\u0435\u0440\u0435\u0437 14 \u043B\u0435\u0442 \u043C\u0438\u0440 \u0443\u0437\u043D\u0430\u043B,
    \u043A\u043E\u0433\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u043F\u043E\u0442\u0435\u0440\u044F\u043B. 
    ### 9. \u0421\u044B\u043D-\u0438\u0437\u0434\u0430\u0442\u0435\u043B\u044C: \xAB\u0421\u0434\u0435\u043B\u0430\u043B
    \u044D\u0442\u043E \u043D\u0430\u0437\u043B\u043E\xBB \u0421\u0430\u043C\u044E\u044D\u043B\u044C
    \u0424\u0435\u0440\u043C\u0430, \u0441\u0442\u0430\u0440\u0448\u0438\u0439 \u0441\u044B\u043D,
    \u0442\u043E\u0436\u0435 \u0431\u044B\u043B \u044E\u0440\u0438\u0441\u0442\u043E\u043C.
    \u041E\u043D \u043D\u0435 \u043E\u0447\u0435\u043D\u044C \u0440\u0430\u0437\u0431\u0438\u0440\u0430\u043B\u0441\u044F
    \u0432 \u0432\u044B\u0441\u0448\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. 
    *   \u0415\u0433\u043E \u043E\u0442\u0446\u0430 \u0443\u0436\u0435 \u043F\u043E\u0447\u0442\u0438
    \u0437\u0430\u0431\u044B\u043B\u0438 \u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u043A\u0440\u0443\u0433\u0430\u0445 (\u043F\u0440\u043E\u0448\u043B\u043E 14
    \u043B\u0435\u0442), \u043A\u043E\u0433\u0434\u0430 \u0421\u0430\u043C\u044E\u044D\u043B\u044C
    \u0440\u0435\u0448\u0438\u043B \u0438\u0437\u0434\u0430\u0442\u044C \u0441\u0431\u043E\u0440\u043D\u0438\u043A
    \xAB\u0420\u0430\u0437\u043D\u044B\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u044F\xBB (Varia Opera Mathematica). 
    *   \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u0441\u0447\u0438\u0442\u0430\u044E\u0442,
    \u0447\u0442\u043E \u0421\u0430\u043C\u044E\u044D\u043B\u044C \u0441\u0434\u0435\u043B\u0430\u043B
    \u044D\u0442\u043E \u0438\u0437 \u0447\u0438\u0441\u0442\u043E\u0433\u043E \u0443\u043F\u0440\u044F\u043C\u0441\u0442\u0432\u0430,
    \u0447\u0442\u043E\u0431\u044B \xAB\u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u043E\u0442\u0446\u0430 \u043D\u0430 \u043E\u0434\u0438\u043D \u0443\u0440\u043E\u0432\u0435\u043D\u044C
    \u0441 \u0414\u0435\u043A\u0430\u0440\u0442\u043E\u043C\xBB. \u0415\u0441\u043B\u0438
    \u0431\u044B \u043D\u0435 \u0430\u043C\u0431\u0438\u0446\u0438\u0438 \u0441\u044B\u043D\u0430,
    \u0412\u0435\u043B\u0438\u043A\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0424\u0435\u0440\u043C\u0430 \u043C\u043E\u0433\u043B\u0430 \u0431\u044B \u043A\u0430\u043D\u0443\u0442\u044C
    \u0432 \u041B\u0435\u0442\u0443 \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430. 
    ### 10. \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0432 \u044F\u0437\u044B\u043A\u0435
    \u0438 \u0431\u044B\u0442\u0443 *   \u0418\u043C\u044F \u0424\u0435\u0440\u043C\u0430
    \u0432\u043E\u0448\u043B\u043E \u0432 \u043E\u0431\u0438\u0445\u043E\u0434 \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0432 \u043D\u0430\u0443\u043A\u0435. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    **\xAB\u041F\u0440\u0438\u043D\u0446\u0438\u043F \u0424\u0435\u0440\u043C\u0430\xBB**
    \u0432 \u043E\u043F\u0442\u0438\u043A\u0435, **\xAB\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0424\u0435\u0440\u043C\u0430\xBB**, **\xAB\u0427\u0438\u0441\u043B\u0430 \u0424\u0435\u0440\u043C\u0430\xBB**. 
    *   \u0412 \u0422\u0443\u043B\u0443\u0437\u0435 \u0435\u0433\u043E \u0434\u043E\u043C
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0441\u044F \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440 \u0438 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043C\u0443\u0437\u0435\u0435\u043C,
    \u0430 \u043D\u0430 \u0444\u0430\u0441\u0430\u0434\u0435 \u0432\u0438\u0441\u0438\u0442
    \u0442\u0430\u0431\u043B\u0438\u0447\u043A\u0430: *\xAB\u0417\u0434\u0435\u0441\u044C
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u041F\u044C\u0435\u0440 \u0434\u0435
    \u0424\u0435\u0440\u043C\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u043E\u043C \u043F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442\u0430,
    \u043F\u0440\u043E\u0441\u043B\u0430\u0432\u0438\u043B \u0422\u0443\u043B\u0443\u0437\u0443
    \u0441\u0432\u043E\u0438\u043C \u0433\u0435\u043D\u0438\u0435\u043C\xBB*. *  
    \u0412 \u0435\u0433\u043E \u0447\u0435\u0441\u0442\u044C \u043D\u0430\u0437\u0432\u0430\u043D
    **\u041B\u0438\u0446\u0435\u0439 \u041F\u044C\u0435\u0440\u0430 \u0434\u0435
    \u0424\u0435\u0440\u043C\u0430** \u2014 \u043E\u0434\u043D\u043E \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0445
    \u0443\u0447\u0435\u0431\u043D\u044B\u0445 \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0439
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438.  **\u0420\u0435\u0437\u044E\u043C\u0438\u0440\u0443\u044E\u0449\u0438\u0439
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441:** \u0424\u0435\u0440\u043C\u0430
    \u0431\u044B\u043B \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B
    \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C, \u0430\u0432\u0442\u043E\u0440\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043D\u0438\u0447\u0435\u0433\u043E
    \u043D\u0435 \u043F\u0435\u0447\u0430\u0442\u0430\u043B, \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0447\u0430\u0441\u0442\u043E \u043E\u0448\u0438\u0431\u0430\u043B\u0441\u044F
    \u0432 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430\u0445, \u043D\u043E \u0435\u0433\u043E
    \u043E\u0448\u0438\u0431\u043A\u0438 (\u043A\u0430\u043A \u0441 \u0412\u0435\u043B\u0438\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0435\u043C\u043E\u0439) \u0434\u0432\u0438\u0433\u0430\u043B\u0438
    \u043D\u0430\u0443\u043A\u0443 \u0432\u043F\u0435\u0440\u0435\u0434 \u0433\u043E\u0440\u0430\u0437\u0434\u043E
    \u0441\u0438\u043B\u044C\u043D\u0435\u0435, \u0447\u0435\u043C \u0432\u0435\u0440\u043D\u044B\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433.
    \u041E\u043D \u2014 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u0439 \u043F\u0440\u0438\u043C\u0435\u0440
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u043D\u0435 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0441\u0442\u0430\u0442\u0443\u0441\u0430, \u0430 \u0442\u0440\u0435\u0431\u0443\u0435\u0442
