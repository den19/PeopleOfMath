  achievementsRu: "\u041B\u0435\u043E\u043D\u0430\u0440\u0434 \u042D\u0439\u043B\u0435\u0440
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F
    \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043F\u043E \u0441\u0432\u043E\u0435\u043C\u0443
    \u043E\u0431\u044A\u0451\u043C\u0443 \u0438 \u0437\u043D\u0430\u0447\u0438\u043C\u043E\u0441\u0442\u0438
    \u043D\u0435 \u0438\u043C\u0435\u0435\u0442 \u0430\u043D\u0430\u043B\u043E\u0433\u043E\u0432
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438. \u0415\u0433\u043E \u043F\u0435\u0440\u0443
    \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442 \u043E\u043A\u043E\u043B\u043E
    850 \u0440\u0430\u0431\u043E\u0442, \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0438\u0445
    \u0432\u0441\u0435 \u0440\u0430\u0437\u0434\u0435\u043B\u044B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0435\u043C\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0444\u0438\u0437\u0438\u043A\u0443, \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044E
    \u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0445
    \u043D\u0430\u0443\u043A. \u041F\u043E \u043E\u0446\u0435\u043D\u043A\u0430\u043C,
    \u0435\u0433\u043E \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438
    \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0438 \u043E\u043A\u043E\u043B\u043E
    \u0442\u0440\u0435\u0442\u0438 \u0432\u0441\u0435\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0438\u0437\u0434\u0430\u043D\u0438\u0439 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435 \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u0437\u0430 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044E\u044E
    \u0447\u0435\u0442\u0432\u0435\u0440\u0442\u044C XVIII \u0432\u0435\u043A\u0430.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u043C\u043E\u0436\u043D\u043E
    \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0442\u044C
    \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u0432\u0437\u0430\u0438\u043C\u043E\u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F\u0445.  ###
    \U0001F9EE \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430: \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u044F\u0437\u044B\u043A\u0430 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438  \u042D\u0439\u043B\u0435\u0440 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0440\u0435\u0448\u0438\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0445 \u0437\u0430\u0434\u0430\u0447,
    \u043E\u043D \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E \u0441\u043E\u0437\u0434\u0430\u043B
    \u044F\u0437\u044B\u043A, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0438 \u0444\u0438\u0437\u0438\u043A\u0430.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u0430\u044F \u0437\u0430\u0441\u043B\u0443\u0433\u0430
    \u2014 \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u0438\u0437 \u043D\u0430\u0431\u043E\u0440\u0430
    \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0445 \u043C\u0435\u0442\u043E\u0434\u043E\u0432
    \u0432 \u0435\u0434\u0438\u043D\u0443\u044E, \u0441\u0442\u0440\u043E\u0439\u043D\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443.  *   **\u041A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438**: \u0412 \u0441\u0432\u043E\u0451\u043C
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u043C
    \u0442\u0440\u0443\u0434\u0435 **\xAB\u0412\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0432 \u0430\u043D\u0430\u043B\u0438\u0437 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445\xBB
    (1748)** \u042D\u0439\u043B\u0435\u0440 \u043F\u043E\u043B\u043E\u0436\u0438\u043B
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0432\u0441\u0435\u0433\u043E \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    **\u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u0444\u0443\u043D\u043A\u0446\u0438\u0438**.
    \u0414\u043E \u043D\u0435\u0433\u043E \u0430\u043D\u0430\u043B\u0438\u0437 \u0431\u044B\u043B
    \u0441\u043A\u043E\u0440\u0435\u0435 \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435\u043C
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0438\u0451\u043C\u043E\u0432. \u042D\u0439\u043B\u0435\u0440 \u0436\u0435
    \u0437\u0430\u044F\u0432\u0438\u043B, \u0447\u0442\u043E \xAB\u0432\u0435\u0441\u044C
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E
    \u043C\u0430\u043B\u044B\u0445 \u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F
    \u0432\u043E\u043A\u0440\u0443\u0433 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D \u0438 \u0438\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439\xBB,
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0432 \u0444\u0443\u043D\u043A\u0446\u0438\u044E
    \u043A\u0430\u043A \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u0435. \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043E\u0442\u0434\u0435\u043B\u0438\u043B\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043E\u0442 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u0438 \u043F\u0440\u0438\u0434\u0430\u043B\u0430 \u0435\u0439 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C.
    *   **\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043D\u043E\u0432\u044B\u0445
    \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438**:
    \u042D\u0439\u043B\u0435\u0440 \u043F\u043E \u043F\u0440\u0430\u0432\u0443 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    **\u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u043C \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F** \u2014 \u0440\u0430\u0437\u0434\u0435\u043B\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0438\u0449\u0435\u0442 \u0444\u0443\u043D\u043A\u0446\u0438\u0438,
    \u0434\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0449\u0438\u0435 \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C
    \u0438\u043B\u0438 \u043C\u0438\u043D\u0438\u043C\u0443\u043C \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u044B. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0440\u0430\u0437\u0432\u0438\u043B \u0442\u0435\u043E\u0440\u0438\u044E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439, \u0437\u0430\u043B\u043E\u0436\u0438\u0432
    \u043E\u0441\u043D\u043E\u0432\u044B \u043A\u0430\u043A \u0434\u043B\u044F \u043E\u0431\u044B\u043A\u043D\u043E\u0432\u0435\u043D\u043D\u044B\u0445,
    \u0442\u0430\u043A \u0438 \u0434\u043B\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0432 \u0447\u0430\u0441\u0442\u043D\u044B\u0445 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0445.
    *   **\u041D\u043E\u0432\u044B\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0438 \u0442\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B**:
    \u042D\u0439\u043B\u0435\u0440 \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B, \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u0432 \u043C\u0435\u0442\u043E\u0434\u044B
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u0434\u043B\u044F \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432 \u0446\u0435\u043B\u044B\u0445 \u0447\u0438\u0441\u0435\u043B.
    \u0412 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0435\u0433\u043E
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C
    \u0441\u0442\u0430\u043B\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    **\u0437\u0430\u043A\u043E\u043D\u0430 \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438**
    (\u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0439 \u0437\u0430\u043A\u043E\u043D
    \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438), \u0441\u0442\u0430\u0432\u0448\u0435\u0433\u043E
    \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C \u043A\u0430\u043C\u043D\u0435\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B. *   **\u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u043A\u0430**: \u041C\u043D\u043E\u0433\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u044B \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u0441\u0447\u0438\u0442\u0430\u0435\u043C
    \u0441\u0430\u043C\u043E \u0441\u043E\u0431\u043E\u0439 \u0440\u0430\u0437\u0443\u043C\u0435\u044E\u0449\u0438\u043C\u0438\u0441\u044F,
    \u0432\u0432\u0451\u043B \u0438\u043C\u0435\u043D\u043D\u043E \u042D\u0439\u043B\u0435\u0440.
    \u0421\u0440\u0435\u0434\u0438 \u043D\u0438\u0445:     *   **f(x)** \u2014 \u0434\u043B\u044F
    \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u0438.    
    *   **\u03A3** \u2014 \u0434\u043B\u044F \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    \u0441\u0443\u043C\u043C\u044B.     *   **e** \u2014 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0430.    
    *   **i** \u2014 \u043C\u043D\u0438\u043C\u0430\u044F \u0435\u0434\u0438\u043D\u0438\u0446\u0430.    
    *   \u041F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0430\u0446\u0438\u044F
    **\u03C0** (\u043F\u0438).  ### \u2699\uFE0F \u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430
    \u0438 \u0444\u0438\u0437\u0438\u043A\u0430: \u043F\u0435\u0440\u0435\u0432\u043E\u0434
    \u0444\u0438\u0437\u0438\u043A\u0438 \u043D\u0430 \u044F\u0437\u044B\u043A \u0444\u043E\u0440\u043C\u0443\u043B 
    \u0412\u043A\u043B\u0430\u0434 \u042D\u0439\u043B\u0435\u0440\u0430 \u0432 \u0444\u0438\u0437\u0438\u043A\u0443
    \u043D\u0435 \u043C\u0435\u043D\u0435\u0435 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u0435\u043D.
    \u0415\u0441\u043B\u0438 \u041D\u044C\u044E\u0442\u043E\u043D \u0438\u0437\u043B\u0430\u0433\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0437\u0430\u043A\u043E\u043D\u044B \u043F\u0440\u0435\u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u043D\u0430 \u044F\u0437\u044B\u043A\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u0442\u043E \u042D\u0439\u043B\u0435\u0440 \u043F\u0435\u0440\u0435\u0432\u0435\u043B
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443 \u043D\u0430 \u044F\u0437\u044B\u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430, \u0441\u0434\u0435\u043B\u0430\u0432
    \u0435\u0451 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u0439 \u0434\u043B\u044F
    \u0440\u0430\u0441\u0447\u0451\u0442\u043E\u0432.  *   **\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430**: \u0415\u0433\u043E \u0434\u0432\u0443\u0445\u0442\u043E\u043C\u043D\u0430\u044F
    **\xAB\u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430, \u0438\u043B\u0438 \u041D\u0430\u0443\u043A\u0430
    \u043E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438, \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u043D\u0430\u044F
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\xBB
    (1736)** \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u044B\u043C
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u043C, \u0433\u0434\u0435 \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0430
    \u0442\u043E\u0447\u043A\u0438 \u0431\u044B\u043B\u0430 \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0430
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043D\u043E\u0432\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F. \u042D\u0442\u043E
    \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u043E \u0435\u043C\u0443 \u043E\u0431\u0449\u0435\u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0443\u044E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C. *   **\u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430
    \u0442\u0432\u0451\u0440\u0434\u043E\u0433\u043E \u0442\u0435\u043B\u0430**:
    \u042D\u0439\u043B\u0435\u0440 \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438 \u0442\u0432\u0451\u0440\u0434\u043E\u0433\u043E
    \u0442\u0435\u043B\u0430. \u041E\u043D \u0432\u0432\u0451\u043B **\xAB\u0443\u0433\u043B\u044B
    \u042D\u0439\u043B\u0435\u0440\u0430\xBB** \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F \u0442\u0432\u0451\u0440\u0434\u043E\u0433\u043E
    \u0442\u0435\u043B\u0430, \u0432\u044B\u0432\u0435\u043B **\xAB\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u042D\u0439\u043B\u0435\u0440\u0430\xBB** \u0434\u043B\u044F \u0435\u0433\u043E
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0438 \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u043B
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u0446\u0435\u043D\u0442\u0440\u0430
    \u043C\u0430\u0441\u0441 \u0438 \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0432\u043E\u043A\u0440\u0443\u0433 \u043D\u0435\u0433\u043E. \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430 **\xAB\u0422\u0435\u043E\u0440\u0438\u044F
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0442\u0432\u0451\u0440\u0434\u044B\u0445
    \u0442\u0435\u043B\xBB (1765)** \u0441\u0442\u0430\u043B\u0430 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. *  
    **\u0413\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0430**:
    \u0412 1757 \u0433\u043E\u0434\u0443 \u042D\u0439\u043B\u0435\u0440 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435 **\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u042D\u0439\u043B\u0435\u0440\u0430**, \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0449\u0438\u0435
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E\u0439
    (\u043D\u0435\u0432\u044F\u0437\u043A\u043E\u0439) \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0438.
    \u042D\u0442\u0438 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C \u0433\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438.
    *   **\u041F\u0440\u0438\u043D\u0446\u0438\u043F \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0433\u043E
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F**: \u042D\u0439\u043B\u0435\u0440
    \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u041C\u043E\u043F\u0435\u0440\u0442\u044E\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E\u0442 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439 \u043F\u0440\u0438\u043D\u0446\u0438\u043F
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438, \u043F\u043E\u043A\u0430\u0437\u0430\u0432,
    \u0447\u0442\u043E \u043F\u0440\u0438 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438
    \u0442\u0435\u043B\u0430 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u0430 (\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435)
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0442 \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435. *   **\u041E\u043F\u0442\u0438\u043A\u0430**:
    \u0412 \u0441\u043F\u043E\u0440\u0435 \u043E \u043F\u0440\u0438\u0440\u043E\u0434\u0435
    \u0441\u0432\u0435\u0442\u0430 \u042D\u0439\u043B\u0435\u0440 \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B
    \u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043A\u043E\u043C \u0432\u043E\u043B\u043D\u043E\u0432\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u0431\u044B\u043B\u0430 \u0430\u043B\u044C\u0442\u0435\u0440\u043D\u0430\u0442\u0438\u0432\u043E\u0439
    \u043D\u044C\u044E\u0442\u043E\u043D\u043E\u0432\u0441\u043A\u043E\u0439 \u043A\u043E\u0440\u043F\u0443\u0441\u043A\u0443\u043B\u044F\u0440\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F
    \u0430\u0445\u0440\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043E\u0432 \u0434\u043B\u044F
    \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u043E\u0432.  ### \U0001F30C
    \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F \u0438 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0435
    \u043D\u0430\u0443\u043A\u0438  \u0413\u0435\u043D\u0438\u0439 \u042D\u0439\u043B\u0435\u0440\u0430
    \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B\u0441\u044F \u0438 \u0432 \u0440\u0435\u0448\u0435\u043D\u0438\u0438
    \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0445 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447.  *   **\u041D\u0435\u0431\u0435\u0441\u043D\u0430\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430**: \u041E\u043D \u043C\u043D\u043E\u0433\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0435\u0439
    \u0437\u0430\u0434\u0430\u0447\u0435\u0439 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u041B\u0443\u043D\u044B (\u0437\u0430\u0434\u0430\u0447\u0430 \u0442\u0440\u0451\u0445
    \u0442\u0435\u043B: \u0421\u043E\u043B\u043D\u0446\u0435, \u0417\u0435\u043C\u043B\u044F,
    \u041B\u0443\u043D\u0430). \u0415\u0433\u043E \u0440\u0430\u0441\u0447\u0451\u0442\u044B
    \u0431\u044B\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u043E\u0447\u043D\u044B, \u0447\u0442\u043E \u043B\u0435\u0433\u043B\u0438
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u043C\u043E\u0440\u0435\u0445\u043E\u0434\u043D\u044B\u0445
    \u0442\u0430\u0431\u043B\u0438\u0446 \u0434\u043B\u044F \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u0434\u043E\u043B\u0433\u043E\u0442\u044B \u0432 \u043C\u043E\u0440\u0435. \u042D\u0439\u043B\u0435\u0440
    \u0442\u0430\u043A\u0436\u0435 \u043F\u0435\u0440\u0432\u044B\u043C \u0441 \u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B
    **\u043C\u0430\u0441\u0441\u0443 \u041B\u0443\u043D\u044B**, \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0432,
    \u0447\u0442\u043E \u043E\u043D\u0430 \u043C\u0435\u043D\u044C\u0448\u0435 \u0437\u0435\u043C\u043D\u043E\u0439
    \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E \u0432 81 \u0440\u0430\u0437.
    *   **\u0418\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u044B\u0435 \u0440\u0430\u0441\u0447\u0451\u0442\u044B**:
    \u042D\u0439\u043B\u0435\u0440 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430\u043C\u0438 \u043E\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438
    \u043A\u043E\u0440\u0430\u0431\u043B\u0435\u0439, \u0441\u043E\u0437\u0434\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u0442\u0443\u0440\u0431\u0438\u043D \u0438
    \u0432\u0435\u0442\u0440\u044F\u043D\u044B\u0445 \u043C\u0435\u043B\u044C\u043D\u0438\u0446.
    \u0412 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0441\u043E\u043F\u0440\u043E\u0442\u0438\u0432\u043B\u0435\u043D\u0438\u044F
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    **\u0444\u043E\u0440\u043C\u0443\u043B\u0430 \u042D\u0439\u043B\u0435\u0440\u0430**
    \u0434\u043B\u044F \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043D\u0430\u0433\u0440\u0443\u0437\u043A\u0438, \u043F\u0440\u0438 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0441\u0436\u0438\u043C\u0430\u0435\u043C\u0430\u044F \u043A\u043E\u043B\u043E\u043D\u043D\u0430
    \u0442\u0435\u0440\u044F\u0435\u0442 \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u044C.
    \u042D\u0432\u043E\u043B\u044C\u0432\u0435\u043D\u0442\u043D\u044B\u0439 \u043F\u0440\u043E\u0444\u0438\u043B\u044C
    \u0437\u0443\u0431\u0430 \u0448\u0435\u0441\u0442\u0435\u0440\u0451\u043D, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u0432
    \u043C\u0430\u0448\u0438\u043D\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0438,
    \u0442\u0430\u043A\u0436\u0435 \u0441\u0432\u044F\u0437\u0430\u043D \u0441 \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430\u043C\u0438. *   **\u041A\u0430\u0440\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u044F**:
    \u0420\u0430\u0431\u043E\u0442\u0430\u044F \u0432 \u0420\u043E\u0441\u0441\u0438\u0438,
    \u043E\u043D \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u043B \u043A\u0430\u0440\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0441\u0442\u0440\u0430\u043D\u044B, \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u043F\u043E\u043B\u043D\u043E\u0433\u043E
    **\u0413\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u0442\u043B\u0430\u0441\u0430 \u0420\u043E\u0441\u0441\u0438\u0438** \u0432
    1745 \u0433\u043E\u0434\u0443.  ### \U0001F4DC \u041D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043F\u0440\u043E\u0441\u0432\u0435\u0449\u0435\u043D\u0438\u0435  \u042D\u0439\u043B\u0435\u0440
    \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C,
    \u043D\u043E \u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C
    \u043D\u0430\u0443\u043A\u0438. \u0415\u0433\u043E **\xAB\u041F\u0438\u0441\u044C\u043C\u0430
    \u043A \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0439 \u043F\u0440\u0438\u043D\u0446\u0435\u0441\u0441\u0435
    \u043E \u0440\u0430\u0437\u043D\u044B\u0445 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445 \u043C\u0430\u0442\u0435\u0440\u0438\u044F\u0445\xBB
    (1768-1772)** \u0441\u0442\u0430\u043B\u0438 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u043C
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C \u043E\u0441\u043D\u043E\u0432
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438, \u043E\u043F\u0442\u0438\u043A\u0438,
    \u0430\u043A\u0443\u0441\u0442\u0438\u043A\u0438 \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438,
    \u0432\u044B\u0434\u0435\u0440\u0436\u0430\u0432 \u043E\u043A\u043E\u043B\u043E
    40 \u0438\u0437\u0434\u0430\u043D\u0438\u0439 \u043D\u0430 10 \u044F\u0437\u044B\u043A\u0430\u0445.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0438
    \u043F\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0435 **\xAB\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u0430\u044F
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430\xBB (1768-1769)**. 
    \u0414\u0430\u0436\u0435 \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u043B\u043D\u043E\u0439
    \u043F\u043E\u0442\u0435\u0440\u0438 \u0437\u0440\u0435\u043D\u0438\u044F \u0432
    1766 \u0433\u043E\u0434\u0443 \u042D\u0439\u043B\u0435\u0440 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B
    \u0434\u0438\u043A\u0442\u043E\u0432\u0430\u0442\u044C \u0441\u0432\u043E\u0438
    \u0440\u0430\u0431\u043E\u0442\u044B, \u0441\u043E\u0437\u0434\u0430\u0432 \u0437\u0430
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 17 \u043B\u0435\u0442
    \u0436\u0438\u0437\u043D\u0438 \u043E\u043A\u043E\u043B\u043E 380 \u0441\u0442\u0430\u0442\u0435\u0439
    \u0438 \u043A\u043D\u0438\u0433. \u0415\u0433\u043E \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C,
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F \u044F\u0441\u043D\u043E\u0441\u0442\u044C
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u0438 \u0433\u043B\u0443\u0431\u0438\u043D\u0430
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439 \u0441\u0434\u0435\u043B\u0430\u043B\u0438
    \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C \xAB\u043E\u0431\u0449\u0438\u043C
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C\xBB \u0434\u043B\u044F \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0445
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0439 \u0443\u0447\u0451\u043D\u044B\u0445. 
    \u0415\u0441\u043B\u0438 \u0445\u043E\u0442\u0438\u0442\u0435, \u043C\u044B \u043C\u043E\u0436\u0435\u043C
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0435 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C\u0441\u044F
    \u043D\u0430 \u043A\u0430\u043A\u043E\u0439-\u043B\u0438\u0431\u043E \u0438\u0437
    \u044D\u0442\u0438\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043D\u0430 \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434\u0435 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0447\u0438\u0441\u0435\u043B \u0438\u043B\u0438 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u0445
    \u0433\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u0430 \u042D\u0439\u043B\u0435\u0440\u0430
    \u2014 \u044D\u0442\u043E \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E \u0441\u0447\u0430\u0441\u0442\u044C\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043E\u043D \u043E\u0431\u0440\u0451\u043B
    \u0432 \u0441\u0435\u043C\u044C\u0435, \u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0435\u0433\u043E \u043D\u0435 \u0441\u043B\u043E\u043C\u0438\u043B\u0430. \u041E\u043D\u0430
    \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0435\u0439 \u043B\u044E\u0431\u043E\u0432\u044C\u044E,
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435\u043C 13 \u0434\u0435\u0442\u0435\u0439
    \u0438 \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C\u044E \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0432 \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u0438 \u043F\u043E\u043B\u043D\u043E\u0433\u043E
    \u0434\u043E\u043C\u0430 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0445
    \u0434\u0435\u0442\u0435\u0439.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466
    \u0411\u0440\u0430\u043A \u0441 \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u043E\u0439
    \u0413\u0437\u0435\u043B\u044C: \u0433\u043B\u0430\u0432\u043D\u0430\u044F \u043B\u044E\u0431\u043E\u0432\u044C 
    \u042D\u0439\u043B\u0435\u0440 \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430
    **\u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0435 \u0413\u0437\u0435\u043B\u044C**
    7 \u044F\u043D\u0432\u0430\u0440\u044F 1734 \u0433\u043E\u0434\u0430, \u0432\u0441\u043A\u043E\u0440\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0432\u044B\u0441\u0448\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A. \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u0448\u0432\u0435\u0439\u0446\u0430\u0440\u0441\u043A\u043E\u0433\u043E
    \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0430 \u0413\u0435\u043E\u0440\u0433\u0430
    \u0413\u0437\u0435\u043B\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0438, \u0438 \u0432\u043D\u0443\u0447\u043A\u043E\u0439
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u0446\u044B
    \u0438 \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u0438\u0441\u0442\u043A\u0438
    \u041C\u0430\u0440\u0438\u0438 \u0421\u0438\u0431\u0438\u043B\u043B\u044B \u041C\u0435\u0440\u0438\u0430\u043D.
    \u041F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0434\u0430\u043D\u043D\u044B\u043C,
    \u043E\u043D\u0430 \u0442\u043E\u0436\u0435 \u0431\u044B\u043B\u0430 \u0440\u043E\u0434\u043E\u043C
    \u0438\u0437 \u0441\u0435\u043C\u044C\u0438, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0439
    \u0441\u043E \u0428\u0432\u0435\u0439\u0446\u0430\u0440\u0438\u0435\u0439.  \u0418\u0445
    \u0431\u0440\u0430\u043A, \u043F\u0440\u043E\u0434\u043B\u0438\u0432\u0448\u0438\u0439\u0441\u044F
    \u043F\u043E\u0447\u0442\u0438 40 \u043B\u0435\u0442, \u0431\u044B\u043B \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C
    \u0438 \u043A\u0440\u0435\u043F\u043A\u0438\u043C. \u0417\u0430 \u044D\u0442\u043E
    \u0432\u0440\u0435\u043C\u044F \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0430
    \u0440\u043E\u0434\u0438\u043B\u0430 \u042D\u0439\u043B\u0435\u0440\u0443 **13
    \u0434\u0435\u0442\u0435\u0439**. \u042D\u0442\u0430 \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435
    \u043E\u0433\u0440\u043E\u043C\u043D\u0430\u044F \u0441\u0435\u043C\u044C\u044F
    \u0441\u0442\u0430\u043B\u0430 \u043D\u0435 \u043F\u043E\u043C\u0435\u0445\u043E\u0439,
    \u0430 \u0447\u0430\u0441\u0442\u044C\u044E \u0435\u0433\u043E \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0430.
    \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438 \u0438
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043E\u0442\u043C\u0435\u0447\u0430\u043B\u0438,
    \u0447\u0442\u043E \u042D\u0439\u043B\u0435\u0440 \u0447\u0430\u0441\u0442\u043E
    \u0434\u0435\u043B\u0430\u043B \u0441\u0432\u043E\u0438 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F, \u0434\u0435\u0440\u0436\u0430
    \u043D\u0430 \u0440\u0443\u043A\u0430\u0445 \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438\u0437 \u043C\u0430\u043B\u044B\u0448\u0435\u0439, \u0432 \u0442\u043E
    \u0432\u0440\u0435\u043C\u044F \u043A\u0430\u043A \u0434\u0440\u0443\u0433\u0438\u0435
    \u0434\u0435\u0442\u0438 \u0438\u0433\u0440\u0430\u043B\u0438 \u0443 \u0435\u0433\u043E
    \u043D\u043E\u0433. \u042D\u0442\u0430 \u0442\u0440\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0434\u0435\u0442\u0430\u043B\u044C \u0440\u0438\u0441\u0443\u0435\u0442 \u043E\u0431\u0440\u0430\u0437
    \u0443\u0447\u0451\u043D\u043E\u0433\u043E, \u0434\u043B\u044F \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0441\u0435\u043C\u044C\u044F \u0431\u044B\u043B\u0430 \u043D\u0435\u043E\u0442\u044A\u0435\u043C\u043B\u0435\u043C\u043E\u0439
    \u0447\u0430\u0441\u0442\u044C\u044E \u0436\u0438\u0437\u043D\u0438, \u0430 \u043D\u0435
    \u043F\u0440\u0435\u043F\u044F\u0442\u0441\u0442\u0432\u0438\u0435\u043C \u0434\u043B\u044F
    \u0440\u0430\u0431\u043E\u0442\u044B.  \u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u0438\u0437 13 \u0434\u0435\u0442\u0435\u0439 \u0432\u044B\u0436\u0438\u043B\u0438
    \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u044F\u0442\u0435\u0440\u043E: \u0442\u0440\u0438
    \u0441\u044B\u043D\u0430 \u0438 \u0434\u0432\u0435 \u0434\u043E\u0447\u0435\u0440\u0438.
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u043E\u0431\u044B\u0447\u043D\u043E\u0439
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439 \u0434\u043B\u044F XVIII
    \u0432\u0435\u043A\u0430, \u043A\u043E\u0433\u0434\u0430 \u0434\u0435\u0442\u0441\u043A\u0430\u044F
    \u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0441\u0442\u044C \u0431\u044B\u043B\u0430
    \u043E\u0447\u0435\u043D\u044C \u0432\u044B\u0441\u043E\u043A\u0430.  ### \U0001F3DB\uFE0F
    \u0414\u0435\u0442\u0438 \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0435\u043D\u0438\u0435
    \u0434\u0438\u043D\u0430\u0441\u0442\u0438\u0438  \u0414\u0435\u0442\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432\u044B\u0436\u0438\u043B\u0438, \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C
    \u043F\u043E\u0448\u043B\u0438 \u043F\u043E \u0441\u0442\u043E\u043F\u0430\u043C
    \u043E\u0442\u0446\u0430 \u0438 \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438
    \u0437\u0430\u043C\u0435\u0442\u043D\u044B\u0439 \u0441\u043B\u0435\u0434 \u0432
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438:  *   **\u0418\u043E\u0433\u0430\u043D\u043D
    \u0410\u043B\u044C\u0431\u0440\u0435\u0445\u0442 \u042D\u0439\u043B\u0435\u0440
    (1734\u20131800):** \u0421\u0442\u0430\u0440\u0448\u0438\u0439 \u0441\u044B\u043D,
    \u0440\u043E\u0434\u0438\u0432\u0448\u0438\u0439\u0441\u044F \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0435.
    \u0421\u0442\u0430\u043B \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u0438 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u2014 \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u0451\u043C \u0418\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0441\u043A\u043E\u0439
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A \u0432
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0435. \u041E\u043D \u0431\u044B\u043B
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C,
    \u043D\u043E \u0438 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0438\u043C \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u043E\u043C
    \u043E\u0442\u0446\u0430, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u0430.
    *   **\u041A\u0430\u0440\u043B \u041B\u0435\u043E\u043D\u0442\u044C\u0435\u0432\u0438\u0447
    \u042D\u0439\u043B\u0435\u0440 (1740\u20131790):** \u0412\u0442\u043E\u0440\u043E\u0439
    \u0441\u044B\u043D, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0448\u0451\u043B
    \u043F\u043E \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u043E\u0439
    \u0441\u0442\u0435\u0437\u0435. *   **\u0425\u0440\u0438\u0441\u0442\u043E\u0444\u043E\u0440
    \u041B\u0435\u043E\u043D\u0442\u044C\u0435\u0432\u0438\u0447 \u042D\u0439\u043B\u0435\u0440
    (1743\u20131808):** \u041C\u043B\u0430\u0434\u0448\u0438\u0439 \u0441\u044B\u043D,
    \u0438\u0437\u0431\u0440\u0430\u0432\u0448\u0438\u0439 \u0432\u043E\u0435\u043D\u043D\u0443\u044E
    \u043A\u0430\u0440\u044C\u0435\u0440\u0443 \u0438 \u0434\u043E\u0441\u043B\u0443\u0436\u0438\u0432\u0448\u0438\u0439\u0441\u044F
    \u0434\u043E \u0433\u0435\u043D\u0435\u0440\u0430\u043B-\u043B\u0435\u0439\u0442\u0435\u043D\u0430\u043D\u0442\u0430,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0432\u0448\u0438\u0439
    \u0421\u0435\u0441\u0442\u0440\u043E\u0440\u0435\u0446\u043A\u0438\u043C \u043E\u0440\u0443\u0436\u0435\u0439\u043D\u044B\u043C
    \u0437\u0430\u0432\u043E\u0434\u043E\u043C.  \u041F\u043E\u0442\u043E\u043C\u043A\u0438
    \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u0430 \u042D\u0439\u043B\u0435\u0440\u0430
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B\u0438 \u0435\u0433\u043E
    \u0440\u043E\u0434 \u0432 \u0420\u043E\u0441\u0441\u0438\u0438 \u0438 \u0441\u0442\u0430\u043B\u0438
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B \u043D\u0430 \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0438 \u0432\u043E\u0435\u043D\u043D\u043E\u0439 \u0441\u043B\u0443\u0436\u0431\u0435.
    \u0421\u0440\u0435\u0434\u0438 \u043D\u0438\u0445 \u0431\u044B\u043B\u0438 \u0433\u0435\u043D\u0435\u0440\u0430\u043B\u044B,
    \u0433\u0443\u0431\u0435\u0440\u043D\u0430\u0442\u043E\u0440\u044B \u0438 \u043E\u0444\u0438\u0446\u0435\u0440\u044B. 
    ### \U0001F494 \u0412\u0442\u043E\u0440\u043E\u0439 \u0431\u0440\u0430\u043A
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B 
    \u0412 1773 \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u0447\u0442\u0438
    40 \u043B\u0435\u0442 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438, \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0430
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C. \u042D\u0439\u043B\u0435\u0440
    \u0442\u044F\u0436\u0435\u043B\u043E \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u043B
    \u043F\u043E\u0442\u0435\u0440\u044E. \u0421\u043F\u0443\u0441\u0442\u044F \u0442\u0440\u0438
    \u0433\u043E\u0434\u0430, \u0432 1776 \u0433\u043E\u0434\u0443, \u043E\u043D
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u0435\u0451 \u0441\u0432\u043E\u0434\u043D\u043E\u0439
    \u0441\u0435\u0441\u0442\u0440\u0435 \u2014 **\u0421\u0430\u043B\u043E\u043C\u0435\u0435
    \u0410\u0431\u0438\u0433\u0435\u0439\u043B \u0413\u0437\u0435\u043B\u044C**.
    \u0412\u0442\u043E\u0440\u043E\u0439 \u0431\u0440\u0430\u043A, \u043F\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C,
    \u0442\u043E\u0436\u0435 \u0431\u044B\u043B \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C,
    \u0438 \u0421\u0430\u043B\u043E\u043C\u0435\u044F \u0437\u0430\u0431\u043E\u0442\u0438\u043B\u0430\u0441\u044C
    \u043E\u0431 \u0443\u0436\u0435 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043E\u0441\u043B\u0435\u043F\u0448\u0435\u043C \u0443\u0447\u0451\u043D\u043E\u043C
    \u0434\u043E \u0441\u0430\u043C\u043E\u0439 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    \u0432 1783 \u0433\u043E\u0434\u0443.  \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C,
    \u043B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u042D\u0439\u043B\u0435\u0440\u0430,
    \u043E\u043C\u0440\u0430\u0447\u0451\u043D\u043D\u0430\u044F \u043F\u043E\u0442\u0435\u0440\u0435\u0439
    \u043C\u043D\u043E\u0433\u0438\u0445 \u0434\u0435\u0442\u0435\u0439 \u0438 \u0434\u0432\u0443\u0445
    \u0442\u044F\u0436\u0451\u043B\u044B\u0445 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0439
    \u043D\u0430 \u0433\u043B\u0430\u0437\u0430\u0445, \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
    \u0435\u0433\u043E \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0441\u0442\u043E\u0439\u043A\u043E\u0441\u0442\u044C \u0438 \u0436\u0438\u0437\u043D\u0435\u043B\u044E\u0431\u0438\u0435.
    \u0421\u0435\u043C\u044C\u044F \u0431\u044B\u043B\u0430 \u0434\u043B\u044F \u043D\u0435\u0433\u043E
    \u043D\u0430\u0434\u0451\u0436\u043D\u043E\u0439 \u0433\u0430\u0432\u0430\u043D\u044C\u044E,
    \u0442\u043E\u0439 \u0441\u0430\u043C\u043E\u0439 \"\u0442\u0438\u0445\u043E\u0439
    \u043F\u0440\u0438\u0441\u0442\u0430\u043D\u044C\u044E\", \u043E\u0442\u043A\u0443\u0434\u0430
    \u043E\u043D \u0447\u0435\u0440\u043F\u0430\u043B \u0441\u0438\u043B\u044B \u0434\u043B\u044F
    \u0441\u0432\u043E\u0438\u0445 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0441\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0439."
  personalLifeEn: 
  shortBioRu: "\u041B\u0435\u043E\u043D\u0430\u0440\u0434 \u042D\u0439\u043B\u0435\u0440
    \u2014 \u044D\u0442\u043E, \u0431\u0435\u0437 \u043F\u0440\u0435\u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u0438\u044F,
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0443\u043C\u043E\u0432 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0430.
    \u041E\u043D \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u0430 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0447\u0451\u043D\u044B\u043C, \u0447\u044C\u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u043E\u0445\u0432\u0430\u0442\u0438\u043B\u0438 \u043F\u043E\u0447\u0442\u0438
    \u0432\u0441\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435 \u0442\u043E\u0433\u0434\u0430
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043D\u0430\u0443\u043A\u0438. \u0415\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043F\u0440\u0435\u0434\u0430\u043D\u043D\u043E\u0441\u0442\u0438 \u043D\u0430\u0443\u043A\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B\u0430\u0441\u044C
    \u0434\u0430\u0436\u0435 \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u043B\u043D\u043E\u0439
    \u043F\u043E\u0442\u0435\u0440\u0438 \u0437\u0440\u0435\u043D\u0438\u044F.  ###
    \U0001F4DC \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u044E\u043D\u043E\u0441\u0442\u044C:
    \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435 \u0433\u0435\u043D\u0438\u044F
    \u0432 \u0411\u0430\u0437\u0435\u043B\u0435  \u041B\u0435\u043E\u043D\u0430\u0440\u0434
    \u042D\u0439\u043B\u0435\u0440 \u0440\u043E\u0434\u0438\u043B\u0441\u044F 15
    \u0430\u043F\u0440\u0435\u043B\u044F 1707 \u0433\u043E\u0434\u0430 \u0432 \u0448\u0432\u0435\u0439\u0446\u0430\u0440\u0441\u043A\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u0435 \u0411\u0430\u0437\u0435\u043B\u0435, \u0432
    \u0441\u0435\u043C\u044C\u0435 \u043F\u0430\u0441\u0442\u043E\u0440\u0430 \u041F\u0430\u0443\u043B\u044F
    \u042D\u0439\u043B\u0435\u0440\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0430\u043C \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439 \u0438 \u043A\u043E\u0433\u0434\u0430-\u0442\u043E
    \u0443\u0447\u0438\u043B\u0441\u044F \u0443 \u042F\u043A\u043E\u0431\u0430 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438.
    \u041F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u043E\u0442\u0435\u0446 \u0433\u043E\u0442\u043E\u0432\u0438\u043B \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u0430
    \u043A \u0434\u0443\u0445\u043E\u0432\u043D\u043E\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u0435,
    \u043D\u043E \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u0438\u0432\u0438\u043B
    \u0435\u043C\u0443 \u043B\u044E\u0431\u043E\u0432\u044C \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u042D\u0442\u043E \u043E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C \u0441\u0443\u0434\u044C\u0431\u043E\u043D\u043E\u0441\u043D\u044B\u043C
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435\u043C.  \u0412 1720 \u0433\u043E\u0434\u0443,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 13 \u043B\u0435\u0442,
    \u042D\u0439\u043B\u0435\u0440 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0411\u0430\u0437\u0435\u043B\u044C\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442.
    \u0422\u0430\u043C \u043E\u043D \u0431\u044B\u0441\u0442\u0440\u043E \u043F\u0440\u0438\u0432\u043B\u0451\u043A
    \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435 \u043F\u0440\u043E\u0441\u043B\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u0418\u043E\u0433\u0430\u043D\u043D\u0430
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0438 \u0440\u0430\u0437\u0433\u043B\u044F\u0434\u0435\u043B \u0432 \u044E\u043D\u043E\u0448\u0435
    \u043D\u0435\u043E\u0431\u044B\u0447\u0430\u0439\u043D\u044B\u0439 \u0442\u0430\u043B\u0430\u043D\u0442.
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438 \u0434\u0430\u0432\u0430\u043B
    \u0435\u043C\u0443 \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u0442\u0430\u0442\u044C\u0438 \u0434\u043B\u044F \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F, \u0430 \u043F\u043E \u0441\u0443\u0431\u0431\u043E\u0442\u0430\u043C
    \u043B\u0438\u0447\u043D\u043E \u0440\u0430\u0437\u0431\u0438\u0440\u0430\u043B
    \u0441 \u043D\u0438\u043C \u0442\u0440\u0443\u0434\u043D\u044B\u0435 \u043C\u0435\u0441\u0442\u0430.
    \u042D\u0442\u043E\u0442 \u043E\u043F\u044B\u0442 \u042D\u0439\u043B\u0435\u0440
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u043B\u0443\u0447\u0448\u0438\u043C
    \u0441\u043F\u043E\u0441\u043E\u0431\u043E\u043C \u0434\u043E\u0431\u0438\u0442\u044C\u0441\u044F
    \u0443\u0441\u043F\u0435\u0445\u0430 \u0432 \u043D\u0430\u0443\u043A\u0435. 
    \u0412 1724 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    17 \u043B\u0435\u0442, \u042D\u0439\u043B\u0435\u0440 \u043F\u0440\u043E\u0438\u0437\u043D\u0451\u0441
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0443\u044E \u0440\u0435\u0447\u044C
    \u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u0414\u0435\u043A\u0430\u0440\u0442\u0430
    \u0438 \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432. \u041F\u043E\u0437\u0436\u0435
    \u043E\u043D \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0432 \u0411\u0430\u0437\u0435\u043B\u0435,
    \u043D\u043E \u0435\u0433\u043E \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0443\u0440\u0443
    \u043E\u0442\u043A\u043B\u043E\u043D\u0438\u043B\u0438 \u0438\u0437-\u0437\u0430
    \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u044E\u043D\u043E\u0433\u043E \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0430. 
    ### \U0001F1F7\U0001F1FA \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 (1727\u20131741): \u043F\u0435\u0440\u0432\u044B\u0435
    \u0442\u0440\u0438\u0443\u043C\u0444\u044B  \u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u043C
    \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C \u0432 \u0441\u0443\u0434\u044C\u0431\u0435
    \u042D\u0439\u043B\u0435\u0440\u0430 \u0441\u0442\u0430\u043B\u043E \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435
    \u0432 \u043D\u0435\u0434\u0430\u0432\u043D\u043E \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u0443\u044E
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A \u0432
    1726 \u0433\u043E\u0434\u0443. \u0420\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u044E
    \u0435\u043C\u0443 \u0434\u0430\u043B\u0438 \u0431\u0440\u0430\u0442\u044C\u044F
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0443\u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438 \u0442\u0430\u043C.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u0438\u0437\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u0435\u043C\u0443 \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u043B\u0438
    \u043C\u0435\u0441\u0442\u043E \u043F\u043E \u043A\u0430\u0444\u0435\u0434\u0440\u0435
    \u0444\u0438\u0437\u0438\u043E\u043B\u043E\u0433\u0438\u0438, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \u043E\u043D \u0432\u0441\u0435\u0440\u044C\u0451\u0437 \u0437\u0430\u043D\u044F\u043B\u0441\u044F
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435\u043C \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u044B.
    \u041E\u0434\u043D\u0430\u043A\u043E \u043F\u043E \u043F\u0440\u0438\u0431\u044B\u0442\u0438\u0438
    \u0432 \u0421\u0430\u043D\u043A\u0442-\u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433
    24 \u043C\u0430\u044F 1727 \u0433\u043E\u0434\u0430 \u043E\u043D \u0431\u044B\u043B
    \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D \u0430\u0434\u044A\u044E\u043D\u043A\u0442\u043E\u043C
    \u043F\u043E \u0432\u044B\u0441\u0448\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. 
    \u0412 \u0420\u043E\u0441\u0441\u0438\u0438 \u0442\u0430\u043B\u0430\u043D\u0442
    \u042D\u0439\u043B\u0435\u0440\u0430 \u0440\u0430\u0441\u043A\u0440\u044B\u043B\u0441\u044F
    \u0432 \u043F\u043E\u043B\u043D\u043E\u0439 \u043C\u0435\u0440\u0435. \u041E\u043D
    \u0431\u044B\u0441\u0442\u0440\u043E \u043E\u0441\u0432\u043E\u0438\u043B \u0440\u0443\u0441\u0441\u043A\u0438\u0439
    \u044F\u0437\u044B\u043A \u0438 \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u043B\u0441\u044F
    \u0432 \u0440\u0430\u0431\u043E\u0442\u0443. \u0415\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043F\u043E\u0448\u043B\u0430
    \u0432 \u0433\u043E\u0440\u0443: * \u0412 **1731 \u0433\u043E\u0434\u0443** \u043E\u043D
    \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0444\u0438\u0437\u0438\u043A\u0438, \u0430 \u0432 **1733 \u0433\u043E\u0434\u0443**
    \u2014 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u043C \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0432\u044B\u0441\u0448\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0441\u043C\u0435\u043D\u0438\u0432 \u0443\u0435\u0445\u0430\u0432\u0448\u0435\u0433\u043E
    \u043D\u0430 \u0440\u043E\u0434\u0438\u043D\u0443 \u0414\u0430\u043D\u0438\u0438\u043B\u0430
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438.  \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0441\u0442\u0430\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C. \u042D\u0439\u043B\u0435\u0440
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u0432 \u043A\u0430\u0440\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438
    \u0420\u043E\u0441\u0441\u0438\u0438, \u043F\u0438\u0441\u0430\u043B \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0438,
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0435\u0439.
    \u041E\u0434\u043D\u0438\u043C \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u044F\u0440\u043A\u0438\u0445
    \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432 \u0441\u0442\u0430\u043B\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u043E \u0440\u0430\u0441\u0447\u0451\u0442\u0443
    \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438 \u043A\u043E\u043C\u0435\u0442\u044B
    \u0432 1735 \u0433\u043E\u0434\u0443. \u0413\u0440\u0443\u043F\u043F\u0430 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u0432
    \u043F\u0440\u043E\u0441\u0438\u043B\u0430 \u043D\u0430 \u044D\u0442\u043E \u0442\u0440\u0438
    \u043C\u0435\u0441\u044F\u0446\u0430, \u0430 \u042D\u0439\u043B\u0435\u0440 \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u043B
    \u0432\u0441\u0435 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0432\u0441\u0435\u0433\u043E \u0437\u0430 \u0442\u0440\u0438 \u0434\u043D\u044F!
    \u041E\u0434\u043D\u0430\u043A\u043E \u0442\u0430\u043A\u043E\u0435 \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0435
    \u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u0438\u0435 \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u043A \u0431\u043E\u043B\u0435\u0437\u043D\u0438, \u0432 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u043F\u0440\u0430\u0432\u044B\u0439 \u0433\u043B\u0430\u0437.  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u044D\u0442\u043E, \u0432 1736 \u0433\u043E\u0434\u0443 \u0432\u044B\u0448\u043B\u043E
    \u0435\u0433\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0434\u0432\u0443\u0445\u0442\u043E\u043C\u043D\u043E\u0435 \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0435
    **\xAB\u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430, \u0438\u043B\u0438 \u041D\u0430\u0443\u043A\u0430
    \u043E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438, \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u043D\u0430\u044F
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\xBB**,
    \u0433\u0434\u0435 \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0442\u0435\u043B, \u0447\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u043D\u0430\u0447\u0430\u043B\u043E\u043C \u043D\u043E\u0432\u043E\u0439
    \u044D\u0440\u044B \u0432 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435. 
    ### \U0001F1E9\U0001F1EA \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 (1741\u20131766): \u0440\u0430\u0441\u0446\u0432\u0435\u0442
    \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435  \u0412 1741 \u0433\u043E\u0434\u0443,
    \u043D\u0430 \u0444\u043E\u043D\u0435 \u043D\u0435\u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u043E\u0439
    \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438
    \u0432 \u0420\u043E\u0441\u0441\u0438\u0438 \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0410\u043D\u043D\u044B \u0418\u043E\u0430\u043D\u043D\u043E\u0432\u043D\u044B,
    \u042D\u0439\u043B\u0435\u0440 \u043F\u0440\u0438\u043D\u044F\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435
    \u043F\u0440\u0443\u0441\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u044F
    \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430 II \u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u0411\u0435\u0440\u043B\u0438\u043D. \u0422\u0430\u043C \u043E\u043D
    \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043A\u043B\u0430\u0441\u0441 \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A.  \u0417\u0430
    25 \u043B\u0435\u0442 \u0436\u0438\u0437\u043D\u0438 \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0435
    \u042D\u0439\u043B\u0435\u0440 \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043E\u043A\u043E\u043B\u043E
    300 \u0440\u0430\u0431\u043E\u0442. \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0441\u0442\u0430\u043B \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C \u0435\u0433\u043E
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439: * **1748 \u0433\u043E\u0434**
    \u2014 \u0432\u044B\u0445\u043E\u0434 \u0432 \u0441\u0432\u0435\u0442 **\xAB\u0412\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u0432 \u0430\u043D\u0430\u043B\u0438\u0437 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E
    \u043C\u0430\u043B\u044B\u0445\xBB**, \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043D\u0430
    \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F \u0432\u043F\u0435\u0440\u0451\u0434
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u0432\u0441\u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430. * **1755 \u0433\u043E\u0434** \u2014
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043E **\xAB\u0414\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435\xBB**.  \u041F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u043E
    \u043E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F, \u0440\u0435\u0448\u0438\u043B
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0437\u0430\u0434\u0430\u0447
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B, \u0433\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435
    \u0438 \u043E\u043F\u0442\u0438\u043A\u0435. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    **\xAB\u041F\u0438\u0441\u044C\u043C\u0430 \u043A \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0439
    \u043F\u0440\u0438\u043D\u0446\u0435\u0441\u0441\u0435 \u043E \u0440\u0430\u0437\u043D\u044B\u0445
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445
    \u043C\u0430\u0442\u0435\u0440\u0438\u044F\u0445\xBB**, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0442\u0430\u043B\u0438 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u044B\u043C \u043D\u0430\u0443\u0447\u043D\u043E-\u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u044B\u043C
    \u0442\u0440\u0443\u0434\u043E\u043C \u0438 \u0432\u044B\u0434\u0435\u0440\u0436\u0430\u043B\u0438
    \u043E\u043A\u043E\u043B\u043E 40 \u0438\u0437\u0434\u0430\u043D\u0438\u0439
    \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438 \u044F\u0437\u044B\u043A\u0430\u0445. 
    \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u043E\u043C
    II, \u043E\u0434\u043D\u0430\u043A\u043E, \u0431\u044B\u043B\u0438 \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u044B\u043C\u0438:
    \u043A\u043E\u0440\u043E\u043B\u044C \u043D\u0435 \u043E\u0446\u0435\u043D\u0438\u043B
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u0438
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u042D\u0439\u043B\u0435\u0440\u0430, \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u044F
    \u0435\u043C\u0443 \u0431\u043E\u043B\u0435\u0435 \u0441\u0432\u0435\u0442\u0441\u043A\u0438\u0445
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u0432. \u0418\u043C\u0435\u043D\u043D\u043E
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u0432 1766 \u0433\u043E\u0434\u0443,
    \u043F\u043E\u043B\u0443\u0447\u0438\u0432 \u043D\u043E\u0432\u043E\u0435 \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435
    \u043E\u0442 \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u0440\u0438\u0446\u044B
    \u0415\u043A\u0430\u0442\u0435\u0440\u0438\u043D\u044B II, \u042D\u0439\u043B\u0435\u0440
    \u0431\u0435\u0437 \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u0439 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u0420\u043E\u0441\u0441\u0438\u044E.  ### \U0001F1F7\U0001F1FA \u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433 \u0438 \u0442\u0440\u0438\u0443\u043C\u0444
    \u043D\u0430\u0434 \u0441\u043B\u0435\u043F\u043E\u0442\u043E\u0439 (1766\u20131783) 
    \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433,
    \u042D\u0439\u043B\u0435\u0440 \u0432\u0441\u043A\u043E\u0440\u0435 \u043F\u043E\u0447\u0442\u0438
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043E\u0441\u043B\u0435\u043F
    \u043D\u0430 \u0432\u0442\u043E\u0440\u043E\u0439 \u0433\u043B\u0430\u0437. \u041D\u043E
    \u044D\u0442\u043E \u043D\u0435 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u043E
    \u0435\u0433\u043E, \u0430, \u043D\u0430\u043F\u0440\u043E\u0442\u0438\u0432,
    \u043A\u0430\u0436\u0435\u0442\u0441\u044F, \u0434\u0430\u0436\u0435 \u043F\u043E\u0434\u0441\u0442\u0435\u0433\u043D\u0443\u043B\u043E
    \u0435\u0433\u043E \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u043E\u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C.
    \u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044F \u0441\u0432\u043E\u0438
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F, \u043E\u043D
    \u0434\u0438\u043A\u0442\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u0430\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438 \u0438 \u043E\u0444\u043E\u0440\u043C\u043B\u044F\u043B\u0438
    \u0438\u0445. \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u043E\u0442
    \u043F\u0435\u0440\u0438\u043E\u0434, \u0443\u0436\u0435 \u043D\u0435 \u0432\u0438\u0434\u044F
    \u043D\u0438 \u0441\u0442\u0440\u043E\u0447\u043A\u0438, \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432\u043E\u0448\u043B\u0438 \u0432
    \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u043D\u0430\u0443\u043A\u0438:  |
    \u0413\u043E\u0434 | \u0422\u0440\u0443\u0434 | \u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    | | :--- | :--- | :--- | | **1768\u20131770** | **\xAB\u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0435
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435\xBB** | \u0417\u0430\u0432\u0435\u0440\u0448\u0438\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0442\u0440\u0438\u043B\u043E\u0433\u0438\u044E
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0430\u043D\u0430\u043B\u0438\u0437\u0443 (\u0432\u043C\u0435\u0441\u0442\u0435
    \u0441\u043E \xAB\u0412\u0432\u0435\u0434\u0435\u043D\u0438\u0435\u043C\xBB \u0438
    \xAB\u0414\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435\u043C\xBB). | |
    **1768\u20131769** | **\xAB\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u0430\u044F
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430\xBB** | \u041A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A \u0430\u043B\u0433\u0435\u0431\u0440\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u044B\u0434\u0435\u0440\u0436\u0430\u043B
    \u043E\u043A\u043E\u043B\u043E 30 \u0438\u0437\u0434\u0430\u043D\u0438\u0439
    \u043D\u0430 6 \u044F\u0437\u044B\u043A\u0430\u0445. | | **1768\u20131774** |
    **\xAB\u041F\u0438\u0441\u044C\u043C\u0430 \u043A \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0439
    \u043F\u0440\u0438\u043D\u0446\u0435\u0441\u0441\u0435...\xBB** | \u041F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0435
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0444\u0438\u0437\u0438\u043A\u0438,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438 \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438,
    \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0451\u043D\u043D\u043E\u0435 \u043D\u0430
    \u043C\u043D\u043E\u0433\u0438\u0435 \u044F\u0437\u044B\u043A\u0438. |  \u0417\u0430
    \u0441\u0432\u043E\u044E \u0436\u0438\u0437\u043D\u044C \u042D\u0439\u043B\u0435\u0440
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0431\u043E\u043B\u0435\u0435 **850
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0440\u0430\u0431\u043E\u0442**,
    \u0430 \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435,
    \u0441\u043E\u0431\u0438\u0440\u0430\u0435\u043C\u043E\u0435 \u0432 \u043F\u043E\u043B\u043D\u043E\u0435
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435 \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439
    (Opera Omnia), \u043D\u0430\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u0435\u0442
    \u0434\u0435\u0441\u044F\u0442\u043A\u0438 \u0442\u043E\u043C\u043E\u0432 \u0438
    \u0438\u0437\u0434\u0430\u0451\u0442\u0441\u044F \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440.  ### \U0001F4DD \u041D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0438 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 
    \u0412\u043A\u043B\u0430\u0434 \u042D\u0439\u043B\u0435\u0440\u0430 \u0432 \u043D\u0430\u0443\u043A\u0443
    \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435 \u043D\u0435\u043E\u0431\u044A\u044F\u0442\u0435\u043D.
    \u041E\u043D: * **\u041F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u0438\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437**, \u043F\u0440\u0438\u0434\u0430\u0432
    \u0435\u043C\u0443 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439
    \u0432\u0438\u0434 \u0438 \u0441\u043E\u0437\u0434\u0430\u0432 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0435 \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435
    \u0438 \u0442\u0435\u043E\u0440\u0438\u044E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. * **\u0417\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438
    \u0442\u0432\u0451\u0440\u0434\u043E\u0433\u043E \u0442\u0435\u043B\u0430 \u0438
    \u0433\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438**,
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u0432
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F.
    * **\u0412\u043D\u0451\u0441 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u0447\u0438\u0441\u0435\u043B,
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E, \u043E\u043F\u0442\u0438\u043A\u0443,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044E** (\u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B
    \u043C\u0430\u0441\u0441\u0443 \u041B\u0443\u043D\u044B) \u0438 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0434\u0440\u0443\u0433\u0438\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438.
    * **\u0412\u0432\u0451\u043B \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439
    \u0438 \u0442\u0435\u0440\u043C\u0438\u043D\u043E\u0432**, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u044B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440: \u0441\u0438\u043C\u0432\u043E\u043B\u044B
    \u0447\u0438\u0441\u043B\u0430 \u03C0 (\u043F\u0438), \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432
    e, \u043C\u043D\u0438\u043C\u043E\u0439 \u0435\u0434\u0438\u043D\u0438\u0446\u044B
    i \u0438 \u043C\u043D\u043E\u0433\u0438\u0435 \u0434\u0440\u0443\u0433\u0438\u0435. 
    \u042D\u0439\u043B\u0435\u0440 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    18 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F 1783 \u0433\u043E\u0434\u0430
    \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0435 \u043E\u0442
    \u0430\u043F\u043E\u043F\u043B\u0435\u043A\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0443\u0434\u0430\u0440\u0430. \u041E\u043D \u0431\u044B\u043B \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u043D\u0430 \u0421\u043C\u043E\u043B\u0435\u043D\u0441\u043A\u043E\u043C \u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0441\u043A\u043E\u043C
    \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435, \u0430 \u0432 1956 \u0433\u043E\u0434\u0443
    \u0435\u0433\u043E \u043F\u0440\u0430\u0445 \u0431\u044B\u043B \u043F\u0435\u0440\u0435\u043D\u0435\u0441\u0451\u043D
    \u0432 \u041D\u0435\u043A\u0440\u043E\u043F\u043E\u043B\u044C XVIII \u0432\u0435\u043A\u0430
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E-\u041D\u0435\u0432\u0441\u043A\u043E\u0439
    \u043B\u0430\u0432\u0440\u044B.  \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C
    \u2014 \u044D\u0442\u043E \u043F\u0440\u0438\u043C\u0435\u0440 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439
    \u0441\u0430\u043C\u043E\u043E\u0442\u0434\u0430\u0447\u0438, \u043B\u044E\u0431\u0432\u0438
    \u043A \u0437\u043D\u0430\u043D\u0438\u044F\u043C \u0438 \u0441\u0438\u043B\u044B
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0434\u0443\u0445\u0430, \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0433\u043E
    \u0442\u0432\u043E\u0440\u0438\u0442\u044C \u0432\u0435\u043B\u0438\u043A\u043E\u0435
    \u0434\u0430\u0436\u0435 \u043F\u0435\u0440\u0435\u0434 \u043B\u0438\u0446\u043E\u043C
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043D\u0435\u043C\u043E\u0449\u0438.
    \u0416\u0430\u043D-\u0411\u0430\u0442\u0438\u0441\u0442 \u0416\u043E\u0437\u0435\u0444
    \u0424\u0443\u0440\u044C\u0435, \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0441\u043A\u0430\u0437\u0430\u043B \u043E \u043D\u0451\u043C: \xAB**\u0427\u0438\u0442\u0430\u0439\u0442\u0435
    \u042D\u0439\u043B\u0435\u0440\u0430, \u0447\u0438\u0442\u0430\u0439\u0442\u0435
    \u042D\u0439\u043B\u0435\u0440\u0430, \u043E\u043D \u2014 \u043D\u0430\u0448
    \u043E\u0431\u0449\u0438\u0439 \u0443\u0447\u0438\u0442\u0435\u043B\u044C**\xBB.
    \u0418 \u044D\u0442\u0438 \u0441\u043B\u043E\u0432\u0430 \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F
    \u0430\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u043C\u0438 \u0438 \u0441\u0435\u0433\u043E\u0434\u043D\u044F."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u0430
    \u042D\u0439\u043B\u0435\u0440\u0430 \u2014 \u044D\u0442\u043E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0447\u0435\u0440\u0435\u0434\u0430 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0444\u043E\u0440\u043C\u0443\u043B, \u043D\u043E \u0438 \u043A\u0430\u043B\u0435\u0439\u0434\u043E\u0441\u043A\u043E\u043F
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445,
    \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445 \u0438 \u0434\u0430\u0436\u0435
    \u043D\u0435\u043C\u043D\u043E\u0433\u043E \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439. \u0415\u0433\u043E \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u0430\u044F
    \u043F\u0430\u043C\u044F\u0442\u044C, \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u043E\u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0435 \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0435
    \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0441\u0434\u0435\u043B\u0430\u043B\u0438 \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u043E\u0439.  \u0412\u043E\u0442
    \u0441\u0430\u043C\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438,
    \u0440\u0430\u0437\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0435 \u043F\u043E
    \u0442\u0435\u043C\u0430\u043C:  ### \U0001F9E0 \u0424\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438: \u043F\u0430\u043C\u044F\u0442\u044C,
    \u0441\u0447\u0435\u0442 \u0438 \u0441\u043B\u0443\u0445  \u042D\u0439\u043B\u0435\u0440
    \u043E\u0431\u043B\u0430\u0434\u0430\u043B \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u043C\u0438 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044F\u043C\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u0440\u0430\u0436\u0430\u043B\u0438
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432: 
    *   **\u0425\u043E\u0434\u044F\u0447\u0430\u044F \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u044F.**
    \u041E\u043D \u043F\u043E\u043C\u043D\u0438\u043B \u043D\u0430\u0438\u0437\u0443\u0441\u0442\u044C
    \"\u042D\u043D\u0435\u0438\u0434\u0443\" \u0412\u0435\u0440\u0433\u0438\u043B\u0438\u044F
    \u2014 \u043E\u0433\u0440\u043E\u043C\u043D\u0443\u044E \u043F\u043E\u044D\u043C\u0443.
    \u0422\u0430\u043A\u0436\u0435 \u0432 \u0435\u0433\u043E \u043F\u0430\u043C\u044F\u0442\u0438
    \u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0441\u044C \u0432\u0441\u0435 \u0442\u0435\u043A\u0441\u0442\u044B
    \"\u0418\u043B\u0438\u0430\u0434\u044B\" \u0438 \"\u041E\u0434\u0438\u0441\u0441\u0435\u0438\"
    \u0413\u043E\u043C\u0435\u0440\u0430. \u0411\u043E\u043B\u0435\u0435 \u0442\u043E\u0433\u043E,
    \u043E\u043D \u043C\u043E\u0433 \u0432\u043E\u0441\u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0441\u0442\u0438
    \u043B\u044E\u0431\u043E\u0439 \u0430\u0431\u0437\u0430\u0446 \u0438\u0437 \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043D\u043D\u043E\u0439
    \u043A\u043D\u0438\u0433\u0438, \u0434\u0430\u0436\u0435 \u0435\u0441\u043B\u0438
    \u044D\u0442\u0430 \u043A\u043D\u0438\u0433\u0430 \u0431\u044B\u043B\u0430 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u0440\u043E\u043B\u0438\u0441\u0442\u0430\u043D\u0430. *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A-\u043A\u0430\u043B\u044C\u043A\u0443\u043B\u044F\u0442\u043E\u0440.**
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B, \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0441\u043F\u043E\u0440\u0430 \u0441 \u0414\u0435\u043D\u0438 \u0414\u0438\u0434\u0440\u043E,
    \u042D\u0439\u043B\u0435\u0440 \u043F\u043E\u0440\u0430\u0437\u0438\u043B \u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u044B\u0445,
    \u044F\u043A\u043E\u0431\u044B \u0434\u043E\u043A\u0430\u0437\u0430\u0432 \u0431\u044B\u0442\u0438\u0435
    \u0411\u043E\u0433\u0430 \u0444\u043E\u0440\u043C\u0443\u043B\u043E\u0439: *\xAB(a
    + b\u207F)/n = x\xBB*. \u041D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435
    \u044D\u0442\u043E \u0431\u044B\u043B\u0430 \u0448\u0443\u0442\u043A\u0430, \u043D\u043E
    \u043E\u043D\u0430 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442,
    \u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0432\u0435\u043B\u0438\u043A\u0430
    \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044F.
    \u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438 \u043E\u043D
    \u043F\u043E\u0440\u0430\u0436\u0430\u043B \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F\u043C\u0438
    \u0432 \u0443\u043C\u0435. *   **\u0421\u043B\u043E\u043D \u0438 \u043C\u0443\u0445\u0430.**
    \u041F\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435, \u043A \u042D\u0439\u043B\u0435\u0440\u0443
    \u043E\u0431\u0440\u0430\u0442\u0438\u043B\u0438\u0441\u044C \u0441 \u0437\u0430\u0434\u0430\u0447\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430
    \u0432 \u0442\u0443\u043F\u0438\u043A \u043C\u043D\u043E\u0433\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432:
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C, \u0447\u0442\u043E \u0441\u043B\u043E\u043D
    \u0442\u044F\u0436\u0435\u043B\u0435\u0435 \u043C\u0443\u0445\u0438. \u042D\u0439\u043B\u0435\u0440
    \u0440\u0435\u0448\u0438\u043B \u0435\u0451, \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0432
    \u0441\u043B\u043E\u0436\u043D\u0443\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u043D\u0435\u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432 \u0438 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439, \u0434\u043E\u043A\u0430\u0437\u0430\u0432,
    \u0447\u0442\u043E \u0434\u0430\u0436\u0435 \u0432 \u0441\u043B\u043E\u0436\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435 \u043C\u0430\u0441\u0441\u0430 \u0441\u043B\u043E\u043D\u0430
    \u0431\u043E\u043B\u044C\u0448\u0435 \u043C\u0430\u0441\u0441\u044B \u043C\u0443\u0445\u0438.
    \u042D\u0442\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u2014 \u044F\u0440\u043A\u0438\u0439
    \u043F\u0440\u0438\u043C\u0435\u0440 \u0435\u0433\u043E \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0432\u0441\u0451, \u0447\u0442\u043E \u0443\u0433\u043E\u0434\u043D\u043E. 
    ### \U0001F56F\uFE0F \u0422\u0440\u0438\u0443\u043C\u0444 \u043D\u0430\u0434
    \u0441\u043B\u0435\u043F\u043E\u0442\u043E\u0439: \"\u0413\u043B\u0430\u0437\u0430
    \u0443\u043C\u0430\"  \u042D\u0442\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u044B\u0439 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0438 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u044E\u0449\u0438\u0439
    \u0444\u0430\u043A\u0442 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438: 
    *   **\u041F\u043E\u0442\u0435\u0440\u044F \u0437\u0440\u0435\u043D\u0438\u044F.**
    \u0412 1735 \u0433\u043E\u0434\u0443, \u0440\u0430\u0431\u043E\u0442\u0430\u044F
    \u043D\u0430\u0434 \u0437\u0430\u0434\u0430\u0447\u0435\u0439 \u043F\u043E \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    (\u0440\u0430\u0441\u0447\u0451\u0442 \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438
    \u043A\u043E\u043C\u0435\u0442\u044B), \u042D\u0439\u043B\u0435\u0440 \u043F\u0440\u043E\u0432\u0451\u043B
    \u0442\u0440\u0438 \u0434\u043D\u044F \u0431\u0435\u0437 \u0441\u043D\u0430.
    \u041A\u043E\u043B\u043B\u0435\u0433\u0438 \u043F\u0440\u043E\u0441\u0438\u043B\u0438
    \u043D\u0430 \u044D\u0442\u043E \u0442\u0440\u0438 \u043C\u0435\u0441\u044F\u0446\u0430,
    \u0430 \u043E\u043D \u0432\u0441\u0451 \u0441\u0434\u0435\u043B\u0430\u043B \u0437\u0430
    \u0442\u0440\u0438 \u0434\u043D\u044F. \u041E\u0434\u043D\u0430\u043A\u043E \u0441\u0432\u0435\u0440\u0445\u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u0438\u0435
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0442\u043E\u043C\u0443, \u0447\u0442\u043E
    \u043E\u043D \u043F\u043E\u0442\u0435\u0440\u044F\u043B \u043F\u0440\u0430\u0432\u044B\u0439
    \u0433\u043B\u0430\u0437. *   **\u0412\u0442\u043E\u0440\u0430\u044F \u0441\u043B\u0435\u043F\u043E\u0442\u0430.**
    \u041F\u043E \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
    \u0432 \u0420\u043E\u0441\u0441\u0438\u044E \u0432 1766 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u0447\u0442\u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043E\u0441\u043B\u0435\u043F \u043D\u0430 \u0432\u0442\u043E\u0440\u043E\u0439
    \u0433\u043B\u0430\u0437. \u041A\u0430\u0437\u0430\u043B\u043E\u0441\u044C, \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u0443\u0447\u0451\u043D\u043E\u0433\u043E \u043E\u043A\u043E\u043D\u0447\u0435\u043D\u0430.
    \u041D\u043E \u042D\u0439\u043B\u0435\u0440 \u043D\u0435 \u0441\u0434\u0430\u043B\u0441\u044F.
    *   **\u0414\u043D\u0435\u0432\u043D\u0438\u043A \u0432 \u0442\u0435\u043C\u043D\u043E\u0442\u0435.**
    \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0437\u0430\u043F\u0438\u0441\u0438:
    \u043F\u0438\u0441\u0430\u043B \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B \u043C\u0435\u043B\u043E\u043C \u043D\u0430
    \u0433\u0440\u0438\u0444\u0435\u043B\u044C\u043D\u043E\u0439 \u0434\u043E\u0441\u043A\u0435
    \u0438\u043B\u0438 \u043A\u0440\u0443\u043F\u043D\u043E \u0432\u044B\u0432\u043E\u0434\u0438\u043B
    \u0438\u0445 \u043D\u0430 \u0431\u0443\u043C\u0430\u0433\u0435. \u0427\u0442\u043E\u0431\u044B
    \u043D\u0435 \u0437\u0430\u0431\u044B\u0442\u044C \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0441\u0432\u043E\u0438\u0445 \u043C\u044B\u0441\u043B\u0435\u0439, \u043E\u043D
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u043A\u0430\u0440\u0430\u043D\u0434\u0430\u0448, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B \u0441\u043B\u0435\u0434, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043D \u043C\u043E\u0433 \u043E\u0449\u0443\u043F\u0430\u0442\u044C \u043F\u0430\u043B\u044C\u0446\u0430\u043C\u0438.
    *   **\"\u0427\u0438\u0442\u0430\u0439\u0442\u0435 \u042D\u0439\u043B\u0435\u0440\u0430\".**
    \u0423\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E, \u043D\u043E
    \u0438\u043C\u0435\u043D\u043D\u043E \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    17 \u043B\u0435\u0442 \u043F\u043E\u043B\u043D\u043E\u0439 \u0441\u043B\u0435\u043F\u043E\u0442\u044B
    \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0431\u043E\u043B\u0435\u0435
    \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u044B \u0441\u0432\u043E\u0438\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432 (\u043E\u043A\u043E\u043B\u043E 380 \u0441\u0442\u0430\u0442\u0435\u0439
    \u0438 \u043A\u043D\u0438\u0433)! \u041E\u043D \u0434\u0438\u043A\u0442\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0437\u044F\u0442\u044E,
    \u0441\u044B\u043D\u043E\u0432\u044C\u044F\u043C \u0438\u043B\u0438 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0449\u0438\u043C. \u0415\u0433\u043E
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u0431\u044B\u043B\u0438
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u044F\u0441\u043D\u044B\u043C\u0438
    \u0438 \u043B\u043E\u0433\u0438\u0447\u043D\u044B\u043C\u0438, \u0447\u0442\u043E
    \u043D\u0435 \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u0438 \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438
    \u0447\u0435\u0440\u043D\u043E\u0432\u0438\u043A\u043E\u0432.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466
    \u0421\u0435\u043C\u0435\u0439\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0438 \u0434\u0435\u0442\u0438: \"\u0413\u0435\u043D\u0438\u0439 \u043D\u0430
    \u043A\u043E\u043B\u0435\u043D\u044F\u0445\"  \u042D\u0439\u043B\u0435\u0440
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0443\u0447\u0451\u043D\u044B\u043C,
    \u043D\u043E \u0438 \u043B\u044E\u0431\u044F\u0449\u0438\u043C \u0441\u0435\u043C\u044C\u044F\u043D\u0438\u043D\u043E\u043C,
    \u0447\u0442\u043E \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u0435\u0442 \u0435\u0433\u043E
    \u043E\u0431\u0440\u0430\u0437\u0443 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u043D\u043E\u0441\u0442\u0438: 
    *   **\u0414\u0435\u0442\u0438 \u2014 \u044D\u0442\u043E \u043C\u0443\u0437\u044B\u043A\u0430.**
    \u042D\u0439\u043B\u0435\u0440 \u043E\u0447\u0435\u043D\u044C \u043B\u044E\u0431\u0438\u043B
    \u043C\u0443\u0437\u044B\u043A\u0443. \u041E\u043D \u0438\u0433\u0440\u0430\u043B
    \u043D\u0430 \u043A\u043B\u0430\u0432\u0435\u0441\u0438\u043D\u0435, \u0438 \u0447\u0430\u0441\u0442\u043E,
    \u0447\u0442\u043E\u0431\u044B \u0443\u0441\u043F\u043E\u043A\u043E\u0438\u0442\u044C
    \u043F\u043B\u0430\u0447\u0443\u0449\u0435\u0433\u043E \u0440\u0435\u0431\u0435\u043D\u043A\u0430,
    \u043E\u043D \u0441\u0430\u0436\u0430\u043B \u0435\u0433\u043E \u043A \u0441\u0435\u0431\u0435
    \u043D\u0430 \u043A\u043E\u043B\u0435\u043D\u0438 \u0438 \u043D\u0430\u0447\u0438\u043D\u0430\u043B
    \u0438\u0433\u0440\u0430\u0442\u044C, \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044F
    \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u044F\u0442\u044C \u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u0413\u043E\u0432\u043E\u0440\u044F\u0442, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0431\u044B\u043B\u0438 \u0441\u0434\u0435\u043B\u0430\u043D\u044B \u0438\u043C\u0435\u043D\u043D\u043E
    \u0442\u043E\u0433\u0434\u0430, \u043A\u043E\u0433\u0434\u0430 \u043D\u0430 \u0435\u0433\u043E
    \u043A\u043E\u043B\u0435\u043D\u044F\u0445 \u0441\u0438\u0434\u0435\u043B \u043E\u0434\u0438\u043D
    \u0438\u0437 13 \u0434\u0435\u0442\u0435\u0439, \u0430 \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438\u0433\u0440\u0430\u043B\u0438 \u043D\u0430 \u043F\u043E\u043B\u0443 \u0440\u044F\u0434\u043E\u043C.
    *   **13 \u0434\u0435\u0442\u0435\u0439.** \u0423 \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u043E
    13 \u0434\u0435\u0442\u0435\u0439 \u043E\u0442 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0436\u0435\u043D\u044B (\u041A\u0430\u0442\u0430\u0440\u0438\u043D\u044B \u0413\u0437\u0435\u043B\u044C).
    \u0418\u0437 \u043D\u0438\u0445 \u0432\u044B\u0436\u0438\u043B\u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u044F\u0442\u0435\u0440\u043E. \u042D\u0442\u043E \u0431\u044B\u043B\u0430
    \u0441\u0443\u0440\u043E\u0432\u0430\u044F \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    XVIII \u0432\u0435\u043A\u0430, \u0438 \u043F\u043E\u0442\u0435\u0440\u044F \u0434\u0435\u0442\u0435\u0439
    \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u043B \u043C\u0443\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E.
    *   **\u0422\u0451\u0449\u0430 \u0438 \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u0446\u0430.**
    \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0436\u0435\u043D\u044B \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0435\u0451 \u0441\u0432\u043E\u0434\u043D\u043E\u0439 \u0441\u0435\u0441\u0442\u0440\u0435.
    \u0415\u0433\u043E \u0442\u0435\u0449\u0430, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u0446\u0430 \u041C\u0430\u0440\u0438\u044F
    \u0421\u0438\u0431\u0438\u043B\u043B\u0430 \u041C\u0435\u0440\u0438\u0430\u043D,
    \u0431\u044B\u043B\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430 \u0441\u0432\u043E\u0438\u043C\u0438
    \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0430\u0446\u0438\u044F\u043C\u0438
    \u043D\u0430\u0441\u0435\u043A\u043E\u043C\u044B\u0445, \u043D\u043E \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043E\u043D\u0430 \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C \u043A\u0430\u043A
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u0441\u0432\u044F\u0437\u0443\u044E\u0449\u0438\u043C
    \u0437\u0432\u0435\u043D\u043E\u043C \u0434\u043B\u044F \u0441\u0435\u043C\u044C\u0438
    \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430. 
    ### \U0001F5FA\uFE0F \u041A\u0430\u0440\u0442\u043E\u0433\u0440\u0430\u0444 \u0438
    \u0448\u043F\u0438\u043E\u043D  \u042D\u0439\u043B\u0435\u0440 \u0431\u044B\u043B
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A\u043E\u043C,
    \u043D\u043E \u0438 \u043E\u0447\u0435\u043D\u044C \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C:  *   **\u041F\u0435\u0440\u0432\u0430\u044F
    \u043A\u0430\u0440\u0442\u0430 \u0420\u043E\u0441\u0441\u0438\u0438.** \u0412
    1745 \u0433\u043E\u0434\u0443 \u043F\u043E\u0434 \u0435\u0433\u043E \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0431\u044B\u043B \u0438\u0437\u0434\u0430\u043D \u043F\u0435\u0440\u0432\u044B\u0439
    \u043F\u043E\u043B\u043D\u044B\u0439 **\"\u0413\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u0442\u043B\u0430\u0441 \u0420\u043E\u0441\u0441\u0438\u0438\"**. \u042D\u0442\u043E
    \u0431\u044B\u043B\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u0430
    \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0438 \u0434\u0430\u043D\u043D\u044B\u0445
    \u0441 \u0441\u043E\u0442\u0435\u043D \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u0439.
    *   **\u0421\u0435\u043A\u0440\u0435\u0442\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438.**
    \u041F\u043E \u043F\u043E\u0440\u0443\u0447\u0435\u043D\u0438\u044E \u0440\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u0440\u0438\u0446\u044B \u0415\u043A\u0430\u0442\u0435\u0440\u0438\u043D\u044B
    II \u042D\u0439\u043B\u0435\u0440 \u0440\u0435\u0448\u0430\u043B \u0437\u0430\u0434\u0430\u0447\u0438
    \u043F\u043E \u043D\u0430\u0432\u0438\u0433\u0430\u0446\u0438\u0438, \u043A\u0430\u0440\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u0438 \u0434\u0430\u0436\u0435 \u0431\u0430\u043B\u043B\u0438\u0441\u0442\u0438\u043A\u0435.
    \u041E\u043D \u0431\u044B\u043B, \u043F\u043E \u0441\u0443\u0442\u0438, \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u043E\u043C \u043F\u043E \u043D\u0430\u0443\u043A\u0435. 
    ### \U0001F934 \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441
    \u043C\u043E\u043D\u0430\u0440\u0445\u0430\u043C\u0438  \u042D\u0439\u043B\u0435\u0440
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043F\u0440\u0438 \u0434\u0432\u0443\u0445
    \u0432\u0435\u043B\u0438\u043A\u0438\u0445 \u043C\u043E\u043D\u0430\u0440\u0445\u0430\u0445
    \u2014 \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0435 II (\u041F\u0440\u0443\u0441\u0441\u0438\u044F)
    \u0438 \u0415\u043A\u0430\u0442\u0435\u0440\u0438\u043D\u0435 II (\u0420\u043E\u0441\u0441\u0438\u044F),
    \u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435 \u043A \u043D\u0435\u043C\u0443
    \u0431\u044B\u043B\u043E \u0434\u0438\u0430\u043C\u0435\u0442\u0440\u0430\u043B\u044C\u043D\u043E
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u044B\u043C: 
    *   **\u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u0441 \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u043E\u043C
    II.** \u041F\u0440\u0443\u0441\u0441\u043A\u0438\u0439 \u043A\u043E\u0440\u043E\u043B\u044C,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u043F\u0440\u043E\u0441\u0432\u0435\u0449\u0451\u043D\u043D\u044B\u043C,
    \u043D\u0435 \u043B\u044E\u0431\u0438\u043B \u042D\u0439\u043B\u0435\u0440\u0430.
    \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B \u0435\u0433\u043E \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0441\u043A\u0443\u0447\u043D\u044B\u043C \u0438 \u043D\u0435 \"\u0441\u0432\u0435\u0442\u0441\u043A\u0438\u043C\".
    \u0424\u0440\u0438\u0434\u0440\u0438\u0445 \u0433\u043E\u0432\u043E\u0440\u0438\u043B,
    \u0447\u0442\u043E \u042D\u0439\u043B\u0435\u0440 \u043F\u043E\u0445\u043E\u0436
    \u043D\u0430 \"\u0443\u0447\u0451\u043D\u043E\u0433\u043E \u043C\u0443\u0436\u0438\u043A\u0430\"
    \u0438 \u043D\u0435 \u0443\u043C\u0435\u0435\u0442 \u0432\u0435\u0441\u0442\u0438
    \u0431\u0435\u0441\u0435\u0434\u0443. \u041E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043A\u043E\u0440\u043E\u043B\u044C \u0441\u043F\u0440\u043E\u0441\u0438\u043B
    \u042D\u0439\u043B\u0435\u0440\u0430, \u043F\u043E\u0447\u0435\u043C\u0443 \u043E\u043D
    \u043D\u0435 \u0442\u0430\u043A\u043E\u0439 \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u044B\u0439,
    \u043A\u0430\u043A \u0412\u043E\u043B\u044C\u0442\u0435\u0440. \u041D\u0430 \u044D\u0442\u043E
    \u042D\u0439\u043B\u0435\u0440 \u043E\u0442\u0432\u0435\u0442\u0438\u043B: *\xAB\u0412\u0430\u0448\u0435
    \u0412\u0435\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E, \u044F \u043D\u0435
    \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u0435\u043D, \u043F\u043E\u0442\u043E\u043C\u0443
    \u0447\u0442\u043E \u043C\u043E\u0438 \u043E\u0442\u0432\u0435\u0442\u044B \u0438\u043C\u0435\u044E\u0442
    \u0441\u043C\u044B\u0441\u043B, \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u043E\u0441\u0442\u0440\u043E\u0442 \u0433\u043E\u0441\u043F\u043E\u0434\u0438\u043D\u0430
    \u0412\u043E\u043B\u044C\u0442\u0435\u0440\u0430\xBB*. *   **\u041E\u0431\u043E\u0436\u0430\u043D\u0438\u0435
    \u0415\u043A\u0430\u0442\u0435\u0440\u0438\u043D\u044B II.** \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C
    \u0432 \u0420\u043E\u0441\u0441\u0438\u044E, \u042D\u0439\u043B\u0435\u0440 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043E\u0442 \u0415\u043A\u0430\u0442\u0435\u0440\u0438\u043D\u044B \u0446\u0430\u0440\u0441\u043A\u0438\u0439
    \u043F\u0440\u0438\u0435\u043C. \u041E\u043D\u0430 \u043D\u0430\u0437\u043D\u0430\u0447\u0438\u043B\u0430
    \u0435\u043C\u0443 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u0438\u0435,
    \u0447\u0442\u043E\u0431\u044B \u043E\u043D \u043D\u0438 \u0432 \u0447\u0451\u043C
    \u043D\u0435 \u043D\u0443\u0436\u0434\u0430\u043B\u0441\u044F, \u0438 \u0441\u043A\u0430\u0437\u0430\u043B\u0430:
    *\xAB\u0415\u0441\u043B\u0438 \u042D\u0439\u043B\u0435\u0440 \u043E\u0441\u043B\u0435\u043F,
    \u043F\u0443\u0441\u0442\u044C \u0434\u0438\u043A\u0442\u0443\u0435\u0442 \u2014
    \u044F \u0437\u0430\u043F\u043B\u0430\u0447\u0443 \u0437\u0430 \u0432\u0441\u0435\u0445
    \u043F\u0438\u0441\u0446\u043E\u0432\xBB*. \u041E\u043D\u0430 \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430
    \u0435\u043C\u0443 \u043F\u043E\u043B\u043D\u0443\u044E \u0441\u0432\u043E\u0431\u043E\u0434\u0443
    \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430.  ### \u270D\uFE0F
    \"\u041F\u0438\u0441\u044C\u043C\u0430 \u043A \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0439
    \u043F\u0440\u0438\u043D\u0446\u0435\u0441\u0441\u0435\" \u2014 \u0431\u0435\u0441\u0442\u0441\u0435\u043B\u043B\u0435\u0440
    XVIII \u0432\u0435\u043A\u0430  \u042D\u0439\u043B\u0435\u0440 \u0431\u044B\u043B
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u043C \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C
    \u043D\u0430\u0443\u043A\u0438. \u0415\u0433\u043E **\"\u041F\u0438\u0441\u044C\u043C\u0430
    \u043A \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0439 \u043F\u0440\u0438\u043D\u0446\u0435\u0441\u0441\u0435
    \u043E \u0440\u0430\u0437\u043D\u044B\u0445 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445 \u043C\u0430\u0442\u0435\u0440\u0438\u044F\u0445\"**,
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0435 \u0432 1768\u20131772
    \u0433\u043E\u0434\u0430\u0445, \u0441\u0442\u0430\u043B\u0438 \u043C\u0438\u0440\u043E\u0432\u044B\u043C
    \u0431\u0435\u0441\u0442\u0441\u0435\u043B\u043B\u0435\u0440\u043E\u043C. \u042D\u0442\u0430
    \u043A\u043D\u0438\u0433\u0430 \u0431\u044B\u043B\u0430 \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043D\u0430
    \u043D\u0430 10 \u044F\u0437\u044B\u043A\u043E\u0432, \u0432\u044B\u0434\u0435\u0440\u0436\u0430\u043B\u0430
    \u043E\u043A\u043E\u043B\u043E 40 \u0438\u0437\u0434\u0430\u043D\u0438\u0439.
    \u041F\u043E \u0441\u0443\u0442\u0438, \u044D\u0442\u043E \u0431\u044B\u043B\u0430
    \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u044F \u0444\u0438\u0437\u0438\u043A\u0438
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438 \u0442\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u0430\u044F
    \u0436\u0438\u0432\u044B\u043C \u0438 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u043C
    \u044F\u0437\u044B\u043A\u043E\u043C. \u0414\u0430\u0436\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u042D\u0439\u043B\u0435\u0440\u0430 \u044D\u0442\u0443
    \u043A\u043D\u0438\u0433\u0443 \u0447\u0438\u0442\u0430\u043B\u0438 \u043C\u043D\u043E\u0433\u0438\u0435
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F.  ### \u26B0\uFE0F \u0421\u043C\u0435\u0440\u0442\u044C
    \u0438 \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u044F  \u042D\u0439\u043B\u0435\u0440
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 18 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F
    1783 \u0433\u043E\u0434\u0430 \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0435.
    \u041B\u0435\u0433\u0435\u043D\u0434\u0430 \u0433\u043B\u0430\u0441\u0438\u0442,
    \u0447\u0442\u043E \u043E\u043D \u0443\u043C\u0435\u0440 \u0442\u0430\u043A \u0436\u0435,
    \u043A\u0430\u043A \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B. \u0412
    \u0442\u043E\u0442 \u0434\u0435\u043D\u044C \u043E\u043D \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F\u043C\u0438 \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438
    \u0432\u043E\u0437\u0434\u0443\u0448\u043D\u043E\u0433\u043E \u0448\u0430\u0440\u0430.
    \u041F\u043E\u043A\u0430 \u0435\u0433\u043E \u0437\u044F\u0442\u044C \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u043B
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443, \u042D\u0439\u043B\u0435\u0440 \u0432\u0437\u044F\u043B
    \u0442\u0430\u0431\u0430\u043A\u0435\u0440\u043A\u0443, \u043F\u043E\u043D\u044E\u0445\u0430\u043B
    \u0442\u0430\u0431\u0430\u043A\u0443 \u0438... \u0432\u0434\u0440\u0443\u0433
    \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441: *\xAB\u042F \u0443\u043C\u0438\u0440\u0430\u044E\xBB*.
    \u0412 \u0442\u043E\u0442 \u0436\u0435 \u043C\u0438\u0433 \u0435\u0433\u043E
    \u0441\u0435\u0440\u0434\u0446\u0435 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u043E\u0441\u044C.
    \u041D\u0430 \u0435\u0433\u043E \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u0438
    (\u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E-\u041D\u0435\u0432\u0441\u043A\u043E\u0439
    \u043B\u0430\u0432\u0440\u0435) \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u0430
    \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0433\u043B\u0430\u0441\u0438\u0442: *\xAB\u0417\u0434\u0435\u0441\u044C \u043F\u043E\u043A\u043E\u0438\u0442\u0441\u044F
    \u043F\u0440\u0430\u0445 \u043C\u0443\u0434\u0440\u043E\u0433\u043E, \u043F\u0440\u0430\u0432\u0435\u0434\u043D\u043E\u0433\u043E
    \u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u0430
    \u042D\u0439\u043B\u0435\u0440\u0430\xBB*."
