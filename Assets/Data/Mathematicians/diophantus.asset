    \u0442\u044F\u0436\u043A\u043E\u0435 \u0433\u043E\u0440\u0435,* > *\u0422\u0443\u0442
    \u0438 \u0443\u0432\u0438\u0434\u0435\u043B \u043F\u0440\u0435\u0434\u0435\u043B
    \u0436\u0438\u0437\u043D\u0438 \u043F\u0435\u0447\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0432\u043E\u0435\u0439.\xBB*  \u042D\u0442\u0430 \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u044F
