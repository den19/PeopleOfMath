    \u043E\u043A\u0443\u0442\u0430\u043D\u043D\u0430\u044F \u0442\u0430\u0439\u043D\u043E\u0439,
    \u0434\u0435\u043B\u0430\u0435\u0442 \u0435\u0433\u043E \u0444\u0438\u0433\u0443\u0440\u0443
    \u0435\u0449\u0435 \u0431\u043E\u043B\u0435\u0435 \u0432\u0435\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u2014 \u043C\u044B \u0437\u043D\u0430\u0435\u043C \u0435\u0433\u043E \u043F\u043E
    \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0442\u0440\u0443\u0434\u0430\u043C, \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0448\u0438\u043C
    \u0432\u0435\u043A\u0430."
  shortBioEn: 
  interestingFactsRu: "\u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430
    \u0442\u043E, \u0447\u0442\u043E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u043E\u043A\u0443\u0442\u0430\u043D\u0430
    \u0442\u0430\u0439\u043D\u043E\u0439, \u0441 \u0435\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C
    \u0441\u0432\u044F\u0437\u0430\u043D\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439 \u0438 \u0444\u0430\u043A\u0442\u043E\u0432.
    \u041F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u044E \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u0442\u044C\u0441\u044F
    \u0432 \u043C\u0438\u0440 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0434\u0435\u0442\u0430\u043B\u0435\u0439, \u043E\u043A\u0440\u0443\u0436\u0430\u044E\u0449\u0438\u0445
    \u044D\u0442\u043E\u0433\u043E \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430.  ### \u26B0\uFE0F
    \u042D\u043F\u0438\u0442\u0430\u0444\u0438\u044F-\u0433\u043E\u043B\u043E\u0432\u043E\u043B\u043E\u043C\u043A\u0430 
    \u0421\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0438 \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u0430\u044F
    \u0441 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u043C, \u2014 \u044D\u0442\u043E
    \u043D\u0430\u0434\u043F\u0438\u0441\u044C \u043D\u0430 \u0435\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u044C\u043D\u043E\u043C
    \u043A\u0430\u043C\u043D\u0435, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u044B\u043B\u0430
    \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430 \u0432 \u0432\u0438\u0434\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0438. \u0415\u0451 \u0430\u0432\u0442\u043E\u0440\u043E\u043C,
    \u043A\u0430\u043A \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0431\u044B\u043B
    \u0434\u0440\u0443\u0433\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u041C\u0435\u0442\u0440\u043E\u0434\u043E\u0440.  > *\xAB\u041F\u0440\u0430\u0445
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u0433\u0440\u043E\u0431\u043D\u0438\u0446\u0430
    \u043F\u043E\u043A\u043E\u0438\u0442; \u0434\u0438\u0432\u0438\u0441\u044C \u0435\u0439
    \u2014 \u0438 \u043A\u0430\u043C\u0435\u043D\u044C* > *\u041C\u0443\u0434\u0440\u044B\u043C
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E\u043C \u0435\u0433\u043E
