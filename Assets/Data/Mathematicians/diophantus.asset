  achievementsRu: "\u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0438\u0439
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0440\u044F\u0434 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0430 \u0432\u0435\u043A\u0430 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0438
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0415\u0433\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043B\u0435\u0436\u0430\u0442 \u0432 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430, \u043D\u043E\u0432\u043E\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u0430
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0438 \u0432 \u0441\u0430\u043C\u043E\u043C \u043F\u043E\u0434\u0445\u043E\u0434\u0435
    \u043A \u0447\u0438\u0441\u043B\u0430\u043C.  ### \U0001F4A1 \u041E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u043E\u0442 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 
    \u0413\u0440\u0435\u0447\u0435\u0441\u043A\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0434\u043E \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u0431\u044B\u043B\u0430
    \u0442\u0435\u0441\u043D\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439: \u0437\u0430\u0434\u0430\u0447\u0438
    \u0440\u0435\u0448\u0430\u043B\u0438\u0441\u044C \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0447\u0435\u0440\u0442\u0435\u0436\u0435\u0439 \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0439, \u0434\u0430\u0436\u0435
    \u0435\u0441\u043B\u0438 \u043E\u043D\u0438 \u0431\u044B\u043B\u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043F\u043E \u0441\u0432\u043E\u0435\u0439 \u0441\u0443\u0442\u0438.  \u0414\u0438\u043E\u0444\u0430\u043D\u0442
    \u0432 \u043A\u043E\u0440\u043D\u0435 \u0438\u0437\u043C\u0435\u043D\u0438\u043B
    \u044D\u0442\u043E\u0442 \u043F\u043E\u0434\u0445\u043E\u0434. \u041E\u043D \u043F\u0435\u0440\u0432\u044B\u043C
    \u0438\u0437 \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u0445 \u0443\u0447\u0435\u043D\u044B\u0445
    \u043D\u0430\u0447\u0430\u043B \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C **\u0447\u0438\u0441\u0442\u043E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B**, \u043D\u0435 \u043F\u0440\u0438\u0431\u0435\u0433\u0430\u044F
    \u043A \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438\u043D\u0442\u0435\u0440\u043F\u0440\u0435\u0442\u0430\u0446\u0438\u0438
    \u0434\u043B\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0438 \u0440\u0435\u0448\u0435\u043D\u0438\u044F. \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C \u0448\u0430\u0433\u043E\u043C
    \u0432\u043F\u0435\u0440\u0435\u0434, \u0432\u044B\u0434\u0435\u043B\u0438\u0432
    \u0430\u043B\u0433\u0435\u0431\u0440\u0443 \u0432 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u0441\u0434\u0435\u043B\u0430\u0432 \u0435\u0435 \u0431\u043E\u043B\u0435\u0435
    \u0433\u0438\u0431\u043A\u0438\u043C \u0438 \u043C\u043E\u0449\u043D\u044B\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0437\u0430\u0434\u0430\u0447.  ###
    \u270D\uFE0F \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043F\u0435\u0440\u0432\u043E\u0433\u043E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430  \u0414\u043E \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u0432\u0441\u0435 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438\u0441\u044C \u0441\u043B\u043E\u0432\u0430\u043C\u0438
    \u2014 \u044D\u0442\u043E \u0431\u044B\u043B\u0430 \u0442\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u0430\u044F
    **\u0440\u0438\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u0430**.
    \u042D\u0442\u043E \u0434\u0435\u043B\u0430\u043B\u043E \u0437\u0430\u043F\u0438\u0441\u0438
    \u0433\u0440\u043E\u043C\u043E\u0437\u0434\u043A\u0438\u043C\u0438 \u0438 \u043D\u0435\u0443\u0434\u043E\u0431\u043D\u044B\u043C\u0438
    \u0434\u043B\u044F \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0439. 
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    **\u0441\u0438\u043D\u043A\u043E\u043F\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0443\u044E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0443** \u2014 \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u0441\u043E\u043A\u0440\u0430\u0449\u0435\u043D\u043D\u044B\u0445 \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u043B\u0430 \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u0446\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u043A\u0438. \u041E\u043D \u0432\u0432\u0435\u043B
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u0437\u043D\u0430\u043A\u0438
    \u0434\u043B\u044F:  *   **\u041D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439
    (`\u03C2`)** \u0438 \u0435\u0435 \u0441\u0442\u0435\u043F\u0435\u043D\u0435\u0439,
    \u0432\u043F\u043B\u043E\u0442\u044C \u0434\u043E \u0448\u0435\u0441\u0442\u043E\u0439
    (`\u0394\u03A5` \u0434\u043B\u044F \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430,
    `\u039A\u03A5` \u0434\u043B\u044F \u043A\u0443\u0431\u0430 \u0438 \u0442.\u0434.).
    *   **\u0412\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u044F** (\u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443\u0442\u0430\u044F
    \u0431\u0443\u043A\u0432\u0430 \u03A8). *   **\u0420\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u0430**
    (\u0441\u043E\u043A\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u043E\u0442 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043B\u043E\u0432\u0430 \"\u0440\u0430\u0432\u043D\u044B\u0439\").  \u0411\u043E\u043B\u0435\u0435
    \u0442\u043E\u0433\u043E, \u043E\u043D \u043E\u043F\u0438\u0441\u0430\u043B **\u043F\u0440\u0430\u0432\u0438\u043B\u0430
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439 \u0441 \u044D\u0442\u0438\u043C\u0438
    \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u043C\u0438**: \u043F\u0440\u0438\u0432\u0435\u043B
    \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u043F\u0440\u0438\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u043F\u043E\u0434\u043E\u0431\u043D\u044B\u0445 \u0447\u043B\u0435\u043D\u043E\u0432,
    \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0430 \u0447\u043B\u0435\u043D\u043E\u0432
    \u0438\u0437 \u043E\u0434\u043D\u043E\u0439 \u0447\u0430\u0441\u0442\u0438 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u0432 \u0434\u0440\u0443\u0433\u0443\u044E \u0441\u043E \u0441\u043C\u0435\u043D\u043E\u0439
    \u0437\u043D\u0430\u043A\u0430 \u0438, \u0447\u0442\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0432\u0430\u0436\u043D\u043E, \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    **\u043F\u0440\u0430\u0432\u0438\u043B\u043E \u0437\u043D\u0430\u043A\u043E\u0432**
    \u043F\u0440\u0438 \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0438 (\xAB\u043C\u0438\u043D\u0443\u0441
    \u043D\u0430 \u043C\u0438\u043D\u0443\u0441 \u0434\u0430\u0451\u0442 \u043F\u043B\u044E\u0441\xBB).
    \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u043E
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C \u0438 \u0440\u0435\u0448\u0430\u0442\u044C
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F,
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0443\u0441\u043A\u043E\u0440\u0438\u0432
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441 \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F. 
    ### \U0001F50D \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432 \u0430\u043D\u0430\u043B\u0438\u0437:
    \u043C\u0435\u0442\u043E\u0434 \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439  \u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u2014 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0430 \u043C\u0435\u0442\u043E\u0434\u0430
    \u0434\u043B\u044F \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    **\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439** (\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0441 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u043C\u0438 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C\u0438).
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434,
    \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430\xBB, \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    \u0441\u043E\u0431\u043E\u0439 \u0441\u0431\u043E\u0440\u043D\u0438\u043A \u0437\u0430\u0434\u0430\u0447,
    \u0434\u043B\u044F \u043A\u0430\u0436\u0434\u043E\u0439 \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u043D \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
    \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0439 \u043C\u0435\u0442\u043E\u0434
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F. \u041E\u0434\u043D\u0430\u043A\u043E,
    \u0437\u0430 \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u043C\u0438 \u043F\u0440\u0438\u0435\u043C\u0430\u043C\u0438
    \u043F\u0440\u043E\u0441\u043B\u0435\u0436\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u043E\u0431\u0449\u0438\u0439 \u043F\u043E\u0434\u0445\u043E\u0434.  \u0421\u0443\u0442\u044C
    \u0435\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u0430 \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0432\u0438\u0434\u0430
    `F(x, y) = 0` \u0431\u044B\u043B\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439: 
    1.  \u041D\u0443\u0436\u043D\u043E \u043D\u0430\u0439\u0442\u0438 \u043E\u0434\u043D\u043E
    \u0447\u0430\u0441\u0442\u043D\u043E\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0435,
    \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, `(a, b)`. 2.  \u0417\u0430\u0442\u0435\u043C
    \u0447\u0435\u0440\u0435\u0437 \u044D\u0442\u0443 \u0442\u043E\u0447\u043A\u0443
    \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u0442\u0441\u044F \u043F\u0440\u044F\u043C\u0430\u044F
    \u0441 \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0433\u043B\u043E\u0432\u044B\u043C \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u043E\u043C
    `k`. 3.  \u041D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u0432\u0442\u043E\u0440\u0430\u044F
    \u0442\u043E\u0447\u043A\u0430 \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u044F
    \u044D\u0442\u043E\u0439 \u043F\u0440\u044F\u043C\u043E\u0439 \u0441 \u043A\u0440\u0438\u0432\u043E\u0439,
    \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u0439 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435\u043C.
    \u041F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443 \u0438 \u0442\u043E\u0447\u043A\u0430,
    \u0438 \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442 \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B,
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B \u043D\u043E\u0432\u043E\u0439
    \u0442\u043E\u0447\u043A\u0438 \u0442\u0430\u043A\u0436\u0435 \u0431\u0443\u0434\u0443\u0442
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u043C\u0438. 
    \u042D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434, \u043F\u043E \u0441\u0443\u0442\u0438,
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043C\u043E\u0449\u043D\u044B\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u0433\u0435\u043D\u0435\u0440\u0430\u0446\u0438\u0438 \u043D\u043E\u0432\u044B\u0445
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0440\u0435\u0448\u0435\u043D\u0438\u0439
    \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435 \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E. \u041E\u043D \u043E\u043A\u0430\u0437\u0430\u043B
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E.  ### \U0001F48E \u041D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u043E\u0435
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435 \u043A \u0447\u0438\u0441\u043B\u0430\u043C 
    \u0414\u043B\u044F \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u0430
    \u0434\u0440\u0435\u0432\u043D\u0435\u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0447\u0438\u0441\u043B\u0430\u043C\u0438
    \u0431\u044B\u043B\u0438 \u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430. \u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u0436\u0435
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0435\u0449\u0435 \u043E\u0434\u043D\u0443
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E:  *   **\u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0434\u0440\u043E\u0431\u0435\u0439 \u0447\u0438\u0441\u043B\u0430\u043C\u0438:**
    \u041E\u043D \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u043C \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0442\u044C
    **\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435 \u0447\u0438\u0441\u043B\u0430**
    (\u0434\u0440\u043E\u0431\u0438) \u043D\u0430\u0440\u0430\u0432\u043D\u0435 \u0441
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u043C\u0438 \u0438
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
    \u0438\u0445 \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0439.
    *   **\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D:** \u0425\u043E\u0442\u044F \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u0443 \u043D\u0435\u0433\u043E \u043D\u0435 \u0431\u044B\u043B\u043E,
    \u043E\u043D \u0432\u0432\u0435\u043B **\u0441\u0438\u043C\u0432\u043E\u043B
    \u0434\u043B\u044F \u0432\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u044F** \u0438
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0439
    \u0441 \u0432\u044B\u0447\u0438\u0442\u0430\u0435\u043C\u044B\u043C\u0438 \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u0430\u043C\u0438,
    \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043E\u043F\u0435\u0440\u0438\u0440\u0443\u044F
    \u0438\u043C\u0438 \u0432 \u0441\u0432\u043E\u0438\u0445 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F\u0445. 
    ### \U0001F30D \u0412\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u043C\u0438\u0440\u043E\u0432\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443  \u0414\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u043D\u0435 \u0431\u044B\u043B\u0438
    \u0437\u0430\u0431\u044B\u0442\u044B. \u0415\u0433\u043E \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430\xBB
    \u0441\u0442\u0430\u043B\u0430 \u043C\u043E\u0441\u0442\u043E\u043C, \u043F\u043E
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443 \u0437\u043D\u0430\u043D\u0438\u044F
    \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u0438 \u043F\u0435\u0440\u0435\u0448\u043B\u0438
    \u043A \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C
    (\u0432 X \u0432\u0435\u043A\u0435) \u0438 \u0437\u0430\u0442\u0435\u043C, \u0447\u0435\u0440\u0435\u0437
    \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u0438\u0435 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u044B
    (\u0441\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u2014 \u0438\u0437\u0434\u0430\u043D\u0438\u0435 \u0411\u0430\u0448\u0435 \u0434\u0435
    \u041C\u0435\u0437\u0438\u0440\u0438\u0430\u043A\u0430 \u0432 1621 \u0433\u043E\u0434\u0443),
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0443.  \u0420\u0430\u0431\u043E\u0442\u0430
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u043E\u043A\u0430\u0437\u0430\u043B\u0430
    \u043A\u043B\u044E\u0447\u0435\u0432\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u044B
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B. \u0415\u0433\u043E
    \u043C\u0435\u0442\u043E\u0434\u044B \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u043B\u0438
    \u0442\u0430\u043A\u0438\u0445 \u0433\u0438\u0433\u0430\u043D\u0442\u043E\u0432,
    \u043A\u0430\u043A \u0424\u0440\u0430\u043D\u0441\u0443\u0430 \u0412\u0438\u0435\u0442,
    \u041F\u044C\u0435\u0440 \u0424\u0435\u0440\u043C\u0430 (\u0438\u043C\u0435\u043D\u043D\u043E
    \u043D\u0430 \u043F\u043E\u043B\u044F\u0445 \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\xBB
    \u0431\u044B\u043B\u0430 \u0437\u0430\u043F\u0438\u0441\u0430\u043D\u0430 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u0412\u0435\u043B\u0438\u043A\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430),
    \u041B\u0435\u043E\u043D\u0430\u0440\u0434 \u042D\u0439\u043B\u0435\u0440, \u041A\u0430\u0440\u043B
    \u042F\u043A\u043E\u0431\u0438 \u0438 \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435. 
    ### \u0418\u0442\u043E\u0433\u043E\u0432\u044B\u0439 \u0432\u043A\u043B\u0430\u0434 
    | **\u0421\u0444\u0435\u0440\u0430 \u0432\u043A\u043B\u0430\u0434\u0430** | **\u041A\u0440\u0430\u0442\u043A\u043E\u0435
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F**
    | | :--- | :--- | | **\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430** | \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043F\u0435\u0440\u0432\u0443\u044E \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0441\u043E\u043A\u0440\u0430\u0449\u0435\u043D\u043D\u044B\u0445
    \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439 \u0434\u043B\u044F
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445, \u0441\u0442\u0435\u043F\u0435\u043D\u0435\u0439
    \u0438 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439, \u043F\u0435\u0440\u0435\u0439\u0434\u044F
    \u043E\u0442 \u0441\u043B\u043E\u0432\u0435\u0441\u043D\u043E\u0439 \u043A \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u043E\u0439
    \u0437\u0430\u043F\u0438\u0441\u0438. | | **\u041E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u043E\u0442 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438** | \u041F\u0435\u0440\u0432\u044B\u043C
    \u0441\u0442\u0430\u043B \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C \u0447\u0438\u0441\u0442\u044B\u0435
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B, \u043D\u0435 \u043F\u0440\u0438\u0431\u0435\u0433\u0430\u044F
    \u043A \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F\u043C \u0434\u043B\u044F
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439.
    | | **\u041C\u0435\u0442\u043E\u0434 \u0440\u0435\u0448\u0435\u043D\u0438\u044F**
    | \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043E\u0431\u0449\u0438\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434 (\xAB\u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432
    \u0430\u043D\u0430\u043B\u0438\u0437\xBB) \u0434\u043B\u044F \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0440\u0435\u0448\u0435\u043D\u0438\u0439
    \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. | | **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B** | \u0424\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0441\u043D\u043E\u0432\u0430\u043B \u043D\u043E\u0432\u044B\u0439 \u0440\u0430\u0437\u0434\u0435\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0432
    \u0432 \u0446\u0435\u043D\u0442\u0440 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0432 \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u043B\u0430\u0445. \u0415\u0433\u043E \u0438\u043C\u044F \u043D\u043E\u0441\u0438\u0442
    \u043A\u043B\u0430\u0441\u0441 \u0437\u0430\u0434\u0430\u0447 \u2014 **\u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F**. | | **\u041D\u043E\u0432\u043E\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u0447\u0438\u0441\u043B\u0430** |
    \u0423\u0440\u0430\u0432\u043D\u044F\u043B \u0432 \u043F\u0440\u0430\u0432\u0430\u0445
    \u0434\u0440\u043E\u0431\u0438 \u0438 \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430, \u0434\u043E\u043F\u0443\u0441\u0442\u0438\u0432
    \u0438\u0445 \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0439,
    \u0438 \u043D\u0430\u0447\u0430\u043B \u043E\u043F\u0435\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u0430\u043C\u0438. |  \u0414\u0438\u043E\u0444\u0430\u043D\u0442
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0435\u0448\u0430\u043B
    \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438
    \u2014 \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u043D\u043E\u0432\u044B\u0439
    \u044F\u0437\u044B\u043A \u0438 \u043C\u0435\u0442\u043E\u0434, \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0432
    \u0430\u043B\u0433\u0435\u0431\u0440\u0443 \u0438\u0437 \u043D\u0430\u0431\u043E\u0440\u0430
    \u0440\u0435\u0446\u0435\u043F\u0442\u043E\u0432 \u0432 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0438 \u043F\u043E\u043B\u043D\u0443\u044E \u0441\u043C\u044B\u0441\u043B\u0430
    \u043D\u0430\u0443\u043A\u0443."
  achievementsEn: 
  personalLifeRu: "\u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    **\u043E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u0440\u043E\u0432\u043D\u043E
    \u043D\u0438\u0447\u0435\u0433\u043E, \u043A\u0440\u043E\u043C\u0435 \u0447\u0438\u0441\u0435\u043B,
    \u0437\u0430\u0448\u0438\u0444\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0432 \u0435\u0433\u043E \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u0438**.  
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0435\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u043E\u0448\u043B\u0438 \u0434\u043E
    \u043D\u0430\u0441 \u0447\u0435\u0440\u0435\u0437 \u0442\u0440\u0443\u0434\u044B,
    \u0431\u044B\u0442\u043E\u0432\u0430\u044F \u0438 \u043B\u0438\u0447\u043D\u0430\u044F
    \u0441\u0442\u043E\u0440\u043E\u043D\u0430 \u0436\u0438\u0437\u043D\u0438 \u044D\u0442\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0441\u043A\u0440\u044B\u0442\u0430 \u0432\u043E \u043C\u0440\u0430\u043A\u0435
    \u0432\u0435\u043A\u043E\u0432. \u0423 \u043D\u0430\u0441 \u043D\u0435\u0442
    \u043D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E \u043F\u0438\u0441\u044C\u043C\u0430,
    \u043D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u043D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F
    \u043E \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u0435, \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0430\u0445
    \u0438\u043B\u0438 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0435 \u0432\u043D\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u043D\u0442\u0435\u043A\u0441\u0442\u0430.   \u0412\u0441\u0435,
    \u0447\u0442\u043E \u043C\u044B \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u043C\u043E\u0436\u0435\u043C
    \xAB\u0437\u043D\u0430\u0442\u044C\xBB \u043E \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438, \u2014 \u044D\u0442\u043E \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0438-\u044D\u043F\u0438\u0442\u0430\u0444\u0438\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0434\u0430\u0436\u0435 \u0437\u0434\u0435\u0441\u044C
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F
    \u043A \u044D\u0442\u043E\u0439 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
    \u0441 \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E\u0441\u0442\u044C\u044E. 
    ---  ### 1. \u042D\u043F\u0438\u0442\u0430\u0444\u0438\u044F-\u0437\u0430\u0434\u0430\u0447\u0430:
    \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439 \xAB\u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\xBB 
    \u0412 \xAB\u041F\u0430\u043B\u0430\u0442\u0438\u043D\u0441\u043A\u043E\u0439
    \u0430\u043D\u0442\u043E\u043B\u043E\u0433\u0438\u0438\xBB (\u0441\u0431\u043E\u0440\u043D\u0438\u043A\u0435
    \u0434\u0440\u0435\u0432\u043D\u0435\u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0445
    \u044D\u043F\u0438\u0433\u0440\u0430\u043C\u043C, \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u043C
    \u043E\u043A\u043E\u043B\u043E 500 \u0433\u043E\u0434\u0430 \u043D. \u044D.)
    \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0430\u044F
    \u0437\u0430\u0434\u0430\u0447\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F,
    \u043A\u0430\u043A \u0441\u0447\u0438\u0442\u0430\u043B\u043E\u0441\u044C, \u0431\u044B\u043B\u0430
    \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u0430 \u043D\u0430 \u043C\u043E\u0433\u0438\u043B\u044C\u043D\u043E\u043C
    \u043A\u0430\u043C\u043D\u0435 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430: 
    > *\xAB\u041F\u0440\u0430\u0445 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u0433\u0440\u043E\u0431\u043D\u0438\u0446\u0430 \u043F\u043E\u043A\u043E\u0438\u0442;
    \u0434\u0438\u0432\u0438\u0441\u044C \u0435\u0439 \u2014 \u0438 \u043A\u0430\u043C\u0435\u043D\u044C*
    > *\u041C\u0443\u0434\u0440\u044B\u043C \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E\u043C
    \u0435\u0433\u043E \u0441\u043A\u0430\u0436\u0435\u0442 \u0443\u0441\u043E\u043F\u0448\u0435\u0433\u043E
    \u0432\u0435\u043A.* > *\u0412\u043E\u043B\u0435\u0439 \u0431\u043E\u0433\u043E\u0432
    \u0448\u0435\u0441\u0442\u0443\u044E \u0447\u0430\u0441\u0442\u044C \u0436\u0438\u0437\u043D\u0438
    \u043E\u043D \u043F\u0440\u043E\u0436\u0438\u043B \u0440\u0435\u0431\u0451\u043D\u043A\u043E\u043C.*
    > *\u0418 \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443 \u0448\u0435\u0441\u0442\u043E\u0439
    \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B \u0441 \u043F\u0443\u0448\u043A\u043E\u043C
    \u043D\u0430 \u0449\u0435\u043A\u0430\u0445.* > *\u0422\u043E\u043B\u044C\u043A\u043E
    \u043C\u0438\u043D\u0443\u043B\u0430 \u0441\u0435\u0434\u044C\u043C\u0430\u044F,
    \u0441 \u043F\u043E\u0434\u0440\u0443\u0433\u043E\u0439 \u043E\u043D \u043E\u0431\u0440\u0443\u0447\u0438\u043B\u0441\u044F.*
    > *\u0421 \u043D\u0435\u044E, \u043F\u044F\u0442\u044C \u043B\u0435\u0442 \u043F\u0440\u043E\u0432\u0435\u0434\u044F,
    \u0441\u044B\u043D\u0430 \u0434\u043E\u0436\u0434\u0430\u043B\u0441\u044F \u043C\u0443\u0434\u0440\u0435\u0446;*
    > *\u0422\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u043B\u0436\u0438\u0437\u043D\u0438
    \u043E\u0442\u0446\u043E\u0432\u0441\u043A\u043E\u0439 \u0432\u043E\u0437\u043B\u044E\u0431\u043B\u0435\u043D\u043D\u044B\u0439
    \u0441\u044B\u043D \u0435\u0433\u043E \u043F\u0440\u043E\u0436\u0438\u043B.*
    > *\u041E\u0442\u043D\u044F\u0442 \u043E\u043D \u0431\u044B\u043B \u0443 \u043E\u0442\u0446\u0430
    \u0440\u0430\u043D\u043D\u0435\u0439 \u043C\u043E\u0433\u0438\u043B\u043E\u0439
    \u0441\u0432\u043E\u0435\u0439.* > *\u0414\u0432\u0430\u0436\u0434\u044B \u0434\u0432\u0430
    \u0433\u043E\u0434\u0430 \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u044C \u043E\u043F\u043B\u0430\u043A\u0438\u0432\u0430\u043B
    \u0442\u044F\u0436\u043A\u043E\u0435 \u0433\u043E\u0440\u0435,* > *\u0422\u0443\u0442
    \u0438 \u0443\u0432\u0438\u0434\u0435\u043B \u043F\u0440\u0435\u0434\u0435\u043B
    \u0436\u0438\u0437\u043D\u0438 \u043F\u0435\u0447\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0432\u043E\u0435\u0439\xBB.*  ---  ### 2. \u0420\u0435\u0448\u0435\u043D\u0438\u0435
    \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u0438: \u0425\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044F
    \u0436\u0438\u0437\u043D\u0438  \u0415\u0441\u043B\u0438 \u0440\u0435\u0448\u0438\u0442\u044C
    \u044D\u0442\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435, \u0441\u043B\u043E\u0436\u0438\u0432
    \u0432\u0441\u0435 \u0447\u0430\u0441\u0442\u0438 \u0436\u0438\u0437\u043D\u0438
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430, \u043C\u044B \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u043C,
    \u0447\u0442\u043E \u043E\u043D \u043F\u0440\u043E\u0436\u0438\u043B **84 \u0433\u043E\u0434\u0430**.
    \u0418\u0441\u0445\u043E\u0434\u044F \u0438\u0437 \u044D\u0442\u043E\u0433\u043E,
    \u043C\u044B \u043C\u043E\u0436\u0435\u043C \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0443\u044E \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044E
    \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u0430\u0433\u0430\u0435\u043C\u043E\u0439
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438:  *   **\u0414\u0435\u0442\u0441\u0442\u0432\u043E
    (0\u201314 \u043B\u0435\u0442):** \u041F\u0435\u0440\u0432\u0443\u044E \u0448\u0435\u0441\u0442\u0443\u044E
    \u0447\u0430\u0441\u0442\u044C \u0436\u0438\u0437\u043D\u0438 (84 / 6 = 14 \u043B\u0435\u0442)
    \u043E\u043D \u043F\u0440\u043E\u0436\u0438\u043B \u0440\u0435\u0431\u0435\u043D\u043A\u043E\u043C.
    *   **\u042E\u043D\u043E\u0441\u0442\u044C (14\u201321 \u0433\u043E\u0434):**
    \u0415\u0449\u0435 \u043E\u0434\u043D\u0443 \u0434\u0432\u0435\u043D\u0430\u0434\u0446\u0430\u0442\u0443\u044E
    \u0447\u0430\u0441\u0442\u044C \u0436\u0438\u0437\u043D\u0438 (84 / 12 = 7 \u043B\u0435\u0442)
    \u043E\u043D \u0431\u044B\u043B \u044E\u043D\u043E\u0448\u0435\u0439, \u0438
    \u0438\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \xAB\u043F\u0443\u0448\u043E\u043A\xBB \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0435\u0433\u043E \u0449\u0435\u043A\u0430\u0445 (\u0442\u043E
    \u0435\u0441\u0442\u044C \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B\u043E
    \u043F\u043E\u043B\u043E\u0432\u043E\u0435 \u0441\u043E\u0437\u0440\u0435\u0432\u0430\u043D\u0438\u0435).
    \u041A 21 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B \u0432\u0437\u0440\u043E\u0441\u043B\u044B\u043C
    \u043C\u0443\u0436\u0447\u0438\u043D\u043E\u0439. *   **\u041E\u0431\u0440\u0443\u0447\u0435\u043D\u0438\u0435
    (\u0432 33 \u0433\u043E\u0434\u0430):** \u0421\u043B\u0435\u0434\u0443\u044E\u0449\u0430\u044F
    \u0441\u0435\u0434\u044C\u043C\u0430\u044F \u0447\u0430\u0441\u0442\u044C \u0436\u0438\u0437\u043D\u0438
    (84 / 7 = 12 \u043B\u0435\u0442) \u043F\u0440\u043E\u0448\u043B\u0430 \u0434\u043E
    \u043C\u043E\u043C\u0435\u043D\u0442\u0430 \u043E\u0431\u0440\u0443\u0447\u0435\u043D\u0438\u044F.
    21 + 12 = **33 \u0433\u043E\u0434\u0430**. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0432 \u044D\u0442\u043E\u043C \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    (\u043F\u043E \u043C\u0435\u0440\u043A\u0430\u043C \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u0438
    \u2014 \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E \u043F\u043E\u0437\u0434\u043D\u043E)
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u043E\u0431\u0440\u0443\u0447\u0438\u043B\u0441\u044F
    \u0441\u043E \u0441\u0432\u043E\u0435\u0439 \xAB\u043F\u043E\u0434\u0440\u0443\u0433\u043E\u0439\xBB
    (\u0436\u0435\u043D\u043E\u0439). *   **\u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0441\u044B\u043D\u0430 (\u0432 38 \u043B\u0435\u0442):** \u041F\u043E\u0441\u043B\u0435
    \u043E\u0431\u0440\u0443\u0447\u0435\u043D\u0438\u044F \u043E\u043D \u043F\u0440\u043E\u0436\u0438\u043B
    \u0441 \u0436\u0435\u043D\u043E\u0439 5 \u043B\u0435\u0442, \u043F\u0440\u0435\u0436\u0434\u0435
    \u0447\u0435\u043C \u0443 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0441\u044B\u043D. 33 + 5 = **38 \u043B\u0435\u0442**. *   **\u0421\u043C\u0435\u0440\u0442\u044C
    \u0441\u044B\u043D\u0430 (\u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0443 80
    \u043B\u0435\u0442):** \u0421\u044B\u043D \u043F\u0440\u043E\u0436\u0438\u043B
    \u0440\u043E\u0432\u043D\u043E \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443
    \u0436\u0438\u0437\u043D\u0438 \u043E\u0442\u0446\u0430 (84 / 2 = 42 \u0433\u043E\u0434\u0430).
    \u0417\u043D\u0430\u0447\u0438\u0442, \u0441\u044B\u043D \u0443\u043C\u0435\u0440,
    \u043A\u043E\u0433\u0434\u0430 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0443
    \u0431\u044B\u043B\u043E 38 + 42 = **80 \u043B\u0435\u0442**. *   **\u0421\u043C\u0435\u0440\u0442\u044C
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 (\u0432 84 \u0433\u043E\u0434\u0430):**
    \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u0441\u044B\u043D\u0430
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u043E\u043F\u043B\u0430\u043A\u0438\u0432\u0430\u043B
    \u0435\u0433\u043E \u0440\u043E\u0432\u043D\u043E 4 \u0433\u043E\u0434\u0430
    (\u0434\u0432\u0430\u0436\u0434\u044B \u0434\u0432\u0430) \u0438 \u0443\u043C\u0435\u0440
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 80 + 4 = **84 \u0433\u043E\u0434\u0430**. 
    ---  ### 3. \u041D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u043E\u0436\u043D\u043E
    \u0434\u043E\u0432\u0435\u0440\u044F\u0442\u044C \u044D\u0442\u043E\u0439 \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u0438? 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043A\u0440\u0430\u0441\u043E\u0442\u0443
    \u044D\u0442\u043E\u0439 \u0438\u0441\u0442\u043E\u0440\u0438\u0438, \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u0438 \u0444\u0438\u043B\u043E\u043B\u043E\u0433\u0438 \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F
    \u043A \u043D\u0435\u0439 \u043A\u0430\u043A \u043A **\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0430\u043D\u0435\u043A\u0434\u043E\u0442\u0443**, \u0430 \u043D\u0435 \u043A
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0444\u0430\u043A\u0442\u0443 \u043F\u043E \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u043C
    \u043F\u0440\u0438\u0447\u0438\u043D\u0430\u043C:  1.  **\u041E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0439:**
    \u041D\u0435\u0442 \u043D\u0438\u043A\u0430\u043A\u0438\u0445 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0431\u044B \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B\u0438,
    \u0447\u0442\u043E \u044D\u0442\u0430 \u043D\u0430\u0434\u043F\u0438\u0441\u044C
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u043D\u0430 \u043C\u043E\u0433\u0438\u043B\u0435
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438.
    \u0412\u043F\u0435\u0440\u0432\u044B\u0435 \u043E\u043D\u0430 \u043F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0435\u0440\u0435\u0437 200 \u0441
    \u043B\u0438\u0448\u043D\u0438\u043C \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435
    \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u0430\u0433\u0430\u0435\u043C\u043E\u0439
    \u0441\u043C\u0435\u0440\u0442\u0438. 2.  **\u0421\u043B\u0438\u0448\u043A\u043E\u043C
    \xAB\u043A\u0440\u0443\u0433\u043B\u044B\u0435\xBB \u0447\u0438\u0441\u043B\u0430:**
    \u0412\u043E\u0437\u0440\u0430\u0441\u0442 84 \u0433\u043E\u0434\u0430, \u0430
    \u0442\u0430\u043A\u0436\u0435 \u0432\u0441\u0435 \u044D\u0442\u0430\u043F\u044B
    (14, 7, 12, 5, 42, 4 \u0433\u043E\u0434\u0430) \u043F\u043E\u0434\u043E\u0431\u0440\u0430\u043D\u044B
    \u0442\u0430\u043A, \u0447\u0442\u043E\u0431\u044B \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E
    \u0440\u0435\u0448\u0438\u0442\u044C \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435.
    \u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438
    \u0434\u0430\u0442\u044B \u0432\u0440\u044F\u0434 \u043B\u0438 \u0431\u044B\u043B\u0438
    \u0431\u044B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043A\u0440\u0430\u0442\u043D\u044B
    \u0448\u0435\u0441\u0442\u0438, \u0441\u0435\u043C\u0438 \u0438 \u0434\u0432\u043E\u0439\u043A\u0435.
    \u0421\u043A\u043E\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043E, \u044D\u0442\u043E
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u0430\u044F \u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u0433\u0440\u0430, \u0433\u0434\u0435 \xAB\u0448\u0435\u0441\u0442\u0430\u044F
    \u0447\u0430\u0441\u0442\u044C\xBB, \xAB\u0441\u0435\u0434\u044C\u043C\u0430\u044F
    \u0447\u0430\u0441\u0442\u044C\xBB \u0438 \xAB\u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0430\xBB
    \u0431\u044B\u043B\u0438 \u0432\u044B\u0431\u0440\u0430\u043D\u044B \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u0434\u043B\u044F \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u043A\u0440\u0430\u0441\u0438\u0432\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0438,
    \u0430 \u0436\u0438\u0437\u043D\u044C \u0441\u0430\u043C\u043E\u0433\u043E \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u0431\u044B\u043B\u0430 \u043F\u0440\u043E\u0441\u0442\u043E \xAB\u043F\u043E\u0434\u043E\u0433\u043D\u0430\u043D\u0430\xBB
    \u043F\u043E\u0434 \u044D\u0442\u0438 \u0446\u0438\u0444\u0440\u044B. 3.  **\u041D\u0435\u0442
    \u0438\u043C\u0435\u043D:** \u0412 \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u0438
    \u043D\u0435\u0442 \u043D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E \u0438\u043C\u0435\u043D\u0438.
    \u041D\u0435 \u043D\u0430\u0437\u0432\u0430\u043D\u0430 \u0436\u0435\u043D\u0430,
    \u043D\u0435 \u043D\u0430\u0437\u0432\u0430\u043D \u0441\u044B\u043D. \u041C\u044B
    \u0434\u0430\u0436\u0435 \u043D\u0435 \u0437\u043D\u0430\u0435\u043C, \u043A\u0430\u043A
    \u0437\u0432\u0430\u043B\u0438 \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u0439
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u0438\u043B\u0438 \u0435\u0433\u043E
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432.  ---  ### 4. \u0415\u0441\u0442\u044C
    \u043B\u0438 \u0435\u0449\u0435 \u043A\u0430\u043A\u0438\u0435-\u043B\u0438\u0431\u043E
    \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F?  **\u0410\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E
    \u043D\u0438\u043A\u0430\u043A\u0438\u0445.**   - \u041C\u044B \u043D\u0435 \u0437\u043D\u0430\u0435\u043C,
    \u0431\u044B\u043B\u0430 \u043B\u0438 \u0443 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u044F (\u043A\u0440\u043E\u043C\u0435
    \u0437\u0430\u043D\u044F\u0442\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439)
    \u0438\u043B\u0438 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435. -
    \u041C\u044B \u043D\u0435 \u0437\u043D\u0430\u0435\u043C, \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u043B\u0438 \u043E\u043D \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u044B
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438. - \u041C\u044B
    \u043D\u0435 \u0437\u043D\u0430\u0435\u043C, \u0431\u044B\u043B \u043B\u0438
    \u043E\u043D \u0436\u0435\u043D\u0430\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0434\u0438\u043D \u0440\u0430\u0437 \u0438\u043B\u0438, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0435\u0433\u043E \xAB\u043F\u043E\u0434\u0440\u0443\u0433\u0430\xBB \u0432
    \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u0438 \u2014 \u044D\u0442\u043E \u043B\u0438\u0448\u044C
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u044B\u0439 \u043E\u0431\u043E\u0440\u043E\u0442,
    \u0430 \u043D\u0435 \u0440\u0435\u0430\u043B\u044C\u043D\u0430\u044F \u0441\u0443\u043F\u0440\u0443\u0433\u0430.
    - \u041C\u044B \u043D\u0435 \u0437\u043D\u0430\u0435\u043C, \u0431\u044B\u043B\u0438
    \u043B\u0438 \u0443 \u043D\u0435\u0433\u043E \u0434\u0440\u0443\u0433\u0438\u0435
    \u0434\u0435\u0442\u0438, \u043A\u0440\u043E\u043C\u0435 \u0443\u043C\u0435\u0440\u0448\u0435\u0433\u043E
    \u0441\u044B\u043D\u0430. - \u041C\u044B \u043D\u0435 \u0437\u043D\u0430\u0435\u043C,
    \u043A\u0430\u043A \u043E\u043D \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u043B,
    \u0447\u0435\u043C \u043F\u0438\u0442\u0430\u043B\u0441\u044F, \u0431\u043E\u043B\u0435\u043B
    \u043B\u0438 \u043E\u043D \u0438 \u043A\u0430\u043A \u0438\u043C\u0435\u043D\u043D\u043E
    \u0443\u043C\u0435\u0440.  ---  ### \u0418\u0442\u043E\u0433  \u0415\u0441\u043B\u0438
    \u043F\u043E\u0434\u0432\u043E\u0434\u0438\u0442\u044C \u0447\u0435\u0440\u0442\u0443,
    \u0442\u043E **\u0432\u0441\u044F \u043B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u0443\u043C\u0435\u0449\u0430\u0435\u0442\u0441\u044F
    \u0432 \u043E\u0434\u043D\u043E \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435**: *\xAB\u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u043B\u0435\u0433\u0435\u043D\u0434\u0435, \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u0432 33 \u0433\u043E\u0434\u0430, \u0432 38 \u043B\u0435\u0442 \u0441\u0442\u0430\u043B
    \u043E\u0442\u0446\u043E\u043C, \u0432 80 \u043B\u0435\u0442 \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u0441\u044B\u043D\u0430 \u0438 \u0443\u043C\u0435\u0440 \u0432 84 \u0433\u043E\u0434\u0430,
    \u043E\u043F\u043B\u0430\u043A\u0438\u0432\u0430\u044F \u0435\u0433\u043E\xBB*.  
    \u041E\u0434\u043D\u0430\u043A\u043E \u0434\u0430\u0436\u0435 \u044D\u0442\u0430
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F \u2014 \u043D\u0435
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0430\u043A\u0442, \u0430 \u0432\u0441\u0435\u0433\u043E \u043B\u0438\u0448\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u043E\u043B\u043E\u0432\u043E\u043B\u043E\u043C\u043A\u0430, \u043F\u0440\u0438\u043F\u0438\u0441\u0430\u043D\u043D\u0430\u044F
    \u0435\u043C\u0443 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u043C\u0438
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F\u043C\u0438. \u0412 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u043C\u044B \u0438\u043C\u0435\u0435\u043C \u0434\u0435\u043B\u043E \u0441 \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u0443\u043C\u043E\u0432
    \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u0438, \u043E \u0447\u0430\u0441\u0442\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043C\u044B \u043D\u0435 \u0437\u043D\u0430\u0435\u043C \u0440\u043E\u0432\u043D\u044B\u043C
    \u0441\u0447\u0435\u0442\u043E\u043C \u043D\u0438\u0447\u0435\u0433\u043E. \u0418\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u0430 \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u0441\u0447\u0438\u0442\u0430\u0442\u044C
    \u0435\u0433\u043E \u0444\u0438\u0433\u0443\u0440\u0443 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043C\u0438\u0444\u0438\u0447\u0435\u0441\u043A\u043E\u0439."
  personalLifeEn: 
  shortBioRu: "# \u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0438\u0439:
    \u041F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F 
    **\u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0438\u0439**
    (\u043E\u043A. III \u0432\u0435\u043A\u0430 \u043D. \u044D.) \u2014 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u0438, \u0447\u044C\u0438
    \u0438\u0434\u0435\u0438 \u043D\u0430 \u0432\u0435\u043A\u0430 \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438
    \u0441\u0432\u043E\u0451 \u0432\u0440\u0435\u043C\u044F. \u0415\u0433\u043E \u0447\u0430\u0441\u0442\u043E
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \xAB\u043E\u0442\u0446\u043E\u043C
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B\xBB, \u0438 \u043E\u043D \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u043F\u0440\u0435\u0436\u0434\u0435 \u0432\u0441\u0435\u0433\u043E \u043A\u0430\u043A
    \u0430\u0432\u0442\u043E\u0440 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430 \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430\xBB. 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442,
    **\u043E \u0441\u0430\u043C\u043E\u0439 \u0436\u0438\u0437\u043D\u0438 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043A\u0440\u0430\u0439\u043D\u0435
    \u043C\u0430\u043B\u043E** \u2014 \u043E\u043D\u0430 \u043E\u043A\u0443\u0442\u0430\u043D\u0430
    \u0442\u0430\u0439\u043D\u0430\u043C\u0438 \u0438 \u0434\u043E\u043C\u044B\u0441\u043B\u0430\u043C\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440
    \u0432\u044B\u0437\u044B\u0432\u0430\u044E\u0442 \u0441\u043F\u043E\u0440\u044B
    \u0441\u0440\u0435\u0434\u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432
    \u043D\u0430\u0443\u043A\u0438.  ---  ## I. \u0417\u0430\u0433\u0430\u0434\u043A\u0430
    \u0436\u0438\u0437\u043D\u0438: \u041A\u043E\u0433\u0434\u0430 \u0438 \u0433\u0434\u0435
    \u0436\u0438\u043B \u0414\u0438\u043E\u0444\u0430\u043D\u0442?  ### 1. \u041C\u0435\u0441\u0442\u043E
    \u0436\u0438\u0437\u043D\u0438 \u0414\u043E\u043F\u043E\u0434\u043B\u0438\u043D\u043D\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043B\u0438\u0448\u044C \u0442\u043E,
    \u0447\u0442\u043E \u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u0436\u0438\u043B
    \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438
    \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0439**. \u042D\u0442\u043E
    \u0431\u044B\u043B \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0439
    \u043D\u0430\u0443\u0447\u043D\u044B\u0439 \u0446\u0435\u043D\u0442\u0440 \u044D\u043B\u043B\u0438\u043D\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430, \u0433\u0434\u0435 \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0430\u0441\u044C
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0430\u044F
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0430. \u042D\u0442\u043E
    \u043C\u0435\u0441\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u0432\u043E \u0432\u0441\u0435\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445. 
    ### 2. \u0412\u0440\u0435\u043C\u044F \u0436\u0438\u0437\u043D\u0438: \"\u041F\u043B\u0430\u0432\u0430\u044E\u0449\u0438\u0435\"
    \u0434\u0430\u0442\u044B \u0422\u043E\u0447\u043D\u044B\u0435 \u0434\u0430\u0442\u044B
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0438 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u043C \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0435\u0439
    \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0438. \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u043C\u043E\u0433\u0443\u0442 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u043B\u0438\u0448\u044C \"\u0432\u0438\u043B\u043A\u0443\" \u0432 500 \u043B\u0435\u0442: 
    *   **\u041D\u0438\u0436\u043D\u044F\u044F \u0433\u0440\u0430\u043D\u0438\u0446\u0430
    (terminus post quem):** \u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u0432 \u0441\u0432\u043E\u0435\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 \xAB\u041E \u043C\u043D\u043E\u0433\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u043B\u0430\u0445\xBB \u0441\u0441\u044B\u043B\u0430\u0435\u0442\u0441\u044F
    \u043D\u0430 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    **\u0413\u0438\u043F\u0441\u0438\u043A\u043B\u0430**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0436\u0438\u043B \u0432 **\u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0435
    II \u0432\u0435\u043A\u0430 \u0434\u043E \u043D. \u044D.**. \u0417\u043D\u0430\u0447\u0438\u0442,
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u0436\u0438\u043B \u043F\u043E\u0437\u0436\u0435.
    *   **\u0412\u0435\u0440\u0445\u043D\u044F\u044F \u0433\u0440\u0430\u043D\u0438\u0446\u0430
    (terminus ante quem):** \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    **\u0422\u0435\u043E\u043D \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0438\u0439**
    (\u043E\u0442\u0435\u0446 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \u0413\u0438\u043F\u0430\u0442\u0438\u0438), \u0436\u0438\u0432\u0448\u0438\u0439
    \u0432 **\u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0435 IV \u0432\u0435\u043A\u0430
    \u043D. \u044D.**, \u0446\u0438\u0442\u0438\u0440\u0443\u0435\u0442 \u0432 \u0441\u0432\u043E\u0438\u0445
    \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u044F\u0445 \u043E\u0442\u0440\u044B\u0432\u043A\u0438
    \u0438\u0437 \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\xBB
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430. \u0417\u043D\u0430\u0447\u0438\u0442,
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u0436\u0438\u043B \u0440\u0430\u043D\u044C\u0448\u0435. 
    \u0414\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432 \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u043E
    \u0436\u0438\u0437\u043D\u044C \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u043A **\u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0435 III \u0432\u0435\u043A\u0430
    \u043D. \u044D. (\u043E\u043A. 250 \u0433.)**. \u042D\u0442\u043E\u0442 \u0432\u044B\u0432\u043E\u0434
    \u043E\u0441\u043D\u043E\u0432\u044B\u0432\u0430\u043B\u0441\u044F \u043D\u0430
    \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0438,
    \u0447\u0442\u043E \u0443\u043F\u043E\u043C\u044F\u043D\u0443\u0442\u044B\u0439
    \u0432 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0438\u0438 \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\xBB
    \xAB\u0434\u043E\u0441\u0442\u043E\u043F\u043E\u0447\u0442\u0435\u043D\u043D\u044B\u0439
    \u0414\u0438\u043E\u043D\u0438\u0441\u0438\u0439\xBB \u2014 \u044D\u0442\u043E
    \u0414\u0438\u043E\u043D\u0438\u0441\u0438\u0439 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0438\u0439,
    \u0435\u043F\u0438\u0441\u043A\u043E\u043F, \u0436\u0438\u0432\u0448\u0438\u0439
    \u0438\u043C\u0435\u043D\u043D\u043E \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F. 
    \u041E\u0434\u043D\u0430\u043A\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F, \u0432
    \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0423. \u041A\u043D\u043E\u0440\u0440\u0430, \u0441\u0442\u0430\u0432\u044F\u0442
    \u044D\u0442\u0443 \u0434\u0430\u0442\u0438\u0440\u043E\u0432\u043A\u0443 \u043F\u043E\u0434
    \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u0435. \u041E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0435\u0441\u0442\u044C \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u043F\u043E\u043B\u0430\u0433\u0430\u0442\u044C, \u0447\u0442\u043E \u0414\u0438\u043E\u0444\u0430\u043D\u0442
    \u043C\u043E\u0433 \u0436\u0438\u0442\u044C **\u0440\u0430\u043D\u044C\u0448\u0435,
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0434\u0430\u0436\u0435 \u0432
    I \u0432\u0435\u043A\u0435 \u043D. \u044D.**. \u0422\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0440\u0430\u0437\u0431\u0440\u043E\u0441
    \u0434\u0430\u0442 \u0432 \u0440\u0430\u0437\u043D\u044B\u0445 \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u044F\u0445
    \u043E\u0447\u0435\u043D\u044C \u0432\u0435\u043B\u0438\u043A: \u043E\u0442 **\u043E\u043A.
    200 \u0433.** \u0434\u043E **409 \u0433. \u043D. \u044D.**.  ---  ## II. \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \"\u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\":
    \u042D\u043F\u0438\u0442\u0430\u0444\u0438\u044F \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 
    \u041F\u043E\u0447\u0442\u0438 \u0432\u0441\u0435, \u0447\u0442\u043E \"\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\"
    \u043E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430,
    \u0432\u0437\u044F\u0442\u043E \u0438\u0437 \u043E\u0434\u043D\u043E\u0439 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0438, \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432\u0448\u0435\u0439\u0441\u044F
    \u0432 \xAB\u041F\u0430\u043B\u0430\u0442\u0438\u043D\u0441\u043A\u043E\u0439
    \u0430\u043D\u0442\u043E\u043B\u043E\u0433\u0438\u0438\xBB \u2014 \u0441\u0431\u043E\u0440\u043D\u0438\u043A\u0435
    \u0434\u0440\u0435\u0432\u043D\u0435\u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0445
    \u044D\u043F\u0438\u0433\u0440\u0430\u043C\u043C, \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u043C
    \u043E\u043A\u043E\u043B\u043E 500 \u0433\u043E\u0434\u0430 \u043D. \u044D.. 
    \u041D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u0431\u044B\u043B\u0430
    \u043B\u0438 \u044D\u0442\u0430 \u043D\u0430\u0434\u043F\u0438\u0441\u044C \u043D\u0430
    \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435 \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u0430
    \u043D\u0430 \u0435\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u044C\u043D\u043E\u043C
    \u043A\u0430\u043C\u043D\u0435, \u0438\u043B\u0438 \u0436\u0435 \u044D\u0442\u043E
    \u043F\u0440\u043E\u0441\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0437\u0430\u0434\u0430\u0447\u0430, \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043D\u043D\u0430\u044F
    \u043F\u043E\u0437\u0436\u0435. \u0422\u0435\u043C \u043D\u0435 \u043C\u0435\u043D\u0435\u0435,
    \u043E\u043D\u0430 \u0434\u0430\u0435\u0442 \u043D\u0430\u043C \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0435
    \u0446\u0438\u0444\u0440\u044B:  > \xAB\u041F\u0440\u0430\u0445 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u0433\u0440\u043E\u0431\u043D\u0438\u0446\u0430 \u043F\u043E\u043A\u043E\u0438\u0442;
    \u0434\u0438\u0432\u0438\u0441\u044C \u0435\u0439 \u2014 \u0438 \u043A\u0430\u043C\u0435\u043D\u044C
    \u041C\u0443\u0434\u0440\u044B\u043C \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E\u043C
    \u0435\u0433\u043E \u0441\u043A\u0430\u0436\u0435\u0442 \u0443\u0441\u043E\u043F\u0448\u0435\u0433\u043E
    \u0432\u0435\u043A. \u0412\u043E\u043B\u0435\u0439 \u0431\u043E\u0433\u043E\u0432
    \u0448\u0435\u0441\u0442\u0443\u044E \u0447\u0430\u0441\u0442\u044C \u0436\u0438\u0437\u043D\u0438
    \u043E\u043D \u043F\u0440\u043E\u0436\u0438\u043B \u0440\u0435\u0431\u0451\u043D\u043A\u043E\u043C.
    \u0418 \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443 \u0448\u0435\u0441\u0442\u043E\u0439
    \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B \u0441 \u043F\u0443\u0448\u043A\u043E\u043C
    \u043D\u0430 \u0449\u0435\u043A\u0430\u0445. \u0422\u043E\u043B\u044C\u043A\u043E
    \u043C\u0438\u043D\u0443\u043B\u0430 \u0441\u0435\u0434\u044C\u043C\u0430\u044F,
    \u0441 \u043F\u043E\u0434\u0440\u0443\u0433\u043E\u0439 \u043E\u043D \u043E\u0431\u0440\u0443\u0447\u0438\u043B\u0441\u044F.
    \u0421 \u043D\u0435\u044E, \u043F\u044F\u0442\u044C \u043B\u0435\u0442 \u043F\u0440\u043E\u0432\u0435\u0434\u044F,
    \u0441\u044B\u043D\u0430 \u0434\u043E\u0436\u0434\u0430\u043B\u0441\u044F \u043C\u0443\u0434\u0440\u0435\u0446;
    \u0422\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u043B\u0436\u0438\u0437\u043D\u0438
    \u043E\u0442\u0446\u043E\u0432\u0441\u043A\u043E\u0439 \u0432\u043E\u0437\u043B\u044E\u0431\u043B\u0435\u043D\u043D\u044B\u0439
    \u0441\u044B\u043D \u0435\u0433\u043E \u043F\u0440\u043E\u0436\u0438\u043B. \u041E\u0442\u043D\u044F\u0442
    \u043E\u043D \u0431\u044B\u043B \u0443 \u043E\u0442\u0446\u0430 \u0440\u0430\u043D\u043D\u0435\u0439
    \u043C\u043E\u0433\u0438\u043B\u043E\u0439 \u0441\u0432\u043E\u0435\u0439. \u0414\u0432\u0430\u0436\u0434\u044B
    \u0434\u0432\u0430 \u0433\u043E\u0434\u0430 \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u044C
    \u043E\u043F\u043B\u0430\u043A\u0438\u0432\u0430\u043B \u0442\u044F\u0436\u043A\u043E\u0435
    \u0433\u043E\u0440\u0435, \u0422\u0443\u0442 \u0438 \u0443\u0432\u0438\u0434\u0435\u043B
    \u043F\u0440\u0435\u0434\u0435\u043B \u0436\u0438\u0437\u043D\u0438 \u043F\u0435\u0447\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0432\u043E\u0435\u0439\xBB.  \u0415\u0441\u043B\u0438 \u0440\u0435\u0448\u0438\u0442\u044C
    \u044D\u0442\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435, \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E **\u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u043F\u0440\u043E\u0436\u0438\u043B
    84 \u0433\u043E\u0434\u0430**.  \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C,
    \u0438\u0437 \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u0438 \u043C\u044B \u043C\u043E\u0436\u0435\u043C
    \"\u0443\u0437\u043D\u0430\u0442\u044C\" \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044E
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438: *   **\u0414\u0435\u0442\u0441\u0442\u0432\u043E:**
    \u0434\u043E 14 \u043B\u0435\u0442 (1/6 \u043E\u0442 84). *   **\u042E\u043D\u043E\u0441\u0442\u044C
    (\u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u0435 \u0431\u043E\u0440\u043E\u0434\u044B):**
    \u0434\u043E 21 \u0433\u043E\u0434\u0430 (\u0435\u0449\u0435 1/12 \u0436\u0438\u0437\u043D\u0438).
    *   **\u0416\u0435\u043D\u0438\u0442\u044C\u0431\u0430:** \u0432 33 \u0433\u043E\u0434\u0430
    (\u0435\u0449\u0435 1/7 \u0436\u0438\u0437\u043D\u0438, \u0442.\u0435. +12 \u043B\u0435\u0442).
    *   **\u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0441\u044B\u043D\u0430:**
    \u0432 38 \u043B\u0435\u0442 (\u0447\u0435\u0440\u0435\u0437 5 \u043B\u0435\u0442
    \u043F\u043E\u0441\u043B\u0435 \u0436\u0435\u043D\u0438\u0442\u044C\u0431\u044B).
    *   **\u0421\u043C\u0435\u0440\u0442\u044C \u0441\u044B\u043D\u0430:** \u0441\u044B\u043D
    \u043F\u0440\u043E\u0436\u0438\u043B \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443
    \u0436\u0438\u0437\u043D\u0438 \u043E\u0442\u0446\u0430, \u0442.\u0435. 42 \u0433\u043E\u0434\u0430,
    \u0438 \u0443\u043C\u0435\u0440, \u043A\u043E\u0433\u0434\u0430 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0443
    \u0431\u044B\u043B\u043E 80 \u043B\u0435\u0442. *   **\u0421\u043C\u0435\u0440\u0442\u044C
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430:** \u0447\u0435\u0440\u0435\u0437
    4 \u0433\u043E\u0434\u0430 \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0441\u044B\u043D\u0430, \u0432 84 \u0433\u043E\u0434\u0430.  ---  ## III. \u041D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  \u0418\u043C\u0435\u043D\u043D\u043E
    \u0442\u0440\u0443\u0434\u044B, \u0430 \u043D\u0435 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F,
    \u0441\u0434\u0435\u043B\u0430\u043B\u0438 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430
    \u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u043C.  ### 1. \u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434: \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430\xBB
    (\u1F08\u03C1\u03B9\u03B8\u03BC\u03B7\u03C4\u03B9\u03BA\u03AC) \u042D\u0442\u043E
    \u043D\u0435 \u0443\u0447\u0435\u0431\u043D\u0438\u043A \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438
    \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C \u0441\u043C\u044B\u0441\u043B\u0435,
    \u0430 \u0441\u0431\u043E\u0440\u043D\u0438\u043A \u0438\u0437 \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E
    **260 \u0437\u0430\u0434\u0430\u0447** \u0441 \u0440\u0435\u0448\u0435\u043D\u0438\u044F\u043C\u0438. 
    *   **\u0421\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430:** \u0418\u0437\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u0442\u0440\u0443\u0434 \u0441\u043E\u0441\u0442\u043E\u044F\u043B \u0438\u0437
    **13 \u043A\u043D\u0438\u0433**. \u0414\u043E \u043D\u0430\u0441 \u0434\u043E\u0448\u043B\u0438
    \u043D\u0435 \u0432\u0441\u0435: 6 \u043A\u043D\u0438\u0433 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0441\u044C
    \u043D\u0430 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u043C \u044F\u0437\u044B\u043A\u0435,
    \u0430 \u0435\u0449\u0435 4 (\u043A\u043D\u0438\u0433\u0438 IV\u2013VII) \u0431\u044B\u043B\u0438
    \u043D\u0430\u0439\u0434\u0435\u043D\u044B \u0432 \u0430\u0440\u0430\u0431\u0441\u043A\u043E\u043C
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0435 \u0432 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0435
    \u041C\u0435\u0448\u0445\u0435\u0434\u0430 (\u0418\u0440\u0430\u043D) \u0432
    1968 \u0433\u043E\u0434\u0443. *   **\u0413\u043B\u0430\u0432\u043D\u0430\u044F
    \u0438\u0434\u0435\u044F:** \u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u0438\u0441\u043A\u0430\u043B
    **\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u044F**
    (\u0442.\u0435. \u0446\u0435\u043B\u044B\u0435 \u0438 \u0434\u0440\u043E\u0431\u043D\u044B\u0435)
    \u0434\u043B\u044F \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u0435\u0433\u043E
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0438 \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0446\u0435\u043B\u044B\u0435 \u0447\u0438\u0441\u043B\u0430.
    \u041E\u043D \u043F\u0435\u0440\u0432\u044B\u043C \u0432 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u0438
    \u0441\u0442\u0430\u043B \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0442\u044C
    \u0434\u0440\u043E\u0431\u0438 \u043D\u0430\u0440\u0430\u0432\u043D\u0435 \u0441
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u043C\u0438 \u0447\u0438\u0441\u043B\u0430\u043C\u0438. 
    ### 2. \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F \u0432 \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u043A\u0435
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432, \u0432\u0432\u0435\u0434\u044F \u0440\u0430\u0437\u0432\u0438\u0442\u0443\u044E
    \u0431\u0443\u043A\u0432\u0435\u043D\u043D\u0443\u044E \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u043A\u0443.
    \u0414\u043E \u043D\u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u044B\u043A\u043B\u0430\u0434\u043A\u0438 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438\u0441\u044C
    \u0441\u043B\u043E\u0432\u0430\u043C\u0438. \u041E\u043D \u0436\u0435 \u0441\u0442\u0430\u043B
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0441\u043E\u043A\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u0434\u043B\u044F \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    (\u03B6), \u0435\u0433\u043E \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430,
    \u043A\u0443\u0431\u0430 \u0438 \u0434\u0440\u0443\u0433\u0438\u0445 \u0441\u0442\u0435\u043F\u0435\u043D\u0435\u0439,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0434\u043B\u044F \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
    \u0432\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u044F. \u042D\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B\u043E
    \u0435\u0433\u043E \u0437\u0430\u043F\u0438\u0441\u0438 \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u044B\u043C\u0438
    \u0438 \u043F\u0440\u0438\u0431\u043B\u0438\u0437\u0438\u043B\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0443
    \u043A \u0442\u043E\u043C\u0443 \u0432\u0438\u0434\u0443, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043C\u044B \u0435\u0435 \u0437\u043D\u0430\u0435\u043C \u0441\u0435\u0439\u0447\u0430\u0441. 
    ### 3. \u0414\u0440\u0443\u0433\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    \u041E\u0442 \u0434\u0440\u0443\u0433\u0438\u0445 \u0435\u0433\u043E \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0441\u044C \u043B\u0438\u0448\u044C
    \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u044B: *   **\xAB\u041E \u043C\u043D\u043E\u0433\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u043B\u0430\u0445\xBB** \u2014 \u0442\u0440\u0430\u043A\u0442\u0430\u0442,
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044E\u0449\u0438\u0439 \u0438\u0434\u0435\u0438
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430. *   **\xAB\u041F\u043E\u0440\u0438\u0437\u043C\u044B\xBB**
    \u2014 \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E \u0446\u0438\u0442\u0430\u0442\u0430\u043C \u0432 \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0435\xBB. 
    ---  ## IV. \u0412\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u043C\u0438\u0440\u043E\u0432\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443  *   **\u0410\u0440\u0430\u0431\u0441\u043A\u0438\u0439
    \u043C\u0438\u0440:** \u0412 X \u0432\u0435\u043A\u0435 \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430\xBB
    \u0431\u044B\u043B\u0430 \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043D\u0430
    \u043D\u0430 \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0439 \u044F\u0437\u044B\u043A
    \u0438 \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0430 \u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0438\u0441\u043B\u0430\u043C\u0441\u043A\u043E\u0433\u043E \u043C\u0438\u0440\u0430.
    *   **\u0415\u0432\u0440\u043E\u043F\u0430 \u041D\u043E\u0432\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438:** \u0412 1575 \u0433\u043E\u0434\u0443
    \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u043F\u0435\u0440\u0432\u044B\u0439
    \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u0438\u0439 \u043F\u0435\u0440\u0435\u0432\u043E\u0434,
    \u0430 \u0432 1621 \u0433\u043E\u0434\u0443 \u2014 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434 \u0411\u0430\u0448\u0435 \u0434\u0435
    \u041C\u0435\u0437\u0438\u0440\u0438\u0430\u043A\u0430. \u0418\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u043E\u0442 \u044D\u043A\u0437\u0435\u043C\u043F\u043B\u044F\u0440
    \u0441\u0442\u0430\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u043C
    \u043D\u0430 \u0432\u0435\u0441\u044C \u043C\u0438\u0440: \u043D\u0430 \u0435\u0433\u043E
    \u043F\u043E\u043B\u044F\u0445 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A **\u041F\u044C\u0435\u0440
    \u0424\u0435\u0440\u043C\u0430** \u0437\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0412\u0435\u043B\u0438\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443, \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044F,
    \u0447\u0442\u043E \u043D\u0430\u0448\u0435\u043B \"\u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\".
    *   **\u0418\u043C\u044F \u0432 \u0432\u0435\u043A\u0430\u0445:** \u0412 \u0447\u0435\u0441\u0442\u044C
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u043D\u0430\u0437\u0432\u0430\u043D
    \u0446\u0435\u043B\u044B\u0439 \u0440\u0430\u0437\u0434\u0435\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u2014 **\u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F**
    (\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0432 \u0446\u0435\u043B\u044B\u0445
    \u0447\u0438\u0441\u043B\u0430\u0445). \u0415\u0433\u043E \u0438\u0434\u0435\u0438
    \u043B\u0435\u0433\u043B\u0438 \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0440\u0430\u0431\u043E\u0442
    \u042D\u0439\u043B\u0435\u0440\u0430, \u0413\u0430\u0443\u0441\u0441\u0430, \u042F\u043A\u043E\u0431\u0438
    \u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435.  ---  ## \u041A\u0440\u0430\u0442\u043A\u0438\u0435
