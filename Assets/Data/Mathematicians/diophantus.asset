    \u0448\u0435\u0441\u0442\u0443\u044E \u0447\u0430\u0441\u0442\u044C \u0436\u0438\u0437\u043D\u0438
    \u043E\u043D \u043F\u0440\u043E\u0436\u0438\u043B \u0440\u0435\u0431\u0451\u043D\u043A\u043E\u043C.*
    > *\u0418 \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443 \u0448\u0435\u0441\u0442\u043E\u0439
