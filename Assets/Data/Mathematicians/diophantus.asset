    \u043A\u0430\u043A \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442 \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044F
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438, \u0435\u0441\u043B\u0438 \u0432\u0435\u0440\u0438\u0442\u044C
    \u044D\u0442\u043E\u0439 \u043D\u0430\u0434\u043F\u0438\u0441\u0438:  *   **\u0414\u0435\u0442\u0441\u0442\u0432\u043E:**
    \u0434\u043E 14 \u043B\u0435\u0442. *   **\u042E\u043D\u043E\u0441\u0442\u044C
    (\u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u0435 \u0431\u043E\u0440\u043E\u0434\u044B):**
    \u0434\u043E 21 \u0433\u043E\u0434\u0430. *   **\u0416\u0435\u043D\u0438\u0442\u044C\u0431\u0430:**
    \u0432 33 \u0433\u043E\u0434\u0430. *   **\u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0441\u044B\u043D\u0430:** \u0432 38 \u043B\u0435\u0442. *   **\u0421\u043C\u0435\u0440\u0442\u044C
    \u0441\u044B\u043D\u0430:** \u0432 42 \u0433\u043E\u0434\u0430 (\u043A\u043E\u0433\u0434\u0430
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0443 \u0431\u044B\u043B\u043E 80
    \u043B\u0435\u0442). *   **\u0421\u043C\u0435\u0440\u0442\u044C \u0441\u0430\u043C\u043E\u0433\u043E
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430:** \u0432 84 \u0433\u043E\u0434\u0430. 
    ### \U0001F48E \"\u041E\u0442\u0435\u0446 \u0430\u043B\u0433\u0435\u0431\u0440\u044B\"
    \u0438 \u0435\u0433\u043E \u044F\u0437\u044B\u043A  \u0414\u0438\u043E\u0444\u0430\u043D\u0442
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0443\u044E
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u041E\u043D \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u0432 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u043C \u043C\u0438\u0440\u0435
    \u043D\u0430\u0447\u0430\u043B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
    **\u0440\u0430\u0437\u0432\u0438\u0442\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u043A\u0443**, \u0438\u0437\u0431\u0430\u0432\u0438\u0432\u0448\u0438\u0441\u044C
    \u043E\u0442 \u0433\u0440\u043E\u043C\u043E\u0437\u0434\u043A\u0438\u0445 \u0441\u043B\u043E\u0432\u0435\u0441\u043D\u044B\u0445
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0439. \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0432 \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u043E\u043C \u0432\u0438\u0434\u0435. 
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043E\u043D \u0432\u0432\u0435\u043B
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u0437\u043D\u0430\u043A\u0438
    \u0434\u043B\u044F \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    (`\u03C2`), \u0435\u0433\u043E \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430
    (`\u0394\u03A5`) \u0438 \u043A\u0443\u0431\u0430 (`\u039A\u03A5`). \u042D\u0442\u043E
    \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439 \u043F\u0440\u043E\u0440\u044B\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430.  ### \U0001F3AF \"\u0414\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\": \u0433\u043E\u043D\u043A\u0430
    \u0447\u0435\u0440\u0435\u0437 \u0432\u0435\u043A\u0430  \u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u2014
    \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430\xBB. \u042D\u0442\u043E
    \u0441\u0431\u043E\u0440\u043D\u0438\u043A \u0437\u0430\u0434\u0430\u0447 (\u0432
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432\u0448\u0438\u0445\u0441\u044F
    \u043A\u043D\u0438\u0433\u0430\u0445 \u0438\u0445 **189**), \u0440\u0435\u0448\u0430\u044F
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043D \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
    \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u044B\u0435 \u043C\u0435\u0442\u043E\u0434\u044B
    \u043F\u043E\u0438\u0441\u043A\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u0439
    \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. \u0421\u0435\u0433\u043E\u0434\u043D\u044F
    \u0442\u0430\u043A\u0438\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F,
    \u0433\u0434\u0435 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435
    \u2014 \u0446\u0435\u043B\u044B\u0435 \u0447\u0438\u0441\u043B\u0430, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B
    \u043A\u0430\u043A \xAB\u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\xBB.  \u041D\u043E \u043D\u0430
    \u044D\u0442\u043E\u043C \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043D\u0435
    \u0437\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0441 \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u043E\u0439\xBB
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441\u0430\u043C\u0430\u044F \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0434\u0440\u0430\u043C\u0430 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438.
    \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    **\u041F\u044C\u0435\u0440 \u0424\u0435\u0440\u043C\u0430**, \u0447\u0438\u0442\u0430\u044F
    \u0438\u0437\u0434\u0430\u043D\u0438\u0435 \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430,
    \u043D\u0430 \u043F\u043E\u043B\u044F\u0445 \u043A\u043D\u0438\u0433\u0438 \u0437\u0430\u043F\u0438\u0441\u0430\u043B
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435, \u0447\u0442\u043E
    \u0434\u043B\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F `x\u207F
    + y\u207F = z\u207F` \u043F\u0440\u0438 `n>2` \u043D\u0435\u0442 \u0446\u0435\u043B\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439. \u0420\u044F\u0434\u043E\u043C \u043E\u043D
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0444\u0440\u0430\u0437\u0443, \u0447\u0442\u043E \u043D\u0430\u0448\u0451\u043B
    \xAB\u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435 \u0447\u0443\u0434\u0435\u0441\u043D\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\xBB,
    \u043D\u043E \u043F\u043E\u043B\u044F \u043A\u043D\u0438\u0433\u0438 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0443\u0437\u043A\u0438, \u0447\u0442\u043E\u0431\u044B \u0435\u0433\u043E \u0432\u043C\u0435\u0441\u0442\u0438\u0442\u044C.
    \u042D\u0442\u0430 \u0437\u0430\u043C\u0435\u0442\u043A\u0430 \u0441\u0442\u0430\u043B\u0430
    \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439 **\u0412\u0435\u043B\u0438\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0424\u0435\u0440\u043C\u0430**,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0438 \u0431\u043E\u043B\u0435\u0435
    350 \u043B\u0435\u0442!  ### \U0001F30D \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0432 \u043A\u043E\u0441\u043C\u043E\u0441\u0435 \u0438 \u043D\u0430\u0443\u043A\u0435 
    \u0412\u043B\u0438\u044F\u043D\u0438\u0435 \u0438 \u0441\u043B\u0430\u0432\u0430
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u043F\u0435\u0440\u0435\u0448\u0430\u0433\u043D\u0443\u043B\u0438
    \u0447\u0435\u0440\u0435\u0437 \u0442\u044B\u0441\u044F\u0447\u0435\u043B\u0435\u0442\u0438\u044F,
    \u0438 \u0432 \u043F\u0430\u043C\u044F\u0442\u044C \u043E \u043D\u0435\u043C
    \u043D\u0430\u0437\u0432\u0430\u043D:  *   **\u041A\u0440\u0430\u0442\u0435\u0440
    \u043D\u0430 \u041B\u0443\u043D\u0435** \u2014 \u043D\u0430 \u0432\u0438\u0434\u0438\u043C\u043E\u0439
    \u0441\u0442\u043E\u0440\u043E\u043D\u0435 \u043D\u0430\u0448\u0435\u0433\u043E
    \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430 \u0435\u0441\u0442\u044C \u043A\u0440\u0430\u0442\u0435\u0440,
    \u043D\u043E\u0441\u044F\u0449\u0438\u0439 \u0435\u0433\u043E \u0438\u043C\u044F
    (Diophantus). *   **\u0426\u0435\u043B\u044B\u0439 \u0440\u0430\u0437\u0434\u0435\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438** \u2014 \u0442\u0435\u043E\u0440\u0438\u044F
    **\u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439**
    \u0438 **\u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432 \u0430\u043D\u0430\u043B\u0438\u0437**
    \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C\u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B.  \u0412\u0441\u0451
    \u044D\u0442\u043E \u0434\u0435\u043B\u0430\u0435\u0442 \u0444\u0438\u0433\u0443\u0440\u0443
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F \u0443\u0447\u0435\u043D\u044B\u043C,
    \u043D\u043E \u0438 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439 \u043B\u0435\u0433\u0435\u043D\u0434\u043E\u0439,
    \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C \u0438 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0434\u0430\u043B\u0438 \u043F\u0438\u0449\u0443 \u0434\u043B\u044F \u0443\u043C\u0430
    \u0438 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0435\u043D\u0438\u0435 \u043D\u0430
    \u0432\u0435\u043A\u0430 \u0432\u043F\u0435\u0440\u0435\u0434."
