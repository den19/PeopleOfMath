  achievementsRu: "\u0415\u0441\u043B\u0438 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u0413\u0435\u043E\u0440\u0433\u0430 \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    \u2014 \u044D\u0442\u043E \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F \u0433\u0435\u043D\u0438\u044F,
    \u0442\u043E \u0435\u0433\u043E **\u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0438 \u0432\u043A\u043B\u0430\u0434 \u0432 \u043D\u0430\u0443\u043A\u0443**
    \u2014 \u044D\u0442\u043E \u043F\u043E\u0434\u043B\u0438\u043D\u043D\u0430\u044F
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F, \u0441\u0440\u0430\u0432\u043D\u0438\u043C\u0430\u044F
    \u0441 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435\u043C \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438\u043B\u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u041A\u0430\u043D\u0442\u043E\u0440 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B \u043D\u043E\u0432\u044B\u0439
    \u0440\u0430\u0437\u0434\u0435\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438;
    \u043E\u043D \u0438\u0437\u043C\u0435\u043D\u0438\u043B \u0441\u0430\u043C\u043E
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u0442\u0430\u043A\u043E\u0435
    **\u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C**,
    \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0432 \u0435\u0451 \u0438\u0437
    \u0442\u0443\u043C\u0430\u043D\u043D\u043E\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0433\u043E
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F \u0432 \u0441\u0442\u0440\u043E\u0433\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043E\u0431\u044A\u0435\u043A\u0442.  \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D
    \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439
    \u0440\u0430\u0437\u0431\u043E\u0440 \u0435\u0433\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439, \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0445
    \u0432 \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E-\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043F\u043E\u0440\u044F\u0434\u043A\u0435.  ### 1. \u0421\u0442\u0440\u043E\u0433\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 (1870\u20131872) \u0414\u043E \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043E\u043F\u0435\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0447\u0438\u0441\u043B\u0430\u043C\u0438 (\\( \\sqrt{2}, \\pi, e \\)), \u043D\u043E
    \u043D\u0435 \u0438\u043C\u0435\u043B\u0438 \u0438\u0445 \u0441\u0442\u0440\u043E\u0433\u043E\u0433\u043E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F. \u0412 \u0441\u0432\u043E\u0435\u0439
    \u0440\u0430\u043D\u043D\u0435\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 **\u041A\u0430\u043D\u0442\u043E\u0440
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0442\u0435\u043E\u0440\u0438\u044E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0435\u0439**.
    *   **\u0421\u0443\u0442\u044C**: \u041E\u043D \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B
    \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435 \u0447\u0438\u0441\u043B\u043E
    \u043A\u0430\u043A \u043F\u0440\u0435\u0434\u0435\u043B \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \xAB\u0441\u0442\u044F\u0433\u0438\u0432\u0430\u044E\u0442\u0441\u044F\xBB
    \u0434\u0440\u0443\u0433 \u043A \u0434\u0440\u0443\u0433\u0443 (\u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u041A\u043E\u0448\u0438). *   **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435**:
    \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0443 \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u043D\u0430 \u043F\u0440\u043E\u0447\u043D\u043E\u043C
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0435,
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E \u043E\u0442 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    (\u043A\u0430\u043A \u0443 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430).
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u043F\u0435\u0440\u0432\u043E\u0435
    \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u043E\u0435 \u0432\u0442\u043E\u0440\u0436\u0435\u043D\u0438\u0435
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u0432 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430.  ---  ### 2. \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    \u0438 \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \xAB\u041C\u043E\u0449\u043D\u043E\u0441\u0442\u0438\xBB
    (1874) \u042D\u0442\u043E \u2014 \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u043F\u0440\u043E\u0440\u044B\u0432
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430. \u041E\u043D \u0432\u0432\u0451\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\u043C\u043E\u0449\u043D\u043E\u0441\u0442\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430** \u043A\u0430\u043A \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F \xAB\u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432\xBB \u043D\u0430 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430. \u0414\u0432\u0430 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0438\u043C\u0435\u044E\u0442 \u0440\u0430\u0432\u043D\u0443\u044E \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C,
    \u0435\u0441\u043B\u0438 \u043C\u0435\u0436\u0434\u0443 \u043D\u0438\u043C\u0438
    \u043C\u043E\u0436\u043D\u043E \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u0432\u0437\u0430\u0438\u043C\u043D\u043E-\u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E\u0435
    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435 (\u0431\u0438\u0435\u043A\u0446\u0438\u044E). 
    *   **\u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    1874 \u0433\u043E\u0434\u0430**: \u041A\u0430\u043D\u0442\u043E\u0440 \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0432\u0441\u0435\u0445
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B (\u043A\u043E\u0440\u043D\u0435\u0439 \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432
    \u0441 \u0446\u0435\u043B\u044B\u043C\u0438 \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u0430\u043C\u0438)
    \u0441\u0447\u0451\u0442\u043D\u043E, \u0430 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0432\u0441\u0435\u0445 \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u2014 **\u043D\u0435\u0441\u0447\u0451\u0442\u043D\u043E**.
    *   **\u041C\u0435\u0442\u043E\u0434 \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438
    (1891)**: \u041F\u043E\u0437\u0436\u0435 \u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u043F\u0440\u043E\u0441\u0442\u043E\u0439
    \u043C\u0435\u0442\u043E\u0434 \xAB\u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0430\xBB, \u0447\u0442\u043E\u0431\u044B
    \u043D\u0430\u0433\u043B\u044F\u0434\u043D\u043E \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
    \u0447\u0442\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0432\u0441\u0435\u0445
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445 \u0434\u0432\u043E\u0438\u0447\u043D\u044B\u0445
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0435\u0439
    (\u0430 \u0437\u043D\u0430\u0447\u0438\u0442, \u0438 \u0442\u043E\u0447\u0435\u043A
    \u043E\u0442\u0440\u0435\u0437\u043A\u0430) \u043D\u0435\u043B\u044C\u0437\u044F
    \u043F\u0435\u0440\u0435\u0441\u0447\u0438\u0442\u0430\u0442\u044C \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0447\u0438\u0441\u043B\u0430\u043C\u0438. \u042D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434
    \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043C\u043E\u0449\u043D\u0435\u0439\u0448\u0438\u0445
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432 \u043B\u043E\u0433\u0438\u043A\u0438
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432. 
    ---  ### 3. \u0418\u0435\u0440\u0430\u0440\u0445\u0438\u044F \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0435\u0439:
    \u0422\u0440\u0430\u043D\u0441\u0444\u0438\u043D\u0438\u0442\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430 (\u0410\u043B\u0435\u0444-\u043D\u0443\u043B\u044C
    \u0438 \u0434\u0430\u043B\u0435\u0435) \u041A\u0430\u043D\u0442\u043E\u0440 \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438
    \u0431\u044B\u0432\u0430\u044E\u0442 \u0440\u0430\u0437\u043D\u044B\u0445 \xAB\u0440\u0430\u0437\u043C\u0435\u0440\u043E\u0432\xBB
    (\u043C\u043E\u0449\u043D\u043E\u0441\u0442\u0435\u0439).  *   **\u0421\u0447\u0451\u0442\u043D\u0430\u044F
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C**:
    \u041C\u043E\u0449\u043D\u043E\u0441\u0442\u044C \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0440\u044F\u0434\u0430 (\\( \\mathbb{N} \\)) \u043E\u043D \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0438\u043B
    \u043A\u0430\u043A \\( \\aleph_0 \\) (\xAB\u0430\u043B\u0435\u0444-\u043D\u0443\u043B\u044C\xBB,
    \u043F\u0435\u0440\u0432\u0430\u044F \u0431\u0443\u043A\u0432\u0430 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0433\u043E
    \u0430\u043B\u0444\u0430\u0432\u0438\u0442\u0430). \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0441\u0432\u043E\u044E \u043F\u043B\u043E\u0442\u043D\u043E\u0441\u0442\u044C,
    \u0438\u043C\u0435\u0435\u0442 \u0442\u0430\u043A\u0443\u044E \u0436\u0435 \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C
    \\( \\aleph_0 \\). *   **\u041C\u043E\u0449\u043D\u043E\u0441\u0442\u044C \u043A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C\u0430**:
    \u041C\u043E\u0449\u043D\u043E\u0441\u0442\u044C \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B (\\( \\mathbb{R} \\)) \u043E\u043D \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0438\u043B
    \u0431\u0443\u043A\u0432\u043E\u0439 \\( \\mathfrak{c} \\) (\u0438\u043B\u0438
    \\( 2^{\\aleph_0} \\)). \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \\( \\aleph_0 < \\mathfrak{c} \\) (\u043A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C
    \u0441\u0442\u0440\u043E\u0433\u043E \u0431\u043E\u043B\u044C\u0448\u0435 \u0441\u0447\u0451\u0442\u043D\u043E\u0433\u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430). *   **\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430
    \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u043E\u0432**: \u041A\u0430\u043D\u0442\u043E\u0440
    \u0441\u043E\u0437\u0434\u0430\u043B \u0446\u0435\u043B\u0443\u044E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0443
    \u0434\u043B\u044F \u044D\u0442\u0438\u0445 \u0447\u0438\u0441\u0435\u043B: \u043E\u043D
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \\( \\aleph_0
    + \\aleph_0 = \\aleph_0 \\) \u0438 \\( \\aleph_0 \\cdot \\aleph_0 = \\aleph_0
    \\), \u043D\u043E \\( 2^{\\aleph_0} > \\aleph_0 \\). *   **\u0418\u0435\u0440\u0430\u0440\u0445\u0438\u044F
    \u0430\u043B\u0435\u0444\u043E\u0432**: \u041E\u043D \u0432\u0432\u0451\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \\( \\aleph_1, \\aleph_2, \\dots,
    \\aleph_\\omega \\) \u0438 \u0442.\u0434., \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0432
    \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u0432\u043E\u0441\u0445\u043E\u0434\u044F\u0449\u0443\u044E
    \u043B\u0435\u0441\u0442\u043D\u0438\u0446\u0443 \u0432\u0441\u0451 \u0431\u043E\u043B\u0435\u0435
    \u043C\u043E\u0449\u043D\u044B\u0445 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0435\u0439. 
    ---  ### 4. \u041A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C-\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    (CH) \u041F\u0440\u043E\u0432\u0435\u0434\u044F \u0433\u0440\u0430\u043D\u0438\u0446\u0443
    \u043C\u0435\u0436\u0434\u0443 \\( \\aleph_0 \\) \u0438 \\( \\mathfrak{c} \\)
    (\u043A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C\u043E\u043C), \u041A\u0430\u043D\u0442\u043E\u0440
    \u0437\u0430\u0434\u0430\u043B \u0441\u0430\u043A\u0440\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043E\u043F\u0440\u043E\u0441: **\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043B\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E, \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0441\u0442\u0440\u043E\u0433\u043E
    \u0431\u043E\u043B\u044C\u0448\u0435 \\( \\aleph_0 \\), \u043D\u043E \u0441\u0442\u0440\u043E\u0433\u043E
    \u043C\u0435\u043D\u044C\u0448\u0435 \\( \\mathfrak{c} \\)?**  *   **\u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430**:
    \u041A\u0430\u043D\u0442\u043E\u0440 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u043B,
    \u0447\u0442\u043E \u0442\u0430\u043A\u043E\u0439 \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u0447\u043D\u043E\u0439
    \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u0438 \u043D\u0435\u0442, \u0442\u043E
    \u0435\u0441\u0442\u044C \\( \\mathfrak{c} = \\aleph_1 \\). \u042D\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E **\u041A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C-\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u043E\u0439**.
    *   **\u0421\u0443\u0434\u044C\u0431\u0430 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B**:
    \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u0439 \u0432
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432\u043E\u043F\u0440\u043E\u0441 \u0438\u0437 \u0441\u043F\u0438\u0441\u043A\u0430
    \xAB\u041F\u0440\u043E\u0431\u043B\u0435\u043C \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430\xBB
    (\u21161), \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F\u043C\u0438
    \u043C\u0443\u0447\u0438\u043B \u0443\u043C\u044B. \u041B\u0438\u0448\u044C \u0432
    1963 \u0433\u043E\u0434\u0443 \u041F\u043E\u043B \u041A\u043E\u044D\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u044D\u0442\u0443 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    **\u043D\u0435\u043B\u044C\u0437\u044F \u043D\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
    \u043D\u0438 \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u044C**
    \u0432 \u0440\u0430\u043C\u043A\u0430\u0445 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u043E\u0439
    \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u043A\u0438 \u0426\u0435\u0440\u043C\u0435\u043B\u043E-\u0424\u0440\u0435\u043D\u043A\u0435\u043B\u044F
    (ZFC). \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443\u043B\u043E
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043E \u043F\u0440\u0438\u0440\u043E\u0434\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u0442\u0438\u043D, \u043D\u043E \u043D\u0430\u0447\u0430\u043B\u043E\u0441\u044C
    \u0432\u0441\u0451 \u0441 \u0434\u043E\u0433\u0430\u0434\u043A\u0438 \u041A\u0430\u043D\u0442\u043E\u0440\u0430. 
    ---  ### 5. \u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441 \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438
    (\u041E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \u043E\u0442\u0440\u0435\u0437\u043A\u0430
    \u0432 \u043A\u0432\u0430\u0434\u0440\u0430\u0442, 1877) \u042D\u0442\u043E \u043E\u0434\u043D\u043E
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043A\u043E\u043D\u0442\u0440\u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u044B\u0445
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439 \u041A\u0430\u043D\u0442\u043E\u0440\u0430,
    \u0432\u044B\u0437\u0432\u0430\u0432\u0448\u0435\u0435 \u0448\u043E\u043A \u0443
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432. 
    *   **\u0421\u0443\u0442\u044C**: \u041A\u0430\u043D\u0442\u043E\u0440 \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043C\u0435\u0436\u0434\u0443 \u0442\u043E\u0447\u043A\u0430\u043C\u0438
    \u043E\u0442\u0440\u0435\u0437\u043A\u0430 \u043F\u0440\u044F\u043C\u043E\u0439
    (\u043E\u0434\u043D\u043E\u043C\u0435\u0440\u043D\u044B\u0439 \u043E\u0431\u044A\u0435\u043A\u0442)
    \u0438 \u0442\u043E\u0447\u043A\u0430\u043C\u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430
    (\u0434\u0432\u0443\u043C\u0435\u0440\u043D\u044B\u0439 \u043E\u0431\u044A\u0435\u043A\u0442)
    \u043C\u043E\u0436\u043D\u043E \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    **\u0432\u0437\u0430\u0438\u043C\u043D\u043E-\u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E\u0435
    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435**. *  
    **\u0424\u043E\u0440\u043C\u0443\u043B\u0430**: \u041E\u043D \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u0444\u0443\u043D\u043A\u0446\u0438\u044E \\( f(x, y) \\), \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043A\u043E\u0434\u0438\u0440\u0443\u0435\u0442 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B
    \u0434\u0432\u0443\u0445 \u0447\u0438\u0441\u0435\u043B \u0432 \u043E\u0434\u043D\u043E
    \u0447\u0438\u0441\u043B\u043E \u0447\u0435\u0440\u0435\u0437 \u043F\u0435\u0440\u0435\u043C\u0435\u0448\u0438\u0432\u0430\u043D\u0438\u0435
    \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u044B\u0445 \u0437\u043D\u0430\u043A\u043E\u0432
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \\( 0.a_1a_2a_3... \\) \u0438
    \\( 0.b_1b_2b_3... \\) \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u044E\u0442\u0441\u044F
    \u0432 \\( 0.a_1b_1a_2b_2... \\)). *   **\u0412\u044B\u0432\u043E\u0434**: \u041E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0442\u043E\u0447\u0435\u043A \u043F\u0440\u044F\u043C\u043E\u0439, \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438
    \u0438 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430
    **\u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u0430** (\\( \\mathfrak{c}
    \\)). \u042D\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E, \u0447\u0442\u043E
    \xAB\u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C\xBB \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430
    (1D, 2D, 3D) \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u0442\u0441\u044F
    \u043D\u0435 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E\u043C
    \u0442\u043E\u0447\u0435\u043A, \u0430 \u0438\u0445 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\u043C\u0438 (\u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u044C\u044E).
    \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E
    \u043F\u043E\u0434\u0432\u0435\u043B\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438 \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438. 
    ---  ### 6. \u041A\u0430\u043D\u0442\u043E\u0440\u043E\u0432\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    (\u041A\u0430\u043D\u0442\u043E\u0440\u043E\u0432\u0441\u043A\u0430\u044F \u043F\u044B\u043B\u044C,
    1883) \u0412 \u0445\u043E\u0434\u0435 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u044B\u0445 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0441\u043E\u0437\u0434\u0430\u043B \xAB\u043C\u043E\u043D\u0441\u0442\u0440\u0430\xBB
    \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u0432 \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u043E\u0432
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438.  *   **\u041F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435**:
    \u0411\u0435\u0440\u0435\u0442\u0441\u044F \u043E\u0442\u0440\u0435\u0437\u043E\u043A
    [0,1]. \u0418\u0437 \u043D\u0435\u0433\u043E \u0443\u0434\u0430\u043B\u044F\u0435\u0442\u0441\u044F
    \u0441\u0440\u0435\u0434\u043D\u044F\u044F \u0442\u0440\u0435\u0442\u044C (\u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F
    [0, 1/3] \u0438 [2/3, 1]). \u0417\u0430\u0442\u0435\u043C \u0443\u0434\u0430\u043B\u044F\u0435\u0442\u0441\u044F
    \u0441\u0440\u0435\u0434\u043D\u044F\u044F \u0442\u0440\u0435\u0442\u044C \u0438\u0437
    \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u043E\u0441\u0442\u0430\u0432\u0448\u0435\u0433\u043E\u0441\u044F
    \u043E\u0442\u0440\u0435\u0437\u043A\u0430, \u0438 \u0442\u0430\u043A \u0434\u043E
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438.
    *   **\u0421\u0432\u043E\u0439\u0441\u0442\u0432\u0430**:     1.  \u042D\u0442\u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E **\u043D\u0438\u0433\u0434\u0435
    \u043D\u0435 \u043F\u043B\u043E\u0442\u043D\u043E** (\u043D\u0435 \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442
    \u043D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u0430).    
    2.  \u041E\u043D\u043E \u0438\u043C\u0435\u0435\u0442 **\u043D\u0443\u043B\u0435\u0432\u0443\u044E
    \u043C\u0435\u0440\u0443** (\u0435\u0433\u043E \u0434\u043B\u0438\u043D\u0430
    \u0440\u0430\u0432\u043D\u0430 0).     3.  \u041F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u043E\u043D\u043E \u0438\u043C\u0435\u0435\u0442 \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C
    **\u043A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C** (\\( \\mathfrak{c}
    \\))! \u0422\u043E \u0435\u0441\u0442\u044C, \u0432 \u043D\u0451\u043C \u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0436\u0435 \u0442\u043E\u0447\u0435\u043A, \u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0432\u043E \u0432\u0441\u0451\u043C \u043E\u0442\u0440\u0435\u0437\u043A\u0435,
    \u0445\u043E\u0442\u044F \u0441\u0443\u043C\u043C\u0430\u0440\u043D\u0430\u044F
    \u0434\u043B\u0438\u043D\u0430 \u0435\u0433\u043E \u043E\u0442\u0440\u0435\u0437\u043A\u043E\u0432
    \u0440\u0430\u0432\u043D\u0430 \u043D\u0443\u043B\u044E. *   **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435**:
    \u042D\u0442\u043E \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u043B\u043E \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u043E\u0435
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \xAB\u0440\u0430\u0437 \u0434\u043B\u0438\u043D\u0430
    \u0440\u0430\u0432\u043D\u0430 \u043D\u0443\u043B\u044E, \u0437\u043D\u0430\u0447\u0438\u0442
    \u0442\u043E\u0447\u0435\u043A \u043C\u0430\u043B\u043E\xBB. \u042D\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u043E\u0442\u043F\u0440\u0430\u0432\u043D\u043E\u0439
    \u0442\u043E\u0447\u043A\u043E\u0439 \u0434\u043B\u044F \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u0435\u0440\u044B \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430
    \u041B\u0435\u0431\u0435\u0433\u0430.  ---  ### 7. \u0422\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F
    \u0438 \xAB\u041F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u044B\u0435 \u0442\u043E\u0447\u043A\u0438\xBB
    (\u0422\u0435\u043E\u0440\u0438\u044F \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0445
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432) \u0412 1872\u20131884 \u0433\u043E\u0434\u0430\u0445
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u0443\u044E \u0442\u0435\u043E\u0440\u0438\u044E
    \u0442\u043E\u0447\u0435\u0447\u043D\u044B\u0445 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    \u043D\u0430 \u043F\u0440\u044F\u043C\u043E\u0439.  *   \u041E\u043D \u0432\u0432\u0451\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u043E\u0439
    \u0442\u043E\u0447\u043A\u0438** (\u0442\u043E\u0447\u043A\u0438 \u0441\u0433\u0443\u0449\u0435\u043D\u0438\u044F
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430) \u0438 **\u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u043E\u0433\u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430** \\( P' \\) (\u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0432\u0441\u0435\u0445 \u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u044B\u0445
    \u0442\u043E\u0447\u0435\u043A P). *   \u0417\u0430\u0442\u0435\u043C \u043E\u043D
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u043F\u043E\u0432\u0442\u043E\u0440\u043D\u044B\u0435
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0435: \\( P'',
    P''', \\dots, P^{(\\infty)} \\). *   \u0412 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0435
    \u043E\u043D \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u043B
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u043F\u043E \u0442\u0438\u043F\u0443
    \u0438\u0445 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0445
    \u0438 \u043E\u0442\u043A\u0440\u044B\u043B \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432, \u0434\u043B\u044F \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u044D\u0442\u043E\u0442 \u043F\u0440\u043E\u0446\u0435\u0441\u0441 \u043D\u0435
    \u0437\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u043B\u0441\u044F \u0434\u0430\u0436\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u0448\u0430\u0433\u043E\u0432. \u042D\u0442\u043E
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u0435\u0433\u043E \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    **\u0442\u0440\u0430\u043D\u0441\u0444\u0438\u043D\u0438\u0442\u043D\u043E\u0439
    \u0438\u043D\u0434\u0443\u043A\u0446\u0438\u0438** \u2014 \u043C\u0435\u0442\u043E\u0434\u0430
    \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0439, \u0433\u0434\u0435
    \u0448\u0430\u0433\u0438 \u043D\u0443\u043C\u0435\u0440\u0443\u044E\u0442\u0441\u044F
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u043C\u0438,
    \u043D\u043E \u0438 \u0442\u0440\u0430\u043D\u0441\u0444\u0438\u043D\u0438\u0442\u043D\u044B\u043C\u0438
    \u0447\u0438\u0441\u043B\u0430\u043C\u0438 \\( \\omega, \\omega+1, \\omega+2
    \\) \u0438 \u0442.\u0434. \u042D\u0442\u043E \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u043E \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u0434\u0435\u0441\u043A\u0440\u0438\u043F\u0442\u0438\u0432\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432. 
    ---  ### 8. \u0412\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B (\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u041A\u0430\u043D\u0442\u043E\u0440\u0430-\u0411\u0435\u0440\u043D\u0448\u0442\u0435\u0439\u043D\u0430)
    \u0425\u043E\u0442\u044F \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0431\u044B\u043B\u043E \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u043E
    \u0411\u0435\u0440\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C (\u043F\u0440\u0438
    \u0443\u0447\u0430\u0441\u0442\u0438\u0438 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430),
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u0435\u0451 \u043E\u0441\u043D\u043E\u0432\u0443. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430-\u0411\u0435\u0440\u043D\u0448\u0442\u0435\u0439\u043D\u0430**:
    \u0415\u0441\u043B\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    A \u0440\u0430\u0432\u043D\u043E\u043C\u043E\u0449\u043D\u043E \u043F\u043E\u0434\u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0443
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 B, \u0430 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    B \u0440\u0430\u0432\u043D\u043E\u043C\u043E\u0449\u043D\u043E \u043F\u043E\u0434\u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0443
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 A, \u0442\u043E A \u0438
    B \u0440\u0430\u0432\u043D\u043E\u043C\u043E\u0449\u043D\u044B. *   \u042D\u0442\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u043E \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0438
    \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0430 \u0441\u0442\u0440\u043E\u0433\u043E
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u0442\u044C, \u0447\u0442\u043E
    \\( \\aleph_0 \\cdot \\aleph_0 = \\aleph_0 \\) \u0438 \u0434\u0440\u0443\u0433\u0438\u0435
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438.  ---  ### 9. \u041E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435
    \u041D\u0435\u043C\u0435\u0446\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u0438 \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u043E\u0432
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A\u043E\u043C, \u043D\u043E \u0438
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u043C \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C
    \u043D\u0430\u0443\u043A\u0438.  *   \u0412 1890 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043E\u0441\u043D\u043E\u0432\u0430\u043B **\u041D\u0435\u043C\u0435\u0446\u043A\u043E\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E (DMV)** \u0438 \u0441\u0442\u0430\u043B
    \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u044B\u043C \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C.
    *   \u041E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u043B\u043E\u0431\u0431\u0438\u0440\u043E\u0432\u0430\u043B
    \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u0445
    \u0432\u0441\u0442\u0440\u0435\u0447. \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0435\u0433\u043E \u0443\u0441\u0438\u043B\u0438\u044F\u043C \u0432 1897 \u0433\u043E\u0434\u0443
    \u0432 \u0426\u044E\u0440\u0438\u0445\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0441\u044F
    **\u041F\u0435\u0440\u0432\u044B\u0439 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u0439
    \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    (ICM)**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441 \u0442\u0435\u0445
    \u043F\u043E\u0440 \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u0442\u0441\u044F
    \u0440\u0430\u0437 \u0432 \u0447\u0435\u0442\u044B\u0440\u0435 \u0433\u043E\u0434\u0430.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044F
    (\u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435 \u0431\u0443\u0440\u043D\u044B\u0445
    \u0441\u043F\u043E\u0440\u043E\u0432) \u043D\u0430\u0447\u0430\u043B\u0430 \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C
    \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435. 
    ---  ### 10. \u0424\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0430
    \u0430\u043A\u0441\u0438\u043E\u043C\u044B \u0432\u044B\u0431\u043E\u0440\u0430
    (\u0432 \u043D\u0435\u044F\u0432\u043D\u043E\u043C \u0432\u0438\u0434\u0435)
    \u0425\u043E\u0442\u044F \u0430\u043A\u0441\u0438\u043E\u043C\u0443 \u0432\u044B\u0431\u043E\u0440\u0430
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u042D\u0440\u043D\u0441\u0442 \u0426\u0435\u0440\u043C\u0435\u043B\u043E \u043F\u043E\u0437\u0436\u0435
    (1904), \u041A\u0430\u043D\u0442\u043E\u0440 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0435\u0451 \u0432 \u043D\u0435\u044F\u0432\u043D\u043E\u0439 \u0444\u043E\u0440\u043C\u0435,
    \u043A\u043E\u0433\u0434\u0430 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u043B\u044E\u0431\u043E\u0435 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043C\u043E\u0436\u043D\u043E \xAB\u0445\u043E\u0440\u043E\u0448\u043E \u0443\u043F\u043E\u0440\u044F\u0434\u043E\u0447\u0438\u0442\u044C\xBB
    (\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E \u0445\u043E\u0440\u043E\u0448\u043E
    \u0443\u043F\u043E\u0440\u044F\u0434\u043E\u0447\u0435\u043D\u0438\u0438). \u041E\u043D
    \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u043E \u043F\u043E\u043D\u0438\u043C\u0430\u043B,
    \u0447\u0442\u043E \u043A\u0430\u0436\u0434\u044B\u0439 \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u044B\u043C
    \u043E\u0440\u0434\u0438\u043D\u0430\u043B\u043E\u043C, \u0438, \u0445\u043E\u0442\u044F
    \u043D\u0435 \u0441\u043C\u043E\u0433 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u044D\u0442\u043E \u0441\u0442\u0440\u043E\u0433\u043E, \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u043B\u0435\u0433\u043B\u0438 \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432. 
    ---  ### \U0001F52C \u0418\u0442\u043E\u0433\u043E\u0432\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0432\u043A\u043B\u0430\u0434\u0430 \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    (\u0412\u0437\u0433\u043B\u044F\u0434 \u0432 \u0431\u0443\u0434\u0443\u0449\u0435\u0435) 
    \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0430\u0441\u0448\u0438\u0440\u0438\u043B\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u2014 \u043E\u043D\u0438
    \u0441\u043F\u0430\u0441\u043B\u0438 \u0435\u0451 \u043E\u0442 \u043A\u0440\u0438\u0437\u0438\u0441\u0430.
    \u0412 XIX \u0432\u0435\u043A\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0443\u0442\u043A\u043D\u0443\u043B\u0430\u0441\u044C \u0432 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u044B
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E \u043C\u0430\u043B\u044B\u0445
    \u0438 \u0441\u0445\u043E\u0434\u044F\u0449\u0438\u0445\u0441\u044F \u0440\u044F\u0434\u043E\u0432.
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0434\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C
    **\u043D\u043E\u0432\u044B\u0439 \u044F\u0437\u044B\u043A**:  1.  \u0422\u0435\u043E\u0440\u0438\u044F
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432 \u0441\u0442\u0430\u043B\u0430
    **\u0431\u0430\u0437\u043E\u0439** \u0434\u043B\u044F \u0432\u0441\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    (\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437, \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F,
    \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437, \u0442\u0435\u043E\u0440\u0438\u044F \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439
    \u0441\u0442\u0440\u043E\u044F\u0442\u0441\u044F \u043D\u0430 \u043F\u043E\u043D\u044F\u0442\u0438\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430). 2.  \u0415\u0433\u043E
    \u0438\u0434\u0435\u0438 \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0438
    \u043D\u0430 **\u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438**,
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u043D\u0430 \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u043E\u0432
    (\u043E\u0442\u0440\u0438\u0446\u0430\u0432\u0448\u0438\u0445 \u0430\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u0443\u044E
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C)
    \u0438 \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0441\u0442\u043E\u0432 (\u043F\u0440\u0438\u043D\u044F\u0432\u0448\u0438\u0445
    \u0435\u0451). \u041F\u043E\u0431\u0435\u0434\u0430 \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0441\u0442\u043E\u0432
    (\u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442) \u0441\u0434\u0435\u043B\u0430\u043B\u0430
    \u0442\u0435\u043E\u0440\u0438\u044E \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C \u043A\u0430\u043C\u043D\u0435\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F. 3.  \u0415\u0433\u043E
    \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439 \u043C\u0435\u0442\u043E\u0434
    \u043F\u043E\u0437\u0436\u0435 \u0431\u044B\u043B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D
    **\u041A\u0443\u0440\u0442\u043E\u043C \u0413\u0451\u0434\u0435\u043B\u0435\u043C**
    \u0434\u043B\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0442\u0435\u043E\u0440\u0435\u043C \u043E \u043D\u0435\u043F\u043E\u043B\u043D\u043E\u0442\u0435,
    \u0430 **\u0410\u043B\u0430\u043D\u043E\u043C \u0422\u044C\u044E\u0440\u0438\u043D\u0433\u043E\u043C**
    \u2014 \u0434\u043B\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043D\u0435\u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0441\u0442\u0438
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438,
    \u0447\u0442\u043E \u043B\u0435\u0433\u043B\u043E \u0432 \u043E\u0441\u043D\u043E\u0432\u0443
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432
    \u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0438.  \u041A\u0430\u043D\u0442\u043E\u0440
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B \u0434\u043B\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \xAB\u0440\u0430\u0439\xBB, \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E,
    \u043A\u0430\u043A \u0441\u043A\u0430\u0437\u0430\u043B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442,
    \u0438\u0445 \u043D\u0435 \u0441\u043C\u043E\u0436\u0435\u0442 \u0438\u0437\u0433\u043D\u0430\u0442\u044C
    \u043D\u0438\u043A\u0442\u043E. \u0418 \u044D\u0442\u043E\u0442 \u0440\u0430\u0439
    \u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F \u043D\u0430 \u0442\u0440\u0451\u0445
    \u043A\u0438\u0442\u0430\u0445: **\u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C,
    \u0442\u0440\u0430\u043D\u0441\u0444\u0438\u043D\u0438\u0442\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0430\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u0430\u044F \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C**."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0413\u0435\u043E\u0440\u0433\u0430 \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    \u2014 \u044D\u0442\u043E \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438 \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0440\u0430\u0437\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u043B\u0430\u0441\u044C
    \u043D\u0430 \u0444\u043E\u043D\u0435 \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u0432. \u0415\u0441\u043B\u0438 \u0435\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430
    \u0431\u043E\u0440\u044C\u0431\u043E\u0439 \u0437\u0430 \u0438\u0441\u0442\u0438\u043D\u0443,
    \u0442\u043E \u043B\u0438\u0447\u043D\u0430\u044F \u2014 \u044D\u0442\u043E \u0431\u043E\u0440\u044C\u0431\u0430
    \u0437\u0430 \u0434\u0443\u0448\u0435\u0432\u043D\u043E\u0435 \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435,
    \u0441\u043E\u0432\u043C\u0435\u0449\u0435\u043D\u0438\u0435 \u0440\u043E\u043B\u0438
    \u043C\u0443\u0436\u0430, \u043E\u0442\u0446\u0430 \u0438 \u0442\u0432\u043E\u0440\u0446\u0430,
    \u0441\u043B\u043E\u043C\u043B\u0435\u043D\u043D\u043E\u0433\u043E \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C
    \u0432\u043D\u0435\u0448\u043D\u0435\u0433\u043E \u043C\u0438\u0440\u0430 \u0438
    \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0445 \u0434\u0435\u043C\u043E\u043D\u043E\u0432.  
    \u0412\u043E\u0442 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439 \u043F\u043E\u0440\u0442\u0440\u0435\u0442
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u0441\u043A\u0440\u044B\u0432\u0430\u044E\u0449\u0435\u0433\u043E\u0441\u044F
    \u0437\u0430 \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C \xAB\u0430\u043B\u0435\u0444\xBB. 
    ### 1. \u0421\u0435\u043C\u044C\u044F \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435:
    \u041A\u043E\u0440\u043D\u0438, \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0432\u0448\u0438\u0435
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440 \u0413\u0435\u043E\u0440\u0433
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0439
    \u0438 \u0430\u0440\u0442\u0438\u0441\u0442\u0438\u0447\u043D\u043E\u0439 \u0441\u0435\u043C\u044C\u0435,
    \u0447\u0442\u043E \u043D\u0430\u043B\u043E\u0436\u0438\u043B\u043E \u043E\u0442\u043F\u0435\u0447\u0430\u0442\u043E\u043A
    \u043D\u0430 \u0432\u0441\u0451 \u0435\u0433\u043E \u043C\u0438\u0440\u043E\u0432\u043E\u0437\u0437\u0440\u0435\u043D\u0438\u0435. 
    *   **\u041E\u0442\u0435\u0446 (\u0413\u0435\u043E\u0440\u0433-\u0412\u043E\u043B\u044C\u0434\u0435\u043C\u0430\u0440
    \u041A\u0430\u043D\u0442\u043E\u0440):** \u0423\u0441\u043F\u0435\u0448\u043D\u044B\u0439
    \u0431\u0438\u0440\u0436\u0435\u0432\u043E\u0439 \u043C\u0430\u043A\u043B\u0435\u0440,
    \u0432\u044B\u0445\u043E\u0434\u0435\u0446 \u0438\u0437 \u041A\u043E\u043F\u0435\u043D\u0433\u0430\u0433\u0435\u043D\u0430.
    \u041E\u043D \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0432\u0435\u0440\u0443\u044E\u0449\u0438\u043C
    \u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0438\u043D\u043E\u043C (\u0445\u043E\u0442\u044F
    \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u043A\u0438 \u0431\u044B\u043B\u0438
    \u0435\u0432\u0440\u0435\u044F\u043C\u0438-\u0441\u0435\u0444\u0430\u0440\u0434\u0430\u043C\u0438,
    \u043F\u0440\u0438\u043D\u044F\u0432\u0448\u0438\u043C\u0438 \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u0438\u0437\u043C).
    \u041E\u0442\u0435\u0446 \u043F\u0440\u0438\u0432\u0438\u043B \u0413\u0435\u043E\u0440\u0433\u0443
    \u043B\u044E\u0431\u043E\u0432\u044C \u043A \u043F\u043E\u0440\u044F\u0434\u043A\u0443,
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0435 \u0438 \u0434\u0435\u043D\u044C\u0433\u0430\u043C,
    \u043D\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u2014 \u043E\u043D \u0432\u043D\u0443\u0448\u0438\u043B
    \u0441\u044B\u043D\u0443 \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0449\u0443\u0449\u0435\u043D\u0438\u0435 \u0411\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u043F\u0440\u0438\u0440\u043E\u0434\u044B \u0447\u0438\u0441\u0435\u043B \u0438
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438.
    \u0418\u043C\u0435\u043D\u043D\u043E \u043E\u0442\u0435\u0446 \u043D\u0430\u0441\u0442\u043E\u044F\u043B,
    \u0447\u0442\u043E\u0431\u044B \u0413\u0435\u043E\u0440\u0433 \u0441\u0442\u0430\u043B
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C (\u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u0430\u044F
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C),
    \u043D\u043E, \u0443\u0432\u0438\u0434\u0435\u0432 \u0442\u0430\u043B\u0430\u043D\u0442
    \u0441\u044B\u043D\u0430 \u043A \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u0431\u043B\u0430\u0433\u043E\u0441\u043B\u043E\u0432\u0438\u043B \u0435\u0433\u043E
    \u043D\u0430 \u044D\u0442\u043E\u0442 \u043F\u0443\u0442\u044C. \u0421\u043C\u0435\u0440\u0442\u044C
    \u043E\u0442\u0446\u0430 \u0432 1863 \u0433\u043E\u0434\u0443 \u0441\u0442\u0430\u043B\u0430
    \u043F\u0435\u0440\u0432\u044B\u043C \u0442\u044F\u0436\u0435\u043B\u044B\u043C
    \u0443\u0434\u0430\u0440\u043E\u043C \u0434\u043B\u044F \u044E\u043D\u043E\u0433\u043E
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430, \u043D\u043E \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430
    \u0435\u043C\u0443 \u0441\u043E\u043B\u0438\u0434\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E,
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0432\u0448\u0435\u0435 \u043D\u0435
    \u0434\u0443\u043C\u0430\u0442\u044C \u043E \u0445\u043B\u0435\u0431\u0435 \u043D\u0430\u0441\u0443\u0449\u043D\u043E\u043C
    \u0434\u043E\u043B\u0433\u0438\u0435 \u0433\u043E\u0434\u044B. *   **\u041C\u0430\u0442\u044C
    (\u041C\u0430\u0440\u0438\u044F-\u0410\u043D\u043D\u0430 \u0411\u0451\u043C):**
    \u041E\u043D\u0430 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0430
    \u0438\u0437 \u0441\u0435\u043C\u044C\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445
    \u043C\u0443\u0437\u044B\u043A\u0430\u043D\u0442\u043E\u0432. \u0415\u0435 \u0434\u044F\u0434\u044F
    \u2014 \u0419\u043E\u0437\u0435\u0444 \u0411\u0451\u043C \u2014 \u0431\u044B\u043B
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F \u0441\u043A\u0440\u0438\u043F\u0430\u0447\u043E\u043C-\u0432\u0438\u0440\u0442\u0443\u043E\u0437\u043E\u043C.
    \u041E\u0442 \u043C\u0430\u0442\u0435\u0440\u0438 \u0413\u0435\u043E\u0440\u0433
    \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u0442\u043E\u043D\u043A\u0443\u044E
    \u0434\u0443\u0448\u0435\u0432\u043D\u0443\u044E \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u044E,
    \u0430\u0440\u0442\u0438\u0441\u0442\u0438\u0437\u043C \u0438 \u043B\u044E\u0431\u043E\u0432\u044C
    \u043A \u043C\u0443\u0437\u044B\u043A\u0435. \u041E\u043D \u0432\u0435\u043B\u0438\u043A\u043E\u043B\u0435\u043F\u043D\u043E
    \u0438\u0433\u0440\u0430\u043B \u043D\u0430 \u0441\u043A\u0440\u0438\u043F\u043A\u0435,
    \u0438 \u043C\u0443\u0437\u044B\u043A\u0430 \u0431\u044B\u043B\u0430 \u0434\u043B\u044F
    \u043D\u0435\u0433\u043E \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C \xAB\u043B\u0435\u043A\u0430\u0440\u0441\u0442\u0432\u043E\u043C\xBB
    \u0432 \u043C\u0438\u043D\u0443\u0442\u044B \u0434\u0443\u0448\u0435\u0432\u043D\u044B\u0445
    \u043A\u0440\u0438\u0437\u0438\u0441\u043E\u0432. *   **\u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0435:** \u0411\u0443\u0434\u0443\u0447\u0438
    \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u043E\u043C \u0432
    \u043F\u0440\u0430\u0432\u043E\u0441\u043B\u0430\u0432\u043D\u043E\u0439 \u0441\u0442\u043E\u043B\u0438\u0446\u0435,
    \u0434\u0430\u0442\u0447\u0430\u043D\u0438\u043D\u043E\u043C \u043F\u043E \u043F\u0430\u0441\u043F\u043E\u0440\u0442\u0443
    \u0432 \u0440\u0443\u0441\u0441\u043A\u043E\u043C \u0433\u043E\u0440\u043E\u0434\u0435,
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
    \u043F\u0440\u0438\u0432\u044B\u043A \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u0441\u0435\u0431\u044F \xAB\u0447\u0443\u0436\u0438\u043C\xBB \u0438 \u043E\u0442\u0441\u0442\u0430\u0438\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u044E \u0438\u043D\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C.
    \u042D\u0442\u043E \u0437\u0430\u043A\u0430\u043B\u0438\u043B\u043E \u0435\u0433\u043E
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440, \u043D\u043E \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u043E \u043F\u043E\u0442\u0440\u0435\u0431\u043D\u043E\u0441\u0442\u044C
    \u0432 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0442\u0430\u043A \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u043B\u043E \u0432
    \u0437\u0440\u0435\u043B\u044B\u0435 \u0433\u043E\u0434\u044B.  ---  ### 2. \u0421\u0432\u0430\u0434\u044C\u0431\u0430
    \u0438 \u0431\u0440\u0430\u043A: \u0422\u044B\u0441\u044F\u0447\u0430 \u043F\u0438\u0441\u0435\u043C
    \u0438 \u0442\u0438\u0445\u0438\u0439 \u0442\u044B\u043B \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u0434\u043E\u043B\u0433\u043E
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C \u0443\u0435\u0434\u0438\u043D\u0435\u043D\u043D\u043E\u0439
    \u2014 \u043E\u043D \u0431\u044B\u043B \u043F\u043E\u0433\u0440\u0443\u0436\u0435\u043D
    \u0432 \u043D\u0430\u0443\u043A\u0443. \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u043E\u043A\u043E\u043B\u043E 29 \u043B\u0435\u0442 \u043E\u043D \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B
    \u0441\u0432\u043E\u044E \u0431\u0443\u0434\u0443\u0449\u0443\u044E \u0436\u0435\u043D\u0443. 
    *   **\u041A\u0442\u043E \u043E\u043D\u0430:** \u0412 1874 \u0433\u043E\u0434\u0443
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 **\u0412\u0430\u043B\u043B\u0438 \u0413\u0443\u0442\u0442\u043C\u0430\u043D\u043D**
    (Vally Guttmann). \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043D\u0430 8
    \u043B\u0435\u0442 \u043C\u043B\u0430\u0434\u0448\u0435 \u0435\u0433\u043E, \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0430
    \u0438\u0437 \u0441\u0435\u043C\u044C\u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u044B\u0445
    \u0438 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u043D\u044B\u0445
    \u043A\u043E\u043C\u043C\u0435\u0440\u0441\u0430\u043D\u0442\u043E\u0432.  *  
    **\u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0439:**
    \u042D\u0442\u043E \u0431\u044B\u043B \u0441\u043E\u044E\u0437 \u0440\u0430\u0437\u0443\u043C\u0430
    \u0438 \u0441\u0435\u0440\u0434\u0446\u0430. \u0412\u0430\u043B\u043B\u0438 \u0431\u044B\u043B\u0430
    \u043F\u043E\u043B\u043D\u043E\u0439 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C\u044E
    \u0441\u0432\u043E\u0435\u0433\u043E \u043C\u0443\u0436\u0430 \u2014 \u043F\u0440\u0430\u0433\u043C\u0430\u0442\u0438\u0447\u043D\u043E\u0439,
    \u043F\u0440\u0438\u0437\u0435\u043C\u043B\u0435\u043D\u043D\u043E\u0439, \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E\u0439
    \u0438 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E \u0442\u0435\u0440\u043F\u0435\u043B\u0438\u0432\u043E\u0439.
    \u0418\u043C\u0435\u043D\u043D\u043E \u043E\u043D\u0430 \u0432\u0437\u044F\u043B\u0430
    \u043D\u0430 \u0441\u0435\u0431\u044F \u0432\u0441\u0435 \u0431\u044B\u0442\u043E\u0432\u044B\u0435
    \u0438 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0435 \u0432\u043E\u043F\u0440\u043E\u0441\u044B,
    \u043A\u043E\u0433\u0434\u0430 \u0443 \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    \u043D\u0430\u0447\u0430\u043B\u0438\u0441\u044C \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
    \u0441 \u043F\u0441\u0438\u0445\u0438\u043A\u043E\u0439. \u041E\u043D\u0438 \u0432\u0435\u043B\u0438
    \u0438\u043D\u0442\u0435\u043D\u0441\u0438\u0432\u043D\u0443\u044E \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443,
    \u043A\u043E\u0433\u0434\u0430 \u041A\u0430\u043D\u0442\u043E\u0440 \u0443\u0435\u0437\u0436\u0430\u043B
    \u0432 \u043A\u043E\u043C\u0430\u043D\u0434\u0438\u0440\u043E\u0432\u043A\u0438
    \u0438\u043B\u0438 \u043D\u0430 \u043B\u0435\u0447\u0435\u043D\u0438\u0435 \u2014
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C \u043E\u043A\u043E\u043B\u043E
    **1000 \u043F\u0438\u0441\u0435\u043C**, \u0430\u0434\u0440\u0435\u0441\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0436\u0435\u043D\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0431\u0435\u0441\u0446\u0435\u043D\u043D\u044B\u043C \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u043C
    \u0434\u043B\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u043E\u0432.  *  
    **\u041F\u043E\u0437\u043E\u0440 \u0441\u0435\u043C\u044C\u0438:** \u0420\u043E\u0434\u0438\u0442\u0435\u043B\u0438
    \u0412\u0430\u043B\u043B\u0438 \u0431\u044B\u043B\u0438 \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0440\u043E\u0442\u0438\u0432 \u044D\u0442\u043E\u0433\u043E \u0431\u0440\u0430\u043A\u0430,
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u041A\u0430\u043D\u0442\u043E\u0440
    \u0431\u044B\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0432 \xAB\u0437\u0430\u0445\u043E\u043B\u0443\u0441\u0442\u043D\u043E\u043C\xBB
    \u0413\u0430\u043B\u043B\u0435, \u0430 \u043D\u0435 \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u043C
    \u0411\u0435\u0440\u043B\u0438\u043D\u0435, \u0438 \u043A \u0442\u043E\u043C\u0443
    \u0436\u0435 \u043F\u0440\u043E\u0441\u043B\u044B\u043B \xAB\u0435\u0440\u0435\u0442\u0438\u043A\u043E\u043C\xBB
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u041E\u043D\u0438
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438 \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0443
    \u0431\u0435\u0441\u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0438 \u0447\u0443\u0442\u044C \u043D\u0435 \u0441\u043E\u0440\u0432\u0430\u043B\u0438
    \u0441\u0432\u0430\u0434\u044C\u0431\u0443. \u041A\u0430\u043D\u0442\u043E\u0440
    \u043D\u0430\u0441\u0442\u043E\u044F\u043B \u043D\u0430 \u0441\u0432\u043E\u0451\u043C,
    \u043D\u043E \u044D\u0442\u043E\u0442 \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442
    \u0441 \u0440\u043E\u0434\u043D\u0435\u0439 \u0436\u0435\u043D\u044B \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u043B
    \u0435\u043C\u0443 \u043D\u0435\u0440\u0432\u043D\u043E\u0433\u043E \u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u0438\u044F. 
    ---  ### 3. \u0414\u0435\u0442\u0438 \u0438 \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u0439
    \u0431\u044B\u0442 \u0432 \u0413\u0430\u043B\u043B\u0435 \u0413\u0435\u043E\u0440\u0433
    \u0438 \u0412\u0430\u043B\u043B\u0438 \u043F\u0440\u043E\u0436\u0438\u043B\u0438
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0431\u043E\u043B\u0435\u0435 40 \u043B\u0435\u0442.
    \u0423 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C **\u0448\u0435\u0441\u0442\u0435\u0440\u043E
    \u0434\u0435\u0442\u0435\u0439**, \u043D\u043E \u0432\u044B\u0436\u0438\u043B\u043E
    \u0438 \u0434\u043E\u0441\u0442\u0438\u0433\u043B\u043E \u0437\u0440\u0435\u043B\u043E\u0433\u043E
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0430 \u043F\u044F\u0442\u0435\u0440\u043E
    (\u043E\u0434\u0438\u043D \u0440\u0435\u0431\u0435\u043D\u043E\u043A \u0443\u043C\u0435\u0440
    \u0432 \u043C\u043B\u0430\u0434\u0435\u043D\u0447\u0435\u0441\u0442\u0432\u0435). 
    *   **\u0416\u0438\u043B\u0438\u0449\u043D\u044B\u0435 \u0443\u0441\u043B\u043E\u0432\u0438\u044F:**
    \u0421\u0435\u043C\u044C\u044F \u0436\u0438\u043B\u0430 \u0432 \u0413\u0430\u043B\u043B\u0435
    \u0432 \u0434\u043E\u043C\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u0441\u043B\u0443\u0436\u0438\u043B \u043C\u0435\u0441\u0442\u043E\u043C \u0440\u0430\u0431\u043E\u0442\u044B
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430. \u041A\u0430\u0431\u0438\u043D\u0435\u0442
    \u0413\u0435\u043E\u0440\u0433\u0430 \u0431\u044B\u043B \u0437\u0430\u0432\u0430\u043B\u0435\u043D
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044F\u043C\u0438, \u043A\u043D\u0438\u0433\u0430\u043C\u0438
    \u0438 \u043F\u0438\u0441\u044C\u043C\u0430\u043C\u0438. \u0414\u0435\u043D\u0435\u0433
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u0432\u0441\u0435\u0433\u0434\u0430 \u0431\u044B\u043B\u043E
    \u0432 \u043E\u0431\u0440\u0435\u0437, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C (\u043E\u043A\u043B\u0430\u0434
    \u0432 \u0413\u0430\u043B\u043B\u0435 \u0431\u044B\u043B \u043D\u0438\u0437\u043A\u0438\u043C,
    \u0438 \u041A\u0430\u043D\u0442\u043E\u0440 \u043D\u0435 \u0443\u043C\u0435\u043B
    \u0442\u043E\u0440\u0433\u043E\u0432\u0430\u0442\u044C\u0441\u044F \u0437\u0430
    \u043F\u0440\u0438\u0431\u0430\u0432\u043A\u0438). *   **\u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0434\u0435\u0442\u044C\u043C\u0438:** \u041A\u0430\u043D\u0442\u043E\u0440
    \u0431\u044B\u043B \u043E\u0447\u0435\u043D\u044C \u043B\u044E\u0431\u044F\u0449\u0438\u043C
    \u043E\u0442\u0446\u043E\u043C. \u041E\u043D \u0447\u0430\u0441\u0442\u043E \u0438\u0433\u0440\u0430\u043B
    \u0441 \u0434\u0435\u0442\u044C\u043C\u0438, \u0443\u0447\u0438\u043B \u0438\u0445
    \u043C\u0443\u0437\u044B\u043A\u0435. \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E
    \u043F\u0435\u0440\u0438\u043E\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \xAB\u0443\u0445\u043E\u0434\u044B \u0432 \u0441\u0435\u0431\u044F\xBB \u0438
    \u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u0438 \u043F\u0443\u0433\u0430\u043B\u0438
    \u0434\u0435\u0442\u0435\u0439. \u0412 \u043C\u0438\u043D\u0443\u0442\u044B \u043F\u0440\u043E\u0441\u0432\u0435\u0442\u043B\u0435\u043D\u0438\u044F
    \u043E\u043D \u0431\u044B\u043B \u0434\u0443\u0448\u043E\u0439 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u0438,
    \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u044B\u043C \u0441\u043E\u0431\u0435\u0441\u0435\u0434\u043D\u0438\u043A\u043E\u043C;
    \u0432 \u043C\u0438\u043D\u0443\u0442\u044B \u043A\u0440\u0438\u0437\u0438\u0441\u0430
    \u2014 \u0437\u0430\u043F\u0438\u0440\u0430\u043B\u0441\u044F \u0432 \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u0435,
    \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u044F\u0441\u044C \u043E\u0442
    \u0435\u0434\u044B \u0438 \u043E\u0431\u0449\u0435\u043D\u0438\u044F. *   **\u0422\u0440\u0430\u0433\u0435\u0434\u0438\u044F
    1899 \u0433\u043E\u0434\u0430:** \u041F\u0438\u043A \u043B\u0438\u0447\u043D\u043E\u0439
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438 \u043F\u0440\u0438\u0448\u0435\u043B\u0441\u044F
    \u043D\u0430 \u043A\u043E\u043D\u0435\u0446 \u0432\u0435\u043A\u0430. \u0415\u0433\u043E
    \u043C\u043B\u0430\u0434\u0448\u0438\u0439 \u0438, \u043F\u043E \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F\u043C,
    \u0441\u0430\u043C\u044B\u0439 \u043B\u044E\u0431\u0438\u043C\u044B\u0439 \u0441\u044B\u043D
    **\u0420\u0443\u0434\u043E\u043B\u044C\u0444** \u0432\u043D\u0435\u0437\u0430\u043F\u043D\u043E
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u043E\u043A\u043E\u043B\u043E 17 \u043B\u0435\u0442 (\u043F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0434\u0430\u043D\u043D\u044B\u043C \u2014 \u043F\u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0441 \u0441\u043E\u0431\u043E\u0439, \u043F\u043E \u0434\u0440\u0443\u0433\u0438\u043C
    \u2014 \u0443\u043C\u0435\u0440 \u043E\u0442 \u0431\u043E\u043B\u0435\u0437\u043D\u0438).
    \u0414\u043B\u044F \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u044D\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\u043E\u0439.
    \u0418\u043C\u0435\u043D\u043D\u043E \u043F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0439
    \u043F\u043E\u0442\u0435\u0440\u0438 \u0435\u0433\u043E \u043F\u0441\u0438\u0445\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435, \u0438 \u0431\u0435\u0437 \u0442\u043E\u0433\u043E
    \u0448\u0430\u0442\u043A\u043E\u0435, \u0434\u0430\u043B\u043E \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0442\u0440\u0435\u0449\u0438\u043D\u0443.  ---  ### 4. \u0414\u0440\u0443\u0437\u044C\u044F
    \u0438 \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u0435: \u041E\u0441\u0442\u0440\u043E\u0432\u0430
    \u0442\u0435\u043F\u043B\u0430 \u0432 \u043E\u043A\u0435\u0430\u043D\u0435 \u043A\u0440\u0438\u0442\u0438\u043A\u0438
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E
    \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E \u043A\u043E\u043B\u043B\u0435\u0433
    \u043E\u0442\u0432\u0435\u0440\u0433\u0430\u043B\u0438 \u0435\u0433\u043E \u0438\u0434\u0435\u0438,
    \u041A\u0430\u043D\u0442\u043E\u0440 \u043E\u0431\u043B\u0430\u0434\u0430\u043B
    \u0434\u0430\u0440\u043E\u043C \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u0430\u0442\u044C
    \u043B\u044E\u0434\u0435\u0439 \u0432 \u043B\u0438\u0447\u043D\u043E\u043C \u043E\u0431\u0449\u0435\u043D\u0438\u0438.  
    *   **\u0420\u0438\u0445\u0430\u0440\u0434 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434:**
    \u042D\u0442\u043E \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0434\u0440\u0443\u0433, \u0430 \xAB\u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F \u0434\u0443\u0448\u0430\xBB.
    \u0418\u0445 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430 \u0434\u043B\u0438\u043B\u0430\u0441\u044C
    \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F. \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u0431\u044B\u043B \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043A\u0440\u0443\u043F\u043D\u044B\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u043D\u0438\u043C\u0430\u043B
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u0441 \u043F\u043E\u043B\u0443\u0441\u043B\u043E\u0432\u0430
    \u0438 \u043D\u0435 \u0434\u0430\u043B \u0435\u043C\u0443 \u0441\u043E\u0439\u0442\u0438
    \u0441 \u0443\u043C\u0430 \u0432 1870-\u0435 \u0433\u043E\u0434\u044B. \u041E\u043D\u0438
    \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u043B\u0438 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443, \u043D\u043E \u0438
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E, \u0440\u0435\u043B\u0438\u0433\u0438\u044E.
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434 \u043C\u044F\u0433\u043A\u043E,
    \u043D\u043E \u043D\u0430\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E \u043F\u043E\u043F\u0440\u0430\u0432\u043B\u044F\u043B
    \u043E\u0448\u0438\u0431\u043A\u0438 \u041A\u0430\u043D\u0442\u043E\u0440\u0430,
    \u0438 \u0413\u0435\u043E\u0440\u0433 \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B
    \u044D\u0442\u043E \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0442 \u043D\u0435\u0433\u043E.
    *   **\u0414\u0440\u0443\u0437\u044C\u044F-\u0442\u0435\u043E\u043B\u043E\u0433\u0438:**
    \u0412 \u0413\u0430\u043B\u043B\u0435, \u0431\u0443\u0434\u0443\u0447\u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u0432\u0435\u0440\u0443\u044E\u0449\u0438\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0442\u0435\u0441\u043D\u043E \u043E\u0431\u0449\u0430\u043B\u0441\u044F
    \u0441 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430\u043C\u0438
    \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0430. \u041E\u043D \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E
    \u0437\u0430\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043B \u0438\u0445 \u043F\u0438\u0441\u044C\u043C\u0430\u043C\u0438,
    \u043F\u044B\u0442\u0430\u044F\u0441\u044C \u0441\u043E\u0433\u043B\u0430\u0441\u043E\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u044E \u0442\u0435\u043E\u0440\u0438\u044E \u0430\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438
    \u0441 \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0441\u043A\u0438\u043C
    \u0434\u043E\u0433\u043C\u0430\u0442\u043E\u043C \u043E \u0442\u043E\u043C, \u0447\u0442\u043E
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u0435\u043D \u0442\u043E\u043B\u044C\u043A\u043E
    \u0411\u043E\u0433. \u041E\u043D \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0435
    \u0432\u0435\u0440\u0438\u043B, \u0447\u0442\u043E \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u2014 \u044D\u0442\u043E \u043F\u043E\u0441\u043B\u0430\u043D\u0438\u0435 \u0411\u043E\u0433\u0430
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0443, \u0447\u0442\u043E\u0431\u044B
    \u043B\u044E\u0434\u0438 \u043F\u043E\u043D\u044F\u043B\u0438 \u0432\u0435\u043B\u0438\u0447\u0438\u0435
    \u0422\u0432\u043E\u0440\u0446\u0430. *   **\u041C\u043E\u043B\u043E\u0434\u044B\u0435
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0438:**
    \u0412 \u043A\u043E\u043D\u0446\u0435 \u0436\u0438\u0437\u043D\u0438 \u0443 \u043D\u0435\u0433\u043E
    \u043F\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C \u0443\u0447\u0435\u043D\u0438\u043A\u0438
    \u0438 \u0437\u0430\u0449\u0438\u0442\u043D\u0438\u043A\u0438 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0424\u0435\u043B\u0438\u043A\u0441 \u0411\u0435\u0440\u043D\u0448\u0442\u0435\u0439\u043D,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u043C\u043E\u0433\u0430\u043B
    \u0435\u043C\u0443 \u0441 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C\u0438).
    \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u043D\u0438\u043C\u0438
    \u0431\u044B\u043B\u0438 \u043F\u043E\u0447\u0442\u0438 \u043E\u0442\u0435\u0447\u0435\u0441\u043A\u0438\u043C\u0438. 
    ---  ### 5. \u041F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442 \u0438 \u043E\u0434\u0435\u0440\u0436\u0438\u043C\u043E\u0441\u0442\u0438
    \u0411\u0438\u043E\u0433\u0440\u0430\u0444\u044B (\u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0418\u0440\u0432\u0438\u043D\u0433) \u043E\u0442\u043C\u0435\u0447\u0430\u044E\u0442
    \u0443 \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u044F\u0432\u043D\u044B\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043A\u0438 **\u0431\u0438\u043F\u043E\u043B\u044F\u0440\u043D\u043E\u0433\u043E
    \u0430\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430**
    (\u0440\u0430\u043D\u0435\u0435 \u2014 \u043C\u0430\u043D\u0438\u0430\u043A\u0430\u043B\u044C\u043D\u043E-\u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u0432\u043D\u044B\u0439
    \u043F\u0441\u0438\u0445\u043E\u0437).  *   **\u041C\u0430\u043D\u0438\u0430\u043A\u0430\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u0437\u044B:** \u0412 \u043F\u0435\u0440\u0438\u043E\u0434\u044B
    \u043F\u043E\u0434\u044A\u0435\u043C\u0430 \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043F\u043E 15\u201318 \u0447\u0430\u0441\u043E\u0432 \u0432 \u0441\u0443\u0442\u043A\u0438,
    \u043F\u0438\u0441\u0430\u043B \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0435
    \u043F\u0438\u0441\u044C\u043C\u0430 (\u0438\u043D\u043E\u0433\u0434\u0430 \u043F\u043E
    50 \u043F\u0438\u0441\u0435\u043C \u0432 \u0434\u0435\u043D\u044C), \u043C\u043E\u0433
    \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u0442\u044C \u0441 \u043B\u0435\u043A\u0446\u0438\u044F\u043C\u0438
    \u0447\u0430\u0441\u0430\u043C\u0438 \u0431\u0435\u0437 \u043F\u0435\u0440\u0435\u0440\u044B\u0432\u0430.
    \u0412 \u044D\u0442\u0438 \u043C\u043E\u043C\u0435\u043D\u0442\u044B \u043E\u043D
    \u0432\u0435\u0440\u0438\u043B, \u0447\u0442\u043E \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044F
    \u2014 \u044D\u0442\u043E \u0434\u0430\u0440 \u0441\u0432\u044B\u0448\u0435,
    \u0438 \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043E\u0431\u0440\u0430\u0442\u0438\u0442\u044C
    \u0432 \u0441\u0432\u043E\u044E \u0432\u0435\u0440\u0443 \u0432\u0441\u0435\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u043C\u0438\u0440\u0430.
    *   **\u0414\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u0432\u043D\u044B\u0435
    \u0444\u0430\u0437\u044B:** \u0421\u043C\u0435\u043D\u044F\u043B\u0438\u0441\u044C
    \u043F\u043E\u043B\u043D\u043E\u0439 \u0430\u043F\u0430\u0442\u0438\u0435\u0439.
    \u041E\u043D \u043D\u0435 \u043C\u043E\u0433 \u0432\u0441\u0442\u0430\u0442\u044C
    \u0441 \u043A\u0440\u043E\u0432\u0430\u0442\u0438, \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F
    \u043E\u0442 \u043F\u0438\u0449\u0438, \u043D\u0435 \u043C\u043E\u0433 \u0447\u0438\u0442\u0430\u0442\u044C.
    \u041E\u043D \u0436\u0430\u043B\u043E\u0432\u0430\u043B\u0441\u044F \u0412\u0430\u043B\u043B\u0438,
    \u0447\u0442\u043E \u0435\u0433\u043E \u043C\u043E\u0437\u0433 \"\u0432\u044B\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F\",
    \u043A\u0430\u043A \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C. *   **\u0423\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435
    \u0448\u0435\u043A\u0441\u043F\u0438\u0440\u043E\u0432\u0441\u043A\u0438\u043C
    \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u043C:** \u0412 \u0441\u0432\u043E\u0438
    \xAB\u043D\u0435-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435\xBB
    \u0433\u043E\u0434\u044B (\u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0441
    1884 \u043F\u043E 1890-\u0435) \u043E\u043D \u0432\u043F\u0430\u043B \u0432 \u0441\u0432\u043E\u0435\u043E\u0431\u0440\u0430\u0437\u043D\u0443\u044E
    \u043E\u0434\u0435\u0440\u0436\u0438\u043C\u043E\u0441\u0442\u044C \u2014 **\u0448\u0435\u043A\u0441\u043F\u0438\u0440\u043E\u0432\u0441\u043A\u0438\u0439
    \u0432\u043E\u043F\u0440\u043E\u0441**. \u041E\u043D \u043F\u043E\u0442\u0440\u0430\u0442\u0438\u043B
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435 \u0434\u0435\u043D\u044C\u0433\u0438
    \u043D\u0430 \u0438\u0437\u0434\u0430\u043D\u0438\u0435 \u0434\u0432\u0443\u0445
    \u0431\u0440\u043E\u0448\u044E\u0440, \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \xAB\u0441\u0442\u0440\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\xBB
    \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B, \u0447\u0442\u043E \u0430\u0432\u0442\u043E\u0440\u043E\u043C
    \u043F\u044C\u0435\u0441 \u0428\u0435\u043A\u0441\u043F\u0438\u0440\u0430 \u043D\u0430
    \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435 \u0431\u044B\u043B \u0444\u0438\u043B\u043E\u0441\u043E\u0444
    \u0424\u0440\u044D\u043D\u0441\u0438\u0441 \u0411\u044D\u043A\u043E\u043D. \u041A\u043E\u043B\u043B\u0435\u0433\u0438
    \u0441\u0447\u0438\u0442\u0430\u043B\u0438 \u044D\u0442\u043E \u0441\u0443\u043C\u0430\u0441\u0448\u0435\u0441\u0442\u0432\u0438\u0435\u043C,
    \u043D\u043E \u0434\u043B\u044F \u0441\u0430\u043C\u043E\u0433\u043E \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    \u044D\u0442\u043E \u0431\u044B\u043B \u0441\u043F\u043E\u0441\u043E\u0431 \u043E\u0442\u0432\u043B\u0435\u0447\u044C\u0441\u044F
    \u043E\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0440\u0430\u0432\u043C \u0438 \u0434\u0430\u0442\u044C \u0432\u044B\u0445\u043E\u0434
    \u0441\u0432\u043E\u0435\u043C\u0443 \u043F\u043E\u043B\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0434\u0430\u0440\u0443.  ---  ### 6. \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B (1908\u20131918): \u041E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u043E
    \u0432 \u0441\u0442\u0435\u043D\u0430\u0445 \u043A\u043B\u0438\u043D\u0438\u043A\u0438
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u0435
    \u0436\u0438\u0437\u043D\u0438 \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u0431\u044B\u043B\u043E
    \u0441\u0430\u043C\u044B\u043C \u043F\u0435\u0447\u0430\u043B\u044C\u043D\u044B\u043C. 
    *   **\u041F\u0435\u0440\u0432\u0430\u044F \u043C\u0438\u0440\u043E\u0432\u0430\u044F
    \u0432\u043E\u0439\u043D\u0430:** \u0412\u043E\u0439\u043D\u0430 \u0443\u0441\u0443\u0433\u0443\u0431\u0438\u043B\u0430
    \u0435\u0433\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435. \u0418\u043D\u0444\u043B\u044F\u0446\u0438\u044F
    \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u043B\u0430 \u0441\u0431\u0435\u0440\u0435\u0436\u0435\u043D\u0438\u044F
    \u0441\u0435\u043C\u044C\u0438. \u041A\u0430\u043D\u0442\u043E\u0440, \u044F\u0440\u044B\u0439
    \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0439 \u043F\u0430\u0442\u0440\u0438\u043E\u0442,
    \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u043D\u043D\u043E \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u043B
    \u043D\u043E\u0432\u043E\u0441\u0442\u0438 \u0441 \u0444\u0440\u043E\u043D\u0442\u043E\u0432,
    \u0445\u043E\u0442\u044F \u0435\u0433\u043E \u0441\u044B\u043D\u043E\u0432\u044C\u044F
    \u0432\u043E\u0435\u0432\u0430\u043B\u0438. *   **\u041F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u0430\u044F
    \u0433\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u044F:**
    \u0421 1908 \u0433\u043E\u0434\u0430 \u043E\u043D \u043F\u043E\u0447\u0442\u0438
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 **\u041D\u0435\u0440\u0432\u043D\u043E\u0439 \u043A\u043B\u0438\u043D\u0438\u043A\u0435
    (Nervenheilanstalt) \u0432 \u0413\u0430\u043B\u043B\u0435**. \u0423\u0441\u043B\u043E\u0432\u0438\u044F
    \u0442\u0430\u043C \u0431\u044B\u043B\u0438 \u0441\u043F\u0430\u0440\u0442\u0430\u043D\u0441\u043A\u0438\u043C\u0438.
    \u041E\u043D \u0447\u0430\u0441\u0442\u043E \u043D\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B
    \u0436\u0435\u043D\u0443 \u0438 \u0434\u0435\u0442\u0435\u0439, \u043A\u043E\u0433\u0434\u0430
    \u043E\u043D\u0438 \u0435\u0433\u043E \u043D\u0430\u0432\u0435\u0449\u0430\u043B\u0438,
    \u043F\u043E\u0433\u0440\u0443\u0436\u0430\u044F\u0441\u044C \u0432 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u043C\u0438\u0440. *   **\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0434\u043D\u0438:** \u0412 1917 \u0433\u043E\u0434\u0443 \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435 \u043F\u0438\u0441\u044C\u043C\u043E
    \u0441\u0432\u043E\u0435\u043C\u0443 \u0434\u0440\u0443\u0433\u0443-\u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0443,
    \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0430\u044F \u043E \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438
    \u0411\u043E\u0433\u0430. \u041E\u043D \u0443\u0436\u0435 \u043F\u043E\u0447\u0442\u0438
    \u043D\u0435 \u0433\u043E\u0432\u043E\u0440\u0438\u043B. **6 \u044F\u043D\u0432\u0430\u0440\u044F
    1918 \u0433\u043E\u0434\u0430** \u0413\u0435\u043E\u0440\u0433 \u041A\u0430\u043D\u0442\u043E\u0440
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u043E\u0442 \u043E\u0441\u0442\u0440\u043E\u0439
    \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u043E\u0439 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438
    \u043F\u0440\u044F\u043C\u043E \u0432 \u043A\u043B\u0438\u043D\u0438\u043A\u0435. 
    *   **\u041F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u0439 \u043F\u043E\u0437\u043E\u0440:**
    \u041F\u043E \u0438\u0440\u043E\u043D\u0438\u0438 \u0441\u0443\u0434\u044C\u0431\u044B,
    \u0435\u0433\u043E \u0442\u0435\u043B\u043E \u0431\u044B\u043B\u043E \u043F\u0440\u0435\u0434\u0430\u043D\u043E
    \u0437\u0435\u043C\u043B\u0435 \u043D\u0430 \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u043C
    \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435 \u0413\u0430\u043B\u043B\u0435
    \u0441 \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u043F\u043E\u0447\u0435\u0441\u0442\u044F\u043C\u0438. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0438\u0440 \u0432 \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442
    \u0431\u044B\u043B \u043F\u043E\u0433\u043B\u043E\u0449\u0435\u043D \u0432\u043E\u0439\u043D\u043E\u0439,
    \u0430 \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0438\u0443\u043C\u0444
    (\u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432) \u0441\u043B\u0443\u0447\u0438\u043B\u0441\u044F
    \u0443\u0436\u0435 \u0441\u043F\u0443\u0441\u0442\u044F \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438,
    \u0432 1930-\u0435 \u0433\u043E\u0434\u044B, \u043A\u043E\u0433\u0434\u0430 \u0414\u0430\u0432\u0438\u0434
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u043F\u0440\u043E\u0432\u043E\u0437\u0433\u043B\u0430\u0441\u0438\u043B
    \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0435\u043C.  ---  ### 7. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0438\u0437 \u043F\u043E\u0432\u0441\u0435\u0434\u043D\u0435\u0432\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0427\u0442\u043E\u0431\u044B \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u044C
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442, \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0448\u0442\u0440\u0438\u0445\u043E\u0432 \u043A \u0435\u0433\u043E \u043F\u043E\u0432\u0441\u0435\u0434\u043D\u0435\u0432\u043D\u043E\u043C\u0443
    \u0431\u044B\u0442\u0443:  *   **\u0412\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0441\u0442\u0432\u043E:**
    \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u043E\u043D \u0441\u0442\u0430\u043B \u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0446\u0435\u043C
    \u043F\u043E \u044D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u0441\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F\u043C,
    \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u043A\u0440\u0430\u0439\u043D\u0435
    \u0440\u0435\u0434\u043A\u043E \u0434\u043B\u044F \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0445
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u0432 \u0442\u043E\u0439
    \u044D\u043F\u043E\u0445\u0438. *   **\u041E\u0434\u0435\u0436\u0434\u0430:**
    \u041E\u043D \u0431\u044B\u043B \u043E\u0447\u0435\u043D\u044C \u0440\u0430\u0441\u0441\u0435\u044F\u043D
    \u0432 \u043E\u0434\u0435\u0436\u0434\u0435. \u041C\u043E\u0433 \u0432\u044B\u0439\u0442\u0438
    \u043D\u0430 \u0443\u043B\u0438\u0446\u0443 \u0432 \u0434\u043E\u043C\u0430\u0448\u043D\u0438\u0445
    \u0442\u0430\u043F\u043E\u0447\u043A\u0430\u0445 \u0438\u043B\u0438 \u0440\u0430\u0437\u043D\u044B\u0445
    \u043D\u043E\u0441\u043A\u0430\u0445, \u0435\u0441\u043B\u0438 \u0431\u044B\u043B
    \u043F\u043E\u0433\u043B\u043E\u0449\u0435\u043D \u043C\u044B\u0441\u043B\u044C\u044E
    \u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435.
    *   **\u041F\u0438\u0441\u044C\u043C\u0430:** \u041E\u043D \u0431\u044B\u043B
    \u043E\u0434\u0435\u0440\u0436\u0438\u043C \u044D\u043F\u0438\u0441\u0442\u043E\u043B\u044F\u0440\u043D\u044B\u043C
    \u0436\u0430\u043D\u0440\u043E\u043C. \u041E\u043D \u043F\u0438\u0441\u0430\u043B
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C,
    \u043D\u043E \u0438 \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0430\u043C,
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430\u043C, \u043F\u0430\u043F\u0435
    \u0440\u0438\u043C\u0441\u043A\u043E\u043C\u0443 \u041B\u044C\u0432\u0443 XIII
    (\u043F\u044B\u0442\u0430\u044F\u0441\u044C \u0443\u0431\u0435\u0434\u0438\u0442\u044C
    \u0412\u0430\u0442\u0438\u043A\u0430\u043D \u0432 \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0441\u0442\u0438
    \u0441\u0432\u043E\u0435\u0439 \u0442\u0435\u043E\u0440\u0438\u0438 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438).
    \u041F\u043E\u043B\u0443\u0447\u0430\u044F \u043E\u0442\u043A\u0430\u0437, \u043E\u043D
    \u0432\u043F\u0430\u0434\u0430\u043B \u0432 \u044F\u0440\u043E\u0441\u0442\u044C.
    *   **\u0421\u043A\u0440\u0438\u043F\u043A\u0430:** \u0412 \u043A\u043B\u0438\u043D\u0438\u043A\u0435
    \u0432\u0440\u0430\u0447\u0438 \u0440\u0430\u0437\u0440\u0435\u0448\u0430\u043B\u0438
    \u0435\u043C\u0443 \u0438\u0433\u0440\u0430\u0442\u044C \u043D\u0430 \u0441\u043A\u0440\u0438\u043F\u043A\u0435,
    \u0442\u0430\u043A \u043A\u0430\u043A \u044D\u0442\u043E \u0431\u044B\u043B \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0441\u043F\u043E\u0441\u043E\u0431 \xAB\u0434\u043E\u0441\u0442\u0443\u0447\u0430\u0442\u044C\u0441\u044F\xBB
    \u0434\u043E \u0435\u0433\u043E \u0441\u043E\u0437\u043D\u0430\u043D\u0438\u044F.
    \u0418\u0433\u0440\u0430\u044F \u0411\u0435\u0442\u0445\u043E\u0432\u0435\u043D\u0430
    \u0438 \u0411\u0430\u0445\u0430, \u043E\u043D \u043D\u0430 \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0435
    \u0447\u0430\u0441\u044B \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u043B\u0441\u044F
    \u0432 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C, \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0441\u044F
    \u0432\u043D\u043E\u0432\u044C \u0442\u0435\u043C \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u044B\u043C
    \u0438 \u043C\u044F\u0433\u043A\u0438\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043B\u044E\u0431\u0438\u043B\u0430
    \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u044F.  \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u2014
    \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E \u0442\u043E\u043C,
    \u043A\u0430\u043A \u0446\u0435\u043D\u0430 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C \u043D\u0435\u043F\u043E\u043C\u0435\u0440\u043D\u043E
    \u0432\u044B\u0441\u043E\u043A\u043E\u0439. \u041E\u043D \u043E\u0442\u0434\u0430\u043B
    \u0441\u0432\u043E\u0439 \u0440\u0430\u0437\u0443\u043C \u0440\u0430\u0434\u0438
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E\u0431\u044B \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u043E
    \u043D\u0430\u0443\u0447\u0438\u043B\u043E\u0441\u044C \u0432\u0438\u0434\u0435\u0442\u044C
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C."
  personalLifeEn: 
  shortBioRu: "\u0413\u0435\u043E\u0440\u0433 \u041A\u0430\u043D\u0442\u043E\u0440
    (1845\u20131918) \u2014 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0438 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438.
    \u0415\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u2014
    \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u043E\u0437\u0440\u0435\u043D\u0438\u0439, \u043E\u0436\u0435\u0441\u0442\u043E\u0447\u0451\u043D\u043D\u044B\u0445
    \u0441\u043F\u043E\u0440\u043E\u0432 \u0441 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438
    \u0438 \u0442\u044F\u0436\u0451\u043B\u043E\u0439 \u043B\u0438\u0447\u043D\u043E\u0439
    \u0431\u043E\u0440\u044C\u0431\u044B. \u041F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u044E
    \u0432\u0430\u043C \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439 \u043E\u0431\u0437\u043E\u0440
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438 \u0438 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430. 
    ### \U0001F30D \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u044E\u043D\u043E\u0441\u0442\u044C:
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433 \u2013 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044F 
    \u0413\u0435\u043E\u0440\u0433 \u041A\u0430\u043D\u0442\u043E\u0440 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    **3 \u043C\u0430\u0440\u0442\u0430 (19 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    \u043F\u043E \u0441\u0442\u0430\u0440\u043E\u043C\u0443 \u0441\u0442\u0438\u043B\u044E)
    1845 \u0433\u043E\u0434\u0430 \u0432 \u0421\u0430\u043D\u043A\u0442-\u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0435**,
    \u0432 \u0417\u0430\u043F\u0430\u0434\u043D\u043E\u0439 \u043A\u0443\u043F\u0435\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u043E\u043B\u043E\u043D\u0438\u0438. \u041E\u043D \u0431\u044B\u043B \u0441\u0442\u0430\u0440\u0448\u0438\u043C
    \u0438\u0437 \u0448\u0435\u0441\u0442\u0438 \u0434\u0435\u0442\u0435\u0439 \u0432
    \u0441\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0438 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u043E\u0439 \u0441\u0435\u043C\u044C\u0435. 
    *   **\u0421\u0435\u043C\u044C\u044F:** \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u0413\u0435\u043E\u0440\u0433-\u0412\u043E\u043B\u044C\u0434\u0435\u043C\u0430\u0440
    \u041A\u0430\u043D\u0442\u043E\u0440, \u0431\u044B\u043B \u0434\u0430\u0442\u0441\u043A\u0438\u043C
    \u043F\u043E\u0434\u0434\u0430\u043D\u043D\u044B\u043C, \u0443\u0441\u043F\u0435\u0448\u043D\u044B\u043C
    \u0431\u0438\u0440\u0436\u0435\u0432\u044B\u043C \u043C\u0430\u043A\u043B\u0435\u0440\u043E\u043C,
    \u0440\u043E\u0434\u043E\u043C \u0438\u0437 \u0441\u0435\u043C\u044C\u0438 \u043F\u043E\u0440\u0442\u0443\u0433\u0430\u043B\u044C\u0441\u043A\u0438\u0445
    \u0435\u0432\u0440\u0435\u0435\u0432, \u043E\u0441\u0435\u0432\u0448\u0438\u0445
    \u0432 \u0410\u043C\u0441\u0442\u0435\u0440\u0434\u0430\u043C\u0435. \u041C\u0430\u0442\u044C,
    \u041C\u0430\u0440\u0438\u044F-\u0410\u043D\u043D\u0430 \u0411\u0451\u043C, \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0430
    \u0438\u0437 \u0441\u0435\u043C\u044C\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u043C\u0443\u0437\u044B\u043A\u0430\u043D\u0442\u043E\u0432; \u0435\u0451 \u0434\u044F\u0434\u044F
    \u0431\u044B\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u043C
    \u0441\u043A\u0440\u0438\u043F\u0430\u0447\u043E\u043C \u0419\u043E\u0437\u0435\u0444\u043E\u043C
    \u0411\u0451\u043C\u043E\u043C. \u0421\u0430\u043C \u0413\u0435\u043E\u0440\u0433
    \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u043B\u044E\u0431\u043E\u0432\u044C
    \u043A \u043C\u0443\u0437\u044B\u043A\u0435 \u0438 \u0432\u0438\u0440\u0442\u0443\u043E\u0437\u043D\u043E
    \u0438\u0433\u0440\u0430\u043B \u043D\u0430 \u0441\u043A\u0440\u0438\u043F\u043A\u0435.
    *   **\u041F\u0435\u0440\u0435\u0435\u0437\u0434:** \u0412 1856 \u0433\u043E\u0434\u0443,
    \u0438\u0437-\u0437\u0430 \u0431\u043E\u043B\u0435\u0437\u043D\u0438 \u043E\u0442\u0446\u0430,
    \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044E \u0432 \u043F\u043E\u0438\u0441\u043A\u0430\u0445
    \u0431\u043E\u043B\u0435\u0435 \u043C\u044F\u0433\u043A\u043E\u0433\u043E \u043A\u043B\u0438\u043C\u0430\u0442\u0430.
    \u041E\u043D\u0438 \u0436\u0438\u043B\u0438 \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u0432 \u0412\u0438\u0441\u0431\u0430\u0434\u0435\u043D\u0435, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0432\u043E \u0424\u0440\u0430\u043D\u043A\u0444\u0443\u0440\u0442\u0435. *  
    **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:** \u0412
    1860 \u0433\u043E\u0434\u0443 \u041A\u0430\u043D\u0442\u043E\u0440 \u0441 \u043E\u0442\u043B\u0438\u0447\u0438\u0435\u043C
    \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0435
    \u0443\u0447\u0438\u043B\u0438\u0449\u0435 \u0432 \u0414\u0430\u0440\u043C\u0448\u0442\u0430\u0434\u0442\u0435,
    \u043F\u0440\u043E\u044F\u0432\u0438\u0432 \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u043A \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0438.
    \u0412 1862 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0424\u0435\u0434\u0435\u0440\u0430\u043B\u044C\u043D\u044B\u0439 \u043F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u0432 \u0426\u044E\u0440\u0438\u0445\u0435,
    \u043D\u043E \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u043E\u0442\u0446\u0430 \u0432 1863 \u0433\u043E\u0434\u0443, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0441\u043E\u043B\u0438\u0434\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E,
    \u043F\u0435\u0440\u0435\u0432\u0451\u043B\u0441\u044F \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442.  \u0412 \u0411\u0435\u0440\u043B\u0438\u043D\u0435
    \u043E\u043D \u0441\u043B\u0443\u0448\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438
    \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438: **\u041A\u0430\u0440\u043B\u0430
    \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u0430**, **\u042D\u0440\u043D\u0441\u0442\u0430
    \u041A\u0443\u043C\u043C\u0435\u0440\u0430** \u0438 **\u041B\u0435\u043E\u043F\u043E\u043B\u044C\u0434\u0430
    \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440\u0430**. \u041B\u0435\u0442\u043E\u043C
    1866 \u0433\u043E\u0434\u0430 \u043E\u043D \u0442\u0430\u043A\u0436\u0435 \u0443\u0447\u0438\u043B\u0441\u044F
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. \u0412
    1867 \u0433\u043E\u0434\u0443 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u043F\u0440\u0438\u0441\u0432\u043E\u0438\u043B
    \u0435\u043C\u0443 \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0434\u043E\u043A\u0442\u043E\u0440\u0430
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u0437\u0430 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B. 
    ### \U0001F9D1\u200D\U0001F3EB \u041D\u0430\u0447\u0430\u043B\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B
    \u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u0448\u0430\u0433\u0438 \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432  \u0421\u0432\u043E\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u0430\u0440\u044C\u0435\u0440\u0443 \u041A\u0430\u043D\u0442\u043E\u0440
    \u043D\u0430\u0447\u0430\u043B \u0441 \u043D\u0435\u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u0439 \u0448\u043A\u043E\u043B\u0435
    \u0434\u043B\u044F \u0434\u0435\u0432\u043E\u0447\u0435\u043A. \u0412 1869 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043C\u0435\u0441\u0442\u043E
    \u0432 **\u0413\u0430\u043B\u043B\u044C\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435**
    (\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u041C\u0430\u0440\u0442\u0438\u043D\u0430
    \u041B\u044E\u0442\u0435\u0440\u0430), \u0433\u0434\u0435 \u0438 \u043F\u0440\u043E\u0448\u043B\u0430
    \u0432\u0441\u044F \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C.  *   **\u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0440\u043E\u0441\u0442:** \u0412 1872 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0441\u0442\u0430\u043B \u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C,
    \u0430 \u0432 1879 \u0433\u043E\u0434\u0443 \u2014 \u043F\u043E\u043B\u043D\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C. *   **\u0412\u0430\u0436\u043D\u043E\u0435
    \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E:** \u0412 1872 \u0433\u043E\u0434\u0443,
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043E\u0442\u043F\u0443\u0441\u043A\u0430
    \u0432 \u0428\u0432\u0435\u0439\u0446\u0430\u0440\u0438\u0438, \u041A\u0430\u043D\u0442\u043E\u0440
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F \u0441
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    **\u0420\u0438\u0445\u0430\u0440\u0434\u043E\u043C \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u043E\u043C**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0430\u043B \u0435\u0433\u043E
    \u0431\u043B\u0438\u0437\u043A\u0438\u043C \u0434\u0440\u0443\u0433\u043E\u043C
    \u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u0435\u0434\u0438\u043D\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u0438\u043A\u043E\u043C.
    \u041C\u043D\u043E\u0433\u0438\u0435 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0438\u0434\u0435\u0438 \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u0440\u043E\u0436\u0434\u0430\u043B\u0438\u0441\u044C
    \u0438 \u043E\u0442\u0442\u0430\u0447\u0438\u0432\u0430\u043B\u0438\u0441\u044C
    \u0432 \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0435\u0439 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435
    \u0441 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u043E\u043C. *   **\u041F\u0435\u0440\u0432\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B:** \u0412 1872 \u0433\u043E\u0434\u0443
    \u041A\u0430\u043D\u0442\u043E\u0440 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u0447\u0435\u0440\u0435\u0437 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B
    (\u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u0441 \u0434\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u043E\u0432\u044B\u043C\u0438
    \u0441\u0435\u0447\u0435\u043D\u0438\u044F\u043C\u0438).  ### \U0001F4A1 \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435: \u0442\u0435\u043E\u0440\u0438\u044F
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438 
    \u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u043C \u0441\u0442\u0430\u043B
    1874 \u0433\u043E\u0434, \u043A\u043E\u0433\u0434\u0430 \u041A\u0430\u043D\u0442\u043E\u0440
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0443,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0432\u0432\u0451\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    **\u043C\u043E\u0449\u043D\u043E\u0441\u0442\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430**
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u043C\u043E\u0433\u0443\u0442
    \u0431\u044B\u0442\u044C \u0440\u0430\u0437\u043D\u044B\u043C\u0438 \u043F\u043E
    \u0440\u0430\u0437\u043C\u0435\u0440\u0443.  *   **\u0421\u0447\u0451\u0442\u043D\u044B\u0435
    \u0438 \u043D\u0435\u0441\u0447\u0451\u0442\u043D\u044B\u0435 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430:**
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B
    **\u0441\u0447\u0451\u0442\u043D\u043E** (\u0442\u043E \u0435\u0441\u0442\u044C
    \u0435\u0433\u043E \u043C\u043E\u0436\u043D\u043E \u0432\u0437\u0430\u0438\u043C\u043D\u043E-\u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E
    \u0441\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C \u0441 \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0447\u0438\u0441\u043B\u0430\u043C\u0438), \u0430 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0432\u0441\u0435\u0445 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B **\u043D\u0435\u0441\u0447\u0451\u0442\u043D\u043E**.
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u0441\u0435\u043D\u0441\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435, \u043E\u0437\u043D\u0430\u0447\u0430\u0432\u0448\u0435\u0435,
    \u0447\u0442\u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043D\u0435 \u043E\u0434\u043D\u0430, \u0430 **\"\u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0435\u0439\"**.
    *   **\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441 \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438:**
    \u0412 1877 \u0433\u043E\u0434\u0443 \u041A\u0430\u043D\u0442\u043E\u0440 \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0435\u0449\u0451 \u043E\u0434\u0438\u043D \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442: \u043C\u0435\u0436\u0434\u0443
    \u0442\u043E\u0447\u043A\u0430\u043C\u0438 \u043E\u0442\u0440\u0435\u0437\u043A\u0430
    \u0438 \u0442\u043E\u0447\u043A\u0430\u043C\u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430
    (\u0438\u043B\u0438 \u0434\u0430\u0436\u0435 \u043A\u0443\u0431\u0430) \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0432\u0437\u0430\u0438\u043C\u043D\u043E-\u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E\u0435
    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435. \u042D\u0442\u043E
    \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E, \u0447\u0442\u043E \u0443 \u043E\u0434\u043D\u043E\u043C\u0435\u0440\u043D\u044B\u0445
    \u0438 \u0434\u0432\u0443\u043C\u0435\u0440\u043D\u044B\u0445 \u0444\u0438\u0433\u0443\u0440
    \u043E\u0434\u043D\u0430 \u0438 \u0442\u0430 \u0436\u0435 \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C.
    \u0421\u0430\u043C \u041A\u0430\u043D\u0442\u043E\u0440 \u043F\u0438\u0441\u0430\u043B
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0443: **\"\u042F \u0432\u0438\u0436\u0443
    \u044D\u0442\u043E, \u043D\u043E \u043D\u0435 \u0432\u0435\u0440\u044E \u0432
    \u044D\u0442\u043E!\"**.  \u042D\u0442\u0438 \u0438\u0434\u0435\u0438 \u043B\u0435\u0433\u043B\u0438
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 **\u0442\u0440\u0430\u043D\u0441\u0444\u0438\u043D\u0438\u0442\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B**, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E \u0438\u0437\u043B\u043E\u0436\u0438\u043B
    \u0432 \u0440\u0430\u0431\u043E\u0442\u0430\u0445 1879\u20131884 \u0433\u043E\u0434\u043E\u0432
    \u0438 \u0432 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u043C
    \u0442\u0440\u0443\u0434\u0435 **\"Beitr\xE4ge zur Begr\xFCndung der transfiniten
    Mengenlehre\" (\"\u041E\u0441\u043D\u043E\u0432\u044B \u0443\u0447\u0435\u043D\u0438\u044F
    \u043E \u0442\u0440\u0430\u043D\u0441\u0444\u0438\u043D\u0438\u0442\u043D\u044B\u0445
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430\u0445\", 1895\u20131897)**. 
    ### \u2694\uFE0F \u0411\u0438\u0442\u0432\u0430 \u0438\u0434\u0435\u0439: \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442
    \u0441 \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440\u043E\u043C \u0438 \u043D\u0435\u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u0422\u0435\u043E\u0440\u0438\u044F \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0430\u0441\u044C \u0441 \u044F\u0440\u043E\u0441\u0442\u043D\u044B\u043C
    \u0441\u043E\u043F\u0440\u043E\u0442\u0438\u0432\u043B\u0435\u043D\u0438\u0435\u043C.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u043E\u043F\u043F\u043E\u043D\u0435\u043D\u0442\u043E\u043C
    \u0441\u0442\u0430\u043B \u0431\u044B\u0432\u0448\u0438\u0439 \u0443\u0447\u0438\u0442\u0435\u043B\u044C,
    **\u041B\u0435\u043E\u043F\u043E\u043B\u044C\u0434 \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440**,
    \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u043B\u044F\u0432\u0448\u0438\u0439
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. 
    *   **\u041F\u0440\u0438\u0447\u0438\u043D\u0430 \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0430:**
    \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440 \u0431\u044B\u043B \u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043A\u043E\u043C
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u043C\u0438
    \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0431\u044A\u0435\u043A\u0442\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u043E\u0433\u0443\u0442 \u0431\u044B\u0442\u044C \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u044B
    \u0437\u0430 \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435 \u0447\u0438\u0441\u043B\u043E
    \u0448\u0430\u0433\u043E\u0432. \u041F\u043E\u043D\u044F\u0442\u0438\u0435 **\u0430\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438**
    \u0438 \u043D\u0435\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u0431\u044B\u043B\u0438 \u0434\u043B\u044F
    \u043D\u0435\u0433\u043E \u0430\u0431\u0441\u0443\u0440\u0434\u043D\u044B. \u041E\u043D
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    **\"\u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0448\u0430\u0440\u043B\u0430\u0442\u0430\u043D\u043E\u043C\"**,
    **\"\u0440\u0435\u043D\u0435\u0433\u0430\u0442\u043E\u043C\"** \u0438 **\"\u0440\u0430\u0441\u0442\u043B\u0438\u0442\u0435\u043B\u0435\u043C
    \u043C\u043E\u043B\u043E\u0434\u0451\u0436\u0438\"**. *   **\u041F\u0440\u0435\u043F\u044F\u0442\u0441\u0442\u0432\u0438\u044F
    \u0432 \u043A\u0430\u0440\u044C\u0435\u0440\u0435:** \u0418\u0437-\u0437\u0430
    \u0432\u043B\u0438\u044F\u043D\u0438\u044F \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440\u0430
    \u041A\u0430\u043D\u0442\u043E\u0440\u0443 \u043D\u0435 \u0443\u0434\u0430\u043B\u043E\u0441\u044C
    \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0435,
    \u0438 \u043E\u043D \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0432 \u0413\u0430\u043B\u043B\u0435,
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0435\u0433\u043E
    \u043C\u0435\u0447\u0442\u044B \u043E \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0435
    \u0432 \u0432\u0435\u0434\u0443\u0449\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442.
    \u0415\u0433\u043E \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u0441\u0442\u0430\u0442\u044C\u0438 \u0441 \u0442\u0440\u0443\u0434\u043E\u043C
    \u043F\u0440\u043E\u0431\u0438\u0432\u0430\u043B\u0438\u0441\u044C \u0432 \u043F\u0435\u0447\u0430\u0442\u044C. 
    \u041A\u0440\u0438\u0442\u0438\u043A\u0430 \u0431\u044B\u043B\u0430 \u0441\u0442\u043E\u043B\u044C
    \u043E\u0436\u0435\u0441\u0442\u043E\u0447\u0451\u043D\u043D\u043E\u0439, \u0447\u0442\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u043D\u0430\u0437\u0432\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    **\"\u0442\u044F\u0436\u0451\u043B\u043E\u0439 \u0431\u043E\u043B\u0435\u0437\u043D\u044C\u044E\"**,
    \u043F\u043E\u0440\u0430\u0437\u0438\u0432\u0448\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443.
    \u0422\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0437\u0436\u0435 \u0414\u0430\u0432\u0438\u0434
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441\u0451\u0442
    \u0441\u0432\u043E\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    \u0441\u043B\u043E\u0432\u0430: **\"\u041D\u0438\u043A\u0442\u043E \u043D\u0435
    \u0438\u0437\u0433\u043E\u043D\u0438\u0442 \u043D\u0430\u0441 \u0438\u0437 \u0440\u0430\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u043E\u0437\u0434\u0430\u043B
    \u041A\u0430\u043D\u0442\u043E\u0440\"**.  ### \U0001F494 \u041B\u0438\u0447\u043D\u0430\u044F
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F: \u0433\u043E\u0434\u044B \u0431\u043E\u043B\u0435\u0437\u043D\u0438
    \u0438 \u043F\u043E\u0437\u0434\u043D\u0435\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u0421 1884 \u0433\u043E\u0434\u0430 \u041A\u0430\u043D\u0442\u043E\u0440 \u0441\u0442\u0430\u043B
    \u0441\u0442\u0440\u0430\u0434\u0430\u0442\u044C \u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u043E\u0432 **\u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u0438**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u044B
    \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u044E\u0442 \u043A\u0430\u043A \u0441
    \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C \u043A\u0440\u0438\u0442\u0438\u043A\u0438,
    \u0442\u0430\u043A \u0438 \u0441 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u043C
    \u0431\u0438\u043F\u043E\u043B\u044F\u0440\u043D\u044B\u043C \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E\u043C. 
    *   **\u041D\u043E\u0432\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B:**
    \u0412 \u0442\u044F\u0436\u0451\u043B\u044B\u0435 \u043F\u0435\u0440\u0438\u043E\u0434\u044B
    \u043E\u043D \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0438 \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0435\u0439,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435\u043C,
    \u043F\u044B\u0442\u0430\u044F\u0441\u044C \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
    \u0447\u0442\u043E \u0430\u0432\u0442\u043E\u0440\u043E\u043C \u043F\u044C\u0435\u0441
    \u0428\u0435\u043A\u0441\u043F\u0438\u0440\u0430 \u0431\u044B\u043B \u0424\u0440\u044D\u043D\u0441\u0438\u0441
    \u0411\u044D\u043A\u043E\u043D (\u044D\u0442\u043E \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435
    \u0432\u044B\u043B\u0438\u043B\u043E\u0441\u044C \u0432 \u0434\u0432\u0430 \u043F\u0430\u043C\u0444\u043B\u0435\u0442\u0430).
    *   **\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0443\u0434\u0430\u0440:**
    \u0412 1899 \u0433\u043E\u0434\u0443 \u0443\u043C\u0435\u0440 \u0435\u0433\u043E
    \u043C\u043B\u0430\u0434\u0448\u0438\u0439 \u0441\u044B\u043D \u0420\u0443\u0434\u043E\u043B\u044C\u0444,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0434\u043B\u044F \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    \u0442\u044F\u0436\u0451\u043B\u044B\u043C \u0443\u0434\u0430\u0440\u043E\u043C.
    \u0412 1904 \u0433\u043E\u0434\u0443 \u0435\u0433\u043E \u043F\u043E\u0442\u0440\u044F\u0441\u043B\u0430
    \u043D\u0435\u0443\u0434\u0430\u0447\u043D\u0430\u044F \u043F\u043E\u043F\u044B\u0442\u043A\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u042E\u043B\u0438\u0443\u0441\u0430
    \u041A\u0451\u043D\u0438\u0433\u0430 \"\u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u044C\"
    \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044E \u043D\u0430 \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u043C
    \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435 (\u043E\u0448\u0438\u0431\u043A\u0430
    \u041A\u0451\u043D\u0438\u0433\u0430 \u0431\u044B\u043B\u0430 \u0431\u044B\u0441\u0442\u0440\u043E
    \u0438\u0441\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0430, \u043D\u043E \u041A\u0430\u043D\u0442\u043E\u0440\u0443
    \u044D\u0442\u043E \u043D\u0430\u043D\u0435\u0441\u043B\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E
    \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0440\u0430\u0432\u043C\u0443). \u041F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0433\u043E
    \u043E\u043D \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B \u043C\u043D\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0432 \u043A\u043B\u0438\u043D\u0438\u043A\u0430\u0445. 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0432\u0441\u0451
    \u044D\u0442\u043E, \u041A\u0430\u043D\u0442\u043E\u0440 \u043D\u0435 \u043F\u0440\u0435\u043A\u0440\u0430\u0449\u0430\u043B
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u041E\u043D \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    **\u041D\u0435\u043C\u0435\u0446\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430** (Deutsche Mathematiker-Vereinigung)
    \u0432 1890 \u0433\u043E\u0434\u0443 \u0438 \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u044B\u043C
    \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0438\u043D\u0438\u0446\u0438\u0430\u0442\u043E\u0440\u043E\u043C \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u043F\u0435\u0440\u0432\u044B\u0445 **\u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u0445
    \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u043E\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432**
    \u0432 1897 \u0433\u043E\u0434\u0443.  \u0412 1904 \u0433\u043E\u0434\u0443 \u041A\u0430\u043D\u0442\u043E\u0440
    \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D **\u043C\u0435\u0434\u0430\u043B\u0438
    \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440\u0430** \u2014 \u0432\u044B\u0441\u0448\u0435\u0439
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430.
    \u0415\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u043E\u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E
    \u0437\u0430\u0432\u043E\u0451\u0432\u044B\u0432\u0430\u043B\u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0438 \u0441\u0442\u0430\u043B\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u043C\u043D\u043E\u0433\u0438\u0445 \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    \u0413\u0435\u043E\u0440\u0433 \u041A\u0430\u043D\u0442\u043E\u0440 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    **6 \u044F\u043D\u0432\u0430\u0440\u044F 1918 \u0433\u043E\u0434\u0430** \u0432
    \u0413\u0430\u043B\u043B\u0435 \u043E\u0442 \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u043E\u0433\u043E
    \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0430 \u0432 \u043F\u0441\u0438\u0445\u0438\u0430\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u043B\u0438\u043D\u0438\u043A\u0435."
  shortBioEn: 
  interestingFactsRu: "\u0411\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u0413\u0435\u043E\u0440\u0433\u0430
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u043F\u043E\u043B\u043D\u0430 \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0439
    \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u0432,
    \u043D\u043E \u0438 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445,
    \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0445, \u0430 \u0438\u043D\u043E\u0433\u0434\u0430
    \u0438 \u0448\u043E\u043A\u0438\u0440\u0443\u044E\u0449\u0438\u0445 \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u043A\u0430\u043B\u0435\u0439\u0434\u043E\u0441\u043A\u043E\u043F
    \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u043E\u0432: \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u0430\u044F
    \u044F\u0441\u043D\u043E\u0441\u0442\u044C \u0443\u043C\u0430 \u0441\u043E\u0441\u0435\u0434\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u0441 \u043E\u0434\u0435\u0440\u0436\u0438\u043C\u043E\u0441\u0442\u044C\u044E,
    \u0430 \u0441\u0442\u0440\u043E\u0433\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u2014 \u0441 \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0432\u0438\u0434\u0435\u043D\u0438\u044F\u043C\u0438.  \u0412\u043E\u0442 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u043F\u043E\u0434\u0431\u043E\u0440\u043A\u0430
    \u0441\u0430\u043C\u044B\u0445 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0445
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u043E \xAB\u043A\u043E\u0440\u043E\u043B\u0435
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438\xBB. 
    ### 1. \U0001F3BB \u0421\u043A\u0440\u0438\u043F\u0430\u0447, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0447\u0443\u0442\u044C \u043D\u0435 \u0441\u0442\u0430\u043B \u0433\u0443\u043C\u0430\u043D\u0438\u0442\u0430\u0440\u0438\u0435\u043C
    \u041C\u0430\u043B\u043E \u043A\u0442\u043E \u0437\u043D\u0430\u0435\u0442, \u0447\u0442\u043E
    \u041A\u0430\u043D\u0442\u043E\u0440 \u043C\u043E\u0433 \u0431\u044B \u0441\u0442\u0430\u0442\u044C
    \u043D\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0430 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u043C
    \u043C\u0443\u0437\u044B\u043A\u0430\u043D\u0442\u043E\u043C.  *   **\u0412\u0438\u0440\u0442\u0443\u043E\u0437\u043D\u0430\u044F
    \u0438\u0433\u0440\u0430:** \u041E\u043D \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0442\u0430\u043B\u0430\u043D\u0442 \u043E\u0442 \u043C\u0430\u0442\u0435\u0440\u0438\u043D\u0441\u043A\u043E\u0433\u043E
    \u0434\u044F\u0434\u0438, \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E
    \u0441\u043A\u0440\u0438\u043F\u0430\u0447\u0430 \u0419\u043E\u0437\u0435\u0444\u0430
    \u0411\u0451\u043C\u0430. \u041A\u0430\u043D\u0442\u043E\u0440 \u0438\u0433\u0440\u0430\u043B
    \u043D\u0430 \u0441\u043A\u0440\u0438\u043F\u043A\u0435 \u043D\u0430 \u0443\u0440\u043E\u0432\u043D\u0435,
    \u0431\u043B\u0438\u0437\u043A\u043E\u043C \u043A \u043A\u043E\u043D\u0446\u0435\u0440\u0442\u043D\u043E\u043C\u0443,
    \u0438 \u0432 \u044E\u043D\u043E\u0441\u0442\u0438 \u0432\u0441\u0435\u0440\u044C\u0451\u0437
    \u043A\u043E\u043B\u0435\u0431\u0430\u043B\u0441\u044F \u043C\u0435\u0436\u0434\u0443
    \u043C\u0443\u0437\u044B\u043A\u043E\u0439 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439.
    *   **\u042F\u0437\u044B\u043A\u0438:** \u041E\u043D \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E
    \u0433\u043E\u0432\u043E\u0440\u0438\u043B \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u044F\u0437\u044B\u043A\u0430\u0445 (\u0440\u0443\u0441\u0441\u043A\u043E\u043C,
    \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u043C, \u0434\u0430\u0442\u0441\u043A\u043E\u043C,
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u043C, \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u043C,
    \u043B\u0430\u0442\u044B\u043D\u0438) \u0438 \u043B\u044E\u0431\u0438\u043B \u0434\u0435\u043A\u043B\u0430\u043C\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0428\u0435\u043A\u0441\u043F\u0438\u0440\u0430 \u0432 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u0435.
    \u0415\u0433\u043E \u0434\u043E\u043C \u0432 \u0413\u0430\u043B\u043B\u0435 \u0447\u0430\u0441\u0442\u043E
    \u043D\u0430\u043F\u043E\u043B\u043D\u044F\u043B\u0441\u044F \u043C\u0443\u0437\u044B\u043A\u043E\u0439
    \u2014 \u0411\u0430\u0445, \u0411\u0435\u0442\u0445\u043E\u0432\u0435\u043D \u0438
    \u041C\u043E\u0446\u0430\u0440\u0442 \u0431\u044B\u043B\u0438 \u0435\u0433\u043E
    \xAB\u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u043C
    \u0434\u043E\u043F\u0438\u043D\u0433\u043E\u043C\xBB. \u0412\u0440\u0430\u0447\u0438
    \u0432 \u043F\u0441\u0438\u0445\u0438\u0430\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u043B\u0438\u043D\u0438\u043A\u0435 \u043F\u043E\u0437\u0436\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438
    \u0441\u043A\u0440\u0438\u043F\u043A\u0443 \u043A\u0430\u043A \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u043E, \u0447\u0442\u043E\u0431\u044B
    \xAB\u0432\u0435\u0440\u043D\u0443\u0442\u044C\xBB \u0435\u0433\u043E \u0432
    \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C.  ---  ### 2. \U0001F575\uFE0F\u200D\u2642\uFE0F
    \u041E\u0434\u0435\u0440\u0436\u0438\u043C\u043E\u0441\u0442\u044C \u0428\u0435\u043A\u0441\u043F\u0438\u0440\u043E\u043C
    \u0438 \xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0434\u0435\u0442\u0435\u043A\u0442\u0438\u0432\xBB \u042D\u0442\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u044B\u0439 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438.
    \u0412 1884 \u0433\u043E\u0434\u0443, \u043D\u0430\u0445\u043E\u0434\u044F\u0441\u044C
    \u0432 \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439 \u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u0438
    \u0438\u0437-\u0437\u0430 \u0442\u0440\u0430\u0432\u043B\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u041A\u0430\u043D\u0442\u043E\u0440 **\u0431\u0440\u043E\u0441\u0438\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043B\u0435\u0442**
    \u0438 \u0437\u0430\u043D\u044F\u043B\u0441\u044F... \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435\u043C. 
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0437\u0430\u0433\u043E\u0432\u043E\u0440\u0430:**
    \u041E\u043D \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D, \u0447\u0442\u043E
    \u0430\u0432\u0442\u043E\u0440\u043E\u043C \u0432\u0441\u0435\u0445 \u043F\u044C\u0435\u0441
    \u0423\u0438\u043B\u044C\u044F\u043C\u0430 \u0428\u0435\u043A\u0441\u043F\u0438\u0440\u0430
    \u043D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435 \u0431\u044B\u043B
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444 \u0438 \u0443\u0447\u0435\u043D\u044B\u0439
    **\u0424\u0440\u044D\u043D\u0441\u0438\u0441 \u0411\u044D\u043A\u043E\u043D**. 
    *   **\xAB\u0421\u0442\u0440\u043E\u0433\u0438\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\xBB:**
    \u041A\u0430\u043D\u0442\u043E\u0440 \u043F\u043E\u0442\u0440\u0430\u0442\u0438\u043B
    \u0446\u0435\u043B\u043E\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u043D\u0430 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044E \u0434\u0432\u0443\u0445
    \u043E\u0431\u044A\u0435\u043C\u0438\u0441\u0442\u044B\u0445 \u0431\u0440\u043E\u0448\u044E\u0440
    (\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0438\u043A\u0442\u043E \u043D\u0435
    \u043F\u043E\u043A\u0443\u043F\u0430\u043B), \u0433\u0434\u0435 \u043E\u043D
    \xAB\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0441\u0442\u0440\u043E\u0433\u043E\xBB \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B
    \u044D\u0442\u0443 \u0442\u0435\u043E\u0440\u0438\u044E, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u0447\u0430\u0441\u0442\u043E\u0442\u043D\u043E\u0441\u0442\u044C \u0431\u0443\u043A\u0432
    \u0432 \u0442\u0435\u043A\u0441\u0442\u0430\u0445 (\u043F\u043E \u0441\u0443\u0442\u0438,
    \u043E\u043D \u0431\u044B\u043B \u043F\u0438\u043E\u043D\u0435\u0440\u043E\u043C
    \u0441\u0442\u0438\u043B\u043E\u043C\u0435\u0442\u0440\u0438\u0438!).  *   **\u0421\u043C\u0435\u0445
    \u043A\u043E\u043B\u043B\u0435\u0433:** \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0441\u0447\u0438\u0442\u0430\u043B\u0438 \u044D\u0442\u043E \u0434\u0443\u0440\u043D\u044B\u043C
    \u0437\u043D\u0430\u043A\u043E\u043C \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043A\u043E\u043C
    \u0431\u0435\u0437\u0443\u043C\u0438\u044F, \u043D\u043E \u0441\u0430\u043C \u041A\u0430\u043D\u0442\u043E\u0440
    \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0441\u044F \u043A \u044D\u0442\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 \u043E\u0447\u0435\u043D\u044C \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E
    \u0438 \u043E\u0431\u0438\u0436\u0430\u043B\u0441\u044F, \u043A\u043E\u0433\u0434\u0430
    \u0435\u0451 \u043D\u0435 \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B\u0438
    \u0432\u0441\u0435\u0440\u044C\u0451\u0437.  ---  ### 3. \U0001F4DC \u041F\u0438\u0441\u044C\u043C\u0430
    \u041F\u0430\u043F\u0435 \u0420\u0438\u043C\u0441\u043A\u043E\u043C\u0443 \u0438
    \u0442\u0435\u043E\u043B\u043E\u0433\u0430\u043C \u041A\u0430\u043D\u0442\u043E\u0440
    \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u043C
    \u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0438\u043D\u043E\u043C, \u043D\u043E
    \u0435\u0433\u043E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0441\u0442\u044C
    \u0431\u044B\u043B\u0430 \u043E\u0447\u0435\u043D\u044C \u0441\u043F\u0435\u0446\u0438\u0444\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u2014 \u043E\u043D \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0447\u0430\u0441\u0442\u044C\u044E
    \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0438\u044F.  *   **\u0410\u0442\u0430\u043A\u0430
    \u043D\u0430 \u0412\u0430\u0442\u0438\u043A\u0430\u043D:** \u041A\u0430\u043D\u0442\u043E\u0440
    \u0437\u0430\u0432\u0430\u043B\u0438\u0432\u0430\u043B \u043F\u0438\u0441\u044C\u043C\u0430\u043C\u0438
    \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u043E\u0432,
    \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0445 \u0435\u043F\u0438\u0441\u043A\u043E\u043F\u043E\u0432
    \u0438 \u0434\u0430\u0436\u0435 \u0441\u0430\u043C\u043E\u0433\u043E **\u041F\u0430\u043F\u0443
    \u0420\u0438\u043C\u0441\u043A\u043E\u0433\u043E \u041B\u044C\u0432\u0430 XIII**.
    \u041E\u043D \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0443\u0431\u0435\u0434\u0438\u0442\u044C
    \u0438\u0445, \u0447\u0442\u043E \u0442\u0435\u043E\u0440\u0438\u044F \u0442\u0440\u0430\u043D\u0441\u0444\u0438\u043D\u0438\u0442\u043D\u044B\u0445
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432 \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u0411\u043E\u0433\u0430 \u0438 \u0447\u0442\u043E \u0446\u0435\u0440\u043A\u043E\u0432\u044C
    \u0434\u043E\u043B\u0436\u043D\u0430 \u043F\u0440\u0438\u0437\u043D\u0430\u0442\u044C
    \u0435\u0433\u043E \xAB\u0430\u043B\u0435\u0444\u044B\xBB \u043A\u0430\u043A
    \u043F\u0440\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u0435 \u0411\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u043F\u0440\u0438\u0440\u043E\u0434\u044B. *   **\u041E\u0442\u0432\u0435\u0442:**
    \u041F\u0430\u043F\u0430 \u0420\u0438\u043C\u0441\u043A\u0438\u0439 \u0432\u0435\u0436\u043B\u0438\u0432\u043E
    (\u043D\u043E \u0445\u043E\u043B\u043E\u0434\u043D\u043E) \u043F\u043E\u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u0438\u043B
    \u0435\u0433\u043E \u0437\u0430 \u043F\u0438\u0441\u044C\u043C\u0430, \u043D\u043E
    \u0434\u0430\u0436\u0435 \u043D\u0435 \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043B
    \u0438\u0445. \u0410 \u043E\u0434\u0438\u043D \u0438\u0437 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0445
    \u0442\u0435\u043E\u043B\u043E\u0433\u043E\u0432 \u0432 \u043E\u0442\u0432\u0435\u0442
    \u043F\u043E\u0441\u043E\u0432\u0435\u0442\u043E\u0432\u0430\u043B \u0435\u043C\u0443
    \xAB\u043B\u0435\u0447\u0438\u0442\u044C\u0441\u044F \u043E\u0442 \u0433\u043E\u0440\u0434\u044B\u043D\u0438\xBB,
    \u0438\u0431\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
    \u043F\u043E\u0441\u0442\u0438\u0447\u044C \u0411\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C
    \u0443\u0442\u0440\u043E\u043C \u043F\u0435\u0440\u0435\u0434 \u0437\u0430\u0432\u0442\u0440\u0430\u043A\u043E\u043C. 
    ---  ### 4. \U0001F94A \u0411\u043E\u043A\u0441\u0435\u0440\u0441\u043A\u0438\u0439
    \u043F\u043E\u0435\u0434\u0438\u043D\u043E\u043A \u0441 \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440\u043E\u043C
    (\u0432 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435) \u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u0441 \u041B\u0435\u043E\u043F\u043E\u043B\u044C\u0434\u043E\u043C
    \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440\u043E\u043C \u0431\u044B\u043B
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0435\u0439, \u0430 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439
    \xAB\u0445\u043E\u043B\u043E\u0434\u043D\u043E\u0439 \u0432\u043E\u0439\u043D\u043E\u0439\xBB
    \u0432 \u043F\u0438\u0441\u044C\u043C\u0430\u0445.  *   **\u041E\u0441\u043A\u043E\u0440\u0431\u043B\u0435\u043D\u0438\u044F:**
    \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440 \u043D\u0430\u0437\u044B\u0432\u0430\u043B
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \xAB\u0448\u0430\u0440\u043B\u0430\u0442\u0430\u043D\u043E\u043C\xBB,
    \xAB\u043A\u043E\u0440\u0440\u0443\u043C\u043F\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u043C
    \u0443\u043C\u043E\u043C\xBB \u0438 \xAB\u0440\u0430\u0437\u0432\u0440\u0430\u0442\u0438\u0442\u0435\u043B\u0435\u043C
    \u043C\u043E\u043B\u043E\u0434\u0435\u0436\u0438\xBB.  *   **\u041E\u0442\u0432\u0435\u0442
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430:** \u0423\u0441\u0442\u0430\u0432
    \u043E\u0442 \u043D\u0430\u043F\u0430\u0434\u043E\u043A, \u041A\u0430\u043D\u0442\u043E\u0440
    \u0432 \u043E\u0434\u043D\u043E\u043C \u0438\u0437 \u043F\u0438\u0441\u0435\u043C
    \u0432\u044B\u0437\u0432\u0430\u043B \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440\u0430
    \u043D\u0430 **\u0434\u0443\u044D\u043B\u044C**! \u041A\u043E\u043D\u0435\u0447\u043D\u043E,
    \u0434\u043E \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u044B
    \u043D\u0435 \u0434\u043E\u0448\u043B\u043E (\u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440
    \u043F\u0440\u043E\u0438\u0433\u043D\u043E\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u0432\u044B\u0437\u043E\u0432), \u043D\u043E \u0441\u0430\u043C \u0444\u0430\u043A\u0442
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442
    \u0440\u0435\u0448\u0438\u0442\u044C \u0441\u043F\u043E\u0440 \u043D\u0430 \u043F\u0438\u0441\u0442\u043E\u043B\u0435\u0442\u0430\u0445,
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043E \u043D\u0430\u043A\u0430\u043B\u0435
    \u0441\u0442\u0440\u0430\u0441\u0442\u0435\u0439. *   **\u0418\u0440\u043E\u043D\u0438\u044F
    \u0441\u0443\u0434\u044C\u0431\u044B:** \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440
    \u0443\u043C\u0435\u0440 \u0432 1891 \u0433\u043E\u0434\u0443. \u041F\u043E\u0441\u043B\u0435
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u041A\u0430\u043D\u0442\u043E\u0440
    \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E \u0437\u0430\u044F\u0432\u0438\u043B,
    \u0447\u0442\u043E \u0441\u043C\u0435\u0440\u0442\u044C \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440\u0430
    \u2014 \u044D\u0442\u043E \xAB\u0411\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \u0432\u043C\u0435\u0448\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\xBB
    \u0438 \u043D\u0430\u043A\u0430\u0437\u0430\u043D\u0438\u0435 \u0437\u0430 \u0433\u043E\u043D\u0435\u043D\u0438\u044F
    \u043D\u0430 \u0438\u0441\u0442\u0438\u043D\u0443.  ---  ### 5. \U0001F9E9 \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \xAB\u043C\u043E\u043D\u0441\u0442\u0440\u0430\xBB: \u041A\u0430\u043D\u0442\u043E\u0440\u043E\u0432\u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u041A\u043E\u0433\u0434\u0430
    \u041A\u0430\u043D\u0442\u043E\u0440 \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B
    \u0441\u0432\u043E\u0435 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435
    \xAB\u043A\u0430\u043D\u0442\u043E\u0440\u043E\u0432\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E\xBB
    (\u043F\u044B\u043B\u044C), \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u043E\u0434\u0438\u043D \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u043E\u0432
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438.  *   **\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441:**
    \u041E\u043D \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E,
    \u0443 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E **\u0434\u043B\u0438\u043D\u0430
    \u0440\u0430\u0432\u043D\u0430 \u043D\u0443\u043B\u044E**, \u043D\u043E **\u0442\u043E\u0447\u0435\u043A
    \u0432 \u043D\u0435\u043C \u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0436\u0435,
    \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0432\u043E \u0432\u0441\u0435\u043C
    \u043E\u0442\u0440\u0435\u0437\u043A\u0435 \u043F\u0440\u044F\u043C\u043E\u0439**
    (\u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C \u043A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C\u0430). 
    *   **\u0420\u0435\u0430\u043A\u0446\u0438\u044F:** \u041A\u043E\u0433\u0434\u0430
    \u043E\u043D \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u043B \u043E\u0431
    \u044D\u0442\u043E\u043C \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C, \u043C\u043D\u043E\u0433\u0438\u0435
    \u0440\u0435\u0448\u0438\u043B\u0438, \u0447\u0442\u043E \u043E\u043D \u0448\u0443\u0442\u0438\u0442
    \u0438\u043B\u0438 \u0441\u043E\u0448\u0435\u043B \u0441 \u0443\u043C\u0430.
    \u041A\u0430\u043A \u043C\u043E\u0436\u043D\u043E \u0438\u043C\u0435\u0442\u044C
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0442\u043E\u0447\u0435\u043A, \u0435\u0441\u043B\u0438 \u0438\u0445 \u043E\u0431\u0449\u0430\u044F
    \u0434\u043B\u0438\u043D\u0430 \u2014 \u043D\u043E\u043B\u044C? \u042D\u0442\u043E
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u043B\u043E
    \u0432\u0441\u0435\u0439 \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u0421\u0435\u0439\u0447\u0430\u0441
    \u044D\u0442\u043E\u0442 \xAB\u043C\u043E\u043D\u0441\u0442\u0440\xBB \u0438\u0437\u0443\u0447\u0430\u044E\u0442
    \u0432 \u043A\u0443\u0440\u0441\u0430\u0445 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u0435\u0440\u044B.  ---  ###
    6. \U0001F37D \u042D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u0435
    \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0438 \u0438 \u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0441\u0442\u044C
    \u041A\u0430\u043A \u0438 \u043C\u043D\u043E\u0433\u0438\u0435 \u0433\u0435\u043D\u0438\u0438,
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0431\u044B\u043B \u0441\u0442\u0440\u0430\u0448\u043D\u043E
    \u0440\u0430\u0441\u0441\u0435\u044F\u043D \u0432 \u0431\u044B\u0442\u0443. 
    *   **\u0412\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0435\u0446-\u043D\u043E\u0432\u0430\u0442\u043E\u0440:**
    \u0412 \u043A\u043E\u043D\u0446\u0435 XIX \u0432\u0435\u043A\u0430 \u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0441\u0442\u0432\u043E
    \u0431\u044B\u043B\u043E \u044D\u043A\u0437\u043E\u0442\u0438\u043A\u043E\u0439.
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0441\u0442\u0430\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0446\u0435\u043C
    \u043F\u043E \u044D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u0441\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F\u043C,
    \u0447\u0442\u043E \u0448\u043E\u043A\u0438\u0440\u043E\u0432\u0430\u043B\u043E
    \u0435\u0433\u043E \u043C\u044F\u0441\u043E\u0435\u0434\u043D\u044B\u0445 \u043A\u043E\u043B\u043B\u0435\u0433.
    *   **\u041E\u0434\u0435\u0436\u0434\u0430:** \u0415\u0433\u043E \u0436\u0435\u043D\u0430
    \u0412\u0430\u043B\u043B\u0438 \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E
    \u0436\u0430\u043B\u043E\u0432\u0430\u043B\u0430\u0441\u044C \u0432 \u043F\u0438\u0441\u044C\u043C\u0430\u0445,
    \u0447\u0442\u043E \u043E\u043D \u0432\u044B\u0445\u043E\u0434\u0438\u0442 \u0438\u0437
    \u0434\u043E\u043C\u0430 \u0432 \u0440\u0430\u0437\u043D\u044B\u0445 \u043D\u043E\u0441\u043A\u0430\u0445
    \u0438\u043B\u0438 \u0432 \u0434\u043E\u043C\u0430\u0448\u043D\u0438\u0445 \u0442\u0430\u043F\u043E\u0447\u043A\u0430\u0445,
    \u0435\u0441\u043B\u0438 \u0435\u0433\u043E \u043C\u044B\u0441\u043B\u0438 \u0431\u044B\u043B\u0438
    \u0437\u0430\u043D\u044F\u0442\u044B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B. *   **\u0415\u0434\u0430:** \u041E\u043D
    \u043C\u043E\u0433 \u043F\u0440\u043E\u0441\u0438\u0434\u0435\u0442\u044C \u0437\u0430
    \u0441\u0442\u043E\u043B\u043E\u043C \u0441 \u043D\u0435\u0434\u043E\u0435\u0434\u0435\u043D\u043D\u044B\u043C
    \u0441\u0443\u043F\u043E\u043C 6 \u0447\u0430\u0441\u043E\u0432, \u0443\u0441\u0442\u0430\u0432\u0438\u0432\u0448\u0438\u0441\u044C
    \u0432 \u043E\u0434\u043D\u0443 \u0442\u043E\u0447\u043A\u0443 \u0438 \u043F\u0435\u0440\u0435\u0431\u0438\u0440\u0430\u044F
    \u0432 \u0443\u043C\u0435 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0435
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438. 
    ---  ### 7. \U0001F92F \xAB\u042F \u0432\u0438\u0436\u0443 \u044D\u0442\u043E,
    \u043D\u043E \u043D\u0435 \u0432\u0435\u0440\u044E \u0432 \u044D\u0442\u043E!\xBB
    \u042D\u0442\u043E \u043E\u0434\u043D\u0430 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445 \u0444\u0440\u0430\u0437
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    *   **\u041A\u043E\u043D\u0442\u0435\u043A\u0441\u0442:** \u0412 1877 \u0433\u043E\u0434\u0443
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043C\u0435\u0436\u0434\u0443 \u0442\u043E\u0447\u043A\u0430\u043C\u0438
    \u043E\u0442\u0440\u0435\u0437\u043A\u0430 (1D) \u0438 \u0442\u043E\u0447\u043A\u0430\u043C\u0438
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430 (2D) \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0432\u0437\u0430\u0438\u043C\u043D\u043E-\u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E\u0435
    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435. \u041E\u043D
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043E\u0434\u043D\u043E\u043C\u0435\u0440\u043D\u044B\u0439
    \u043E\u0442\u0440\u0435\u0437\u043E\u043A \u0438 \u0434\u0432\u0443\u043C\u0435\u0440\u043D\u044B\u0439
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0442
    **\u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u043E\u0435 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0442\u043E\u0447\u0435\u043A**. *   **\u0428\u043E\u043A:** \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0440\u0430\u0437\u0438\u043B\u043E
    \u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0433\u043E, \u0447\u0442\u043E \u0432
    \u043F\u0438\u0441\u044C\u043C\u0435 \u0441\u0432\u043E\u0435\u043C\u0443 \u0434\u0440\u0443\u0433\u0443
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0443 \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B:
    *\"Je le vois, mais je ne le crois pas!\"* **\xAB\u042F \u0432\u0438\u0436\u0443
    \u044D\u0442\u043E, \u043D\u043E \u044F \u043D\u0435 \u0432\u0435\u0440\u044E
    \u0432 \u044D\u0442\u043E!\xBB**. \u042D\u0442\u043E \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0430\u044F \u0440\u0435\u0430\u043A\u0446\u0438\u044F
    \u0433\u0435\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u043B\u043E\u043C\u0430\u043B
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u044E. 
    ---  ### 8. \U0001F3B2 \u0418\u0433\u0440\u0430 \u0432 \u043A\u0430\u0440\u0442\u044B
    \u043A\u0430\u043A \u0442\u0435\u0440\u0430\u043F\u0438\u044F \u041A\u0430\u043D\u0442\u043E\u0440
    \u043E\u0431\u043E\u0436\u0430\u043B \u0438\u0433\u0440\u0430\u0442\u044C \u0432
    \u043A\u0430\u0440\u0442\u044B, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0432 \u0431\u0440\u0438\u0434\u0436 \u0438 \u0432\u0438\u0441\u0442.  *   **\u0418\u0433\u0440\u043E\u0432\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F:** \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B,
    \u0447\u0442\u043E \u043A\u0430\u0440\u0442\u043E\u0447\u043D\u044B\u0435 \u0438\u0433\u0440\u044B
    \u043F\u043E\u043C\u043E\u0433\u0430\u044E\u0442 \u0435\u0433\u043E \u043C\u043E\u0437\u0433\u0443
    \xAB\u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u0442\u044C\u0441\u044F\xBB
    \u0438 \u043F\u0435\u0440\u0435\u0437\u0430\u0433\u0440\u0443\u0437\u0438\u0442\u044C\u0441\u044F
    \u043E\u0442 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0445
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0435\u0439.
    \u0412 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u0438 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432
    \u0438 \u043A\u043E\u043B\u043B\u0435\u0433 \u043E\u043D \u043C\u043E\u0433 \u043F\u0440\u043E\u0438\u0433\u0440\u044B\u0432\u0430\u0442\u044C
    \u043A\u0440\u0443\u043F\u043D\u044B\u0435 \u0441\u0443\u043C\u043C\u044B (\u0447\u0442\u043E
    \u043E\u0447\u0435\u043D\u044C \u0437\u043B\u0438\u043B\u043E \u0435\u0433\u043E
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u0443\u044E \u0436\u0435\u043D\u0443).
    *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0432 \u043A\u0430\u0440\u0442\u0430\u0445:**
    \u0418\u043D\u043E\u0433\u0434\u0430, \u0440\u0430\u0437\u0434\u0430\u0432\u0430\u044F
    \u043A\u0430\u0440\u0442\u044B, \u043E\u043D \u043D\u0430\u0447\u0438\u043D\u0430\u043B
    \u0431\u043E\u0440\u043C\u043E\u0442\u0430\u0442\u044C \u043F\u0440\u043E *\xAB\u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u043D\u044B\u0435
    \u0432\u0437\u0440\u044B\u0432\u044B\xBB* \u0438 *\xAB\u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A\xBB*,
    \u0447\u0435\u043C \u0432\u0433\u043E\u043D\u044F\u043B \u043F\u0430\u0440\u0442\u043D\u0435\u0440\u043E\u0432
    \u0432 \u0441\u0442\u0443\u043F\u043E\u0440.  ---  ### 9. \U0001F4C9 \u0424\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u043E\u0435
    \u0431\u0435\u0434\u0441\u0442\u0432\u0438\u0435 \u0432 \u043A\u043E\u043D\u0446\u0435
    \u0436\u0438\u0437\u043D\u0438 \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E \u041A\u0430\u043D\u0442\u043E\u0440
    \u0431\u044B\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C,
    \u043E\u043D \u0443\u043C\u0435\u0440 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0431\u0435\u0434\u043D\u044F\u043A\u043E\u043C.   *   **\u041F\u0440\u0438\u0447\u0438\u043D\u0430:**
    \u0412 \u043D\u0430\u0447\u0430\u043B\u0435 \u043A\u0430\u0440\u044C\u0435\u0440\u044B
    \u043E\u043D \u0436\u0438\u043B \u043D\u0430 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E
    \u043E\u0442\u0446\u0430 \u0438 \u043D\u0435 \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B
    \u043F\u0440\u0438\u0431\u0430\u0432\u043A\u0438 \u043A \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u044C\u044E.
    \u041A\u043E\u0433\u0434\u0430 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E
    \u043A\u043E\u043D\u0447\u0438\u043B\u043E\u0441\u044C, \u0430 \u0438\u043D\u0444\u043B\u044F\u0446\u0438\u044F
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u041F\u0435\u0440\u0432\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B \u0432\u0437\u043B\u0435\u0442\u0435\u043B\u0430,
    \u0435\u0433\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u043E\u0433\u043E
    \u043E\u043A\u043B\u0430\u0434\u0430 \u0432 \u0437\u0430\u0445\u043E\u043B\u0443\u0441\u0442\u043D\u043E\u043C
    \u0413\u0430\u043B\u043B\u0435 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B\u043E
    \u0445\u0432\u0430\u0442\u0430\u0442\u044C. *   **\u0423\u043D\u0438\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442:** \u0427\u0442\u043E\u0431\u044B \u043E\u043F\u043B\u0430\u0442\u0438\u0442\u044C
    \u043B\u0435\u0447\u0435\u043D\u0438\u0435 \u0432 \u043F\u0441\u0438\u0445\u0438\u0430\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u043B\u0438\u043D\u0438\u043A\u0435, \u0435\u0433\u043E \u0436\u0435\u043D\u0430
    \u0412\u0430\u043B\u043B\u0438 \u0431\u044B\u043B\u0430 \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u0430
    \u043F\u0438\u0441\u0430\u0442\u044C \u0443\u043D\u0438\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043F\u0440\u043E\u0448\u0435\u043D\u0438\u044F \u043E \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u043E\u0439
    \u043F\u043E\u043C\u043E\u0449\u0438 \u0432 \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0438 \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0443\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E
    \u043D\u0430\u0443\u043A (\u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043A\u043E\u0433\u0434\u0430-\u0442\u043E
    \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0430 \u041A\u0430\u043D\u0442\u043E\u0440\u0443
    \u0432 \u0447\u043B\u0435\u043D\u0441\u0442\u0432\u0435). \u0415\u0439 \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    \u0441 \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u043E\u0439:
    *\xAB\u0415\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u043D\u0435 \u0438\u043C\u0435\u044E\u0442
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u0438\xBB*. 
    ---  ### 10. \U0001F6F8 \u0410\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u0430\u044F
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C
    \u043A\u0430\u043A \u0411\u043E\u0433 \u041A\u0430\u043D\u0442\u043E\u0440 \u0440\u0430\u0437\u043B\u0438\u0447\u0430\u043B
    \u0434\u0432\u0430 \u0432\u0438\u0434\u0430 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438: 
    1.  **\u0422\u0440\u0430\u043D\u0441\u0444\u0438\u043D\u0438\u0442\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430 (\u0410\u043B\u0435\u0444\u044B):** \u042D\u0442\u043E
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u043E\u0436\u043D\u043E \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438,
    \u043E\u043D\u0438 \xAB\u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\xBB \u0443\u043C\u0443
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430. 2.  **\u0410\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u0430\u044F
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C:**
    \u042D\u0442\u043E \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043D\u0435\u043B\u044C\u0437\u044F
    \u043D\u0438 \u0443\u0432\u0435\u043B\u0438\u0447\u0438\u0442\u044C, \u043D\u0438
    \u0434\u0430\u0436\u0435 \u043F\u043E\u043D\u044F\u0442\u044C. \u041A\u0430\u043D\u0442\u043E\u0440
    \u043F\u0440\u044F\u043C\u043E \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u043B
    \u0435\u0451 \u0441 **\u0411\u043E\u0433\u043E\u043C**.  *   **\u041C\u0438\u0441\u0442\u0438\u043A\u0430:**
    \u041E\u043D \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0435 \u0432\u0435\u0440\u0438\u043B,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044F \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    \u0431\u044B\u043B\u0430 \u043D\u0438\u0441\u043F\u043E\u0441\u043B\u0430\u043D\u0430
    \u0435\u043C\u0443 \u0411\u043E\u0433\u043E\u043C \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E,
    \u043A\u0430\u043A \u043E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u0438\u0435.
    \u0412 \u043F\u0435\u0440\u0438\u043E\u0434\u044B \u043C\u0430\u043D\u0438\u0438
    \u043E\u043D \u0433\u043E\u0432\u043E\u0440\u0438\u043B, \u0447\u0442\u043E *\xAB\u0432\u0438\u0434\u0438\u0442
    \u0442\u0440\u0430\u043D\u0441\u0444\u0438\u043D\u0438\u0442\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430\xBB* \u0432 \u044F\u0440\u043A\u0438\u0445 \u0446\u0432\u0435\u0442\u043D\u044B\u0445
    \u043E\u0431\u0440\u0430\u0437\u0430\u0445, \u0441\u043B\u043E\u0432\u043D\u043E
    \u0433\u0430\u043B\u043B\u044E\u0446\u0438\u043D\u0430\u0446\u0438\u0438.  --- 
    ### 11. \U0001F3C6 \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0432
    \u0447\u0443\u0436\u0438\u0445 \u043A\u0440\u0430\u044F\u0445 \u041F\u043E \u0438\u0440\u043E\u043D\u0438\u0438
    \u0441\u0443\u0434\u044C\u0431\u044B, \u043D\u0430 \u0440\u043E\u0434\u0438\u043D\u0435
    \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438 \u041A\u0430\u043D\u0442\u043E\u0440\u0430
    \u0442\u0440\u0430\u0432\u0438\u043B\u0438, \u043D\u043E \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0435\u0439
    \u0435\u0433\u043E \u0443\u0432\u0430\u0436\u0430\u043B\u0438.  *   **\u041C\u0435\u0434\u0430\u043B\u044C
    \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440\u0430 (1904):** \u042D\u0442\u043E
    \u0432\u044B\u0441\u0448\u0430\u044F \u043D\u0430\u0433\u0440\u0430\u0434\u0430
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430. \u041A\u043E\u0433\u0434\u0430
    \u041A\u0430\u043D\u0442\u043E\u0440 \u043F\u0440\u0438\u0435\u0445\u0430\u043B
    \u0432 \u0410\u043D\u0433\u043B\u0438\u044E \u0437\u0430 \u043C\u0435\u0434\u0430\u043B\u044C\u044E,
    \u0435\u0433\u043E \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u043B\u0438 \u043A\u0430\u043A
    \u0433\u0435\u0440\u043E\u044F. \u0428\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0435
    \u0438 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0430\u043F\u043B\u043E\u0434\u0438\u0440\u043E\u0432\u0430\u043B\u0438 \u0435\u043C\u0443
    \u0441\u0442\u043E\u044F, \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F
    \u043A\u0430\u043A \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0435 \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u0438\u0433\u043D\u043E\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u0438 \u0435\u0433\u043E.
    \u041A\u0430\u043D\u0442\u043E\u0440 \u0431\u044B\u043B \u0442\u0430\u043A \u0442\u0440\u043E\u043D\u0443\u0442
    \u044D\u0442\u0438\u043C, \u0447\u0442\u043E \u043F\u043B\u0430\u043A\u0430\u043B
    \u043D\u0430 \u0446\u0435\u0440\u0435\u043C\u043E\u043D\u0438\u0438.  ---  ###
    12. \U0001F635 \u0421\u043C\u0435\u0440\u0442\u044C \u0432 \u0434\u0435\u043D\u044C...
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430? \u041A\u0430\u043D\u0442\u043E\u0440
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 6 \u044F\u043D\u0432\u0430\u0440\u044F
    1918 \u0433\u043E\u0434\u0430 \u0432 \u043F\u0441\u0438\u0445\u0438\u0430\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u043B\u0438\u043D\u0438\u043A\u0435. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u0432 \u0435\u0433\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u043E\u043D \u0431\u044B\u043B \u043E\u0434\u0435\u0440\u0436\u0438\u043C
    \u0438\u0434\u0435\u0435\u0439, \u0447\u0442\u043E **6 \u044F\u043D\u0432\u0430\u0440\u044F**
    \u2014 \u044D\u0442\u043E \u0440\u043E\u043A\u043E\u0432\u0430\u044F \u0434\u0430\u0442\u0430.
    \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E
    \u0432 \u044D\u0442\u043E\u0442 \u0434\u0435\u043D\u044C \u043F\u0440\u043E\u0438\u0437\u043E\u0439\u0434\u0435\u0442
    \u043D\u0435\u043A\u043E\u0435 \xAB\u043E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u0438\u0435\xBB
    \u0438\u043B\u0438 \xAB\u043A\u043E\u043D\u0435\u0446 \u0441\u0432\u0435\u0442\u0430\xBB
    (\u0441\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0435 \u0441 \u0435\u0433\u043E
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F\u043C\u0438 \u0431\u0438\u0431\u043B\u0435\u0439\u0441\u043A\u0438\u0445
    \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432).   \u0418\u0440\u043E\u043D\u0438\u044F
    \u0441\u0443\u0434\u044C\u0431\u044B: \u043E\u043D \u043E\u0448\u0438\u0431\u0441\u044F
    \u0432 \u0441\u0432\u043E\u0438\u0445 \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u0430\u0445,
    \u043D\u043E \u0443\u043C\u0435\u0440 \u0438\u043C\u0435\u043D\u043D\u043E \u0432
    \u044D\u0442\u0443 \u0434\u0430\u0442\u0443, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0441\u0430\u043C \u0436\u0435 \u0438 \u0441\u0447\u0438\u0442\u0430\u043B \u0441\u0430\u043A\u0440\u0430\u043B\u044C\u043D\u043E\u0439. 
    ---  \u0413\u0435\u043E\u0440\u0433 \u041A\u0430\u043D\u0442\u043E\u0440 \u0431\u044B\u043B
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u0438\u0434\u0435\u043B \u043C\u0438\u0440 \u043D\u0435 \u0442\u0430\u043A\u0438\u043C,
    \u043A\u0430\u043A \u0432\u0441\u0435. \u041E\u043D \u0441\u043C\u043E\u0442\u0440\u0435\u043B
    \u043D\u0430 \u043F\u0443\u0441\u0442\u043E\u0442\u0443 \u0438 \u0432\u0438\u0434\u0435\u043B
    \u0442\u0430\u043C \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u0443\u044E
    \u043A\u0440\u0430\u0441\u043E\u0442\u0443, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0437\u0430\u043F\u0438\u0441\u0430\u0442\u044C
    \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u043C\u0438. \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C
    \u2014 \u044D\u0442\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0431\u0435\u0437\u0443\u043C\u0438\u0435 \u0438\u043D\u043E\u0433\u0434\u0430
    \u0445\u043E\u0434\u044F\u0442 \u0440\u0443\u043A\u0430 \u043E\u0431 \u0440\u0443\u043A\u0443,
    \u043D\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u044D\u0442\u043E\u043C\u0443 \xAB\u0431\u0435\u0437\u0443\u043C\u0438\u044E\xBB
    \u043C\u044B \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u0438\u043C\u0435\u0435\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443."
