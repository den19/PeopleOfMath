  shortBioRu: "\u0410\u043D\u0440\u0438\u0301 \u041B\u0435\u043E\u0301\u043D \u041B\u0435\u0431\u0435\u0301\u0433\_\u2014
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 (1910),
    \u043E\u0434\u0438\u043D \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A\u043E\u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439. \u0427\u043B\u0435\u043D
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A (1922), \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430
    (1930) \u0438 \u043C\u043D\u043E\u0433\u0438\u0445 \u0434\u0440\u0443\u0433\u0438\u0445
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u0439,
    \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 \u0447\u043B\u0435\u043D-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442
    \u0410\u041D \u0421\u0421\u0421\u0420 (1929)."
