  achievementsRu: "\u0412\u043A\u043B\u0430\u0434 \u0410\u043D\u0440\u0438 \u041B\u0435\u043E\u043D\u0430
    \u041B\u0435\u0431\u0435\u0433\u0430 \u0432 \u043D\u0430\u0443\u043A\u0443 \u043F\u043E
    \u0441\u0432\u043E\u0435\u043C\u0443 \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u0443
    \u0441\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043C \u0441 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435\u043C
    \u043D\u043E\u0432\u043E\u0433\u043E \u044F\u0437\u044B\u043A\u0430 \u0434\u043B\u044F
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438. \u0415\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u043E\u0432\u044B\u0439
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B, \u0430 \u0446\u0435\u043B\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u043C\u0435\u0440\u044B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u043E \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437.  ### \U0001F9E0 \u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B
    \u041B\u0435\u0431\u0435\u0433\u0430: \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u0432 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438 \u043F\u043B\u043E\u0449\u0430\u0434\u0438 
    \u041A \u043A\u043E\u043D\u0446\u0443 XIX \u0432\u0435\u043A\u0430 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B \u0420\u0438\u043C\u0430\u043D\u0430
    \u0441\u0442\u0430\u043B\u043A\u0438\u0432\u0430\u043B\u0441\u044F \u0441 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u043C\u0438
    \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u0438\u044F\u043C\u0438:
    \u043E\u043D \u043D\u0435 \u043C\u043E\u0433 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0441 \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C\u0438, \u0438\u043C\u0435\u044E\u0449\u0438\u043C\u0438
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0440\u0430\u0437\u0440\u044B\u0432\u043E\u0432 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0441 \u0444\u0443\u043D\u043A\u0446\u0438\u0435\u0439 \u0414\u0438\u0440\u0438\u0445\u043B\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0440\u0430\u0432\u043D\u0430 1 \u043D\u0430
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u043B\u0430\u0445
    \u0438 0 \u043D\u0430 \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445).
    \u041B\u0435\u0431\u0435\u0433 \u043F\u043E\u0434\u043E\u0448\u0435\u043B \u043A
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0435 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E
    \u0438\u043D\u0430\u0447\u0435.  *   **\u0418\u0434\u0435\u044F:** \u0412\u043C\u0435\u0441\u0442\u043E
    \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B \u0440\u0430\u0437\u0431\u0438\u0432\u0430\u0442\u044C
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    (\u043E\u0441\u044C X) \u043D\u0430 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0435
    \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u044B, \u043A\u0430\u043A \u044D\u0442\u043E
    \u0434\u0435\u043B\u0430\u043B \u0420\u0438\u043C\u0430\u043D, \u041B\u0435\u0431\u0435\u0433
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0440\u0430\u0437\u0431\u0438\u0432\u0430\u0442\u044C
    **\u043E\u0431\u043B\u0430\u0441\u0442\u044C \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439**
    (\u043E\u0441\u044C Y). *   **\u041C\u0435\u0440\u0430 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430:**
    \u0414\u043B\u044F \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u0443\u0440\u043E\u0432\u043D\u044F
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439 \\( y_i \\), \u043E\u043D \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0442\u043E\u0447\u0435\u043A
    \\( E_i \\) \u043D\u0430 \u043E\u0441\u0438 X, \u0433\u0434\u0435 \u0444\u0443\u043D\u043A\u0446\u0438\u044F
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0442 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    \u043C\u0435\u0436\u0434\u0443 \\( y_{i-1} \\) \u0438 \\( y_i \\). \u0417\u0430\u0442\u0435\u043C
    \u043E\u043D \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u043B \u043D\u0435 \u0434\u043B\u0438\u043D\u0443
    \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u0430, \u0430 **\xAB\u043C\u0435\u0440\u0443\xBB**
    \u044D\u0442\u043E\u0433\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \\( m(E_i) \\), \u0434\u0430\u0436\u0435 \u0435\u0441\u043B\u0438 \u043E\u043D\u043E
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u043E \u0438\u0437 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0445
    \u0442\u043E\u0447\u0435\u043A. \u0412 \u0441\u043B\u0443\u0447\u0430\u0435 \u0441
    \u0444\u0443\u043D\u043A\u0446\u0438\u0435\u0439 \u0414\u0438\u0440\u0438\u0445\u043B\u0435,
    \u043C\u0435\u0440\u0430 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B
    \u0440\u0430\u0432\u043D\u0430 \u043D\u0443\u043B\u044E, \u0430 \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u2014 \u0435\u0434\u0438\u043D\u0438\u0446\u0435, \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u043E \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u044C
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B. *   **\u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442:**
    \u041F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u044B\u0439 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B,
    \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u044B\u0439 **\u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u043C
    \u041B\u0435\u0431\u0435\u0433\u0430**, \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E \u043C\u043E\u0449\u043D\u044B\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C. \u041A\u043B\u0430\u0441\u0441
    \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u0443\u0435\u043C\u044B\u0445
    \u043F\u043E \u041B\u0435\u0431\u0435\u0433\u0443 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0448\u0438\u0440\u043E\u0447\u0430\u0439\u0448\u0438\u043C
    \u0438 \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442 \u0431\u043E\u043B\u044C\u0448\u0443\u044E
    \u0447\u0430\u0441\u0442\u044C \u0444\u0443\u043D\u043A\u0446\u0438\u0439, \u0441
    \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439,
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435 \u0438 \u0434\u0440\u0443\u0433\u0438\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445.  ### \U0001F4D0 \u0422\u0435\u043E\u0440\u0438\u044F
    \u043C\u0435\u0440\u044B \u041B\u0435\u0431\u0435\u0433\u0430: \u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442
    \u0434\u043B\u044F \u043D\u043E\u0432\u043E\u0433\u043E \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430 
    \u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B \u041B\u0435\u0431\u0435\u0433\u0430
    \u0431\u044B\u043B \u0431\u044B \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u0435\u043D
    \u0431\u0435\u0437 \u0435\u0433\u043E \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u0435\u0440\u044B. \u041E\u043D \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \xAB\u0434\u043B\u0438\u043D\u044B\xBB
    \u0434\u043B\u044F \u043E\u0447\u0435\u043D\u044C \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432, \u043E\u0431\u043E\u0431\u0449\u0438\u0432
    \u0438\u0434\u0435\u0438 \u0441\u0432\u043E\u0438\u0445 \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    \u2014 \u042D\u043C\u0438\u043B\u044F \u0411\u043E\u0440\u0435\u043B\u044F \u0438
    \u041A\u0430\u043C\u0438\u043B\u044F \u0416\u043E\u0440\u0434\u0430\u043D\u0430. 
    *   **\u0410\u043A\u0441\u0438\u043E\u043C\u044B \u043C\u0435\u0440\u044B:**
    \u0412 \u0441\u0432\u043E\u0435\u0439 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u043E\u0439
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438 1902 \u0433\u043E\u0434\u0430
    (\xAB\u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B, \u0434\u043B\u0438\u043D\u0430,
    \u043F\u043B\u043E\u0449\u0430\u0434\u044C\xBB) \u041B\u0435\u0431\u0435\u0433
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B \u043C\u0435\u0440\u0443
    \u043A\u0430\u043A \u0444\u0443\u043D\u043A\u0446\u0438\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0434\u043E\u043B\u0436\u043D\u0430 \u043E\u0431\u043B\u0430\u0434\u0430\u0442\u044C
    \u0442\u0440\u0435\u043C\u044F \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u043C\u0438
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\u043C\u0438: \u0431\u044B\u0442\u044C
    \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043D\u043E\u0439 \u043F\u0440\u0438
    \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0435 (\u043A\u043E\u043D\u0433\u0440\u0443\u044D\u043D\u0442\u043D\u044B\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u0438\u043C\u0435\u044E\u0442
    \u0440\u0430\u0432\u043D\u0443\u044E \u043C\u0435\u0440\u0443), \u0431\u044B\u0442\u044C
    \u0441\u0447\u0451\u0442\u043D\u043E-\u0430\u0434\u0434\u0438\u0442\u0438\u0432\u043D\u043E\u0439
    (\u043C\u0435\u0440\u0430 \u0441\u0443\u043C\u043C\u044B \u0441\u0447\u0451\u0442\u043D\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u043D\u0435\u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432 \u0440\u0430\u0432\u043D\u0430
    \u0441\u0443\u043C\u043C\u0435 \u0438\u0445 \u043C\u0435\u0440) \u0438 \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C
    \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u0443 (0, 1) \u043C\u0435\u0440\u0443,
    \u0440\u0430\u0432\u043D\u0443\u044E 1. *   **\u0418\u0437\u043C\u0435\u0440\u0438\u043C\u044B\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438:** \u041E\u043D \u0432\u0432\u0435\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\u0438\u0437\u043C\u0435\u0440\u0438\u043C\u043E\u0439
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438**. \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E
    \u043F\u0435\u0440\u0435\u043D\u0435\u0441\u0442\u0438 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043F\u0440\u0435\u0434\u0435\u043B \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439) \u043D\u0430 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0448\u0438\u0440\u043E\u043A\u0438\u0439 \u043A\u043B\u0430\u0441\u0441 \u0444\u0443\u043D\u043A\u0446\u0438\u0439,
    \u0442\u0430\u043A \u043A\u0430\u043A \u043A\u043B\u0430\u0441\u0441 \u0438\u0437\u043C\u0435\u0440\u0438\u043C\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0437\u0430\u043C\u043A\u043D\u0443\u0442
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0430. \u042D\u0442\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E
    \u0441\u0442\u0430\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u043C\u043D\u043E\u0433\u0438\u0445 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0445
    \u0442\u0435\u043E\u0440\u0435\u043C.  ### \U0001F4DA \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B \u0438 \u0438\u0445 \u0432\u043B\u0438\u044F\u043D\u0438\u0435 
    \u041B\u0435\u0431\u0435\u0433 \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u0441\u0432\u043E\u0438
    \u0438\u0434\u0435\u0438 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0432
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438, \u043D\u043E
    \u0438 \u0432 \u0440\u044F\u0434\u0435 \u043A\u043D\u0438\u0433, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0442\u0430\u043B\u0438 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438: 
    *   **\xAB\u041B\u0435\u043A\u0446\u0438\u0438 \u043E\u0431 \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438
    \u0438 \u043E\u0442\u044B\u0441\u043A\u0430\u043D\u0438\u0438 \u043F\u0440\u0438\u043C\u0438\u0442\u0438\u0432\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439\xBB (1904)** \u2014 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430 \u0438 \u0435\u0435 \u0441\u0432\u044F\u0437\u0438
    \u0441 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435\u043C.
    *   **\xAB\u041B\u0435\u043A\u0446\u0438\u0438 \u043E \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u044F\u0434\u0430\u0445\xBB (1906)** \u2014 \u0440\u0430\u0431\u043E\u0442\u0430,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B
    \u0441\u0432\u043E\u0439 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B \u043A
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0440\u044F\u0434\u043E\u0432 \u0424\u0443\u0440\u044C\u0435,
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0432 \u0440\u0435\u0448\u0438\u0442\u044C
    \u0440\u044F\u0434 \u0441\u0442\u0430\u0440\u044B\u0445 \u043F\u0440\u043E\u0431\u043B\u0435\u043C
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u0432\u0430\u0436\u043D\u044B\u0435
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u043F\u043E\u0447\u043B\u0435\u043D\u043D\u043E\u043C
    \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438
    \u0440\u044F\u0434\u043E\u0432.  ### \U0001F30D \u0412\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0434\u0440\u0443\u0433\u0438\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 
    \u0418\u0434\u0435\u0438 \u041B\u0435\u0431\u0435\u0433\u0430 \u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E. \u041E\u043D\u0438
    \u043F\u0440\u043E\u043D\u0438\u043A\u043B\u0438 \u0432:  *   **\u0422\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044E:**
    \u041E\u043D \u0432\u043D\u0435\u0441 \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044E,
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u0432 \u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u043E \u043F\u043E\u043A\u0440\u044B\u0442\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C
    \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430.
    *   **\u0422\u0435\u043E\u0440\u0438\u044E \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439:**
    \u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B \u041B\u0435\u0431\u0435\u0433\u0430
    \u0438 \u0442\u0435\u043E\u0440\u0438\u044F \u043C\u0435\u0440\u044B \u0441\u0442\u0430\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u043A\u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439. *  
    **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u0438\u0437\u0438\u043A\u0443 \u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437:** \u0415\u0433\u043E \u0438\u0434\u0435\u0438
    \u0448\u0438\u0440\u043E\u043A\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F
    \u0432 \u044D\u0442\u0438\u0445 \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0430\u0445. 
    ### \U0001F4A1 \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0439 \u0444\u0430\u043A\u0442:
    \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F \u0438 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u044B 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043E\u0431\u0449\u0438\u0445
    \u0442\u0435\u043E\u0440\u0438\u0439 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u0441\u0430\u043C \u041B\u0435\u0431\u0435\u0433 \u0441 \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E\u0441\u0442\u044C\u044E
    \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0441\u044F \u043A \u0447\u0440\u0435\u0437\u043C\u0435\u0440\u043D\u044B\u043C
    \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u044F\u043C. \u041E\u043D \u043F\u0438\u0441\u0430\u043B:
    *\xAB\u0421\u0432\u0435\u0434\u0435\u043D\u043D\u0430\u044F \u043A \u043E\u0431\u0449\u0438\u043C
    \u0442\u0435\u043E\u0440\u0438\u044F\u043C, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0431\u044B\u043B\u0430 \u0431\u044B \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u043E\u0439 \u0431\u0435\u0437 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u044F.
    \u041E\u043D\u0430 \u0431\u044B\u0441\u0442\u0440\u043E \u0431\u044B \u0443\u043C\u0435\u0440\u043B\u0430\xBB*.
    \u0415\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u043F\u043E\u0441\u043B\u0435 1922 \u0433\u043E\u0434\u0430, \u0447\u0430\u0441\u0442\u043E
    \u0431\u044B\u043B\u0438 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u044B
    \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u043A\u0435, \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.  \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0430\u0431\u043E\u0440
    \u0442\u0435\u043E\u0440\u0435\u043C, \u0430 \u0446\u0435\u043B\u044B\u0439 \u043D\u043E\u0432\u044B\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434 \u043A \u0430\u043D\u0430\u043B\u0438\u0437\u0443
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u0438\u0437\u043C\u0435\u043D\u0438\u043B
    \u043E\u0431\u043B\u0438\u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    XX \u0432\u0435\u043A\u0430."
  achievementsEn: 
  personalLifeRu: "### \U0001F476 \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B,
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u0441\u0435\u043C\u044C\u044F 
    \u0410\u043D\u0440\u0438 \u041B\u0435\u043E\u043D \u041B\u0435\u0431\u0435\u0433
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **28 \u0438\u044E\u043D\u044F 1875
    \u0433\u043E\u0434\u0430** \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 **\u0411\u043E\u0432\u0435**
    \u043D\u0430 \u0441\u0435\u0432\u0435\u0440\u0435 \u0424\u0440\u0430\u043D\u0446\u0438\u0438.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446 \u0431\u044B\u043B \u0442\u0438\u043F\u043E\u0433\u0440\u0430\u0444\u0441\u043A\u0438\u043C
    \u0440\u0430\u0431\u043E\u0447\u0438\u043C, \u0430 \u043C\u0430\u0442\u044C \u2014
    \u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0435\u0439. \u0412
    \u0441\u0435\u043C\u044C\u0435 \u0441\u043E\u0431\u0440\u0430\u043B\u0438 \u0445\u043E\u0440\u043E\u0448\u0443\u044E
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441 \u0440\u0430\u043D\u043D\u0438\u0445 \u043B\u0435\u0442 \u043F\u0440\u0438\u043E\u0431\u0449\u0438\u043B\u0430
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430 \u043A \u0437\u043D\u0430\u043D\u0438\u044F\u043C.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u043A\u043E\u0433\u0434\u0430 \u0410\u043D\u0440\u0438
    \u0431\u044B\u043B\u043E \u0435\u0449\u0451 \u0441\u043E\u0432\u0441\u0435\u043C
    \u043C\u0430\u043B\u043E, \u0435\u0433\u043E \u043E\u0442\u0435\u0446 \u0443\u043C\u0435\u0440
    \u043E\u0442 \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0451\u0437\u0430.
    \u041C\u0430\u0442\u044C, \u043E\u0441\u0442\u0430\u0432\u0448\u0438\u0441\u044C
    \u043E\u0434\u043D\u0430, \u043F\u0440\u0438\u043B\u043E\u0436\u0438\u043B\u0430
    \u0432\u0441\u0435 \u0443\u0441\u0438\u043B\u0438\u044F, \u0447\u0442\u043E\u0431\u044B
    \u0434\u0430\u0442\u044C \u0441\u044B\u043D\u0443 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435,
    \u0438 \u0432\u044B\u0445\u043B\u043E\u043F\u043E\u0442\u0430\u043B\u0430 \u0434\u043B\u044F
    \u043D\u0435\u0433\u043E \u043C\u0443\u043D\u0438\u0446\u0438\u043F\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E. \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E
    \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u043E\u043C\u0443 \u044E\u043D\u043E\u0448\u0435
    \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u044C \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u0439
    \u043A\u043E\u043B\u043B\u0435\u0436 \u0432 \u0411\u043E\u0432\u0435, \u0430
    \u0437\u0430\u0442\u0435\u043C \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C
    \u0443\u0447\u0451\u0431\u0443 \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0445
    \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0445 \u043B\u0438\u0446\u0435\u044F\u0445
    \u0421\u0435\u043D-\u041B\u0443\u0438 \u0438 \u041B\u044E\u0434\u043E\u0432\u0438\u043A\u0430
    \u0412\u0435\u043B\u0438\u043A\u043E\u0433\u043E.  ### \U0001F393 \u0423\u0447\u0451\u0431\u0430
    \u0438 \u043D\u0430\u0447\u0430\u043B\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B 
    \u0412 1894 \u0433\u043E\u0434\u0443 \u041B\u0435\u0431\u0435\u0433 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u044D\u043B\u0438\u0442\u043D\u0443\u044E \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u0443\u044E
    **\u0412\u044B\u0441\u0448\u0443\u044E \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443** (\xC9cole Normale Sup\xE9rieure) \u2014 \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0432\u0443\u0437 \u0424\u0440\u0430\u043D\u0446\u0438\u0438. \u041E\u043D \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0435\u0451 \u0432 1897 \u0433\u043E\u0434\u0443, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0434\u0438\u043F\u043B\u043E\u043C \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  \u0421\u0440\u0430\u0437\u0443
    \u043F\u043E\u0441\u043B\u0435 \u0432\u044B\u043F\u0443\u0441\u043A\u0430 \u041B\u0435\u0431\u0435\u0433
    \u043D\u0435 \u0441\u043F\u0435\u0448\u0438\u043B \u043D\u0430 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443. \u041E\u043D \u043E\u0441\u0442\u0430\u043B\u0441\u044F
    \u0432 \u041D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u0435
    \u0435\u0449\u0451 \u043D\u0430 \u0434\u0432\u0430 \u0433\u043E\u0434\u0430,
    \u0440\u0430\u0431\u043E\u0442\u0430\u044F **\u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u043E\u043C
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0430\u0440\u044F**. \u042D\u0442\u043E
    \u0434\u0430\u043B\u043E \u0435\u043C\u0443 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u0431\u0435\u0441\u043F\u043B\u0430\u0442\u043D\u043E \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C\u0441\u044F
    \u0431\u043E\u0433\u0430\u0442\u0435\u0439\u0448\u0435\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043E\u0439 \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u0441\u0430\u043C\u044B\u0435 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0420\u0435\u043D\u0435-\u041B\u0443\u0438 \u0411\u044D\u0440\u0430 \u043F\u043E
    \u0440\u0430\u0437\u0440\u044B\u0432\u043D\u044B\u043C \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C
    \u0438 \u0442\u0440\u0443\u0434\u044B \u041A\u0430\u043C\u0438\u043B\u043B\u0430
    \u0416\u043E\u0440\u0434\u0430\u043D\u0430. \u0412 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434,
    \u0432 **1898 \u0433\u043E\u0434\u0443**, \u0431\u044B\u043B\u0430 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430
    \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u0442\u0430\u0442\u044C\u044F.  ### \U0001F4BC \u0420\u0430\u0431\u043E\u0442\u0430
    \u0438 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0441\u0435\u043C\u044C\u0438 
    \u0421 1899 \u043F\u043E 1902 \u0433\u043E\u0434 \u041B\u0435\u0431\u0435\u0433
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0432 \u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u043C \u043B\u0438\u0446\u0435\u0435
    \u0433\u043E\u0440\u043E\u0434\u0430 **\u041D\u0430\u043D\u0441\u0438**. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0437\u0434\u0435\u0441\u044C, \u0441\u043E\u0432\u043C\u0435\u0449\u0430\u044F
    \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C, \u043E\u043D
    \u0433\u043E\u0442\u043E\u0432\u0438\u043B \u0441\u0432\u043E\u044E \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u0443\u044E
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \xAB\u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B, \u0434\u043B\u0438\u043D\u0430,
    \u043F\u043B\u043E\u0449\u0430\u0434\u044C\xBB.  \u0412 1903 \u0433\u043E\u0434\u0443,
    \u0432\u0441\u043A\u043E\u0440\u0435 \u043F\u043E\u0441\u043B\u0435 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0439
    \u0437\u0430\u0449\u0438\u0442\u044B \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438,
    \u041B\u0435\u0431\u0435\u0433 \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430
    **\u041B\u0443\u0438\u0437-\u041C\u0430\u0440\u0433\u0435\u0440\u0438\u0442 \u0412\u0430\u043B\u043B\u0435**
    (Louise-Marguerite Vallet), \u0441\u0435\u0441\u0442\u0440\u0435 \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438\u0437 \u0441\u0432\u043E\u0438\u0445 \u043E\u0434\u043D\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A\u043E\u0432.
    \u0412 \u0431\u0440\u0430\u043A\u0435 \u0443 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C
    \u0434\u0432\u043E\u0435 \u0434\u0435\u0442\u0435\u0439 \u2014 \u0441\u044B\u043D
    **\u0416\u0430\u043A** \u0438 \u0434\u043E\u0447\u044C **\u0421\u044E\u0437\u0430\u043D\u043D\u0430**.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0441\u0435\u043C\u0435\u0439\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u043D\u0435 \u0441\u043B\u043E\u0436\u0438\u043B\u0430\u0441\u044C,
    \u0438 \u0432 1916 \u0433\u043E\u0434\u0443 \u0441\u0443\u043F\u0440\u0443\u0433\u0438
    \u0440\u0430\u0437\u043E\u0448\u043B\u0438\u0441\u044C.  ### \U0001F4C8 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430: \u043E\u0442 \u043F\u0440\u043E\u0432\u0438\u043D\u0446\u0438\u0438
    \u043A \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u044D\u043B\u0438\u0442\u0435 
    \u0415\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B\u0430\u0441\u044C \u043F\u043E\u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E,
    \u043F\u043E \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0434\u043B\u044F \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043F\u0443\u0442\u0438 \u2014
    \u043E\u0442 \u043F\u0440\u043E\u0432\u0438\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u043E\u0432
    \u043A \u0441\u0442\u043E\u043B\u0438\u0447\u043D\u044B\u043C.  *   **1902\u20131906**:
    \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    **\u0420\u0435\u043D\u043D\u0430**. *   **1906\u20131910**: \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    **\u041F\u0443\u0430\u0442\u044C\u0435**. *   **1910**: \u041D\u0430\u043A\u043E\u043D\u0435\u0446,
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435
    \u0432 \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u0443\u044E \u0421\u043E\u0440\u0431\u043E\u043D\u043D\u0443,
    \u0433\u0434\u0435 \u0441\u0442\u0430\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C,
    \u0430 \u0441 1920 \u0433\u043E\u0434\u0430 \u2014 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C.
    *   **1921**: \u041B\u0435\u0431\u0435\u0433 \u0437\u0430\u043D\u044F\u043B \u043F\u043E\u0441\u0442
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u043C **\u041A\u043E\u043B\u043B\u0435\u0436
    \u0434\u0435 \u0424\u0440\u0430\u043D\u0441**, \u0433\u0434\u0435 \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0436\u0438\u0437\u043D\u0438. 
    \u0412 \u0433\u043E\u0434\u044B \u041F\u0435\u0440\u0432\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u043E\u043D \u0432\u043D\u0451\u0441 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043E\u0431\u043E\u0440\u043E\u043D\u0443,
    \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u043B\u044F\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u043E\u043C\u0438\u0441\u0441\u0438\u044E \u0421\u043B\u0443\u0436\u0431\u044B
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0439. \u041E\u043D
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0440\u0430\u0441\u0447\u0435\u0442\u0430\u043C\u0438
    \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u0439\u0441\u043A\u0438\u0445
    \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0439, \u0437\u0430 \u0447\u0442\u043E
    \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D \u043E\u0440\u0434\u0435\u043D\u0430
    \u041F\u043E\u0447\u0451\u0442\u043D\u043E\u0433\u043E \u043B\u0435\u0433\u0438\u043E\u043D\u0430. 
    ### \U0001F5E3\uFE0F \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441
    \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438 
    \u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440 \u0443 \u041B\u0435\u0431\u0435\u0433\u0430
    \u0431\u044B\u043B \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u043E\u0439, \u0438
    \u0435\u0433\u043E \u043F\u0443\u0442\u044C \u043A \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044E
    \u0431\u044B\u043B \u043E\u0442\u043C\u0435\u0447\u0435\u043D \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438
    \u0441\u043F\u043E\u0440\u0430\u043C\u0438.  *   **\u0420\u0430\u043D\u043D\u044F\u044F
    \u043A\u0440\u0438\u0442\u0438\u043A\u0430**: \u0415\u0433\u043E \u043F\u0435\u0440\u0432\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u044E
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430 \u0420\u0438\u043C\u0430\u043D\u0430
    \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B\u0438 **\u0440\u0435\u0437\u043A\u0443\u044E
    \u043A\u0440\u0438\u0442\u0438\u043A\u0443** \u0441\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u044B
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043D\u044B\u0445 \u0430\u0432\u0442\u043E\u0440\u0438\u0442\u0435\u0442\u043E\u0432,
    \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A \u0416\u0430\u043D \u0413\u0430\u0441\u0442\u043E\u043D
    \u0414\u0430\u0440\u0431\u0443 \u0438 \u041A\u0430\u043C\u0438\u043B\u043B \u0416\u043E\u0440\u0434\u0430\u043D.
    \u041E\u0434\u043D\u0430\u043A\u043E \u043E\u0447\u0435\u043D\u044C \u0441\u043A\u043E\u0440\u043E
    \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044F \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u043B\u0430
    \u0432\u0441\u0435\u043E\u0431\u0449\u0435\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435.
    *   **\u0421\u043E\u043F\u0435\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u0411\u044D\u0440\u043E\u043C**: \u0423 \u043D\u0435\u0433\u043E \u0432\u043E\u0437\u043D\u0438\u043A\u043B\u0430
    \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u0430\u044F \u043D\u0430\u043F\u0440\u044F\u0436\u0451\u043D\u043D\u043E\u0441\u0442\u044C
    \u0432 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u0445 \u0441 \u0420\u0435\u043D\u0435-\u041B\u0443\u0438
    \u0411\u044D\u0440\u043E\u043C. \u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442
    \u043D\u0430\u0447\u0430\u043B\u0441\u044F \u0432 1904 \u0433\u043E\u0434\u0443
    \u0438\u0437-\u0437\u0430 \u0442\u043E\u0433\u043E, \u043A\u0442\u043E \u0438\u0437
    \u043D\u0438\u0445 \u0438\u043C\u0435\u0435\u0442 \u0431\u043E\u043B\u044C\u0448\u0435
    \u043F\u0440\u0430\u0432 \u0447\u0438\u0442\u0430\u0442\u044C \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439
    \u043A\u0443\u0440\u0441 \u043B\u0435\u043A\u0446\u0438\u0439 \u0432 \u041A\u043E\u043B\u043B\u0435\u0436
    \u0434\u0435 \u0424\u0440\u0430\u043D\u0441, \u0438 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043F\u0435\u0440\u0435\u0440\u043E\u0441 \u0432 \u0437\u0430\u0442\u044F\u0436\u043D\u0443\u044E
    \u0432\u0440\u0430\u0436\u0434\u0443. *   **\u0420\u0430\u0437\u043D\u043E\u0433\u043B\u0430\u0441\u0438\u044F
    \u0441 \u0411\u043E\u0440\u0435\u043B\u0435\u043C**: \u041B\u0435\u0431\u0435\u0433
    \u0442\u0430\u043A\u0436\u0435 \u0440\u0430\u0437\u043E\u0448\u0451\u043B\u0441\u044F
    \u0432\u043E \u0432\u0437\u0433\u043B\u044F\u0434\u0430\u0445 \u0441 \u042D\u043C\u0438\u043B\u0435\u043C
    \u0411\u043E\u0440\u0435\u043B\u0435\u043C (\u043A\u043E\u0442\u043E\u0440\u044B\u0439,
    \u043A\u0441\u0442\u0430\u0442\u0438, \u0431\u044B\u043B \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u043C
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C).
    \u0421\u043F\u043E\u0440 \u043A\u0430\u0441\u0430\u043B\u0441\u044F \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u0432
    \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439 \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043C\u043E\u0441\u0442\u0438
    \u0438 \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438. \u0411\u043E\u0440\u0435\u043B\u044C \u043F\u0440\u0438\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0441\u044F
    \u0431\u043E\u043B\u0435\u0435 \u0441\u0442\u0440\u043E\u0433\u0438\u0445 \u043F\u043E\u0437\u0438\u0446\u0438\u0439,
    \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u0430\u043A \u041B\u0435\u0431\u0435\u0433
    \u0441\u043C\u0435\u043B\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0430\u043A\u0441\u0438\u043E\u043C\u0443 \u0432\u044B\u0431\u043E\u0440\u0430
    \u0438 \u043D\u0435\u0434\u0435\u043B\u0438\u043C\u044B\u0435 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0440\u0430\u0437\u043D\u043E\u0433\u043B\u0430\u0441\u0438\u044F, \u043E\u0431\u0430
    \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B\u0438 \u0432\u043A\u043B\u0430\u0434
    \u0434\u0440\u0443\u0433 \u0434\u0440\u0443\u0433\u0430.  \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u043F\u0440\u0438\u0448\u043B\u043E \u043A \u043D\u0435\u043C\u0443 \u043F\u043E\u0437\u0436\u0435:
    \u0432 1922 \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D
    \u0447\u043B\u0435\u043D\u043E\u043C **\u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A**,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0438 \u043C\u043D\u043E\u0433\u0438\u0445
    \u0434\u0440\u0443\u0433\u0438\u0445 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u043C\u0438\u0440\u0430, \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0435
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0435 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E
    (1930) \u0438 \u0410\u041D \u0421\u0421\u0421\u0420 (1929).  ### \U0001F54A\uFE0F
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0441\u043C\u0435\u0440\u0442\u044C  \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0436\u0438\u0437\u043D\u0438 \u041B\u0435\u0431\u0435\u0433\u0430
    \u0431\u044B\u043B\u0438 \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u044B \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u043E\u0431\u044B\u0442\u0438\u044F\u043C\u0438. \u0412\u043E \u0432\u0440\u0435\u043C\u044F
    \u0412\u0442\u043E\u0440\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u0435\u0433\u043E \u0440\u043E\u0434\u043D\u043E\u0439
    \u0434\u043E\u043C \u0432 \u0411\u043E\u0432\u0435 \u0431\u044B\u043B \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D.
    \u041D\u043E \u0431\u043E\u043B\u0435\u0435 \u0442\u044F\u0436\u0451\u043B\u044B\u043C
    \u0443\u0434\u0430\u0440\u043E\u043C \u0441\u0442\u0430\u043B\u0430 \u043D\u0430\u0446\u0438\u0441\u0442\u0441\u043A\u0430\u044F
    \u043E\u043A\u043A\u0443\u043F\u0430\u0446\u0438\u044F \u0424\u0440\u0430\u043D\u0446\u0438\u0438
    \u0432 1940 \u0433\u043E\u0434\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0440\u0430\u043D\u0438\u043B\u0430
    \u0435\u0433\u043E \u043F\u0430\u0442\u0440\u0438\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0447\u0443\u0432\u0441\u0442\u0432\u0430. \u041B\u0435\u0431\u0435\u0433 \u0437\u0430\u043C\u043A\u043D\u0443\u043B\u0441\u044F
    \u0432 \u0441\u0435\u0431\u0435, \u0435\u0433\u043E \u0438 \u0431\u0435\u0437
    \u0442\u043E\u0433\u043E \u0441\u043B\u0430\u0431\u043E\u0435 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435
    \u0440\u0435\u0437\u043A\u043E \u0443\u0445\u0443\u0434\u0448\u0438\u043B\u043E\u0441\u044C. 
    \u0410\u043D\u0440\u0438 \u041B\u0435\u043E\u043D \u041B\u0435\u0431\u0435\u0433
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F **26 \u0438\u044E\u043B\u044F
    1941 \u0433\u043E\u0434\u0430** \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 66 \u043B\u0435\u0442."
  personalLifeEn: 
  shortBioRu: "\u0410\u043D\u0440\u0438 \u041B\u0435\u043E\u043D \u041B\u0435\u0431\u0435\u0433
    (1875\u20131941) \u2014 \u0444\u0438\u0433\u0443\u0440\u0430, \u0447\u044C\u044F
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u0432 \u0434\u0435\u0442\u0430\u043B\u044F\u0445
    \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u0441\u043A\u043E\u0440\u0435\u0435
    \u0447\u0435\u0440\u0435\u0437 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443,
    \u0447\u0435\u043C \u0447\u0435\u0440\u0435\u0437 \u044F\u0440\u043A\u0438\u0435
    \u0432\u043D\u0435\u0448\u043D\u0438\u0435 \u0441\u043E\u0431\u044B\u0442\u0438\u044F.
    \u041E\u043D \u043F\u0440\u043E\u0436\u0438\u043B \u0436\u0438\u0437\u043D\u044C,
    \u0432\u043D\u0435\u0448\u043D\u0435 \u043B\u0438\u0448\u0435\u043D\u043D\u0443\u044E
    \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043E\u0432, \u043D\u043E \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u0443\u044E
    \u0433\u043B\u0443\u0431\u043E\u0447\u0430\u0439\u0448\u0435\u0439 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0435\u0439
    \u044D\u0432\u043E\u043B\u044E\u0446\u0438\u0435\u0439 \u0435\u0433\u043E \u0438\u0434\u0435\u0439. 
    \u0412\u043E\u0442 \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u043B\u043D\u044B\u0439
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442 \u044D\u0442\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0439 \u043D\u0430 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0434\u0430\u043D\u043D\u044B\u0445. 
    ### \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    (1875\u20131897) \u041B\u0435\u0431\u0435\u0433 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    28 \u0438\u044E\u043D\u044F 1875 \u0433\u043E\u0434\u0430 \u0432 \u0433\u043E\u0440\u043E\u0434\u0435
    \u0411\u043E\u0432\u0435 (\u043D\u0430 \u0441\u0435\u0432\u0435\u0440\u0435 \u0424\u0440\u0430\u043D\u0446\u0438\u0438).
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446 \u0431\u044B\u043B \u043F\u0440\u043E\u0441\u0442\u044B\u043C
    \u0442\u0438\u043F\u043E\u0433\u0440\u0430\u0444\u0441\u043A\u0438\u043C \u0440\u0430\u0431\u043E\u0447\u0438\u043C,
    \u0430 \u043C\u0430\u0442\u044C \u2014 \u0448\u0432\u0435\u0435\u0439. \u041A\u043E\u0433\u0434\u0430
    \u0410\u043D\u0440\u0438 \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E
    11 \u043B\u0435\u0442, \u043E\u0442\u0435\u0446 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u043E\u0442 \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437\u0430,
    \u0438 \u0441\u0435\u043C\u044C\u044F \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C
    \u0432 \u043A\u0440\u0430\u0439\u043D\u0435 \u0441\u0442\u0435\u0441\u043D\u0435\u043D\u043D\u044B\u0445
    \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u0445.
    \u0412\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0435 \u0438 \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430
    \u043B\u0435\u0433\u043B\u0438 \u043D\u0430 \u043F\u043B\u0435\u0447\u0438 \u0435\u0433\u043E
    \u043C\u0430\u0442\u0435\u0440\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F,
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0431\u0435\u0434\u043D\u043E\u0441\u0442\u044C,
    \u0441\u0443\u043C\u0435\u043B\u0430 \u0434\u0430\u0442\u044C \u0441\u044B\u043D\u0443
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0443\u0447\u0438\u0442\u044C\u0441\u044F. 
    \u041F\u0440\u043E\u044F\u0432\u0438\u0432 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438, \u043E\u043D
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439
    \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0439 \u043B\u0438\u0446\u0435\u0439
    \u041B\u044E\u0434\u043E\u0432\u0438\u043A\u0430 \u0412\u0435\u043B\u0438\u043A\u043E\u0433\u043E,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u2014 \u0432 \u0412\u044B\u0441\u0448\u0443\u044E
    \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0443\u044E \u0448\u043A\u043E\u043B\u0443
    (\u0432 1894 \u0433\u043E\u0434\u0443). \u0412 \u0441\u0442\u0435\u043D\u0430\u0445
    \u044D\u0442\u043E\u0439 \u0448\u043A\u043E\u043B\u044B \u043E\u043D \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0432 \u0441\u0440\u0435\u0434\u0435 \u0431\u0443\u0434\u0443\u0449\u0438\u0445
    \u0441\u0432\u0435\u0442\u0438\u043B \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438 (\u0441\u0440\u0435\u0434\u0438 \u0435\u0433\u043E
    \u0441\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A\u043E\u0432 \u0431\u044B\u043B,
    \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u041F\u043E\u043B\u044C \u041F\u0435\u043D\u043B\u0435\u0432\u0435).
    \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E \u043F\u0443\u0442\u044C
    \u043D\u0435 \u0431\u044B\u043B \u0431\u0435\u0437\u043E\u0431\u043B\u0430\u0447\u043D\u044B\u043C:
    \u043D\u0430 \u0432\u044B\u043F\u0443\u0441\u043A\u043D\u044B\u0445 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0430\u0445
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u043E\u043D
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B \u043B\u0438\u0448\u044C \u0432\u0442\u043E\u0440\u043E\u0439
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 (\u0430\u0433\u0440\u0435\u0436\u0435
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0432
    1897 \u0433\u043E\u0434\u0443), \u0443\u0441\u0442\u0443\u043F\u0438\u0432 \u043F\u0435\u0440\u0432\u0435\u043D\u0441\u0442\u0432\u043E.
    \u042D\u0442\u043E, \u043E\u0434\u043D\u0430\u043A\u043E, \u043D\u0435 \u043F\u043E\u043C\u0435\u0448\u0430\u043B\u043E
    \u0435\u043C\u0443 \u0437\u0430\u043D\u044F\u0442\u044C\u0441\u044F \u0447\u0438\u0441\u0442\u043E\u0439
    \u043D\u0430\u0443\u043A\u043E\u0439.  ### \u041D\u0430\u0447\u0430\u043B\u043E
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B \u0438 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u043D\u043E\u0432\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438 (1899\u20131902)
    \u0421\u0440\u0430\u0437\u0443 \u043F\u043E\u0441\u043B\u0435 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u041B\u0435\u0431\u0435\u0433 \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0432 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0435 \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0446\u0435\u043D\u0442\u0440\u0430 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439, \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u043E
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0438\u0437\u0443\u0447\u0430\u044F
    \u0442\u0440\u0443\u0434\u044B \u0441\u0432\u043E\u0438\u0445 \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432.
    \u041A\u043B\u044E\u0447\u0435\u0432\u043E\u0439 \u0442\u043E\u0447\u043A\u043E\u0439
    \u043E\u0442\u0441\u0447\u0435\u0442\u0430 \u0434\u043B\u044F \u0435\u0433\u043E
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439 \u0441\u0442\u0430\u043B 1901
    \u0433\u043E\u0434, \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \xAB\u041E\u0431 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0435\xBB.
    \u0412 \u043D\u0435\u0439 \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u043E \u043D\u043E\u0432\u044B\u0439
    \u0432\u0437\u0433\u043B\u044F\u0434 \u043D\u0430 \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435,
    \u043E\u0431\u043E\u0431\u0449\u0438\u0432 \u0438\u0434\u0435\u0438 \u0420\u0438\u043C\u0430\u043D\u0430. 
    \u0414\u0435\u0442\u0430\u043B\u0438 \u0435\u0433\u043E \u043F\u043E\u0434\u0445\u043E\u0434\u0430
    \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0438\u0441\u044C \u0432 \u043E\u0442\u043A\u0430\u0437\u0435
    \u043E\u0442 \u0440\u0430\u0437\u0431\u0438\u0435\u043D\u0438\u044F \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F (\u043E\u0441\u0438
    X) \u0432 \u043F\u043E\u043B\u044C\u0437\u0443 \u0440\u0430\u0437\u0431\u0438\u0435\u043D\u0438\u044F
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439
    (\u043E\u0441\u0438 Y). \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442\u044C \xAB\u043C\u0435\u0440\u0443\xBB
    \u0434\u0430\u0436\u0435 \u0434\u043B\u044F \u043E\u0447\u0435\u043D\u044C \u0441\u043B\u043E\u0436\u043D\u044B\u0445,
    \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0445 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    \u0442\u043E\u0447\u0435\u043A, \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u043D\u0435\u043C\u044B\u0441\u043B\u0438\u043C\u043E
    \u0432 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0430\u043D\u0430\u043B\u0438\u0437\u0435. \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0435\u0433\u043E
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u043E\u0439 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0432 1902 \u0433\u043E\u0434\u0443 \u0432 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. \u0412\u0430\u0436\u043D\u043E
    \u043E\u0442\u043C\u0435\u0442\u0438\u0442\u044C, \u0447\u0442\u043E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u043E\u0432\u043E\u043C\u0443
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0443, \u0430 \u0446\u0435\u043B\u043E\u043C\u0443
    \u043D\u043E\u0432\u043E\u043C\u0443 \u043F\u043E\u043D\u044F\u0442\u0438\u044E
    **\u0438\u0437\u043C\u0435\u0440\u0438\u043C\u043E\u0441\u0442\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432**,
    \u0447\u0442\u043E \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443\u043B\u043E
    \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437.  ### \u0417\u0440\u0435\u043B\u044B\u0435
    \u0433\u043E\u0434\u044B: \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435
    (1902\u20131921) \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442
    \u043C\u043D\u043E\u0433\u0438\u0445 \u043A\u043E\u043B\u043B\u0435\u0433, \u041B\u0435\u0431\u0435\u0433
    \u043D\u0435 \u0441\u0440\u0430\u0437\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043C\u0435\u0441\u0442\u043E \u0432 \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439
    \u044D\u043B\u0438\u0442\u0435. \u0421 1902 \u043F\u043E 1906 \u0433\u043E\u0434
    \u043E\u043D \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B \u0432
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u0420\u0435\u043D\u043D\u0430
    (\u0432 \u0411\u0440\u0435\u0442\u0430\u043D\u0438), \u0437\u0430\u0442\u0435\u043C
    \u043F\u0435\u0440\u0435\u0448\u0435\u043B \u0432 \u041F\u0443\u0430\u0442\u044C\u0435
    (1906\u20131910), \u0433\u0434\u0435 \u0447\u0438\u0442\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438
    \u043F\u043E \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435. \u041B\u0438\u0448\u044C
    \u0432 1910 \u0433\u043E\u0434\u0443 \u043E\u043D \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u041F\u0430\u0440\u0438\u0436, \u0437\u0430\u043D\u044F\u0432 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044F
    (ma\xEEtre de conf\xE9rences) \u0432 \u0421\u043E\u0440\u0431\u043E\u043D\u043D\u0435.
    \u041F\u043E\u043B\u043D\u044B\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u043E\u043D \u0441\u0442\u0430\u043B \u0442\u043E\u043B\u044C\u043A\u043E \u0432
    1919 \u0433\u043E\u0434\u0443.  \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    (1910\u20131920-\u0435) \u2014 \u0432\u0440\u0435\u043C\u044F \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u043F\u043E\u043B\u0435\u043C\u0438\u043A\u0438. \u041B\u0435\u0431\u0435\u0433
    \u0432\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u0443\u044E
    \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u044E \u0441 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u0442\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u2014 \u042D\u043C\u0438\u043B\u0435\u043C
    \u0411\u043E\u0440\u0435\u043B\u0435\u043C. \u0411\u043E\u0440\u0435\u043B\u044C
    \u0438 \u0435\u0433\u043E \u0448\u043A\u043E\u043B\u0430 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B\u0438
    \u0442\u0435\u043E\u0440\u0438\u044E \u043C\u0435\u0440\u044B \u0441 \u043F\u043E\u0437\u0438\u0446\u0438\u0439
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438 \u0438 \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043C\u043E\u0441\u0442\u0438, \u0442\u043E\u0433\u0434\u0430
    \u043A\u0430\u043A \u041B\u0435\u0431\u0435\u0433 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0430\u043A\u0441\u0438\u043E\u043C\u0443 \u0432\u044B\u0431\u043E\u0440\u0430
    \u0438 \u043D\u0435\u0434\u0435\u043B\u0438\u043C\u044B\u0435 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0431\u043E\u043B\u0435\u0435 \u0441\u043C\u0435\u043B\u043E, \u0447\u0442\u043E
    \u0432\u044B\u0437\u044B\u0432\u0430\u043B\u043E \u043A\u0440\u0438\u0442\u0438\u043A\u0443.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0440\u0430\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F,
    \u043E\u0431\u0430 \u0443\u0447\u0435\u043D\u044B\u0445 \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B\u0438
    \u0432\u0435\u043B\u0438\u0447\u0438\u0435 \u0434\u0440\u0443\u0433 \u0434\u0440\u0443\u0433\u0430.
    \u0412 1922 \u0433\u043E\u0434\u0443 \u041B\u0435\u0431\u0435\u0433 \u0431\u044B\u043B
    \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A, \u0441\u043C\u0435\u043D\u0438\u0432
    \u043D\u0430 \u044D\u0442\u043E\u043C \u043F\u043E\u0441\u0442\u0443 \u0410\u043D\u0440\u0438
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 (\u0447\u0442\u043E \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u043D\u043E,
    \u0445\u043E\u0442\u044F \u0438 \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0433\u043E).  ### \u041F\u043E\u0437\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u0412\u0442\u043E\u0440\u0430\u044F \u043C\u0438\u0440\u043E\u0432\u0430\u044F
    \u0432\u043E\u0439\u043D\u0430 (1921\u20131941) \u0421 1921 \u0433\u043E\u0434\u0430
    \u041B\u0435\u0431\u0435\u0433 \u0437\u0430\u043D\u044F\u043B \u043F\u043E\u0441\u0442
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u0432 \u041A\u043E\u043B\u043B\u0435\u0436
    \u0434\u0435 \u0424\u0440\u0430\u043D\u0441, \u0433\u0434\u0435 \u0447\u0438\u0442\u0430\u043B
    \u043A\u0443\u0440\u0441\u044B \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439. \u0412 1930-\u0435 \u0433\u043E\u0434\u044B
    \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B \u0441\u043C\u0435\u0441\u0442\u0438\u043B\u0438\u0441\u044C
    \u0432 \u0441\u0442\u043E\u0440\u043E\u043D\u0443 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438,
    \u043E\u043D \u043C\u043D\u043E\u0433\u043E \u043F\u0438\u0441\u0430\u043B \u043E\u0431
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u043C \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430.  \u0412 1940 \u0433\u043E\u0434\u0443,
    \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u0440\u0430\u0436\u0435\u043D\u0438\u044F
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438 \u0432\u043E \u0412\u0442\u043E\u0440\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u0435, \u041B\u0435\u0431\u0435\u0433,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0443\u0436\u0435 \u043F\u043E\u0436\u0438\u043B\u044B\u043C
    \u0438 \u0431\u043E\u043B\u044C\u043D\u044B\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0432 \u043E\u043A\u043A\u0443\u043F\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u043C
    \u041F\u0430\u0440\u0438\u0436\u0435. \u0423\u0441\u043B\u043E\u0432\u0438\u044F
    \u0432\u043E\u0435\u043D\u043D\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0441\u0438\u043B\u044C\u043D\u043E \u043F\u043E\u0434\u043E\u0440\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435. \u041E\u043D
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 26 \u0438\u044E\u043B\u044F
    1941 \u0433\u043E\u0434\u0430 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    66 \u043B\u0435\u0442.  ### \u041B\u0438\u0447\u043D\u044B\u0435 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u044B\u0435 \u0434\u0435\u0442\u0430\u043B\u0438
    *   **\u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440:** \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438 \u0435\u0433\u043E \u043A\u0430\u043A
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0433\u043E,
    \u0441\u0442\u0440\u043E\u0433\u043E\u0433\u043E \u043A \u0441\u0435\u0431\u0435
    \u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C, \u043D\u043E \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C \u043E\u0431\u043B\u0430\u0434\u0430\u0432\u0448\u0435\u0433\u043E
    \u0442\u043E\u043D\u043A\u0438\u043C \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C
    \u044E\u043C\u043E\u0440\u0430. *   **\u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435:**
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E
    \u0435\u0433\u043E \u0438\u043C\u044F \u043F\u0440\u043E\u0447\u043D\u043E \u0430\u0441\u0441\u043E\u0446\u0438\u0438\u0440\u0443\u0435\u0442\u0441\u044F
    \u0441 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u043C, \u0441\u0430\u043C
    \u041B\u0435\u0431\u0435\u0433 \u0432 \u043A\u043E\u043D\u0446\u0435 \u0436\u0438\u0437\u043D\u0438
    \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C \u0432\u043A\u043B\u0430\u0434\u043E\u043C
    \u0431\u044B\u043B\u0430 \u043D\u0435 \u0441\u0430\u043C\u0430 \u0442\u0435\u0445\u043D\u0438\u043A\u0430
    \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F,
    \u0430 \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u0438\u0435
    \u0441\u0430\u043C\u043E\u0433\u043E \u043F\u043E\u043D\u044F\u0442\u0438\u044F
    \xAB\u043F\u043B\u043E\u0449\u0430\u0434\u0438 \u043F\u043E\u0434 \u043A\u0440\u0438\u0432\u043E\u0439\xBB
    \u043A\u0430\u043A \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u043C\u0435\u0440\u044B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430. 
    \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u043F\u0440\u0438\u043C\u0435\u0440
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B, \u0433\u0434\u0435 \u0433\u043B\u0430\u0432\u043D\u044B\u0435
    \u0434\u0440\u0430\u043C\u044B \u0440\u0430\u0437\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u043B\u0438\u0441\u044C
    \u043D\u0430 \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0430\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0436\u0443\u0440\u043D\u0430\u043B\u043E\u0432, \u0430 \u043D\u0435 \u0432
    \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0445\u0440\u043E\u043D\u0438\u043A\u0430\u0445,
    \u043D\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u043D\u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0438
    \u044F\u0437\u044B\u043A \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0410\u043D\u0440\u0438 \u041B\u0435\u0431\u0435\u0433\u0430,
    \u043F\u043E\u043C\u0438\u043C\u043E \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u044B\u0445
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439,
    \u043F\u043E\u043B\u043D\u0430 \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u043D\u044B\u0445 \u0434\u0435\u0442\u0430\u043B\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0440\u0438\u0441\u0443\u044E\u0442
    \u0435\u0433\u043E \u0436\u0438\u0432\u043E\u0439, \u0443\u0437\u043D\u0430\u0432\u0430\u0435\u043C\u044B\u0439
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442.  ### \U0001F9D2 \u041A\u0443\u0440\u044C\u0451\u0437
    \u0438\u0437 \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0445 \u043B\u0435\u0442 
    \u041E\u0434\u043D\u0430 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439 \u0441\u043B\u0443\u0447\u0438\u043B\u0430\u0441\u044C
    \u0441 \u041B\u0435\u0431\u0435\u0433\u043E\u043C, \u043A\u043E\u0433\u0434\u0430
    \u0435\u043C\u0443 \u0431\u044B\u043B\u043E \u043E\u043A\u043E\u043B\u043E \u0434\u0435\u0441\u044F\u0442\u0438
    \u043B\u0435\u0442. \u041D\u0430 \u0443\u0440\u043E\u043A\u0435 \u043E\u043D
    \u0440\u0435\u0448\u0438\u043B \u0437\u0430\u0434\u0430\u0447\u0443 \u043F\u0435\u0440\u0432\u044B\u043C
    \u0438 \u043F\u0440\u0438\u043D\u0435\u0441 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u0443\u0447\u0438\u0442\u0435\u043B\u044E. \u0423\u0447\u0438\u0442\u0435\u043B\u044C,
    \u0441\u0432\u0435\u0440\u0438\u0432\u0448\u0438\u0441\u044C \u0441 \u043E\u0442\u0432\u0435\u0442\u043E\u043C
    \u0432 \u043A\u043D\u0438\u0433\u0435, \u0441\u043A\u0430\u0437\u0430\u043B \u0435\u043C\u0443:
    \xAB\u042D\u0442\u043E \u043D\u0435\u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E.
    \u041F\u0435\u0440\u0435\u0434\u0435\u043B\u044B\u0432\u0430\u0439\xBB. \u041B\u0435\u0431\u0435\u0433
    \u043E\u0442\u043E\u0448\u0435\u043B, \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u043B
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435, \u043D\u0435 \u043D\u0430\u0448\u0435\u043B
    \u043E\u0448\u0438\u0431\u043A\u0438 \u0438 \u0441\u043D\u043E\u0432\u0430 \u043F\u043E\u0434\u043E\u0448\u0435\u043B
    \u0441 \u0442\u0435\u043C \u0436\u0435 \u043E\u0442\u0432\u0435\u0442\u043E\u043C.
    \u0423\u0447\u0438\u0442\u0435\u043B\u044C \u0441\u043D\u043E\u0432\u0430 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u0435\u0433\u043E \u043F\u0435\u0440\u0435\u0434\u0435\u043B\u044B\u0432\u0430\u0442\u044C. 
    \u0412 \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442, \u043A\u043E\u0433\u0434\u0430
    \u043F\u0435\u0434\u0430\u0433\u043E\u0433 \u0432\u044B\u0448\u0435\u043B \u0438\u0437
    \u043A\u043B\u0430\u0441\u0441\u0430, \u043C\u0430\u043B\u044C\u0447\u0438\u043A
    \u0437\u0430\u0433\u043B\u044F\u043D\u0443\u043B \u0432 \u043A\u043D\u0438\u0433\u0443,
    \u0433\u0434\u0435 \u043D\u0430\u0448\u0435\u043B \u043E\u043F\u0435\u0447\u0430\u0442\u043A\u0443
    \u0432 \u043E\u0442\u0432\u0435\u0442\u0435. \u041B\u0435\u0431\u0435\u0433 \u0431\u044B\u043B
    \u043F\u0440\u0430\u0432 \u0441 \u0441\u0430\u043C\u043E\u0433\u043E \u043D\u0430\u0447\u0430\u043B\u0430,
    \u0430 \u0443\u0447\u0438\u0442\u0435\u043B\u044C \u0441\u043B\u0435\u043F\u043E
    \u0434\u043E\u0432\u0435\u0440\u044F\u043B \u043F\u0435\u0447\u0430\u0442\u043D\u043E\u043C\u0443
    \u0442\u0435\u043A\u0441\u0442\u0443.  ### \U0001F3AD \u0421\u043B\u043E\u0436\u043D\u044B\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440  \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438 \u041B\u0435\u0431\u0435\u0433\u0430
    \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0433\u043E
    \u0438 \u0441\u0442\u0440\u043E\u0433\u043E\u0433\u043E, \u043D\u043E \u0441
    \u0442\u043E\u043D\u043A\u0438\u043C \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C
    \u044E\u043C\u043E\u0440\u0430. \u041E\u043D \u0431\u044B\u043B \u043F\u0440\u043E\u0441\u0442\u044B\u043C
    \u0438 \u043D\u0435\u0443\u043A\u043B\u044E\u0436\u0438\u043C \u0432 \u0441\u0432\u0435\u0442\u0441\u043A\u043E\u043C
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435, \u0447\u0442\u043E \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u043E
    \u0435\u0449\u0435 \u043E\u0434\u043D\u0443 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0443\u044E
    \u0438\u0441\u0442\u043E\u0440\u0438\u044E. \u041E\u0434\u043D\u0430\u0436\u0434\u044B
    \u0432 \u0433\u0430\u0440\u0434\u0435\u0440\u043E\u0431\u0435 \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D\u0430
    \u043E\u043D \u043F\u043E \u043E\u0448\u0438\u0431\u043A\u0435 \u0432\u0437\u044F\u043B
    \u0447\u0443\u0436\u043E\u0435 \u043F\u0430\u043B\u044C\u0442\u043E. \u041A\u043E\u0433\u0434\u0430
    \u043E\u043D \u0437\u0430\u043C\u0435\u0442\u0438\u043B \u043E\u0448\u0438\u0431\u043A\u0443
    \u0438 \u0432\u0435\u0440\u043D\u0443\u043B \u043F\u0430\u043B\u044C\u0442\u043E
    \u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0443, \u0442\u043E\u0442, \u0437\u0430\u043C\u0435\u0442\u0438\u0432
    \u043D\u0430 \u043D\u0435\u043C \u043E\u0440\u0434\u0435\u043D\u0441\u043A\u0443\u044E
    \u043B\u0435\u043D\u0442\u0443, \u0432\u044B\u0441\u043E\u043A\u043E\u043C\u0435\u0440\u043D\u043E
    \u0441\u043A\u0430\u0437\u0430\u043B: \xAB\u0412\u044B \u043C\u043E\u0433\u043B\u0438
    \u0431\u044B \u0437\u0430\u043C\u0435\u0442\u0438\u0442\u044C \u043B\u0435\u043D\u0442\u0443
    \u041F\u043E\u0447\u0435\u0442\u043D\u043E\u0433\u043E \u043B\u0435\u0433\u0438\u043E\u043D\u0430!\xBB 
    \u041B\u0435\u0431\u0435\u0433 \u043F\u0440\u043E\u043C\u043E\u043B\u0447\u0430\u043B.
    \u041E\u043D \u0442\u043E\u0436\u0435 \u0431\u044B\u043B \u043A\u0430\u0432\u0430\u043B\u0435\u0440\u043E\u043C
    \u044D\u0442\u043E\u0433\u043E \u043E\u0440\u0434\u0435\u043D\u0430, \u043D\u043E
    \u043D\u0435 \u0441\u0442\u0430\u043B \u0432\u0441\u0442\u0443\u043F\u0430\u0442\u044C
    \u0432 \u0441\u043F\u043E\u0440 \u0438 \u0443\u043D\u0438\u0436\u0430\u0442\u044C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u043E\u0442\u0432\u0435\u0442\u043E\u043C. 
    ### \U0001F454 \u0421\u0435\u043C\u0435\u0439\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0438 \u0431\u044B\u0442  \u0415\u0433\u043E \u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430 \u043D\u0435 \u043C\u0435\u043D\u0435\u0435
    \u043F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439.
    \u0412 1903 \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u041B\u0443\u0438\u0437-\u041C\u0430\u0440\u0433\u0435\u0440\u0438\u0442
    \u0412\u0430\u043B\u043B\u0435 (\u0441\u0435\u0441\u0442\u0440\u0435 \u0441\u0432\u043E\u0435\u0433\u043E
    \u043E\u0434\u043D\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A\u0430). \u0412
    \u0431\u0440\u0430\u043A\u0435 \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C
    \u0434\u0432\u043E\u0435 \u0434\u0435\u0442\u0435\u0439 \u2014 \u0416\u0430\u043A
    \u0438 \u0421\u044E\u0437\u0430\u043D\u043D\u0430, \u043D\u043E \u0432 1916 \u0433\u043E\u0434\u0443
    \u0441\u0443\u043F\u0440\u0443\u0433\u0438 \u0440\u0430\u0437\u043E\u0448\u043B\u0438\u0441\u044C.
    \u0415\u0433\u043E \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430 \u0441
    \u042D\u043C\u0438\u043B\u0435\u043C \u0411\u043E\u0440\u0435\u043B\u0435\u043C,
    \u043D\u0430\u0439\u0434\u0435\u043D\u043D\u0430\u044F \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044F\u043C\u0438,
    \u0446\u0435\u043D\u043D\u0430 \u0438\u043C\u0435\u043D\u043D\u043E \u0442\u0435\u043C,
    \u0447\u0442\u043E \u0432 \u043D\u0435\u0439 \u041B\u0435\u0431\u0435\u0433 \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0434\u0435\u0438, \u043D\u043E \u0438 \u043F\u043E\u0432\u0441\u0435\u0434\u043D\u0435\u0432\u043D\u044B\u0435
    \u0437\u0430\u0431\u043E\u0442\u044B: \u043E\u043D \u0434\u0435\u043B\u0438\u0442\u0441\u044F
    \u043C\u044B\u0441\u043B\u044F\u043C\u0438 \u043E \u0434\u0435\u043D\u044C\u0433\u0430\u0445,
    \u043E \u043A\u0430\u0440\u044C\u0435\u0440\u043D\u044B\u0445 \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u0430\u0445,
    \u043E \u0436\u0438\u0442\u0435\u0439\u0441\u043A\u0438\u0445 \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u044F\u0445
    \u0438 \u0434\u0430\u0436\u0435 \u043E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438
    \u0441\u0432\u043E\u0438\u0445 \u043A\u043E\u043B\u043B\u0435\u0433. \u042D\u0442\u043E
    \u0434\u0435\u043B\u0430\u0435\u0442 \u0435\u0433\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043E\u0442\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u043D\u044B\u043C \u0433\u0435\u043D\u0438\u0435\u043C,
    \u0430 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439,
    \u043A\u0430\u043A \u0438 \u0432\u0441\u0435, \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u043B
    \u0438\u0437-\u0437\u0430 \u0431\u044B\u0442\u043E\u0432\u044B\u0445 \u043F\u0440\u043E\u0431\u043B\u0435\u043C. 
    ### \U0001F4D0 \u042F\u0440\u043A\u0438\u0439 \u043E\u0431\u0440\u0430\u0437:
    \u0440\u0430\u0437\u043D\u0438\u0446\u0430 \u043C\u0435\u0436\u0434\u0443 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430\u043C\u0438
    \u0420\u0438\u043C\u0430\u043D\u0430 \u0438 \u041B\u0435\u0431\u0435\u0433\u0430 
    \u041E\u043D \u0441\u0430\u043C \u043E\u0447\u0435\u043D\u044C \u043E\u0431\u0440\u0430\u0437\u043D\u043E
    \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u043B \u0440\u0430\u0437\u043D\u0438\u0446\u0443
    \u043C\u0435\u0436\u0434\u0443 \u0441\u0432\u043E\u0438\u043C \u043C\u0435\u0442\u043E\u0434\u043E\u043C
    \u0438 \u043C\u0435\u0442\u043E\u0434\u043E\u043C \u0420\u0438\u043C\u0430\u043D\u0430,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u0431\u044B\u0442\u043E\u0432\u0443\u044E
    \u0430\u043D\u0430\u043B\u043E\u0433\u0438\u044E: *\xAB\u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u044C\u0442\u0435,
    \u0447\u0442\u043E \u0432\u044B \u0434\u043E\u043B\u0436\u043D\u044B \u0437\u0430\u043F\u043B\u0430\u0442\u0438\u0442\u044C
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u0443\u044E \u0441\u0443\u043C\u043C\u0443.
    \u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B \u0420\u0438\u043C\u0430\u043D\u0430
    \u2014 \u044D\u0442\u043E \u043A\u043E\u0433\u0434\u0430 \u0432\u044B \u043F\u0440\u043E\u0441\u0442\u043E
    \u0434\u043E\u0441\u0442\u0430\u0435\u0442\u0435 \u0438\u0437 \u043A\u0430\u0440\u043C\u0430\u043D\u0430
    \u043C\u043E\u043D\u0435\u0442\u044B \u0438 \u0431\u0430\u043D\u043A\u043D\u043E\u0442\u044B
    \u0432 \u0442\u043E\u043C \u043F\u043E\u0440\u044F\u0434\u043A\u0435, \u0432
    \u043A\u0430\u043A\u043E\u043C \u043E\u043D\u0438 \u0442\u0430\u043C \u043B\u0435\u0436\u0430\u0442,
    \u0438 \u043E\u0442\u0434\u0430\u0435\u0442\u0435 \u0438\u0445 \u043A\u0440\u0435\u0434\u0438\u0442\u043E\u0440\u0443,
    \u043F\u043E\u043A\u0430 \u043D\u0435 \u043D\u0430\u0431\u0435\u0440\u0435\u0442\u0435
    \u043D\u0443\u0436\u043D\u0443\u044E \u0441\u0443\u043C\u043C\u0443. \u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B
    \u041B\u0435\u0431\u0435\u0433\u0430 \u2014 \u044D\u0442\u043E \u043A\u043E\u0433\u0434\u0430
    \u0432\u044B \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u0440\u0430\u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442\u0435
    \u0432\u0441\u0435 \u0434\u0435\u043D\u044C\u0433\u0438 \u043F\u043E \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u0443,
    \u0433\u0440\u0443\u043F\u043F\u0438\u0440\u0443\u0435\u0442\u0435 \u043C\u043E\u043D\u0435\u0442\u043A\u0438
    \u0438 \u043A\u0443\u043F\u044E\u0440\u044B \u043E\u0434\u043D\u043E\u0433\u043E
    \u043D\u043E\u043C\u0438\u043D\u0430\u043B\u0430, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u043E\u0442\u0434\u0430\u0435\u0442\u0435 \u0438\u0445 \u0432\u0441\u0435 \u0432\u043C\u0435\u0441\u0442\u0435\xBB*. 
    \u042D\u0442\u0430 \u0430\u043D\u0430\u043B\u043E\u0433\u0438\u044F \u0437\u0430\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442 \u0441\u0443\u0442\u044C
    \u0435\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u0430: \u0432\u043C\u0435\u0441\u0442\u043E
    \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B \xAB\u0441\u043E\u0431\u0438\u0440\u0430\u0442\u044C\xBB
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B, \u0438\u0434\u044F \u043F\u043E
    \u043E\u0441\u0438 X (\u043A\u0430\u043A \u0420\u0438\u043C\u0430\u043D), \u043E\u043D
    \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u0441\u043C\u043E\u0442\u0440\u0438\u0442
    \u043D\u0430 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u0438
    (\u043E\u0441\u044C Y), \u0433\u0440\u0443\u043F\u043F\u0438\u0440\u0443\u0435\u0442
    \u0438\u0445 \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442 \u0441 \xAB\u043C\u0435\u0440\u043E\u0439\xBB
    \u044D\u0442\u0438\u0445 \u0433\u0440\u0443\u043F\u043F.  ### \U0001F9D0 \u0421\u0434\u0435\u0440\u0436\u0430\u043D\u043D\u043E\u0435
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435 \u043A \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u044F\u043C 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043E\u0431\u0449\u0438\u0445
    \u0438 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0445 \u0442\u0435\u043E\u0440\u0438\u0439
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0441\u0430\u043C
    \u041B\u0435\u0431\u0435\u0433 \u043D\u0435 \u0431\u044B\u043B \u043F\u043E\u043A\u043B\u043E\u043D\u043D\u0438\u043A\u043E\u043C
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u0439 \u0440\u0430\u0434\u0438
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u0439. \u041E\u043D \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0441\u0432\u043E\u0435\u0439 \u0444\u0440\u0430\u0437\u043E\u0439: *\xAB\u0421\u0432\u0435\u0434\u0435\u043D\u043D\u0430\u044F
    \u043A \u043E\u0431\u0449\u0438\u043C \u0442\u0435\u043E\u0440\u0438\u044F\u043C,
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0431\u044B\u043B\u0430
    \u0431\u044B \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E\u0439 \u0444\u043E\u0440\u043C\u043E\u0439
    \u0431\u0435\u0437 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u044F\xBB*.
    \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u0437\u0430
    \u043E\u0431\u0449\u0438\u043C\u0438 \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F\u043C\u0438
    \u0432\u0441\u0435\u0433\u0434\u0430 \u0434\u043E\u043B\u0436\u043D\u0430 \u0441\u0442\u043E\u044F\u0442\u044C
    \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u0430\u044F \u0437\u0430\u0434\u0430\u0447\u0430
    \u0438 \u0441\u043C\u044B\u0441\u043B.  ### \U0001F48E \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439
    \u0441\u043B\u0435\u0434  \u0415\u0433\u043E \u0438\u043C\u044F \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u0440\u043E\u0447\u043D\u043E \u0432\u043E\u0448\u043B\u043E \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u044F\u0437\u044B\u043A, \u0447\u0442\u043E \u0434\u0430\u0436\u0435 \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u043E
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439 \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442-\u043C\u0435\u043C,
    \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u0443\u044E\u0449\u0438\u0439
    \u0440\u0430\u0437\u043D\u0438\u0446\u0443 \u043C\u0435\u0436\u0434\u0443 \u043F\u043E\u0434\u0445\u043E\u0434\u0430\u043C\u0438.
    \u041D\u0430 \u043A\u0430\u0440\u0442\u0438\u043D\u043A\u0435 \xAB\u041F\u0440\u043E\u0442\u0438\u0440\u0430\u043D\u0438\u0435
    \u0434\u043E\u0441\u043A\u0438 \u043F\u043E \u041B\u0435\u0431\u0435\u0433\u0443
    \u0438 \u043F\u043E \u0420\u0438\u043C\u0430\u043D\u0443\xBB \u0441\u043B\u0435\u0432\u0430
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C
    \u0448\u0438\u0440\u043E\u043A\u043E\u0439 \u0448\u0432\u0430\u0431\u0440\u043E\u0439
    \u0441\u0442\u0438\u0440\u0430\u0435\u0442 \u043F\u043E\u0447\u0442\u0438 \u0432\u0441\u044E
    \u0434\u043E\u0441\u043A\u0443 (\u043A\u0430\u043A \u041B\u0435\u0431\u0435\u0433
    \xAB\u0441\u043E\u0431\u0438\u0440\u0430\u0435\u0442\xBB \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B,
    \u0440\u0430\u0431\u043E\u0442\u0430\u044F \u0441 \u0431\u043E\u043B\u044C\u0448\u0438\u043C\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430\u043C\u0438 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439),
    \u0430 \u0441\u043F\u0440\u0430\u0432\u0430 \u2014 \u0441\u0442\u0438\u0440\u0430\u0435\u0442
    \u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0437\u043A\u0443\u044E \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u0443\u044E
    \u043F\u043E\u043B\u043E\u0441\u0443 (\u043A\u0430\u043A \u0420\u0438\u043C\u0430\u043D
    \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F \u043F\u043E \u0443\u0437\u043A\u0438\u043C
    \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u0430\u043C \u043E\u0441\u0438
    X)."
