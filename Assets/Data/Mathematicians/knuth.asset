  achievementsRu: "\u0414\u043E\u043D\u0430\u043B\u044C\u0434 \u041A\u043D\u0443\u0442
    \u2014 \u044D\u0442\u043E, \u043F\u043E \u0441\u0443\u0442\u0438, \u0436\u0438\u0432\u043E\u0439
    \u043A\u043B\u0430\u0441\u0441\u0438\u043A, \u0447\u044C\u0435 \u0438\u043C\u044F
    \u0441\u0442\u0430\u043B\u043E \u043D\u0430\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0432 \u043C\u0438\u0440\u0435 IT. \u0415\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0441\u043E\u0441\u0442\u043E\u0438\u0442 \u0438\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u043A\u0438\u0440\u043F\u0438\u0447\u0435\u0439,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440 \u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0435
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435.
    \u0421\u043B\u043E\u0436\u043D\u043E \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u044C
    \u043E\u0434\u043D\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435,
    \u0432\u0435\u0434\u044C \u043A\u0430\u0436\u0434\u043E\u0435 \u0438\u0437 \u043D\u0438\u0445
    \u0441\u0442\u0430\u043B\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C
    \u0432 \u0441\u0432\u043E\u0435\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. 
    ### \U0001F4DA \"\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\":
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0432\u0441\u0435\u0439
    \u043E\u0442\u0440\u0430\u0441\u043B\u0438  \u042D\u0442\u043E, \u0431\u0435\u0441\u0441\u043F\u043E\u0440\u043D\u043E,
    \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434 \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u0438, \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u044F \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432
    \u0438 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440 \u0434\u0430\u043D\u043D\u044B\u0445.
    \u0417\u0430\u043C\u044B\u0441\u0435\u043B \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 1962 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B\u043E \u0435\u0433\u043E \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C
    \u043A\u043D\u0438\u0433\u0443 \u043E \u043A\u043E\u043C\u043F\u0438\u043B\u044F\u0442\u043E\u0440\u0430\u0445.
    \u041A\u043D\u0443\u0442 \u043F\u043E\u0434\u043E\u0448\u0435\u043B \u043A \u0437\u0430\u0434\u0430\u0447\u0435
    \u0433\u043B\u043E\u0431\u0430\u043B\u044C\u043D\u043E: \u043F\u043B\u0430\u043D
    \u0440\u0430\u0437\u0440\u043E\u0441\u0441\u044F \u0434\u043E **\u0441\u0435\u043C\u0438
    \u0442\u043E\u043C\u043E\u0432**, \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0438\u0445
    \u0432\u0441\u0435 \u0430\u0441\u043F\u0435\u043A\u0442\u044B \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u044B\u0445
    \u043D\u0430\u0443\u043A.  \u0421\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430
    \u044D\u0442\u043E\u0433\u043E \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u043E\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430 \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442
    \u0442\u0430\u043A :  *   **\u0422\u043E\u043C 1. \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u044B:** \u0417\u0430\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442, \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044F
    \u0431\u0430\u0437\u043E\u0432\u044B\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u044F,
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442 \u0438 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B. *   **\u0422\u043E\u043C
    2. \u041F\u043E\u043B\u0443\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0435
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u044B:** \u041F\u043E\u0441\u0432\u044F\u0449\u0435\u043D
    \u0433\u0435\u043D\u0435\u0440\u0430\u0446\u0438\u0438 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u0438 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u044F\u043C. *   **\u0422\u043E\u043C
    3. \u0421\u043E\u0440\u0442\u0438\u0440\u043E\u0432\u043A\u0430 \u0438 \u043F\u043E\u0438\u0441\u043A:**
    \u041F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0439\u0448\u0438\u0439 \u0430\u043D\u0430\u043B\u0438\u0437
    \u043C\u0435\u0442\u043E\u0434\u043E\u0432 \u0441\u043E\u0440\u0442\u0438\u0440\u043E\u0432\u043A\u0438
    \u0438 \u043F\u043E\u0438\u0441\u043A\u0430 \u0434\u0430\u043D\u043D\u044B\u0445,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u041A\u043D\u0443\u0442 \u0441\u0447\u0438\u0442\u0430\u043B
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u043C\u0438 \u0430\u0441\u043F\u0435\u043A\u0442\u0430\u043C\u0438
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F.
    *   **\u0422\u043E\u043C 4. \u041A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u043D\u044B\u0435
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u044B:** \u0412\u044B\u0448\u0435\u043B
    \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u0447\u0430\u0441\u0442\u044F\u0445
    (4A, 4B) \u0438 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D \u0441\u043B\u043E\u0436\u043D\u044B\u043C
    \u0437\u0430\u0434\u0430\u0447\u0430\u043C \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u043D\u043E\u0433\u043E
    \u043F\u043E\u0438\u0441\u043A\u0430. *   **\u0422\u043E\u043C\u0430 5-7:** \u041E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0442
    \u0441\u0438\u043D\u0442\u0430\u043A\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u044B, \u0442\u0435\u043E\u0440\u0438\u044E
    \u044F\u0437\u044B\u043A\u043E\u0432 \u0438 \u043A\u043E\u043C\u043F\u0438\u043B\u044F\u0442\u043E\u0440\u044B,
    \u0438 \u0432\u0441\u0451 \u0435\u0449\u0435 \u043D\u0430\u0445\u043E\u0434\u044F\u0442\u0441\u044F
    \u0432 \u0440\u0430\u0431\u043E\u0442\u0435.  \u042D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0432\u044B\u0441\u043E\u0447\u0430\u0439\u0448\u0435\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0410\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E \u0437\u0430\u044F\u0432\u0438\u043B\u043E,
    \u0447\u0442\u043E \u043A\u043D\u0438\u0433\u0430 \"\u0432\u043D\u0435\u0441\u043B\u0430
    \u0431\u043E\u043B\u044C\u0448\u0438\u0439 \u0432\u043A\u043B\u0430\u0434 \u0432
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043D\u044B\u043D\u0435\u0448\u043D\u0435\u043C\u0443 \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044E
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432, \u0447\u0435\u043C \u043B\u044E\u0431\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u043D\u0438\u0433\u0430, \u0432\u044B\u0448\u0435\u0434\u0448\u0430\u044F
    \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F\".
    \u0417\u0430\u043C\u044B\u0441\u0435\u043B, \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430
    \u0438 \u0433\u043B\u0443\u0431\u0438\u043D\u0430 \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u043A\u0438
    \u0441\u0434\u0435\u043B\u0430\u043B\u0438 \"\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\"
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043D\u043E\u0439 \u043A\u043D\u0438\u0433\u043E\u0439
    \u0434\u043B\u044F \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0439 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u043E\u0432.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u0434\u043B\u044F
    \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0430\u0446\u0438\u0438 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432
    \u041A\u043D\u0443\u0442 \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B \u0433\u0438\u043F\u043E\u0442\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440 **MIX**, \u0447\u0442\u043E
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u044B \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E
    \u043E\u0442 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0445 \u044F\u0437\u044B\u043A\u043E\u0432
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F. 
    ### \U0001F9EE \u0421\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C TeX \u0438
    METAFONT: \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F \u0432 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0432\u0435\u0440\u0441\u0442\u043A\u0435  \u0412 \u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0435
    1970-\u0445 \u041A\u043D\u0443\u0442 \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F
    \u0441 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u043E\u0439: \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u043E
    \u0432\u0435\u0440\u0441\u0442\u043A\u0438 \u043D\u043E\u0432\u044B\u0445 \u0438\u0437\u0434\u0430\u043D\u0438\u0439
    \u0435\u0433\u043E \u043A\u043D\u0438\u0433 \u0435\u0433\u043E \u0443\u0436\u0430\u0441\u043D\u043E
    \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u044B\u0432\u0430\u043B\u043E.
    \u0420\u0435\u0448\u0435\u043D\u0438\u0435 \u0431\u044B\u043B\u043E \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u043C:
    \u043E\u043D \u0440\u0435\u0448\u0438\u043B **\u0441\u0430\u043C \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u043E\u0439
    \u0432\u0435\u0440\u0441\u0442\u043A\u0438**.  \u0422\u0430\u043A \u0432 1977
    \u0433\u043E\u0434\u0443 \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C \u0440\u0430\u0431\u043E\u0442\u0430
    \u043D\u0430\u0434 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u043C\u0438 **TeX**
    (\u0434\u043B\u044F \u043D\u0430\u0431\u043E\u0440\u0430 \u0442\u0435\u043A\u0441\u0442\u0430,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u043E\u0440\u043C\u0443\u043B) \u0438 **METAFONT** (\u0434\u043B\u044F
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0448\u0440\u0438\u0444\u0442\u043E\u0432).
    \u042D\u0442\u043E \u0431\u044B\u043B \u0434\u043E\u043B\u0433\u0438\u0439 \u0438
    \u043A\u0440\u043E\u043F\u043E\u0442\u043B\u0438\u0432\u044B\u0439 \u043F\u0443\u0442\u044C:
    \u041A\u043D\u0443\u0442 \u0434\u0443\u043C\u0430\u043B \u0441\u043F\u0440\u0430\u0432\u0438\u0442\u044C\u0441\u044F
    \u0437\u0430 8 \u043C\u0435\u0441\u044F\u0446\u0435\u0432, \u043D\u043E \u0440\u0430\u0431\u043E\u0442\u0430
    \u0437\u0430\u0442\u044F\u043D\u0443\u043B\u0430\u0441\u044C \u043D\u0430 \u0446\u0435\u043B\u044B\u0445
    10 \u043B\u0435\u0442. \u041E\u0434\u043D\u0430\u043A\u043E \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u043F\u0440\u0435\u0432\u0437\u043E\u0448\u0435\u043B \u0432\u0441\u0435 \u043E\u0436\u0438\u0434\u0430\u043D\u0438\u044F.
    TeX \u0441\u0442\u0430\u043B \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043E\u043C
    \u0434\u0435-\u0444\u0430\u043A\u0442\u043E \u0434\u043B\u044F \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0438
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0439,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u0444\u0438\u0437\u0438\u043A\u0435 \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438.
    \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F TeX \u0441\u0442\u0430\u043B\u0430
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u0430 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F
    \u0441\u0442\u0430\u0442\u0435\u0439 \u0441 \u0441\u0430\u043C\u044B\u043C\u0438
    \u0441\u043B\u043E\u0436\u043D\u044B\u043C\u0438 \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u043C\u0438
    \u0432 \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u043C\u0438\u0440\u043E\u0432\u044B\u0445
    \u0436\u0443\u0440\u043D\u0430\u043B\u0430\u0445.  ### \U0001F4A1 \u0418\u043D\u043D\u043E\u0432\u0430\u0446\u0438\u0438:
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432
    \u0438 \"\u0433\u0440\u0430\u043C\u043E\u0442\u043D\u043E\u0435 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435\" 
    \u041F\u043E\u043C\u0438\u043C\u043E \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432 \u0438 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432,
    \u041A\u043D\u0443\u0442 \u043F\u043E\u0434\u0430\u0440\u0438\u043B \u043C\u0438\u0440\u0443
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043A\u043E\u043D\u0446\u0435\u043F\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u0434\u0435\u0439, \u0431\u0435\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0441\u0435\u0439\u0447\u0430\u0441 \u0441\u043B\u043E\u0436\u043D\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u044E \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0441\u0442\u0430. 
    *   **\u041E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432:**
    \u041A\u043D\u0443\u0442\u0430 \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    **\"\u043E\u0442\u0446\u043E\u043C \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432\"**. \u0418\u043C\u0435\u043D\u043D\u043E
    \u043E\u043D \u043F\u0440\u0438\u0432\u043D\u0435\u0441 \u0432 \u044D\u0442\u0443
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u0441\u0442\u0440\u043E\u0433\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0443, \u043D\u0430\u0443\u0447\u0438\u0432
    \u043D\u0430\u0441 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0438\u0441\u0430\u0442\u044C
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B, \u043D\u043E \u0438 \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u0438\u0445 \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C.
    \u0417\u0430 \u044D\u0442\u043E\u0442 \u0432\u043A\u043B\u0430\u0434 \u043E\u043D
    \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D **\u041F\u0440\u0435\u043C\u0438\u0438
    \u0422\u044C\u044E\u0440\u0438\u043D\u0433\u0430 \u0432 1974 \u0433\u043E\u0434\u0443**
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u0432\u0441\u0435\u0433\u043E
    36 \u043B\u0435\u0442, \u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435\u043C. *   **\u041A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044F
    \"\u0433\u0440\u0430\u043C\u043E\u0442\u043D\u043E\u0433\u043E \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\":**
    \u041E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
    \u043D\u0430 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443 \u043D\u0435
    \u043A\u0430\u043A \u043D\u0430 \u0438\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044E
    \u0434\u043B\u044F \u043C\u0430\u0448\u0438\u043D\u044B, \u0430 \u043A\u0430\u043A
    \u043D\u0430 **\u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435,
    \u043F\u043E\u043D\u044F\u0442\u043D\u043E\u0435 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0443**.
    \u042D\u0442\u0430 \u0438\u0434\u0435\u044F \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430
    \u043F\u043E\u0434\u0445\u043E\u0434 \u043A \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E
    \u0438 \u043E\u0444\u043E\u0440\u043C\u043B\u0435\u043D\u0438\u044E \u043A\u043E\u0434\u0430.
    *   **\u0412\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432:** \u041A\u043D\u0443\u0442
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0430\u0432\u0442\u043E\u0440\u043E\u043C
    \u0438 \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u043E\u043C \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u0442\u0430\u043B\u0438 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u043C\u0438
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430\u043C\u0438.
    \u0421\u0440\u0435\u0434\u0438 \u043D\u0438\u0445:     *   **\u0410\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    \u041A\u043D\u0443\u0442\u0430-\u041C\u043E\u0440\u0440\u0438\u0441\u0430-\u041F\u0440\u0430\u0442\u0442\u0430
    (\u041A\u041C\u041F):** \u0434\u043B\u044F \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u043F\u043E\u0438\u0441\u043A\u0430 \u043F\u043E\u0434\u0441\u0442\u0440\u043E\u043A\u0438
    \u0432 \u0441\u0442\u0440\u043E\u043A\u0435.     *   **\u0410\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    \u041A\u043D\u0443\u0442\u0430-\u0411\u0435\u043D\u0434\u0438\u043A\u0441\u0430:**
    \u0434\u043B\u044F \u0432\u044B\u0432\u043E\u0434\u0430 \u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0439
    \u0438\u0437 \u0430\u043A\u0441\u0438\u043E\u043C.     *   **\u041C\u0435\u0442\u043E\u0434
    \u0443\u043F\u043E\u0440\u044F\u0434\u043E\u0447\u0435\u043D\u043D\u044B\u0445
    \u0445\u0435\u0448-\u0442\u0430\u0431\u043B\u0438\u0446:** \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430 (\u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u041E. \u0410\u043C\u0431\u043B\u043E\u043C) \u043F\u043E \u0445\u0435\u0448\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E,
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u0430\u044F
    \u0432 1974 \u0433\u043E\u0434\u0443, \u0441\u0442\u0430\u043B\u0430 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439. 
    ### \U0001F3C6 \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435: \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043D\u0430\u0433\u0440\u0430\u0434 \u0438 \u043F\u0440\u0435\u043C\u0438\u044F
    \u0435\u0433\u043E \u0438\u043C\u0435\u043D\u0438  \u0421\u043F\u0438\u0441\u043E\u043A
    \u043D\u0430\u0433\u0440\u0430\u0434 \u0414\u043E\u043D\u0430\u043B\u044C\u0434\u0430
    \u041A\u043D\u0443\u0442\u0430 \u043E\u0433\u0440\u043E\u043C\u0435\u043D. \u041F\u043E\u043C\u0438\u043C\u043E
    \u041F\u0440\u0435\u043C\u0438\u0438 \u0422\u044C\u044E\u0440\u0438\u043D\u0433\u0430,
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B **\u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0443\u044E
    \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u043C\u0435\u0434\u0430\u043B\u044C
    \u0421\u0428\u0410 (1979)**, **\u041F\u0440\u0435\u043C\u0438\u044E \u041A\u0438\u043E\u0442\u043E
    (1996)**, **\u041C\u0435\u0434\u0430\u043B\u044C \u0414\u0436\u043E\u043D\u0430
    \u0444\u043E\u043D \u041D\u0435\u0439\u043C\u0430\u043D\u0430 (1995)** \u0438
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0434\u0440\u0443\u0433\u0438\u0435.  \u0412
    \u0437\u043D\u0430\u043A \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0433\u043E
    \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u044F \u043A \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434\u0443,
    ACM \u0438 IEEE \u0443\u0447\u0440\u0435\u0434\u0438\u043B\u0438 **\u041F\u0440\u0435\u043C\u0438\u044E
    \u0414\u043E\u043D\u0430\u043B\u044C\u0434\u0430 \u042D. \u041A\u043D\u0443\u0442\u0430**
    \u2014 \u043E\u0434\u043D\u0443 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u0440\u0438\u0441\u0443\u0436\u0434\u0430\u0435\u0442\u0441\u044F \u0437\u0430
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043E\u0441\u043D\u043E\u0432\u044B \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u044B\u0445
    \u043D\u0430\u0443\u043A."
  achievementsEn: 
  personalLifeRu: "\u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F
    \u0445\u0440\u043E\u043D\u0438\u043A\u0430 \u0436\u0438\u0437\u043D\u0438 \u0414\u043E\u043D\u0430\u043B\u044C\u0434\u0430
    \u042D\u0440\u0432\u0438\u043D\u0430 \u041A\u043D\u0443\u0442\u0430 \u2014 \u043E\u0442
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0434\u043E \u043D\u0430\u0448\u0438\u0445
    \u0434\u043D\u0435\u0439, \u0441 \u0430\u043A\u0446\u0435\u043D\u0442\u043E\u043C
    \u043D\u0430 \u043B\u0438\u0447\u043D\u044B\u0435 \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u0432\u0435\u0445\u0438.  ### \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0421\u0435\u043C\u044C\u044F  \u0414\u043E\u043D\u0430\u043B\u044C\u0434
    \u042D\u0440\u0432\u0438\u043D \u041A\u043D\u0443\u0442 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    **10 \u044F\u043D\u0432\u0430\u0440\u044F 1938 \u0433\u043E\u0434\u0430** \u0432
    \u0433\u043E\u0440\u043E\u0434\u0435 \u041C\u0438\u043B\u0443\u043E\u043A\u0438,
    \u0448\u0442\u0430\u0442 \u0412\u0438\u0441\u043A\u043E\u043D\u0441\u0438\u043D.
    \u0415\u0433\u043E \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438 \u2014 \u042D\u0440\u0432\u0438\u043D
    \u0413\u0435\u043D\u0440\u0438 \u041A\u043D\u0443\u0442 \u0438 \u041B\u0443\u0438\u0437\u0430
    \u041C\u0430\u0440\u0438 \u0411\u043E\u043D\u0438\u043D\u0433. \u0421\u0435\u043C\u044C\u044F
    \u0438\u043C\u0435\u043B\u0430 \u043D\u0435\u043C\u0435\u0446\u043A\u043E-\u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0441\u043A\u0438\u0435
    \u043A\u043E\u0440\u043D\u0438. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u041A\u043D\u0443\u0442 \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u043C
    \u0432 \u0441\u0435\u043C\u044C\u0435, \u043A\u0442\u043E \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0432\u044B\u0441\u0448\u0435\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:
    \u0435\u0433\u043E \u043E\u0442\u0435\u0446, \u0445\u043E\u0442\u044C \u0438
    \u0441\u0442\u0430\u043B \u043F\u0435\u0440\u0432\u044B\u043C \u0441\u0440\u0435\u0434\u0438
    \u043F\u0440\u0435\u0434\u043A\u043E\u0432, \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u0432\u0448\u0438\u043C
    \u0432 \u043A\u043E\u043B\u043B\u0435\u0434\u0436, \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C \u0431\u0443\u0445\u0433\u0430\u043B\u0442\u0435\u0440\u0441\u043A\u043E\u0433\u043E
    \u0443\u0447\u0451\u0442\u0430 \u0438 \u0432\u043B\u0430\u0434\u0435\u043B \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0438\u043C
    \u043F\u0435\u0447\u0430\u0442\u043D\u044B\u043C \u0431\u0438\u0437\u043D\u0435\u0441\u043E\u043C.
    \u042D\u0442\u043E\u0442 \"\u043F\u0435\u0447\u0430\u0442\u043D\u044B\u0439\"
    \u0441\u043B\u0435\u0434 \u043E\u0442\u0446\u0430, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u043F\u043E\u0432\u043B\u0438\u044F\u043B \u043D\u0430 \u0431\u0443\u0434\u0443\u0449\u0438\u0439
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441 \u0414\u043E\u043D\u0430\u043B\u044C\u0434\u0430
    \u043A \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u043C
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u043C.  ### \u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u041F\u0435\u0440\u0432\u044B\u0435 \u041F\u0440\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u044F
    \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438  \u0412
    \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u041A\u043D\u0443\u0442 \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u0441\u0435\u0431\u044F \u043A\u0430\u043A \u0432\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434.
    \u0421\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u0443\u0447\u0438\u043B\u0441\u044F
    \u0432 \u0432\u043E\u0441\u044C\u043C\u043E\u043C \u043A\u043B\u0430\u0441\u0441\u0435.
    \u041E\u043D \u043F\u0440\u0438\u043D\u044F\u043B \u0443\u0447\u0430\u0441\u0442\u0438\u0435
    \u0432 \u043A\u043E\u043D\u043A\u0443\u0440\u0441\u0435, \u0433\u0434\u0435 \u043D\u0443\u0436\u043D\u043E
    \u0431\u044B\u043B\u043E \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u043A\u0430\u043A \u043C\u043E\u0436\u043D\u043E \u0431\u043E\u043B\u044C\u0448\u0435
    \u0441\u043B\u043E\u0432 \u0438\u0437 \u0431\u0443\u043A\u0432 \u0444\u0440\u0430\u0437\u044B
    \"Ziegler's Giant Bar\". \u041E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440\u044B
    \u043D\u0430\u0441\u0447\u0438\u0442\u0430\u043B\u0438 \u043E\u043A\u043E\u043B\u043E
    2500 \u0441\u043B\u043E\u0432, \u043D\u043E \u041A\u043D\u0443\u0442, \u043F\u0440\u0438\u0442\u0432\u043E\u0440\u0438\u0432\u0448\u0438\u0441\u044C
    \u0431\u043E\u043B\u044C\u043D\u044B\u043C \u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u0432\u0440\u0435\u043C\u044F \u0434\u043B\u044F \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F
    \u0441\u043B\u043E\u0432\u0430\u0440\u044F, \u043D\u0430\u0448\u0451\u043B **\u0431\u043E\u043B\u0435\u0435
    4500 \u0441\u043B\u043E\u0432** \u0438 \u0432\u044B\u0438\u0433\u0440\u0430\u043B
    \u043A\u043E\u043D\u043A\u0443\u0440\u0441.  \u041E\u043D \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    **\u041C\u0438\u043B\u0443\u043E\u043A\u0441\u043A\u0443\u044E \u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0441\u043A\u0443\u044E
    \u0432\u044B\u0441\u0448\u0443\u044E \u0448\u043A\u043E\u043B\u0443** \u0441
    \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u044B\u043C
    \u0441\u0440\u0435\u0434\u043D\u0438\u043C \u0431\u0430\u043B\u043B\u043E\u043C
    **97.5%**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0434\u043E\u043B\u0433\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u0440\u0435\u043A\u043E\u0440\u0434\u043E\u043C \u0448\u043A\u043E\u043B\u044B. 
    ### \u0423\u0447\u0451\u0431\u0430: \u041E\u0442 \u0424\u0438\u0437\u0438\u043A\u0438
    \u043A \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0438 \u041F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E 
    *   **\u041A\u0435\u0439\u0441\u043E\u0432\u0441\u043A\u0438\u0439 \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 (1956\u20131960):** \u041F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u041A\u043D\u0443\u0442 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432
    \u041A\u0435\u0439\u0441\u043E\u0432\u0441\u043A\u0438\u0439 \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 (\u043D\u044B\u043D\u0435 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u041A\u0435\u0439\u0441 \u0412\u0435\u0441\u0442\u0435\u0440\u043D \u0420\u0435\u0437\u0435\u0440\u0432)
    \u0432 \u041A\u043B\u0438\u0432\u043B\u0435\u043D\u0434\u0435, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E \u043F\u043E \u0444\u0438\u0437\u0438\u043A\u0435.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u043A\u043E\u043B\u0435\u0431\u0430\u043B\u0441\u044F
    \u043C\u0435\u0436\u0434\u0443 \u0444\u0438\u0437\u0438\u043A\u043E\u0439 \u0438
    \u043C\u0443\u0437\u044B\u043A\u043E\u0439, \u043D\u043E \u0432\u044B\u0431\u043E\u0440
    \u0431\u044B\u043B \u0441\u0434\u0435\u043B\u0430\u043D \u0432 \u043F\u043E\u043B\u044C\u0437\u0443
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u0438. \u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u0439
    \u043C\u043E\u043C\u0435\u043D\u0442 \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u043C **IBM
    650**. \u041F\u0440\u043E\u0432\u043E\u0434\u044F \u043D\u043E\u0447\u0438 \u043D\u0430\u043F\u0440\u043E\u043B\u0451\u0442
    \u0441 \u044D\u0442\u043E\u0439 \u043C\u0430\u0448\u0438\u043D\u043E\u0439, \u043E\u043D
    \u0443\u0432\u043B\u0451\u043A\u0441\u044F \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435\u043C,
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0441\u043E\u0432\u0435\u0442\u044B
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0434\u0435\u0440\u0436\u0430\u0442\u044C\u0441\u044F \u043F\u043E\u0434\u0430\u043B\u044C\u0448\u0435.    
    *   **\u0411\u0435\u0439\u0441\u0431\u043E\u043B \u0438 \u0410\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u044B:**
    \u0412 1958 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u0443\u044E \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443
    \u0434\u043B\u044F \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438
