    \u043C\u0435\u043D\u0435\u0434\u0436\u0435\u0440\u043E\u043C \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043E\u043D \u044F\u0432\u043B\u044F\u043B\u0441\u044F. \u0415\u0433\u043E \u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u043E\u0446\u0435\u043D\u0438\u0432\u0430\u043B\u0430 \u0432\u043A\u043B\u0430\u0434
    \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u0438\u0433\u0440\u043E\u043A\u0430,
    \u0447\u0442\u043E \u043F\u043E\u043C\u043E\u0433\u043B\u043E \u043A\u043E\u043C\u0430\u043D\u0434\u0435
    \u0432\u044B\u0438\u0433\u0440\u0430\u0442\u044C \u0447\u0435\u043C\u043F\u0438\u043E\u043D\u0430\u0442
    \u043B\u0438\u0433\u0438. \u042D\u0442\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u044F
