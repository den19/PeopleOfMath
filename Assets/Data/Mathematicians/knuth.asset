    \u041A\u043D\u0443\u0442 \u0441 \u0438\u0440\u043E\u043D\u0438\u0435\u0439 \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B,
    \u0447\u0442\u043E \u043E\u0441\u043D\u043E\u0432\u043D\u0443\u044E \u0438\u0434\u0435\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438 \u043E\u043D
    \u043F\u043E\u043D\u044F\u043B \u0437\u0430 \u0447\u0430\u0441, \u043F\u043E\u0441\u043B\u0435
    \u0447\u0435\u0433\u043E \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C \u0441\u043A\u0430\u0437\u0430\u043B:
    \"\u0414\u043E\u043D, \u044D\u0442\u043E \u0442\u0432\u043E\u044F \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F.
    \u0411\u0435\u0440\u0438 \u0438 \u0443\u0445\u043E\u0434\u0438.\".  ### \u041D\u0430\u0447\u0430\u043B\u043E
    \u041A\u0430\u0440\u044C\u0435\u0440\u044B \u0438 \u0420\u0430\u0431\u043E\u0442\u0430 
    *   **Caltech (1963\u20131968):** \u041F\u043E\u0441\u043B\u0435 \u0437\u0430\u0449\u0438\u0442\u044B
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438 \u041A\u043D\u0443\u0442
    \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0432 \u041A\u0430\u043B\u0438\u0444\u043E\u0440\u043D\u0438\u0439\u0441\u043A\u043E\u043C
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u0430 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430.
    \u041F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u043E, \u0441 1960
    \u043F\u043E 1968 \u0433\u043E\u0434, \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0430\u043D\u0442\u043E\u043C
    \u0432 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u0438 **Burroughs Corporation**,
    \u0433\u0434\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u043E\u0439
    \u043A\u043E\u043C\u043F\u0438\u043B\u044F\u0442\u043E\u0440\u043E\u0432. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0442\u0430\u043C \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u043A\u043E\u043C\u043F\u0438\u043B\u044F\u0442\u043E\u0440
    \u0434\u043B\u044F \u044F\u0437\u044B\u043A\u0430 ALGOL, \u0438 \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043E\u043A\u0430\u0437\u0430\u043B\u0430
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0438\u043D\u0434\u0443\u0441\u0442\u0440\u0438\u044E.  *   **\u041F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435
    \u0432 \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434 (1968):** \u0412 1968
    \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0435\u0440\u0435\u0448\u0451\u043B
    \u0432 **\u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442**. \u0415\u0433\u043E
    \u0440\u0435\u043A\u0440\u0443\u0442\u0438\u0440\u043E\u0432\u0430\u043B \u0414\u0436\u043E\u0440\u0434\u0436
    \u0424\u043E\u0440\u0441\u0430\u0439\u0442, \u0438 \u041A\u043D\u0443\u0442,
    \u0448\u0443\u0442\u044F, \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u043B\u0441\u044F,
    \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u0432 \u043E\u0442\u0441\u0440\u043E\u0447\u043A\u0443
    \u043D\u0430 \u0433\u043E\u0434, \u0447\u0442\u043E\u0431\u044B \"\u0434\u043E\u043F\u0438\u0441\u0430\u0442\u044C
    \u043A\u043D\u0438\u0433\u0443\". \u042D\u0442\u0443 \u043A\u043D\u0438\u0433\u0443,
    \u043A\u0430\u043A \u043E\u043D \u0441\u0430\u043C \u043F\u0440\u0438\u0437\u043D\u0430\u0451\u0442\u0441\u044F,
    \u043E\u043D \u043F\u0438\u0448\u0435\u0442 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440.
    \u0412 \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434\u0435 \u043E\u043D \u0431\u044B\u0441\u0442\u0440\u043E
    \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u0432, \u0432\u043D\u0451\u0441
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435 \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0430
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u044B\u0445 \u043D\u0430\u0443\u043A
    \u0438 \u0432 1977 \u0433\u043E\u0434\u0443 \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0438\u043C\u0435\u043D\u0438
    \u0424\u043B\u0435\u0442\u0447\u0435\u0440\u0430 \u0414\u0436\u043E\u043D\u0441\u0430. 
    ### \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0423\u0447\u0451\u043D\u044B\u043C\u0438
    \u0438 \u0412\u043B\u0438\u044F\u043D\u0438\u0435  \u041A\u043D\u0443\u0442 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B
    \u0442\u0435\u0441\u043D\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0441\u0432\u044F\u0437\u0438 \u0441\u043E \u043C\u043D\u043E\u0433\u0438\u043C\u0438
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0438\u0441\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438. 
    *   **\u0420\u043E\u0431\u0435\u0440\u0442 \u0424\u043B\u043E\u0439\u0434:**
    \u0415\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0430 \u0438 \u0431\u043B\u0438\u0437\u043A\u0438\u0439
    \u0434\u0440\u0443\u0433, \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u043E\u043D\u0438
    \u0432\u043C\u0435\u0441\u0442\u0435 \u043F\u0440\u0438\u0448\u043B\u0438 \u0432
    \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434. \u041A\u043D\u0443\u0442 \u043E\u0447\u0435\u043D\u044C
    \u0442\u0435\u043F\u043B\u043E \u043E\u0442\u0437\u044B\u0432\u0430\u043B\u0441\u044F
    \u043E\u0431 \u0438\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 \u0438 \"\u043F\u0430\u043A\u0435\u0442\u043D\u043E\u0439
    \u0441\u0434\u0435\u043B\u043A\u0435\" \u043F\u043E \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0443
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442. *  
    **\u0410\u043D\u0434\u0440\u0435\u0439 \u0415\u0440\u0448\u043E\u0432:** \u0411\u043E\u043B\u044C\u0448\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u041A\u043D\u0443\u0442\u0430,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432 \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438,
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0433\u043E \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0441\u0442\u0430
    **\u0410\u043D\u0434\u0440\u0435\u044F \u041F\u0435\u0442\u0440\u043E\u0432\u0438\u0447\u0430
    \u0415\u0440\u0448\u043E\u0432\u0430**. \u041A\u043D\u0443\u0442 \u0438\u0437\u0443\u0447\u0430\u043B
    \u0435\u0433\u043E \u043A\u043D\u0438\u0433\u0443 \xAB\u041F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u0434\u043B\u044F \u0411\u042D\u0421\u041C\xBB \u0438 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043E\u043D\u0438 \u0441\u0442\u0430\u043B\u0438 \u0434\u0440\u0443\u0437\u044C\u044F\u043C\u0438.
    \u0421\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C \u043E\u0431\u0448\u0438\u0440\u043D\u0430\u044F
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430 \u043C\u0435\u0436\u0434\u0443
    \u043D\u0438\u043C\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443\u0435\u0442
    \u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u043C \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u043C
    \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0438, \u043E\u0431\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0438
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0430 \u043A\u043D\u0438\u0433 \u041A\u043D\u0443\u0442\u0430
    \u043D\u0430 \u0440\u0443\u0441\u0441\u043A\u0438\u0439 \u044F\u0437\u044B\u043A
    \u0438 \u0434\u0430\u0436\u0435 \u043F\u043B\u0430\u043D\u0430\u0445 \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u044B\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0441\u0438\u043C\u043F\u043E\u0437\u0438\u0443\u043C\u043E\u0432 \u0432 \u0421\u0421\u0421\u0420.
    *   **\u042D\u0434\u0441\u0433\u0435\u0440 \u0414\u0435\u0439\u043A\u0441\u0442\u0440\u0430:**
    \u0421 \u043D\u0438\u043C \u0443 \u041A\u043D\u0443\u0442\u0430 \u0431\u044B\u043B\u0438
    \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F.
    \u0412 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u0414\u0435\u0439\u043A\u0441\u0442\u0440\u0430
    \u043D\u0435\u0433\u0430\u0442\u0438\u0432\u043D\u043E \u043E\u0442\u0437\u044B\u0432\u0430\u043B\u0441\u044F
    \u043E \u0435\u0433\u043E \u0438\u0434\u0435\u0435 \u0441 `DEFINE` \u0432 \u044F\u0437\u044B\u043A\u0435
    ALGOL, \u043D\u043E \u0438\u0445 \u043F\u0443\u0442\u0438 \u043A\u0430\u043A
    \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0438
    \u0447\u0430\u0441\u0442\u043E \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u043B\u0438\u0441\u044C.
    *   **\u0414\u0440\u0443\u0433\u0438\u0435:** \u041A\u043D\u0443\u0442 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u043B
    28 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0438\u043C\u0438 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F\u043C\u0438
    \u0432 \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434\u0435. \u0421\u0440\u0435\u0434\u0438
    \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432 \u2014 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435
    \u0443\u0447\u0451\u043D\u044B\u0435, \u0442\u0430\u043A\u0438\u0435 \u043A\u0430\u043A
    **\u0420\u043E\u0431\u0435\u0440\u0442 \u0421\u0435\u0434\u0436\u0432\u0438\u043A,
    \u041B\u0435\u043E\u043D\u0438\u0434\u0430\u0441 \u0413\u0443\u0439\u0431\u0430\u0441
    \u0438 \u0410\u043D\u0434\u0440\u0435\u0439 \u0411\u0440\u043E\u0434\u0435\u0440**. 
    ### \u0423\u0445\u043E\u0434 \u0438\u0437 \u041F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u044F
    \u0438 \u0421\u043C\u0435\u0440\u0442\u044C  *   **\u041E\u0442\u0441\u0442\u0430\u0432\u043A\u0430
    (1993):** \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043B\u044E\u0431\u043E\u0432\u044C
    \u043A \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u044E,
    \u0432 1993 \u0433\u043E\u0434\u0443 \u041A\u043D\u0443\u0442 \u0443\u0448\u0451\u043B
    \u0432 \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0443 \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0437\u0432\u0430\u043D\u0438\u0435 **\u043F\u043E\u0447\u0451\u0442\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 (Professor Emeritus)**.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u0446\u0435\u043B\u044C\u044E
    \u0431\u044B\u043B\u043E \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0438\u0442\u044C\u0441\u044F
    \u043D\u0430 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0438 \u0441\u0432\u043E\u0435\u0433\u043E
    magnum opus \u2014 \"\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\",
    \u0434\u043E\u0445\u043E\u0434 \u043E\u0442 \u043F\u0440\u043E\u0434\u0430\u0436
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0443\u0436\u0435 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u043B
    \u0435\u0433\u043E \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u043E. *  
    **\u0417\u0434\u043E\u0440\u043E\u0432\u044C\u0435:** \u0412 2006 \u0433\u043E\u0434\u0443
    \u0443 \u043D\u0435\u0433\u043E \u0431\u044B\u043B \u0434\u0438\u0430\u0433\u043D\u043E\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043D
    \u0440\u0430\u043A \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0436\u0435\u043B\u0435\u0437\u044B, \u043E\u043D \u043F\u0435\u0440\u0435\u043D\u0451\u0441
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u044E \u0438 \u043A\u0443\u0440\u0441
    \u043B\u0443\u0447\u0435\u0432\u043E\u0439 \u0442\u0435\u0440\u0430\u043F\u0438\u0438,
    \u043F\u043E\u0441\u043B\u0435 \u0447\u0435\u0433\u043E \u043F\u0440\u043E\u0433\u043D\u043E\u0437
    \u0431\u044B\u043B \u0431\u043B\u0430\u0433\u043E\u043F\u0440\u0438\u044F\u0442\u043D\u044B\u043C. 
    **\u0412\u0430\u0436\u043D\u043E:** **\u0414\u043E\u043D\u0430\u043B\u044C\u0434
    \u042D\u0440\u0432\u0438\u043D \u041A\u043D\u0443\u0442 \u0436\u0438\u0432 \u043F\u043E
    \u0441\u0435\u0439 \u0434\u0435\u043D\u044C** (\u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 1938 \u0433\u043E\u0434\u0443). \u041D\u0430 \u043C\u043E\u043C\u0435\u043D\u0442
    \u043C\u043E\u0435\u0433\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0433\u043E
    \u043E\u0431\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u044F \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
    \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u043D\u0430\u0434 \"\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E\u043C
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\"
    \u0438 \u0432\u0435\u0434\u0451\u0442 \u0430\u043A\u0442\u0438\u0432\u043D\u0443\u044E
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C, \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u044F
    \u0441 \u043B\u0435\u043A\u0446\u0438\u044F\u043C\u0438 \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u044F\u0441\u044C
    \u043C\u0443\u0437\u044B\u043A\u043E\u0439.  ### \u041B\u0438\u0447\u043D\u0430\u044F
    \u0416\u0438\u0437\u043D\u044C  *   **\u0421\u0443\u043F\u0440\u0443\u0433\u0430:**
    **\u041D\u044D\u043D\u0441\u0438 \u0414\u0436\u0438\u043B\u043B \u041A\u0430\u0440\u0442\u0435\u0440**.
    \u041E\u043D\u0438 \u043F\u043E\u0436\u0435\u043D\u0438\u043B\u0438\u0441\u044C
    **24 \u0438\u044E\u043D\u044F 1961 \u0433\u043E\u0434\u0430**, \u043A\u043E\u0433\u0434\u0430
    \u041A\u043D\u0443\u0442 \u0435\u0449\u0451 \u0443\u0447\u0438\u043B\u0441\u044F
    \u0432 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u0443\u0440\u0435 \u041A\u0430\u043B\u0438\u0444\u043E\u0440\u043D\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430. *   **\u0414\u0435\u0442\u0438:**
    \u0423 \u043D\u0438\u0445 \u0434\u0432\u043E\u0435 \u0434\u0435\u0442\u0435\u0439:
    \u0441\u044B\u043D **\u0414\u0436\u043E\u043D \u041C\u0430\u0440\u0442\u0438\u043D
    \u041A\u043D\u0443\u0442** \u0438 \u0434\u043E\u0447\u044C **\u0414\u0436\u0435\u043D\u043D\u0438\u0444\u0435\u0440
    \u0421\u044C\u0435\u0440\u0440\u0430 \u041A\u043D\u0443\u0442**. *   **\u0414\u043E\u043C:**
    \u041A\u043D\u0443\u0442 \u0438 \u0435\u0433\u043E \u0436\u0435\u043D\u0430 \u0414\u0436\u0438\u043B\u043B
    \u0441\u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u043A\u0443 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0434\u043E\u043C\u0430 \u0432 \u043A\u0430\u043C\u043F\u0443\u0441\u0435 \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434\u0430,
    \u043F\u0440\u0435\u0434\u0443\u0441\u043C\u043E\u0442\u0440\u0435\u0432 \u043C\u0435\u0441\u0442\u043E
    \u0434\u043B\u044F \u0445\u0443\u0434\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u043F\u0440\u043E\u0435\u043A\u0442\u043E\u0432 \u0414\u0436\u0438\u043B\u043B
    \u0438 \u043A\u043E\u043C\u043D\u0430\u0442\u0443 \u0434\u043B\u044F \u043C\u0443\u0437\u044B\u043A\u0438
    \u0414\u043E\u043D\u0430\u043B\u044C\u0434\u0430, \u0433\u0434\u0435 \u0432 \u0438\u0442\u043E\u0433\u0435
    \u0431\u044B\u043B \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u044B\u0439
    \u043E\u0440\u0433\u0430\u043D.  ### \u0423\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F
    \u0438 \u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0438  *  
    **\u041C\u0443\u0437\u044B\u043A\u0430:** \u041A\u043D\u0443\u0442 \u2014 \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0447\u0435\u043D\u044B\u0439, \u043D\u043E
    \u0438 \u0438\u0441\u043A\u0443\u0441\u043D\u044B\u0439 \u043E\u0440\u0433\u0430\u043D\u0438\u0441\u0442
    \u0438 \u043A\u043E\u043C\u043F\u043E\u0437\u0438\u0442\u043E\u0440. \u041E\u043D
    \u0438 \u0435\u0433\u043E \u043E\u0442\u0435\u0446 \u0441\u043B\u0443\u0436\u0438\u043B\u0438
    \u043E\u0440\u0433\u0430\u043D\u0438\u0441\u0442\u0430\u043C\u0438 \u0432 \u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0441\u043A\u0438\u0445
    \u0446\u0435\u0440\u043A\u0432\u044F\u0445. \u0412 \u0435\u0433\u043E \u0434\u043E\u043C\u0435
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D \u043E\u0440\u0433\u0430\u043D.
    \u0412 2016 \u0433\u043E\u0434\u0443 \u043E\u043D \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B
    \u043A\u0440\u0443\u043F\u043D\u043E\u0435 \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0435
    \u0434\u043B\u044F \u043E\u0440\u0433\u0430\u043D\u0430 \u043F\u043E\u0434 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435\u043C
    **\xABFantasia Apocalyptica\xBB**, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u043E\u0435
    \u043D\u0430 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u043C \u0442\u0435\u043A\u0441\u0442\u0435
    \u041E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u0438\u044F \u0418\u043E\u0430\u043D\u043D\u0430
    \u0411\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0430. \u041F\u0440\u0435\u043C\u044C\u0435\u0440\u0430
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0430\u0441\u044C \u0432 \u0428\u0432\u0435\u0446\u0438\u0438
    10 \u044F\u043D\u0432\u0430\u0440\u044F 2018 \u0433\u043E\u0434\u0430, \u0432
    \u0434\u0435\u043D\u044C \u0435\u0433\u043E 80-\u043B\u0435\u0442\u0438\u044F.
    *   **\u0427\u0435\u043A\u0438 \u0437\u0430 \u043E\u0448\u0438\u0431\u043A\u0438:**
    \u0418\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0435\u0439
    \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u0435\u0439 \u0432\u044B\u043F\u043B\u0430\u0447\u0438\u0432\u0430\u0442\u044C
    \u0432\u043E\u0437\u043D\u0430\u0433\u0440\u0430\u0436\u0434\u0435\u043D\u0438\u0435
    \u0437\u0430 \u043D\u0430\u0439\u0434\u0435\u043D\u043D\u044B\u0435 \u0432 \u0435\u0433\u043E
    \u043A\u043D\u0438\u0433\u0430\u0445 \u043E\u0448\u0438\u0431\u043A\u0438 \u2014
    **$2.56** (\u043E\u0434\u0438\u043D \"\u0448\u0435\u0441\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u0435\u0440\u0438\u0447\u043D\u044B\u0439
    \u0434\u043E\u043B\u043B\u0430\u0440\"). \u042D\u0442\u0438 \u0447\u0435\u043A\u0438
    \u0441\u0442\u0430\u043B\u0438 \u043A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u043E\u043D\u043D\u044B\u043C\u0438
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430\u043C\u0438. \u0421 2008 \u0433\u043E\u0434\u0430,
    \u0438\u0437-\u0437\u0430 \u043F\u0440\u043E\u0431\u043B\u0435\u043C \u0441 \u043C\u043E\u0448\u0435\u043D\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E\u043C,
    \u043E\u043D \u0432\u044B\u0434\u0430\u0451\u0442 \u0441\u0435\u0440\u0442\u0438\u0444\u0438\u043A\u0430\u0442\u044B
    \u0438\u0437 \u0432\u044B\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \"\u0411\u0430\u043D\u043A\u0430 \u0421\u0430\u043D-\u0421\u0435\u0440\u0440\u0438\u0444\".
    *   **\u0421\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u044C \u0438 \u0438\u0440\u043E\u043D\u0438\u044F:**
    \u041A\u043D\u0443\u0442 \u043D\u0435 \u043B\u0438\u0448\u0451\u043D \u0441\u0430\u043C\u043E\u0438\u0440\u043E\u043D\u0438\u0438.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435 \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u0435:
    *\"Beware of bugs in the above code; I have only proved it correct, not tried
    it.\"* (\u041E\u0441\u0442\u0435\u0440\u0435\u0433\u0430\u0439\u0442\u0435\u0441\u044C
    \u043E\u0448\u0438\u0431\u043E\u043A \u0432 \u043F\u0440\u0438\u0432\u0435\u0434\u0451\u043D\u043D\u043E\u043C
    \u043A\u043E\u0434\u0435; \u044F \u043B\u0438\u0448\u044C \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0435\u0433\u043E \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E\u0441\u0442\u044C,
    \u043D\u043E \u043D\u0435 \u043F\u0440\u043E\u0431\u043E\u0432\u0430\u043B \u0437\u0430\u043F\u0443\u0441\u043A\u0430\u0442\u044C)."
  personalLifeEn: 
  shortBioRu: "**\u0414\u043E\u043D\u0430\u043B\u044C\u0434 \u042D\u0440\u0432\u0438\u043D
    \u041A\u043D\u0443\u0442 (Donald Ervin Knuth)** \u2014 \u044D\u0442\u043E \u0443\u0447\u0435\u043D\u044B\u0439,
    \u0447\u044C\u0435 \u0438\u043C\u044F \u0441\u0442\u0430\u043B\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u043E\u0439
    \u0432 \u043C\u0438\u0440\u0435 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u044B\u0445
    \u043D\u0430\u0443\u043A. \u041E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    10 \u044F\u043D\u0432\u0430\u0440\u044F 1938 \u0433\u043E\u0434\u0430 \u0432
    \u041C\u0438\u043B\u0443\u043E\u043A\u0438, \u0448\u0442\u0430\u0442 \u0412\u0438\u0441\u043A\u043E\u043D\u0441\u0438\u043D,
    \u0438 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0439
    \u043F\u0443\u0442\u044C \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043E \u0442\u043E\u043C, \u043A\u0430\u043A \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0443\u043C \u0438 \u0441\u0442\u0440\u0430\u0441\u0442\u044C \u043A \u043F\u043E\u0440\u044F\u0434\u043A\u0443
    \u043C\u043E\u0433\u0443\u0442 \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C
    \u0446\u0435\u043B\u0443\u044E \u043E\u0442\u0440\u0430\u0441\u043B\u044C.  ###
    \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u043F\u0435\u0440\u0432\u044B\u0435
    \u0448\u0430\u0433\u0438 \u043A \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438 
    \u0421 \u0440\u0430\u043D\u043D\u0438\u0445 \u043B\u0435\u0442 \u0432 \u0414\u043E\u043D\u0430\u043B\u044C\u0434\u0435
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C \u0447\u0435\u0440\u0442\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u0437\u0436\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442
    \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0443: \u043B\u044E\u0431\u043E\u0432\u044C
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u043C\u0443\u0437\u044B\u043A\u0435
    \u0438 \u043F\u0435\u0447\u0430\u0442\u043D\u043E\u043C\u0443 \u0441\u043B\u043E\u0432\u0443.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C
    \u0431\u0443\u0445\u0433\u0430\u043B\u0442\u0435\u0440\u0441\u043A\u043E\u0433\u043E
    \u0443\u0447\u0435\u0442\u0430, \u0432 \u043F\u043E\u0434\u0432\u0430\u043B\u0435
    \u0434\u043E\u043C\u0430 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u043F\u0435\u0447\u0430\u0442\u043D\u044B\u043C \u0434\u0435\u043B\u043E\u043C,
    \u0447\u0442\u043E, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B\u043E
    \u0432 \u0441\u044B\u043D\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441 \u043A
    \u0442\u0438\u043F\u043E\u0433\u0440\u0430\u0444\u0438\u043A\u0435.  \u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u044F,
    \u0441\u043B\u0443\u0447\u0438\u0432\u0448\u0430\u044F\u0441\u044F \u0441 \u043D\u0438\u043C
    \u0432 13 \u043B\u0435\u0442. \u041A\u043E\u043C\u043F\u0430\u043D\u0438\u044F-\u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C
    \u0448\u043E\u043A\u043E\u043B\u0430\u0434\u0430 Ziegler's \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043B\u0430
    \u043A\u043E\u043D\u043A\u0443\u0440\u0441: \u043D\u0443\u0436\u043D\u043E \u0431\u044B\u043B\u043E
    \u043D\u0430\u0439\u0442\u0438 \u043A\u0430\u043A \u043C\u043E\u0436\u043D\u043E
    \u0431\u043E\u043B\u044C\u0448\u0435 \u0441\u043B\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u043E\u0436\u043D\u043E \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0438\u0437 \u0431\u0443\u043A\u0432 \u0432 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0438
    \u043F\u043B\u0438\u0442\u043A\u0438 \"Ziegler's Giant Bar\". \u041E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440\u044B
    \u043D\u0430\u0441\u0447\u0438\u0442\u0430\u043B\u0438 \u043E\u043A\u043E\u043B\u043E
    2500 \u0441\u043B\u043E\u0432. \u041A\u043D\u0443\u0442 \u0436\u0435, \u043C\u0435\u0442\u043E\u0434\u0438\u0447\u043D\u043E
    \u043F\u0435\u0440\u0435\u043B\u0438\u0441\u0442\u0430\u0432 2000 \u0441\u0442\u0440\u0430\u043D\u0438\u0446
    \u0441\u043B\u043E\u0432\u0430\u0440\u044F Funk & Wagnalls, \u0441\u043C\u043E\u0433
    \u043D\u0430\u0439\u0442\u0438 \u0431\u043E\u043B\u0435\u0435 **4700 \u0441\u043B\u043E\u0432**.
    \u0427\u0442\u043E\u0431\u044B \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0438\u0442\u044C\u0441\u044F,
    \u043E\u043D \u0434\u0430\u0436\u0435 \u043F\u0440\u0438\u0442\u0432\u043E\u0440\u0438\u043B\u0441\u044F
    \u0431\u043E\u043B\u044C\u043D\u044B\u043C \u0438 \u043F\u0440\u043E\u043F\u0443\u0441\u0442\u0438\u043B
    \u0448\u043A\u043E\u043B\u0443. \u042D\u0442\u043E\u0442 \u0441\u043B\u0443\u0447\u0430\u0439
    \u043F\u0440\u043E\u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u043D\u044B\u0439 \u043F\u043E\u0434\u0445\u043E\u0434
    \u043A \u0440\u0435\u0448\u0435\u043D\u0438\u044E \u0437\u0430\u0434\u0430\u0447
    \u0438 \u043D\u0435\u0438\u0441\u0441\u044F\u043A\u0430\u0435\u043C\u0443\u044E
    \u044D\u043D\u0435\u0440\u0433\u0438\u044E. \u041A\u0441\u0442\u0430\u0442\u0438,
    \u043E\u043D \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u0441\u0440\u0435\u0434\u043D\u044E\u044E
    \u0448\u043A\u043E\u043B\u0443 \u0441 \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u044B\u043C
    \u0441\u0440\u0435\u0434\u043D\u0438\u043C \u0431\u0430\u043B\u043B\u043E\u043C
    97.5%, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u0440\u0435\u043A\u043E\u0440\u0434\u043E\u043C \u0448\u043A\u043E\u043B\u044B
    \u0434\u043E\u043B\u0433\u0438\u0435 \u0433\u043E\u0434\u044B.  ### \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B: \u043E\u0442 \u0444\u0438\u0437\u0438\u043A\u0438 \u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0438 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E 
    \u0412 1956 \u0433\u043E\u0434\u0443 \u041A\u043D\u0443\u0442 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u041A\u0435\u0439\u0441\u043E\u0432\u0441\u043A\u0438\u0439 \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 (\u043D\u044B\u043D\u0435 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u041A\u0435\u0439\u0441 \u0412\u0435\u0441\u0442\u0435\u0440\u043D \u0420\u0435\u0437\u0435\u0440\u0432)
    \u0432 \u041A\u043B\u0438\u0432\u043B\u0435\u043D\u0434\u0435, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E \u043F\u043E \u0444\u0438\u0437\u0438\u043A\u0435.
    \u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043E\u043D \u043A\u043E\u043B\u0435\u0431\u0430\u043B\u0441\u044F
    \u043C\u0435\u0436\u0434\u0443 \u0444\u0438\u0437\u0438\u043A\u043E\u0439 \u0438
    \u043C\u0443\u0437\u044B\u043A\u043E\u0439, \u043D\u043E \u0432\u044B\u0431\u0440\u0430\u043B
    \u0444\u0438\u0437\u0438\u043A\u0443, \u0442\u0430\u043A \u043A\u0430\u043A \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E.  \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u043A\u0440\u0443\u0442\u043E
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430\u0441\u044C, \u043A\u043E\u0433\u0434\u0430
    \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0443\u0432\u0438\u0434\u0435\u043B
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440 **IBM 650**. \u0412 1956
    \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B \u044D\u0442\u0443 \u043C\u0430\u0448\u0438\u043D\u0443
    \u0438 \u0431\u044B\u043B \u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D. \u0412\u043C\u0435\u0441\u0442\u043E
    \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u044C
    \u0441\u043E\u0432\u0435\u0442\u0430\u043C \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u0439,
    \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0430\u0432\u0448\u0438\u0445,
    \u0447\u0442\u043E \"\u044D\u0442\u043E \u043D\u0438 \u043A \u0447\u0435\u043C\u0443
    \u0445\u043E\u0440\u043E\u0448\u0435\u043C\u0443 \u043D\u0435 \u043F\u0440\u0438\u0432\u0435\u0434\u0435\u0442\",
    \u041A\u043D\u0443\u0442 \u043D\u0430\u0447\u0430\u043B \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u0442\u044C
    \u043D\u043E\u0447\u0438 \u043D\u0430\u043F\u0440\u043E\u043B\u0435\u0442, \u0438\u0437\u0443\u0447\u0430\u044F
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440 \u0438 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u044F
    \u0435\u0433\u043E \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u043D\u043E\u0435
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u0438\u0435. \u041E\u043D
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u043B\u0441\u044F \u0432 \u0442\u0435\u043C\u0443,
    \u0447\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u043B \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443
    \u0434\u043B\u044F \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438
    \u0438\u0433\u0440\u043E\u043A\u043E\u0432 \u0431\u0430\u0441\u043A\u0435\u0442\u0431\u043E\u043B\u044C\u043D\u043E\u0439
    \u043A\u043E\u043C\u0430\u043D\u0434\u044B \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430,
    \u043C\u0435\u043D\u0435\u0434\u0436\u0435\u0440\u043E\u043C \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0431\u044B\u043B. \u042D\u0442\u0430 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430
    \u043F\u043E\u043C\u043E\u0433\u043B\u0430 \u043A\u043E\u043C\u0430\u043D\u0434\u0435
    \u0432\u044B\u0438\u0433\u0440\u0430\u0442\u044C \u0447\u0435\u043C\u043F\u0438\u043E\u043D\u0430\u0442
    \u043B\u0438\u0433\u0438 \u0438 \u0434\u0430\u0436\u0435 \u043F\u043E\u043F\u0430\u043B\u0430
    \u0432 \u0440\u0435\u043F\u043E\u0440\u0442\u0430\u0436\u0438 Newsweek \u0438
    CBS.  \u0412 1960 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u043D\u043E, \u043A\u0430\u043A \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0435\u0433\u043E \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439 \u0432 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438,
    **\u043F\u043E \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0440\u0435\u0448\u0435\u043D\u0438\u044E \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u0432\u0435\u0442\u0430 \u0435\u043C\u0443 \u0431\u044B\u043B\u0430
    \u043F\u0440\u0438\u0441\u0432\u043E\u0435\u043D\u0430 \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430**.  ### \u041F\u0443\u0442\u044C
    \u043A \"\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0443 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\" 
    \u0412 1963 \u0433\u043E\u0434\u0443 \u041A\u043D\u0443\u0442 \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0432
    \u041A\u0430\u043B\u0438\u0444\u043E\u0440\u043D\u0438\u0439\u0441\u043A\u043E\u043C
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 (Caltech) \u0438 \u0441\u0442\u0430\u043B
    \u0442\u0430\u043C \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C. 
    \u0421\u0430\u043C\u043E\u0435 \u0437\u043D\u0430\u043C\u0435\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0441\u043E\u0431\u044B\u0442\u0438\u0435 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E
    \u0432 \u044F\u043D\u0432\u0430\u0440\u0435 1962 \u0433\u043E\u0434\u0430, \u043A\u043E\u0433\u0434\u0430
    \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E Addison-Wesley
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B\u043E \u0435\u043C\u0443
    \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C \u043A\u043D\u0438\u0433\u0443
    \u043E \u043A\u043E\u043C\u043F\u0438\u043B\u044F\u0442\u043E\u0440\u0430\u0445.
    \u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043E\u043D \u043D\u0430\u0431\u0440\u043E\u0441\u0430\u043B
    12 \u0433\u043B\u0430\u0432, \u043D\u043E \u0432 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E
    \u0442\u0435\u043C\u0430 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0431\u043E\u043B\u0435\u0435
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434\u0430. \u0412\u043C\u0435\u0441\u0442\u043E
    \u043A\u043D\u0438\u0433\u0438 \u043F\u043E \u043A\u043E\u043C\u043F\u0438\u043B\u044F\u0442\u043E\u0440\u0430\u043C
    \u043E\u043D \u0440\u0435\u0448\u0438\u043B \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u0432\u0441\u0435\u043E\u0431\u044A\u0435\u043C\u043B\u044E\u0449\u0438\u0439
    \u0442\u0440\u0443\u0434 \u043F\u043E \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0430\u043C
    \u2014 **\"\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\"
    (The Art of Computer Programming)**. \u041F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u044B\u0439
    \u043F\u043B\u0430\u043D \u0438\u0437 \u043E\u0434\u043D\u043E\u0439 \u043A\u043D\u0438\u0433\u0438
    \u0431\u044B\u0441\u0442\u0440\u043E \u0432\u044B\u0440\u043E\u0441 \u0432 \u0448\u0435\u0441\u0442\u044C,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0438 \u0432 \u0441\u0435\u043C\u044C
    \u0442\u043E\u043C\u043E\u0432. \u0420\u0430\u0431\u043E\u0442\u0430 \u043D\u0430\u0434
    \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C
    \u0442\u0440\u0443\u0434\u043E\u043C \u0441\u0442\u0430\u043B\u0430 \u0434\u0435\u043B\u043E\u043C
    \u0432\u0441\u0435\u0439 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438. 
    ### \u0420\u0430\u0441\u0446\u0432\u0435\u0442 \u043A\u0430\u0440\u044C\u0435\u0440\u044B
    \u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u043D\u0430\u0433\u0440\u0430\u0434\u044B 
    \u0412 1968 \u0433\u043E\u0434\u0443 \u0432\u044B\u0448\u0435\u043B \u043F\u0435\u0440\u0432\u044B\u0439
    \u0442\u043E\u043C \"\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\",
    \u0438 \u0432 \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u041A\u043D\u0443\u0442
    \u043F\u0435\u0440\u0435\u0448\u0435\u043B \u0432 \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u0433\u0434\u0435
    \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0434\u043E 1993
    \u0433\u043E\u0434\u0430, \u043F\u043E\u0441\u043B\u0435 \u0447\u0435\u0433\u043E
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0437\u0432\u0430\u043D\u0438\u0435
    **\u043F\u043E\u0447\u0435\u0442\u043D\u043E\u0433\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    (Professor Emeritus)**.  \u0412 1974 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430
    \u0432\u044B\u0448\u043B\u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u0442\u0440\u0438
    \u0442\u043E\u043C\u0430, \u041A\u043D\u0443\u0442 \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    **\u041F\u0440\u0435\u043C\u0438\u0438 \u0422\u044C\u044E\u0440\u0438\u043D\u0433\u0430**
    \u2014 \u0441\u0430\u043C\u043E\u0439 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0439
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u044B\u0445 \u043D\u0430\u0443\u043A
    \u2014 \"\u0437\u0430 \u0435\u0433\u043E \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0430\u043D\u0430\u043B\u0438\u0437 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432
    \u0438 \u0434\u0438\u0437\u0430\u0439\u043D \u044F\u0437\u044B\u043A\u043E\u0432
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F,
    \u0438 \u0432 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u0437\u0430 \u0432\u043A\u043B\u0430\u0434 \u0432 \"\u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\"
    \u0447\u0435\u0440\u0435\u0437 \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    \u043A\u043D\u0438\u0433\u0438\". \u0421\u0440\u0435\u0434\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0434\u0440\u0443\u0433\u0438\u0445 \u043D\u0430\u0433\u0440\u0430\u0434 \u2014
    **\u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430\u044F \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u043C\u0435\u0434\u0430\u043B\u044C \u0421\u0428\u0410** (1979), **\u041F\u0440\u0435\u043C\u0438\u044F
    \u041A\u0438\u043E\u0442\u043E** (1996) \u0438 **\u041C\u0435\u0434\u0430\u043B\u044C
    \u0414\u0436\u043E\u043D\u0430 \u0444\u043E\u043D \u041D\u0435\u0439\u043C\u0430\u043D\u0430**
    (1995).  ### \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 TeX, METAFONT \u0438
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438 \"\u0433\u0440\u0430\u043C\u043E\u0442\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\" 
    \u0412 \u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0435 1970-\u0445 \u0433\u043E\u0434\u043E\u0432
    \u041A\u043D\u0443\u0442 \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F
    \u0441 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u043E\u0439.
    \u0422\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u044F \u043F\u0435\u0447\u0430\u0442\u0438
    \u043C\u0435\u043D\u044F\u043B\u0430\u0441\u044C, \u0438 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u043E
    \u0432\u0435\u0440\u0441\u0442\u043A\u0438 \u043D\u043E\u0432\u043E\u0433\u043E
    \u0438\u0437\u0434\u0430\u043D\u0438\u044F \u0435\u0433\u043E \u043A\u043D\u0438\u0433
    \u0435\u0433\u043E \u0441\u0438\u043B\u044C\u043D\u043E \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043B\u043E.
    \u0427\u0442\u043E\u0431\u044B \u0440\u0435\u0448\u0438\u0442\u044C \u044D\u0442\u0443
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443, \u043E\u043D \u0432\u0437\u044F\u043B\u0441\u044F
    \u0437\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u043E\u0439
    \u0432\u0435\u0440\u0441\u0442\u043A\u0438.  \u0412 1977 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0443
    **TeX** \u2014 \u0441\u0438\u0441\u0442\u0435\u043C\u044B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u043B\u0430 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0442\u044C
    \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E\u0435 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u043E
    \u043D\u0430\u0431\u043E\u0440\u0430, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u043E\u0440\u043C\u0443\u043B. \u041E\u043D \u0434\u0443\u043C\u0430\u043B,
    \u0447\u0442\u043E \u0441\u043F\u0440\u0430\u0432\u0438\u0442\u0441\u044F \u0437\u0430
    8 \u043C\u0435\u0441\u044F\u0446\u0435\u0432, \u043D\u043E \u0440\u0430\u0431\u043E\u0442\u0430
    \u0437\u0430\u0442\u044F\u043D\u0443\u043B\u0430\u0441\u044C \u043D\u0430 10
    \u043B\u0435\u0442. \u041F\u043E\u0437\u0436\u0435 \u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0434\u043B\u044F \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F
    \u0448\u0440\u0438\u0444\u0442\u043E\u0432 \u2014 **METAFONT**.  \u0412 \u0445\u043E\u0434\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u043D\u0430\u0434 TeX \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044E **\"\u0433\u0440\u0430\u043C\u043E\u0442\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\"
    (Literate Programming)**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0435\u0442
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443 \u043D\u0435 \u043A\u0430\u043A
    \u0438\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044E \u0434\u043B\u044F
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u0430, \u0430 \u043A\u0430\u043A
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u043E\u0435 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435,
    \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u043E\u0435
    \u0434\u043B\u044F \u0447\u0442\u0435\u043D\u0438\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C. 
    ### \u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0438 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F  \u041A\u043D\u0443\u0442
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0438\u043C
    \u043F\u0435\u0440\u0444\u0435\u043A\u0446\u0438\u043E\u043D\u0438\u0437\u043C\u043E\u043C.
    \u0417\u0430 \u043A\u0430\u0436\u0434\u0443\u044E \u043D\u0430\u0439\u0434\u0435\u043D\u043D\u0443\u044E
    \u043E\u0448\u0438\u0431\u043A\u0443 \u0432 \u0435\u0433\u043E \u043A\u043D\u0438\u0433\u0430\u0445
    \u043E\u043D \u043F\u043B\u0430\u0442\u0438\u043B \u0432\u043E\u0437\u043D\u0430\u0433\u0440\u0430\u0436\u0434\u0435\u043D\u0438\u0435
    \u0432 **$2.56** (\"\u043E\u0434\u0438\u043D \u0448\u0435\u0441\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u0435\u0440\u0438\u0447\u043D\u044B\u0439
    \u0434\u043E\u043B\u043B\u0430\u0440\"). \u041C\u043D\u043E\u0433\u0438\u0435
    \u043E\u0431\u043B\u0430\u0434\u0430\u0442\u0435\u043B\u0438 \u044D\u0442\u0438\u0445
    \u0447\u0435\u043A\u043E\u0432 \u043D\u0435 \u043E\u0431\u043D\u0430\u043B\u0438\u0447\u0438\u0432\u0430\u043B\u0438
    \u0438\u0445, \u0430 \u0445\u0440\u0430\u043D\u0438\u043B\u0438 \u043A\u0430\u043A
    \u0446\u0435\u043D\u043D\u044B\u0439 \u0441\u0443\u0432\u0435\u043D\u0438\u0440.
    \u0421 2008 \u0433\u043E\u0434\u0430 \u043E\u043D \u0432\u044B\u0441\u044B\u043B\u0430\u0435\u0442
    \u0441\u0435\u0440\u0442\u0438\u0444\u0438\u043A\u0430\u0442\u044B \u0438\u0437
    \u0432\u044B\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u043E\u0433\u043E \"\u0411\u0430\u043D\u043A\u0430
    \u0421\u0430\u043D-\u0421\u0435\u0440\u0440\u0438\u0444\".  \u0412 1990 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u0443\u0448\u0435\u043B
    \u0438\u0437 \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434\u0430, \u0447\u0442\u043E\u0431\u044B
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0438\u0442\u044C\u0441\u044F
    \u043D\u0430 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0438 \"\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\".
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u043D\u043E\u0439
    \u043F\u043E\u0447\u0442\u044B, \u0447\u0442\u043E\u0431\u044B \u0435\u0433\u043E
    \u043D\u0435 \u043E\u0442\u0432\u043B\u0435\u043A\u0430\u043B\u0438. \u041A\u043D\u0443\u0442
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u0435\u043D
    (\u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0438\u043D) \u0438 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0438\u0441\u043A\u0443\u0441\u043D\u044B\u043C \u043E\u0440\u0433\u0430\u043D\u0438\u0441\u0442\u043E\u043C.
    \u041E\u043D \u0434\u0430\u0436\u0435 \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    \u043E\u0440\u0433\u0430\u043D \u0432 \u0441\u0432\u043E\u0435\u043C \u0434\u043E\u043C\u0435.
    \u0415\u0433\u043E \u0434\u0440\u0443\u0433, \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u0438\u0439
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0441\u0442 \u0410\u043D\u0434\u0440\u0435\u0439
    \u0415\u0440\u0448\u043E\u0432, \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u043D \u0438\u0437\u0443\u0447\u0430\u043B \u043F\u043E-\u0440\u0443\u0441\u0441\u043A\u0438
    \u0432 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u0435, \u043E\u043A\u0430\u0437\u0430\u043B
    \u043D\u0430 \u043D\u0435\u0433\u043E \u0431\u043E\u043B\u044C\u0448\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435. \u0412 2008 \u0433\u043E\u0434\u0443
    \u041A\u043D\u0443\u0442 \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D
    \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A."
  shortBioEn: 
  interestingFactsRu: "\u0414\u043E\u043D\u0430\u043B\u044C\u0434 \u041A\u043D\u0443\u0442
    \u2013 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u0430\u044F, \u043D\u043E
    \u0438 \u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u043E \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u0430\u044F.
    \u0417\u0430 \u0441\u0442\u0440\u043E\u0433\u0438\u043C\u0438 \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u043C\u0438
    \u0438 \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0442\u043E\u043C\u0430\u043C\u0438 \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0441 \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u044B\u043C
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C \u044E\u043C\u043E\u0440\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0430\u0441\u043F\u0435\u043A\u0442\u044B
    \u0441\u0432\u043E\u0435\u0439 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0432 \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0438\u0433\u0440\u0443. \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u044F\u0440\u043A\u0438\u0435
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u044B
    \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438. 
    ### \U0001F4B0 \u041D\u0430\u0433\u0440\u0430\u0434\u0430 \u0437\u0430 \u043E\u0448\u0438\u0431\u043A\u0438:
    \xAB\u0428\u0435\u0441\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u0435\u0440\u0438\u0447\u043D\u044B\u0439
    \u0434\u043E\u043B\u043B\u0430\u0440\xBB  \u041F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u0443\u0440\u044C\u0435\u0437 \u0441\u0432\u044F\u0437\u0430\u043D \u0441
    \u0432\u043E\u0437\u043D\u0430\u0433\u0440\u0430\u0436\u0434\u0435\u043D\u0438\u0435\u043C
    \u0437\u0430 \u043D\u0430\u0439\u0434\u0435\u043D\u043D\u044B\u0435 \u043E\u0448\u0438\u0431\u043A\u0438
    \u0432 \u0435\u0433\u043E \u043A\u043D\u0438\u0433\u0430\u0445. \u0417\u0430
    \u043A\u0430\u0436\u0434\u0443\u044E \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u043D\u0443\u044E
    \u043E\u043F\u0435\u0447\u0430\u0442\u043A\u0443 \u0438\u043B\u0438 \u043D\u0435\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C
    \u041A\u043D\u0443\u0442 \u0432\u044B\u043F\u043B\u0430\u0447\u0438\u0432\u0430\u0435\u0442
    **$2.56**. \u042D\u0442\u0430 \u0441\u0443\u043C\u043C\u0430 \u2014 \u043D\u0435
    \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0441\u0442\u044C, \u0430 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430\u044F
    \u0448\u0443\u0442\u043A\u0430: 256 \u0446\u0435\u043D\u0442\u043E\u0432 \u2014
    \u044D\u0442\u043E **\u043E\u0434\u0438\u043D \xAB\u0448\u0435\u0441\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u0435\u0440\u0438\u0447\u043D\u044B\u0439
    \u0434\u043E\u043B\u043B\u0430\u0440\xBB**. \u0427\u0435\u043A\u0438, \u0432\u044B\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0435
    \u0435\u0433\u043E \u0440\u0443\u043A\u043E\u0439, \u0441\u0442\u0430\u043B\u0438
    \u0446\u0435\u043D\u043D\u044B\u043C\u0438 \u0441\u0443\u0432\u0435\u043D\u0438\u0440\u0430\u043C\u0438,
    \u0438 \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u0446\u0435\u0432
    \u043D\u0435 \u043E\u0431\u043D\u0430\u043B\u0438\u0447\u0438\u0432\u0430\u044E\u0442
    \u0438\u0445, \u0430 \u0445\u0440\u0430\u043D\u044F\u0442 \u043A\u0430\u043A
    \u043F\u0430\u043C\u044F\u0442\u044C. \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u0447\u0442\u043E \u043E\u0431\u0449\u0430\u044F \u0441\u0443\u043C\u043C\u0430
    \u0432\u044B\u043F\u043B\u0430\u0442 \u043A 2005 \u0433\u043E\u0434\u0443 \u043F\u0440\u0435\u0432\u044B\u0441\u0438\u043B\u0430
    20 \u0442\u044B\u0441\u044F\u0447 \u043E\u0431\u044B\u0447\u043D\u044B\u0445
    \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432, \u043D\u043E \u043B\u0438\u0448\u044C
    \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0435 \u0447\u0435\u043A\u0438 \u0431\u044B\u043B\u0438
    \u043F\u0440\u0435\u0434\u044A\u044F\u0432\u043B\u0435\u043D\u044B \u0432 \u0431\u0430\u043D\u043A. 
    \u0412 2008 \u0433\u043E\u0434\u0443 \u041A\u043D\u0443\u0442 \u0431\u044B\u043B
    \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443. \u041C\u043E\u0448\u0435\u043D\u043D\u0438\u043A\u0438,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u043D\u043E\u043C\u0435\u0440\u0430
    \u0441 \u0432\u044B\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0445
    \u043D\u0430\u043F\u043E\u043A\u0430\u0437 \u0447\u0435\u043A\u043E\u0432, \u043F\u044B\u0442\u0430\u043B\u0438\u0441\u044C
    \u043E\u043F\u0443\u0441\u0442\u043E\u0448\u0438\u0442\u044C \u0435\u0433\u043E
    \u0441\u0447\u0435\u0442\u0430, \u0438\u0437-\u0437\u0430 \u0447\u0435\u0433\u043E
    \u0435\u043C\u0443 \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C \u0437\u0430\u043A\u0440\u044B\u0442\u044C
    \u0442\u0440\u0438 \u0431\u0430\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0445
    \u0441\u0447\u0435\u0442\u0430. \u0422\u0435\u043F\u0435\u0440\u044C \u0437\u0430
    \u043D\u0430\u0439\u0434\u0435\u043D\u043D\u044B\u0435 \u043E\u0448\u0438\u0431\u043A\u0438
    \u043E\u043D \u0432\u044B\u0441\u044B\u043B\u0430\u0435\u0442 **\u0441\u0435\u0440\u0442\u0438\u0444\u0438\u043A\u0430\u0442\u044B
    \u0438\u0437 \u0432\u044B\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \xAB\u0411\u0430\u043D\u043A\u0430 \u0421\u0430\u043D-\u0421\u0435\u0440\u0440\u0438\u0444\xBB**
    (\u0441\u0442\u0440\u0430\u043D\u044B, \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043D\u043D\u043E\u0439
    \u0432 \u043F\u0435\u0440\u0432\u043E\u0430\u043F\u0440\u0435\u043B\u044C\u0441\u043A\u043E\u0439
    \u0448\u0443\u0442\u043A\u0435 \u0433\u0430\u0437\u0435\u0442\u044B Guardian).
    \u041A\u0430\u043A \u0438\u0440\u043E\u043D\u0438\u0447\u043D\u043E \u0437\u0430\u043C\u0435\u0442\u0438\u043B
    \u0441\u0430\u043C \u0443\u0447\u0435\u043D\u044B\u0439, \u043D\u0430\u0433\u0440\u0430\u0434\u0430
    \u0442\u0435\u043F\u0435\u0440\u044C \u2014 \u044D\u0442\u043E \xAB\u043F\u043E\u0447\u0435\u0442,
    \u0430 \u043D\u0435 \u0440\u0430\u0441\u0447\u0435\u0442\xBB (kudos, not escudos). 
    ### \U0001F9EE \u0412\u0435\u0440\u0441\u0438\u0438 TeX \u0438 METAFONT: \u0412
    \u043F\u043E\u0433\u043E\u043D\u0435 \u0437\u0430 \u03C0 \u0438 e  \u041A\u043D\u0443\u0442
    \u043F\u043E\u0434\u043E\u0448\u0435\u043B \u043A \u0432\u043E\u043F\u0440\u043E\u0441\u0443
    \u043D\u0443\u043C\u0435\u0440\u0430\u0446\u0438\u0438 \u0432\u0435\u0440\u0441\u0438\u0439
    \u0441\u0432\u043E\u0438\u0445 \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u0442\u0432\u043E\u0440\u0435\u043D\u0438\u0439
    \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438\u0437\u044B\u0441\u043A\u0430\u043D\u043D\u043E\u0441\u0442\u044C\u044E.
    \u041D\u0430\u0447\u0438\u043D\u0430\u044F \u0441 \u0432\u0435\u0440\u0441\u0438\u0438
    3.0, \u043D\u043E\u043C\u0435\u0440\u0430 \u0440\u0435\u043B\u0438\u0437\u043E\u0432
    \u0435\u0433\u043E \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B **TeX \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0430\u044E\u0442\u0441\u044F
    \u043A \u0447\u0438\u0441\u043B\u0443 \u03C0**: 3, 3.1, 3.14, 3.141 \u0438 \u0442\u0430\u043A
    \u0434\u0430\u043B\u0435\u0435. \u0410\u043D\u0430\u043B\u043E\u0433\u0438\u0447\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u043D\u043E\u043C\u0435\u0440\u0430
    \u0432\u0435\u0440\u0441\u0438\u0439 \u0448\u0440\u0438\u0444\u0442\u043E\u0432\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B **METAFONT \u0441\u0442\u0440\u0435\u043C\u044F\u0442\u0441\u044F
    \u043A \u0447\u0438\u0441\u043B\u0443 e**. \u042D\u0442\u0430 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u044F
    \u2014 \u043E\u0442\u043B\u0438\u0447\u043D\u044B\u0439 \u043F\u0440\u0438\u043C\u0435\u0440
    \u0435\u0433\u043E \u043B\u044E\u0431\u0432\u0438 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u0442\u043E\u043D\u043A\u043E\u043C\u0443 \u044E\u043C\u043E\u0440\u0443. 
    ### \U0001F4DA \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u044E\u043C\u043E\u0440 \u0432 \u043A\u043D\u0438\u0433\u0430\u0445  \u0428\u0443\u0442\u043A\u0438
    \u041A\u043D\u0443\u0442\u0430 \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u044E\u0442\u0441\u044F
    \u0447\u0435\u043A\u0430\u043C\u0438 \u0438 \u0432\u0435\u0440\u0441\u0438\u044F\u043C\u0438
    \u2014 \u043E\u043D\u0438 \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E
    \u0432\u043F\u043B\u0435\u0442\u0435\u043D\u044B \u0432 \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u044B
    \u0435\u0433\u043E \u043A\u043D\u0438\u0433.  *   **\xAB\u0414\u043E\u043A\u0430\u0437\u0430\u043D\u043E,
    \u043D\u043E \u043D\u0435 \u043F\u0440\u043E\u0432\u0435\u0440\u0435\u043D\u043E\xBB:**
    \u041E\u0434\u043D\u043E \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u0439
    \u0447\u0438\u0442\u0430\u0442\u0435\u043B\u044F\u043C \u0437\u0432\u0443\u0447\u0438\u0442
    \u0442\u0430\u043A: *\xAB\u041E\u0441\u0442\u0435\u0440\u0435\u0433\u0430\u0439\u0442\u0435\u0441\u044C
    \u043E\u0448\u0438\u0431\u043E\u043A \u0432 \u0432\u044B\u0448\u0435\u0443\u043A\u0430\u0437\u0430\u043D\u043D\u043E\u043C
    \u043A\u043E\u0434\u0435; \u044F \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0435\u0433\u043E \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E\u0441\u0442\u044C,
    \u043D\u043E \u043D\u0435 \u043F\u0440\u043E\u0431\u043E\u0432\u0430\u043B \u0437\u0430\u043F\u0443\u0441\u043A\u0430\u0442\u044C
    \u0435\u0433\u043E\xBB*. \u042D\u0442\u043E \u0438\u0440\u043E\u043D\u0438\u0447\u043D\u043E\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0442\u043E\u0433\u043E,
    \u0447\u0442\u043E \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0431\u0435\u0437\u0443\u043F\u0440\u0435\u0447\u043D\u043E\u0441\u0442\u044C
    \u043D\u0435 \u0432\u0441\u0435\u0433\u0434\u0430 \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u0443\u0435\u0442
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u043E\u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C.
    *   **\xAB\u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u043D\u043E\u0441\u0442\u044C\xBB
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u0443:** \u0412 \u043F\u0440\u0438\u043C\u0435\u0447\u0430\u043D\u0438\u044F\u0445
    \u043A \u0443\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044F\u043C \u0432 \u0440\u0430\u0437\u043D\u044B\u0445
    \u0442\u043E\u043C\u0430\u0445 \xAB\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F\xBB
    \u043E\u043D \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0438 \u0441 \u044E\u043C\u043E\u0440\u043E\u043C \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0435\u0442
    \u043D\u0435\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438. \u0412 \u043F\u0435\u0440\u0432\u043E\u043C
    \u0442\u043E\u043C\u0435 \u043E\u043D \u043F\u0438\u0448\u0435\u0442: \xAB\u0412\u0441\u0435
    \u043D\u0435\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438 \u0432 \u044D\u0442\u043E\u043C
    \u0443\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u0435 \u043C\u043E\u0433\u0443\u0442
    \u0431\u044B\u0442\u044C \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u044B
    \u0442\u0435\u043C \u0444\u0430\u043A\u0442\u043E\u043C, \u0447\u0442\u043E \u043E\u043D
    \u0431\u044B\u043B \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D
    \u043F\u0440\u0438 \u043F\u043E\u043C\u043E\u0449\u0438 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u0430\xBB.
    \u0412\u043E \u0432\u0442\u043E\u0440\u043E\u043C \u0442\u043E\u043C\u0435 \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u0435\u0442:
    \xAB...\u043D\u043E \u043D\u0435 \u0432\u0441\u043B\u0435\u043F\u0443\u044E\xBB.
    \u0410 \u0432 \u0442\u0440\u0435\u0442\u044C\u0435\u043C \u0442\u043E\u043C\u0435
    \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442: \xAB\u0443\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C
    \u0431\u044B\u043B \u043E\u0442\u0441\u043E\u0440\u0442\u0438\u0440\u043E\u0432\u0430\u043D
    \u043F\u0440\u0438 \u043F\u043E\u043C\u043E\u0449\u0438 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u0430\xBB.
    \u0422\u0430\u043A \u043E\u043D \u0448\u0443\u0442\u043B\u0438\u0432\u043E \u043F\u0435\u0440\u0435\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442
    \u0432\u0438\u043D\u0443 \u0437\u0430 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0435
    \u043E\u0448\u0438\u0431\u043A\u0438 \u043D\u0430 \u043C\u0430\u0448\u0438\u043D\u0443.
    *   **\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0433\u043E\u043D\u043E\u0440\u0430\u0440\u0430:** \u0412 \u043E\u0433\u043B\u0430\u0432\u043B\u0435\u043D\u0438\u0438
    \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E \u0442\u043E\u043C\u0430 \u0435\u0441\u0442\u044C
    \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u0430\u044F \u0441\u0441\u044B\u043B\u043A\u0430
    \xAB\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0430\u0432\u0442\u043E\u0440\u0441\u043A\u043E\u0433\u043E \u0433\u043E\u043D\u043E\u0440\u0430\u0440\u0430,
    407\xBB. \u041D\u0430 \u0441\u0430\u043C\u043E\u0439 \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0435
    407 \u043D\u0435\u0442 \u043D\u0438\u043A\u0430\u043A\u043E\u0433\u043E \u0442\u0435\u043A\u0441\u0442\u0430
    \u043D\u0430 \u044D\u0442\u0443 \u0442\u0435\u043C\u0443, \u043D\u043E \u0437\u0430\u0442\u043E
    \u0435\u0441\u0442\u044C \u0441\u0445\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \u043E\u0440\u0433\u0430\u043D\u0430.
    \u041A\u043D\u0443\u0442 \u043D\u0430\u043C\u0435\u043A\u0430\u0435\u0442, \u0447\u0442\u043E
    \u043F\u043E\u043A\u0443\u043F\u043A\u0430 \u044D\u0442\u043E\u0433\u043E \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430 \u0431\u044B\u043B\u0430
    \u043F\u0440\u043E\u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u0430
    \u0437\u0430 \u0441\u0447\u0435\u0442 \u043E\u0442\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439
    \u043E\u0442 \u043F\u0440\u043E\u0434\u0430\u0436 \u0435\u0433\u043E \u043A\u043D\u0438\u0433.
    *   **\xAB\u0411\u0435\u0442\u043E\u043D\u043D\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\xBB:**
    \u041D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \u043A\u043D\u0438\u0433\u0438 \xAB\u041A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\xBB (Concrete Mathematics)
    \u2014 \u044D\u0442\u043E \u0438\u0433\u0440\u0430 \u0441\u043B\u043E\u0432,
    \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u044F\u044E\u0449\u0430\u044F \u0441\u043B\u043E\u0432\u0430
    *continuous* (\u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0439)
    \u0438 *discrete* (\u0434\u0438\u0441\u043A\u0440\u0435\u0442\u043D\u044B\u0439).
    \u0412 \u043F\u0440\u0435\u0434\u0438\u0441\u043B\u043E\u0432\u0438\u0438 \u043E\u043D
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u0430\u043D\u0435\u043A\u0434\u043E\u0442,
    \u043A\u0430\u043A \u0432 \u043F\u0435\u0440\u0432\u044B\u0439 \u0434\u0435\u043D\u044C
    \u0447\u0442\u0435\u043D\u0438\u044F \u043A\u0443\u0440\u0441\u0430 \u0435\u0433\u043E
    \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u043F\u043E\u0448\u0443\u0442\u0438\u043B\u0438,
    \u0447\u0442\u043E \u043E\u043D \u0431\u0443\u0434\u0435\u0442 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C
    \xAB\u0442\u0435\u043E\u0440\u0438\u044E \u0431\u0435\u0442\u043E\u043D\u0430\xBB,
    \u0438 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432
    \u0441 \u043A\u0430\u0444\u0435\u0434\u0440\u044B \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0432\u0441\u0442\u0430\u043B\u0438 \u0438 \u043F\u043E\u043A\u0438\u043D\u0443\u043B\u0438
    \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u044E.  ### \U0001F3C6 \u0421\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u043E\u0435
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0435  *   **\xAB\u041C\u0438\u0441\u043A\u0430\xBB
    \u0434\u043B\u044F \u044F\u0433\u043E\u0434:** \u041F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0432 1974 \u0433\u043E\u0434\u0443 \u041F\u0440\u0435\u043C\u0438\u044E \u0422\u044C\u044E\u0440\u0438\u043D\u0433\u0430
    \u2014 \u0441\u0430\u043C\u0443\u044E \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E
    \u043D\u0430\u0433\u0440\u0430\u0434\u0443 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0438, \u041A\u043D\u0443\u0442
    \u043D\u0435 \u0441\u0442\u0430\u043B \u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0441\u0435\u0440\u0435\u0431\u0440\u044F\u043D\u044B\u0439 \u0442\u0440\u043E\u0444\u0435\u0439
    \u043D\u0430 \u0432\u0438\u0434\u043D\u043E\u0435 \u043C\u0435\u0441\u0442\u043E.
    \u0412\u043C\u0435\u0441\u0442\u043E \u044D\u0442\u043E\u0433\u043E \u043E\u043D
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u0435\u0433\u043E
    \u043A\u0430\u043A **\u0432\u0430\u0437\u0443 \u0438\u043B\u0438 \u043C\u0438\u0441\u043A\u0443
    \u0434\u043B\u044F \u043A\u043B\u0443\u0431\u043D\u0438\u043A\u0438 \u0438 \u043C\u043E\u0440\u043E\u0436\u0435\u043D\u043E\u0433\u043E**.
    \u042D\u0442\u043E\u0442 \u0436\u0435\u0441\u0442 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0437\u0443\u0435\u0442
    \u0435\u0433\u043E \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043F\u0440\u0435\u043D\u0435\u0431\u0440\u0435\u0436\u0435\u043D\u0438\u0435
    \u043A \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u043C \u043F\u043E\u0447\u0435\u0441\u0442\u044F\u043C.
    *   **\u042D\u043F\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0430
    \u0438 \u044E\u043D\u043E\u0448\u0435\u0441\u043A\u0438\u0435 \u0448\u0430\u043B\u043E\u0441\u0442\u0438:**
    \u0421\u0432\u043E\u044E \u043F\u0435\u0440\u0432\u0443\u044E \xAB\u043D\u0430\u0443\u0447\u043D\u0443\u044E\xBB
    \u0441\u0442\u0430\u0442\u044C\u044E \u041A\u043D\u0443\u0442 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0432 1957 \u0433\u043E\u0434\u0443 \u0432 \u0448\u043A\u043E\u043B\u044C\u043D\u043E\u043C
    \u0436\u0443\u0440\u043D\u0430\u043B\u0435 \xAB\u0421\u0443\u043C\u0430\u0441\u0448\u0435\u0434\u0448\u0438\u0439\xBB.
    \u0412 \u043D\u0435\u0439 \u043E\u043D \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B
    \u0441\u0432\u043E\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u043C\u0435\u0440,
    \u0433\u0434\u0435 \u043E\u0441\u043D\u043E\u0432\u043D\u0443\u044E \u0435\u0434\u0438\u043D\u0438\u0446\u0443
    \u0441\u0438\u043B\u044B \u043D\u0430\u0437\u0432\u0430\u043B \xABwhatmeworry\xBB
    (\u0447\u0442\u043E \u043C\u043D\u0435 \u0432\u043E\u043B\u043D\u043E\u0432\u0430\u0442\u044C\u0441\u044F),
    \u043E\u0442\u0441\u044B\u043B\u0430\u044F \u043A \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0443
    \u043A\u043E\u043C\u0438\u043A\u0441\u043E\u0432 \u0410\u043B\u044C\u0444\u0440\u0435\u0434\u0443
    \u042D. \u041D\u044C\u044E\u043C\u0430\u043D\u0443.  ### \U0001F3B5 \u041C\u0443\u0437\u044B\u043A\u0430
    \u043A\u0430\u043A \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C  \u041A\u043D\u0443\u0442
    \u2014 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0439
    \u0443\u0447\u0435\u043D\u044B\u0439, \u043D\u043E \u0438 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0439
    \u043C\u0443\u0437\u044B\u043A\u0430\u043D\u0442. \u041A 80-\u043B\u0435\u0442\u0438\u044E
    \u043E\u043D \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u043D\u043E\u0435
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0435 \u0434\u043B\u044F \u043E\u0440\u0433\u0430\u043D\u0430
    \u043F\u043E\u0434 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435\u043C **\xABFantasia
    Apocalyptica\xBB**, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u043E\u0435
    \u043D\u0430 \u0442\u0435\u043A\u0441\u0442\u0435 \u041E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u0438\u044F
    \u0418\u043E\u0430\u043D\u043D\u0430 \u0411\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0430.
    \u0427\u0442\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u043E\u043D \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u0434\u043B\u044F \u0433\u0435\u043D\u0435\u0440\u0430\u0446\u0438\u0438
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043C\u0435\u043B\u043E\u0434\u0438\u0439
    \u0432 \u044D\u0442\u043E\u043C \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0438.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043E\u043D \u043F\u043E-\u0440\u0430\u0437\u043D\u043E\u043C\u0443
    \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0434\u0440\u0435\u0432\u043D\u0435\u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0443\u044E
    \u043C\u0435\u043B\u043E\u0434\u0438\u044E, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C \u0414\u044D\u0432\u0438\u0434\u0430
    \u041A\u0440\u0430\u0445\u0435\u043D\u0431\u044E\u043B\u044F, \u0430 \u0434\u043B\u044F
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0443\u0437\u043E\u0440\u043E\u0432
    (\u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0439 \u043A\u043E\u043B\u043E\u043A\u043E\u043B\u044C\u043D\u044B\u0445
    \u0437\u0432\u043E\u043D\u043E\u0432) \u0438 \u043C\u0435\u043B\u043E\u0434\u0438\u0439
    \u0434\u043B\u044F \xAB\u0434\u0432\u0435\u043D\u0430\u0434\u0446\u0430\u0442\u0438
    \u043A\u043E\u043B\u0435\u043D \u0418\u0437\u0440\u0430\u0438\u043B\u044F\xBB
    \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u043E\u0434\u0445\u043E\u0434\u044B.  ### \U0001F4A1 \u0410\u043D\u0430\u043B\u0438\u0442\u0438\u043A\u0430
    \u0431\u0430\u0441\u043A\u0435\u0442\u0431\u043E\u043B\u0430 \u0438 \u0431\u0443\u0434\u0443\u0449\u0435\u0435
    AI  *   **\u041F\u0435\u0440\u0432\u044B\u0439 \u0432 \u043C\u0438\u0440\u0435
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u043A \u041D\u0411\u0410:** \u0415\u0449\u0435
    \u0432 1958 \u0433\u043E\u0434\u0443, \u0431\u0443\u0434\u0443\u0447\u0438 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C
    \u0438 \u043C\u0435\u043D\u0435\u0434\u0436\u0435\u0440\u043E\u043C \u0431\u0430\u0441\u043A\u0435\u0442\u0431\u043E\u043B\u044C\u043D\u043E\u0439
    \u043A\u043E\u043C\u0430\u043D\u0434\u044B, \u041A\u043D\u0443\u0442 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u0443\u044E \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443
    \u0434\u043B\u044F IBM 650, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043E\u0446\u0435\u043D\u0438\u0432\u0430\u043B\u0430
    \u0432\u043A\u043B\u0430\u0434 \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u0438\u0433\u0440\u043E\u043A\u0430
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u043E \u043D\u0430\u0431\u0440\u0430\u043D\u043D\u044B\u043C
    \u043E\u0447\u043A\u0430\u043C. \u0415\u0433\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u0430
    \u043F\u043E\u043C\u043E\u0433\u043B\u0430 \u043A\u043E\u043C\u0430\u043D\u0434\u0435
    \u0432\u044B\u0438\u0433\u0440\u0430\u0442\u044C \u0447\u0435\u043C\u043F\u0438\u043E\u043D\u0430\u0442
    \u043B\u0438\u0433\u0438, \u0430 \u0441\u0430\u043C\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u044F
