    \u0432\u043E\u043F\u0440\u043E\u0441\u044B, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440:
    *\xAB\u041F\u043E\u0434\u043D\u0438\u043C\u0435\u0442\u0441\u044F \u043B\u0438
    \u0438\u043D\u0434\u0435\u043A\u0441 Nasdaq \u0432 \u0441\u0443\u0431\u0431\u043E\u0442\u0443?\xBB*
    (\u0432\u043E\u043F\u0440\u043E\u0441 \u043E \u0431\u0438\u0440\u0436\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0437\u0430\u043A\u0440\u044B\u0442\u0430
    \u043F\u043E \u0441\u0443\u0431\u0431\u043E\u0442\u0430\u043C) \u0438 *\xAB\u041D\u0430\u043F\u0438\u0448\u0438\u0442\u0435
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0440\u043E\u0432\u043D\u043E
    \u0438\u0437 \u043F\u044F\u0442\u0438 \u0431\u0443\u043A\u0432\xBB*. \u041E\u043D
    \u043F\u0440\u0438\u0437\u043D\u0430\u043B, \u0447\u0442\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u0430
    \xAB\u0433\u043E\u0440\u0430\u0437\u0434\u043E \u043B\u0443\u0447\u0448\u0435
    99% \u0442\u0435\u043A\u0441\u0442\u043E\u0432\xBB, \u043D\u043E \u0442\u0430\u043A\u0436\u0435
    \u043E\u0442\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u043E\u043D\u0430
    \u0434\u0435\u043B\u0430\u0435\u0442 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043E\u0448\u0438\u0431\u043A\u0438.  \u042D\u0442\u0438 \u0434\u0435\u0442\u0430\u043B\u0438
    \u0440\u0438\u0441\u0443\u044E\u0442 \u043E\u0431\u0440\u0430\u0437 \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E, \u043D\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0442
    \u043A \u0436\u0438\u0437\u043D\u0438 \u0441 \u0442\u043E\u0439 \u0436\u0435
    \u0441\u0442\u0440\u0430\u0441\u0442\u044C\u044E, \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u043E\u043C
    \u0438 \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C \u044E\u043C\u043E\u0440\u0430,
    \u0441 \u043A\u0430\u043A\u043E\u0439 \u043E\u043D \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0442
    \u043A \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0430\u043C \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. 
    \u041D\u0430\u0434\u0435\u044E\u0441\u044C, \u044D\u0442\u043E\u0442 \u0441\u0431\u043E\u0440\u043D\u0438\u043A
    \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u0432 \u0431\u044B\u043B \u0434\u043B\u044F
