    \u043E\u0431 \u044D\u0442\u043E\u043C \u043A\u043E\u0440\u043E\u0442\u043A\u043E\u043C\u0435\u0442\u0440\u0430\u0436\u043D\u044B\u0439
    \u0444\u0438\u043B\u044C\u043C \xABThe Electronic Coach\xBB. \u041F\u043E \u0441\u0443\u0442\u0438,
    \u041A\u043D\u0443\u0442 \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u043E\u043F\u0440\u043E\u0445\u043E\u0434\u0446\u0435\u043C
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0431\u0430\u0441\u043A\u0435\u0442\u0431\u043E\u043B\u044C\u043D\u043E\u0439
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u0435\u0439\u0447\u0430\u0441 \u0448\u0438\u0440\u043E\u043A\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0432 \u041D\u0411\u0410. *   **\xAB\u042D\u043A\u0437\u0430\u043C\u0435\u043D\xBB
