  achievementsRu: "\u041A\u043B\u043E\u0434 \u0428\u0435\u043D\u043D\u043E\u043D
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0441\u0442\u0430\u043B\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043D\u0430\u0443\u043A\u0438
    \u0438 \u0442\u0435\u0445\u043D\u0438\u043A\u0438. \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \u043E\u0434\u043D\u043E\u0439 \u0438\u0434\u0435\u0435\u0439
    \u2014 \u044D\u0442\u043E \u0446\u0435\u043B\u0430\u044F \u0441\u0438\u0441\u0442\u0435\u043C\u0430
    \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0449\u0438\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432, \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0438\u0445
    \u043C\u0438\u0440. \u0414\u0430\u0432\u0430\u0439\u0442\u0435 \u0440\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0438\u043C
    \u0438\u0445 \u0432 \u0434\u0435\u0442\u0430\u043B\u044F\u0445.  ### \u2699\uFE0F
    \u0426\u0438\u0444\u0440\u043E\u0432\u0430\u044F \u0441\u0445\u0435\u043C\u043E\u0442\u0435\u0445\u043D\u0438\u043A\u0430:
    \u043E\u0442 \u0440\u0435\u043B\u0435 \u043A \u0431\u0443\u043B\u0435\u0432\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0435  \u041F\u0435\u0440\u0432\u044B\u043C
    \u0438, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0441\u0430\u043C\u044B\u043C
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C
    \u0428\u0435\u043D\u043D\u043E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430 \u0440\u0430\u0431\u043E\u0442\u0430,
    \u043F\u0440\u043E\u0434\u0435\u043B\u0430\u043D\u043D\u0430\u044F \u0438\u043C
    \u0435\u0449\u0435 \u0432 MIT. \u0412 \u0441\u0432\u043E\u0435\u0439 \u043C\u0430\u0433\u0438\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438 **\xAB\u0421\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0440\u0435\u043B\u0435\u0439\u043D\u044B\u0445
    \u0438 \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0441\u0445\u0435\u043C\xBB** (1937 \u0433.) \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432.  *   **\u0421\u0443\u0442\u044C \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F**:
    \u0428\u0435\u043D\u043D\u043E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u0445\u0435\u043C\u044B, \u0441\u043E\u0441\u0442\u043E\u044F\u0449\u0438\u0435
    \u0438\u0437 \u0440\u0435\u043B\u0435 \u0438 \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0442\u0435\u043B\u0435\u0439,
    \u043C\u043E\u0436\u043D\u043E \u043E\u043F\u0438\u0441\u0430\u0442\u044C \u0441
    \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043F\u0440\u043E\u0441\u0442\u043E\u0439
    \u0438 \u0441\u0442\u0440\u043E\u0433\u043E\u0439 **\u0431\u0443\u043B\u0435\u0432\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B**. \u041E\u043D \u0441\u0432\u044F\u0437\u0430\u043B
    \u0434\u0432\u0430 \u043C\u0438\u0440\u0430: \u043B\u043E\u0433\u0438\u043A\u0443
    (\u0438\u0441\u0442\u0438\u043D\u0430/\u043B\u043E\u0436\u044C) \u0438 \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    (\u0432\u043A\u043B\u044E\u0447\u0435\u043D\u043E/\u0432\u044B\u043A\u043B\u044E\u0447\u0435\u043D\u043E,
    1/0). *   **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435**: \u042D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0441\u0442\u0430\u043B\u0430 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432\u0441\u0435\u0445 \u0446\u0438\u0444\u0440\u043E\u0432\u044B\u0445 \u0441\u0445\u0435\u043C,
    \u043B\u0435\u0436\u0430\u0449\u0438\u0445 \u0432 \u043E\u0441\u043D\u043E\u0432\u0435
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u0432.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043D\u0430\u0437\u0432\u0430\u043D\u0430
    **\xAB\u0441\u0430\u043C\u043E\u0439 \u0437\u043D\u0430\u0447\u0438\u043C\u043E\u0439
    \u043C\u0430\u0433\u0438\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0435\u0439
    XX \u0432\u0435\u043A\u0430\xBB**.  ### \U0001F4E1 \u0422\u0435\u043E\u0440\u0438\u044F
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438: \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0441\u0432\u044F\u0437\u0438  \u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434
    \u0436\u0438\u0437\u043D\u0438 \u0428\u0435\u043D\u043D\u043E\u043D\u0430 \u2014
    \u044D\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 **\u0442\u0435\u043E\u0440\u0438\u0438
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0430 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u043D\u0430\u0448\u0435\u043C \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0438
    \u0434\u0430\u043D\u043D\u044B\u0445 \u0438 \u0441\u0432\u044F\u0437\u0438. \u041E\u0441\u043D\u043E\u0432\u044B
    \u0431\u044B\u043B\u0438 \u0437\u0430\u043B\u043E\u0436\u0435\u043D\u044B \u0432
    \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \u0441\u0442\u0430\u0442\u044C\u0435 **\xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0441\u0432\u044F\u0437\u0438\xBB** (1948
    \u0433\u043E\u0434).  \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u0438\u0434\u0435\u0438
    \u044D\u0442\u043E\u0433\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430:  *   **\u041E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438**: \u0428\u0435\u043D\u043D\u043E\u043D
    \u043F\u0435\u0440\u0432\u044B\u043C \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u043F\u043E\u0441\u043E\u0431 \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438,
    \u043E\u0442\u0434\u0435\u043B\u0438\u0432 \u0435\u0433\u043E \u043E\u0442 \u0441\u043C\u044B\u0441\u043B\u0430
    \u0438 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u044F \u0441\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u044F.
    \u0418\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F \u0441\u0442\u0430\u043B\u0430
    \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439 \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u043E\u0439.
    *   **\u041C\u0435\u0440\u0430 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
    (\u042D\u043D\u0442\u0440\u043E\u043F\u0438\u044F)**: \u041E\u043D \u0432\u0432\u0435\u043B
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u0443, \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u0443\u044E
    **\u044D\u043D\u0442\u0440\u043E\u043F\u0438\u0435\u0439**, \u043A\u0430\u043A
    \u043C\u0435\u0440\u0443 \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u0438\u043B\u0438 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438 \u0432 \u0441\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u0438.
    \u042D\u0442\u043E \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u043E\u043D \u043F\u043E\u0437\u0430\u0438\u043C\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0438\u0437 \u0442\u0435\u0440\u043C\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438
    \u043F\u043E \u0441\u043E\u0432\u0435\u0442\u0443 \u0414\u0436\u043E\u043D\u0430
    \u0444\u043E\u043D \u041D\u0435\u0439\u043C\u0430\u043D\u0430. *   **\u0415\u0434\u0438\u043D\u0438\u0446\u0430
    \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F \u2014 \xAB\u0411\u0438\u0442\xBB**:
    \u0418\u043C\u0435\u043D\u043D\u043E \u0428\u0435\u043D\u043D\u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0441\u043B\u043E\u0432\u043E
    **\xAB\u0431\u0438\u0442\xBB** (binary digit) \u043A\u0430\u043A \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u0443\u044E
    \u0435\u0434\u0438\u043D\u0438\u0446\u0443 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
    \u0434\u043B\u044F \u0432\u044B\u0431\u043E\u0440\u0430 \u043C\u0435\u0436\u0434\u0443
    \u0434\u0432\u0443\u043C\u044F \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u043C\u0438
    \u0432\u0430\u0440\u0438\u0430\u043D\u0442\u0430\u043C\u0438. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0428\u0435\u043D\u043D\u043E\u043D\u0430-\u0425\u0430\u0440\u0442\u043B\u0438**:
    \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0437\u0430\u043A\u043E\u043D \u0434\u043B\u044F \u043A\u0430\u043D\u0430\u043B\u043E\u0432
    \u0441\u0432\u044F\u0437\u0438 \u0441 \u0448\u0443\u043C\u043E\u043C. \u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442, \u0447\u0442\u043E
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 **\u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u0430\u044F
    \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0438
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438** (\u043F\u0440\u0435\u0434\u0435\u043B
    \u0428\u0435\u043D\u043D\u043E\u043D\u0430), \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043D\u0435\u043B\u044C\u0437\u044F \u043F\u0440\u0435\u0432\u044B\u0441\u0438\u0442\u044C
    \u0431\u0435\u0437 \u0440\u0438\u0441\u043A\u0430 \u043E\u0448\u0438\u0431\u043E\u043A.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435 \u043A\u043E\u0434\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435,
    \u043C\u043E\u0436\u043D\u043E \u0441\u043A\u043E\u043B\u044C \u0443\u0433\u043E\u0434\u043D\u043E
    \u0431\u043B\u0438\u0437\u043A\u043E \u043F\u0440\u0438\u0431\u043B\u0438\u0437\u0438\u0442\u044C\u0441\u044F
    \u043A \u044D\u0442\u043E\u0439 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438,
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432 \u043F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0431\u0435\u0437\u043E\u0448\u0438\u0431\u043E\u0447\u043D\u0443\u044E
    \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0443.  \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0430 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043E\u0441\u043D\u043E\u0432\u0443 \u0434\u043B\u044F \u0432\u0441\u0435\u0445
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 \u0441\u0438\u0441\u0442\u0435\u043C
    \u0441\u0432\u044F\u0437\u0438: \u043E\u0442 \u0441\u043E\u0442\u043E\u0432\u043E\u0439
    \u0442\u0435\u043B\u0435\u0444\u043E\u043D\u0438\u0438 \u0438 \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442\u0430
    \u0434\u043E \u043A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0432\u044F\u0437\u0438 \u0438 \u0441\u0436\u0430\u0442\u0438\u044F \u0434\u0430\u043D\u043D\u044B\u0445. 
    ### \U0001F510 \u041A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u044F:
    \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430
    \u0432 \u043D\u0430\u0443\u043A\u0443  \u0420\u0430\u0431\u043E\u0442\u0430\u044F
    \u0432 Bell Labs \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0412\u0442\u043E\u0440\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B \u0438
    \u043F\u043E\u0441\u043B\u0435 \u043D\u0435\u0435, \u0428\u0435\u043D\u043D\u043E\u043D
    \u0432\u043D\u0435\u0441 \u043D\u0435\u043E\u0446\u0435\u043D\u0438\u043C\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u044E. 
    *   **\u041A\u043B\u044E\u0447\u0435\u0432\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430**:
    \u0412 1949 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0442\u0430\u0442\u044C\u044E **\xAB\u0422\u0435\u043E\u0440\u0438\u044F
    \u0441\u0432\u044F\u0437\u0438 \u0432 \u0441\u0435\u043A\u0440\u0435\u0442\u043D\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0445\xBB**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u0442\u0430\u043B\u0430 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C
    \u0435\u0433\u043E \u0437\u0430\u0441\u0435\u043A\u0440\u0435\u0447\u0435\u043D\u043D\u043E\u0433\u043E
    \u0434\u043E\u043A\u043B\u0430\u0434\u0430 1945 \u0433\u043E\u0434\u0430. *  
    **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435**: \u0412 \u044D\u0442\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u0441\u0442\u0440\u043E\u0433\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442 \u043A \u0430\u043D\u0430\u043B\u0438\u0437\u0443
    \u0448\u0438\u0444\u0440\u043E\u0432. \u041E\u043D \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F **\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E\u0439
    \u0441\u0435\u043A\u0440\u0435\u0442\u043D\u043E\u0441\u0442\u0438**, \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0441\u0442\u043E\u0439\u043A\u043E\u0441\u0442\u044C \u0448\u0438\u0444\u0440\u0430
    \u0412\u0435\u0440\u043D\u0430\u043C\u0430 \u0438 \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    **\u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u0438**
    \u2014 \u043E\u0431\u044A\u0435\u043C\u0430 \u0448\u0438\u0444\u0440\u0442\u0435\u043A\u0441\u0442\u0430,
    \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0433\u043E \u0434\u043B\u044F
    \u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E\u0439 \u0440\u0430\u0441\u0448\u0438\u0444\u0440\u043E\u0432\u043A\u0438.
    \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u0430
    \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u044E \u0438\u0437
    \u0440\u0435\u043C\u0435\u0441\u043B\u0430 \u0432 \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443.  ### \U0001F916 \u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442 \u0438 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u044B 
    \u0428\u0435\u043D\u043D\u043E\u043D \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043F\u0438\u043E\u043D\u0435\u0440\u043E\u0432, \u0437\u0430\u043B\u043E\u0436\u0438\u0432\u0448\u0438\u0445
    \u043E\u0441\u043D\u043E\u0432\u044B \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0430.  *   **\u0428\u0430\u0445\u043C\u0430\u0442\u043D\u044B\u0439
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440**: \u0412 1950 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0440\u0430\u0431\u043E\u0442\u0443, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043E\u043F\u0438\u0441\u0430\u043B, \u043A\u0430\u043A \u043C\u043E\u0436\u043D\u043E
    \u0437\u0430\u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440 \u0434\u043B\u044F \u0438\u0433\u0440\u044B
    \u0432 \u0448\u0430\u0445\u043C\u0430\u0442\u044B, \u0438 \u0434\u0430\u0436\u0435
    \u0441\u043E\u0437\u0434\u0430\u043B \u043E\u0434\u043D\u0443 \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u0442\u0430\u043A\u0438\u0445 \u043C\u0430\u0448\u0438\u043D. *   **\u041C\u044B\u0448\u044C
    \xAB\u0422\u0435\u0441\u0435\u0439\xBB**: \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043C\u044B\u0448\u044C, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043C\u043E\u0433\u043B\u0430
    \u043E\u0431\u0443\u0447\u0430\u0442\u044C\u0441\u044F \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C
    \u0432\u044B\u0445\u043E\u0434 \u0438\u0437 \u043B\u0430\u0431\u0438\u0440\u0438\u043D\u0442\u0430,
    \u0437\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u044F \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0439
    \u043F\u0443\u0442\u044C \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u0432 \u0441\u0430\u043C\u043E\u043E\u0431\u0443\u0447\u0430\u044E\u0449\u0435\u0433\u043E\u0441\u044F
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430.  \u042D\u0442\u0438
    \u0440\u0430\u0431\u043E\u0442\u044B \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u044B \u0434\u043B\u044F \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F
    \u043A\u0438\u0431\u0435\u0440\u043D\u0435\u0442\u0438\u043A\u0438 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u043E\u0432, \u0438 \u0438\u043C\u0435\u043D\u043D\u043E
    \u0437\u0430 \u044D\u0442\u043E \u0435\u0433\u043E \u0432\u044B\u0441\u043E\u043A\u043E
    \u0446\u0435\u043D\u0438\u043B\u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0438,
    \u0432\u043F\u043B\u043E\u0442\u044C \u0434\u043E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u0430
    \u0410.\u041D. \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430. 
    \u0412 \u0446\u0435\u043B\u043E\u043C, \u0441\u043E\u0432\u043E\u043A\u0443\u043F\u043D\u043E\u0441\u0442\u044C
    \u044D\u0442\u0438\u0445 \u0442\u0440\u0443\u0434\u043E\u0432 \u0441\u043E\u0437\u0434\u0430\u043B\u0430
    \u043E\u0441\u043D\u043E\u0432\u0443 \u0434\u043B\u044F \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0439
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438. \u0420\u0430\u0431\u043E\u0442\u044B
    \u0428\u0435\u043D\u043D\u043E\u043D\u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0440\u0435\u0448\u0438\u043B\u0438 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0435
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438,
    \u043D\u043E \u0438 \u0434\u0430\u043B\u0438 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u044F\u0437\u044B\u043A \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u0438 \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u043B\u044E\u0431\u044B\u0445 \u0441\u0438\u0441\u0442\u0435\u043C, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445
    \u0441 \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0435\u0439, \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u043E\u0439
    \u0438 \u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0435\u043C \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438."
  achievementsEn: 
  personalLifeRu: "\u041A\u043B\u043E\u0434 \u0428\u0435\u043D\u043D\u043E\u043D
    \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0432\u0435\u043B\u0438\u043A\u0438\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C, \u043D\u043E \u0438 \u043E\u0447\u0435\u043D\u044C
    \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u0430
    \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430, \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0445
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445
    \u043B\u0438\u0447\u043D\u044B\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0439.
    \u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439 \u0440\u0430\u0441\u0441\u043A\u0430\u0437
    \u043E \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u043E\u043C
    \u043F\u0443\u0442\u0438.  ### \U0001F476 \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435,
    \u0421\u0435\u043C\u044C\u044F \u0438 \u0414\u0435\u0442\u0441\u0442\u0432\u043E 
    \u041A\u043B\u043E\u0434 \u042D\u043B\u0432\u0443\u0434 \u0428\u0435\u043D\u043D\u043E\u043D
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **30 \u0430\u043F\u0440\u0435\u043B\u044F
    1916 \u0433\u043E\u0434\u0430** \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u041F\u0435\u0442\u043E\u0446\u043A\u0438,
    \u0448\u0442\u0430\u0442 \u041C\u0438\u0447\u0438\u0433\u0430\u043D. \u0425\u043E\u0442\u044F
    \u043E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0432 \u041F\u0435\u0442\u043E\u0446\u043A\u0438,
    \u043F\u0435\u0440\u0432\u044B\u0435 \u0448\u0435\u0441\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u044C
    \u043B\u0435\u0442 \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438
    \u043E\u043D \u043F\u0440\u043E\u0432\u0435\u043B \u0432 \u0441\u043E\u0441\u0435\u0434\u043D\u0435\u043C
    \u0413\u044D\u0439\u043B\u043E\u0440\u0434\u0435, \u0448\u0442\u0430\u0442 \u041C\u0438\u0447\u0438\u0433\u0430\u043D,
    \u043A\u0443\u0434\u0430 \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432\u0441\u043A\u043E\u0440\u0435 \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F.  \u0415\u0433\u043E \u0441\u0435\u043C\u044C\u044F
    \u0441\u043E\u0437\u0434\u0430\u043B\u0430 \u0431\u043B\u0430\u0433\u043E\u043F\u0440\u0438\u044F\u0442\u043D\u0443\u044E
    \u0441\u0440\u0435\u0434\u0443 \u0434\u043B\u044F \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F
    \u0435\u0433\u043E \u0442\u0430\u043B\u0430\u043D\u0442\u043E\u0432: *   **\u041E\u0442\u0435\u0446**,
    \u041A\u043B\u043E\u0434 \u0428\u0435\u043D\u043D\u043E\u043D-\u0441\u0442\u0430\u0440\u0448\u0438\u0439
    (1862\u20131934), \u0431\u044B\u043B \u0431\u0438\u0437\u043D\u0435\u0441\u043C\u0435\u043D\u043E\u043C,
    \u0430\u0434\u0432\u043E\u043A\u0430\u0442\u043E\u043C \u0438 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u0441\u0443\u0434\u044C\u0435\u0439 \u043F\u043E
    \u0434\u0435\u043B\u0430\u043C \u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0435.
    \u041E\u043D \u043E\u0431\u043B\u0430\u0434\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0441\u043A\u043B\u0430\u0434\u043E\u043C \u0443\u043C\u0430 \u0438 \u043F\u043E\u043E\u0449\u0440\u044F\u043B
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F \u0441\u044B\u043D\u0430.
    *   **\u041C\u0430\u0442\u044C**, \u041C\u0435\u0439\u0431\u0435\u043B \u0412\u0443\u043B\u0444
    \u0428\u0435\u043D\u043D\u043E\u043D (1890\u20131945), \u0431\u044B\u043B\u0430
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0445 \u044F\u0437\u044B\u043A\u043E\u0432,
    \u0430 \u043F\u043E\u0437\u0436\u0435 \u0441\u0442\u0430\u043B\u0430 \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u0413\u044D\u0439\u043B\u043E\u0440\u0434\u0441\u043A\u043E\u0439 \u0441\u0440\u0435\u0434\u043D\u0435\u0439
    \u0448\u043A\u043E\u043B\u044B. *   **\u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442**: \u0421\u0430\u043C \u0422\u043E\u043C\u0430\u0441
    \u042D\u0434\u0438\u0441\u043E\u043D \u0431\u044B\u043B \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0438\u043C
    \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u043C,
    \u0438 \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u0428\u0435\u043D\u043D\u043E\u043D
    \u0441\u0447\u0438\u0442\u0430\u043B \u0435\u0433\u043E \u0441\u0432\u043E\u0438\u043C
    \u0433\u0435\u0440\u043E\u0435\u043C.  \u0412 \u044E\u043D\u043E\u0441\u0442\u0438
    \u0428\u0435\u043D\u043D\u043E\u043D \u0431\u044B\u043B \u043D\u0435\u0443\u0442\u043E\u043C\u0438\u043C\u044B\u043C
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u0435\u043C.
    \u041E\u043D \u0441\u043E\u0431\u0438\u0440\u0430\u043B \u043C\u043E\u0434\u0435\u043B\u0438
    \u0441\u0430\u043C\u043E\u043B\u0435\u0442\u043E\u0432, \u0441\u043E\u0437\u0434\u0430\u043B
    \u0440\u0430\u0434\u0438\u043E\u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u043C\u0443\u044E
    \u043B\u043E\u0434\u043A\u0443 \u0438 \u0434\u0430\u0436\u0435 \u0442\u0435\u043B\u0435\u0433\u0440\u0430\u0444\u043D\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u043C\u0435\u0436\u0434\u0443 \u0441\u0432\u043E\u0438\u043C
    \u0434\u043E\u043C\u043E\u043C \u0438 \u0434\u043E\u043C\u043E\u043C \u0434\u0440\u0443\u0433\u0430,
    \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u043C
    \u0432 \u043F\u043E\u043B\u0443\u043C\u0438\u043B\u0435. \u0422\u0430\u043A\u0436\u0435
    \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043A\u0443\u0440\u044C\u0435\u0440\u043E\u043C
    \u0432 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u0438 Western Union.  ### \U0001F393
    \u0423\u0447\u0451\u0431\u0430 \u0438 \u041D\u0430\u0443\u0447\u043D\u044B\u0435
    \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u044F  \u0412 **1932 \u0433\u043E\u0434\u0443**
    \u0428\u0435\u043D\u043D\u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u041C\u0438\u0447\u0438\u0433\u0430\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442.
    \u041E\u043D \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u0435\u0433\u043E \u0432
    **1936 \u0433\u043E\u0434\u0443**, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0441\u0440\u0430\u0437\u0443 \u0434\u0432\u0435 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430: \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u043F\u043E \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u0442\u0435\u0445\u043D\u0438\u043A\u0435. 
    \u0417\u0430\u0442\u0435\u043C \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u041C\u0430\u0441\u0441\u0430\u0447\u0443\u0441\u0435\u0442\u0441\u043A\u0438\u0439
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 (MIT), \u0433\u0434\u0435 \u0441\u0442\u0430\u043B
    \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u043C \u0412\u044D\u043D\u0438\u0432\u0430\u0440\u0430
    \u0411\u0443\u0448\u0430, \u0440\u0430\u0431\u043E\u0442\u0430\u044F \u043D\u0430\u0434
    \u0435\u0433\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C \u2014
    \u0430\u043D\u0430\u043B\u043E\u0433\u043E\u0432\u044B\u043C \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u043C.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C \u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B
    \u0441\u0432\u043E\u0435 \u043F\u0435\u0440\u0432\u043E\u0435 \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435.  \u0412 \u0441\u0432\u043E\u0435\u0439
    \u043C\u0430\u0433\u0438\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438
    **\xAB\u0421\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
