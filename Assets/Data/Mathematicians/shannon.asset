    \u0438 \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0441\u0445\u0435\u043C\xBB** (1937 \u0433., \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430
    \u0432 1938 \u0433.) \u0428\u0435\u043D\u043D\u043E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u044B \u0431\u0443\u043B\u0435\u0432\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434\u044F\u0442 \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0445\u0435\u043C. \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u0441\u0442\u0430\u043B\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432\u0441\u0435\u0445 \u0446\u0438\u0444\u0440\u043E\u0432\u044B\u0445 \u0441\u0445\u0435\u043C
    \u0438 \u0431\u044B\u043B\u043E \u043D\u0430\u0437\u0432\u0430\u043D\u043E **\xAB\u0441\u0430\u043C\u043E\u0439
    \u0437\u043D\u0430\u0447\u0438\u043C\u043E\u0439 \u043C\u0430\u0433\u0438\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0435\u0439 XX \u0432\u0435\u043A\u0430\xBB**. 
    \u041F\u043E \u0441\u043E\u0432\u0435\u0442\u0443 \u0411\u0443\u0448\u0430 \u0428\u0435\u043D\u043D\u043E\u043D
    \u0437\u0430\u043D\u044F\u043B\u0441\u044F \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u0434\u0440\u0443\u0433\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u044C\u044E.
    \u0415\u0433\u043E \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0430\u044F
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F, \u0437\u0430\u0449\u0438\u0449\u0435\u043D\u043D\u0430\u044F
    \u0432 MIT \u0432 **1940 \u0433\u043E\u0434\u0443**, \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430
    \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 **\xAB\u0410\u043B\u0433\u0435\u0431\u0440\u0430
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043D\u0435\u0442\u0438\u043A\u0438\xBB**. \u0412 \u043D\u0435\u0439
    \u043E\u043D \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
