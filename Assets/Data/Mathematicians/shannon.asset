  personalLifeEn: 
  shortBioRu: "\u041A\u043B\u043E\u0434 \u042D\u043B\u0432\u0443\u0434 \u0428\u0435\u043D\u043D\u043E\u043D
    (1916\u20132001) \u2014 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438 \u0438\u043D\u0436\u0435\u043D\u0435\u0440,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \xAB\u043E\u0442\u0446\u043E\u043C \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0432\u0435\u043A\u0430\xBB. \u041E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
    \u0438 \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0439 \u0441\u0445\u0435\u043C\u043E\u0442\u0435\u0445\u043D\u0438\u043A\u0438,
    \u0431\u0435\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u0435\u043D
    \u043D\u0438 \u043E\u0434\u0438\u043D \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440 \u0438\u043B\u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u0430
    \u0441\u0432\u044F\u0437\u0438.  \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u0435\u0433\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F. 
    ### \U0001F9EC \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u044E\u043D\u043E\u0441\u0442\u044C:
    \u041C\u0438\u0447\u0438\u0433\u0430\u043D  \u041A\u043B\u043E\u0434 \u042D\u043B\u0432\u0443\u0434
    \u0428\u0435\u043D\u043D\u043E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    **30 \u0430\u043F\u0440\u0435\u043B\u044F 1916 \u0433\u043E\u0434\u0430** \u0432
    \u043A\u0443\u0440\u043E\u0440\u0442\u043D\u043E\u043C \u0433\u043E\u0440\u043E\u0434\u043A\u0435
    \u041F\u0435\u0442\u043E\u0446\u043A\u0438, \u0448\u0442\u0430\u0442 \u041C\u0438\u0447\u0438\u0433\u0430\u043D,
    \u043D\u043E \u0432\u044B\u0440\u043E\u0441 \u0432 \u0441\u043E\u0441\u0435\u0434\u043D\u0435\u043C
    \u0413\u044D\u0439\u043B\u043E\u0440\u0434\u0435. \u0415\u0433\u043E \u0441\u0435\u043C\u044C\u044F
    \u043F\u0440\u0438\u0432\u0438\u043B\u0430 \u0435\u043C\u0443 \u043B\u044E\u0431\u043E\u0432\u044C
    \u043A \u043D\u0430\u0443\u043A\u0435 \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443: 
    *   **\u041E\u0442\u0435\u0446**, \u041A\u043B\u043E\u0434 \u0428\u0435\u043D\u043D\u043E\u043D-\u0441\u0442\u0430\u0440\u0448\u0438\u0439
    (1862\u20131934), \u0431\u044B\u043B \u0431\u0438\u0437\u043D\u0435\u0441\u043C\u0435\u043D\u043E\u043C,
    \u0430\u0434\u0432\u043E\u043A\u0430\u0442\u043E\u043C \u0438 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u0441\u0443\u0434\u044C\u0435\u0439. \u041E\u043D
    \u043E\u0431\u043B\u0430\u0434\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0441\u043A\u043B\u0430\u0434\u043E\u043C \u0443\u043C\u0430 \u0438 \u043F\u043E\u043E\u0449\u0440\u044F\u043B
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F \u0441\u044B\u043D\u0430.
    *   **\u041C\u0430\u0442\u044C**, \u041C\u0435\u0439\u0431\u0435\u043B \u0412\u0443\u043B\u0444
    \u0428\u0435\u043D\u043D\u043E\u043D (1890\u20131945), \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0445 \u044F\u0437\u044B\u043A\u043E\u0432,
    \u0430 \u043F\u043E\u0437\u0436\u0435 \u0441\u0442\u0430\u043B\u0430 \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u0448\u043A\u043E\u043B\u044B, \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043F\u043E\u0441\u0435\u0449\u0430\u043B
    \u041A\u043B\u043E\u0434. *   **\u0414\u0435\u0434** \u043F\u043E \u043E\u0442\u0446\u043E\u0432\u0441\u043A\u043E\u0439
    \u043B\u0438\u043D\u0438\u0438 \u0431\u044B\u043B \u0444\u0435\u0440\u043C\u0435\u0440\u043E\u043C
    \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u0435\u043C,
    \u0441\u043E\u0437\u0434\u0430\u0432\u0448\u0438\u043C, \u0432 \u0442\u043E\u043C
    \u0447\u0438\u0441\u043B\u0435, \u0441\u0442\u0438\u0440\u0430\u043B\u044C\u043D\u0443\u044E
    \u043C\u0430\u0448\u0438\u043D\u0443. *   **\u0422\u043E\u043C\u0430\u0441 \u042D\u0434\u0438\u0441\u043E\u043D**
    \u0431\u044B\u043B \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0438\u043C
    \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u043C. 
    \u0412 \u044E\u043D\u043E\u0441\u0442\u0438 \u0428\u0435\u043D\u043D\u043E\u043D
    \u0431\u044B\u043B \u043D\u0435\u0443\u0442\u043E\u043C\u0438\u043C\u044B\u043C
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u0435\u043C:
    \u0441\u043E\u0431\u0438\u0440\u0430\u043B \u043C\u043E\u0434\u0435\u043B\u0438
    \u0441\u0430\u043C\u043E\u043B\u0435\u0442\u043E\u0432 \u0438 \u0440\u0430\u0434\u0438\u043E\u043F\u0440\u0438\u0435\u043C\u043D\u0438\u043A\u0438,
    \u0441\u043E\u0437\u0434\u0430\u043B \u0440\u0430\u0434\u0438\u043E\u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u043C\u0443\u044E
    \u043B\u043E\u0434\u043A\u0443 \u0438 \u0442\u0435\u043B\u0435\u0433\u0440\u0430\u0444\u043D\u0443\u044E
    \u043B\u0438\u043D\u0438\u044E \u0434\u043E \u0434\u043E\u043C\u0430 \u0434\u0440\u0443\u0433\u0430,
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043A\u0443\u0440\u044C\u0435\u0440\u043E\u043C
    Western Union. \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F
    \u0436\u043E\u043D\u0433\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0438 \u0435\u0437\u0434\u043E\u0439 \u043D\u0430 \u043E\u0434\u043D\u043E\u043A\u043E\u043B\u0435\u0441\u043D\u043E\u043C
    \u0432\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434\u0435.  ### \U0001F393
    \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u043C\u0430\u0433\u0438\u0441\u0442\u0435\u0440\u0441\u043A\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0432\u0435\u043A\u0430  \u0412 **1932
    \u0433\u043E\u0434\u0443** \u0428\u0435\u043D\u043D\u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u041C\u0438\u0447\u0438\u0433\u0430\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0432 **1936 \u0433\u043E\u0434\u0443** \u0441 \u0434\u0432\u0443\u043C\u044F
    \u0441\u0442\u0435\u043F\u0435\u043D\u044F\u043C\u0438 \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430
    \u2014 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u0442\u0435\u0445\u043D\u0438\u043A\u0435. 
    \u0417\u0430\u0442\u0435\u043C \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u041C\u0430\u0441\u0441\u0430\u0447\u0443\u0441\u0435\u0442\u0441\u043A\u0438\u0439
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 (MIT), \u0433\u0434\u0435 \u0441\u0442\u0430\u043B
    \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u043C \u0412\u044D\u043D\u0438\u0432\u0430\u0440\u0430
    \u0411\u0443\u0448\u0430 \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u0430\u0434
    \u0435\u0433\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C \u2014
    \u0430\u043D\u0430\u043B\u043E\u0433\u043E\u0432\u044B\u043C \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u043C.
    \u0410\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u0443\u044F \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u0440\u0435\u043B\u0435\u0439\u043D\u044B\u0435 \u0441\u0445\u0435\u043C\u044B,
    \u0428\u0435\u043D\u043D\u043E\u043D \u043E\u0441\u043E\u0437\u043D\u0430\u043B,
    \u0447\u0442\u043E \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u044B \u0431\u0443\u043B\u0435\u0432\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434\u044F\u0442 \u0434\u043B\u044F \u0438\u0445
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F.  \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C
    \u0441\u0442\u0430\u043B\u0430 \u0435\u0433\u043E \u043C\u0430\u0433\u0438\u0441\u0442\u0435\u0440\u0441\u043A\u0430\u044F
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F **\xAB\u0421\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0440\u0435\u043B\u0435\u0439\u043D\u044B\u0445
    \u0438 \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0441\u0445\u0435\u043C\xBB** (1937 \u0433\u043E\u0434, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430
    \u0432 1938-\u043C). \u0412 \u043D\u0435\u0439 \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043B\u044E\u0431\u0443\u044E \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0437\u0430\u0434\u0430\u0447\u0443 \u043C\u043E\u0436\u043D\u043E \u0440\u0435\u0448\u0438\u0442\u044C
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0446\u0435\u043F\u0435\u0439, \u0433\u0434\u0435 \xAB1\xBB \u2014 \u044D\u0442\u043E
    \xAB\u0432\u043A\u043B\u044E\u0447\u0435\u043D\u043E\xBB (\u0438\u0441\u0442\u0438\u043D\u0430),
    \u0430 \xAB0\xBB \u2014 \xAB\u0432\u044B\u043A\u043B\u044E\u0447\u0435\u043D\u043E\xBB
    (\u043B\u043E\u0436\u044C). \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432\u0441\u0435\u0445 \u0446\u0438\u0444\u0440\u043E\u0432\u044B\u0445 \u0441\u0445\u0435\u043C
    \u0438 \u0431\u044B\u043B\u0430 \u043D\u0430\u0437\u0432\u0430\u043D\u0430 **\xAB\u0441\u0430\u043C\u043E\u0439
    \u0437\u043D\u0430\u0447\u0438\u043C\u043E\u0439 \u043C\u0430\u0433\u0438\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0435\u0439 XX \u0432\u0435\u043A\u0430\xBB**. 
    ### \U0001F4A3 \u0412\u043E\u0435\u043D\u043D\u044B\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438  \u0412 **1940 \u0433\u043E\u0434\u0443**
    \u0428\u0435\u043D\u043D\u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0432
    MIT \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u0443 \xAB\u0410\u043B\u0433\u0435\u0431\u0440\u0430
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043D\u0435\u0442\u0438\u043A\u0438\xBB.  \u0412\u0435\u0441\u043D\u043E\u0439
    **1941 \u0433\u043E\u0434\u0430** \u043E\u043D \u043D\u0430\u0447\u0430\u043B
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 Bell Labs. \u0412 \u0433\u043E\u0434\u044B
    \u0412\u0442\u043E\u0440\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u043E\u043D \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F \u0437\u0435\u043D\u0438\u0442\u043D\u044B\u043C
    \u043E\u0433\u043D\u0435\u043C \u0438, \u0447\u0442\u043E \u0432\u0430\u0436\u043D\u0435\u0435,
    \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0435\u0439.
    \u0428\u0435\u043D\u043D\u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0448\u0438\u0444\u0440\u043E\u0432\u0430\u043D\u0438\u044F \u0434\u043B\u044F
    \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0441\u0432\u044F\u0437\u0438, \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435
    \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u0433\u043E\u0432\u043E\u0440\u043E\u0432
    \u0427\u0435\u0440\u0447\u0438\u043B\u043B\u044F \u0438 \u0420\u0443\u0437\u0432\u0435\u043B\u044C\u0442\u0430.
    \u0421\u0430\u043C \u043E\u043D \u0433\u043E\u0432\u043E\u0440\u0438\u043B, \u0447\u0442\u043E
    \u0438\u043C\u0435\u043D\u043D\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u0432
    \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u043F\u043E\u0434\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0430
    \u0435\u0433\u043E \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438.  ### \U0001F4E1
    \u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u043F\u0440\u043E\u0440\u044B\u0432:
    \u0442\u0435\u043E\u0440\u0438\u044F \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438 
    \u0412 **1948 \u0433\u043E\u0434\u0443** \u0428\u0435\u043D\u043D\u043E\u043D
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    **\xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0441\u0432\u044F\u0437\u0438\xBB** (A
    Mathematical Theory of Communication). \u041E\u043D\u0430 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B\u0430
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E, \u0440\u0430\u0437 \u0438
    \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u043E\u0442\u0434\u0435\u043B\u0438\u0432
    *\u0441\u043C\u044B\u0441\u043B* \u0441\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u044F
    \u043E\u0442 \u0435\u0433\u043E *\u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044F*. \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0438\u0434\u0435\u0438 \u044D\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u044B: 
    *   **\u041E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438**:
    \u0418\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F \u2014 \u044D\u0442\u043E
    \u043C\u0435\u0440\u0430 \u0441\u043D\u044F\u0442\u043E\u0439 \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0441\u0442\u0438.
    \u0415\u0435 \u043C\u043E\u0436\u043D\u043E \u0438\u0437\u043C\u0435\u0440\u044F\u0442\u044C,
    \u043D\u0435 \u043E\u0431\u0440\u0430\u0449\u0430\u044F \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u044F
    \u043D\u0430 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435. *  
    **\u0411\u0438\u0442**: \u041E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0441\u043B\u043E\u0432\u043E
    **\xAB\u0431\u0438\u0442\xBB** (binary digit) \u043A\u0430\u043A \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u0443\u044E
    \u0435\u0434\u0438\u043D\u0438\u0446\u0443 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438.
    *   **\u042D\u043D\u0442\u0440\u043E\u043F\u0438\u044F**: \u041E\u043D \u0432\u0432\u0435\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043C\u0435\u0440\u0443 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438, \u043D\u0430\u0437\u0432\u0430\u0432
    \u0435\u0435 **\u044D\u043D\u0442\u0440\u043E\u043F\u0438\u0435\u0439** (\u043F\u043E
    \u0441\u043E\u0432\u0435\u0442\u0443 \u0414\u0436\u043E\u043D\u0430 \u0444\u043E\u043D
    \u041D\u0435\u0439\u043C\u0430\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u043D\u0438\u043A\u0442\u043E
    \u0442\u043E\u043B\u043A\u043E\u043C \u043D\u0435 \u0437\u043D\u0430\u0435\u0442,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0442\u0430\u043A\u043E\u0435, \u0438
    \u044D\u0442\u043E \u0434\u0430\u0441\u0442 \u0428\u0435\u043D\u043D\u043E\u043D\u0443
    \u043F\u0440\u0435\u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u043E \u0432
    \u0441\u043F\u043E\u0440\u0430\u0445). *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0428\u0435\u043D\u043D\u043E\u043D\u0430**: \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0433\u043E \u0437\u0430\u0448\u0443\u043C\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u043A\u0430\u043D\u0430\u043B\u0430 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u0430\u044F \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C
    \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438,
    \u043A \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043C\u043E\u0436\u043D\u043E
    \u043F\u0440\u0438\u0431\u043B\u0438\u0437\u0438\u0442\u044C\u0441\u044F \u0441\u043A\u043E\u043B\u044C
    \u0443\u0433\u043E\u0434\u043D\u043E \u0431\u043B\u0438\u0437\u043A\u043E, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435 \u043A\u043E\u0434\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435,
    \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u0443\u044F \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C \u0441\u043A\u043E\u043B\u044C \u0443\u0433\u043E\u0434\u043D\u043E
    \u043C\u0430\u043B\u0443\u044E \u043E\u0448\u0438\u0431\u043A\u0443.  \u042D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E
    \u0441\u0434\u0435\u043B\u0430\u043B\u0430 \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u043C. 
    ### \U0001F916 \u0418\u0433\u0440\u044B, \u043C\u0430\u0448\u0438\u043D\u044B
    \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0443\u0440\u0430  \u0412 1950-\u0435
    \u0433\u043E\u0434\u044B \u0428\u0435\u043D\u043D\u043E\u043D, \u043F\u043E\u043C\u0438\u043C\u043E
    \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u044B,
    \u0441\u043E\u0437\u0434\u0430\u043B \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430: *   **\u041C\u0430\u0448\u0438\u043D\u0430
    \u0434\u043B\u044F \u0438\u0433\u0440\u044B \u0432 \u0448\u0430\u0445\u043C\u0430\u0442\u044B**:
    \u041E\u0434\u043D\u0430 \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u043E\u0433\u043B\u0438 \u0438\u0433\u0440\u0430\u0442\u044C
    \u0432 \u0448\u0430\u0445\u043C\u0430\u0442\u044B. *   **\u041C\u044B\u0448\u044C
    \xAB\u0422\u0435\u0441\u0435\u0439\xBB**: \u042D\u043B\u0435\u043A\u0442\u0440\u043E\u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043C\u044B\u0448\u044C, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043E\u0431\u0443\u0447\u0430\u043B\u0430\u0441\u044C
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C \u0432\u044B\u0445\u043E\u0434
    \u0438\u0437 \u043B\u0430\u0431\u0438\u0440\u0438\u043D\u0442\u0430, \u0437\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u044F
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0439 \u043F\u0443\u0442\u044C
    \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u0432 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0430. *   **\xAB\u041E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u043C\u0430\u0448\u0438\u043D\u0430\xBB**: \u041A\u043E\u0440\u043E\u0431\u043A\u0430
    \u0441 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0442\u0443\u043C\u0431\u043B\u0435\u0440\u043E\u043C. \u041F\u0440\u0438 \u0435\u0433\u043E
    \u0432\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0438 \u0438\u0437 \u043A\u043E\u0440\u043E\u0431\u043A\u0438
    \u0432\u044B\u0435\u0437\u0436\u0430\u043B\u0430 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0440\u0443\u043A\u0430, \u0432\u044B\u043A\u043B\u044E\u0447\u0430\u043B\u0430
    \u0442\u0443\u043C\u0431\u043B\u0435\u0440 \u0438 \u043F\u0440\u044F\u0442\u0430\u043B\u0430\u0441\u044C
    \u043E\u0431\u0440\u0430\u0442\u043D\u043E.  \u0412 **1956 \u0433\u043E\u0434\u0443**
    \u0428\u0435\u043D\u043D\u043E\u043D \u043F\u043E\u043A\u0438\u043D\u0443\u043B
    Bell Labs, \u0430 \u0441 **1957 \u0433\u043E\u0434\u0430** \u043D\u0430\u0447\u0430\u043B
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C \u0432 MIT.
    \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u043E\u043D
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F \u0434\u043E **1978 \u0433\u043E\u0434\u0430**.
    \u0412 \u044D\u0442\u0438 \u0433\u043E\u0434\u044B \u043E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0440\u0430\u0437\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043B \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430
    \u0434\u043B\u044F \u0438\u0433\u0440\u044B \u0432 \u0440\u0443\u043B\u0435\u0442\u043A\u0443,
    \u0442\u0435\u043E\u0440\u0438\u044E \u0436\u043E\u043D\u0433\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F,
    \u0441\u043E\u0437\u0434\u0430\u043B \u0440\u0430\u043A\u0435\u0442\u043D\u044B\u0439
    \u0444\u0440\u0438\u0441\u0431\u0438 \u0438 \u043C\u043E\u0442\u043E\u0440\u0438\u0437\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043F\u043E\u0433\u043E-\u0441\u0442\u0438\u043A.  ### \U0001F4D6 \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u041F\u043E\u0441\u043B\u0435 \u0443\u0445\u043E\u0434\u0430 \u0438\u0437 MIT
    \u0428\u0435\u043D\u043D\u043E\u043D \u043F\u043E\u0447\u0442\u0438 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B
    \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B, \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0432
    \u0441\u0435\u0431\u044F \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F\u043C
    \u0438 \u0445\u043E\u0431\u0431\u0438.  \u0412 **1985 \u0433\u043E\u0434\u0443**
    \u043E\u043D \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u043D\u0430 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u043C
    \u0441\u0438\u043C\u043F\u043E\u0437\u0438\u0443\u043C\u0435 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438 \u0432 \u0411\u0440\u0430\u0439\u0442\u043E\u043D\u0435,
    \u0433\u0434\u0435 \u0435\u0433\u043E \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u043D\u0435 \u0443\u0437\u043D\u0430\u043B\u0438. \u041D\u0430 \u0431\u0430\u043D\u043A\u0435\u0442\u0435
    \u043E\u043D \u043F\u043E\u0436\u043E\u043D\u0433\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0442\u0440\u0435\u043C\u044F \u043C\u044F\u0447\u0438\u043A\u0430\u043C\u0438
    \u0438 \u0440\u0430\u0437\u0434\u0430\u043B \u0441\u043E\u0442\u043D\u0438 \u0430\u0432\u0442\u043E\u0433\u0440\u0430\u0444\u043E\u0432
    \u2014 \u044D\u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442 \u0441\u0442\u0430\u043B
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u043C.  \u041A\u043B\u043E\u0434
    \u0428\u0435\u043D\u043D\u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    **24 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 2001 \u0433\u043E\u0434\u0430**
    \u0432 \u041C\u0435\u0434\u0444\u043E\u0440\u0434\u0435, \u0448\u0442\u0430\u0442
    \u041C\u0430\u0441\u0441\u0430\u0447\u0443\u0441\u0435\u0442\u0441, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    84 \u043B\u0435\u0442. \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u043E\u043D \u0441\u0442\u0440\u0430\u0434\u0430\u043B
    \u043E\u0442 \u0431\u043E\u043B\u0435\u0437\u043D\u0438 \u0410\u043B\u044C\u0446\u0433\u0435\u0439\u043C\u0435\u0440\u0430. 
    \u041E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u0432\u044B\u0441\u0448\u0438\u0445 \u043D\u0430\u0433\u0440\u0430\u0434, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0443\u044E \u043C\u0435\u0434\u0430\u043B\u044C
    \u043D\u0430\u0443\u043A\u0438 \u0421\u0428\u0410 (1966) \u0438 \u041A\u0438\u043E\u0442\u0441\u043A\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E (1985). \u0415\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C
    \u043D\u0430\u0437\u0432\u0430\u043D \u0430\u0441\u0442\u0435\u0440\u043E\u0438\u0434
    \u0438 \u0443\u0447\u0440\u0435\u0436\u0434\u0435\u043D\u0430 \u043F\u0440\u0435\u043C\u0438\u044F
    IEEE \u0437\u0430 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438."
  shortBioEn: 
  interestingFactsRu: "\u041A\u043B\u043E\u0434 \u0428\u0435\u043D\u043D\u043E\u043D
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C, \u043D\u043E \u0438 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u043C
    \u0432\u044B\u0434\u0443\u043C\u0449\u0438\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B \u0441\u0432\u043E\u044E
    \u0436\u0438\u0437\u043D\u044C \u0432 \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0438\u0433\u0440\u0443. \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0435 \u0444\u0430\u043A\u0442\u044B
    \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438. 
    ### \U0001F939 \xAB\u0411\u0435\u0441\u043F\u043E\u043B\u0435\u0437\u043D\u0430\u044F
    \u043C\u0430\u0448\u0438\u043D\u0430\xBB \u0438 \u043A\u043E\u0440\u043E\u043B\u044C
    \u0433\u0430\u0434\u0436\u0435\u0442\u043E\u0432  \u0428\u0435\u043D\u043D\u043E\u043D
    \u043E\u0431\u043E\u0436\u0430\u043B \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u044C
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430, \u043B\u0438\u0448\u0435\u043D\u043D\u044B\u0435
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043C\u044B\u0441\u043B\u0430. \u0421\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0435\u0433\u043E \u0438\u0433\u0440\u0443\u0448\u043A\u0430 \u2014 **\xAB\u041E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u043C\u0430\u0448\u0438\u043D\u0430\xBB** (Ultimate Machine): \u044D\u0442\u043E
    \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0430\u044F \u043A\u043E\u0440\u043E\u0431\u043A\u0430
    \u0441 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0442\u0435\u043B\u0435\u043C.
    \u041A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E \u0432\u043A\u043B\u044E\u0447\u0430\u043B\u0438,
    \u0432\u043D\u0443\u0442\u0440\u0438 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u043B\u0430\u0441\u044C
    \u043A\u0440\u044B\u0448\u043A\u0430, \u043E\u0442\u0442\u0443\u0434\u0430 \u0432\u044B\u0435\u0437\u0436\u0430\u043B\u0430
    \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0440\u0443\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0432\u044B\u043A\u043B\u044E\u0447\u0430\u043B\u0430
    \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0442\u0435\u043B\u044C
    \u0438 \u043F\u0440\u044F\u0442\u0430\u043B\u0430\u0441\u044C \u043E\u0431\u0440\u0430\u0442\u043D\u043E.
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u0447\u0438\u0441\u0442\u043E\u0435
    \u0432\u043E\u043F\u043B\u043E\u0449\u0435\u043D\u0438\u0435 \u044E\u043C\u043E\u0440\u0430
    \u0438 \u043B\u044E\u0431\u0432\u0438 \u043A \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435. 
    \u0415\u0433\u043E \u0434\u043E\u043C \u043D\u0430 \u043E\u0437\u0435\u0440\u0435
    \u041C\u0438\u0441\u0442\u0438\u043A \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C
    \u043C\u0443\u0437\u0435\u0435\u043C \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u0432.
    \u0422\u0430\u043C \u043C\u043E\u0436\u043D\u043E \u0431\u044B\u043B\u043E \u0443\u0432\u0438\u0434\u0435\u0442\u044C:
    *   \u0420\u043E\u0431\u043E\u0442\u0430-\u0436\u043E\u043D\u0433\u043B\u0435\u0440\u0430,
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0433\u043E \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0442\u044C
    \u0432 \u0432\u043E\u0437\u0434\u0443\u0445\u0435 \u043F\u044F\u0442\u044C \u043C\u044F\u0447\u0435\u0439.
    *   \u0414\u0432\u0443\u0445\u043C\u0435\u0441\u0442\u043D\u044B\u0439 \u043E\u0434\u043D\u043E\u043A\u043E\u043B\u0435\u0441\u043D\u044B\u0439
    \u0432\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043E\u043D \u043A\u0430\u0442\u0430\u043B\u0441\u044F \u0441 \u0436\u0435\u043D\u043E\u0439.
    *   \u041A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440 **THROBAC I**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u043B \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F \u0432 \u0440\u0438\u043C\u0441\u043A\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435 \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F.
    *   \u041C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0430\u043B\u0435\u0446 \u043D\u0430 \u043A\u0443\u0445\u043D\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u043C\u043E\u0436\u043D\u043E \u0431\u044B\u043B\u043E \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0442\u044C
    \u0438\u0437 \u043F\u043E\u0434\u0432\u0430\u043B\u0430. *   \u041E\u0433\u043D\u0435\u043C\u0435\u0442\u043D\u0443\u044E
    \u0442\u0440\u0443\u0431\u0443 \u0438 \u043F\u0440\u0443\u0436\u0438\u043D\u043D\u044B\u0439
    \u0448\u0435\u0441\u0442 \u0441 \u0431\u0435\u043D\u0437\u0438\u043D\u043E\u0432\u044B\u043C
    \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u0435\u043C.  ### \U0001F3B0
    \u041F\u043E\u0431\u0435\u0433 \u0432 \u041B\u0430\u0441-\u0412\u0435\u0433\u0430\u0441:
    \u043F\u0435\u0440\u0432\u044B\u0439 \u043D\u043E\u0441\u0438\u043C\u044B\u0439
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440  \u0412 1960-\u0445 \u0433\u043E\u0434\u0430\u0445
    \u0428\u0435\u043D\u043D\u043E\u043D \u0432\u043C\u0435\u0441\u0442\u0435 \u0441
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u042D\u0434\u0432\u0430\u0440\u0434\u043E\u043C
    \u0422\u043E\u0440\u043F\u043E\u043C \u0437\u0430\u0434\u0443\u043C\u0430\u043B
    \u043E\u0431\u044B\u0433\u0440\u0430\u0442\u044C \u0440\u0443\u043B\u0435\u0442\u043A\u0443
    \u0432 \u041B\u0430\u0441-\u0412\u0435\u0433\u0430\u0441\u0435. \u041E\u043D\u0438
    \u0441\u043E\u0437\u0434\u0430\u043B\u0438, \u043F\u043E \u0441\u0443\u0442\u0438,
    **\u043F\u0435\u0440\u0432\u044B\u0439 \u0432 \u043C\u0438\u0440\u0435 \u043D\u043E\u0441\u0438\u043C\u044B\u0439
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440**, \u0447\u0442\u043E\u0431\u044B
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C,
    \u0432 \u043A\u0430\u043A\u043E\u043C \u0441\u0435\u043A\u0442\u043E\u0440\u0435
    \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u0448\u0430\u0440\u0438\u043A. 
    *   **\u0423\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E**: \u0420\u0430\u0437\u043C\u0435\u0440\u043E\u043C
    \u0441 \u043F\u0430\u0447\u043A\u0443 \u0441\u0438\u0433\u0430\u0440\u0435\u0442,
    \u0435\u0433\u043E \u043F\u0440\u044F\u0442\u0430\u043B\u0438 \u0432 \u043E\u0431\u0443\u0432\u0438,
    \u0430 \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u043B\u0438 \u0438\u043C \u0441
    \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043D\u0430\u0436\u0430\u0442\u0438\u0439
    \u043F\u0430\u043B\u044C\u0446\u0430\u043C\u0438 \u043D\u043E\u0433. *   **\u0421\u0435\u043A\u0440\u0435\u0442\u043D\u0430\u044F
    \u0441\u0432\u044F\u0437\u044C**: \u041A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440
    \u043F\u043E\u0434\u0430\u0432\u0430\u043B \u0441\u0438\u0433\u043D\u0430\u043B\u044B
    \u0447\u0435\u0440\u0435\u0437 \u043A\u0440\u043E\u0448\u0435\u0447\u043D\u044B\u0439
    \u0434\u0438\u043D\u0430\u043C\u0438\u043A \u0432 \u0443\u0445\u0435. \u041F\u0440\u043E\u0432\u043E\u0434\u0430
    \u0431\u044B\u043B\u0438 \u0432\u044B\u043A\u0440\u0430\u0448\u0435\u043D\u044B
    \u0432 \u0446\u0432\u0435\u0442 \u043A\u043E\u0436\u0438 \u0438 \u043F\u0440\u0438\u043A\u043B\u0435\u0435\u043D\u044B
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C \u0433\u0440\u0438\u043C\u043E\u043C,
    \u0447\u0442\u043E\u0431\u044B \u0438\u0445 \u043D\u0435 \u0431\u044B\u043B\u043E
    \u0432\u0438\u0434\u043D\u043E. *   **\u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442**:
    \u0423\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u043E,
    \u0434\u0430\u0432\u0430\u044F \u043F\u0440\u0435\u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u043E
    \u043D\u0430\u0434 \u043A\u0430\u0437\u0438\u043D\u043E. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0434\u0443\u044D\u0442 \u043F\u0440\u0435\u043A\u0440\u0430\u0442\u0438\u043B
    \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u044F, \u0438\u0441\u043F\u0443\u0433\u0430\u0432\u0448\u0438\u0441\u044C
    \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u0441\u043B\u0443\u0436\u0431
    \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438 \u0438
    \u043C\u0430\u0444\u0438\u0438. \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u0434\u0438\u043D\u0430\u043C\u0438\u043A
    \u0422\u043E\u0440\u043F\u0430 \u0432\u044B\u043F\u0430\u043B \u0438\u0437 \u0443\u0445\u0430
    \u043D\u0430 \u0432\u0438\u0434\u0443 \u0443 \u0432\u0441\u0435\u0445, \u0447\u0442\u043E
    \u0435\u0434\u0432\u0430 \u043D\u0435 \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u043A \u0440\u0430\u0437\u043E\u0431\u043B\u0430\u0447\u0435\u043D\u0438\u044E. 
    ### \U0001F3AA \u041D\u0430\u0443\u043A\u0430 \u0438 \u0446\u0438\u0440\u043A
    \u043D\u0430 \u043E\u0434\u043D\u043E\u0439 \u0434\u043E\u0440\u043E\u0436\u043A\u0435 
    \u0423\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F \u0428\u0435\u043D\u043D\u043E\u043D\u0430
    \u0431\u044B\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0438\u043B\u044C\u043D\u044B, \u0447\u0442\u043E \u043F\u0440\u043E\u043D\u0438\u0437\u044B\u0432\u0430\u043B\u0438
    \u0432\u0441\u044E \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C. *   **\u0416\u043E\u043D\u0433\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435**:
    \u041E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0436\u043E\u043D\u0433\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0435 \u0432 Bell Labs, \u043D\u043E
    \u0438 \u0441\u043E\u0437\u0434\u0430\u043B **\u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u0436\u043E\u043D\u0433\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F**,
    \u0432\u044B\u0432\u043E\u0434\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0439. \u041E\u043D \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0436\u043E\u043D\u0433\u043B\u0438\u0440\u0443\u044E\u0449\u0438\u0445
    \u043C\u0430\u0448\u0438\u043D, \u043D\u043E \u0441\u0430\u043C \u0442\u0430\u043A
    \u0438 \u043D\u0435 \u0441\u043C\u043E\u0433 \u043F\u0440\u0435\u0432\u0437\u043E\u0439\u0442\u0438
    \u0440\u0435\u043A\u043E\u0440\u0434 \u0432 \u0447\u0435\u0442\u044B\u0440\u0435
    \u043C\u044F\u0447\u0430. *   **\u0423\u043D\u0438\u0446\u0438\u043A\u043B**:
    \u0428\u0435\u043D\u043D\u043E\u043D\u0430 \u0447\u0430\u0441\u0442\u043E \u043C\u043E\u0436\u043D\u043E
    \u0431\u044B\u043B\u043E \u0443\u0432\u0438\u0434\u0435\u0442\u044C \u0440\u0430\u0437\u044A\u0435\u0437\u0436\u0430\u044E\u0449\u0438\u043C
    \u043F\u043E \u043A\u043E\u0440\u0438\u0434\u043E\u0440\u0430\u043C \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430 \u043E\u0434\u043D\u043E\u043A\u043E\u043B\u0435\u0441\u043D\u043E\u043C
    \u0432\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434\u0435 \u2014 \u0438 \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C \u0436\u043E\u043D\u0433\u043B\u0438\u0440\u0443\u044E\u0449\u0438\u043C. 
    ### \U0001F9E9 \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u0448\u0443\u0442\u043A\u0438
    \u0438 \u0432\u0441\u0442\u0440\u0435\u0447\u0438  *   **\xAB\u042D\u043D\u0442\u0440\u043E\u043F\u0438\u044F\xBB
    \u043E\u0442 \u0444\u043E\u043D \u041D\u0435\u0439\u043C\u0430\u043D\u0430**:
    \u0421\u0430\u043C\u043E\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435
    \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \"\u043A\u0443\u0440\u0451\u0437\u043D\u043E\u0435\"
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435. \u0428\u0435\u043D\u043D\u043E\u043D
    \u0445\u043E\u0442\u0435\u043B \u043D\u0430\u0437\u0432\u0430\u0442\u044C \u043C\u0435\u0440\u0443
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438 \"\u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0441\u0442\u044C\u044E\",
    \u043D\u043E \u0414\u0436\u043E\u043D \u0444\u043E\u043D \u041D\u0435\u0439\u043C\u0430\u043D
    \u043F\u043E\u0441\u043E\u0432\u0435\u0442\u043E\u0432\u0430\u043B \u043D\u0430\u0437\u0432\u0430\u0442\u044C
    \u0435\u0451 \"\u044D\u043D\u0442\u0440\u043E\u043F\u0438\u0435\u0439\". \u0412\u043E-\u043F\u0435\u0440\u0432\u044B\u0445,
    \u044D\u0442\u043E\u0442 \u0442\u0435\u0440\u043C\u0438\u043D \u0443\u0436\u0435
    \u0431\u044B\u043B \u0432 \u0444\u0438\u0437\u0438\u043A\u0435, \u0430 \u0432\u043E-\u0432\u0442\u043E\u0440\u044B\u0445,
    **\"\u043D\u0438\u043A\u0442\u043E \u0442\u043E\u043B\u043A\u043E\u043C \u043D\u0435
    \u0437\u043D\u0430\u0435\u0442, \u0447\u0442\u043E \u0442\u0430\u043A\u043E\u0435
    \u044D\u043D\u0442\u0440\u043E\u043F\u0438\u044F, \u0438 \u044D\u0442\u043E \u0434\u0430\u0441\u0442
    \u0432\u0430\u043C \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u043F\u0440\u0435\u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u043E
    \u0432 \u0441\u043F\u043E\u0440\u0430\u0445\"**.  *   **\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0432 \u0411\u0440\u0430\u0439\u0442\u043E\u043D**: \u0412 1985 \u0433\u043E\u0434\u0443
    \u0428\u0435\u043D\u043D\u043E\u043D, \u0443\u0436\u0435 \u0434\u0430\u0432\u043D\u043E
    \u043D\u0435 \u043F\u043E\u044F\u0432\u043B\u044F\u0432\u0448\u0438\u0439\u0441\u044F
    \u043D\u0430 \u043F\u0443\u0431\u043B\u0438\u043A\u0435, \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E
    \u043F\u0440\u0438\u0435\u0445\u0430\u043B \u043D\u0430 \u043A\u043E\u043D\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u044E
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
    \u0432 \u0411\u0440\u0430\u0439\u0442\u043E\u043D. \u041F\u043E\u043D\u0430\u0447\u0430\u043B\u0443
    \u0435\u0433\u043E \u043D\u0438\u043A\u0442\u043E \u043D\u0435 \u0443\u0437\u043D\u0430\u043B.
    \u041D\u0430 \u0431\u0430\u043D\u043A\u0435\u0442\u0435 \u043E\u043D \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441
    \u043A\u043E\u0440\u043E\u0442\u043A\u0443\u044E \u0440\u0435\u0447\u044C, \u0437\u0430\u0442\u0435\u043C
    \u0432\u0441\u0442\u0430\u043B \u0438 \u043D\u0430\u0447\u0430\u043B \u0436\u043E\u043D\u0433\u043B\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0442\u0440\u0435\u043C\u044F \u043C\u044F\u0447\u0430\u043C\u0438. \u041F\u043E\u0441\u043B\u0435
    \u044D\u0442\u043E\u0433\u043E \u0441\u043E\u0442\u043D\u0438 \u0443\u0447\u0435\u043D\u044B\u0445
    \u0432\u044B\u0441\u0442\u0440\u043E\u0438\u043B\u0438\u0441\u044C \u0432 \u043E\u0447\u0435\u0440\u0435\u0434\u044C
    \u0437\u0430 \u0435\u0433\u043E \u0430\u0432\u0442\u043E\u0433\u0440\u0430\u0444\u043E\u043C,
    \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u044F \u044D\u0442\u043E \u0447\u0443\u0432\u0441\u0442\u0432\u043E
    \u0441 \u0442\u0435\u043C, \u0435\u0441\u043B\u0438 \u0431\u044B \u043D\u0430
    \u0438\u0445 \u043A\u043E\u043D\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u044E
    \u044F\u0432\u0438\u043B\u0441\u044F \u0441\u0430\u043C \u0418\u0441\u0430\u0430\u043A
    \u041D\u044C\u044E\u0442\u043E\u043D.  ### \U0001F4DA \u0418\u0442\u043E\u0433 
    \u0416\u0438\u0437\u043D\u044C \u041A\u043B\u043E\u0434\u0430 \u0428\u0435\u043D\u043D\u043E\u043D\u0430
    \u2014 \u044D\u0442\u043E \u044F\u0440\u043A\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439
    \u0433\u0435\u043D\u0438\u0439 \u043D\u0435 \u0437\u0430\u043C\u044B\u043A\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0440\u0430\u043C\u043A\u0430\u0445 \u043E\u0434\u043D\u043E\u0439 \u043D\u0430\u0443\u043A\u0438.
    \u041E\u043D \u0443\u043C\u0435\u043B \u0432\u0438\u0434\u0435\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0432 \u0436\u043E\u043D\u0433\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438,
    \u0442\u0435\u043E\u0440\u0438\u044E \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439
    \u0432 \u0440\u0443\u043B\u0435\u0442\u043A\u0435 \u0438 \u043B\u043E\u0433\u0438\u043A\u0443
    \u0432 \u0441\u0430\u043C\u044B\u0445 \u0431\u0435\u0437\u0443\u043C\u043D\u044B\u0445
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u0430\u0445, \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u044F
    \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u0443\u044E \u043D\u0430\u0443\u043A\u0443
    \u0432 \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u0435
    \u043F\u0440\u0438\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435."
