    \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F, \u043E\u043D\u0430
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0430 \u0435\u0433\u043E \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0443\u044E
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u043D\u0430 \u0441\u0442\u044B\u043A\u0435 \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D. 
    ### \U0001F52C \u0420\u0430\u0431\u043E\u0442\u0430 \u0438 \u0412\u0437\u0430\u0438\u043C\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
