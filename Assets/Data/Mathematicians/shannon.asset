    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0428\u0435\u043D\u043D\u043E\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0442\u0435\u0441\u043D\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u0430
    \u0441 \u0434\u0432\u0443\u043C\u044F \u043C\u0435\u0441\u0442\u0430\u043C\u0438. 
    **1. Bell Labs (1941\u20131956):** \u0412\u0435\u0441\u043D\u043E\u0439 **1941
    \u0433\u043E\u0434\u0430** \u0428\u0435\u043D\u043D\u043E\u043D \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 Bell Labs, \u0433\u0434\u0435 \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0434\u043E 1956 \u0433\u043E\u0434\u0430. \u0412 \u0433\u043E\u0434\u044B \u0412\u0442\u043E\u0440\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B \u043E\u043D
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0437\u0435\u043D\u0438\u0442\u043D\u044B\u043C \u043E\u0433\u043D\u0435\u043C
    \u0438, \u0447\u0442\u043E \u0432\u0430\u0436\u043D\u0435\u0435, \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0435\u0439.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u0432 \u044D\u0442\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043F\u0440\u0438\u0432\u0435\u043B\u0430
    \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0448\u0438\u0444\u0440\u043E\u0432\u0430\u043D\u0438\u044F.  \u041E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0437\u043D\u0430\u043A\u043E\u0432\u044B\u0445
    \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u0432 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438
    \u0441\u0442\u0430\u043B\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u0432
    **1943 \u0433\u043E\u0434\u0443** \u0441 \u0410\u043B\u0430\u043D\u043E\u043C
    \u0422\u044C\u044E\u0440\u0438\u043D\u0433\u043E\u043C. \u0422\u044C\u044E\u0440\u0438\u043D\u0433
    \u0431\u044B\u043B \u0432 \u0412\u0430\u0448\u0438\u043D\u0433\u0442\u043E\u043D\u0435,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0434\u0435\u043B\u0438\u0442\u044C\u0441\u044F
    \u0441 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u043C\u0438
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438 \u043C\u0435\u0442\u043E\u0434\u0430\u043C\u0438
    \u0432\u0437\u043B\u043E\u043C\u0430 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0445
    \u0448\u0438\u0444\u0440\u043E\u0432. \u041E\u043D\u0438 \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B\u0438\u0441\u044C
    \u0432 \u0441\u0442\u043E\u043B\u043E\u0432\u043E\u0439 Bell Labs \u0438 \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u043B\u0438
    \u0441\u0432\u043E\u0438 \u0438\u0434\u0435\u0438. \u0422\u044C\u044E\u0440\u0438\u043D\u0433
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B \u0428\u0435\u043D\u043D\u043E\u043D\u0443
    \u0441\u0432\u043E\u044E \u0440\u0430\u0431\u043E\u0442\u0443 \u043E \xAB\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0439
    \u043C\u0430\u0448\u0438\u043D\u0435 \u0422\u044C\u044E\u0440\u0438\u043D\u0433\u0430\xBB,
    \u0447\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u043E \u043D\u0430
    \u0428\u0435\u043D\u043D\u043E\u043D\u0430 \u0431\u043E\u043B\u044C\u0448\u043E\u0435
    \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u0438\u0435.  \u0412 **1948
    \u0433\u043E\u0434\u0443** \u0428\u0435\u043D\u043D\u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 **\xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0441\u0432\u044F\u0437\u0438\xBB**, \u0433\u0434\u0435
    \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\xAB\u0431\u0438\u0442\xBB**
    \u043A\u0430\u043A \u0435\u0434\u0438\u043D\u0438\u0446\u0443 \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438 \u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438. 
    **2. MIT (1956\u20131978):** \u0421 **1956 \u0433\u043E\u0434\u0430** \u0428\u0435\u043D\u043D\u043E\u043D
    \u043D\u0430\u0447\u0430\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C
    \u0432 MIT, \u0430 \u0441 1957 \u0433\u043E\u0434\u0430 \u0441\u0442\u0430\u043B
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C. \u041E\u043D
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    Bell Labs, \u043D\u043E \u043E\u0441\u043D\u043E\u0432\u043D\u0430\u044F \u0435\u0433\u043E
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0431\u044B\u043B\u0430
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u043E\u043C.
    \u0412 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D
    \u043C\u043D\u043E\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u0430\u0434
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430\u043C\u0438 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0430, \u0441\u043E\u0437\u0434\u0430\u043B
    \u0448\u0430\u0445\u043C\u0430\u0442\u043D\u044B\u0439 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440
    \u0438 \u043E\u0431\u0443\u0447\u0430\u0435\u043C\u0443\u044E \u043C\u044B\u0448\u044C
    \xAB\u0422\u0435\u0441\u0435\u0439\xBB.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466
    \u041B\u0438\u0447\u043D\u0430\u044F \u0416\u0438\u0437\u043D\u044C \u0438 \u0425\u043E\u0431\u0431\u0438 
    \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u0428\u0435\u043D\u043D\u043E\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0441\u0442\u043E\u043B\u044C \u0436\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u0430,
    \u043A\u0430\u043A \u0438 \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430. \u041E\u043D \u0431\u044B\u043B \u0434\u0432\u0430\u0436\u0434\u044B
    \u0436\u0435\u043D\u0430\u0442:  *   **\u041F\u0435\u0440\u0432\u044B\u0439 \u0431\u0440\u0430\u043A**
    \u0441 \u041D\u043E\u0440\u043C\u043E\u0439 \u041B\u0435\u0432\u043E\u0440 \u0431\u044B\u043B
    \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D \u0432 1940 \u0433\u043E\u0434\u0443,
    \u043D\u043E \u043F\u0440\u043E\u0434\u043B\u0438\u043B\u0441\u044F \u0432\u0441\u0435\u0433\u043E
    \u043E\u043A\u043E\u043B\u043E \u0433\u043E\u0434\u0430 \u0438 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B\u0441\u044F
    \u0440\u0430\u0437\u0432\u043E\u0434\u043E\u043C. *   **\u0412\u0442\u043E\u0440\u043E\u0439
    \u0431\u0440\u0430\u043A** \u0441 **\u041C\u044D\u0440\u0438 \u042D\u043B\u0438\u0437\u0430\u0431\u0435\u0442
    \xAB\u0411\u0435\u0442\u0442\u0438\xBB \u041C\u0443\u0440** \u0431\u044B\u043B
    \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D \u0432 **1949 \u0433\u043E\u0434\u0443**.
    \u0411\u0435\u0442\u0442\u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430
    \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u043C \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u043A\u043E\u043C
    \u0432 Bell Labs \u0438 \u0447\u0430\u0441\u0442\u043E \u043F\u043E\u043C\u043E\u0433\u0430\u043B\u0430
    \u0428\u0435\u043D\u043D\u043E\u043D\u0443 \u0432 \u0435\u0433\u043E \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F\u0445.
    \u0423 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0442\u0440\u043E\u0435
    \u0434\u0435\u0442\u0435\u0439: \u0441\u044B\u043D\u043E\u0432\u044C\u044F \u0420\u043E\u0431\u0435\u0440\u0442,
    \u0414\u0436\u0435\u0439\u043C\u0441, \u042D\u043D\u0434\u0440\u044E \u041C\u0443\u0440
    \u0438 \u0434\u043E\u0447\u044C \u041C\u0430\u0440\u0433\u0430\u0440\u0438\u0442\u0430. 
    \u0417\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438 \u043D\u0430\u0443\u043A\u0438
    \u0428\u0435\u043D\u043D\u043E\u043D \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0441\u0432\u043E\u0438\u043C\u0438 \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u043C\u0438
    \u0445\u043E\u0431\u0431\u0438. \u041E\u043D \u043B\u044E\u0431\u0438\u043B **\u0436\u043E\u043D\u0433\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435**
    \u0438 **\u0435\u0437\u0434\u0443 \u043D\u0430 \u043E\u0434\u043D\u043E\u043A\u043E\u043B\u0435\u0441\u043D\u043E\u043C
    \u0432\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434\u0435**, \u043F\u0440\u0438\u0447\u0435\u043C
    \u0447\u0430\u0441\u0442\u043E \u0434\u0435\u043B\u0430\u043B \u044D\u0442\u043E
    \u043F\u0440\u044F\u043C\u043E \u0432 \u043A\u043E\u0440\u0438\u0434\u043E\u0440\u0430\u0445
    Bell Labs \u0438 MIT. \u041E\u043D \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **\xAB\u0411\u0435\u0441\u043F\u043E\u043B\u0435\u0437\u043D\u0443\u044E
    \u043C\u0430\u0448\u0438\u043D\u0443\xBB** (Ultimate Machine), \u0440\u0430\u043A\u0435\u0442\u043D\u044B\u0439
    \u043B\u0435\u0442\u0430\u044E\u0449\u0438\u0439 \u0434\u0438\u0441\u043A, \u043C\u043E\u0442\u043E\u0440\u0438\u0437\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043F\u043E\u0433\u043E-\u0441\u0442\u0438\u043A \u0438 \u0434\u0430\u0436\u0435
    \u0434\u0432\u0443\u0445\u043C\u0435\u0441\u0442\u043D\u044B\u0439 \u043E\u0434\u043D\u043E\u043A\u043E\u043B\u0435\u0441\u043D\u044B\u0439
    \u0432\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434.  \u0412\u043C\u0435\u0441\u0442\u0435
    \u0441 \u0436\u0435\u043D\u043E\u0439 \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438
    \u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043B
    \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u0438 \u0434\u043B\u044F \u0438\u0433\u0440\u044B
    \u0432 \u0431\u043B\u044D\u043A\u0434\u0436\u0435\u043A \u0438 \u0434\u0430\u0436\u0435
    \u0441\u043E\u0437\u0434\u0430\u043B \u043E\u0434\u0438\u043D \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u043D\u043E\u0441\u0438\u043C\u044B\u0445 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u0432
    \u0434\u043B\u044F \u043F\u043E\u0434\u0441\u0447\u0435\u0442\u0430 \u043A\u0430\u0440\u0442. 
    ### \U0001F9D3 \u0421\u043C\u0435\u0440\u0442\u044C \u0438 \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u041A\u043B\u043E\u0434 \u0428\u0435\u043D\u043D\u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    **24 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 2001 \u0433\u043E\u0434\u0430**
    \u0432 \u041C\u0435\u0434\u0444\u043E\u0440\u0434\u0435, \u0448\u0442\u0430\u0442
    \u041C\u0430\u0441\u0441\u0430\u0447\u0443\u0441\u0435\u0442\u0441, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    84 \u043B\u0435\u0442. \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438
    \u043E\u043D \u0441\u0442\u0440\u0430\u0434\u0430\u043B \u043E\u0442 \u0431\u043E\u043B\u0435\u0437\u043D\u0438
    \u0410\u043B\u044C\u0446\u0433\u0435\u0439\u043C\u0435\u0440\u0430 \u0438 \u043F\u0440\u043E\u0432\u0435\u043B
    \u0441\u0432\u043E\u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0432 \u0434\u043E\u043C\u0435 \u043F\u0440\u0435\u0441\u0442\u0430\u0440\u0435\u043B\u044B\u0445. 
    \u041E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043F\u043E\u0441\u043B\u0435
    \u0441\u0435\u0431\u044F \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B, \u0430 \u0446\u0435\u043B\u0443\u044E \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u0443\u044E
    \u0438\u0434\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438
    \u043C\u0438\u0440. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438
    \u0441\u0442\u0430\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0439 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438,
    \u0430 \u0435\u0433\u043E \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434 \u043A \u0436\u0438\u0437\u043D\u0438 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u0435\u0442
    \u0443\u0447\u0435\u043D\u044B\u0445 \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u0435\u0439
    \u043F\u043E \u0441\u0435\u0439 \u0434\u0435\u043D\u044C.  ### \u0420\u0435\u0437\u044E\u043C\u0435
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u0441\u043E\u0431\u044B\u0442\u0438\u0439
