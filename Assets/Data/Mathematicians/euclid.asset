  achievementsRu: "\u0413\u043E\u0432\u043E\u0440\u0438\u0442\u044C \u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u0445
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u2014 \u0437\u043D\u0430\u0447\u0438\u0442
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043E \u043D\u0430\u0431\u043E\u0440\u0435 \u0442\u0435\u043E\u0440\u0435\u043C,
    \u0430 \u043E **\u0441\u043C\u0435\u043D\u0435 \u043F\u0430\u0440\u0430\u0434\u0438\u0433\u043C\u044B**
    \u0432 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u043C
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0438. \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F
    \u043D\u0435 \u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0432 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0438
    \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0445 \u0444\u043E\u0440\u043C\u0443\u043B
    (\u043C\u043D\u043E\u0433\u0438\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u0434\u043E \u043D\u0435\u0433\u043E), \u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0432 **\u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043A\u0430\u043A \u0441\u0442\u0440\u043E\u0433\u043E\u0439 \u0434\u0435\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438** \u0438 \u043C\u0435\u0442\u043E\u0434\u043E\u043B\u043E\u0433\u0438\u0438
    \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u044F.   \u0427\u0442\u043E\u0431\u044B
    \u043E\u0442\u0432\u0435\u0442 \u0431\u044B\u043B \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u043C, \u0440\u0430\u0437\u0431\u0435\u0440\u0435\u043C
    \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043F\u043E \u0442\u0440\u0435\u043C \u0443\u0440\u043E\u0432\u043D\u044F\u043C:
    **\u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442**, **\u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430** \u0438 **\u043C\u0435\u0436\u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0430\u0440\u043D\u044B\u0435
    \u043D\u0430\u0443\u043A\u0438**.  ### 1. \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u0432 \u043C\u0435\u0442\u043E\u0434\u0435: \u0410\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u043A\u043E-\u0434\u0435\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u0430\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430 (\u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434)  \u0414\u043E \u0415\u0432\u043A\u043B\u0438\u0434\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0431\u044B\u043B\u0430
    \u043D\u0430\u0431\u043E\u0440\u043E\u043C \u044D\u043C\u043F\u0438\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0430\u0432\u0438\u043B (\u043A\u0430\u043A \u0443 \u0435\u0433\u0438\u043F\u0442\u044F\u043D
    \u0438\u043B\u0438 \u0432\u0430\u0432\u0438\u043B\u043E\u043D\u044F\u043D) \u0438
    \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0447\u0438\u0441\u0435\u043B
    (\u043A\u0430\u043A \u0443 \u043F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u0435\u0432).
    \u0415\u0432\u043A\u043B\u0438\u0434 \u0441\u043E\u0437\u0434\u0430\u043B **\xAB\u0447\u0438\u0441\u0442\u0443\u044E\xBB
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E**, \u0433\u0434\u0435
    \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0441\u0442\u044C \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0439
    \u043D\u0435 \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u043E\u0442 \u043E\u043F\u044B\u0442\u0430,
    \u0430 \u0432\u044B\u0442\u0435\u043A\u0430\u0435\u0442 \u0438\u0437 \u043B\u043E\u0433\u0438\u043A\u0438. 
    -   **\u0418\u0435\u0440\u0430\u0440\u0445\u0438\u044F \u0437\u043D\u0430\u043D\u0438\u0439:**
    \u041E\u043D \u0432\u0432\u0435\u043B \u0436\u0435\u0441\u0442\u043A\u0443\u044E
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0443: **\u041E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u2192 \u0410\u043A\u0441\u0438\u043E\u043C\u044B (\u041E\u0431\u0449\u0438\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F) \u2192 \u041F\u043E\u0441\u0442\u0443\u043B\u0430\u0442\u044B
    \u2192 \u0422\u0435\u043E\u0440\u0435\u043C\u044B**. -   **5 \u041F\u043E\u0441\u0442\u0443\u043B\u0430\u0442\u043E\u0432:**
    \u0415\u0432\u043A\u043B\u0438\u0434 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E
    \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u0432\u0441\u0435 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0435
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u043C\u043E\u0436\u043D\u043E
    \u0432\u044B\u0432\u0435\u0441\u0442\u0438 \u0438\u0437 \u043F\u044F\u0442\u0438
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0439. \u0421\u0430\u043C\u044B\u043C
    \u0441\u043F\u043E\u0440\u043D\u044B\u043C \u0438\u0437 \u043D\u0438\u0445 \u0441\u0442\u0430\u043B
    **\u041F\u044F\u0442\u044B\u0439 \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442**
    (\u043E \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u044F\u043C\u044B\u0445). \u0414\u0432\u0435 \u0442\u044B\u0441\u044F\u0447\u0438
    \u043B\u0435\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0431\u0435\u0437\u0443\u0441\u043F\u0435\u0448\u043D\u043E \u043F\u044B\u0442\u0430\u043B\u0438\u0441\u044C
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u0435\u0433\u043E, \u043F\u043E\u043A\u0430
    \u0432 XIX \u0432\u0435\u043A\u0435 \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439,
    \u0413\u0430\u0443\u0441\u0441 \u0438 \u0411\u043E\u0439\u044F\u0438 \u043D\u0435
    \u0437\u0430\u043C\u0435\u043D\u0438\u043B\u0438 \u0435\u0433\u043E \u043D\u0430
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u044B\u0439,
    \u043E\u0442\u043A\u0440\u044B\u0432 **\u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0443
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E**. \u0422\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0415\u0432\u043A\u043B\u0438\u0434
    \u043D\u0435\u0432\u043E\u043B\u044C\u043D\u043E \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0434\u043B\u044F \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430, \u0445\u043E\u0442\u044F
    \u0441\u0430\u043C \u043E\u0431 \u044D\u0442\u043E\u043C \u043D\u0435 \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u0432\u0430\u043B. 
    ---  ### 2. \u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F (\u043F\u043E \u043A\u043D\u0438\u0433\u0430\u043C
    \xAB\u041D\u0430\u0447\u0430\u043B\xBB)  \u0412 13 \u043A\u043D\u0438\u0433\u0430\u0445
    \xAB\u041D\u0430\u0447\u0430\u043B\xBB \u0415\u0432\u043A\u043B\u0438\u0434 \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u0430\u043B
    \u0447\u0443\u0436\u0438\u0435 \u0438\u0434\u0435\u0438; \u043E\u043D \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0438\u0445, \u043F\u0440\u0438\u0434\u0430\u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C. \u0412\u043E\u0442 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0431\u043B\u043E\u043A\u0438:  **\u0410. \u0422\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B (\u041A\u043D\u0438\u0433\u0438 VII\u2013IX)** 
    -   **\u041E\u0441\u043D\u043E\u0432\u043D\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438:** \u0415\u0432\u043A\u043B\u0438\u0434
    \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0441\u0442\u0440\u043E\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E **\u043B\u044E\u0431\u043E\u0435
    \u0446\u0435\u043B\u043E\u0435 \u0447\u0438\u0441\u043B\u043E \u0440\u0430\u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u043C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u0438
    \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C**
    (\u0445\u043E\u0442\u044F \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E \u0432 \u0432\u0438\u0434\u0435 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0439). -   **\u0411\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B:**
    \u041E\u043D \u0434\u0430\u043B \u043F\u0435\u0440\u0432\u043E\u0435 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E.
    \u042D\u0442\u043E \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043E\u0442 \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u043E\u0433\u043E (\u0435\u0441\u043B\u0438
    \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u044C \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0439
    \u0441\u043F\u0438\u0441\u043E\u043A \u043F\u0440\u043E\u0441\u0442\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u0438 \u043F\u0435\u0440\u0435\u043C\u043D\u043E\u0436\u0438\u0442\u044C
    \u0438\u0445, \u043F\u0440\u0438\u0431\u0430\u0432\u0438\u0432 1, \u043C\u044B
    \u043F\u043E\u043B\u0443\u0447\u0438\u043C \u043D\u043E\u0432\u043E\u0435 \u043F\u0440\u043E\u0441\u0442\u043E\u0435)
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u0438\u0437\u0443\u0447\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0448\u043A\u043E\u043B\u0430\u0445. -   **\u0410\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 (\u041A\u043D\u0438\u0433\u0430 VII):**
    \u0412\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0435\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u2014 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C \u0434\u043B\u044F \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    **\u043D\u0430\u0438\u0431\u043E\u043B\u044C\u0448\u0435\u0433\u043E \u043E\u0431\u0449\u0435\u0433\u043E
    \u0434\u0435\u043B\u0438\u0442\u0435\u043B\u044F (\u041D\u041E\u0414)** \u0434\u0432\u0443\u0445
    \u0447\u0438\u0441\u0435\u043B. \u042D\u0442\u043E \u0441\u0430\u043C\u044B\u0439
    \u0434\u0440\u0435\u0432\u043D\u0438\u0439 \u0438\u0437 \u0434\u043E\u0448\u0435\u0434\u0448\u0438\u0445
    \u0434\u043E \u043D\u0430\u0441 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u0432
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u043E\u0439 \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u0435. 
    **\u0411. \u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438
    \u0438 \u0441\u0442\u0435\u0440\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    (\u041A\u043D\u0438\u0433\u0438 I\u2013VI, XI\u2013XIII)**  -   **\u041F\u0440\u0438\u0437\u043D\u0430\u043A\u0438
    \u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u0430 \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432:**
    \u0421\u0442\u0440\u043E\u0433\u0430\u044F \u0441\u0438\u0441\u0442\u0435\u043C\u0430
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432,
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0430\u044F \u043D\u0430\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0442\u044C
    \u0444\u0438\u0433\u0443\u0440\u044B \u0434\u0440\u0443\u0433 \u043D\u0430 \u0434\u0440\u0443\u0433\u0430
    \u043C\u044B\u0441\u043B\u0435\u043D\u043D\u043E, \u0430 \u043D\u0435 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438.
    -   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430
    (\u041A\u043D\u0438\u0433\u0430 I):** \u0425\u043E\u0442\u044F \u041F\u0438\u0444\u0430\u0433\u043E\u0440
    \u043E\u0442\u043A\u0440\u044B\u043B \u0435\u0451 \u0440\u0430\u043D\u044C\u0448\u0435,
    \u0415\u0432\u043A\u043B\u0438\u0434 \u0434\u0430\u043B \u043F\u0435\u0440\u0432\u043E\u0435
    \u0434\u043E\u0448\u0435\u0434\u0448\u0435\u0435 \u0434\u043E \u043D\u0430\u0441
    \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E,
    \u043F\u0440\u0438\u0447\u0435\u043C \u0441\u0440\u0430\u0437\u0443 \u0434\u0432\u0443\u043C\u044F
    \u0441\u043F\u043E\u0441\u043E\u0431\u0430\u043C\u0438. \u041E\u043D \u043D\u0435
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u0441\u0447\u0435\u0442\u0430,
    \u0430 \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B \u0447\u0435\u0440\u0435\u0437
    \u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u043E \u043F\u043B\u043E\u0449\u0430\u0434\u0435\u0439
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432, \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u044B\u0445
    \u043D\u0430 \u043A\u0430\u0442\u0435\u0442\u0430\u0445 \u0438 \u0433\u0438\u043F\u043E\u0442\u0435\u043D\u0443\u0437\u0435.
    -   **\u0417\u043E\u043B\u043E\u0442\u043E\u0435 \u0441\u0435\u0447\u0435\u043D\u0438\u0435
    (\u041A\u043D\u0438\u0433\u0430 VI):** \u041E\u043D \u0441\u0442\u0440\u043E\u0433\u043E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B \u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043E\u0442\u0440\u0435\u0437\u043A\u0430 \u0432 \u043A\u0440\u0430\u0439\u043D\u0435\u043C
    \u0438 \u0441\u0440\u0435\u0434\u043D\u0435\u043C \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0438
    (\u0447\u0438\u0441\u043B\u043E \u03C6 \u2248 1,618) \u0438 \u0432\u0432\u0435\u043B
    \u0435\u0433\u043E \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0445 \u043C\u043D\u043E\u0433\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432.
    -   **\u041F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u0438\u043A\u043E\u0432
    (\u041A\u043D\u0438\u0433\u0430 XIII):** \u041A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u044F
    \xAB\u041D\u0430\u0447\u0430\u043B\xBB. \u0415\u0432\u043A\u043B\u0438\u0434
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043B, \u0447\u0442\u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    **\u0440\u043E\u0432\u043D\u043E \u043F\u044F\u0442\u044C \u041F\u043B\u0430\u0442\u043E\u043D\u043E\u0432\u044B\u0445
    \u0442\u0435\u043B** (\u0442\u0435\u0442\u0440\u0430\u044D\u0434\u0440, \u043A\u0443\u0431,
    \u043E\u043A\u0442\u0430\u044D\u0434\u0440, \u0434\u043E\u0434\u0435\u043A\u0430\u044D\u0434\u0440,
    \u0438\u043A\u043E\u0441\u0430\u044D\u0434\u0440) \u0438 \u043D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E
    \u0431\u043E\u043B\u044C\u0448\u0435. \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u043A\u0430\u043A \u0432\u043F\u0438\u0441\u0430\u0442\u044C \u0438\u0445 \u0432
    \u0441\u0444\u0435\u0440\u0443, \u0438 \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0438\u0445 \u0441\u0442\u043E\u0440\u043E\u043D. 
    ---  ### 3. \u0412\u043A\u043B\u0430\u0434 \u0432 \u0441\u043C\u0435\u0436\u043D\u044B\u0435
    \u043D\u0430\u0443\u043A\u0438 (\u041E\u043F\u0442\u0438\u043A\u0430, \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F,
    \u041C\u0443\u0437\u044B\u043A\u0430)  \u0415\u0432\u043A\u043B\u0438\u0434 \u0431\u044B\u043B
    \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0441\u0442\u043E\u043C,
    \u0438 \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0432\u044B\u0445\u043E\u0434\u044F\u0442 \u0434\u0430\u043B\u0435\u043A\u043E
    \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u044B \u0447\u0438\u0441\u0442\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  -   **\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043E\u043F\u0442\u0438\u043A\u0430 (\u0422\u0440\u0430\u043A\u0442\u0430\u0442
    \xAB\u041E\u043F\u0442\u0438\u043A\u0430\xBB):** \u042D\u0442\u043E \u043E\u0434\u043D\u0430
    \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0440\u0430\u0431\u043E\u0442 \u043F\u043E
    \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u0435.      -  
    \u0415\u0432\u043A\u043B\u0438\u0434 \u043F\u043E\u0441\u0442\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B,
    \u0447\u0442\u043E \u0441\u0432\u0435\u0442 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u0435\u0442\u0441\u044F
    \u043F\u0440\u044F\u043C\u043E\u043B\u0438\u043D\u0435\u0439\u043D\u043E (\u043B\u0443\u0447\u0438
    \u2014 \u044D\u0442\u043E \u043F\u0440\u044F\u043C\u044B\u0435 \u043B\u0438\u043D\u0438\u0438).     
    -   \u041E\u043D \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C
    \u0437\u0440\u0435\u043D\u0438\u044F \u043D\u0435 \u043A\u0430\u043A \xAB\u0432\u044B\u0445\u043E\u0434
    \u043B\u0443\u0447\u0435\u0439 \u0438\u0437 \u0433\u043B\u0430\u0437\u0430\xBB
    (\u043A\u0430\u043A \u0443\u0447\u0438\u043B \u041F\u043B\u0430\u0442\u043E\u043D),
    \u0430 \u043A\u0430\u043A \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043E\u043F\u0442\u0438\u043A\u0443, \u0437\u0430\u043B\u043E\u0436\u0438\u0432
    \u043E\u0441\u043D\u043E\u0432\u044B **\u0442\u0435\u043E\u0440\u0438\u0438 \u043B\u0438\u043D\u0435\u0439\u043D\u043E\u0439
    \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u044B**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0447\u0435\u0440\u0435\u0437 1500 \u043B\u0435\u0442 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442
    \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0430\u043C \u0420\u0435\u043D\u0435\u0441\u0441\u0430\u043D\u0441\u0430
    \u043F\u0438\u0441\u0430\u0442\u044C \u0440\u0435\u0430\u043B\u0438\u0441\u0442\u0438\u0447\u043D\u044B\u0435
    \u043A\u0430\u0440\u0442\u0438\u043D\u044B. -   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0437\u0435\u0440\u043A\u0430\u043B (\xAB\u041A\u0430\u0442\u043E\u043F\u0442\u0440\u0438\u043A\u0430\xBB):**
    \u041E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u0430\u043A\u043E\u043D \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044F:
    *\u0443\u0433\u043E\u043B \u043F\u0430\u0434\u0435\u043D\u0438\u044F \u0440\u0430\u0432\u0435\u043D
    \u0443\u0433\u043B\u0443 \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044F*
    \u0432 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0438 \u043A \u043F\u043B\u043E\u0441\u043A\u0438\u043C
    \u0438 \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u0437\u0435\u0440\u043A\u0430\u043B\u0430\u043C,
    \u043F\u0440\u043E\u0441\u0447\u0438\u0442\u0430\u0432, \u0433\u0434\u0435 \u0441\u043E\u0439\u0434\u0443\u0442\u0441\u044F
    \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u043D\u044B\u0435 \u043B\u0443\u0447\u0438
    (\u0444\u043E\u043A\u0443\u0441). -   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u043C\u0443\u0437\u044B\u043A\u0438 (\xAB\u0421\u0435\u0447\u0435\u043D\u0438\u044F
    \u043A\u0430\u043D\u043E\u043D\u0430\xBB):** \u0415\u0432\u043A\u043B\u0438\u0434
    \u043F\u0435\u0440\u0435\u0432\u0435\u043B \u043C\u0443\u0437\u044B\u043A\u0443
    \u0432 \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u044C \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u0445
    \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u0439. \u041E\u043D \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043B \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u044B
    (\u043E\u043A\u0442\u0430\u0432\u0430, \u043A\u0432\u0438\u043D\u0442\u0430,
    \u043A\u0432\u0430\u0440\u0442\u0430) \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043A\u043E\u043D\u0441\u043E\u043D\u0430\u043D\u0441 (\u0431\u043B\u0430\u0433\u043E\u0437\u0432\u0443\u0447\u0438\u0435)
    \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u0435\u0442 \u043F\u0440\u0438 \u043F\u0440\u043E\u0441\u0442\u044B\u0445
    \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u0445
    \u0434\u043B\u0438\u043D \u0441\u0442\u0440\u0443\u043D (2:1, 3:2, 4:3).  --- 
    ### 4. \u0412\u043B\u0438\u044F\u043D\u0438\u0435, \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0435\u0435
    \u0432\u0440\u0435\u043C\u044F (\u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435)  \u0414\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u0441\u0442\u0430\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u043E\u0439
    \u0434\u043B\u044F \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u0430
    \u0432 \u0446\u0435\u043B\u043E\u043C:  -   **\u0421\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0438:**
    \u041E\u043D \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u0434\u043B\u044F \u0432\u0441\u0435\u0433\u043E, \u0447\u0442\u043E \u043A\u0430\u0436\u0435\u0442\u0441\u044F
    \u043E\u0447\u0435\u0432\u0438\u0434\u043D\u044B\u043C. \u042D\u0442\u043E \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u043E
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F \u0443\u0447\u0435\u043D\u044B\u0445,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0435 \u0432\u0435\u0440\u044F\u0442
    \xAB\u043D\u0430 \u0433\u043B\u0430\u0437\xBB, \u0430 \u0442\u0440\u0435\u0431\u0443\u044E\u0442
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0432\u044B\u0432\u043E\u0434\u0430.
    -   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u044F
    \u0444\u0438\u0437\u0438\u043A\u0438:** \u0418\u043C\u0435\u043D\u043D\u043E
    \u0415\u0432\u043A\u043B\u0438\u0434 \u0441\u043E\u0437\u0434\u0430\u043B \u044F\u0437\u044B\u043A,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0437\u0430\u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u0444\u0438\u0437\u0438\u043A\u0430. \u041A\u043E\u0433\u0434\u0430 \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A,
    \u041A\u0435\u043F\u043B\u0435\u0440, \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0438 \u041D\u044C\u044E\u0442\u043E\u043D \u043D\u0430\u0447\u043D\u0443\u0442
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435
    \u043F\u043B\u0430\u043D\u0435\u0442, \u043E\u043D\u0438 \u0431\u0443\u0434\u0443\u0442
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0443 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    (\u043F\u0440\u044F\u043C\u044B\u0435, \u043A\u0440\u0443\u0433\u0438, \u044D\u043B\u043B\u0438\u043F\u0441\u044B,
    \u043A\u043E\u043D\u0443\u0441\u044B). \u0411\u0435\u0437 \xAB\u041D\u0430\u0447\u0430\u043B\xBB
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u043D\u0435 \u0431\u044B\u043B\u043E
    \u0431\u044B \u043D\u0435\u0431\u0435\u0441\u043D\u043E\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438. 
    **\u0418\u0442\u043E\u0433\u043E\u0432\u0430\u044F \u0441\u0443\u0442\u044C \u0435\u0433\u043E
    \u0432\u043A\u043B\u0430\u0434\u0430:**  \u041E\u043D \u043D\u0435 \u043E\u0442\u043A\u0440\u044B\u043B
    *\u0447\u0442\u043E-\u0442\u043E \u043E\u0434\u043D\u043E*. \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    **\u043C\u0430\u0448\u0438\u043D\u0443 \u0434\u043B\u044F \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u0430
    \u043D\u043E\u0432\u044B\u0445 \u0438\u0441\u0442\u0438\u043D**. \u041F\u043E\u043A\u0430
    \u0434\u0440\u0443\u0433\u0438\u0435 \u0446\u0438\u0432\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u0438
    \u043D\u0430\u043A\u0430\u043F\u043B\u0438\u0432\u0430\u043B\u0438 \u0444\u0430\u043A\u0442\u044B,
    \u0415\u0432\u043A\u043B\u0438\u0434 \u0434\u0430\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0443
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442, \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0438\u0439
    \u0438\u0437 \u0433\u043E\u0440\u0441\u0442\u043A\u0438 \u0430\u043A\u0441\u0438\u043E\u043C
    \u0432\u044B\u0432\u043E\u0434\u0438\u0442\u044C \u0437\u043D\u0430\u043D\u0438\u0435
    \u043E \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C \u043A\u043E\u0441\u043C\u043E\u0441\u0435.
    \u0418\u043C\u0435\u043D\u043D\u043E \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \xAB\u0415\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F\xBB \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440 \u2014 \u0441\u0438\u043D\u043E\u043D\u0438\u043C \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E\u0439,
    \u043D\u0435\u0437\u044B\u0431\u043B\u0435\u043C\u043E\u0439 \u043B\u043E\u0433\u0438\u043A\u0438. "
  achievementsEn: 
  personalLifeRu: "\u042D\u0442\u043E \u0441\u0430\u043C\u044B\u0439 \u0441\u043B\u043E\u0436\u043D\u044B\u0439
    \u0432\u043E\u043F\u0440\u043E\u0441 \u043E \u0415\u0432\u043A\u043B\u0438\u0434\u0435,
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E **\u043E \u0435\u0433\u043E
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438 \u043D\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u0440\u043E\u0432\u043D\u043E
    \u043D\u0438\u0447\u0435\u0433\u043E**.   \u0412 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u0438
    \u0432\u043E\u043E\u0431\u0449\u0435 \u043D\u0435 \u0431\u044B\u043B\u043E \u043F\u0440\u0438\u043D\u044F\u0442\u043E
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C \u0447\u0430\u0441\u0442\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u0443\u0447\u0435\u043D\u044B\u0445 \u2014 \u0438\u0445
    \u0446\u0435\u043D\u0438\u043B\u0438 \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0437\u0430 \u0442\u0440\u0443\u0434\u044B, \u0430 \u043D\u0435 \u0437\u0430
    \u0431\u044B\u0442. \u0411\u0438\u043E\u0433\u0440\u0430\u0444\u044B \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0445
    \u0432\u0435\u043A\u043E\u0432 (\u0440\u0438\u043C\u0441\u043A\u0438\u0435, \u0432\u0438\u0437\u0430\u043D\u0442\u0438\u0439\u0441\u043A\u0438\u0435,
    \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0435) \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u043B\u0438
    \u043E\u0431\u043B\u0438\u043A \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u0432
    \u043F\u043E \u0438\u0445 \u043A\u043D\u0438\u0433\u0430\u043C, \u0430 \u043D\u0435
    \u043F\u043E \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0430\u043C \u0438\u043B\u0438
    \u043F\u0438\u0441\u044C\u043C\u0430\u043C.   \u0422\u043E, \u0447\u0442\u043E
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u0432\u044B\u0434\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442\u0435 \u0437\u0430 \xAB\u0444\u0430\u043A\u0442\u044B
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438 \u0415\u0432\u043A\u043B\u0438\u0434\u0430\xBB
    (\u0436\u0435\u043D\u0430, \u0434\u0435\u0442\u0438, \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0438)
    \u2014 \u044D\u0442\u043E **\u0447\u0438\u0441\u0442\u044B\u0439 \u0432\u044B\u043C\u044B\u0441\u0435\u043B**
    \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u0435\u0439 \u041D\u043E\u0432\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0438\u043B\u0438 \u0440\u0430\u043D\u043D\u0435\u0433\u043E
    \u0421\u0440\u0435\u0434\u043D\u0435\u0432\u0435\u043A\u043E\u0432\u044C\u044F,
    \u043D\u0435 \u0438\u043C\u0435\u044E\u0449\u0438\u0439 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0439.  
    \u041E\u0434\u043D\u0430\u043A\u043E \u044F \u043C\u043E\u0433\u0443 \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0432\u0430\u043C \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439 \u043E\u0431\u0437\u043E\u0440
    **\u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0414\u041E\u0421\u0422\u041E\u0412\u0415\u0420\u041D\u041E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043E \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438,
    \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u0438 \u0438 \u0431\u044B\u0442\u0435**,
    \u0438\u0441\u0445\u043E\u0434\u044F \u0438\u0437 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u043D\u0442\u0435\u043A\u0441\u0442\u0430 \u0438 \u043A\u043E\u0441\u0432\u0435\u043D\u043D\u044B\u0445
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0439:  ### 1. \u0421\u0435\u043C\u0435\u0439\u043D\u043E\u0435
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    (\u0421\u043F\u043B\u043E\u0448\u043D\u044B\u0435 \u0434\u043E\u0433\u0430\u0434\u043A\u0438) 
    -   **\u0418\u043C\u044F:** \u0415\u0433\u043E \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0435
    \u0438\u043C\u044F \u2014 **\u0395\u1F50\u03BA\u03BB\u03B5\u03AF\u03B4\u03B7\u03C2**
    (\u042D\u0432\u043A\u043B\u0438\u0434\u0435\u0441), \u0447\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442
    \xAB\u0421\u043B\u0430\u0432\u043D\u044B\u0439\xBB \u0438\u043B\u0438 \xAB\u041F\u0440\u043E\u0441\u043B\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0439\xBB.
    \u042D\u0442\u043E \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u043D\u043E\u0435
    \u0438\u043C\u044F \u0432 \u0414\u0440\u0435\u0432\u043D\u0435\u0439 \u0413\u0440\u0435\u0446\u0438\u0438,
    \u0447\u0442\u043E \u0443\u0441\u043B\u043E\u0436\u043D\u044F\u0435\u0442 \u0438\u0434\u0435\u043D\u0442\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044E.
    -   **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435:**
    \u0413\u0434\u0435 \u043E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u2014
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E. \u041F\u043E\u0437\u0434\u043D\u0438\u0435
    \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0435 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0431\u0438\u043E\u0433\u0440\u0430\u0444
    \u0418\u0431\u043D \u0430\u043B\u044C-\u041A\u0438\u0444\u0442\u0438 \u0432 XIII
    \u0432\u0435\u043A\u0435) \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044E\u0442,
    \u0447\u0442\u043E \u043E\u043D \u0431\u044B\u043B \u0440\u043E\u0434\u043E\u043C
    \u0438\u0437 **\u0422\u0438\u0440\u0430** (\u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439
    \u041B\u0438\u0432\u0430\u043D) \u0438\u043B\u0438 \u0438\u0437 **\u0414\u0430\u043C\u0430\u0441\u043A\u0430**
    (\u0421\u0438\u0440\u0438\u044F). \u041E\u0434\u043D\u0430\u043A\u043E \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432 \u0441\u043A\u043B\u043E\u043D\u044F\u044E\u0442\u0441\u044F
    \u043A \u0442\u043E\u043C\u0443, \u0447\u0442\u043E \u043E\u043D \u0431\u044B\u043B
    **\u0433\u0440\u0435\u043A\u043E\u043C \u043F\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044E**,
    \u043D\u043E \u0440\u043E\u0434\u0438\u043B\u0441\u044F, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438 \u0413\u0440\u0435\u0446\u0438\u0438,
    \u0432 \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u044D\u043B\u043B\u0438\u043D\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u043E\u043B\u043E\u043D\u0438\u0439. -   **\u0421\u0435\u043C\u044C\u044F:**
    \u041D\u0435\u0442 \u043D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F
    \u043E \u0435\u0433\u043E \u043E\u0442\u0446\u0435, \u043C\u0430\u0442\u0435\u0440\u0438,
    \u0431\u0440\u0430\u0442\u044C\u044F\u0445 \u0438\u043B\u0438 \u0441\u0435\u0441\u0442\u0440\u0430\u0445.
    \u041D\u0435\u0442 \u0437\u0430\u043F\u0438\u0441\u0435\u0439 \u043E \u0442\u043E\u043C,
    \u0431\u044B\u043B \u043B\u0438 \u043E\u043D \u0436\u0435\u043D\u0430\u0442 \u0438\u043B\u0438
    \u0438\u043C\u0435\u043B \u0434\u0435\u0442\u0435\u0439. \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430 \u0438\u043B\u0438
    \u041F\u043B\u0430\u0442\u043E\u043D\u0430, \u043E \u0440\u043E\u0434\u043E\u0441\u043B\u043E\u0432\u043D\u043E\u0439
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u043D\u0435\u0442 \u043D\u0438 \u0441\u0442\u0440\u043E\u0447\u043A\u0438. 
    ### 2. \u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440 \u0438 \u043C\u0430\u043D\u0435\u0440\u0430
    \u043E\u0431\u0449\u0435\u043D\u0438\u044F (\u041F\u043E \u0430\u043D\u0435\u043A\u0434\u043E\u0442\u0430\u043C) 
    \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435 \xAB\u043B\u0438\u0447\u043D\u044B\u0435\xBB
    \u0447\u0435\u0440\u0442\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u043E
    \u043D\u0430\u0441 \u0434\u043E\u0448\u043B\u0438, \u2014 \u044D\u0442\u043E
    \u0435\u0433\u043E \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435
    \u0441 \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C\u0438 \u0438 \u0446\u0430\u0440\u0435\u043C,
    \u0437\u0430\u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0435
    \u0432 \u0434\u0432\u0443\u0445 \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0445: 
    -   **\u0426\u0430\u0440\u0441\u043A\u0438\u0439 \u043F\u0443\u0442\u044C (\u0421\u0430\u043C\u0430\u044F
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F \u0447\u0435\u0440\u0442\u0430
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0430):** \u041A\u0430\u043A
    \u0443\u0436\u0435 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043B\u043E\u0441\u044C,
    \u0446\u0430\u0440\u044C \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 I \u0441\u043F\u0440\u043E\u0441\u0438\u043B
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430, \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043B\u0438 \u0431\u043E\u043B\u0435\u0435 \u043B\u0435\u0433\u043A\u0438\u0439
    \u0441\u043F\u043E\u0441\u043E\u0431 \u0432\u044B\u0443\u0447\u0438\u0442\u044C
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E, \u0447\u0435\u043C \u0447\u0438\u0442\u0430\u0442\u044C
    \u0435\u0433\u043E \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435 \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB.
    \u0415\u0432\u043A\u043B\u0438\u0434 \u043E\u0442\u0432\u0435\u0442\u0438\u043B:
    *\xAB\u0412 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u043D\u0435\u0442
    \u0446\u0430\u0440\u0441\u043A\u043E\u0439 \u0434\u043E\u0440\u043E\u0433\u0438\xBB*.
    \u042D\u0442\u043E\u0442 \u043E\u0442\u0432\u0435\u0442 \u0440\u0438\u0441\u0443\u0435\u0442
    \u0435\u0433\u043E \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    **\u0441\u0442\u0440\u043E\u0433\u043E\u0433\u043E, \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438 \u0431\u0435\u0441\u043A\u043E\u043C\u043F\u0440\u043E\u043C\u0438\u0441\u0441\u043D\u043E\u0433\u043E**
    \u0432 \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u0445 \u043D\u0430\u0443\u043A\u0438.
    \u041E\u043D \u043D\u0435 \u043B\u044C\u0441\u0442\u0438\u043B \u043C\u043E\u043D\u0430\u0440\u0445\u0443
    \u0438 \u043D\u0435 \u0443\u043F\u0440\u043E\u0449\u0430\u043B \u043D\u0430\u0443\u043A\u0443
    \u0440\u0430\u0434\u0438 \u0443\u0433\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0432\u043B\u0430\u0441\u0442\u0438. -   **\u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435
    \u043A \u0434\u0435\u043D\u044C\u0433\u0430\u043C (\u041F\u043E \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0443
    \u0421\u0442\u043E\u0431\u0435\u044F):** \u0414\u0440\u0443\u0433\u043E\u0439
    \u0430\u043D\u0435\u043A\u0434\u043E\u0442 (\u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u043D\u044B\u0439
    \u0418\u043E\u0430\u043D\u043D\u043E\u043C \u0421\u0442\u043E\u0431\u0435\u0435\u043C)
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442, \u0447\u0442\u043E
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432
    \u0441\u043F\u0440\u043E\u0441\u0438\u043B \u0415\u0432\u043A\u043B\u0438\u0434\u0430:
    *\xAB\u041A\u0430\u043A\u043E\u0439 \u043F\u0440\u043E\u043A \u043E\u0442 \u0437\u0430\u043D\u044F\u0442\u0438\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439?\xBB* \u0412\u043C\u0435\u0441\u0442\u043E
    \u043B\u0435\u043A\u0446\u0438\u0438 \u043E \u043F\u043E\u043B\u044C\u0437\u0435,
    \u0415\u0432\u043A\u043B\u0438\u0434 \u043F\u043E\u0437\u0432\u0430\u043B \u0440\u0430\u0431\u0430
    \u0438 \u0441\u043A\u0430\u0437\u0430\u043B: *\xAB\u0414\u0430\u0439 \u0435\u043C\u0443
    \u0442\u0440\u0438 \u043E\u0431\u043E\u043B\u0430 (\u043C\u0435\u043B\u043A\u0438\u0435
    \u043C\u043E\u043D\u0435\u0442\u044B), \u0440\u0430\u0437 \u043E\u043D \u043D\u0435\u043F\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u0445\u043E\u0447\u0435\u0442 \u0438\u043C\u0435\u0442\u044C \u043F\u0440\u0438\u0431\u044B\u043B\u044C
    \u043E\u0442 \u0441\u0432\u043E\u0438\u0445 \u0437\u043D\u0430\u043D\u0438\u0439\xBB*.
    \u042D\u0442\u043E\u0442 \u043F\u043E\u0441\u0442\u0443\u043F\u043E\u043A \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0437\u0443\u0435\u0442
    \u0435\u0433\u043E \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    **\u0438\u0440\u043E\u043D\u0438\u0447\u043D\u043E\u0433\u043E, \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u043D\u043E\u0433\u043E
    \u0443\u043C\u0430**, \u0434\u043B\u044F \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0437\u043D\u0430\u043D\u0438\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0441\u0430\u043C\u043E\u0446\u0435\u043B\u044C\u044E, \u0430 \u043D\u0435 \u0440\u0435\u043C\u0435\u0441\u043B\u043E\u043C
    \u0434\u043B\u044F \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u043A\u0430. \u041E\u043D
    \u043F\u0440\u0435\u0437\u0438\u0440\u0430\u043B \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043C\u0435\u0440\u043A\u0430\u043D\u0442\u0438\u043B\u044C\u043D\u043E\u0441\u0442\u044C. 
    ### 3. \u0421\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u0441\u0442\u0430\u0442\u0443\u0441
    \u0438 \u0431\u044B\u0442 \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438 
    \u041F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443 \u043E\u043D \u0436\u0438\u043B
    \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438 \u043E\u043A\u043E\u043B\u043E
    300 \u0433\u043E\u0434\u0430 \u0434\u043E \u043D. \u044D., \u043C\u044B \u043C\u043E\u0436\u0435\u043C
    \u0440\u0435\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0435\u0433\u043E \u0431\u044B\u0442, \u043E\u043F\u0438\u0440\u0430\u044F\u0441\u044C
    \u043D\u0430 \u043E\u0431\u0449\u0443\u044E \u0438\u0441\u0442\u043E\u0440\u0438\u044E
    \u0433\u043E\u0440\u043E\u0434\u0430:  -   **\u041C\u0435\u0441\u0442\u043E \u0436\u0438\u0437\u043D\u0438:**
    \u041E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043F\u0440\u0438 **\u041C\u0443\u0441\u0435\u0439\u043E\u043D\u0435
    (\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u043C
    \u043C\u0443\u0437\u0435\u0435)** \u2014 \u044D\u0442\u043E \u0431\u044B\u043B\u043E
    \u043D\u0435\u0447\u0442\u043E \u0441\u0440\u0435\u0434\u043D\u0435\u0435 \u043C\u0435\u0436\u0434\u0443
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u043E\u043C,
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u043C
    \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u0438 \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u0435\u043C.
    \u0423\u0447\u0435\u043D\u044B\u0435 \u0442\u0430\u043C \u0436\u0438\u043B\u0438
    \u043D\u0430 \u043F\u043E\u043B\u043D\u043E\u043C \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u0438\u0438, \u0435\u043B\u0438
    \u0431\u0435\u0441\u043F\u043B\u0430\u0442\u043D\u044B\u0439 \u043E\u0431\u0435\u0434
    \u0438 \u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0430\u043B\u0438\u0441\u044C
    \u043E\u0442 \u043D\u0430\u043B\u043E\u0433\u043E\u0432. \u0415\u0432\u043A\u043B\u0438\u0434,
    \u0441\u043A\u043E\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043E, \u0436\u0438\u043B
    \u0432 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445 \u043A\u043E\u043C\u043D\u0430\u0442\u0430\u0445
    \u043F\u0440\u0438 \u041C\u0443\u0441\u0435\u0439\u043E\u043D\u0435 \u0438\u043B\u0438
    \u0440\u044F\u0434\u043E\u043C \u0441 \u0446\u0430\u0440\u0441\u043A\u0438\u043C
    \u043A\u0432\u0430\u0440\u0442\u0430\u043B\u043E\u043C \u0411\u0440\u0443\u0445\u0435\u0439\u043E\u043D.
    -   **\u041C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435:** \u0411\u0443\u0434\u0443\u0447\u0438
    \u0433\u043B\u0430\u0432\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B, \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0430\u043B
    \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u0438\u0435 \u043E\u0442 \u043A\u0430\u0437\u043D\u044B
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F. \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u0432-\u0441\u0442\u043E\u0438\u043A\u043E\u0432,
    \u043E\u043D \u043D\u0435 \u0431\u0435\u0434\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0438 \u043C\u043E\u0433 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442\u044C
    \u0441\u0435\u0431\u0435 \u0440\u0430\u0431\u043E\u0432 (\u043A\u0430\u043A \u0441\u043B\u0435\u0434\u0443\u0435\u0442
    \u0438\u0437 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u0441 \u0442\u0440\u0435\u043C\u044F
    \u043E\u0431\u043E\u043B\u0430\u043C\u0438) \u0434\u043B\u044F \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u043D\u0443\u0436\u0434, \u0447\u0442\u043E\u0431\u044B \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u0442\u044C
    \u0432\u0440\u0435\u043C\u044F \u0434\u043B\u044F \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439.
    -   **\u0420\u0430\u0441\u043F\u043E\u0440\u044F\u0434\u043E\u043A \u0434\u043D\u044F:**
    \u0412\u0435\u0440\u043E\u044F\u0442\u043D\u0435\u0435 \u0432\u0441\u0435\u0433\u043E,
    \u0435\u0433\u043E \u0434\u0435\u043D\u044C \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B
    \u0441\u0442\u0440\u043E\u0433\u043E \u0440\u0435\u0433\u043B\u0430\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E:
    \u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0435 \u043B\u0435\u043A\u0446\u0438\u0438
    (\u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0438 \u0432 \u043F\u043E\u0440\u0442\u0438\u043A\u0430\u0445
    \u0438\u043B\u0438 \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u044F\u0445
    \u041C\u0443\u0441\u0435\u0439\u043E\u043D\u0430) \u0438 \u0440\u0430\u0431\u043E\u0442\u0430
    \u043D\u0430\u0434 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044F\u043C\u0438
    \u0432 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0435.   ### 4.
    \u0412\u043D\u0435\u0448\u043D\u043E\u0441\u0442\u044C \u0438 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435
    (\u041F\u043E\u043B\u043D\u043E\u0435 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435
    \u0434\u0430\u043D\u043D\u044B\u0445)  -   \u041D\u0435\u0442 \u043D\u0438 \u043E\u0434\u043D\u043E\u0439
    \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0439 \u0441\u0442\u0430\u0442\u0443\u0438
    \u0438\u043B\u0438 \u0431\u044E\u0441\u0442\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0431\u044B \u0442\u043E\u0447\u043D\u043E \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u043B\u0438
    \u0415\u0432\u043A\u043B\u0438\u0434\u0443. \u0422\u0435 \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u044B \u0432\u0438\u0434\u0438\u043C
    \u0432 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0430\u0445 (\u0431\u043E\u0440\u043E\u0434\u0430\u0442\u044B\u0439
    \u0441\u0442\u0430\u0440\u0435\u0446 \u0441 \u0446\u0438\u0440\u043A\u0443\u043B\u0435\u043C),
    \u2014 \u044D\u0442\u043E \u043F\u043B\u043E\u0434 \u0444\u0430\u043D\u0442\u0430\u0437\u0438\u0438
    \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u043E\u0432 \u044D\u043F\u043E\u0445\u0438
    \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0438 \u041D\u043E\u0432\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438. -   \u041D\u0435\u0442 \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u0439
    \u043E \u0442\u043E\u043C, \u0431\u043E\u043B\u0435\u043B \u043B\u0438 \u043E\u043D,
    \u043A\u0430\u043A \u0443\u043C\u0435\u0440 \u0438 \u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0442\u043E\u0447\u043D\u043E \u043F\u0440\u043E\u0436\u0438\u043B. \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0434\u043E\u0436\u0438\u043B \u0434\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439
    \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0438 (\u0438\u0441\u0445\u043E\u0434\u044F
    \u0438\u0437 \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442 \u043C\u043E\u043B\u043E\u0434\u043E\u0439
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u043A\u0430\u043A \u0443\u0436\u0435
    \u0441\u043E\u0441\u0442\u043E\u044F\u0432\u0448\u0435\u0433\u043E\u0441\u044F
    \u043C\u044D\u0442\u0440\u0430), \u043D\u043E \u0434\u0430\u0442\u0430 \u0435\u0433\u043E
    \u0441\u043C\u0435\u0440\u0442\u0438 (\u043E\u043A\u043E\u043B\u043E 265\u2013260
    \u0433\u0433. \u0434\u043E \u043D. \u044D.) \u0442\u0430\u043A\u0436\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043B\u0438\u0448\u044C \u0440\u0435\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0435\u0439. 
    ### 5. \u041F\u0443\u0442\u0430\u043D\u0438\u0446\u0430 \u0441 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    (\u0412\u0430\u0436\u043D\u044B\u0439 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0430\u043A\u0442)  \u0427\u0442\u043E\u0431\u044B \u043E\u0442\u0432\u0435\u0442
    \u0431\u044B\u043B \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u043C, \u043D\u0443\u0436\u043D\u043E
    \u0443\u043F\u043E\u043C\u044F\u043D\u0443\u0442\u044C \u043E\u0431 \u043E\u0434\u043D\u043E\u0439
    \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u0432\u0438\u0442
    \u043F\u043E\u0434 \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u0435 \u0434\u0430\u0436\u0435
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E:  -  
    \u0412 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0445\u0440\u043E\u043D\u0438\u043A\u0430\u0445 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442\u0441\u044F
    **\u043A\u0430\u043A \u043C\u0438\u043D\u0438\u043C\u0443\u043C \u0442\u0440\u0438
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430** \u0438\u0437 \u043E\u0434\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0438\u043E\u0434\u0430: \u043D\u0430\u0448 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444-\u043C\u0435\u0433\u0430\u0440\u0438\u043A
    (\u0443\u0447\u0435\u043D\u0438\u043A \u0421\u043E\u043A\u0440\u0430\u0442\u0430)
    \u0438 \u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u043E\u0440.  -   \u0412
    \u0441\u0440\u0435\u0434\u043D\u0438\u0435 \u0432\u0435\u043A\u0430 \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 (\u0418\u0431\u043D \u0430\u043B\u044C-\u041A\u0438\u0444\u0442\u0438)
    \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E \u0441\u043E\u0435\u0434\u0438\u043D\u0438\u043B\u0438
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u0438\u0437 \u041C\u0435\u0433\u0430\u0440\u044B,
    \u043F\u0440\u0438\u043F\u0438\u0441\u0430\u0432 \u043D\u0430\u0448\u0435\u043C\u0443
    \u0443\u0447\u0435\u043D\u043E\u043C\u0443 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0434\u043E\u043B\u0433\u0443\u044E \u0436\u0438\u0437\u043D\u044C (\u043F\u043E\u0447\u0442\u0438
    400 \u043B\u0435\u0442) \u0438 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F.
    \u041B\u0438\u0448\u044C \u0432 \u044D\u043F\u043E\u0445\u0443 \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 (\u041F\u044C\u0435\u0442\u0440\u043E
    \u0422\u0430\u043A\u043A\u043E\u043B\u0430) \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u043B\u0438
    \u044D\u0442\u0443 \u043F\u0443\u0442\u0430\u043D\u0438\u0446\u0443, \u043D\u043E
    \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u043E\u0441\u0442\u0438 \u0432 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438
    \u0444\u0430\u043A\u0442\u043E\u0432 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u0438\u0431\u0430\u0432\u0438\u043B\u043E. 
    ---  **\u0420\u0435\u0437\u044E\u043C\u0438\u0440\u0443\u044F:** \u0415\u0441\u043B\u0438
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C \u0441\u0442\u0440\u043E\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u043E, **\u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0443 \u0415\u0432\u043A\u043B\u0438\u0434\u0430
    \u0434\u043B\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043D\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E**.
    \u041E\u043D \u043F\u0440\u043E\u0436\u0438\u043B \u0441\u0432\u043E\u044E \u0436\u0438\u0437\u043D\u044C
    \u0432\u043D\u0443\u0442\u0440\u0438 \u0441\u0432\u043E\u0438\u0445 \u0447\u0435\u0440\u0442\u0435\u0436\u0435\u0439
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432.
    \u041E\u043D \u043D\u0435 \u043F\u0438\u0441\u0430\u043B \u043C\u0435\u043C\u0443\u0430\u0440\u043E\u0432,
    \u043D\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043B \u0432 \u043B\u0438\u0447\u043D\u043E\u0439
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435 (\u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C),
    \u0438 \u0435\u0433\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u043D\u0435 \u0441\u043E\u0447\u043B\u0438 \u043D\u0443\u0436\u043D\u044B\u043C
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C, \u0435\u043B \u043B\u0438
    \u043E\u043D \u043E\u043B\u0438\u0432\u043A\u0438 \u0438\u043B\u0438 \u043B\u044E\u0431\u0438\u043B
    \u043B\u0438 \u0432\u0438\u043D\u043E.   \u0412\u0441\u0435, \u0447\u0442\u043E
    \u043C\u044B \u0437\u043D\u0430\u0435\u043C \u043E \u043D\u0435\u043C \u043A\u0430\u043A
    \u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0435, \u0443\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0434\u0432\u0430 \u0435\u0433\u043E \u043A\u0440\u044B\u043B\u0430\u0442\u044B\u0445
    \u043E\u0442\u0432\u0435\u0442\u0430: **\xAB\u041D\u0435\u0442 \u0446\u0430\u0440\u0441\u043A\u043E\u0433\u043E
    \u043F\u0443\u0442\u0438\xBB** \u0438 **\xAB\u0414\u0430\u0439 \u0435\u043C\u0443
    \u0442\u0440\u0438 \u043E\u0431\u043E\u043B\u0430\xBB**. \u0418\u0441\u0445\u043E\u0434\u044F
    \u0438\u0437 \u043D\u0438\u0445, \u043C\u043E\u0436\u043D\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u0432\u044B\u0432\u043E\u0434, \u0447\u0442\u043E \u044D\u0442\u043E \u0431\u044B\u043B
    \u0438\u0440\u043E\u043D\u0438\u0447\u043D\u044B\u0439, \u0441\u0442\u0440\u043E\u0433\u0438\u0439,
    \u0431\u0435\u0441\u043A\u043E\u0440\u044B\u0441\u0442\u043D\u044B\u0439 \u0438
    \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0439
    \u0434\u0443\u0445\u043E\u043C \u0433\u0440\u0435\u043A, \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0432\u0448\u0438\u0439 \u0441\u0435\u0431\u044F
    \u041B\u043E\u0433\u043E\u0441\u0443 (\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0437\u043D\u0430\u043D\u0438\u044E). \u0412\u0441\u0435 \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u2014 \u0432\u044B\u043C\u044B\u0441\u0435\u043B."
  personalLifeEn: 
  shortBioRu: "\u0411\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u0439 \u043E \u0415\u0432\u043A\u043B\u0438\u0434\u0435
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C \u043E\u0447\u0435\u043D\u044C
    \u043C\u0430\u043B\u043E, \u0438 \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
    \u0438\u0437 \u043D\u0438\u0445 \u2014 \u044D\u0442\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u044B
    \u0438 \u043E\u0442\u0440\u044B\u0432\u043E\u0447\u043D\u044B\u0435 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F,
    \u0434\u043E\u0448\u0435\u0434\u0448\u0438\u0435 \u0447\u0435\u0440\u0435\u0437
    \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F. \u0422\u0435\u043C \u043D\u0435
    \u043C\u0435\u043D\u0435\u0435, \u0435\u0433\u043E \u0444\u0438\u0433\u0443\u0440\u0430
    \u043A\u0430\u043A \xAB\u043E\u0442\u0446\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB
    \u0438 \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434,
    \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB, \u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0432\u0441\u044E \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u043D\u0430\u0443\u043A\u0438. 
    ### \U0001F4DC \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0432\u0435\u0445\u0438
    \u0436\u0438\u0437\u043D\u0438  \u0411\u043E\u043B\u044C\u0448\u0430\u044F \u0447\u0430\u0441\u0442\u044C
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u043C\u044B \xAB\u0437\u043D\u0430\u0435\u043C\xBB
    \u043E \u0415\u0432\u043A\u043B\u0438\u0434\u0435, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0430
    \u043D\u0430 \u043A\u043E\u0441\u0432\u0435\u043D\u043D\u044B\u0445 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u0445. 
    *   **\u0412\u0440\u0435\u043C\u044F \u0436\u0438\u0437\u043D\u0438:** \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0436\u0438\u043B \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E
    **\u0432 325\u2013265 \u0433\u043E\u0434\u0430\u0445 \u0434\u043E \u043D. \u044D.**.
    \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u043C \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440\u043E\u043C
    \u0441\u043B\u0443\u0436\u0438\u0442 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430 \u041F\u0440\u043E\u043A\u043B\u0430
    (V \u0432\u0435\u043A \u043D. \u044D.), \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u0438\u0441\u0430\u043B, \u0447\u0442\u043E \u0415\u0432\u043A\u043B\u0438\u0434
    \u0436\u0438\u043B \u0432\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0430 \u0446\u0430\u0440\u044F
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F I \u0421\u043E\u0442\u0435\u0440\u0430
    (\u043F\u0440\u0430\u0432\u0438\u043B \u0432 306\u2013283 \u0433\u0433. \u0434\u043E
    \u043D. \u044D.), \u0431\u044B\u043B \u043C\u043E\u043B\u043E\u0436\u0435 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432
    \u041F\u043B\u0430\u0442\u043E\u043D\u0430, \u043D\u043E \u0441\u0442\u0430\u0440\u0448\u0435
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430 (\u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u043E\u043A. 287 \u0433. \u0434\u043E \u043D. \u044D.). \u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u0432 \u0441\u0432\u043E\u0438\u0445 \u0442\u0440\u0443\u0434\u0430\u0445 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430, \u0447\u0442\u043E \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442
    \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044E. *   **\u041C\u0435\u0441\u0442\u043E
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438:** \u0415\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B\u0430 \u0432 **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438
    \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0439**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u044D\u043B\u043B\u0438\u043D\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438. \u041F\u0440\u0435\u0434\u043F\u043E\u043B\u0430\u0433\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0431\u044B\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0435\u043C I \u0438 \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \u0442\u0430\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0432 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u043C \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u043C
    \u041C\u0443\u0441\u0435\u0439\u043E\u043D\u0435 (\u0445\u0440\u0430\u043C\u0435
    \u043C\u0443\u0437) \u043F\u0440\u0438 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0435.
    *   **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:**
    \u0422\u043E\u0447\u043D\u043E\u0435 \u043C\u0435\u0441\u0442\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E. \u041E\u0434\u043D\u0430
    \u0438\u0437 \u0432\u0435\u0440\u0441\u0438\u0439 (\u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432\u0448\u0430\u044F\u0441\u044F
    \u0432 \u0430\u0440\u0430\u0431\u0441\u043A\u043E\u0439 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0438
    XII \u0432\u0435\u043A\u0430) \u0433\u043B\u0430\u0441\u0438\u0442, \u0447\u0442\u043E
    \u043E\u043D \u0431\u044B\u043B \u0433\u0440\u0435\u043A\u043E\u043C, \u0440\u043E\u0434\u043E\u043C
    \u0438\u0437 \u0422\u0438\u0440\u0430, \u0438 \u0436\u0438\u043B \u0432 \u0421\u0438\u0440\u0438\u0438.
    \u0422\u0430\u043A\u0436\u0435 \u0435\u0441\u0442\u044C \u0434\u0430\u043D\u043D\u044B\u0435,
    \u0447\u0442\u043E \u043E\u043D \u0443\u0447\u0438\u043B\u0441\u044F \u0432 \u0410\u0444\u0438\u043D\u0430\u0445
    \u0443 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u041F\u043B\u0430\u0442\u043E\u043D\u0430, \u0447\u0442\u043E \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u043E
    \u043D\u0430 \u0435\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    *   **\u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0430\u043D\u0435\u043A\u0434\u043E\u0442:**
    \u0418\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u043E\u043C\u0443 \u043F\u0435\u0440\u0438\u043E\u0434\u0443
    \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0434\u0438\u0430\u043B\u043E\u0433. \u0426\u0430\u0440\u044C \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u0441\u043F\u0440\u043E\u0441\u0438\u043B \u0415\u0432\u043A\u043B\u0438\u0434\u0430,
    \u0435\u0441\u0442\u044C \u043B\u0438 \u0431\u043E\u043B\u0435\u0435 \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0439
    \u043F\u0443\u0442\u044C \u043A \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u0447\u0435\u043C \u0435\u0433\u043E \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB.
    \u041D\u0430 \u0447\u0442\u043E \u0443\u0447\u0435\u043D\u044B\u0439 \u043E\u0442\u0432\u0435\u0442\u0438\u043B
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u043E\u0439 \u0444\u0440\u0430\u0437\u043E\u0439:
    **\xAB\u0412 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u043D\u0435\u0442
    \u0446\u0430\u0440\u0441\u043A\u043E\u0433\u043E \u043F\u0443\u0442\u0438\xBB**. 
    ### \U0001F4DA \u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434:
    \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB \u0438 \u0434\u0440\u0443\u0433\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B  \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u043E,
    \u0445\u043E\u0442\u044F \u0431\u043E\u043B\u044C\u0448\u0430\u044F \u0447\u0430\u0441\u0442\u044C
    \u0435\u0433\u043E \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439 \u0443\u0442\u0435\u0440\u044F\u043D\u0430
    \u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E \u0441\u0441\u044B\u043B\u043A\u0430\u043C \u0434\u0440\u0443\u0433\u0438\u0445
    \u0430\u0432\u0442\u043E\u0440\u043E\u0432.  *   **\xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB
    (\u042D\u043B\u0435\u043C\u0435\u043D\u0442\u044B):** \u042D\u0442\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u0432 13 \u043A\u043D\u0438\u0433\u0430\u0445, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0430 \u0434\u0432\u0435 \u0442\u044B\u0441\u044F\u0447\u0438 \u043B\u0435\u0442
    \u0441\u0442\u0430\u043B \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u043C \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u043C
    \u043F\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u0412 \u043D\u0435\u043C \u0415\u0432\u043A\u043B\u0438\u0434 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u043E\u0431\u043E\u0431\u0449\u0438\u043B \u0432\u0441\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0439
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    (\u0424\u0430\u043B\u0435\u0441, \u041F\u0438\u0444\u0430\u0433\u043E\u0440,
    \u0415\u0432\u0434\u043E\u043A\u0441, \u0422\u0435\u044D\u0442\u0435\u0442).
    \u041E\u043D \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u043A\u0430\u043A \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u0434\u0435\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443, \u0438\u0441\u0445\u043E\u0434\u044F
    \u0438\u0437 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0439,
    5 \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442\u043E\u0432 \u0438 5 \u0430\u043A\u0441\u0438\u043E\u043C,
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0432\u044B\u0432\u0435\u043B
    465 \u0442\u0435\u043E\u0440\u0435\u043C. *   **\u0414\u0440\u0443\u0433\u0438\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435 \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u044F:**    
    *   **\xAB\u0414\u0430\u043D\u043D\u044B\u0435\xBB** \u2014 \u0432\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437.     *   **\xAB\u041E\u043F\u0442\u0438\u043A\u0430\xBB**
    \u0438 **\xAB\u041A\u0430\u0442\u043E\u043F\u0442\u0440\u0438\u043A\u0430\xBB**
    \u2014 \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043F\u0442\u0438\u043A\u0435, \u0433\u0434\u0435 \u043E\u043D \u0438\u0437\u043B\u043E\u0436\u0438\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u044B
    \u0438 \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044F \u0432 \u0437\u0435\u0440\u043A\u0430\u043B\u0430\u0445.    
    *   **\xAB\u0421\u0435\u0447\u0435\u043D\u0438\u044F \u043A\u0430\u043D\u043E\u043D\u0430\xBB
    (\u0438\u043B\u0438 \xAB\u0414\u0435\u043B\u0435\u043D\u0438\u0435 \u043A\u0430\u043D\u043E\u043D\u0430\xBB)**
    \u2014 \u0442\u0440\u0430\u043A\u0442\u0430\u0442 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u0443\u0437\u044B\u043A\u0438, \u0433\u0434\u0435 \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u044E\u0442\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0441\u043D\u043E\u0432\u044B \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u043E\u0432.     *   **\xAB\u041E
    \u0434\u0435\u043B\u0435\u043D\u0438\u0438 \u0444\u0438\u0433\u0443\u0440\xBB**
    \u2014 \u0434\u043E\u0448\u0435\u0434\u0448\u0435\u0435 \u0434\u043E \u043D\u0430\u0441
    \u0432 \u0430\u0440\u0430\u0431\u0441\u043A\u043E\u043C \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0435
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0435. *   **\u0423\u0442\u0435\u0440\u044F\u043D\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B:** \u0415\u0432\u043A\u043B\u0438\u0434 \u0442\u0430\u043A\u0436\u0435
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0447\u0435\u0442\u044B\u0440\u0435
    \u043A\u043D\u0438\u0433\u0438 \u043E \xAB\u041A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0435\u0447\u0435\u043D\u0438\u044F\u0445\xBB (\u0442\u0435\u043C\u0430
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0437\u0436\u0435 \u0440\u0430\u0437\u0432\u0438\u0442\u0430
    \u0410\u043F\u043E\u043B\u043B\u043E\u043D\u0438\u0435\u043C \u041F\u0435\u0440\u0433\u0441\u043A\u0438\u043C)
    \u0438 \xAB\u041F\u043E\u0440\u0438\u0437\u043C\u044B\xBB, \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u0435\u0433\u043E\u0434\u043D\u044F
    \u043C\u043E\u0436\u043D\u043E \u0440\u0435\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043B\u0438\u0448\u044C \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E \u043F\u043E
    \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u044F\u043C \u041F\u0430\u043F\u043F\u0430
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E. 
    \u0417\u0430 \u0441\u0432\u043E\u044E \u0436\u0438\u0437\u043D\u044C \u0415\u0432\u043A\u043B\u0438\u0434
    \u0441\u0442\u0430\u043B \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A\u043E\u043C
    \u0430\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B \u0438 \u0441\u043E\u0437\u0434\u0430\u043B \u0442\u0440\u0443\u0434,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043D\u0430 \u043C\u043D\u043E\u0433\u0438\u0435 \u0432\u0435\u043A\u0430 \u0432\u043F\u0435\u0440\u0435\u0434.
    \u0415\u0433\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F, \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u0430\u044F
    **\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439**, \u0438\u0437\u0443\u0447\u0430\u0435\u0442
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430
    \u0438 \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0441\u043D\u043E\u0432\u043E\u0439
    \u0448\u043A\u043E\u043B\u044C\u043D\u043E\u0433\u043E \u043A\u0443\u0440\u0441\u0430
    \u0432\u043E \u0432\u0441\u0435\u043C \u043C\u0438\u0440\u0435."
  shortBioEn: 
  interestingFactsRu: "\u041E \u0436\u0438\u0437\u043D\u0438 \u0415\u0432\u043A\u043B\u0438\u0434\u0430
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u0442\u0430\u043A \u043C\u0430\u043B\u043E,
    \u0447\u0442\u043E \u043A\u0430\u0436\u0434\u0430\u044F \u0434\u043E\u0448\u0435\u0434\u0448\u0430\u044F
    \u0434\u043E \u043D\u0430\u0441 \u0434\u0435\u0442\u0430\u043B\u044C \u2014 \u0443\u0436\u0435
    \u0441\u043E\u043A\u0440\u043E\u0432\u0438\u0449\u0435. \u0414\u0430\u0436\u0435
    \u0435\u0433\u043E \u043F\u043E\u0440\u0442\u0440\u0435\u0442\u044B \u2014 \u043F\u043B\u043E\u0434
    \u0444\u0430\u043D\u0442\u0430\u0437\u0438\u0438 \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u043E\u0432,
    \u0432\u0435\u0434\u044C \u043D\u0438 \u043E\u0434\u043D\u043E\u0439 \u043F\u0440\u0438\u0436\u0438\u0437\u043D\u0435\u043D\u043D\u043E\u0439
    \u0441\u0442\u0430\u0442\u0443\u0438 \u043D\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C.
    \u041D\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u0430 \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u0430 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445,
    \u0430 \u043F\u043E\u0440\u043E\u0439 \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432. \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435 \u0438\u0437 \u043D\u0438\u0445. 
    ### \U0001F4DC \u0422\u0430\u0439\u043D\u0430 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438:
    \u041E\u0448\u0438\u0431\u043A\u0430, \u0434\u043B\u0438\u0432\u0448\u0430\u044F\u0441\u044F
    \u0432\u0435\u043A\u0430  \u041D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438
    \u043C\u043D\u043E\u0433\u0438\u0445 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0439
    \u0443\u0447\u0435\u043D\u044B\u0445 \u043C\u0443\u0447\u0438\u043B \u0432\u043E\u043F\u0440\u043E\u0441:
    \u0430 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u043B\u0438
    \u043D\u0430\u0448 \u0415\u0432\u043A\u043B\u0438\u0434 \u043D\u0430 \u0441\u0430\u043C\u043E\u043C
    \u0434\u0435\u043B\u0435? \u041F\u0440\u043E\u0431\u043B\u0435\u043C\u0430 \u0431\u044B\u043B\u0430
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u0432 \u0414\u0440\u0435\u0432\u043D\u0435\u0439
    \u0413\u0440\u0435\u0446\u0438\u0438 \u0431\u044B\u043B\u043E \u043A\u0430\u043A
    \u043C\u0438\u043D\u0438\u043C\u0443\u043C \u0434\u0432\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u0441 \u044D\u0442\u0438\u043C
    \u0438\u043C\u0435\u043D\u0435\u043C: **\u0415\u0432\u043A\u043B\u0438\u0434-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A**
    \u0438 **\u0415\u0432\u043A\u043B\u0438\u0434 \u0438\u0437 \u041C\u0435\u0433\u0430\u0440\u044B**,
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444-\u0441\u043E\u043A\u0440\u0430\u0442\u0438\u043A,
    \u0436\u0438\u0432\u0448\u0438\u0439 \u043D\u0430 \u0441\u0442\u043E \u043B\u0435\u0442
    \u0440\u0430\u043D\u044C\u0448\u0435.   \u0418\u0437-\u0437\u0430 \u044D\u0442\u043E\u0433\u043E
    \u0441\u0440\u0435\u0434\u043D\u0435\u0432\u0435\u043A\u043E\u0432\u044B\u0435
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0447\u0438\u043A\u0438 \u0438 \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u0447\u0430\u0441\u0442\u043E
    \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u044F\u043B\u0438 \u0438\u0445 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438,
    \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u044F \u043D\u0430\u0448\u0435\u043C\u0443
    \u0433\u0435\u0440\u043E\u044E \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0434\u043E\u043B\u0433\u0443\u044E \u0436\u0438\u0437\u043D\u044C (\u043F\u043E\u0447\u0442\u0438
    400 \u043B\u0435\u0442!) \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u044B, \u043A \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u043E\u043D \u043D\u0435 \u0438\u043C\u0435\u043B \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F.
    \u041B\u0438\u0448\u044C \u0432 \u044D\u043F\u043E\u0445\u0443 \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043F\u0443\u0442\u0430\u043D\u0438\u0446\u0443 \u0443\u0434\u0430\u043B\u043E\u0441\u044C
    \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u0442\u044C, \u043D\u043E \u0438 \u0441\u0435\u0433\u043E\u0434\u043D\u044F
    \u043F\u0440\u0438 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0438
    \xAB\u0415\u0432\u043A\u043B\u0438\u0434\u0430\xBB \u0432\u0430\u0436\u043D\u043E
    \u0443\u0442\u043E\u0447\u043D\u044F\u0442\u044C: \u0442\u043E\u0433\u043E \u0441\u0430\u043C\u043E\u0433\u043E,
    \u0438\u0437 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438. 
    ### \U0001F451 \u0414\u0432\u0430 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u0430\u043D\u0435\u043A\u0434\u043E\u0442\u0430, \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0432\u0448\u0438\u0445
    \u0435\u0433\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440  \u0412\u0441\u0435,
    \u0447\u0442\u043E \u043C\u044B \u0437\u043D\u0430\u0435\u043C \u043E \u043B\u0438\u0447\u043D\u044B\u0445
    \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0430\u0445 \u0415\u0432\u043A\u043B\u0438\u0434\u0430,
    \u0443\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u0432
    \u0434\u0432\u0435 \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0435 \u0438\u0441\u0442\u043E\u0440\u0438\u0438,
    \u043F\u0435\u0440\u0435\u0441\u043A\u0430\u0437\u0430\u043D\u043D\u044B\u0435
    \u043F\u043E\u0437\u0434\u043D\u0438\u043C\u0438 \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u043C\u0438
    \u0430\u0432\u0442\u043E\u0440\u0430\u043C\u0438. \u041E\u043D\u0438 \u044F\u0440\u043A\u043E
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0437\u0443\u044E\u0442
    \u0435\u0433\u043E \u043A\u0430\u043A \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438 \u0438\u0440\u043E\u043D\u0438\u0447\u043D\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E. 
    *   **\xAB\u0412 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u043D\u0435\u0442
    \u0446\u0430\u0440\u0441\u043A\u0438\u0445 \u043F\u0443\u0442\u0435\u0439\xBB.**
    \u042D\u0442\u043E \u0441\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430. \u0426\u0430\u0440\u044C \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    I, \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C \u043D\u0430\u0443\u043A,
    \u0440\u0435\u0448\u0438\u043B \u0438\u0437\u0443\u0447\u0438\u0442\u044C \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u043F\u043E \xAB\u041D\u0430\u0447\u0430\u043B\u0430\u043C\xBB. \u0423\u0431\u0435\u0434\u0438\u0432\u0448\u0438\u0441\u044C,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0441\u043B\u043E\u0436\u043D\u043E, \u043E\u043D \u0441\u043F\u0440\u043E\u0441\u0438\u043B
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430, \u043D\u0435\u0442 \u043B\u0438 \u0431\u043E\u043B\u0435\u0435
    \u043B\u0435\u0433\u043A\u043E\u0433\u043E \u0441\u043F\u043E\u0441\u043E\u0431\u0430.
    \u041E\u0442\u0432\u0435\u0442 \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0441\u0442\u0430\u043B
    \u043A\u0440\u044B\u043B\u0430\u0442\u043E\u0439 \u0444\u0440\u0430\u0437\u043E\u0439,
    \u043E\u0437\u043D\u0430\u0447\u0430\u044E\u0449\u0435\u0439, \u0447\u0442\u043E
    \u0434\u043B\u044F \u043F\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043D\u0430\u0443\u043A\u0438 \u043D\u0435\u0442 \u043F\u0440\u0438\u0432\u0438\u043B\u0435\u0433\u0438\u0439
    \u0438 \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0445 \u043F\u0443\u0442\u0435\u0439
    \u2014 \u043D\u0443\u0436\u043D\u043E \u0442\u0440\u0443\u0434\u0438\u0442\u044C\u0441\u044F. 
    *   **\xAB\u0414\u0430\u0439 \u0435\u043C\u0443 \u0442\u0440\u0438 \u043E\u0431\u043E\u043B\u0430\xBB.**
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u043E\u0434\u0438\u043D \u0438\u0437
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432, \u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0430\u0447\u0430\u0432 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435,
    \u0441\u043F\u0440\u043E\u0441\u0438\u043B \u0415\u0432\u043A\u043B\u0438\u0434\u0430:
    \xAB\u0410 \u043A\u0430\u043A\u0430\u044F \u043C\u043D\u0435 \u0431\u0443\u0434\u0435\u0442
    \u043F\u043E\u043B\u044C\u0437\u0430 \u043E\u0442 \u044D\u0442\u0438\u0445 \u0437\u043D\u0430\u043D\u0438\u0439?\xBB.
    \u0415\u0432\u043A\u043B\u0438\u0434, \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u0431\u044B\u043B\u0430 \u0447\u0443\u0436\u0434\u0430 \u043C\u0435\u0440\u043A\u0430\u043D\u0442\u0438\u043B\u044C\u043D\u043E\u0441\u0442\u044C,
    \u043D\u0435 \u0441\u0442\u0430\u043B \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0442\u044C
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0432\u044B\u0433\u043E\u0434\u0443.
    \u0412\u043C\u0435\u0441\u0442\u043E \u044D\u0442\u043E\u0433\u043E \u043E\u043D
    \u043F\u043E\u0434\u043E\u0437\u0432\u0430\u043B \u0441\u043B\u0443\u0433\u0443
    \u0438 \u0432\u0435\u043B\u0435\u043B \u0434\u0430\u0442\u044C \u0443\u0447\u0435\u043D\u0438\u043A\u0443
    \u043C\u043E\u043D\u0435\u0442\u0443, \u0441\u043A\u0430\u0437\u0430\u0432: \xAB**\u0414\u0430\u0439
    \u0435\u043C\u0443 \u0434\u0435\u043D\u0435\u0433, \u0440\u0430\u0437 \u0435\u043C\u0443
    \u0445\u043E\u0447\u0435\u0442\u0441\u044F \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C
    \u043F\u0440\u0438\u0431\u044B\u043B\u044C \u043E\u0442 \u043D\u0430\u0443\u043A\u0438**\xBB.
    \u042D\u0442\u043E\u0442 \u043F\u043E\u0441\u0442\u0443\u043F\u043E\u043A \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u0438\u0432\u0430\u0435\u0442
    \u0435\u0433\u043E \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u0435, \u0447\u0442\u043E
    \u043D\u0430\u0443\u043A\u0430 \u2014 \u044D\u0442\u043E \u0441\u0430\u043C\u043E\u0446\u0435\u043D\u043D\u043E\u0441\u0442\u044C,
    \u0430 \u043D\u0435 \u0440\u0435\u043C\u0435\u0441\u043B\u043E \u0434\u043B\u044F
    \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u043A\u0430.  ### \U0001F4DA \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB:
    \u041A\u043D\u0438\u0433\u0430-\u0440\u0435\u043A\u043E\u0440\u0434\u0441\u043C\u0435\u043D 
    \u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434 \u0415\u0432\u043A\u043B\u0438\u0434\u0430,
    \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB (\u0432 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u0435
    \u2014 13 \u043A\u043D\u0438\u0433, \u0430 \u043D\u0435 15, \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0434\u0432\u0435 \u0434\u043E\u043F\u0438\u0441\u0430\u043B\u0438 \u043F\u043E\u0437\u0436\u0435),
    \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u0440\u0435\u043A\u043E\u0440\u0434.  *   **\u041F\u043E \u0442\u0438\u0440\u0430\u0436\u0430\u043C
    \u0438 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E** \u0435\u0433\u043E
    \u0447\u0430\u0441\u0442\u043E \u0441\u0442\u0430\u0432\u044F\u0442 \u043D\u0430
    \u0432\u0442\u043E\u0440\u043E\u0435 \u043C\u0435\u0441\u0442\u043E \u043F\u043E\u0441\u043B\u0435
    \u0411\u0438\u0431\u043B\u0438\u0438. \u041E\u043A\u043E\u043B\u043E 2000 \u043B\u0435\u0442
    \u043E\u043D \u0431\u044B\u043B \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u043C
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u043C \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0432\u043E \u0432\u0441\u0435\u043C \u043C\u0438\u0440\u0435. \u0422\u043E\u043B\u044C\u043A\u043E
    \u0434\u043E XX \u0432\u0435\u043A\u0430 \u0435\u0433\u043E \u0438\u0437\u0434\u0430\u0432\u0430\u043B\u0438
    \u0431\u043E\u043B\u0435\u0435 2500 \u0440\u0430\u0437. *   **\u0423\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0435
    \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435.** \u042D\u0442\u043E \u0431\u044B\u043B\u0438
    \u043D\u0435 \u043F\u0435\u0440\u0432\u044B\u0435 \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438, \u043D\u043E \u0432\u0441\u0435
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0435
    \u0442\u0440\u0443\u0434\u044B \u0431\u044B\u043B\u0438 \u0437\u0430\u0431\u044B\u0442\u044B,
    \u0430 \u0442\u0440\u0443\u0434 \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u0441\u0442\u0430\u043B
    \u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u043C. \u041E\u043D
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u043E\u0431\u0440\u0430\u043B
    \u0447\u0443\u0436\u0438\u0435 \u0437\u043D\u0430\u043D\u0438\u044F, \u0430 \u0441\u043E\u0437\u0434\u0430\u043B
    \u0441\u0442\u0440\u043E\u0439\u043D\u0443\u044E \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0438\u0437 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0439,
    \u0430\u043A\u0441\u0438\u043E\u043C \u0438 \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442\u043E\u0432,
    \u0447\u0435\u043C \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.  ### \U0001F52D
    \u0423\u0447\u0435\u043D\u044B\u0439 \u0441 \u0434\u0443\u0448\u043E\u0439 \u043C\u0443\u0437\u044B\u043A\u0430\u043D\u0442\u0430
    \u0438 \u043E\u043F\u0442\u0438\u043A\u0430\u043C\u0438  \u0415\u0432\u043A\u043B\u0438\u0434
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \xAB\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u043E\u043C\xBB.
    \u0415\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B \u043F\u0440\u043E\u0441\u0442\u0438\u0440\u0430\u043B\u0438\u0441\u044C
    \u0434\u0430\u043B\u0435\u043A\u043E \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u044B
    \u0447\u0435\u0440\u0442\u0435\u0436\u0435\u0439.  *   **\u041E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u044C
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043F\u0442\u0438\u043A\u0438.** \u0415\u0433\u043E \u0442\u0440\u0430\u043A\u0442\u0430\u0442
    \xAB\u041E\u043F\u0442\u0438\u043A\u0430\xBB \u2014 \u043E\u0434\u043D\u043E
    \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u0434\u043E\u0448\u0435\u0434\u0448\u0438\u0445
    \u0434\u043E \u043D\u0430\u0441 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    \u043E \u0441\u0432\u0435\u0442\u0435. \u041E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u0430\u043A\u043E\u043D \u043F\u0440\u044F\u043C\u043E\u043B\u0438\u043D\u0435\u0439\u043D\u043E\u0433\u043E
    \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \u0441\u0432\u0435\u0442\u0430 \u0438 \u0437\u0430\u043A\u043E\u043D \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044F,
    \u0437\u0430\u043B\u043E\u0436\u0438\u0432 \u043E\u0441\u043D\u043E\u0432\u044B
    \u0434\u043B\u044F \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u043E\u0432
    \u044D\u043F\u043E\u0445\u0438 \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u044B \u0434\u043B\u044F
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u043B\u0438\u043D\u0435\u0439\u043D\u043E\u0439
    \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u044B. *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0438 \u043C\u0443\u0437\u044B\u043A\u0430\u043D\u0442.** \u0415\u0432\u043A\u043B\u0438\u0434
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0442\u0440\u0430\u043A\u0442\u0430\u0442
    \xAB\u0421\u0435\u0447\u0435\u043D\u0438\u044F \u043A\u0430\u043D\u043E\u043D\u0430\xBB
    \u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u0443\u0437\u044B\u043A\u0438. \u041E\u043D
    \u043E\u043F\u0438\u0441\u0430\u043B **\u043C\u043E\u043D\u043E\u0445\u043E\u0440\u0434**
    (\u043E\u0434\u043D\u043E\u0441\u0442\u0440\u0443\u043D\u043D\u044B\u0439 \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442) \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043B \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u044B, \u043F\u043E\u043A\u0430\u0437\u0430\u0432,
    \u0447\u0442\u043E \u0437\u0432\u0443\u0447\u0430\u043D\u0438\u0435 \u0441\u0442\u0440\u0443\u043D\u044B
    \u043F\u043E\u0434\u0447\u0438\u043D\u044F\u0435\u0442\u0441\u044F \u043F\u0440\u043E\u0441\u0442\u044B\u043C
    \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u043C \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u044F\u043C.
    \u0422\u0430\u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C \u0443 \u0438\u0441\u0442\u043E\u043A\u043E\u0432
    \u0431\u0443\u0434\u0443\u0449\u0438\u0445 \u043A\u043B\u0430\u0432\u0438\u0448\u043D\u044B\u0445
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432.  ###
    \U0001F30C \u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441, \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0438\u0439
    \u043C\u0438\u0440  \u0421\u0430\u043C\u044B\u0439 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442 \u0432 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u0441\u043B\u0443\u0447\u0438\u043B\u0441\u044F
    \u0441\u043F\u0443\u0441\u0442\u044F **\u0431\u043E\u043B\u0435\u0435 \u0447\u0435\u043C
    2000 \u043B\u0435\u0442** \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438. 
    \u0413\u043B\u0430\u0432\u043D\u0430\u044F \xAB\u043D\u0435\u0437\u044B\u0431\u043B\u0435\u043C\u0430\u044F\xBB
    \u0438\u0441\u0442\u0438\u043D\u0430 \u0435\u0433\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u2014 **\u041F\u044F\u0442\u044B\u0439 \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442**
    \u043E \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u044F\u043C\u044B\u0445 \u2014 \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0430\u0445\u0438\u043B\u043B\u0435\u0441\u043E\u0432\u043E\u0439 \u043F\u044F\u0442\u043E\u0439.
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432\u0435\u043A\u0430\u043C\u0438
    \u043F\u044B\u0442\u0430\u043B\u0438\u0441\u044C \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u0435\u0433\u043E \u043A\u0430\u043A \u0442\u0435\u043E\u0440\u0435\u043C\u0443,
    \u043D\u043E \u0431\u0435\u0437\u0443\u0441\u043F\u0435\u0448\u043D\u043E. \u0412
    XIX \u0432\u0435\u043A\u0435 \u0441\u0440\u0430\u0437\u0443 \u0434\u0432\u043E\u0435
    \u0443\u0447\u0435\u043D\u044B\u0445, \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439
    \u0438 \u0420\u0438\u043C\u0430\u043D, \u043F\u043E\u0448\u043B\u0438 \u0434\u0440\u0443\u0433\u0438\u043C
    \u043F\u0443\u0442\u0435\u043C: \u043E\u043D\u0438 **\u043E\u0442\u0431\u0440\u043E\u0441\u0438\u043B\u0438
    \u044D\u0442\u043E\u0442 \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442** \u0438
    \u0441\u043E\u0437\u0434\u0430\u043B\u0438 \u043D\u043E\u0432\u044B\u0435, **\u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u044B
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438**, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442 \u0438\u0441\u043A\u0440\u0438\u0432\u043B\u0435\u043D\u043D\u044B\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430.   \u0418\u0440\u043E\u043D\u0438\u044F
    \u0441\u0443\u0434\u044C\u0431\u044B \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E
    \u0438\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u0438 \xAB\u043D\u0435\u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0435\xBB
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u043F\u043E\u0437\u0436\u0435
    \u043B\u0435\u0433\u043B\u0438 \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u043E\u0431\u0449\u0435\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430. \u0422\u0430\u043A \u0441\u0438\u0441\u0442\u0435\u043C\u0430,
    \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u0430\u044F \u0415\u0432\u043A\u043B\u0438\u0434\u043E\u043C
    \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F \u043C\u0438\u0440\u0430,
    \u0447\u0435\u0440\u0435\u0437 \u0442\u044B\u0441\u044F\u0447\u0435\u043B\u0435\u0442\u0438\u044F
    \u043F\u043E\u043C\u043E\u0433\u043B\u0430 \u043F\u043E\u043D\u044F\u0442\u044C,
    \u0447\u0442\u043E \u043C\u0438\u0440 \u0443\u0441\u0442\u0440\u043E\u0435\u043D
    \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u0441\u043B\u043E\u0436\u043D\u0435\u0435."
