    \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C \u043F\u0440\u0438\u0432\u0435\u0441\u0442\u0438
    \u043A \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u043E \u043E\u0442\u043B\u0438\u0447\u0430\u044E\u0449\u0435\u043C\u0443\u0441\u044F
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0443. \u042D\u0442\u043E
    \u044F\u0432\u043B\u0435\u043D\u0438\u0435, \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u043E\u0435
    **\u0434\u0435\u0442\u0435\u0440\u043C\u0438\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u043C
    \u0445\u0430\u043E\u0441\u043E\u043C**, \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0434\u0430\u0436\u0435 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0434\u0435\u0442\u0435\u0440\u043C\u0438\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043C\u043E\u0433\u0443\u0442 \u0432\u0435\u0441\u0442\u0438
    \u0441\u0435\u0431\u044F \u043D\u0435\u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0443\u0435\u043C\u043E. 
    ### \U0001F52C \u0424\u0438\u0437\u0438\u043A\u0430: \u041D\u0430 \u043F\u0443\u0442\u0438
    \u043A \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438 
    \u0412 \u0444\u0438\u0437\u0438\u043A\u0435 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438 XX \u0432\u0435\u043A\u0430. 
    *   **\u041F\u0440\u0438\u043D\u0446\u0438\u043F \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438**:
    \u0417\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043B\u0435\u0442
    \u0434\u043E \u0440\u0430\u0431\u043E\u0442 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    **\u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438**
    \u043A\u0430\u043A \u043E\u0431\u0449\u0438\u0439 \u0437\u0430\u043A\u043E\u043D
    \u043F\u0440\u0438\u0440\u043E\u0434\u044B. *   **\u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u0421\u0422\u041E**:
    \u0412 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0445 1898-1905
    \u0433\u043E\u0434\u043E\u0432 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u044E\u0442\u0441\u044F
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u0441\u0435
    \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0435 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u044B
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438:
    \u0443\u0441\u043B\u043E\u0432\u043D\u043E\u0441\u0442\u044C \u043F\u043E\u043D\u044F\u0442\u0438\u044F
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0441\u0442\u0438,
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u041B\u043E\u0440\u0435\u043D\u0446\u0430 \u0438 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043D\u043E\u0441\u0442\u044C
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u041C\u0430\u043A\u0441\u0432\u0435\u043B\u043B\u0430.
    \u0415\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u043B\u0438
    \u043F\u043E\u0447\u0432\u0443 \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u0441\u043C\u043E\u0442\u0440\u0430
    \u043F\u043E\u043D\u044F\u0442\u0438\u0439 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430
    \u0438 \u0432\u0440\u0435\u043C\u0435\u043D\u0438.  ### \U0001F4DA \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F
    \u043D\u0430\u0443\u043A\u0438: \u041A\u043E\u043D\u0432\u0435\u043D\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0437\u043C 
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u043C \u043D\u0430\u0443\u043A\u0438.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u0430\u044F \u0438\u0434\u0435\u044F,
    \u0440\u0430\u0437\u0432\u0438\u0442\u0430\u044F \u0432 \u0442\u0440\u0443\u0434\u0435
    \xAB\u041D\u0430\u0443\u043A\u0430 \u0438 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430\xBB
    (1902), \u2014 \u044D\u0442\u043E **\u043A\u043E\u043D\u0432\u0435\u043D\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0437\u043C**. 
    *   **\u0421\u0443\u0442\u044C \u043A\u043E\u043D\u0432\u0435\u043D\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0437\u043C\u0430**:
    \u041E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u044B \u043D\u0430\u0443\u043A\u0438
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0430\u043A\u0441\u0438\u043E\u043C\u044B
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438) \u043D\u0435 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E\u0439 \u0438\u0441\u0442\u0438\u043D\u043E\u0439
    \u0438\u043B\u0438 \u043B\u043E\u0436\u044C\u044E. \u042D\u0442\u043E **\u0441\u043E\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u044F
    (\u043A\u043E\u043D\u0432\u0435\u043D\u0446\u0438\u0438)**, \u0443\u0434\u043E\u0431\u043D\u044B\u0435
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u044B \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u043C \u0434\u043B\u044F
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F \u043C\u0438\u0440\u0430. *  
    **\u0420\u043E\u043B\u044C \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B**:
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u043E
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u0440\u043E\u043B\u044C
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u0432 \u043D\u0430\u0443\u043A\u0435,
    \u043F\u043E\u043A\u0430\u0437\u0430\u0432, \u0447\u0442\u043E \u043E\u043D\u0430
    \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u0430 \u0434\u043B\u044F
    \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u044F \u0444\u0430\u043A\u0442\u043E\u0432
    \u0438 \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F \u0442\u0435\u043E\u0440\u0438\u0439.
    \u041F\u043E \u0435\u0433\u043E \u043C\u0435\u0442\u043A\u043E\u043C\u0443 \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044E,
    \u043D\u0430\u0443\u043A\u0430 \u0441\u0442\u0440\u043E\u0438\u0442\u0441\u044F
    \u0438\u0437 \u0444\u0430\u043A\u0442\u043E\u0432, \u043A\u0430\u043A \u0434\u043E\u043C
    \u0438\u0437 \u043A\u0438\u0440\u043F\u0438\u0447\u0435\u0439, \u043D\u043E \u043F\u0440\u043E\u0441\u0442\u043E\u0435
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435 \u0444\u0430\u043A\u0442\u043E\u0432
    \u0435\u0449\u0435 \u043D\u0435 \u0435\u0441\u0442\u044C \u043D\u0430\u0443\u043A\u0430.
    *   **\u041F\u0440\u0438\u043D\u0446\u0438\u043F \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u044F**:
    \u041E\u043D \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u044F,
    \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u043D\u043E\u0432\u0430\u044F \u0442\u0435\u043E\u0440\u0438\u044F \u043D\u0435
    \u043E\u0442\u0432\u0435\u0440\u0433\u0430\u0435\u0442 \u0441\u0442\u0430\u0440\u0443\u044E,
    \u0430 \u043B\u0438\u0448\u044C \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u0433\u0440\u0430\u043D\u0438\u0446\u044B \u0435\u0451 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043C\u043E\u0441\u0442\u0438. 
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u043A\u043D\u0438\u0433\u0430
    \xAB\u041D\u0430\u0443\u043A\u0430 \u0438 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430\xBB
    \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u043B\u0430 \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E
    \u0410\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430
    \u0438 \u0441\u0442\u0430\u043B\u0430 \u043E\u0434\u043D\u043E\u0439 \u0438\u0437
    \u043E\u0442\u043F\u0440\u0430\u0432\u043D\u044B\u0445 \u0442\u043E\u0447\u0435\u043A
    \u0434\u043B\u044F \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438. 
    \u0412 \u0446\u0435\u043B\u043E\u043C, \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u2014 \u044D\u0442\u043E \u043F\u0440\u0438\u043C\u0435\u0440 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0433\u043B\u0443\u0431\u0438\u043D\u044B. \u041E\u043D \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0435\u0448\u0430\u043B \u0437\u0430\u0434\u0430\u0447\u0438,
    \u043D\u043E \u0438 \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B \u043D\u043E\u0432\u044B\u0435
    \u044F\u0437\u044B\u043A\u0438 \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u043C\u0438\u0440\u0430, \u043C\u043D\u043E\u0433\u0438\u0435 \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F
    \u0432 \u0446\u0435\u043D\u0442\u0440\u0435 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438."
  achievementsEn: 
  personalLifeRu: "\u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F,
    \u0434\u0435\u0442\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u0445\u0440\u043E\u043D\u0438\u043A\u0430 \u0436\u0438\u0437\u043D\u0438 \u0410\u043D\u0440\u0438
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u2014 \u043E\u0442 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0434\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0445 \u0434\u043D\u0435\u0439,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043C\u044B \u043F\u0440\u043E\u0441\u043B\u0435\u0434\u0438\u043C
    \u0435\u0433\u043E \u043F\u0443\u0442\u044C \u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438. 
    ### \U0001F476 \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u0434\u0435\u0442\u0441\u0442\u0432\u043E:
    \u0424\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435 \u0433\u0435\u043D\u0438\u044F 
    \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    **29 \u0430\u043F\u0440\u0435\u043B\u044F 1854 \u0433\u043E\u0434\u0430** \u0432
    \u043C\u0435\u0441\u0442\u0435\u0447\u043A\u0435 \u0421\u0438\u0442\u0435-\u0414\u044E\u043A\u0430\u043B\u044C
    \u0431\u043B\u0438\u0437 \u0433\u043E\u0440\u043E\u0434\u0430 \u041D\u0430\u043D\u0441\u0438
    (\u041B\u043E\u0442\u0430\u0440\u0438\u043D\u0433\u0438\u044F, \u0424\u0440\u0430\u043D\u0446\u0438\u044F).
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, **\u041B\u0435\u043E\u043D \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435**,
    \u0431\u044B\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u044B \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u041D\u0430\u043D\u0441\u0438, \u0430 \u043C\u0430\u0442\u044C, **\u042D\u0436\u0435\u043D\u0438
    \u041B\u0430\u043D\u0443\u0430**, \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B\u0430
    \u0441\u0435\u0431\u044F \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u044E
    \u0434\u0435\u0442\u0435\u0439 \u2014 \u0410\u043D\u0440\u0438 \u0438 \u0435\u0433\u043E
    \u043C\u043B\u0430\u0434\u0448\u0435\u0439 \u0441\u0435\u0441\u0442\u0440\u044B
    \u0410\u043B\u0438\u043D\u044B. \u0421\u0435\u043C\u044C\u044F \u0431\u044B\u043B\u0430
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439: \u0435\u0433\u043E
    \u0434\u0432\u043E\u044E\u0440\u043E\u0434\u043D\u044B\u0439 \u0431\u0440\u0430\u0442
    \u0420\u0430\u0439\u043C\u043E\u043D \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0441\u0442\u0430\u043B \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438.  \u0421 \u0440\u0430\u043D\u043D\u0435\u0433\u043E
    \u0434\u0435\u0442\u0441\u0442\u0432\u0430 \u0437\u0430 \u0410\u043D\u0440\u0438
    \u0437\u0430\u043A\u0440\u0435\u043F\u0438\u043B\u0430\u0441\u044C \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044F
    \u043D\u0435\u043E\u0431\u044B\u0447\u0430\u0439\u043D\u043E **\u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0433\u043E**
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430. \u041E\u043D \u043C\u043E\u0433
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043E\u0442\u043A\u043B\u044E\u0447\u0430\u0442\u044C\u0441\u044F
    \u043E\u0442 \u0432\u043D\u0435\u0448\u043D\u0435\u0433\u043E \u043C\u0438\u0440\u0430,
    \u043F\u043E\u0433\u0440\u0443\u0436\u0430\u044F\u0441\u044C \u0432 \u0441\u0432\u043E\u0438
    \u043C\u044B\u0441\u043B\u0438, \u0447\u0442\u043E \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u043E
    \u043E \u043D\u0435\u043C \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043B\u0435\u0433\u0435\u043D\u0434. \u042D\u0442\u0430 \u0447\u0435\u0440\u0442\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D \u043F\u0440\u043E\u043D\u0435\u0441
    \u0447\u0435\u0440\u0435\u0437 \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C,
    \u0431\u044B\u043B\u0430 \u043D\u0435 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043A\u043E\u043C,
    \u0430 \u0441\u043A\u043E\u0440\u0435\u0435 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0435\u0433\u043E \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u043A \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439
    \u043A\u043E\u043D\u0446\u0435\u043D\u0442\u0440\u0430\u0446\u0438\u0438.  \u0412
    \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u0410\u043D\u0440\u0438 \u043F\u0435\u0440\u0435\u043D\u0435\u0441
    \u0442\u044F\u0436\u0435\u043B\u0443\u044E \u0444\u043E\u0440\u043C\u0443 **\u0434\u0438\u0444\u0442\u0435\u0440\u0438\u0438**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u0438\u0432\u0435\u043B\u0430
    \u043A \u043E\u0441\u043B\u043E\u0436\u043D\u0435\u043D\u0438\u044F\u043C: \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C\u0443
    \u043F\u0430\u0440\u0430\u043B\u0438\u0447\u0443 \u043D\u043E\u0433 \u0438 \u043C\u044F\u0433\u043A\u043E\u0433\u043E
    \u043D\u0435\u0431\u0430. \u041D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043C\u0435\u0441\u044F\u0446\u0435\u0432 \u043E\u043D \u0431\u044B\u043B \u043F\u0440\u0438\u043A\u043E\u0432\u0430\u043D
    \u043A \u043F\u043E\u0441\u0442\u0435\u043B\u0438 \u0438 \u043D\u0435 \u043C\u043E\u0433
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C. \u042D\u0442\u043E \u0432\u0440\u0435\u043C\u044F
    \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043E\u0431\u043E\u0441\u0442\u0440\u0438\u043B\u043E \u0435\u0433\u043E \u0441\u043B\u0443\u0445
    \u0438 \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044E
    \u0440\u0435\u0434\u043A\u043E\u0439 \u0444\u043E\u0440\u043C\u044B **\u0441\u0438\u043D\u0435\u0441\u0442\u0435\u0437\u0438\u0438**
    \u2014 \u043E\u043D \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B
    \u0437\u0432\u0443\u043A\u0438 \u0432 \u0446\u0432\u0435\u0442\u0435, \u0438
    \u044D\u0442\u0430 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C \u0443 \u043D\u0435\u0433\u043E
    \u043D\u0430 \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C. \u041A \u0441\u0447\u0430\u0441\u0442\u044C\u044E,
    \u043E\u043D \u0441\u043C\u043E\u0433 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C\u0441\u044F,
    \u043D\u043E \u0431\u043E\u043B\u0435\u0437\u043D\u044C \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0441\u0434\u0435\u043B\u0430\u043B\u0430 \u0435\u0433\u043E \u043C\u044F\u0433\u043A\u0438\u043C
    \u0438 \u0437\u0430\u0441\u0442\u0435\u043D\u0447\u0438\u0432\u044B\u043C.  \u0418\u0437-\u0437\u0430
    \u0441\u043B\u0430\u0431\u043E\u0433\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F
    \u0435\u0433\u043E \u0434\u043E\u043C\u0430\u0448\u043D\u0438\u043C \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435\u043C
    \u0437\u0430\u043D\u044F\u043B\u0441\u044F \u0434\u0440\u0443\u0433 \u0441\u0435\u043C\u044C\u0438,
    **\u0410\u043B\u044C\u0444\u043E\u043D\u0441 \u0413\u0438\u043D\u0446\u0435\u043B\u0438\u043D**.
    \u041E\u043D \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B \u0441 \u0410\u043D\u0440\u0438
    \u0431\u0435\u0441\u0435\u0434\u044B, \u043F\u043E\u0447\u0442\u0438 \u043D\u0435
    \u0442\u0440\u0435\u0431\u0443\u044F \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442. \u042D\u0442\u043E \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u043E
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u0443\u044E \u043C\u0430\u043D\u0435\u0440\u0443
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0443\u0441\u0432\u0430\u0438\u0432\u0430\u0442\u044C
    \u0438 \u043E\u0431\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0442\u044C
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E \u0432 \u0443\u043C\u0435,
    \u0431\u0435\u0437 \u0444\u0438\u043A\u0441\u0430\u0446\u0438\u0438 \u043D\u0430
    \u0431\u0443\u043C\u0430\u0433\u0435, \u0447\u0442\u043E \u0432 \u0431\u0443\u0434\u0443\u0449\u0435\u043C
    \u043F\u043E\u0440\u043E\u0436\u0434\u0430\u043B\u043E \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u0438 \u0441 \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u044B\u043C
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C.  ### \U0001F393
    \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435: \u041F\u0443\u0442\u044C
    \u043E\u0442 \u0441\u043B\u043E\u0432\u0435\u0441\u043D\u043E\u0441\u0442\u0438
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435  \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0445\u043E\u0440\u043E\u0448\u0435\u0439 \u0434\u043E\u043C\u0430\u0448\u043D\u0435\u0439
    \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0435, \u0432 **8,5 \u043B\u0435\u0442**
    \u0410\u043D\u0440\u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0441\u0440\u0430\u0437\u0443
    \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439 \u043A\u043B\u0430\u0441\u0441
    \u043B\u0438\u0446\u0435\u044F \u041D\u0430\u043D\u0441\u0438. \u0412 \u043B\u0438\u0446\u0435\u0435
    \u0435\u0433\u043E \u043E\u0442\u043C\u0435\u0447\u0430\u043B\u0438 \u043A\u0430\u043A
    \u043F\u0440\u0438\u043B\u0435\u0436\u043D\u043E\u0433\u043E \u0438 \u043B\u044E\u0431\u043E\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u0438\u043A\u0430, \u0430 \u043E\u0434\u043D\u043E \u0438\u0437
    \u0435\u0433\u043E \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439 \u043F\u043E
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u043C\u0443 \u044F\u0437\u044B\u043A\u0443
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u043D\u0430\u0437\u0432\u0430\u043B
    \xAB\u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u043C \u0448\u0435\u0434\u0435\u0432\u0440\u043E\u043C\xBB.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u043F\u043E\u043D\u0430\u0447\u0430\u043B\u0443
    \u0435\u0433\u043E \u0441\u0442\u0440\u0430\u0441\u0442\u044C\u044E \u0431\u044B\u043B\u0430
    **\u0441\u043B\u043E\u0432\u0435\u0441\u043D\u043E\u0441\u0442\u044C**, \u0430
    \u043D\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430.  \u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u0439
    \u043C\u043E\u043C\u0435\u043D\u0442 \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u0434\u0438\u043D \u0438\u0437 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u043B\u0438\u0446\u0435\u044F \u043F\u0440\u0438\u0448\u0435\u043B \u043A \u0435\u0433\u043E
    \u043C\u0430\u0442\u0435\u0440\u0438 \u0438 \u0432\u0437\u0432\u043E\u043B\u043D\u043E\u0432\u0430\u043D\u043D\u043E
    \u0437\u0430\u044F\u0432\u0438\u043B: \"\u041C\u0430\u0434\u0430\u043C, \u0432\u0430\u0448
    \u0441\u044B\u043D \u0431\u0443\u0434\u0435\u0442 \u0432\u0435\u043B\u0438\u043A\u0438\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C!\". \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u044D\u0442\u043E, \u0410\u043D\u0440\u0438 \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u043F\u0435\u0440\u0435\u0448\u0435\u043B \u043D\u0430 \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0441\u043B\u043E\u0432\u0435\u0441\u043D\u043E\u0441\u0442\u0438 \u0438 **5
    \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1871 \u0433\u043E\u0434\u0430** \u0443\u0441\u043F\u0435\u0448\u043D\u043E
    \u0441\u0434\u0430\u043B \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u044B \u043D\u0430
    \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430 \u0441\u043B\u043E\u0432\u0435\u0441\u043D\u043E\u0441\u0442\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E \u043F\u0443\u0442\u044C
    \u043A \u043D\u0430\u0443\u043A\u0435 \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u044F\u043C\u043E\u043B\u0438\u043D\u0435\u0439\u043D\u044B\u043C.
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F **\u0444\u0440\u0430\u043D\u043A\u043E-\u043F\u0440\u0443\u0441\u0441\u043A\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B** (1870\u20131871) \u041D\u0430\u043D\u0441\u0438
    \u0431\u044B\u043B \u043E\u043A\u043A\u0443\u043F\u0438\u0440\u043E\u0432\u0430\u043D
    \u043D\u0435\u043C\u0446\u0430\u043C\u0438. \u0428\u0435\u0441\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u0438\u043B\u0435\u0442\u043D\u0438\u0439
    \u0410\u043D\u0440\u0438 \u043F\u043E\u043C\u043E\u0433\u0430\u043B \u043E\u0442\u0446\u0443
    \u0432 \u0433\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u0435 \u0434\u043B\u044F
    \u0440\u0430\u043D\u0435\u043D\u044B\u0445, \u0430 \u0437\u0430\u0442\u0435\u043C,
    \u043F\u043E\u0442\u0440\u044F\u0441\u0435\u043D\u043D\u044B\u0439 \u043F\u043E\u0440\u0430\u0436\u0435\u043D\u0438\u0435\u043C
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438, \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u043E\u043D\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0430 \u0442\u0435\u043C\u0443: **\"\u041A\u0430\u043A
    \u043C\u043E\u0436\u0435\u0442 \u043D\u0430\u0446\u0438\u044F \u0432\u043E\u0437\u0432\u044B\u0441\u0438\u0442\u044C\u0441\u044F?\"**. 
    \u0412 \u0442\u043E\u043C \u0436\u0435 1871 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0440\u0435\u0448\u0438\u043B \u0441\u0434\u0430\u0432\u0430\u0442\u044C \u044D\u043A\u0437\u0430\u043C\u0435\u043D
    \u043D\u0430 \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430
    \u043D\u0430\u0443\u043A. \u0418 \u0437\u0434\u0435\u0441\u044C \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C
    \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0441\u0442\u044C: \u043E\u043F\u043E\u0437\u0434\u0430\u0432
    \u0438 \u043D\u0435\u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E \u043F\u043E\u043D\u044F\u0432
    \u0437\u0430\u0434\u0430\u043D\u0438\u0435, \u043E\u043D **\u043F\u0440\u043E\u0432\u0430\u043B\u0438\u043B
    \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435**,
    \u043D\u0430\u0447\u0430\u0432 \u0438\u0437\u043B\u0430\u0433\u0430\u0442\u044C
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u0434\u0440\u0443\u0433\u043E\u0439
    \u0432\u043E\u043F\u0440\u043E\u0441. \u041A \u0441\u0447\u0430\u0441\u0442\u044C\u044E,
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u0437\u043D\u0430\u043B\u0438
    \u043E \u0435\u0433\u043E \u0442\u0430\u043B\u0430\u043D\u0442\u0435 \u0438,
    \u0437\u0430\u043A\u0440\u044B\u0432 \u0433\u043B\u0430\u0437\u0430 \u043D\u0430
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438, \u043F\u0440\u0438\u043D\u044F\u043B\u0438
    \u0435\u0433\u043E \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0439 \u043E\u0442\u0432\u0435\u0442
    \u043D\u0430 \u0443\u0441\u0442\u043D\u043E\u043C \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0435. 
    ### \u26CF\uFE0F \u041D\u0430\u0447\u0430\u043B\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B:
    \u041E\u0442 \u0448\u0430\u0445\u0442 \u0434\u043E \u0421\u043E\u0440\u0431\u043E\u043D\u043D\u044B 
    \u0412 \u043E\u043A\u0442\u044F\u0431\u0440\u0435 **1873 \u0433\u043E\u0434\u0430**
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E **\u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443** \u0432 \u041F\u0430\u0440\u0438\u0436\u0435,
    \u0433\u0434\u0435 \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0441\u0442\u0430\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A **\u0428\u0430\u0440\u043B\u044C
    \u042D\u0440\u043C\u0438\u0442**. \u0417\u0430\u0442\u0435\u043C, \u043F\u043E
    \u043E\u043A\u043E\u043D\u0447\u0430\u043D\u0438\u0438, \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 **\u0413\u043E\u0440\u043D\u0443\u044E \u0448\u043A\u043E\u043B\u0443**,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u044E \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430. 
    \u042D\u0442\u043E \u0431\u044B\u043B \u0432\u0430\u0436\u043D\u044B\u0439 \u044D\u0442\u0430\u043F
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438. \u041A\u0430\u0440\u044C\u0435\u0440\u0443
    \u043E\u043D \u043D\u0430\u0447\u0438\u043D\u0430\u043B \u043D\u0435 \u043A\u0430\u043A
    \"\u0447\u0438\u0441\u0442\u044B\u0439\" \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A.
    \u041E\u043D \u0438\u0437\u0443\u0447\u0430\u043B \u0433\u0435\u043E\u043B\u043E\u0433\u0438\u044E,
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 \u0448\u0430\u0445\u0442\u0430\u0445,
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0432\u0435\u043D\u0442\u0438\u043B\u044F\u0446\u0438\u0435\u0439
    \u0438 \u0433\u043E\u0440\u043D\u044B\u043C \u0434\u0435\u043B\u043E\u043C. \u0414\u0430\u0436\u0435
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0443\u0447\u0435\u0431\u044B \u0432
    \u0413\u043E\u0440\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u0435 \u043E\u043D
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0441\u0432\u043E\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F \u0438
    \u0432 **1879 \u0433\u043E\u0434\u0443** \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C. \u041E\u0434\u0438\u043D
    \u0438\u0437 \u0447\u043B\u0435\u043D\u043E\u0432 \u043A\u043E\u043C\u0438\u0441\u0441\u0438\u0438,
    \u0413\u0430\u0441\u0442\u043E\u043D \u0414\u0430\u0440\u0431\u0443, \u0441\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0432 \u043D\u0435\u0439 \u0431\u044B\u043B\u043E \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u0430 \u0434\u043B\u044F \xAB\u043C\u043D\u043E\u0433\u0438\u0445
    \u0445\u043E\u0440\u043E\u0448\u0438\u0445 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0439\xBB. 
    \u041F\u043E\u043B\u0443\u0447\u0438\u0432 \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0434\u043E\u043A\u0442\u043E\u0440\u0430, \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u043D\u0430\u0447\u0430\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0443\u044E
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0432
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u0433\u043E\u0440\u043E\u0434\u0430
    **\u041A\u0430\u043D (\u041D\u043E\u0440\u043C\u0430\u043D\u0434\u0438\u044F)**.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C \u043E\u043D \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B
    \u0441\u0432\u043E\u044E \u0431\u0443\u0434\u0443\u0449\u0443\u044E \u0436\u0435\u043D\u0443,
    **\u041B\u0443\u0438\u0437\u0443 \u041F\u0443\u043B\u0435\u043D \u0434\u2019\u0410\u043D\u0434\u0435\u0441\u0438**.
    **20 \u0430\u043F\u0440\u0435\u043B\u044F 1881 \u0433\u043E\u0434\u0430** \u043E\u043D\u0438
    \u043F\u043E\u0436\u0435\u043D\u0438\u043B\u0438\u0441\u044C. \u0423 \u043D\u0438\u0445
    \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0447\u0435\u0442\u0432\u0435\u0440\u043E
    \u0434\u0435\u0442\u0435\u0439: \u0442\u0440\u0438 \u0434\u043E\u0447\u0435\u0440\u0438
    \u0438 \u0441\u044B\u043D.  ### \U0001F680 \u0412 \u041F\u0430\u0440\u0438\u0436\u0435:
    \u0420\u0430\u0441\u0446\u0432\u0435\u0442 \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u0423\u0436\u0435 \u0432 \u043E\u043A\u0442\u044F\u0431\u0440\u0435 **1881 \u0433\u043E\u0434\u0430**
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435 \u0437\u0430\u043D\u044F\u0442\u044C
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044F
    \u043D\u0430 \u0424\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0435 \u043D\u0430\u0443\u043A
    \u0432 **\u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    (\u0421\u043E\u0440\u0431\u043E\u043D\u043D\u0435)**. \u041F\u043E\u0437\u0436\u0435,
    \u0441 1886 \u0433\u043E\u0434\u0430, \u043E\u043D \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u043B
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.  \u0415\u0433\u043E
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u043E\u0448\u043B\u0430 \u0432 \u0433\u043E\u0440\u0443. \u0412 **1886
    \u0433\u043E\u0434\u0443**, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    32 \u043B\u0435\u0442, \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 , \u0430 \u0432 \u044F\u043D\u0432\u0430\u0440\u0435
    **1887 \u0433\u043E\u0434\u0430** \u0435\u0433\u043E \u0438\u0437\u0431\u0440\u0430\u043B\u0438
    \u0447\u043B\u0435\u043D\u043E\u043C **\u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A**.
    \u0421 1893 \u0433\u043E\u0434\u0430 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B \u0432 \u0411\u044E\u0440\u043E \u0434\u043E\u043B\u0433\u043E\u0442,
    \u0430 \u0441 1896 \u0433\u043E\u0434\u0430 \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u043B
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438. 
    ### \U0001F91D \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441
    \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438:
    \u0411\u043B\u0430\u0433\u043E\u0440\u043E\u0434\u0441\u0442\u0432\u043E \u0438
    \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435  \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C, \u043D\u043E \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0431\u043B\u0430\u0433\u043E\u0440\u043E\u0434\u0441\u0442\u0432\u0430 \u0438
    \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u043E\u0441\u0442\u0438. \u041E\u043D
    \u0431\u044B\u043B \u0442\u0432\u0435\u0440\u0434 \u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0441\u043F\u043E\u0440\u0430\u0445, \u043D\u043E \u043D\u0435\u0438\u0437\u043C\u0435\u043D\u043D\u043E
    \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u043B \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435
    \u043A \u043E\u043F\u043F\u043E\u043D\u0435\u043D\u0442\u0430\u043C \u0438 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0431\u044B\u043B \u0437\u0430\u043C\u0435\u0448\u0430\u043D \u0432
    \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u0430\u0445. \u041E\u0445\u043E\u0442\u043D\u043E
    \u043F\u043E\u043C\u043E\u0433\u0430\u043B \u043C\u043E\u043B\u043E\u0434\u044B\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C.  \u041F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u0435\u043D
    \u0435\u0433\u043E \u044D\u043F\u0438\u0437\u043E\u0434 \u0441 **\u0410\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C**. \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0437\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043B\u0435\u0442
    \u0434\u043E \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043C\u043D\u043E\u0433\u0438\u0435 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u043A\u043E\u0433\u0434\u0430 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 1905 \u0433\u043E\u0434\u0443, \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u043D\u0435 \u0441\u0442\u0430\u043B \u043E\u0441\u043F\u0430\u0440\u0438\u0432\u0430\u0442\u044C
    \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442, \u0430 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0442\u0435\u0440\u043C\u0438\u043D\u043E\u043B\u043E\u0433\u0438\u044E
    \u0438 \u043D\u0430\u0437\u044B\u0432\u0430\u0442\u044C \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438\u043C\u0435\u043D\u0435\u043C \u041B\u043E\u0440\u0435\u043D\u0446\u0430,
    \u0445\u043E\u0442\u044F \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u043D \u043F\u0440\u0438\u0434\u0430\u043B
    \u0438\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439
    \u0432\u0438\u0434. \u042D\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u043E \u0435\u0433\u043E \u0440\u0435\u0434\u043A\u043E\u043C \u0431\u0435\u0441\u043A\u043E\u0440\u044B\u0441\u0442\u0438\u0438.
    \u0425\u043E\u0442\u044F \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043C\u043D\u0435\u043D\u0438\u0435, \u0447\u0442\u043E \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0438 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D \u043D\u0435 \u0431\u044B\u043B\u0438
    \u0431\u043B\u0438\u0437\u043A\u043E \u0437\u043D\u0430\u043A\u043E\u043C\u044B,
    \u0438\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u043F\u0443\u0442\u0438
    \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u043B\u0438\u0441\u044C \u0447\u0435\u0440\u0435\u0437
    \u0413\u0435\u0440\u043C\u0430\u043D\u0430 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E,
    \u0434\u0440\u0443\u0433\u0430 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0438 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430 \u0441 \u0440\u0430\u0431\u043E\u0442\u0430\u043C\u0438
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430. 
    ### \U0001F3DB\uFE0F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0441\u043C\u0435\u0440\u0442\u044C  \u0412 1906 \u0433\u043E\u0434\u0443
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D
    **\u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A**.
    \u041E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u0438 \u0447\u0438\u0442\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u0438 \u043F\u043E \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043C\u0430\u0433\u043D\u0435\u0442\u0438\u0437\u043C\u0443
    \u0438 \u0440\u0430\u0434\u0438\u043E\u0441\u0432\u044F\u0437\u0438.  \u0417\u0434\u043E\u0440\u043E\u0432\u044C\u0435
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u043D\u0430\u0447\u0430\u043B\u043E
    \u0443\u0445\u0443\u0434\u0448\u0430\u0442\u044C\u0441\u044F. \u0412 1909 \u0433\u043E\u0434\u0443
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438\u0437 \u0441\u0432\u043E\u0438\u0445 \u0434\u043E\u043A\u043B\u0430\u0434\u043E\u0432
    \u043E\u043D \u043F\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u0435\u0431\u044F \u043F\u043B\u043E\u0445\u043E. \u0410\u043D\u0440\u0438
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    **17 \u0438\u044E\u043B\u044F 1912 \u0433\u043E\u0434\u0430** \u0432 \u041F\u0430\u0440\u0438\u0436\u0435
    \u043F\u043E\u0441\u043B\u0435 \u043D\u0435\u0443\u0434\u0430\u0447\u043D\u043E\u0439
    \u0445\u0438\u0440\u0443\u0440\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438. \u0415\u043C\u0443 \u0431\u044B\u043B\u043E
    58 \u043B\u0435\u0442. \u041E\u043D \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u0432 \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u043C \u0441\u043A\u043B\u0435\u043F\u0435
    \u043D\u0430 \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435 \u041C\u043E\u043D\u043F\u0430\u0440\u043D\u0430\u0441. 
    \u0415\u0441\u0442\u044C \u0432\u0435\u0440\u0441\u0438\u044F, \u0447\u0442\u043E
    \u043E\u043D \u043F\u0440\u0435\u0434\u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u043A\u043E\u043D\u0447\u0438\u043D\u0443: \u0432 \u0441\u0432\u043E\u0435\u0439
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0439 \u0441\u0442\u0430\u0442\u044C\u0435,
    \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u0434\u043B\u044F \u043D\u0435\u0433\u043E
    \u043D\u0435\u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043D\u043E, \u043E\u043D
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043D\u0435\u0440\u0435\u0448\u0435\u043D\u043D\u0443\u044E
    \u0437\u0430\u0434\u0430\u0447\u0443, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0432\u0441\u043A\u043E\u0440\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0414\u0436\u043E\u0440\u0434\u0436 \u0411\u0438\u0440\u043A\u0433\u043E\u0444."
  personalLifeEn: 
  shortBioRu: "\u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0447\u0430\u0441\u0442\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C-\u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u043E\u043C,
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u0445\u0432\u0430\u0442\u0438\u043B \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u0441\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    \u0415\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u2014
    \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0445\u0440\u043E\u043D\u0438\u043A\u0430
    \u0436\u0438\u0437\u043D\u0438, \u043D\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u044F \u0433\u0435\u043D\u0438\u044F,
    \u0447\u044C\u0438 \u0438\u0434\u0435\u0438 \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438 \u043D\u0430\u0443\u043A\u0443. 
    ### \U0001F4DC \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u043E\u0442\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u043E:
    \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E\u0433\u043E
    \u0443\u043C\u0430  \u0416\u044E\u043B\u044C \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 29 \u0430\u043F\u0440\u0435\u043B\u044F
    1854 \u0433\u043E\u0434\u0430 \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u041D\u0430\u043D\u0441\u0438,
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u044B \u041B\u0435\u043E\u043D\u0430
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435. \u0421 \u0440\u0430\u043D\u043D\u0438\u0445
    \u043B\u0435\u0442 \u043E\u043D \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B
    \u0447\u0435\u0440\u0442\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0438
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C: \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0430\u044F
    \u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0441\u0442\u044C \u0438
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u0443\u0445\u043E\u0434\u0438\u0442\u044C \u0432 \u0441\u0432\u043E\u0438 \u043C\u044B\u0441\u043B\u0438. 
    **\u0412\u0430\u0436\u043D\u043E\u0435 \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u0435.**
    \u0412 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u0410\u043D\u0440\u0438 \u0442\u044F\u0436\u0435\u043B\u043E
    \u043F\u0435\u0440\u0435\u0431\u043E\u043B\u0435\u043B \u0434\u0438\u0444\u0442\u0435\u0440\u0438\u0435\u0439.
    \u0411\u043E\u043B\u0435\u0437\u043D\u044C \u0434\u0430\u043B\u0430 \u043E\u0441\u043B\u043E\u0436\u043D\u0435\u043D\u0438\u0435
    \u043D\u0430 \u043D\u043E\u0433\u0438 \u0438 \u043C\u044F\u0433\u043A\u043E\u0435
    \u043D\u0451\u0431\u043E, \u0438\u0437-\u0437\u0430 \u0447\u0435\u0433\u043E
    \u043E\u043D \u0434\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F
    \u043D\u0435 \u043C\u043E\u0433 \u0445\u043E\u0434\u0438\u0442\u044C \u0438 \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C.
    \u042D\u0442\u043E\u0442 \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u043D\u044B\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E \u043E\u0431\u043E\u0441\u0442\u0440\u0438\u043B
    \u0435\u0433\u043E \u0441\u043B\u0443\u0445 \u0438 \u043F\u0440\u0438\u0432\u0435\u043B
    \u043A \u0440\u0435\u0434\u043A\u043E\u043C\u0443 \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0443
    \u2014 \u0441\u0438\u043D\u0435\u0441\u0442\u0435\u0437\u0438\u0438, \u043F\u0440\u0438
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B
    \u0437\u0432\u0443\u043A\u0438 \u0432 \u0446\u0432\u0435\u0442\u0435.  **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435.**
    \u0418\u0437-\u0437\u0430 \u0441\u043B\u0430\u0431\u043E\u0433\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F
    \u043F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0410\u043D\u0440\u0438
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u043C\u0430. \u0415\u0433\u043E
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C \u0431\u044B\u043B \u0434\u0440\u0443\u0433
    \u0441\u0435\u043C\u044C\u0438, \u0410\u043B\u044C\u0444\u043E\u043D\u0441 \u0413\u0438\u043D\u0446\u0435\u043B\u0438\u043D,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B
    \u0441 \u043D\u0438\u043C \u0431\u0435\u0441\u0435\u0434\u044B, \u043F\u043E\u0447\u0442\u0438
    \u043D\u0435 \u0442\u0440\u0435\u0431\u0443\u044F \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B. \u0422\u0430\u043A \u0443 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0440\u0430\u0437\u0432\u0438\u043B\u0430\u0441\u044C \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0430
    \u0440\u0435\u0448\u0430\u0442\u044C \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0432 \u0443\u043C\u0435. \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u0432\u043E\u0441\u044C\u043C\u0438 \u0441 \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u043E\u0439
    \u043B\u0435\u0442 \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0441\u0440\u0430\u0437\u0443 \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439
    \u043A\u043B\u0430\u0441\u0441 \u043B\u0438\u0446\u0435\u044F \u041D\u0430\u043D\u0441\u0438. 
    **\u0418\u043D\u0442\u0435\u0440\u0435\u0441 \u043A \u043D\u0430\u0443\u043A\u0430\u043C.**
    \u0418\u0437\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F \u0433\u0443\u043C\u0430\u043D\u0438\u0442\u0430\u0440\u043D\u044B\u043C\u0438
    \u043D\u0430\u0443\u043A\u0430\u043C\u0438 \u0438 \u0434\u0430\u0436\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430
    \u0441\u043B\u043E\u0432\u0435\u0441\u043D\u043E\u0441\u0442\u0438 \u0441 \u043E\u0442\u043B\u0438\u0447\u0438\u0435\u043C.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0430\u043B\u0430\u043D\u0442 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u0440\u0430\u043D\u043E: \u043E\u0434\u0438\u043D \u0438\u0437 \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \u0410\u043D\u0440\u0438 \u0441\u0442\u0430\u043D\u0435\u0442 \u0432\u0435\u043B\u0438\u043A\u0438\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C. \u041B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u043E,
    \u0447\u0442\u043E \u043D\u0430 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0435
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u043D\u0430
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430
    \u043D\u0430\u0443\u043A \u043E\u043D \u043F\u0440\u043E\u0432\u0430\u043B\u0438\u043B\u0441\u044F
    \u0438\u0437-\u0437\u0430 \u0441\u0432\u043E\u0435\u0439 \u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0441\u0442\u0438,
    \u043F\u0435\u0440\u0435\u043F\u0443\u0442\u0430\u0432 \u0442\u0435\u043C\u0443
    \u0437\u0430\u0434\u0430\u043D\u0438\u044F.  **\u0412\u043B\u0438\u044F\u043D\u0438\u0435
    \u0432\u043E\u0439\u043D\u044B.** \u0415\u0433\u043E \u044E\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u0438\u0448\u043B\u0430\u0441\u044C \u043D\u0430 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B \u0444\u0440\u0430\u043D\u043A\u043E-\u043F\u0440\u0443\u0441\u0441\u043A\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B (1870\u20131871). \u041E\u043A\u043A\u0443\u043F\u0430\u0446\u0438\u044F
    \u0440\u043E\u0434\u043D\u043E\u0433\u043E \u041D\u0430\u043D\u0441\u0438, \u0445\u0430\u043E\u0441
    \u0438 \u043F\u043E\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \u0424\u0440\u0430\u043D\u0446\u0438\u0438
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u043F\u043E\u0442\u0440\u044F\u0441\u043B\u0438
    \u044E\u043D\u043E\u0448\u0443. \u041E\u043D \u043F\u043E\u043C\u043E\u0433\u0430\u043B
    \u043E\u0442\u0446\u0443 \u0432 \u0433\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u0435
    \u0438 \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u043E\u043D\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0430 \u0442\u0435\u043C\u0443 \xAB\u041A\u0430\u043A
    \u043D\u0430\u0446\u0438\u044F \u043C\u043E\u0436\u0435\u0442 \u0432\u043E\u0437\u0432\u044B\u0441\u0438\u0442\u044C\u0441\u044F?\xBB. 
    ### \U0001F393 \u041F\u0443\u0442\u044C \u0432 \u043D\u0430\u0443\u043A\u0443:
    \u043E\u0442 \u0413\u043E\u0440\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u044B
    \u0434\u043E \u0421\u043E\u0440\u0431\u043E\u043D\u043D\u044B  **\u041E\u0431\u0443\u0447\u0435\u043D\u0438\u0435.**
    \u0412 1873 \u0433\u043E\u0434\u0443 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E
    \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435. \u0415\u0433\u043E
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C \u0441\u0442\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0428\u0430\u0440\u043B\u044C \u042D\u0440\u043C\u0438\u0442. \u0417\u0430\u0442\u0435\u043C
    \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0432 \u0413\u043E\u0440\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u0435, \u0447\u0442\u043E\u0431\u044B
    \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u044E
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430.  **\u0414\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0430\u044F
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F.** \u0412
    1879 \u0433\u043E\u0434\u0443 \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u042D\u0440\u043C\u0438\u0442\u0430 \u043E\u043D \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C. \u0420\u0430\u0431\u043E\u0442\u0430
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u043E\u0439, \u0447\u0442\u043E,
    \u043F\u043E \u0441\u043B\u043E\u0432\u0430\u043C \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438\u0437 \u0447\u043B\u0435\u043D\u043E\u0432 \u043A\u043E\u043C\u0438\u0441\u0441\u0438\u0438,
    \u0432 \u043D\u0435\u0439 \u0431\u044B\u043B\u043E \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u0430 \u0434\u043B\u044F \xAB\u043C\u043D\u043E\u0433\u0438\u0445
    \u0445\u043E\u0440\u043E\u0448\u0438\u0445 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0439\xBB. 
    **\u041D\u0430\u0447\u0430\u043B\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B.**
    \u041F\u043E\u0441\u043B\u0435 \u0437\u0430\u0449\u0438\u0442\u044B \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0438\u043D\u0441\u043F\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u0433\u043E\u0440\u043D\u043E\u0433\u043E \u0434\u0435\u043B\u0430, \u043D\u043E
    \u0432\u0441\u043A\u043E\u0440\u0435 \u043D\u0430\u0447\u0430\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0443\u044E
    \u043A\u0430\u0440\u044C\u0435\u0440\u0443 \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u041A\u0430\u043D\u0430. \u0423\u0436\u0435 \u0432 1881 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    (\u0421\u043E\u0440\u0431\u043E\u043D\u043D\u0443), \u0433\u0434\u0435 \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u043B
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u0438 \u0447\u0438\u0442\u0430\u043B
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0434\u043E \u043A\u043E\u043D\u0446\u0430
    \u0436\u0438\u0437\u043D\u0438.  **\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C.**
    \u0412 1881 \u0433\u043E\u0434\u0443 \u0410\u043D\u0440\u0438 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u041B\u0443\u0438\u0437\u0435 \u041F\u0443\u043B\u0435\u043D \u0434\u2019\u0410\u043D\u0434\u0435\u0441\u0438.
    \u0423 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0447\u0435\u0442\u0432\u0435\u0440\u043E
    \u0434\u0435\u0442\u0435\u0439: \u0442\u0440\u0438 \u0434\u043E\u0447\u0435\u0440\u0438
    \u0438 \u0441\u044B\u043D.  ### \U0001F680 \u041D\u0430\u0443\u0447\u043D\u044B\u0435
    \u043F\u0440\u043E\u0440\u044B\u0432\u044B: \u0442\u0440\u0438\u0443\u043C\u0444\u044B
    \u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F  \u041D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E \u2014 \u0431\u043E\u043B\u0435\u0435
    500 \u0441\u0442\u0430\u0442\u0435\u0439 \u0438 \u043A\u043D\u0438\u0433. \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0431\u044B\u043B\u0430 \u043C\u0435\u0436\u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0430\u0440\u043D\u043E\u0439,
    \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u043B \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0441\u0440\u0430\u0437\u0443 \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445.  *   **\u041A\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439**: \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0441\u043E\u0437\u0434\u0430\u043B \u043D\u043E\u0432\u044B\u0439 \u0440\u0430\u0437\u0434\u0435\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B \u043F\u043E\u043D\u044F\u0442\u044C
    \u043E\u0431\u0449\u0435\u0435 \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439,
    \u043D\u0435 \u0440\u0435\u0448\u0430\u044F \u0438\u0445. \u042D\u0442\u043E
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u043E \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435.  *   **\u0417\u0430\u0434\u0430\u0447\u0430
    \u0442\u0440\u0435\u0445 \u0442\u0435\u043B \u0438 \u0445\u0430\u043E\u0441**:
    \u0412 1887 \u0433\u043E\u0434\u0443 \u043A\u043E\u0440\u043E\u043B\u044C \u0428\u0432\u0435\u0446\u0438\u0438
    \u041E\u0441\u043A\u0430\u0440 II \u043D\u0430\u0437\u043D\u0430\u0447\u0438\u043B
    \u043F\u0440\u0435\u043C\u0438\u044E \u0437\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0442\u0440\u0435\u0445 \u0442\u0435\u043B
    (\u0440\u0430\u0441\u0447\u0435\u0442 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u0442\u0440\u0435\u0445 \u0433\u0440\u0430\u0432\u0438\u0442\u0438\u0440\u0443\u044E\u0449\u0438\u0445
    \u0442\u0435\u043B). \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u044D\u0442\u0443 \u043F\u0440\u0435\u043C\u0438\u044E \u0432 1889 \u0433\u043E\u0434\u0443,
    \u043D\u043E \u0432 \u0445\u043E\u0434\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441\u0434\u0435\u043B\u0430\u043B \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435. \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u0432 \u0442\u0430\u043A\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C
    **\u0445\u0430\u043E\u0442\u0438\u0447\u043D\u044B\u043C**: \u0434\u0430\u0436\u0435
    \u043C\u0430\u043B\u0435\u0439\u0448\u0435\u0435 \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u044B\u0445 \u0443\u0441\u043B\u043E\u0432\u0438\u0439
    \u043C\u043E\u0436\u0435\u0442 \u043F\u0440\u0438\u0432\u0435\u0441\u0442\u0438
    \u043A \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u043D\u0435\u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0443\u0435\u043C\u043E\u043C\u0443
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0443. \u042D\u0442\u043E
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u043E
    \u043E\u0441\u043D\u043E\u0432\u044B \u0442\u0435\u043E\u0440\u0438\u0438 \u0445\u0430\u043E\u0441\u0430. 
    *   **\u0421\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438**:
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0442\u0446\u043E\u043C
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438 \u2014 \u0440\u0430\u0437\u0434\u0435\u043B\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0438\u0437\u0443\u0447\u0430\u044E\u0449\u0435\u0433\u043E
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430 \u0444\u0438\u0433\u0443\u0440,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0435 \u043C\u0435\u043D\u044F\u044E\u0442\u0441\u044F
    \u043F\u0440\u0438 \u0434\u0435\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F\u0445.
    \u041E\u043D \u0432\u0432\u0435\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F, \u0442\u0430\u043A\u0438\u0435 \u043A\u0430\u043A
    **\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u044F** \u0438 **\u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0433\u0440\u0443\u043F\u043F\u0430**, \u0438 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C \u043D\u0435\u0440\u0435\u0448\u0435\u043D\u043D\u043E\u0439
    \u043F\u043E\u0447\u0442\u0438 100 \u043B\u0435\u0442.  *   **\u041D\u0430 \u043F\u0443\u0442\u0438
    \u043A \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438**:
    \u0412 1905 \u0433\u043E\u0434\u0443, \u043F\u043E\u0447\u0442\u0438 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u0441 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C, \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u044B,
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0438\u0435 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u041E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    **\u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438**
    \u0434\u043B\u044F \u0432\u0441\u0435\u0445 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u044F\u0432\u043B\u0435\u043D\u0438\u0439, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u041B\u043E\u0440\u0435\u043D\u0446\u0430 \u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u043B
    \u0438\u0445 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043D\u043E\u0441\u0442\u044C.
    \u041E\u0434\u043D\u0430\u043A\u043E \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D
    \u043F\u043E\u0448\u0435\u043B \u0434\u0430\u043B\u044C\u0448\u0435, \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u0432
    \u0440\u0435\u0448\u0430\u044E\u0449\u0438\u0439 \u0448\u0430\u0433 \u043A \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u0438\u044E
    \u0441\u0443\u0442\u0438 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430
    \u0438 \u0432\u0440\u0435\u043C\u0435\u043D\u0438.  *   **\u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F
    \u043D\u0430\u0443\u043A\u0438: \u043A\u043E\u043D\u0432\u0435\u043D\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0437\u043C**.
    \u0412 \u0441\u0432\u043E\u0438\u0445 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445
    \u043A\u043D\u0438\u0433\u0430\u0445, \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A
    \xAB\u041D\u0430\u0443\u043A\u0430 \u0438 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430\xBB
    (1903), \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0440\u0430\u0437\u0432\u0438\u043B
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0443\u044E \u0434\u043E\u043A\u0442\u0440\u0438\u043D\u0443
    **\u043A\u043E\u043D\u0432\u0435\u043D\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0437\u043C\u0430**.
    \u041E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u044B \u043D\u0430\u0443\u043A\u0438
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F) \u043D\u0435 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0438\u0441\u0442\u0438\u043D\u043D\u044B\u043C\u0438 \u0438\u043B\u0438 \u043B\u043E\u0436\u043D\u044B\u043C\u0438.
    \u042D\u0442\u043E, \u0441\u043A\u043E\u0440\u0435\u0435, **\u0441\u043E\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u044F
    (\u043A\u043E\u043D\u0432\u0435\u043D\u0446\u0438\u0438)** \u0438 \u0443\u0434\u043E\u0431\u043D\u044B\u0435
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B, \u0432\u044B\u0431\u043E\u0440
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0434\u0438\u043A\u0442\u0443\u0435\u0442\u0441\u044F
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u043E\u0439. 
    ### \U0001F3DB\uFE0F \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B 
    **\u0417\u0432\u0430\u043D\u0438\u044F.** \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0431\u044B\u043B \u0443\u0432\u0435\u043D\u0447\u0430\u043D \u0432\u0441\u0435\u043C\u0438
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u043C\u0438 \u0434\u043B\u044F
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u043F\u043E\u0447\u0435\u0441\u0442\u044F\u043C\u0438.
    \u0412 1887 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B \u0447\u043B\u0435\u043D\u043E\u043C
    \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A, \u0430 \u0432 1906 \u0433\u043E\u0434\u0443 \u2014
    \u0435\u0435 \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C
    \u0431\u043E\u043B\u0435\u0435 30 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u043C\u0438\u0440\u0430, \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A.  **\u041B\u0438\u0447\u043D\u043E\u0441\u0442\u044C.**
    \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u043A\u0430\u043A \u0431\u043B\u0430\u0433\u043E\u0440\u043E\u0434\u043D\u043E\u0433\u043E,
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438 \u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u043E \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430. \u041E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u0432 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0438, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0432\u0441\u0442\u0430\u043B \u043D\u0430 \u0437\u0430\u0449\u0438\u0442\u0443
    \u0410\u043B\u044C\u0444\u0440\u0435\u0434\u0430 \u0414\u0440\u0435\u0439\u0444\u0443\u0441\u0430,
    \u0440\u0430\u0437\u043E\u0431\u043B\u0430\u0447\u0438\u0432 \u043B\u0436\u0435\u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442\u044B \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u044F. 
    **\u0421\u043C\u0435\u0440\u0442\u044C.** \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 17 \u0438\u044E\u043B\u044F
    1912 \u0433\u043E\u0434\u0430 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 58 \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438 \u043F\u043E \u043F\u043E\u0432\u043E\u0434\u0443
    \u043F\u0440\u043E\u0441\u0442\u0430\u0442\u044B. \u041E\u043D \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u0432 \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u043C \u0441\u043A\u043B\u0435\u043F\u0435
    \u043D\u0430 \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435 \u041C\u043E\u043D\u043F\u0430\u0440\u043D\u0430\u0441."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u043F\u043E\u043B\u043D\u0430 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0439 \u0438
    \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u0439.
    \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u0443\u043C, \u043F\u043E\u0433\u0440\u0443\u0436\u0451\u043D\u043D\u044B\u0439
    \u0432 \u043C\u0438\u0440 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0445
    \u0438\u0434\u0435\u0439, \u0443\u0436\u0438\u0432\u0430\u043B\u0441\u044F \u0432
    \u043D\u0451\u043C \u0441 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E\u0439
    \u0431\u0435\u0441\u043F\u043E\u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C\u044E
    \u0432 \u0431\u044B\u0442\u043E\u0432\u044B\u0445 \u043C\u0435\u043B\u043E\u0447\u0430\u0445.
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u044F\u0440\u043A\u0438\u0435,
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0438 \u043A\u0443\u0440\u044C\u0451\u0437\u043D\u044B\u0435 \u0444\u0430\u043A\u0442\u044B
    \u0438\u0437 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.  ### \U0001F92F
    \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u0430\u044F \u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0441\u0442\u044C:
    \xAB\u0411\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439\xBB
    \u0443\u043C, \u043F\u043E\u0442\u0435\u0440\u044F\u043D\u043D\u044B\u0439 \u0432
    \u043C\u0438\u0440\u0435  \u0420\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0441\u0442\u044C
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0432\u043E\u0448\u043B\u0430
    \u0432 \u043B\u0435\u0433\u0435\u043D\u0434\u044B. \u0423\u0447\u0451\u043D\u044B\u0439
    \u043C\u043E\u0433 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043E\u0442\u043A\u043B\u044E\u0447\u0438\u0442\u044C\u0441\u044F
    \u043E\u0442 \u0432\u043D\u0435\u0448\u043D\u0435\u0433\u043E \u043C\u0438\u0440\u0430,
    \u043F\u043E\u0433\u0440\u0443\u0436\u0430\u044F\u0441\u044C \u0432 \u0441\u0432\u043E\u0438
    \u043C\u044B\u0441\u043B\u0438, \u0447\u0442\u043E \u043F\u043E\u0440\u043E\u0436\u0434\u0430\u043B\u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445
    \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0439.  *   **\u041F\u043E\u0445\u0438\u0442\u0438\u0442\u0435\u043B\u044C
    \u043A\u043B\u0435\u0442\u043E\u043A**: \u041E\u0434\u043D\u0430\u0436\u0434\u044B,
    \u0433\u0443\u043B\u044F\u044F \u0438 \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u044F\u044F,
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0434\u043E\u043C\u043E\u0439 \u0438 \u0441 \u0443\u0434\u0438\u0432\u043B\u0435\u043D\u0438\u0435\u043C
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B, \u0447\u0442\u043E \u043D\u0435\u0441\u0451\u0442
    \u0432 \u0440\u0443\u043A\u0430\u0445... \u043D\u043E\u0432\u0443\u044E \u043F\u043B\u0435\u0442\u0451\u043D\u0443\u044E
    \u043A\u043B\u0435\u0442\u043A\u0443. \u041E\u043D \u043D\u0435 \u043C\u043E\u0433
    \u0432\u0441\u043F\u043E\u043C\u043D\u0438\u0442\u044C, \u0433\u0434\u0435 \u0435\u0451
    \u0432\u0437\u044F\u043B. \u041F\u0440\u0438\u0448\u043B\u043E\u0441\u044C \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
    \u043F\u043E \u0441\u0432\u043E\u0438\u043C \u0441\u043B\u0435\u0434\u0430\u043C,
    \u0447\u0442\u043E\u0431\u044B \u043D\u0430\u0439\u0442\u0438 \u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0430-\u043A\u043E\u0440\u0437\u0438\u043D\u0449\u0438\u043A\u0430,
    \u0443 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \xAB\u043F\u043E\u0437\u0430\u0438\u043C\u0441\u0442\u0432\u043E\u0432\u0430\u043B\xBB
    \u0442\u043E\u0432\u0430\u0440.  *   **\u0411\u0435\u043B\u044C\u0451 \u0438
    \u043F\u043E\u0440\u0442\u0444\u0435\u043B\u044C**: \u041A\u043E\u0433\u0434\u0430
    \u043E\u043D \u0431\u044B\u043B \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C
    \u0438 \u0441\u043E\u0431\u0438\u0440\u0430\u043B\u0441\u044F \u0432 \u043F\u043E\u0435\u0437\u0434\u043A\u0443
    \u043F\u043E \u0410\u0432\u0441\u0442\u0440\u0438\u0438, \u0435\u0433\u043E \u043C\u0430\u0442\u044C,
    \u043E\u043F\u0430\u0441\u0430\u044F\u0441\u044C, \u0447\u0442\u043E \u043E\u043D
    \u043F\u043E\u0442\u0435\u0440\u044F\u0435\u0442 \u043F\u043E\u0440\u0442\u0444\u0435\u043B\u044C
    \u0438\u0437-\u0437\u0430 \u0441\u0432\u043E\u0435\u0439 \u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0441\u0442\u0438,
    \u043F\u0440\u0438\u0448\u0438\u043B\u0430 \u043A \u043D\u0435\u043C\u0443 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0435
    \u043A\u043E\u043B\u043E\u043A\u043E\u043B\u044C\u0447\u0438\u043A\u0438. \u041F\u043B\u0430\u043D
    \u0441\u0440\u0430\u0431\u043E\u0442\u0430\u043B, \u043D\u043E \u0441 \u0434\u0440\u0443\u0433\u0438\u043C
    \u044D\u0444\u0444\u0435\u043A\u0442\u043E\u043C: \u0432\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C,
    \u043C\u0430\u0442\u044C \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B\u0430,
    \u0447\u0442\u043E \u0410\u043D\u0440\u0438 \u043F\u0440\u0438\u0432\u0451\u0437
    \u0432 \u0441\u0432\u043E\u0451\u043C \u0441\u0430\u043A\u0432\u043E\u044F\u0436\u0435
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0440\u0442\u0444\u0435\u043B\u044C,
    \u043D\u043E \u0438... \u0430\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u043E
    \u0441\u043B\u043E\u0436\u0435\u043D\u043D\u0443\u044E \u0430\u0432\u0441\u0442\u0440\u0438\u0439\u0441\u043A\u0443\u044E
    \u043F\u0440\u043E\u0441\u0442\u044B\u043D\u044E, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u043F\u043E \u043E\u0448\u0438\u0431\u043A\u0435 \u043F\u0440\u0438\u043D\u044F\u043B
    \u0437\u0430 \u0441\u0432\u043E\u044E \u043D\u043E\u0447\u043D\u0443\u044E \u0440\u0443\u0431\u0430\u0448\u043A\u0443. 
    *   **\u041F\u0440\u043E\u0432\u0430\u043B\u0435\u043D\u043D\u044B\u0439 \u044D\u043A\u0437\u0430\u043C\u0435\u043D**:
    \u0415\u0433\u043E \u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C \u0438 \u0432 \u044E\u043D\u043E\u0441\u0442\u0438.
    \u041D\u0430 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0435 \u043D\u0430 \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430 \u043D\u0430\u0443\u043A
    \u043E\u043D \u043E\u043F\u043E\u0437\u0434\u0430\u043B, \u043F\u0435\u0440\u0435\u043F\u0443\u0442\u0430\u043B
    \u0442\u0435\u043C\u0443 \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B \u0438 \xAB\u043F\u0440\u043E\u0432\u0430\u043B\u0438\u043B\xBB
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443. \u0421\u043F\u0430\u0441\u043B\u0430
    \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044E \u043B\u0438\u0448\u044C \u0435\u0433\u043E
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0430\u044F \u0443\u0441\u0442\u043D\u0430\u044F
    \u0447\u0430\u0441\u0442\u044C, \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0437\u0430\u043A\u0440\u044B\u043B\u0438 \u0433\u043B\u0430\u0437\u0430 \u043D\u0430
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438.  ###
    \U0001F956 \u0412\u0435\u043B\u0438\u043A\u0430\u044F \u0431\u0438\u0442\u0432\u0430
    \u0437\u0430 \u0431\u0430\u0433\u0435\u0442: \u041F\u043E\u0431\u0435\u0434\u0430
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438 \u043D\u0430\u0434
    \u0431\u0443\u043B\u043E\u0447\u043D\u0438\u043A\u043E\u043C  \u042D\u0442\u043E,
    \u043F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u0430\u044F \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442,
    \u043A\u0430\u043A \u043E\u043D \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u043B
    \u043D\u0430\u0443\u043A\u0443 \u0432 \u043F\u043E\u0432\u0441\u0435\u0434\u043D\u0435\u0432\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438. \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435,
    \u043A\u0430\u043A \u0438\u0441\u0442\u0438\u043D\u043D\u044B\u0439 \u0444\u0440\u0430\u043D\u0446\u0443\u0437,
    \u043A\u0430\u0436\u0434\u044B\u0439 \u0434\u0435\u043D\u044C \u043F\u043E\u043A\u0443\u043F\u0430\u043B
    \u0431\u0430\u0433\u0435\u0442 \u0438, \u0431\u0443\u0434\u0443\u0447\u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C,
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0432\u0435\u0441 \u043D\u0435\u0441\u0442\u0430\u0431\u0438\u043B\u0435\u043D. 
    1.  **\u041F\u0435\u0440\u0432\u043E\u0435 \u0440\u0430\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435**:
    \u041E\u043D \u043D\u0430\u0447\u0430\u043B \u0432\u0437\u0432\u0435\u0448\u0438\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u0439 \u0445\u043B\u0435\u0431 \u0438 \u0432 \u0442\u0435\u0447\u0435\u043D\u0438\u0435
    \u0433\u043E\u0434\u0430 \u0441\u043A\u0440\u0443\u043F\u0443\u043B\u0451\u0437\u043D\u043E
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u043B \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B.
    \u041A\u043E\u0433\u0434\u0430 \u043E\u043D \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    \u0433\u0440\u0430\u0444\u0438\u043A, \u0442\u043E \u0443\u0432\u0438\u0434\u0435\u043B,
    \u0447\u0442\u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0432\u0435\u0441\u0430 \u043E\u0431\u0440\u0430\u0437\u0443\u0435\u0442 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u043E\u043B\u043E\u043A\u043E\u043B\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u0443\u044E
    \u043A\u0440\u0438\u0432\u0443\u044E, \u043D\u043E \u0441 \u043F\u0438\u043A\u043E\u043C
    \u043D\u0435 \u043D\u0430 \u043E\u0442\u043C\u0435\u0442\u043A\u0435 \u0432 1
    \u043A\u0433, \u0430 \u043E\u043A\u043E\u043B\u043E 950 \u0433\u0440\u0430\u043C\u043C\u043E\u0432.
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u0431\u0435\u0441\u0441\u043F\u043E\u0440\u043D\u044B\u043C
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0431\u0443\u043B\u043E\u0447\u043D\u0438\u043A
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435\u0434\u043E\u0432\u0435\u0448\u0438\u0432\u0430\u0435\u0442, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u0440\u0435\u0446\u0435\u043F\u0442 \u0434\u043B\u044F 950-\u0433\u0440\u0430\u043C\u043C\u043E\u0432\u044B\u0445
    \u0431\u0443\u0445\u0430\u043D\u043E\u043A. \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u043E\u0431\u0440\u0430\u0442\u0438\u043B\u0441\u044F \u0432 \u043F\u043E\u043B\u0438\u0446\u0438\u044E,
    \u0438 \u0431\u0443\u043B\u043E\u0447\u043D\u0438\u043A\u0430 \u043E\u0448\u0442\u0440\u0430\u0444\u043E\u0432\u0430\u043B\u0438. 
    2.  **\u0412\u0442\u043E\u0440\u043E\u0435 \u0440\u0430\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435**:
    \u0411\u0443\u043B\u043E\u0447\u043D\u0438\u043A \u0438\u0441\u043F\u0443\u0433\u0430\u043B\u0441\u044F
    \u0438 \u0440\u0435\u0448\u0438\u043B, \u0447\u0442\u043E \u0431\u043E\u043B\u044C\u0448\u0435
    \u043D\u0435 \u0431\u0443\u0434\u0435\u0442 \u043E\u0431\u043C\u0430\u043D\u044B\u0432\u0430\u0442\u044C
    \u0441\u0430\u043C\u043E\u0433\u043E \u043E\u043F\u0430\u0441\u043D\u043E\u0433\u043E
    \u043F\u043E\u043A\u0443\u043F\u0430\u0442\u0435\u043B\u044F. \u041D\u043E \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u0432\u0437\u0432\u0435\u0448\u0438\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u0439 \u0445\u043B\u0435\u0431. \u0427\u0435\u0440\u0435\u0437
    \u0433\u043E\u0434 \u043E\u043D \u0441\u043D\u043E\u0432\u0430 \u043F\u0440\u0438\u0448\u0451\u043B
    \u0432 \u043F\u043E\u043B\u0438\u0446\u0438\u044E \u0441 \u0437\u0430\u044F\u0432\u043B\u0435\u043D\u0438\u0435\u043C,
    \u0447\u0442\u043E \u043E\u0431\u043C\u0430\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442\u0441\u044F!
    \u041A\u043E\u0433\u0434\u0430 \u0431\u0443\u043B\u043E\u0447\u043D\u0438\u043A
    \u0443\u0437\u043D\u0430\u043B \u043E\u0431 \u044D\u0442\u043E\u043C, \u043E\u043D
    \u0431\u044B\u043B \u0432 \u0448\u043E\u043A\u0435: \u043E\u043D \u0436\u0435
    \u0432\u0441\u0435\u0433\u0434\u0430 \u0434\u0430\u0432\u0430\u043B \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0441\u0430\u043C\u044B\u0439 \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u0431\u0430\u0433\u0435\u0442!. 
    3.  **\u0420\u0430\u0437\u043E\u0431\u043B\u0430\u0447\u0435\u043D\u0438\u0435**:
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u043F\u043E\u043A\u0430\u0437\u0430\u043B
    \u043F\u043E\u043B\u0438\u0446\u0438\u0438 \u043D\u043E\u0432\u044B\u0439 \u0433\u0440\u0430\u0444\u0438\u043A.
    \u041D\u0430 \u044D\u0442\u043E\u0442 \u0440\u0430\u0437 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0432\u0435\u0441\u0430 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u043E
    \u0441\u043E\u0431\u043E\u0439 \u0442\u0443 \u0436\u0435 \u043A\u043E\u043B\u043E\u043A\u043E\u043B\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u0443\u044E
    \u043A\u0440\u0438\u0432\u0443\u044E \u0441 \u043F\u0438\u043A\u043E\u043C \u043D\u0430
    950 \u0433\u0440\u0430\u043C\u043C\u043E\u0432, \u043D\u043E... \u043E\u0431\u0440\u0435\u0437\u0430\u043D\u043D\u0443\u044E
    \u0441 \u043B\u0435\u0432\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B.
    \u0412\u0441\u0435 \u0431\u0443\u0445\u0430\u043D\u043A\u0438 \u0432\u0435\u0441\u0438\u043B\u0438
    \u0440\u043E\u0432\u043D\u043E 1 \u043A\u0433 \u0438\u043B\u0438 \u0447\u0443\u0442\u044C
    \u0431\u043E\u043B\u044C\u0448\u0435. \u0423\u0447\u0451\u043D\u044B\u0439 \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B:
    \u0431\u0443\u043B\u043E\u0447\u043D\u0438\u043A \u043D\u0435 \u0438\u0437\u043C\u0435\u043D\u0438\u043B
    \u0440\u0435\u0446\u0435\u043F\u0442, \u0430 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043D\u0430\u0447\u0430\u043B \u043E\u0442\u0431\u0438\u0440\u0430\u0442\u044C
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0441\u0430\u043C\u044B\u0435 \u0442\u044F\u0436\u0451\u043B\u044B\u0435
    \u0431\u0430\u0433\u0435\u0442\u044B \u0438\u0437 \u043E\u0431\u0449\u0435\u0439
    \u043F\u0430\u0440\u0442\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432\u044B\u0431\u0438\u0432\u0430\u043B\u0438\u0441\u044C \u0438\u0437 \u043E\u0431\u0449\u0435\u0433\u043E
    \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F.
    \u042D\u0442\u043E\u0442 \u0441\u043B\u0443\u0447\u0430\u0439 \u2014 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0439
    \u043F\u0440\u0438\u043C\u0435\u0440 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u044F \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438. 
    ### \U0001F9E0 \u041E\u0441\u043E\u0431\u044B\u0439 \u043C\u0435\u0442\u043E\u0434
    \u0440\u0430\u0431\u043E\u0442\u044B: \xAB\u0418\u043D\u043A\u0443\u0431\u0430\u0446\u0438\u044F\xBB
    \u0438\u0434\u0435\u0439  \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u043D\u0435
    \u0431\u044B\u043B \u0442\u0440\u0443\u0434\u043E\u0433\u043E\u043B\u0438\u043A\u043E\u043C
    \u0432 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0441\u043C\u044B\u0441\u043B\u0435. \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439 \u0440\u0435\u0436\u0438\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B
    \u0435\u0433\u043E \u043F\u043E\u0434\u0441\u043E\u0437\u043D\u0430\u043D\u0438\u044E
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u043D\u0430\u0434 \u0441\u0430\u043C\u044B\u043C\u0438
    \u0441\u043B\u043E\u0436\u043D\u044B\u043C\u0438 \u0437\u0430\u0434\u0430\u0447\u0430\u043C\u0438. 
    *   **\u0421\u0442\u0440\u043E\u0433\u0438\u0439 \u0433\u0440\u0430\u0444\u0438\u043A**:
    \u041E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E \u0434\u0432\u0430 \u0447\u0430\u0441\u0430 \u0443\u0442\u0440\u043E\u043C
    (\u0441 10 \u0434\u043E 12) \u0438 \u0434\u0432\u0430 \u0447\u0430\u0441\u0430
    \u0432\u0435\u0447\u0435\u0440\u043E\u043C (\u0441 5 \u0434\u043E 7). \u041F\u043E\u0441\u043B\u0435
    \u0443\u0436\u0438\u043D\u0430 \u043E\u043D \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B. \u042D\u0442\u043E\u0442
    \u043F\u043E\u0434\u0445\u043E\u0434 \u043E\u043D \u0441\u0430\u043C \u043D\u0430\u0437\u044B\u0432\u0430\u043B
    \xAB\u0438\u043D\u043A\u0443\u0431\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u043C
    \u043F\u0435\u0440\u0438\u043E\u0434\u043E\u043C\xBB: \u043E\u043D \u0441\u043E\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u0442\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F \u043E\u0442 \u0437\u0430\u0434\u0430\u0447\u0438,
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044F \u043F\u043E\u0434\u0441\u043E\u0437\u043D\u0430\u043D\u0438\u044E
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C \u0440\u0435\u0448\u0435\u043D\u0438\u0435.
    \u041E\u043D \u0432\u0435\u0440\u0438\u043B, \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u044F \u0438 \u043F\u043E\u0434\u0441\u043E\u0437\u043D\u0430\u043D\u0438\u0435
    \u0438\u0433\u0440\u0430\u044E\u0442 \u043A\u043B\u044E\u0447\u0435\u0432\u0443\u044E
    \u0440\u043E\u043B\u044C \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0435, \u0430 \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437.  ### \U0001F91D \u0411\u043B\u0430\u0433\u043E\u0440\u043E\u0434\u0441\u0442\u0432\u043E
    \u0438 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435 \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u043E\u0432 
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445
    \u0443\u0447\u0451\u043D\u044B\u0445, \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0433\u0440\u044F\u0437\u043D\u044B\u0445 \u0441\u043F\u043E\u0440\u0430\u0445
    \u0437\u0430 \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442. \u042D\u0442\u043E
    \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u0430\u044F
    \u043F\u043E\u0437\u0438\u0446\u0438\u044F. \u0421\u0430\u043C\u044B\u043C \u044F\u0440\u043A\u0438\u043C
    \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u043C \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u041E\u043D \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0435\u0451 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u0434\u043E \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430.
    \u041E\u0434\u043D\u0430\u043A\u043E \u043E\u043D \u0434\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u043E
    \u0443\u0441\u0442\u0443\u043F\u0438\u043B \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442,
    \u043D\u0430\u0437\u0432\u0430\u0432 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438\u043C\u0435\u043D\u0435\u043C \u041B\u043E\u0440\u0435\u043D\u0446\u0430,
    \u0445\u043E\u0442\u044F \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u043D \u043F\u0440\u0438\u0434\u0430\u043B
    \u0438\u043C \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0432\u0438\u0434. \u0414\u043B\u044F \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u043E
    \u0432\u0430\u0436\u043D\u0435\u0435, \u0447\u0442\u043E \u0442\u0435\u043E\u0440\u0438\u044F
    \u043A\u0440\u0430\u0441\u0438\u0432\u0430 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u0430,
    \u0447\u0435\u043C \u0447\u044C\u0451-\u0442\u043E \u0438\u043C\u044F \u043D\u0430
    \u043D\u0435\u0439.  ### \u26A1 \u041F\u0440\u043E\u0447\u0438\u0435 \u043A\u0443\u0440\u044C\u0451\u0437\u044B 
    *   **\u0426\u0432\u0435\u0442\u043D\u043E\u0439 \u0441\u043B\u0443\u0445**:
    \u041F\u043E\u0441\u043B\u0435 \u043F\u0435\u0440\u0435\u043D\u0435\u0441\u0451\u043D\u043D\u043E\u0439
    \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u0434\u0438\u0444\u0442\u0435\u0440\u0438\u0438
    \u0443 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0440\u0430\u0437\u0432\u0438\u043B\u0430\u0441\u044C
    \u0441\u0438\u043D\u0435\u0441\u0442\u0435\u0437\u0438\u044F \u2014 \u043E\u043D
    \u0430\u0441\u0441\u043E\u0446\u0438\u0438\u0440\u043E\u0432\u0430\u043B \u0437\u0432\u0443\u043A\u0438
    \u0441 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u043C\u0438
    \u0446\u0432\u0435\u0442\u0430\u043C\u0438. \u042D\u0442\u0430 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C \u0443 \u043D\u0435\u0433\u043E
    \u043D\u0430 \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C. *   **\u0412\u043D\u0435\u0448\u043D\u0438\u0439
    \u0432\u0438\u0434**: \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438 \u0435\u0433\u043E \u043A\u0430\u043A
    \u043D\u0435\u0432\u044B\u0441\u043E\u043A\u043E\u0433\u043E (\u043E\u043A\u043E\u043B\u043E
    165 \u0441\u043C) \u0431\u043B\u043E\u043D\u0434\u0438\u043D\u0430 \u0441 \u043E\u0447\u0435\u043D\u044C
    \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u0433\u043E\u043B\u043E\u0432\u043E\u0439,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432 \u0448\u0438\u0440\u0438\u043D\u0443.
    \u041E\u043D \u0441\u0442\u043E\u044F\u043B, \u0441\u0443\u0442\u0443\u043B\u044F\u0441\u044C
    \u0438 \u0437\u0430\u043F\u0440\u043E\u043A\u0438\u043D\u0443\u0432 \u043C\u043E\u0440\u0449\u0438\u043D\u0438\u0441\u0442\u044B\u0439
    \u043B\u043E\u0431, \u0438 \u0433\u043E\u0432\u043E\u0440\u0438\u043B \u0441
    \u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u044B\u043C \u0432\u0438\u0434\u043E\u043C,
    \u043A\u0430\u043A \u0431\u0443\u0434\u0442\u043E \u0434\u0443\u043C\u0430\u043B
    \u043E \u0447\u0451\u043C-\u0442\u043E \u0434\u0440\u0443\u0433\u043E\u043C,
    \u0434\u0430\u0436\u0435 \u043A\u043E\u0433\u0434\u0430 \u0431\u044B\u043B \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043D
    \u0432 \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440\u0435. *   **\u0424\u0438\u043B\u043E\u0441\u043E\u0444,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043D\u0435 \u043B\u044E\u0431\u0438\u043B\u0438
    \u0432 \u0421\u0421\u0421\u0420**: \u0412 \u0421\u0421\u0421\u0420 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    \xAB\u0442\u0438\u043F\u0438\u0447\u043D\u044B\u043C \u0431\u0443\u0440\u0436\u0443\u0430\u0437\u043D\u044B\u043C
    \u0438\u0434\u0435\u0430\u043B\u0438\u0437\u043C\u043E\u043C\xBB. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u044B \u0431\u044B\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B,
    \u0447\u0442\u043E \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u0430\u044F \u043D\u0430\u0443\u043A\u0430
    \u043D\u0435 \u043C\u043E\u0433\u043B\u0430 \u043E\u0431\u043E\u0439\u0442\u0438\u0441\u044C
    \u0431\u0435\u0437 \u043D\u0438\u0445, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0440\u0430\u0434\u0438\u043E\u0444\u0438\u0437\u0438\u043A\u0438
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u0439."
