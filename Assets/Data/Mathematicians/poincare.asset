  achievementsRu: "\u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435,
    \u0431\u0435\u0441\u0441\u043F\u043E\u0440\u043D\u043E, \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0438\u0433\u0443\u0440 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430\u0443\u043A\u0438. \u0415\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0444\u0438\u0437\u0438\u043A\u0438 \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438.
    \u0412\u043A\u043B\u0430\u0434 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C
    \u2014 \u0432\u043E \u043C\u043D\u043E\u0433\u0438\u0445 \u0441\u043B\u0443\u0447\u0430\u044F\u0445
    \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B \u0446\u0435\u043B\u044B\u0435
    \u043D\u043E\u0432\u044B\u0435 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u043C\u044B\u0441\u043B\u0438. \u041D\u0438\u0436\u0435
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u044B \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u0438 \u0442\u0440\u0443\u0434\u044B
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0432 \u0434\u0435\u0442\u0430\u043B\u044F\u0445. 
    ### \U0001F9EE \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:
    \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043D\u043E\u0432\u043E\u0439
    \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438  \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0435\u0440\u0435\u0432\u043E\u0440\u043E\u0442
    \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u0440\u0430\u0437\u0434\u0435\u043B\u0430\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0415\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0437\u0434\u0435\u0441\u044C :  *   **\u0422\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F
    (Analysis Situs)**: \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u043F\u043E
    \u043F\u0440\u0430\u0432\u0443 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0442\u0446\u043E\u043C \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    \u2014 \u0440\u0430\u0437\u0434\u0435\u043B\u0430, \u0438\u0437\u0443\u0447\u0430\u044E\u0449\u0435\u0433\u043E
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u044E\u0442\u0441\u044F
    \u043F\u0440\u0438 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0445
    \u0434\u0435\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F\u0445.     *   **\u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F**: \u041E\u043D \u0432\u0432\u0435\u043B
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u044F
    **\u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u044B** \u0438 **\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438**,
    \u0437\u0430\u043B\u043E\u0436\u0438\u0432 \u043E\u0441\u043D\u043E\u0432\u044B
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438. \u042D\u0442\u0438 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0442 \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430 \u043F\u043E
    \u0438\u0445 \xAB\u0434\u044B\u0440\u043A\u0430\u043C\xBB \u0438 \xAB\u0440\u0443\u0447\u043A\u0430\u043C\xBB.    
    *   **\u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435**:
    \u0415\u0433\u043E \u0441\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430, \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u0432 1904 \u0433\u043E\u0434\u0443, \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u043B\u044E\u0431\u043E\u0435 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0435
    \u0442\u0440\u0435\u0445\u043C\u0435\u0440\u043D\u043E\u0435 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0433\u043E\u043C\u043E\u0442\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u0438
    \u044D\u043A\u0432\u0438\u0432\u0430\u043B\u0435\u043D\u0442\u043D\u043E \u0442\u0440\u0435\u0445\u043C\u0435\u0440\u043D\u043E\u0439
    \u0441\u0444\u0435\u0440\u0435, \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0441\u0444\u0435\u0440\u043E\u0439. \u042D\u0442\u0430 \u0437\u0430\u0434\u0430\u0447\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u0431\u044B\u043B\u0430 \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u0430
    \u0413\u0440\u0438\u0433\u043E\u0440\u0438\u0435\u043C \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u043E\u043C
    \u043B\u0438\u0448\u044C \u0432 2002-2003 \u0433\u043E\u0434\u0430\u0445.  *  
    **\u041A\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F \u0442\u0435\u043E\u0440\u0438\u044F
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439**: \u0412\u043C\u0435\u0441\u0442\u043E
    \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B \u043F\u044B\u0442\u0430\u0442\u044C\u0441\u044F
    \u043D\u0430\u0439\u0442\u0438 \u0442\u043E\u0447\u043D\u044B\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439, \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043C\u0435\u0442\u043E\u0434\u044B,
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0438\u0435 \u043F\u043E\u043D\u044F\u0442\u044C
    **\u043E\u0431\u0449\u0435\u0435 \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435**
    \u0438\u0445 \u0440\u0435\u0448\u0435\u043D\u0438\u0439. \u042D\u0442\u043E \u0434\u0430\u043B\u043E
    \u0442\u043E\u043B\u0447\u043E\u043A \u043A \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0434\u0438\u043D\u0430\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C.  *   **\u0410\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438**: \u041E\u043D \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B
    \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0441\u0432\u044F\u0437\u044C
    \u043C\u0435\u0436\u0434\u0443 \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u043C\u0438
    \u0438 \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C\u0438, \u043F\u043E\u043A\u0430\u0437\u0430\u0432,
    \u0447\u0442\u043E \u043E\u043D\u0438 \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u0442
    \u043E\u0434\u043D\u043E\u0439 \u0438 \u0442\u043E\u0439 \u0436\u0435 \u0433\u0440\u0443\u043F\u043F\u0435
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439.  ### \U0001F30C \u041D\u0435\u0431\u0435\u0441\u043D\u0430\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430: \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0445\u0430\u043E\u0441\u0430  \u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043D\u0435\u0431\u0435\u0441\u043D\u043E\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438
    \u043F\u0440\u0438\u0432\u0435\u043B\u0438 \u043A \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044E,
    \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0435\u043C\u0443 \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043C\u0438\u0440\u043E\u0432\u043E\u0437\u0437\u0440\u0435\u043D\u0438\u0435. 
    *   **\u0417\u0430\u0434\u0430\u0447\u0430 \u0442\u0440\u0435\u0445 \u0442\u0435\u043B**:
    \u0412 1889 \u0433\u043E\u0434\u0443 \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u0443
    \u043F\u043E \u044D\u0442\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0435 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0440\u0435\u043C\u0438\u044E
    \u043A\u043E\u0440\u043E\u043B\u044F \u041E\u0441\u043A\u0430\u0440\u0430 II.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0432 \u0445\u043E\u0434\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B \u0441\u0435\u043D\u0441\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435. \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0432 \u0441\u0438\u0441\u0442\u0435\u043C\u0435 \u0438\u0437
    \u0442\u0440\u0435\u0445 \u0433\u0440\u0430\u0432\u0438\u0442\u0438\u0440\u0443\u044E\u0449\u0438\u0445
    \u0442\u0435\u043B \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u0442\u044C
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u043D\u0430 \u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0441\u0440\u043E\u043A **\u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E**.
    *   **\u0414\u0435\u0442\u0435\u0440\u043C\u0438\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0445\u0430\u043E\u0441**: \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043C\u0430\u043B\u0435\u0439\u0448\u0430\u044F
    \u043E\u0448\u0438\u0431\u043A\u0430 \u0432 \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u044B\u0445
