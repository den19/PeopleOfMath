  achievementsRu: "\u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0411\u043B\u0435\u0437\u0430 \u041F\u0430\u0441\u043A\u0430\u043B\u044F \u2014
    \u044D\u0442\u043E \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u043F\u0440\u0438\u043C\u0435\u0440 \u0442\u043E\u0433\u043E, \u043A\u0430\u043A
    \u0432\u0441\u0435\u0433\u043E \u0437\u0430 \u0434\u0432\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u043C\u043E\u0436\u043D\u043E \u0437\u0430\u043B\u043E\u0436\u0438\u0442\u044C
    \u043E\u0441\u043D\u043E\u0432\u044B \u0441\u0440\u0430\u0437\u0443 \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445 \u043D\u0430\u0443\u043A\u0438.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u043F\u0440\u043E\u0441\u0442\u0438\u0440\u0430\u0435\u0442\u0441\u044F
    \u043E\u0442 \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0434\u043E \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u043E\u0439 \u0444\u0438\u0437\u0438\u043A\u0438
    \u0438 \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0442\u0435\u0445\u043D\u0438\u043A\u0438.  ### \U0001F9EE \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:
    \u041E\u0442 \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0434\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439  \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u041F\u0430\u0441\u043A\u0430\u043B\u044F
    \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0442 \u043A\u0430\u043A
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E, \u0442\u0430\u043A \u0438
    \u043D\u043E\u0432\u0443\u044E \u0434\u043B\u044F \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.  *  
    **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u041F\u0430\u0441\u043A\u0430\u043B\u044F
    (\u041F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u0430\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F):**
    \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 16 \u043B\u0435\u0442
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0441\u0432\u043E\u044E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u043E \"\u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0448\u0435\u0441\u0442\u0438\u0432\u0435\u0440\u0448\u0438\u043D\u043D\u0438\u043A\u0435\".
    \u0421\u0443\u0442\u044C \u0435\u0435 \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E
    \u0443 \u043B\u044E\u0431\u043E\u0433\u043E \u0448\u0435\u0441\u0442\u0438\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430,
    \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E \u0432 \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0441\u0435\u0447\u0435\u043D\u0438\u0435 (\u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u044C,
    \u044D\u043B\u043B\u0438\u043F\u0441, \u043F\u0430\u0440\u0430\u0431\u043E\u043B\u0443
    \u0438\u043B\u0438 \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u0443), \u0442\u043E\u0447\u043A\u0438
    \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u044F \u0442\u0440\u0435\u0445
    \u043F\u0430\u0440 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u044B\u0445
    \u0441\u0442\u043E\u0440\u043E\u043D \u043B\u0435\u0436\u0430\u0442 \u043D\u0430
    \u043E\u0434\u043D\u043E\u0439 \u043F\u0440\u044F\u043C\u043E\u0439. \u042D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430, \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u043D\u0430\u044F
    \u0432 \"\u041E\u043F\u044B\u0442\u0435 \u043E \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0435\u0447\u0435\u043D\u0438\u044F\u0445\", \u0441\u0442\u0430\u043B\u0430
    \u043C\u043E\u0449\u043D\u044B\u043C \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u0435\u043C
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u041F\u0430\u043F\u043F\u0430 \u0438
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0430 \u043E\u0441\u043D\u043E\u0432\u044B
    \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.
    *   **\u0422\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A \u041F\u0430\u0441\u043A\u0430\u043B\u044F
    \u0438 \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0430:**
    \u0425\u043E\u0442\u044F \u044D\u0442\u0430 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0430\u0431\u043B\u0438\u0446\u0430 \u0431\u044B\u043B\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u0438 \u0434\u043E \u043D\u0435\u0433\u043E \u0432 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445
    \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u0430\u0445, \u0438\u043C\u0435\u043D\u043D\u043E
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0432 \u0441\u0432\u043E\u0435\u043C
    \"\u0422\u0440\u0430\u043A\u0442\u0430\u0442\u0435 \u043E\u0431 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0435\" (1654)
    \u0432\u0441\u0435\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0435 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u0435\u0435 \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430.
    \u042D\u0442\u043E\u0442 \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u043D\u043E\u0441\u0438\u0442
    \u0435\u0433\u043E \u0438\u043C\u044F. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439:** \u0412
    \u0445\u043E\u0434\u0435 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0438
    \u0441 \u041F\u044C\u0435\u0440\u043E\u043C \u0424\u0435\u0440\u043C\u0430 \u0432
    1654 \u0433\u043E\u0434\u0443 \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0440\u0435\u0448\u0438\u043B
    \"\u0437\u0430\u0434\u0430\u0447\u0443 \u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u0441\u0442\u0430\u0432\u043E\u043A\", \u0437\u0430\u043B\u043E\u0436\u0438\u0432
    \u043E\u0441\u043D\u043E\u0432\u044B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u043D\u043E\u0435
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0435 \u0432 \u0441\u0432\u043E\u0435\u043C
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u043C \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u043C
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442\u0435 \u2014 \"\u0441\u0442\u0430\u0432\u043A\u0435
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F\".  ### \u2699\uFE0F \u0424\u0438\u0437\u0438\u043A\u0430
    \u0438 \u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0430:
    \u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0437\u0430\u043A\u043E\u043D\u044B  \u0412\u043A\u043B\u0430\u0434 \u041F\u0430\u0441\u043A\u0430\u043B\u044F
    \u0432 \u0444\u0438\u0437\u0438\u043A\u0443 \u0431\u044B\u043B \u043D\u0435 \u043C\u0435\u043D\u0435\u0435
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u043C
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043D \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u043C\u0438
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043C\u0438. 
    *   **\u0417\u0430\u043A\u043E\u043D \u041F\u0430\u0441\u043A\u0430\u043B\u044F
    (\u0413\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0430):**
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0444\u0438\u0437\u0438\u043A\u0443 \u2014 \u044D\u0442\u043E \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0437\u0430\u043A\u043E\u043D\u0430, \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435,
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0438\u043C\u043E\u0435 \u043D\u0430
    \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u044C \u0438\u043B\u0438 \u0433\u0430\u0437,
    \u043F\u0435\u0440\u0435\u0434\u0430\u0435\u0442\u0441\u044F \u0431\u0435\u0437
    \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u044F \u0432 \u043A\u0430\u0436\u0434\u0443\u044E
    \u0442\u043E\u0447\u043A\u0443 \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0438
    \u0438\u043B\u0438 \u0433\u0430\u0437\u0430. \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u0441\u0442\u0430\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0433\u0438\u0434\u0440\u0430\u0432\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u0430\u0448\u0438\u043D, \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0433\u0438\u0434\u0440\u0430\u0432\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0440\u0435\u0441\u0441, \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043E\u043D \u0441\u0430\u043C
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E \u043E\u043F\u0438\u0441\u0430\u043B.
    *   **\u041E\u043F\u044B\u0442 \u043D\u0430 \u0433\u043E\u0440\u0435 \u041F\u044E\u0438-\u0434\u0435-\u0414\u043E\u043C:**
    \u0412 1648 \u0433\u043E\u0434\u0443 \u043F\u043E \u0438\u0434\u0435\u0435 \u041F\u0430\u0441\u043A\u0430\u043B\u044F
    \u0435\u0433\u043E \u0437\u044F\u0442\u044C \u0424\u043B\u043E\u0440\u0430\u043D
    \u041F\u0435\u0440\u044C\u0435 \u043F\u0440\u043E\u0432\u0435\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442: \u0438\u0437\u043C\u0435\u0440\u0438\u043B
    \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u0440\u0442\u0443\u0442\u0438 \u0432
    \u0431\u0430\u0440\u043E\u043C\u0435\u0442\u0440\u0435 \u0443 \u043F\u043E\u0434\u043D\u043E\u0436\u0438\u044F
    \u0438 \u043D\u0430 \u0432\u0435\u0440\u0448\u0438\u043D\u0435 \u0433\u043E\u0440\u044B
    \u041F\u044E\u0438-\u0434\u0435-\u0414\u043E\u043C. \u041F\u0430\u0434\u0435\u043D\u0438\u0435
    \u0443\u0440\u043E\u0432\u043D\u044F \u0440\u0442\u0443\u0442\u0438 \u043D\u0430
    \u0432\u0435\u0440\u0448\u0438\u043D\u0435 \u0441\u0442\u0430\u043B\u043E \u043D\u0435\u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0436\u0438\u043C\u044B\u043C
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u043D\u043E\u0433\u043E \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0438 \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043B\u043E \u0443\u0447\u0435\u043D\u0438\u0435
    \u043E \"\u0431\u043E\u044F\u0437\u043D\u0438 \u043F\u0443\u0441\u0442\u043E\u0442\u044B\".
    *   **\"\u0422\u0440\u0430\u043A\u0442\u0430\u0442 \u043E \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0438
    \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0435\u0439\" \u0438 \"\u0422\u0440\u0430\u043A\u0442\u0430\u0442
    \u043E \u0432\u0435\u0441\u0435 \u0432\u043E\u0437\u0434\u0443\u0445\u0430\":**
    \u0412 \u044D\u0442\u0438\u0445 \u0440\u0430\u0431\u043E\u0442\u0430\u0445, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438,
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u043E\u0431\u043E\u0431\u0449\u0438\u043B \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
    \u0441\u0432\u043E\u0438\u0445 \u043E\u043F\u044B\u0442\u043E\u0432, \u0434\u043E\u043A\u0430\u0437\u0430\u0432,
    \u0447\u0442\u043E \u0432\u043E\u0437\u0434\u0443\u0445 \u0438\u043C\u0435\u0435\u0442
    \u0432\u0435\u0441 \u0438 \u043F\u043E\u0434\u0447\u0438\u043D\u044F\u0435\u0442\u0441\u044F
    \u0442\u0435\u043C \u0436\u0435 \u0437\u0430\u043A\u043E\u043D\u0430\u043C \u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0438,
    \u0447\u0442\u043E \u0438 \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0438. 
    ### \U0001F4BB \u0422\u0435\u0445\u043D\u0438\u043A\u0430 \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F 
    \u0421\u0442\u0440\u0435\u043C\u043B\u0435\u043D\u0438\u0435 \u043A \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u044E \u0437\u043D\u0430\u043D\u0438\u0439
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u041F\u0430\u0441\u043A\u0430\u043B\u044F
    \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438. 
    *   **\"\u041F\u0430\u0441\u043A\u0430\u043B\u0438\u043D\u0430\" (\u0421\u0447\u0435\u0442\u043D\u0430\u044F
    \u043C\u0430\u0448\u0438\u043D\u0430):** \u0412 1642 \u0433\u043E\u0434\u0443,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 19 \u043B\u0435\u0442,
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0443
    \u043D\u0430\u0434 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435\u043C \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0447\u0435\u0442\u043D\u043E\u0439 \u043C\u0430\u0448\u0438\u043D\u044B,
    \u0447\u0442\u043E\u0431\u044B \u043E\u0431\u043B\u0435\u0433\u0447\u0438\u0442\u044C
    \u0441\u0432\u043E\u0435\u043C\u0443 \u043E\u0442\u0446\u0443, \u043D\u0430\u043B\u043E\u0433\u043E\u0432\u043E\u043C\u0443
    \u0441\u0431\u043E\u0440\u0449\u0438\u043A\u0443, \u0443\u0442\u043E\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0440\u0430\u0441\u0447\u0435\u0442\u044B. \u0412 \u043E\u0441\u043D\u043E\u0432\u0435
    \"\u041F\u0430\u0441\u043A\u0430\u043B\u0438\u043D\u044B\" \u043B\u0435\u0436\u0430\u043B
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445
    \u043A\u043E\u043B\u0435\u0441: \u043F\u0440\u0438 \u043F\u043E\u043B\u043D\u043E\u043C
    \u043E\u0431\u043E\u0440\u043E\u0442\u0435 \u043A\u043E\u043B\u0435\u0441\u0430
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0441 9 \u0434\u043E 0),
    \u043E\u043D\u043E \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u043B\u043E \u0435\u0434\u0438\u043D\u0438\u0446\u0443
    \u0432 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439 \u0440\u0430\u0437\u0440\u044F\u0434.
    \u0425\u043E\u0442\u044F \u0438\u0437-\u0437\u0430 \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0432\u044B\u0441\u043E\u043A\u043E\u0439 \u0441\u0442\u043E\u0438\u043C\u043E\u0441\u0442\u0438
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E \u043D\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u043E
    \u043C\u0430\u0441\u0441\u043E\u0432\u043E\u0433\u043E \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044F,
    \u0437\u0430\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0439 \u0432 \u043D\u0435\u0433\u043E
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0430
    \u0440\u0430\u0437\u0440\u044F\u0434\u043E\u0432 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u0432 \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u0435 \u0430\u0440\u0438\u0444\u043C\u043E\u043C\u0435\u0442\u0440\u043E\u0432
    \u0432\u043F\u043B\u043E\u0442\u044C \u0434\u043E XX \u0432\u0435\u043A\u0430. 
    ### \u270D\uFE0F \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u0431\u044B\u043B\u0438 \u0438\u0437\u0434\u0430\u043D\u044B \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E,
    \u043E\u043D\u0438 \u0441\u0442\u0430\u043B\u0438 \u043A\u043B\u0430\u0441\u0441\u0438\u043A\u043E\u0439
    \u043A\u0430\u043A \u043D\u0430\u0443\u0447\u043D\u043E\u0439, \u0442\u0430\u043A
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0439 \u043C\u044B\u0441\u043B\u0438. 
    | \u041D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \u0442\u0440\u0443\u0434\u0430
    | \u0413\u043E\u0434 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F/\u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438
    | \u041A\u0440\u0430\u0442\u043A\u043E\u0435 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    | | :--- | :--- | :--- | | \"\u041E\u043F\u044B\u0442 \u043E \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0435\u0447\u0435\u043D\u0438\u044F\u0445\" | 1640 | \u0420\u0430\u0431\u043E\u0442\u0430,
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0430\u044F **\u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F**, \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u0430\u044F
    \u0432 16 \u043B\u0435\u0442. | | \"\u0422\u0440\u0430\u043A\u0442\u0430\u0442
    \u043E\u0431 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0435\" |
    1654 | \u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432 **\u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F** \u0438 \u0435\u0433\u043E \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0439
    \u0432 \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0435.
    | | \"\u0422\u0440\u0430\u043A\u0442\u0430\u0442 \u043E \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0438
    \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0435\u0439\" \u0438 \"\u0422\u0440\u0430\u043A\u0442\u0430\u0442
    \u043E \u0432\u0435\u0441\u0435 \u0432\u043E\u0437\u0434\u0443\u0445\u0430\"
    | 1663 (\u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E) | \u0420\u0430\u0431\u043E\u0442\u044B,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0438\u0437\u043B\u043E\u0436\u0435\u043D
    **\u0437\u0430\u043A\u043E\u043D \u041F\u0430\u0441\u043A\u0430\u043B\u044F**
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u043D\u043E\u0433\u043E \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F.
    |"
  achievementsEn: 
  personalLifeRu: "\u0416\u0438\u0437\u043D\u044C \u0411\u043B\u0435\u0437\u0430
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0433\u043E \u0432\u0437\u043B\u0435\u0442\u0430,
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E\u0439 \u0431\u043E\u0440\u044C\u0431\u044B
    \u0441 \u0445\u0440\u0443\u043F\u043A\u0438\u043C \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435\u043C
    \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0433\u043E \u0434\u0443\u0445\u043E\u0432\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0435\u0432\u043E\u0440\u043E\u0442\u0430. \u0415\u0433\u043E
    \u043B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430
    \u0442\u0435\u0441\u043D\u043E \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u0430
    \u0441 \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u043E\u0439
    \u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u043C\u0438 \u0441
    \u0431\u043B\u0438\u0437\u043A\u0438\u043C\u0438, \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u0435\u0442
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E \u043F\u043E-\u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u043C\u0443
    \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u043E\u0439.  ### \U0001F476
    \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435, \u0441\u0435\u043C\u044C\u044F
    \u0438 \u0434\u0435\u0442\u0441\u0442\u0432\u043E \u0432 \u041E\u0432\u0435\u0440\u043D\u0438 
    \u0411\u043B\u0435\u0437 \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    19 \u0438\u044E\u043D\u044F 1623 \u0433\u043E\u0434\u0430 \u0432 \u0433\u043E\u0440\u043E\u0434\u0435
    \u041A\u043B\u0435\u0440\u043C\u043E\u043D-\u0424\u0435\u0440\u0440\u0430\u043D
    \u043D\u0430 \u044E\u0433\u0435 \u0424\u0440\u0430\u043D\u0446\u0438\u0438. \u041E\u043D
    \u0431\u044B\u043B \u0442\u0440\u0435\u0442\u044C\u0438\u043C \u0440\u0435\u0431\u0435\u043D\u043A\u043E\u043C
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u042D\u0442\u044C\u0435\u043D\u0430 \u041F\u0430\u0441\u043A\u0430\u043B\u044F,
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u0441\u0443\u0434\u044C\u0438
    \u0438 \u043D\u0430\u043B\u043E\u0433\u043E\u0432\u043E\u0433\u043E \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u0430,
    \u0438 \u0410\u043D\u0442\u0443\u0430\u043D\u0435\u0442\u0442\u044B \u0411\u0435\u0433\u043E\u043D.
    \u0421\u0435\u043C\u044C\u044F \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u043B\u0430
    \u043A \"\u0434\u0432\u043E\u0440\u044F\u043D\u0441\u0442\u0432\u0443 \u043C\u0430\u043D\u0442\u0438\u0438\"
    \u2014 \u0441\u043B\u043E\u044E \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u043A\u0443\u043F\u0430\u043B\u0438
    \u0441\u0432\u043E\u0438 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043F\u0435\u0440\u0435\u0434\u0430\u0432\u0430\u043B\u0438 \u0438\u0445
    \u043F\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0443.  \u0421\u0435\u043C\u044C\u044F
    \u041F\u0430\u0441\u043A\u0430\u043B\u0435\u0439 \u0431\u044B\u043B\u0430 \u043E\u0447\u0435\u043D\u044C
    \u0434\u0440\u0443\u0436\u043D\u043E\u0439. \u0423 \u0411\u043B\u0435\u0437\u0430
    \u0431\u044B\u043B\u043E \u0434\u0432\u0435 \u0441\u0435\u0441\u0442\u0440\u044B:
    \u0441\u0442\u0430\u0440\u0448\u0430\u044F \u0416\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    (\u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u0432 1620 \u0433\u043E\u0434\u0443)
    \u0438 \u043C\u043B\u0430\u0434\u0448\u0430\u044F \u0416\u0430\u043A\u043B\u0438\u043D
    (\u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u0432 1625 \u0433\u043E\u0434\u0443),
    \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438 \u043E\u043D \u0432\u0441\u044E
    \u0436\u0438\u0437\u043D\u044C \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u043B
    \u0441\u0430\u043C\u044B\u0435 \u0442\u0435\u043F\u043B\u044B\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F.
    \u0415\u0433\u043E \u043C\u0430\u0442\u044C, \u0410\u043D\u0442\u0443\u0430\u043D\u0435\u0442\u0442\u0430,
    \u0431\u044B\u043B\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430 \u0441\u0432\u043E\u0435\u0439
    \u043A\u0440\u043E\u0442\u043E\u0441\u0442\u044C\u044E \u0438 \u043D\u0430\u0431\u043E\u0436\u043D\u043E\u0441\u0442\u044C\u044E,
    \u043D\u043E \u043E\u043D\u0430 \u0443\u043C\u0435\u0440\u043B\u0430, \u043A\u043E\u0433\u0434\u0430
    \u0411\u043B\u0435\u0437\u0443 \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E
    \u0442\u0440\u0438 \u0433\u043E\u0434\u0430. \u041F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0439
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0435
    \u0434\u0435\u0442\u0435\u0439 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043B\u0435\u0433\u043B\u043E \u043D\u0430 \u043F\u043B\u0435\u0447\u0438 \u043E\u0442\u0446\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0442\u0430\u043A \u0438 \u043D\u0435
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043F\u043E\u0432\u0442\u043E\u0440\u043D\u043E. 
    \u0421\u0430\u043C \u0411\u043B\u0435\u0437 \u0441 \u0440\u0430\u043D\u043D\u0435\u0433\u043E
    \u0434\u0435\u0442\u0441\u0442\u0432\u0430 \u0431\u044B\u043B \u043E\u0447\u0435\u043D\u044C
    \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u043D\u043D\u044B\u043C. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0434\u0430\u0436\u0435 \u043B\u0435\u0433\u0435\u043D\u0434\u0430, \u0447\u0442\u043E
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u0434\u0432\u0443\u0445
    \u043B\u0435\u0442 \u043E\u043D \u0442\u044F\u0436\u0435\u043B\u043E \u0437\u0430\u0431\u043E\u043B\u0435\u043B,
    \u0438 \u0435\u0433\u043E \u0432\u044B\u0437\u0434\u043E\u0440\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0441\u0432\u044F\u0437\u0430\u043B\u0438 \u0441 \"\u0440\u0430\u0441\u043A\u0430\u044F\u043D\u0438\u0435\u043C\"
    \u043C\u0435\u0441\u0442\u043D\u043E\u0439 \u0436\u0435\u043D\u0449\u0438\u043D\u044B,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u0431\u0432\u0438\u043D\u044F\u043B\u0438
    \u0432 \u0441\u0433\u043B\u0430\u0437\u0435. \u0412\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043E\u043D \u0441\u0442\u0440\u0430\u0434\u0430\u043B \u043E\u0442 \u043C\u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0433\u043E\u043B\u043E\u0432\u043D\u044B\u0445 \u0431\u043E\u043B\u0435\u0439
    \u0438 \u043F\u0440\u043E\u0431\u043B\u0435\u043C \u0441 \u043F\u0438\u0449\u0435\u0432\u0430\u0440\u0435\u043D\u0438\u0435\u043C
    \u043D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438 \u043F\u043E\u0447\u0442\u0438
    \u0432\u0441\u0435\u0439 \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438. 
    ### \U0001F4DA \u0423\u0447\u0451\u0431\u0430: \u0424\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \"\u0434\u043E\u043C\u0430\u0448\u043D\u0438\u0439\" \u0442\u0430\u043B\u0430\u043D\u0442 
    \u042D\u0442\u044C\u0435\u043D \u041F\u0430\u0441\u043A\u0430\u043B\u044C, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0441\u0430\u043C \u0443\u0432\u0430\u0436\u0430\u0435\u043C\u044B\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0440\u0435\u0448\u0438\u043B \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C \u0441\u0435\u0431\u044F
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044E \u0434\u0435\u0442\u0435\u0439.
    \u041F\u043E \u0435\u0433\u043E \u043C\u043D\u0435\u043D\u0438\u044E, \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u043E \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u0434\u0440\u0435\u0432\u043D\u0438\u0435 \u044F\u0437\u044B\u043A\u0438 (\u043B\u0430\u0442\u044B\u043D\u044C
    \u0438 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0439), \u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u2014 \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u043D\u0430\u0443\u043A\u0430 \u2014 \u0431\u044B\u043B\u0430 \u043F\u043E\u0434
    \u0441\u0442\u0440\u043E\u0433\u0438\u043C \u0437\u0430\u043F\u0440\u0435\u0442\u043E\u043C
    \u0434\u043E 15 \u043B\u0435\u0442. \u041E\u0434\u043D\u0430\u043A\u043E, \u043A\u0430\u043A
    \u044D\u0442\u043E \u0447\u0430\u0441\u0442\u043E \u0431\u044B\u0432\u0430\u0435\u0442
    \u0441 \u0433\u0435\u043D\u0438\u044F\u043C\u0438, \u0437\u0430\u043F\u0440\u0435\u0442
    \u043B\u0438\u0448\u044C \u0440\u0430\u0437\u0436\u0435\u0433 \u0438\u043D\u0442\u0435\u0440\u0435\u0441. 
    *   **\u0421\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \"\u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\" \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438:**
    \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 12 \u043B\u0435\u0442
    \u0411\u043B\u0435\u0437, \u043D\u0435 \u0437\u043D\u0430\u044F \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0439
    \u0444\u0438\u0433\u0443\u0440, \u043D\u0430\u0447\u0430\u043B \u0440\u0438\u0441\u043E\u0432\u0430\u0442\u044C
    \u0443\u0433\u043B\u0435\u043C \u043D\u0430 \u043F\u043E\u043B\u0443 \u0438 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B 32-\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u043E \u0441\u0443\u043C\u043C\u0435
    \u0443\u0433\u043B\u043E\u0432 \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430.
    \u041F\u043E\u0440\u0430\u0436\u0435\u043D\u043D\u044B\u0439 \u043E\u0442\u0435\u0446
    \u0442\u0443\u0442 \u0436\u0435 \u0441\u043D\u044F\u043B \u0437\u0430\u043F\u0440\u0435\u0442
    \u0438 \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043B \u0441\u044B\u043D\u0443
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u044B. *   **\u041D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0441\u0440\u0435\u0434\u0430:** \u042D\u0442\u044C\u0435\u043D \u0432\u0432\u0435\u043B
    \u0441\u044B\u043D\u0430 \u0432 \u043A\u0440\u0443\u0436\u043E\u043A \u041C\u0430\u0440\u0435\u043D\u0430
    \u041C\u0435\u0440\u0441\u0435\u043D\u043D\u0430 \u2014 \u044D\u043B\u0438\u0442\u043D\u044B\u0439
    \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0439 \u043A\u043B\u0443\u0431,
    \u0433\u0434\u0435 \u0441\u043E\u0431\u0438\u0440\u0430\u043B\u0438\u0441\u044C
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0435 \u0443\u043C\u044B
    \u0415\u0432\u0440\u043E\u043F\u044B (\u0420\u043E\u0431\u0435\u0440\u0432\u0430\u043B\u044C,
    \u0414\u0435\u0437\u0430\u0440\u0433, \u0413\u0430\u0441\u0441\u0435\u043D\u0434\u0438).
    \u0422\u0430\u043C, \u0435\u0449\u0435 \u0431\u0443\u0434\u0443\u0447\u0438 \u043F\u043E\u0434\u0440\u043E\u0441\u0442\u043A\u043E\u043C,
    \u0411\u043B\u0435\u0437 \u0432\u043F\u0438\u0442\u044B\u0432\u0430\u043B \u0441\u0430\u043C\u044B\u0435
    \u043F\u0435\u0440\u0435\u0434\u043E\u0432\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0438\u0434\u0435\u0438 \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. 
    ### \U0001F468\u200D\U0001F4BC \u0420\u0430\u0431\u043E\u0442\u0430 \u0438 \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C  \u041D\u0430\u0443\u0447\u043D\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u041F\u0430\u0441\u043A\u0430\u043B\u044F
    \u0431\u044B\u043B\u0430 \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0438 \u0441\u043E\u043F\u0440\u043E\u0432\u043E\u0436\u0434\u0430\u043B\u0430\u0441\u044C
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u044B\u043C\u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F\u043C\u0438. 
    *   **\u041F\u0435\u0440\u0432\u044B\u0435 \u0442\u0440\u0443\u0434\u044B:**
    \u0412 16 \u043B\u0435\u0442 \u043E\u043D \u043F\u0438\u0448\u0435\u0442 \u0442\u0440\u0430\u043A\u0442\u0430\u0442
    \"\u041E\u043F\u044B\u0442 \u043E \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0435\u0447\u0435\u043D\u0438\u044F\u0445\", \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u0443\u0435\u0442 \u0441\u0432\u043E\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u043E \"\u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C \u0448\u0435\u0441\u0442\u0438\u0432\u0435\u0440\u0448\u0438\u043D\u043D\u0438\u043A\u0435\".
    \u042D\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u043F\u043E\u0442\u0440\u044F\u0441\u043B\u043E \u0434\u0430\u0436\u0435 \u0414\u0435\u043A\u0430\u0440\u0442\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0432\u0435\u0440\u0438\u0442\u044C, \u0447\u0442\u043E \u0435\u0433\u043E \u0430\u0432\u0442\u043E\u0440\u043E\u043C
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043F\u043E\u0434\u0440\u043E\u0441\u0442\u043E\u043A.
    *   **\"\u041F\u0430\u0441\u043A\u0430\u043B\u0438\u043D\u0430\":** \u0412 1642
    \u0433\u043E\u0434\u0443 (\u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    19 \u043B\u0435\u0442) \u043E\u043D \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0430\u0435\u0442
    \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0447\u0435\u0442\u043D\u043E\u0439 \u043C\u0430\u0448\u0438\u043D\u044B,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043C\u043E\u0447\u044C \u043E\u0442\u0446\u0443,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043D\u0430\u043B\u043E\u0433\u043E\u0432\u044B\u043C \u0438\u043D\u0442\u0435\u043D\u0434\u0430\u043D\u0442\u043E\u043C
    \u0432 \u0420\u0443\u0430\u043D\u0435. \u041F\u043E\u0441\u043B\u0435 \u0431\u043E\u043B\u0435\u0435
    \u0447\u0435\u043C 50 \u043F\u0440\u043E\u0442\u043E\u0442\u0438\u043F\u043E\u0432
    \u043F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \"\u043F\u0430\u0441\u043A\u0430\u043B\u0438\u043D\u0430\"
    \u2014 \u043F\u0435\u0440\u0432\u044B\u0439 \u0432 \u043C\u0438\u0440\u0435 \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0439
    \u043A\u0430\u043B\u044C\u043A\u0443\u043B\u044F\u0442\u043E\u0440, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043C\u043E\u0433 \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0442\u044C
    \u0438 \u0432\u044B\u0447\u0438\u0442\u0430\u0442\u044C, \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u044F \u0440\u0430\u0437\u0440\u044F\u0434\u044B. 
    ### \U0001F465 \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441
    \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438 
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441 \u0432\u0435\u0434\u0443\u0449\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. 
    *   **\u0420\u0435\u043D\u0435 \u0414\u0435\u043A\u0430\u0440\u0442:** \u0418\u0445
    \u043B\u0438\u0447\u043D\u0430\u044F \u0432\u0441\u0442\u0440\u0435\u0447\u0430
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0430\u0441\u044C \u0432 \u041F\u0430\u0440\u0438\u0436\u0435
    \u0432 1647 \u0433\u043E\u0434\u0443. \u0411\u0435\u0441\u0435\u0434\u0430 \u0431\u044B\u043B\u0430
    \u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u043D\u043E\u0439: \u043E\u043D\u0438
    \u043D\u0435 \u0441\u043E\u0448\u043B\u0438\u0441\u044C \u0432\u043E \u0432\u0437\u0433\u043B\u044F\u0434\u0430\u0445
    \u043D\u0430 \u043F\u0440\u0438\u0440\u043E\u0434\u0443 \u0432\u0430\u043A\u0443\u0443\u043C\u0430
    \u0438 \u0440\u043E\u043B\u044C \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430
    \u0432 \u043D\u0430\u0443\u043A\u0435. \u0414\u0435\u043A\u0430\u0440\u0442 \u0441\u043A\u0435\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0442\u043D\u0435\u0441\u0441\u044F \u043A \u044E\u043D\u044B\u043C \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u043C
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F, \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435
    \u043A \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0435 \u043F\u043E \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0441\u0435\u0447\u0435\u043D\u0438\u044F\u043C. *   **\u041F\u044C\u0435\u0440
    \u0424\u0435\u0440\u043C\u0430:** \u0412 1654 \u0433\u043E\u0434\u0443, \u043F\u043E
    \u043F\u0440\u043E\u0441\u044C\u0431\u0435 \u0434\u0440\u0443\u0433\u0430-\u0438\u0433\u0440\u043E\u043A\u0430
    \u0448\u0435\u0432\u0430\u043B\u044C\u0435 \u0434\u0435 \u041C\u0435\u0440\u0435,
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u043D\u0430\u0447\u0430\u043B \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443
    \u0441 \u0424\u0435\u0440\u043C\u0430 \u043E \"\u0437\u0430\u0434\u0430\u0447\u0435
    \u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u0438\u0438 \u0441\u0442\u0430\u0432\u043E\u043A\"
    \u0432 \u0430\u0437\u0430\u0440\u0442\u043D\u044B\u0445 \u0438\u0433\u0440\u0430\u0445.
    \u042D\u0442\u0430 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430 \u0441\u0442\u0430\u043B\u0430
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u043D\u043E\u0432\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u044B \u2014 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.  ###
    \U0001F64F \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0438 \u0434\u0443\u0445\u043E\u0432\u043D\u044B\u0439 \u043F\u0435\u0440\u0435\u043B\u043E\u043C 
    \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u041F\u0430\u0441\u043A\u0430\u043B\u044F
    \u0431\u044B\u043B\u0430 \u043E\u0442\u043C\u0435\u0447\u0435\u043D\u0430 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C\u0438
    \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u043C\u0438 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u044F\u043C\u0438
    \u0438 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u043E\u0431\u044B\u0442\u0438\u044F\u043C\u0438.  *   **\u041F\u0435\u0440\u0432\u043E\u0435
    \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u0435 (1646):** \u041A\u043E\u0433\u0434\u0430
    \u0435\u0433\u043E \u043E\u0442\u0435\u0446 \u0441\u043B\u043E\u043C\u0430\u043B
    \u0431\u0435\u0434\u0440\u043E, \u0432 \u0434\u043E\u043C\u0435 \u043F\u043E\u0441\u0435\u043B\u0438\u043B\u0438\u0441\u044C
    \u0434\u0432\u0430 \u0432\u0440\u0430\u0447\u0430-\u044F\u043D\u0441\u0435\u043D\u0438\u0441\u0442\u0430.
    \u042F\u043D\u0441\u0435\u043D\u0438\u0437\u043C \u0431\u044B\u043B \u0441\u0442\u0440\u043E\u0433\u0438\u043C
    \u0442\u0435\u0447\u0435\u043D\u0438\u0435\u043C \u0432 \u043A\u0430\u0442\u043E\u043B\u0438\u0446\u0438\u0437\u043C\u0435,
    \u0431\u043B\u0438\u0437\u043A\u0438\u043C \u043A \u0438\u0434\u0435\u044F\u043C
    \u0410\u0432\u0433\u0443\u0441\u0442\u0438\u043D\u0430. \u041F\u043E\u0434 \u0438\u0445
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u0438 \u0432\u0441\u044F \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u044F \u043F\u0440\u043E\u043D\u0438\u043A\u043B\u0438\u0441\u044C
    \u044D\u0442\u043E\u0439 \u0441\u0443\u0440\u043E\u0432\u043E\u0439 \u0434\u043E\u043A\u0442\u0440\u0438\u043D\u043E\u0439.
    *   **\"\u0421\u0432\u0435\u0442\u0441\u043A\u0438\u0439\" \u043F\u0435\u0440\u0438\u043E\u0434
    (1651-1654):** \u0412 1651 \u0433\u043E\u0434\u0443 \u0443\u043C\u0438\u0440\u0430\u0435\u0442
    \u043E\u0442\u0435\u0446, \u0430 \u0432 1652 \u0433\u043E\u0434\u0443 \u0435\u0433\u043E
    \u043C\u043B\u0430\u0434\u0448\u0430\u044F \u0441\u0435\u0441\u0442\u0440\u0430
    \u0416\u0430\u043A\u043B\u0438\u043D \u0443\u0445\u043E\u0434\u0438\u0442 \u0432
    \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u044C \u041F\u043E\u0440-\u0420\u043E\u044F\u043B\u044C
    \u2014 \u0446\u0435\u043D\u0442\u0440 \u044F\u043D\u0441\u0435\u043D\u0438\u0437\u043C\u0430.
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0442\u044F\u0436\u0435\u043B\u043E
    \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u0435\u0442 \u044D\u0442\u0438
    \u043F\u043E\u0442\u0435\u0440\u0438 \u0438 \u043E\u0442\u0434\u0430\u043B\u044F\u0435\u0442\u0441\u044F
    \u043E\u0442 \u0440\u0435\u043B\u0438\u0433\u0438\u0438. \u0412\u0440\u0430\u0447\u0438
    \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0443\u044E\u0442 \u0435\u043C\u0443
    \u0440\u0430\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F, \u0438 \u043E\u043D
    \u043E\u043A\u0443\u043D\u0430\u0435\u0442\u0441\u044F \u0432 \u0441\u0432\u0435\u0442\u0441\u043A\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C: \u043F\u043E\u0441\u0435\u0449\u0430\u0435\u0442
    \u0431\u0430\u043B\u044B, \u0442\u0435\u0430\u0442\u0440\u044B, \u0441\u0430\u043B\u043E\u043D\u044B.
    \u0412 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D
    \u0437\u0430\u0432\u043E\u0434\u0438\u0442 \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u0430
    \u0432 \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0443\u0433\u0430\u0445 \u0438 \u0434\u0430\u0436\u0435 \u0443\u0445\u0430\u0436\u0438\u0432\u0430\u0435\u0442
    \u0437\u0430 \u0434\u0435\u0432\u0443\u0448\u043A\u0430\u043C\u0438, \u043D\u043E,
    \u043F\u043E \u0441\u043B\u043E\u0432\u0430\u043C \u0435\u0433\u043E \u0441\u0435\u0441\u0442\u0440\u044B,
    \u044D\u0442\u043E \u0431\u044B\u043B \"\u043C\u0438\u0440\u0441\u043A\u043E\u0439
    \u0434\u0443\u0445, \u0432\u0435\u0441\u044C\u043C\u0430 \u043E\u0442\u043B\u0438\u0447\u043D\u044B\u0439
    \u043E\u0442 \u0435\u0432\u0430\u043D\u0433\u0435\u043B\u044C\u0441\u043A\u043E\u0433\u043E\".
    *   **\u041D\u043E\u0447\u044C \u043E\u0433\u043D\u044F (23 \u043D\u043E\u044F\u0431\u0440\u044F
    1654 \u0433\u043E\u0434\u0430):** \u041A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u0435\u0439
    \u0435\u0433\u043E \u0434\u0443\u0445\u043E\u0432\u043D\u044B\u0445 \u0438\u0441\u043A\u0430\u043D\u0438\u0439
    \u0441\u0442\u0430\u043B\u0430 \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043D\u043E\u0447\u044C \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B \"\u0432\u0442\u043E\u0440\u044B\u043C
    \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u0435\u043C\". \u041E\u043D
    \u0437\u0430\u043F\u0438\u0441\u0430\u043B \u043F\u0435\u0440\u0435\u0436\u0438\u0442\u043E\u0435
    \u043D\u0430 \u043A\u043B\u043E\u0447\u043A\u0435 \u043F\u0435\u0440\u0433\u0430\u043C\u0435\u043D\u0442\u0430
    (\"\u041C\u0435\u043C\u043E\u0440\u0438\u0430\u043B\"), \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u043E \u0441\u0430\u043C\u043E\u0439 \u0441\u043C\u0435\u0440\u0442\u0438
    \u043D\u043E\u0441\u0438\u043B \u0437\u0430\u0448\u0438\u0442\u044B\u043C \u0432
    \u043F\u043E\u0434\u043A\u043B\u0430\u0434\u043A\u0443 \u043A\u0430\u043C\u0437\u043E\u043B\u0430.
    *   **\u0416\u0438\u0437\u043D\u044C \u0432 \u041F\u043E\u0440-\u0420\u043E\u044F\u043B\u0435:**
    \u041F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0439 \u043D\u043E\u0447\u0438
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0443\u0434\u0430\u043B\u044F\u0435\u0442\u0441\u044F
    \u0432 \u041F\u043E\u0440-\u0420\u043E\u044F\u043B\u044C. \u041E\u043D \u043D\u0435
    \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u043C\u043E\u043D\u0430\u0445\u043E\u043C,
    \u043D\u043E \u043F\u0440\u0435\u043A\u0440\u0430\u0449\u0430\u0435\u0442 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0438\u0437\u044B\u0441\u043A\u0430\u043D\u0438\u044F \u0438 \u043F\u043E\u0441\u0432\u044F\u0449\u0430\u0435\u0442
    \u0441\u0435\u0431\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u0438 \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u0438. \u041E\u043D \u0432\u0435\u0434\u0435\u0442
    \u0430\u0441\u043A\u0435\u0442\u0438\u0447\u043D\u044B\u0439 \u043E\u0431\u0440\u0430\u0437
    \u0436\u0438\u0437\u043D\u0438: \u0441\u043F\u0438\u0442 \u043D\u0430 \u0436\u0435\u0441\u0442\u043A\u043E\u0439
    \u043F\u043E\u0441\u0442\u0435\u043B\u0438, \u0435\u0441\u0442 \u043D\u0430 \u043A\u0443\u0445\u043D\u0435,
    \u0441\u0442\u0430\u0440\u0430\u0435\u0442\u0441\u044F \u043E\u0431\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
    \u0431\u0435\u0437 \u0441\u043B\u0443\u0433.  ### \U0001F54A\uFE0F \u0421\u043C\u0435\u0440\u0442\u044C 
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u041F\u0430\u0441\u043A\u0430\u043B\u044F \u0431\u044B\u043B\u0438
    \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u044B \u043C\u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0431\u043E\u043B\u0435\u0437\u043D\u044F\u043C\u0438. \u041A 39 \u0433\u043E\u0434\u0430\u043C
    \u043E\u043D \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u043B\u0430\u0431, \u0447\u0442\u043E \u043F\u043E\u0447\u0442\u0438 \u043D\u0435
    \u043C\u043E\u0433 \u043F\u0435\u0440\u0435\u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F.
    \u041E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 \u041F\u0430\u0440\u0438\u0436\u0435
    19 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1662 \u0433\u043E\u0434\u0430,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u0432\u0441\u0435\u0433\u043E
    39 \u043B\u0435\u0442, \u0432 \u043C\u0443\u043A\u0430\u0445 \u043E\u0442 \u043D\u0435\u0438\u0437\u043B\u0435\u0447\u0438\u043C\u043E\u0439
    \u0431\u043E\u043B\u0435\u0437\u043D\u0438. \u0415\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u044C
    \u0441\u0442\u0430\u043B\u0430 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0435\u043C
    \u043A\u043E\u0440\u043E\u0442\u043A\u043E\u0439, \u043D\u043E \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043D\u0430\u0441\u044B\u0449\u0435\u043D\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438,
    \u043F\u043E\u043B\u043D\u043E\u0439 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u043E\u0437\u0440\u0435\u043D\u0438\u0439 \u0438 \u0434\u0443\u0445\u043E\u0432\u043D\u044B\u0445
    \u0438\u0441\u043A\u0430\u043D\u0438\u0439."
  personalLifeEn: 
  shortBioRu: "\u0411\u043B\u0435\u0437 \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    (1623\u20131662) \u2014 \u044D\u0442\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A-\u044D\u043F\u043E\u0445\u0430,
    \u0447\u044C\u044F \u043A\u043E\u0440\u043E\u0442\u043A\u0430\u044F, \u043D\u043E
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E \u043D\u0430\u0441\u044B\u0449\u0435\u043D\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0432\u043C\u0435\u0441\u0442\u0438\u043B\u0430
    \u0432 \u0441\u0435\u0431\u044F \u0438 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u043F\u0440\u043E\u0437\u0440\u0435\u043D\u0438\u044F,
    \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439 \u0434\u0443\u0445\u043E\u0432\u043D\u044B\u0439
    \u043A\u0440\u0438\u0437\u0438\u0441, \u0438 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u0445 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u044B\u0445
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0439.
    \u041E\u043D \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0443\u0447\u0435\u043D\u044B\u043C, \u0430, \u043F\u043E \u043C\u0435\u0442\u043A\u043E\u043C\u0443
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \xAB\u043C\u044B\u0441\u043B\u044F\u0449\u0438\u043C \u0442\u0440\u043E\u0441\u0442\u043D\u0438\u043A\u043E\u043C\xBB,
    \u0447\u044C\u0435 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441\u0442\u0430\u043B\u043E \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u044F\u0440\u043A\u0438\u0445 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u043A\u0440\u0438\u0437\u0438\u0441\u0430 \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u0437\u043D\u0430\u043D\u0438\u044F XVII \u0432\u0435\u043A\u0430. 
    ### \U0001F37C \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435  \u0411\u043B\u0435\u0437
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    19 \u0438\u044E\u043D\u044F 1623 \u0433\u043E\u0434\u0430 \u0432 \u041A\u043B\u0435\u0440\u043C\u043E\u043D-\u0424\u0435\u0440\u0440\u0430\u043D\u0435,
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u042D\u0442\u044C\u0435\u043D\u0430 \u041F\u0430\u0441\u043A\u0430\u043B\u044F,
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u0430
    \u0438 \u043F\u0440\u0435\u0434\u0441\u0435\u0434\u0430\u0442\u0435\u043B\u044F
    \u043D\u0430\u043B\u043E\u0433\u043E\u0432\u043E\u0433\u043E \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F,
    \u0438 \u0410\u043D\u0442\u0443\u0430\u043D\u0435\u0442\u0442\u044B \u0411\u0435\u0433\u043E\u043D.
    \u0421\u0435\u043C\u044C\u044F \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u043B\u0430
    \u043A \xAB\u0434\u0432\u043E\u0440\u044F\u043D\u0441\u0442\u0432\u0443 \u043C\u0430\u043D\u0442\u0438\u0438\xBB
    \u2014 \u0441\u043B\u043E\u044E \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u043E\u0432,
    \u0447\u044C\u0435 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0431\u044B\u043B\u043E
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043E \u043D\u0435 \u043D\u0430 \u0434\u0440\u0435\u0432\u043D\u043E\u0441\u0442\u0438
    \u0440\u043E\u0434\u0430, \u0430 \u043D\u0430 \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u043C\u043E\u0439
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438.  \u0421\u0443\u0434\u044C\u0431\u0430
    \u0411\u043B\u0435\u0437\u0430 \u0431\u044B\u043B\u0430 \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u0430
    \u0440\u0430\u043D\u043D\u0435\u0439 \u0443\u0442\u0440\u0430\u0442\u043E\u0439:
    \u0435\u0433\u043E \u043C\u0430\u0442\u044C \u0443\u043C\u0435\u0440\u043B\u0430,
    \u043A\u043E\u0433\u0434\u0430 \u0435\u043C\u0443 \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E
    \u0442\u0440\u0438 \u0433\u043E\u0434\u0430. \u0412 1631 \u0433\u043E\u0434\u0443
    \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u041F\u0430\u0440\u0438\u0436, \u0438 \u043E\u0442\u0435\u0446, \u042D\u0442\u044C\u0435\u043D,
    \u0441\u0430\u043C \u0443\u0432\u0430\u0436\u0430\u0435\u043C\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0440\u0435\u0448\u0438\u043B \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0432\u0437\u044F\u0442\u044C \u043D\u0430 \u0441\u0435\u0431\u044F \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0434\u0435\u0442\u0435\u0439, \u043D\u0435 \u0434\u043E\u0432\u0435\u0440\u044F\u044F
    \u0435\u0433\u043E \u0448\u043A\u043E\u043B\u0435. \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0434\u043B\u044F \u0441\u044B\u043D\u0430 \u0441\u0442\u0440\u043E\u0433\u0443\u044E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442 \u043E\u0442\u0434\u0430\u0432\u0430\u043B\u0441\u044F
    \u0434\u0440\u0435\u0432\u043D\u0438\u043C \u044F\u0437\u044B\u043A\u0430\u043C
    (\u043B\u0430\u0442\u044B\u043D\u0438 \u0438 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u043C\u0443),
    \u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u0442\u0435\u0446 \u0441\u0447\u0438\u0442\u0430\u043B \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u043C, \u0431\u044B\u043B\u0430
    \u043F\u043E\u0434 \u0437\u0430\u043F\u0440\u0435\u0442\u043E\u043C \u0434\u043E
    15 \u043B\u0435\u0442.  \u041E\u0434\u043D\u0430\u043A\u043E, \u043A\u0430\u043A
    \u044D\u0442\u043E \u0447\u0430\u0441\u0442\u043E \u0431\u044B\u0432\u0430\u0435\u0442
    \u0441 \u0433\u0435\u043D\u0438\u044F\u043C\u0438, \u0437\u0430\u043F\u0440\u0435\u0442
    \u043B\u0438\u0448\u044C \u043F\u043E\u0434\u0441\u0442\u0435\u0433\u043D\u0443\u043B
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441. \u041F\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
    \u0441\u0435\u0441\u0442\u0440\u044B \u041F\u0430\u0441\u043A\u0430\u043B\u044F,
    \u0416\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u044B, 12-\u043B\u0435\u0442\u043D\u0438\u0439
    \u0411\u043B\u0435\u0437, \u043D\u0435 \u0437\u043D\u0430\u044F \u043D\u0438\u043A\u0430\u043A\u0438\u0445
    \u0430\u043A\u0441\u0438\u043E\u043C, \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0443\u0433\u043B\u0435\u0439
    \u043D\u0430 \u043F\u043E\u043B\u0443, \xAB\u043E\u0442\u043A\u0440\u044B\u043B\xBB
    32-\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u0415\u0432\u043A\u043B\u0438\u0434\u0430
    \u043E \u0441\u0443\u043C\u043C\u0435 \u0443\u0433\u043B\u043E\u0432 \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430.
    \u041F\u043E\u0440\u0430\u0436\u0435\u043D\u043D\u044B\u0439 \u044D\u0442\u0438\u043C,
    \u043E\u0442\u0435\u0446 \u0441\u043C\u0435\u043D\u0438\u043B \u0433\u043D\u0435\u0432
    \u043D\u0430 \u043C\u0438\u043B\u043E\u0441\u0442\u044C \u0438 \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043B
    \u0441\u044B\u043D\u0443 \u0447\u0438\u0442\u0430\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043D\u0438\u0433\u0438, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0432\u0432\u0435\u043B
    \u0435\u0433\u043E \u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u0439 \u043A\u0440\u0443\u0436\u043E\u043A
    \u041C\u0435\u0440\u0441\u0435\u043D\u043D\u0430 \u2014 \u043A\u043B\u0443\u0431,
    \u0433\u0434\u0435 \u0441\u043E\u0431\u0438\u0440\u0430\u043B\u0438\u0441\u044C
    \u0432\u0435\u0434\u0443\u0449\u0438\u0435 \u0443\u043C\u044B \u0415\u0432\u0440\u043E\u043F\u044B:
    \u0420\u043E\u0431\u0435\u0440\u0432\u0430\u043B\u044C, \u0414\u0435\u0437\u0430\u0440\u0433,
    \u0413\u0430\u0441\u0441\u0435\u043D\u0434\u0438, \u0430 \u0438\u043D\u043E\u0433\u0434\u0430
    \u0438 \u0441\u0430\u043C \u0414\u0435\u043A\u0430\u0440\u0442. \u0412 16 \u043B\u0435\u0442,
    \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u044B\u0439
    \u0440\u0430\u0431\u043E\u0442\u0430\u043C\u0438 \u0414\u0435\u0437\u0430\u0440\u0433\u0430,
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \xAB\u041E\u043F\u044B\u0442 \u043E \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0435\u0447\u0435\u043D\u0438\u044F\u0445\xBB (Essai pour les coniques),
    \u0433\u0434\u0435 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u043E \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0448\u0435\u0441\u0442\u0438\u0432\u0435\u0440\u0448\u0438\u043D\u043D\u0438\u043A\u0435
    \u2014 \u043E\u0434\u043D\u0443 \u0438\u0437 \u043E\u0441\u043D\u043E\u0432 \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u0414\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u0431\u044B\u043B\u043E \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F, \u0447\u0442\u043E
    \u0414\u0435\u043A\u0430\u0440\u0442, \u0443\u0432\u0438\u0434\u0435\u0432 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C,
    \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0432\u0435\u0440\u0438\u0442\u044C,
    \u0447\u0442\u043E \u0435\u0435 \u0430\u0432\u0442\u043E\u0440\u043E\u043C \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u043F\u043E\u0434\u0440\u043E\u0441\u0442\u043E\u043A,
    \u0438 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u043B, \u0447\u0442\u043E
    \u044D\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u043E\u0442\u0446\u0430. 
    ### \U0001F52C \u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0438 \xAB\u043F\u0430\u0441\u043A\u0430\u043B\u0438\u043D\u0430\xBB  \u0412
    1639 \u0433\u043E\u0434\u0443 \u042D\u0442\u044C\u0435\u043D\u0430 \u041F\u0430\u0441\u043A\u0430\u043B\u044F
    \u043D\u0430\u0437\u043D\u0430\u0447\u0430\u044E\u0442 \u0438\u043D\u0442\u0435\u043D\u0434\u0430\u043D\u0442\u043E\u043C
    (\u0441\u0431\u043E\u0440\u0449\u0438\u043A\u043E\u043C \u043D\u0430\u043B\u043E\u0433\u043E\u0432)
    \u0432 \u0420\u0443\u0430\u043D, \u0438 \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0437\u0436\u0430\u0435\u0442
    \u0442\u0443\u0434\u0430. \u0411\u043B\u0435\u0437 \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442
    \u043E\u0442\u0446\u0443 \u0441 \u0443\u0442\u043E\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0440\u0430\u0441\u0447\u0435\u0442\u0430\u043C\u0438 \u0438 \u0432 1642 \u0433\u043E\u0434\u0443
    (\u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 19 \u043B\u0435\u0442)
    \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0430\u0435\u0442 \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0441\u0447\u0435\u0442\u043D\u043E\u0439
    \u043C\u0430\u0448\u0438\u043D\u044B \u2014 \xAB\u043F\u0430\u0441\u043A\u0430\u043B\u0438\u043D\u044B\xBB.
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u0440\u0438\u0441\u043F\u043E\u0441\u043E\u0431\u043B\u0435\u043D\u0438\u0435,
    \u0430 \u043F\u0435\u0440\u0432\u044B\u0439 \u0432 \u043C\u0438\u0440\u0435 \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0439
    \u043A\u0430\u043B\u044C\u043A\u0443\u043B\u044F\u0442\u043E\u0440, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043C\u043E\u0433 \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0442\u044C
    \u0438 \u0432\u044B\u0447\u0438\u0442\u0430\u0442\u044C, \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u044F \u0440\u0430\u0437\u0440\u044F\u0434\u044B
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0448\u0435\u0441\u0442\u0435\u0440\u0435\u043D\u043E\u043A. \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B \u043E\u043A\u043E\u043B\u043E
    50 \u043F\u0440\u043E\u0442\u043E\u0442\u0438\u043F\u043E\u0432, \u043F\u0440\u0435\u0436\u0434\u0435
    \u0447\u0435\u043C \u0434\u043E\u0432\u0435\u043B \u043C\u0430\u0448\u0438\u043D\u0443
    \u0434\u043E \u0443\u043C\u0430. \u0425\u043E\u0442\u044F \u043A\u043E\u043C\u043C\u0435\u0440\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0443\u0441\u043F\u0435\u0445\u0430 \xAB\u043F\u0430\u0441\u043A\u0430\u043B\u0438\u043D\u0430\xBB
    \u043D\u0435 \u0438\u043C\u0435\u043B\u0430 \u0438\u0437-\u0437\u0430 \u0432\u044B\u0441\u043E\u043A\u043E\u0439
    \u0441\u0442\u043E\u0438\u043C\u043E\u0441\u0442\u0438, \u0441\u0430\u043C \u043F\u0440\u0438\u043D\u0446\u0438\u043F
    \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445 \u043A\u043E\u043B\u0435\u0441
    \u043B\u0435\u0433 \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0430\u0440\u0438\u0444\u043C\u043E\u043C\u0435\u0442\u0440\u043E\u0432
    \u043D\u0430 \u0442\u0440\u0438 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F
    \u0432\u043F\u0435\u0440\u0435\u0434.  \u0412 \u0420\u0443\u0430\u043D\u0435
    \u0436\u0435 \u0432 1646 \u0433\u043E\u0434\u0443 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442
    \u043F\u0435\u0440\u0432\u043E\u0435 \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F \u043A \u0440\u0435\u043B\u0438\u0433\u0438\u0438.
    \u041F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E \u043A\u0430\u043A \u0435\u0433\u043E
    \u043E\u0442\u0435\u0446 \u0441\u043B\u043E\u043C\u0430\u043B \u0431\u0435\u0434\u0440\u043E,
    \u0437\u0430 \u043D\u0438\u043C \u0443\u0445\u0430\u0436\u0438\u0432\u0430\u043B\u0438
    \u0434\u0432\u0430 \u0432\u0440\u0430\u0447\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0431\u044B\u043B\u0438 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C\u0438
    \u044F\u043D\u0441\u0435\u043D\u0438\u0441\u0442\u0430\u043C\u0438. \u042F\u043D\u0441\u0435\u043D\u0438\u0437\u043C
    \u2014 \u044D\u0442\u043E \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u0442\u0435\u0447\u0435\u043D\u0438\u0435
    \u0432 \u043A\u0430\u0442\u043E\u043B\u0438\u0446\u0438\u0437\u043C\u0435, \u0431\u043B\u0438\u0437\u043A\u043E\u0435
    \u043A \u0438\u0434\u0435\u044F\u043C \u0410\u0432\u0433\u0443\u0441\u0442\u0438\u043D\u0430
    \u043E \u043F\u0440\u0435\u0434\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u0438 \u0441\u043F\u0430\u0441\u0430\u044E\u0449\u0435\u0439 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0442\u0438.
    \u041F\u043E\u0434 \u0438\u0445 \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0438 \u0432\u0441\u044F \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u044F,
    \u043F\u0440\u043E\u043D\u0438\u043A\u0430\u044E\u0442\u0441\u044F \u044D\u0442\u043E\u0439
    \u0441\u0443\u0440\u043E\u0432\u043E\u0439 \u0434\u043E\u043A\u0442\u0440\u0438\u043D\u043E\u0439. 
    \u0412 \u044D\u0442\u043E \u0436\u0435 \u0432\u0440\u0435\u043C\u044F \u0435\u0433\u043E
    \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0442 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u043F\u044B\u0442\u044B. \u041E\u043D \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u0435\u0442
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u044B \u0422\u043E\u0440\u0440\u0438\u0447\u0435\u043B\u043B\u0438
    \u0441 \u0440\u0442\u0443\u0442\u043D\u044B\u043C \u0431\u0430\u0440\u043E\u043C\u0435\u0442\u0440\u043E\u043C,
    \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044F \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u043D\u043E\u0433\u043E \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u0443\u0441\u0442\u043E\u0442\u044B
    \u2014 \u043F\u043E\u043D\u044F\u0442\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0430\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u0438\u0430\u043D\u0446\u044B
    \u043E\u0442\u0432\u0435\u0440\u0433\u0430\u043B\u0438. \u0412 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u043C
    \u043E\u043F\u044B\u0442\u0435 \u043D\u0430 \u0433\u043E\u0440\u0435 \u041F\u044E\u0438-\u0434\u0435-\u0414\u043E\u043C
    (\u043F\u043E \u043F\u0440\u043E\u0441\u044C\u0431\u0435 \u041F\u0430\u0441\u043A\u0430\u043B\u044F
    \u0435\u0433\u043E \u043F\u0440\u043E\u0432\u0435\u043B \u0437\u044F\u0442\u044C,
    \u0424\u043B\u043E\u0440\u0430\u043D \u041F\u0435\u0440\u044C\u0435) \u043E\u043D
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0432\u043E\u0437\u0434\u0443\u0445\u0430 \u0443\u043C\u0435\u043D\u044C\u0448\u0430\u0435\u0442\u0441\u044F
    \u0441 \u0432\u044B\u0441\u043E\u0442\u043E\u0439, \u0447\u0442\u043E \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u043B\u043E \u0442\u0435\u043E\u0440\u0438\u044E
    \u0422\u043E\u0440\u0440\u0438\u0447\u0435\u043B\u043B\u0438. \u041D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435
    \u044D\u0442\u0438\u0445 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u043E\u0432
    \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0439 \u0437\u0430\u043A\u043E\u043D
    \u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0438 (\u0437\u0430\u043A\u043E\u043D
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F) \u043E \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0435
    \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F \u0432 \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u044F\u0445 
    \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u0448\u043F\u0440\u0438\u0446
    \u0438 \u0433\u0438\u0434\u0440\u0430\u0432\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0440\u0435\u0441\u0441. \u041F\u043E\u0437\u0436\u0435 \u0435\u0433\u043E
    \u0438\u043C\u0435\u043D\u0435\u043C \u043D\u0430\u0437\u0432\u0430\u043B\u0438
    \u0435\u0434\u0438\u043D\u0438\u0446\u0443 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u2014 \u043F\u0430\u0441\u043A\u0430\u043B\u044C.  ### \U0001F3AD \xAB\u0421\u0432\u0435\u0442\u0441\u043A\u0438\u0439\xBB
    \u043F\u0435\u0440\u0438\u043E\u0434 \u0438 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439 
    \u0412 1647 \u0433\u043E\u0434\u0443 \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u043F\u0435\u0440\u0435\u0435\u0437\u0436\u0430\u0435\u0442 \u0432 \u041F\u0430\u0440\u0438\u0436,
    \u0433\u0434\u0435 \u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0442\u0441\u044F
    \u0441 \u0414\u0435\u043A\u0430\u0440\u0442\u043E\u043C. \u0418\u0445 \u043E\u0431\u0449\u0435\u043D\u0438\u0435
    \u0431\u044B\u043B\u043E \u043A\u0440\u0430\u0442\u043A\u0438\u043C, \u043D\u043E
    \u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u043D\u044B\u043C: \u043E\u043D\u0438
    \u043D\u0435 \u0441\u043E\u0448\u043B\u0438\u0441\u044C \u0432\u043E \u0432\u0437\u0433\u043B\u044F\u0434\u0430\u0445
    \u043D\u0430 \u043F\u0443\u0441\u0442\u043E\u0442\u0443 \u0438 \u043C\u0435\u0442\u043E\u0434\u043E\u043B\u043E\u0433\u0438\u044E
    \u043D\u0430\u0443\u043A\u0438. \u041F\u0430\u0441\u043A\u0430\u043B\u044C, \u0432
    \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0414\u0435\u043A\u0430\u0440\u0442\u0430,
    \u0441\u0447\u0438\u0442\u0430\u043B \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430 \u043D\u0430\u0434
    \u0434\u0435\u0434\u0443\u043A\u0446\u0438\u0435\u0439.  \u041F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u0442\u0446\u0430 \u0432 1651 \u0433\u043E\u0434\u0443
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u0435\u0442
    \u043A\u0440\u0438\u0437\u0438\u0441. \u041E\u043D \u0441\u0431\u043B\u0438\u0436\u0430\u0435\u0442\u0441\u044F
    \u0441 \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0432\u0435\u0442\u0441\u043A\u043E\u0439 \u0441\u0440\u0435\u0434\u043E\u0439,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u0441 \u0433\u0435\u0440\u0446\u043E\u0433\u043E\u043C
    \u0434\u0435 \u0420\u0443\u0430\u043D\u043D\u0435, \u0438 \u0437\u0430\u0432\u0441\u0435\u0433\u0434\u0430\u0442\u0430\u044F\u043C\u0438
    \u0441\u0430\u043B\u043E\u043D\u043E\u0432, \u0442\u0430\u043A\u0438\u043C\u0438
    \u043A\u0430\u043A \u0448\u0435\u0432\u0430\u043B\u044C\u0435 \u0434\u0435 \u041C\u0435\u0440\u0435
    \u0438 \u0414\u0430\u043C\u044C\u0435\u043D \u041C\u0438\u0442\u0442\u043E\u043D.
    \u0418\u043C\u0435\u043D\u043D\u043E \u043E\u0442 \u043D\u0438\u0445, \u0437\u0430\u044F\u0434\u043B\u044B\u0445
    \u0438\u0433\u0440\u043E\u043A\u043E\u0432 \u0432 \u043A\u043E\u0441\u0442\u0438
    \u0438 \u043A\u0430\u0440\u0442\u044B, \u043E\u043D \u0443\u0441\u043B\u044B\u0448\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \xAB\u0437\u0430\u0434\u0430\u0447\u0443
    \u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u0438\u0438 \u0441\u0442\u0430\u0432\u043E\u043A\xBB:
    \u043A\u0430\u043A \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C \u0431\u0430\u043D\u043A,
    \u0435\u0441\u043B\u0438 \u0438\u0433\u0440\u0430 \u043F\u0440\u0435\u0440\u0432\u0430\u043D\u0430
    \u0434\u043E\u0441\u0440\u043E\u0447\u043D\u043E?. \u0412 \u0445\u043E\u0434\u0435
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0438 \u0441 \u041F\u044C\u0435\u0440\u043E\u043C
    \u0424\u0435\u0440\u043C\u0430 \u0432 1654 \u0433\u043E\u0434\u0443 \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442 \u0440\u0435\u0448\u0435\u043D\u0438\u0435,
    \u0442\u0435\u043C \u0441\u0430\u043C\u044B\u043C \u0437\u0430\u043B\u043E\u0436\u0438\u0432
    \u043E\u0441\u043D\u043E\u0432\u044B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.
    \u0412 \u044D\u0442\u043E\u0442 \u0436\u0435 \u043F\u0435\u0440\u0438\u043E\u0434
    \u043E\u043D \u043F\u0438\u0448\u0435\u0442 \xAB\u0422\u0440\u0430\u043A\u0442\u0430\u0442
    \u043E\u0431 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0435\xBB,
    \u0433\u0434\u0435 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0442\u0430\u0431\u043B\u0438\u0446\u0443 \u0431\u0438\u043D\u043E\u043C\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u043E\u0432,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0443\u044E \u0442\u0435\u043F\u0435\u0440\u044C
    \u043A\u0430\u043A \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F.  ### \U0001F525 \u041D\u043E\u0447\u044C
    \u043E\u0433\u043D\u044F \u0438 \u0443\u0445\u043E\u0434 \u0432 \u041F\u043E\u0440-\u0420\u043E\u044F\u043B\u044C 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0441\u043B\u0430\u0432\u0443
    \u0438 \u0441\u0432\u0435\u0442\u0441\u043A\u0438\u0435 \u0443\u0441\u043F\u0435\u0445\u0438,
    \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0435\u0435 \u0431\u0435\u0441\u043F\u043E\u043A\u043E\u0439\u0441\u0442\u0432\u043E
    \u0438 \u0431\u043E\u043B\u0435\u0437\u043D\u0438 (\u0441 18 \u043B\u0435\u0442
    \u0435\u0433\u043E \u043C\u0443\u0447\u0438\u043B\u0438 \u0441\u0438\u043B\u044C\u043D\u044B\u0435
    \u0433\u043E\u043B\u043E\u0432\u043D\u044B\u0435 \u0431\u043E\u043B\u0438) \u043D\u0435
    \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0438 \u041F\u0430\u0441\u043A\u0430\u043B\u044F.
    \u041A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u0435\u0439 \u0435\u0433\u043E
    \u0434\u0443\u0445\u043E\u0432\u043D\u044B\u0445 \u0438\u0441\u043A\u0430\u043D\u0438\u0439
    \u0441\u0442\u0430\u043B\u0430 \u043D\u043E\u0447\u044C \u0441 23 \u043D\u0430
    24 \u043D\u043E\u044F\u0431\u0440\u044F 1654 \u0433\u043E\u0434\u0430. \u0412
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0438 \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u044F \u043E\u043D \u043F\u0435\u0440\u0435\u0436\u0438\u043B
    \xAB\u0432\u0442\u043E\u0440\u043E\u0435 \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u0435\xBB
    \u2014 \u0442\u043E\u0442\u0430\u043B\u044C\u043D\u043E\u0435, \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u043A \u0411\u043E\u0433\u0443.
    \u041F\u043E\u0442\u0440\u044F\u0441\u0435\u043D\u0438\u0435 \u0431\u044B\u043B\u043E
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0438\u043B\u044C\u043D\u044B\u043C,
    \u0447\u0442\u043E \u043E\u043D \u0437\u0430\u043F\u0438\u0441\u0430\u043B \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u043D\u043E\u0435
    \u043D\u0430 \u043A\u043B\u043E\u0447\u043A\u0435 \u043F\u0435\u0440\u0433\u0430\u043C\u0435\u043D\u0442\u0430.
    \u042D\u0442\u043E\u0442 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442, \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u044B\u0439
    \xAB\u041C\u0435\u043C\u043E\u0440\u0438\u0430\u043B\u043E\u043C\xBB, \u043D\u0430\u0447\u0438\u043D\u0430\u043B\u0441\u044F
    \u0441\u043B\u043E\u0432\u043E\u043C \xAB\u041E\u0433\u043E\u043D\u044C\xBB (Feu)
    \u0438 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B \u0441\u0442\u0440\u043E\u043A\u0438
    \u043B\u0438\u0447\u043D\u043E\u0433\u043E \u043E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u0438\u044F.
    \u0414\u043E \u0441\u0430\u043C\u043E\u0439 \u0441\u043C\u0435\u0440\u0442\u0438
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u043D\u043E\u0441\u0438\u043B \u044D\u0442\u0443
    \u0437\u0430\u043F\u0438\u0441\u043A\u0443, \u0437\u0430\u0448\u0438\u0442\u0443\u044E
    \u0432 \u043F\u043E\u0434\u043A\u043B\u0430\u0434\u043A\u0443 \u043A\u0430\u043C\u0437\u043E\u043B\u0430. 
    \u0412 \u044F\u043D\u0432\u0430\u0440\u0435 1655 \u0433\u043E\u0434\u0430 \u043E\u043D
    \u0443\u0434\u0430\u043B\u044F\u0435\u0442\u0441\u044F \u0432 \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u044C
    \u041F\u043E\u0440-\u0420\u043E\u044F\u043B\u044C \u2014 \u0446\u0435\u043D\u0442\u0440
    \u044F\u043D\u0441\u0435\u043D\u0438\u0437\u043C\u0430. \u041E\u043D \u043D\u0435
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0442 \u043C\u043E\u043D\u0430\u0448\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u043E\u0441\u0442\u0440\u0438\u0433\u0430, \u043D\u043E \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u043E\u0432
    \u0438 \u043F\u043E\u043B\u0435\u043C\u0438\u0441\u0442\u043E\u0432 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F. 
    ### \u270D\uFE0F \u0413\u043B\u0430\u0432\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B:
    \xAB\u041F\u0438\u0441\u044C\u043C\u0430\xBB \u0438 \xAB\u041C\u044B\u0441\u043B\u0438\xBB 
    \u0412 \u041F\u043E\u0440-\u0420\u043E\u044F\u043B\u0435 \u0440\u0430\u0437\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u043E-\u043F\u043E\u043B\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0430\u043B\u0430\u043D\u0442 \u041F\u0430\u0441\u043A\u0430\u043B\u044F. 
    1.  **\xAB\u041F\u0438\u0441\u044C\u043C\u0430 \u043A \u043F\u0440\u043E\u0432\u0438\u043D\u0446\u0438\u0430\u043B\u0443\xBB
    (1656\u20131657)** \u2014 \u044D\u0442\u043E \u0441\u0435\u0440\u0438\u044F \u0438\u0437
    18 \u0441\u0430\u0442\u0438\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043F\u0438\u0441\u0435\u043C,
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0445 \u043F\u043E\u0434
    \u043F\u0441\u0435\u0432\u0434\u043E\u043D\u0438\u043C\u043E\u043C \u041B\u0443\u0438
    \u0434\u0435 \u041C\u043E\u043D\u0442\u0430\u043B\u044C\u0442. \u0412 \u043D\u0438\u0445
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435,
    \u0441 \u044F\u0437\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u0438\u0435\u043C
    \u0438 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u0440\u0430\u0437\u0433\u0440\u043E\u043C\u0438\u043B \u043C\u043E\u0440\u0430\u043B\u044C\u043D\u0443\u044E
    \u043A\u0430\u0437\u0443\u0438\u0441\u0442\u0438\u043A\u0443 \u0438\u0435\u0437\u0443\u0438\u0442\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435, \u043F\u043E \u043C\u043D\u0435\u043D\u0438\u044E
    \u044F\u043D\u0441\u0435\u043D\u0438\u0441\u0442\u043E\u0432, \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u043B\u0435\u0433\u043A\u043E \u043E\u0442\u043F\u0443\u0441\u043A\u0430\u043B\u0438
    \u0433\u0440\u0435\u0445\u0438 \u0431\u043E\u0433\u0430\u0442\u044B\u043C \u0433\u0440\u0435\u0448\u043D\u0438\u043A\u0430\u043C.
    \u042D\u0442\u043E\u0442 \u043F\u0430\u043C\u0444\u043B\u0435\u0442 \u0441\u0442\u0430\u043B
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0441\u043A\u0438\u043C
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u043E\u043C, \u043D\u043E \u0438
    \u0448\u0435\u0434\u0435\u0432\u0440\u043E\u043C \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u043F\u0440\u043E\u0437\u044B, \u043E\u0431\u0440\u0430\u0437\u0446\u043E\u043C
    \u0441\u0430\u0442\u0438\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u0442\u0438\u043B\u044F, \u043F\u043E\u0432\u043B\u0438\u044F\u0432\u0448\u0438\u043C
    \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0432\u0441\u0435\u0439
    \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u044B. 
    2.  **\xAB\u041C\u044B\u0441\u043B\u0438\xBB** \u2014 \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0439 \u0442\u0440\u0443\u0434
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F, \u043D\u0430\u0434 \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0434\u043E \u0441\u0430\u043C\u043E\u0439
    \u0441\u043C\u0435\u0440\u0442\u0438. \u042D\u0442\u043E \u0431\u044B\u043B\u0430
    \u0437\u0430\u0434\u0443\u043C\u0430\u043D\u043D\u0430\u044F \u0438\u043C \xAB\u0410\u043F\u043E\u043B\u043E\u0433\u0438\u044F
    \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0441\u043A\u043E\u0439 \u0440\u0435\u043B\u0438\u0433\u0438\u0438\xBB
    \u2014 \u043A\u043D\u0438\u0433\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u043B\u0430 \u0443\u0431\u0435\u0434\u0438\u0442\u044C
    \u0441\u043A\u0435\u043F\u0442\u0438\u043A\u043E\u0432 \u0438 \u043D\u0435\u0432\u0435\u0440\u0443\u044E\u0449\u0438\u0445
    \u0432 \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0441\u0442\u0438 \u0432\u0435\u0440\u044B.
    \u041E\u043D \u0442\u0430\u043A \u0438 \u043D\u0435 \u0443\u0441\u043F\u0435\u043B
    \u043F\u0440\u0438\u0432\u0435\u0441\u0442\u0438 \u0441\u0432\u043E\u0438 \u0437\u0430\u043F\u0438\u0441\u0438
    \u0432 \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u043F\u043E\u0440\u044F\u0434\u043E\u043A. \u0423\u0436\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0435
    \u0437\u0430\u043C\u0435\u0442\u043A\u0438 \u0438 \u0430\u0444\u043E\u0440\u0438\u0437\u043C\u044B
    \u0431\u044B\u043B\u0438 \u0441\u043E\u0431\u0440\u0430\u043D\u044B \u0438 \u0438\u0437\u0434\u0430\u043D\u044B
    \u043F\u043E\u0434 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435\u043C \xAB\u041C\u044B\u0441\u043B\u0438\xBB. 
    \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \xAB\u041C\u044B\u0441\u043B\u044F\u0445\xBB
    \u0437\u0430\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438 \u0432\u0435\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u043E\u0431\u0440\u0430\u0437 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u0437\u0430\u0442\u0435\u0440\u044F\u043D\u043D\u043E\u0433\u043E \u043C\u0435\u0436\u0434\u0443
    \u0434\u0432\u0443\u043C\u044F \u0431\u0435\u0437\u0434\u043D\u0430\u043C\u0438
    \u2014 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439 \u0438 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043D\u0438\u0447\u0442\u043E\u0436\u0435\u0441\u0442\u0432\u043E\u043C. \u0427\u0435\u043B\u043E\u0432\u0435\u043A,
    \u043F\u043E \u041F\u0430\u0441\u043A\u0430\u043B\u044E, \u2014 \u044D\u0442\u043E
    \xAB\u043C\u044B\u0441\u043B\u044F\u0449\u0438\u0439 \u0442\u0440\u043E\u0441\u0442\u043D\u0438\u043A\xBB.
    \u041E\u043D \u0441\u043B\u0430\u0431 \u0438 \u0445\u0440\u0443\u043F\u043E\u043A,
    \u043A\u0430\u043A \u0442\u0440\u043E\u0441\u0442\u043D\u0438\u043A, \u043D\u043E
    \u0432\u0435\u043B\u0438\u0447\u0438\u0435 \u0435\u0433\u043E \u0432 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u043C\u044B\u0441\u043B\u0438\u0442\u044C. \u0412 \u044D\u0442\u043E\u043C \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0438
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0441 \u0442\u0430\u043A\u043E\u0439 \u043E\u0441\u0442\u0440\u043E\u0442\u043E\u0439
    \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0432\u043E\u043F\u0440\u043E\u0441
    \u043E \u0433\u0440\u0430\u043D\u0438\u0446\u0430\u0445 \u0440\u0430\u0437\u0443\u043C\u0430
    \u0438 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0435\u043C\u0443 \xAB\u043B\u043E\u0433\u0438\u043A\u0443 \u0441\u0435\u0440\u0434\u0446\u0430\xBB
    \u2014 \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u043E\u0435 \u043F\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u043F\u0435\u0440\u0432\u044B\u0445 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u043E\u0432
    \u0431\u044B\u0442\u0438\u044F.  \u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    *\xAB\u0441\u0442\u0430\u0432\u043A\u0430 \u041F\u0430\u0441\u043A\u0430\u043B\u044F\xBB*
    \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442\u043E\u0432 \xAB\u041C\u044B\u0441\u043B\u0435\u0439\xBB:
    \u0430\u0442\u0435\u0438\u0441\u0442\u0443 \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442\u0441\u044F
    \xAB\u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C\xBB \u043D\u0430 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u0411\u043E\u0433\u0430, \u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443
    \u0434\u0430\u0436\u0435 \u0432 \u0441\u043B\u0443\u0447\u0430\u0435 \u043F\u0440\u043E\u0438\u0433\u0440\u044B\u0448\u0430
    \u043E\u043D \u0442\u0435\u0440\u044F\u0435\u0442 \u043B\u0438\u0448\u044C \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0435
    \u0437\u0435\u043C\u043D\u044B\u0435 \u0431\u043B\u0430\u0433\u0430, \u0430 \u0432
    \u0441\u043B\u0443\u0447\u0430\u0435 \u0432\u044B\u0438\u0433\u0440\u044B\u0448\u0430
    \u043E\u0431\u0440\u0435\u0442\u0430\u0435\u0442 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435
    \u0431\u043B\u0430\u0436\u0435\u043D\u0441\u0442\u0432\u043E. \u041F\u043E \u0441\u0443\u0442\u0438,
    \u044D\u0442\u043E \u043F\u0440\u0430\u0433\u043C\u0430\u0442\u0438\u0447\u043D\u044B\u0439
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442 \u0432 \u043F\u043E\u043B\u044C\u0437\u0443
    \u0432\u0435\u0440\u044B, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043D\u0430 \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439,
    \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043E\u043D \u0441\u0430\u043C \u043F\u0440\u0438\u043B\u043E\u0436\u0438\u043B
    \u0440\u0443\u043A\u0443.  ### \U0001F319 \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0435 
    \u0411\u043E\u043B\u044C\u0448\u0443\u044E \u0447\u0430\u0441\u0442\u044C \u0436\u0438\u0437\u043D\u0438
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0441\u0442\u0440\u0430\u0434\u0430\u043B
    \u043E\u0442 \u0442\u044F\u0436\u0435\u043B\u043E\u0439, \u043C\u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0431\u043E\u043B\u0435\u0437\u043D\u0438. \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0441\u043B\u0430\u0431\u043E\u0441\u0442\u044C \u0441\u0442\u0430\u043B\u0430
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0438\u043B\u044C\u043D\u043E\u0439,
    \u0447\u0442\u043E \u043E\u043D \u043F\u043E\u0447\u0442\u0438 \u043D\u0435 \u043C\u043E\u0433
    \u043F\u0435\u0440\u0435\u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F.
    \u0422\u0435\u043C \u043D\u0435 \u043C\u0435\u043D\u0435\u0435, \u043E\u043D
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0442\u0432\u043E\u0440\u0438\u0442\u044C:
    \u0440\u0430\u0437\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043B \u043F\u0440\u043E\u0435\u043A\u0442
    \u043D\u043E\u0432\u043E\u0433\u043E \u0432\u0438\u0434\u0430 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0442\u0440\u0430\u043D\u0441\u043F\u043E\u0440\u0442\u0430 (\u043E\u043C\u043D\u0438\u0431\u0443\u0441\u0430)
    \u0434\u043B\u044F \u0431\u0435\u0434\u043D\u044B\u0445 , \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0434\u0438\u0441\u043F\u0443\u0442\u0430\u0445. 
    \u0411\u043B\u0435\u0437 \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 19 \u0430\u0432\u0433\u0443\u0441\u0442\u0430
    1662 \u0433\u043E\u0434\u0430, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    39 \u043B\u0435\u0442, \u0432 \u043C\u0443\u043A\u0430\u0445 \u043E\u0442 \u043D\u0435\u0438\u0437\u043B\u0435\u0447\u0438\u043C\u043E\u0439
    \u0431\u043E\u043B\u0435\u0437\u043D\u0438. \u0415\u0433\u043E \u0443\u0445\u043E\u0434
    \u0431\u044B\u043B \u043F\u043E\u043B\u043E\u043D \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u0441\u043C\u0438\u0440\u0435\u043D\u0438\u044F \u0438 \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u0430.
    \u0421\u043F\u0443\u0441\u0442\u044F \u0432\u0435\u043A\u0430 \u0435\u0433\u043E
    \u0438\u0434\u0435\u0438 \u043E \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F,
    \u043E \xAB\u043B\u043E\u0433\u0438\u043A\u0435 \u0441\u0435\u0440\u0434\u0446\u0430\xBB
    \u0431\u044B\u043B\u0438 \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u044F\u0442\u044B
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430\u043C\u0438-\u044D\u043A\u0437\u0438\u0441\u0442\u0435\u043D\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u0430\u043C\u0438,
    \u0430 \u041B\u0435\u0432 \u0422\u043E\u043B\u0441\u0442\u043E\u0439 \u043D\u0430\u0437\u044B\u0432\u0430\u043B
    \u0435\u0433\u043E \xAB\u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0430\xBB."
  shortBioEn: 
  interestingFactsRu: "\u0417\u0430 \u0441\u0432\u043E\u044E \u043D\u0435\u0434\u043E\u043B\u0433\u0443\u044E,
    \u043D\u043E \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E \u044F\u0440\u043A\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u0411\u043B\u0435\u0437 \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u0443\u0441\u043F\u0435\u043B \u043F\u0440\u043E\u044F\u0432\u0438\u0442\u044C
    \u0441\u0435\u0431\u044F \u0432 \u0441\u0430\u043C\u044B\u0445 \u0440\u0430\u0437\u043D\u044B\u0445,
    \u043F\u043E\u0440\u043E\u0439 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0445
    \u0438\u043F\u043E\u0441\u0442\u0430\u0441\u044F\u0445. \u041F\u043E\u043C\u0438\u043C\u043E
    \u0432\u0435\u043B\u0438\u043A\u0438\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439,
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u043F\u043E\u043B\u043D\u0430
    \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0445, \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445
    \u0438 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432.  ### \U0001F4D6 \u0421\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \xAB\u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\xBB \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0432 12 \u043B\u0435\u0442  \u041F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u044B\u0439
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043A\u0443\u0440\u044C\u0435\u0437
    \u0438\u0437 \u0435\u0433\u043E \u0434\u0435\u0442\u0441\u0442\u0432\u0430 \u0441\u0432\u044F\u0437\u0430\u043D
    \u0441 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u043C \u043C\u0435\u0442\u043E\u0434\u043E\u043C
    \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u044F, \u0432\u044B\u0431\u0440\u0430\u043D\u043D\u044B\u043C
    \u043E\u0442\u0446\u043E\u043C. \u042D\u0442\u044C\u0435\u043D \u041F\u0430\u0441\u043A\u0430\u043B\u044C,
    \u043E\u043F\u0430\u0441\u0430\u044F\u0441\u044C, \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0443\u0432\u043B\u0435\u0447\u0435\u0442
    \u0441\u044B\u043D\u0430 \u0438 \u043F\u043E\u043C\u0435\u0448\u0430\u0435\u0442
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E \u0434\u0440\u0435\u0432\u043D\u0438\u0445
    \u044F\u0437\u044B\u043A\u043E\u0432, \u0441\u043F\u0440\u044F\u0442\u0430\u043B
    \u0432\u0441\u0435 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0438 \u0438 \u0437\u0430\u043F\u0440\u0435\u0442\u0438\u043B
    \u0411\u043B\u0435\u0437\u0443 \u0434\u0430\u0436\u0435 \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0430\u0442\u044C\u0441\u044F
    \u043A \u044D\u0442\u043E\u0439 \u043D\u0430\u0443\u043A\u0435 \u0434\u043E 15
    \u043B\u0435\u0442.  \u041E\u0434\u043D\u0430\u043A\u043E \u0437\u0430\u043F\u0440\u0435\u0442
    \u0432\u043E\u0437\u044B\u043C\u0435\u043B \u043E\u0431\u0440\u0430\u0442\u043D\u044B\u0439
    \u044D\u0444\u0444\u0435\u043A\u0442. \u041E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043E\u0442\u0435\u0446 \u0437\u0430\u0441\u0442\u0430\u043B 12-\u043B\u0435\u0442\u043D\u0435\u0433\u043E
    \u0411\u043B\u0435\u0437\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441
    \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0443\u0433\u043B\u044F \u043D\u0430
    \u043F\u043E\u043B\u0443 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B \u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u043E \u0441\u0443\u043C\u043C\u0435
    \u0443\u0433\u043B\u043E\u0432 \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430.
    \u041F\u043E\u0440\u0430\u0436\u0435\u043D\u043D\u044B\u0439 \u044D\u0442\u0438\u043C,
    \u042D\u0442\u044C\u0435\u043D \u0441\u043D\u044F\u043B \u0437\u0430\u043F\u0440\u0435\u0442
    \u0438 \u043F\u043E\u0434\u0430\u0440\u0438\u043B \u0441\u044B\u043D\u0443 \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043B
    \u0441\u0430\u043C, \u0431\u0435\u0437 \u0447\u044C\u0438\u0445-\u043B\u0438\u0431\u043E
    \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u0439.  ### \U0001F58B\uFE0F
    \u0418\u0437\u0432\u0438\u043D\u0435\u043D\u0438\u0435 \u0437\u0430 \u0434\u043B\u0438\u043D\u043D\u043E\u0435
    \u043F\u0438\u0441\u044C\u043C\u043E (\u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E
    \u043B\u0430\u043A\u043E\u043D\u0438\u0447\u043D\u043E\u0441\u0442\u0438)  \u0412
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u044B
    \u0438 \u0440\u0438\u0442\u043E\u0440\u0438\u043A\u0438 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F \u0444\u0440\u0430\u0437\u0430
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F. \u0412 \u043E\u0434\u043D\u043E\u043C
    \u0438\u0437 \u0441\u0432\u043E\u0438\u0445 \u043F\u0438\u0441\u0435\u043C \u043E\u043D
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B: \xAB\u041F\u0440\u043E\u0441\u0442\u0438\u0442\u0435,
    \u0447\u0442\u043E \u043F\u0438\u0448\u0443 \u0432\u0430\u043C \u0442\u0430\u043A\u043E\u0435
    \u0434\u043B\u0438\u043D\u043D\u043E\u0435 \u043F\u0438\u0441\u044C\u043C\u043E,
    \u0443 \u043C\u0435\u043D\u044F \u043D\u0435 \u0431\u044B\u043B\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C \u043A\u043E\u0440\u043E\u0442\u043A\u043E\u0435\xBB.
    \u042D\u0442\u043E\u0442 \u0430\u0444\u043E\u0440\u0438\u0437\u043C \u0441\u0442\u0430\u043B
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u043C
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u043A\u0440\u0430\u0442\u043A\u043E\u0441\u0442\u044C
    \u2014 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430.  ### \U0001F4A1 \u0422\u0435\u043E\u0440\u0438\u044F
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439... \u0438
    \u0441\u0442\u0440\u0430\u0441\u0442\u044C \u043A \u0430\u0437\u0430\u0440\u0442\u043D\u044B\u043C
    \u0438\u0433\u0440\u0430\u043C  \u041A\u0430\u043A \u044D\u0442\u043E \u043D\u0438
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u043E,
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0434\u043B\u044F \u0441\u0442\u0440\u043E\u0433\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439
    \u0431\u044B\u043B \u0437\u0430\u043B\u043E\u0436\u0435\u043D \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044E \u0435\u0433\u043E \u0434\u0440\u0443\u0433\u0430,
    \u043A\u0430\u0432\u0430\u043B\u0435\u0440\u0430 \u0434\u0435 \u041C\u0435\u0440\u0435,
    \u0430\u0437\u0430\u0440\u0442\u043D\u044B\u043C\u0438 \u0438\u0433\u0440\u0430\u043C\u0438
    \u0432 \u043A\u043E\u0441\u0442\u0438. \u0414\u0435 \u041C\u0435\u0440\u0435
    \u0437\u0430\u0434\u0430\u043B \u041F\u0430\u0441\u043A\u0430\u043B\u044E \u0438
    \u0434\u0440\u0443\u0433\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C
    \u0437\u0430\u0434\u0430\u0447\u0443 \u043E \u0442\u043E\u043C, \u043A\u0430\u043A
    \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u0432\u044B\u0438\u0433\u0440\u044B\u0448 \u043F\u0440\u0438 \u043F\u0440\u0435\u0440\u0432\u0430\u043D\u043D\u043E\u0439
    \u043F\u0430\u0440\u0442\u0438\u0438. \u0412 \u0445\u043E\u0434\u0435 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0438
    \u0441 \u0424\u0435\u0440\u043C\u0430 \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u043D\u0430\u0448\u0435\u043B \u0440\u0435\u0448\u0435\u043D\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0438 \u043B\u0435\u0433\u043B\u043E \u0432 \u043E\u0441\u043D\u043E\u0432\u0443
    \u043D\u043E\u0432\u043E\u0439 \u043D\u0430\u0443\u043A\u0438. \u0422\u0430\u043A
    \u0441\u0432\u0435\u0442\u0441\u043A\u043E\u0435 \u0440\u0430\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0432\u0435\u043B\u0438\u043A\u043E\u043C\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044E.  ### \U0001F68C \u0421\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C
    \u043F\u0435\u0440\u0432\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0442\u0440\u0430\u043D\u0441\u043F\u043E\u0440\u0442\u0430  \u0417\u0430 \u0433\u043E\u0434
    \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438, \u0432 1662 \u0433\u043E\u0434\u0443,
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0438\u0434\u0435\u044E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0432
    \u041F\u0430\u0440\u0438\u0436\u0435 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0442\u0440\u0430\u043D\u0441\u043F\u043E\u0440\u0442\u0430 \u2014 \xAB\u043A\u0430\u0440\u0435\u0442
    \u0437\u0430 \u043F\u044F\u0442\u044C \u0441\u0443\xBB (carrosses \xE0 cinq sols).
    \u042D\u0442\u043E \u0431\u044B\u043B\u0438 \u043C\u043D\u043E\u0433\u043E\u043C\u0435\u0441\u0442\u043D\u044B\u0435
    \u043A\u0430\u0440\u0435\u0442\u044B, \u043A\u0443\u0440\u0441\u0438\u0440\u043E\u0432\u0430\u0432\u0448\u0438\u0435
    \u043F\u043E \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u044B\u043C
    \u043C\u0430\u0440\u0448\u0440\u0443\u0442\u0430\u043C, \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u0430\u0432\u0442\u043E\u0431\u0443\u0441\u0430. \u041E\u043D \u0431\u044B\u043B
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0447\u0435\u043D\u044B\u043C,
    \u043D\u043E \u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u043E\u043C, \u0434\u0443\u043C\u0430\u044E\u0449\u0438\u043C
    \u043E\u0431 \u0443\u0434\u043E\u0431\u0441\u0442\u0432\u0435 \u0433\u043E\u0440\u043E\u0436\u0430\u043D. 
    ### \U0001FA7A \u0411\u043E\u043B\u0435\u0437\u043D\u044C, \u043A\u043E\u043B\u0434\u043E\u0432\u0441\u0442\u0432\u043E
    \u0438 \u0434\u0432\u0435 \u043A\u043E\u0448\u043A\u0438  \u0417\u0434\u043E\u0440\u043E\u0432\u044C\u0435
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F \u0431\u044B\u043B\u043E \u043A\u0440\u0430\u0439\u043D\u0435
    \u0441\u043B\u0430\u0431\u044B\u043C \u0441 \u0441\u0430\u043C\u043E\u0433\u043E
    \u0434\u0435\u0442\u0441\u0442\u0432\u0430, \u0447\u0442\u043E \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u043E
    \u043E\u0434\u0438\u043D \u0436\u0443\u0442\u043A\u043E\u0432\u0430\u0442\u044B\u0439
    \u044D\u043F\u0438\u0437\u043E\u0434. \u041A\u043E\u0433\u0434\u0430 \u0435\u043C\u0443
    \u0431\u044B\u043B \u0432\u0441\u0435\u0433\u043E \u0433\u043E\u0434, \u043E\u043D
    \u0442\u044F\u0436\u0435\u043B\u043E \u0437\u0430\u0431\u043E\u043B\u0435\u043B,
    \u0438 \u0435\u0433\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u0431\u044B\u043B\u043E \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u043C, \u0447\u0442\u043E \u043E\u043A\u0440\u0443\u0436\u0430\u044E\u0449\u0438\u0435
    \u0437\u0430\u043F\u043E\u0434\u043E\u0437\u0440\u0438\u043B\u0438 \u043A\u043E\u043B\u0434\u043E\u0432\u0441\u0442\u0432\u043E.
    \u0421\u043E\u0441\u0435\u0434\u0438 \u0443\u043A\u0430\u0437\u0430\u043B\u0438
    \u043D\u0430 \u043F\u043E\u0436\u0438\u043B\u0443\u044E \u0436\u0435\u043D\u0449\u0438\u043D\u0443,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0437\u0430 \u043D\u0438\u043C \u0443\u0445\u0430\u0436\u0438\u0432\u0430\u043B\u0430.
    \u041F\u043E\u0434 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C \u0442\u0430
    \u043F\u0440\u0438\u0437\u043D\u0430\u043B\u0430\u0441\u044C \u0432 \u043D\u0430\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u043F\u043E\u0440\u0447\u0438. \u0414\u043B\u044F \xAB\u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0430\xBB
    \u0437\u0430\u043A\u043B\u044F\u0442\u0438\u044F \u043A \u0431\u043E\u043B\u044C\u043D\u043E\u043C\u0443
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0443 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0438
    \u0434\u0432\u0443\u0445 \u0431\u0435\u0437\u0434\u043E\u043C\u043D\u044B\u0445
    \u043A\u043E\u0448\u0435\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0437\u0430\u0442\u0435\u043C,
    \u043F\u043E \u0441\u043E\u0432\u0435\u0442\u0443 \u0437\u043D\u0430\u0445\u0430\u0440\u0435\u0439,
    \u0432\u044B\u0431\u0440\u043E\u0441\u0438\u043B\u0438 \u0438\u0437 \u043E\u043A\u043D\u0430.
    \u0427\u0435\u0440\u0435\u0437 \u043D\u0435\u0434\u0435\u043B\u044E \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u043F\u043E\u0448\u0435\u043B \u043D\u0430 \u043F\u043E\u043F\u0440\u0430\u0432\u043A\u0443.
    \u041A \u0441\u0447\u0430\u0441\u0442\u044C\u044E, \u044D\u0442\u043E\u0442 \u044D\u043F\u0438\u0437\u043E\u0434
    \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u043B\u0438\u0448\u044C \u043C\u0440\u0430\u0447\u043D\u044B\u043C
    \u0441\u0443\u0435\u0432\u0435\u0440\u0438\u0435\u043C \u043F\u0440\u043E\u0448\u043B\u043E\u0433\u043E. 
    ### \U0001F92F \xAB\u041D\u043E\u0447\u044C \u043E\u0433\u043D\u044F\xBB \u0438
    \u0437\u0430\u043F\u0438\u0441\u043A\u0430 \u0432 \u043F\u043E\u0434\u043A\u043B\u0430\u0434\u043A\u0435 
    \u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u0439 \u043C\u043E\u043C\u0435\u043D\u0442
    \u0432 \u0436\u0438\u0437\u043D\u0438 \u041F\u0430\u0441\u043A\u0430\u043B\u044F
    \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u043D\u043E\u0447\u044C
    \u0441 23 \u043D\u0430 24 \u043D\u043E\u044F\u0431\u0440\u044F 1654 \u0433\u043E\u0434\u0430.
    \u041E\u043D \u043F\u0435\u0440\u0435\u0436\u0438\u043B \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043E\u043F\u0438\u0441\u0430\u043B \u043D\u0430 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u043C
    \u043A\u043B\u043E\u0447\u043A\u0435 \u043F\u0435\u0440\u0433\u0430\u043C\u0435\u043D\u0442\u0430,
    \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u043E\u043C \xAB\u041C\u0435\u043C\u043E\u0440\u0438\u0430\u043B\u043E\u043C\xBB.
    \u0422\u0435\u043A\u0441\u0442 \u043D\u0430\u0447\u0438\u043D\u0430\u043B\u0441\u044F
    \u0441\u043E \u0441\u043B\u043E\u0432\u0430 \xAB\u041E\u0433\u043E\u043D\u044C\xBB
    (Feu) \u0438 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B \u0441\u0442\u0440\u043E\u043A\u0438
    \u043E \u0411\u043E\u0433\u0435 \u0410\u0432\u0440\u0430\u0430\u043C\u0430 \u0438
    \u0418\u0430\u043A\u043E\u0432\u0430, \u0430 \u043D\u0435 \xAB\u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u0432
    \u0438 \u0443\u0447\u0435\u043D\u044B\u0445\xBB. \u0414\u043E \u0441\u0430\u043C\u043E\u0439
    \u0441\u043C\u0435\u0440\u0442\u0438 \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u043D\u043E\u0441\u0438\u043B \u044D\u0442\u0443 \u0437\u0430\u043F\u0438\u0441\u043A\u0443,
    \u0437\u0430\u0448\u0438\u0442\u043E\u0439 \u0432 \u043F\u043E\u0434\u043A\u043B\u0430\u0434\u043A\u0443
    \u0441\u0432\u043E\u0435\u0433\u043E \u043A\u0430\u043C\u0437\u043E\u043B\u0430. 
    ### \U0001F4AC \u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435 \xAB\u041F\u0430\u0440\u0438
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F\xBB  \u041E\u0434\u0438\u043D \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0435\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442\u043E\u0432 \u2014 \u043F\u0440\u0430\u0433\u043C\u0430\u0442\u0438\u0447\u043D\u044B\u0439
    \u0434\u043E\u0432\u043E\u0434 \u0432 \u043F\u043E\u043B\u044C\u0437\u0443 \u0432\u0435\u0440\u044B,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043A\u0430\u043A \xAB\u041F\u0430\u0440\u0438
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F\xBB. \u0421\u0443\u0442\u044C \u0435\u0433\u043E
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u043F\u0435\u0440\u0435\u0434
    \u043B\u0438\u0446\u043E\u043C \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0435\u0435 \xAB\u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C\xBB
    \u043D\u0430 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u0411\u043E\u0433\u0430, \u0442\u0430\u043A \u043A\u0430\u043A \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0439
    \u0432\u044B\u0438\u0433\u0440\u044B\u0448 (\u0432\u0435\u0447\u043D\u043E\u0435
    \u0431\u043B\u0430\u0436\u0435\u043D\u0441\u0442\u0432\u043E) \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E
    \u0432\u0435\u043B\u0438\u043A, \u0430 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0439
    \u043F\u0440\u043E\u0438\u0433\u0440\u044B\u0448 (\u043E\u0442\u043A\u0430\u0437
    \u043E\u0442 \u0437\u0435\u043C\u043D\u044B\u0445 \u0443\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u0439)
    \u043A\u043E\u043D\u0435\u0447\u0435\u043D \u0438 \u043C\u0430\u043B.  ### \u2699\uFE0F
    50 \u043F\u0440\u043E\u0442\u043E\u0442\u0438\u043F\u043E\u0432 \u043A\u0430\u043B\u044C\u043A\u0443\u043B\u044F\u0442\u043E\u0440\u0430 
    \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \xAB\u041F\u0430\u0441\u043A\u0430\u043B\u0438\u043D\u044B\xBB
    \u2014 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043A\u0430\u043B\u044C\u043A\u0443\u043B\u044F\u0442\u043E\u0440\u0430 \u0434\u043B\u044F
    \u043F\u043E\u043C\u043E\u0449\u0438 \u043E\u0442\u0446\u0443 \u0432 \u043D\u0430\u043B\u043E\u0433\u043E\u0432\u044B\u0445
    \u043F\u043E\u0434\u0441\u0447\u0435\u0442\u0430\u0445 \u2014 \u0437\u0430\u043D\u044F\u043B\u043E
    \u0443 \u043D\u0435\u0433\u043E \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043B\u0435\u0442. \u0427\u0442\u043E\u0431\u044B \u0434\u043E\u0432\u0435\u0441\u0442\u0438
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E \u0434\u043E \u0443\u043C\u0430,
    \u043E\u043D \u0438\u0437\u0433\u043E\u0442\u043E\u0432\u0438\u043B \u043E\u043A\u043E\u043B\u043E
    50 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445 \u043F\u0440\u043E\u0442\u043E\u0442\u0438\u043F\u043E\u0432. 
    ### \U0001F3C6 \u041F\u043E\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u044C \u0432
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C \u043A\u043E\u043D\u043A\u0443\u0440\u0441\u0435 
    \u0412 1658 \u0433\u043E\u0434\u0443 \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u043F\u043E\u0434 \u043F\u0441\u0435\u0432\u0434\u043E\u043D\u0438\u043C\u043E\u043C
    \u043E\u0431\u044A\u044F\u0432\u0438\u043B \u043A\u043E\u043D\u043A\u0443\u0440\u0441
    \u043D\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0437\u0430\u0434\u0430\u0447,
    \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445 \u0441 \u0446\u0438\u043A\u043B\u043E\u0438\u0434\u043E\u0439
    (\u043A\u0440\u0438\u0432\u043E\u0439, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442 \u0442\u043E\u0447\u043A\u0430
    \u043D\u0430 \u043A\u0430\u0442\u044F\u0449\u0435\u043C\u0441\u044F \u043A\u043E\u043B\u0435\u0441\u0435).
    \u041A\u043E\u0433\u0434\u0430 \u043F\u0440\u0438\u0448\u043B\u043E \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439, \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435
    \u043E\u0442 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B
    \u0441\u0432\u043E\u0439 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0432\u0430\u0440\u0438\u0430\u043D\u0442 \u0438, \u0432\u044B\u0441\u0442\u0443\u043F\u0438\u0432
    \u0432 \u0440\u043E\u043B\u0438 \u0441\u0443\u0434\u044C\u0438, \u043F\u0440\u0438\u0441\u0443\u0434\u0438\u043B
    \u043F\u043E\u0431\u0435\u0434\u0443 \u0441\u0430\u043C\u043E\u043C\u0443 \u0441\u0435\u0431\u0435.
    \u0411\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0439 \u0445\u043E\u0434, \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u0443\u044E\u0449\u0438\u0439
    \u0438 \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u0433\u043E\u0440\u0434\u043E\u0441\u0442\u044C,
    \u0438 \u0447\u0443\u0432\u0441\u0442\u0432\u043E \u044E\u043C\u043E\u0440\u0430. 
    \u0412 \u0436\u0438\u0437\u043D\u0438 \u044D\u0442\u043E\u0433\u043E \u0433\u0435\u043D\u0438\u044F
    \u043F\u0440\u0438\u0447\u0443\u0434\u043B\u0438\u0432\u043E \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u043B\u0438\u0441\u044C
    \u0434\u0435\u0442\u0441\u043A\u0430\u044F \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C,
    \u0430\u0437\u0430\u0440\u0442, \u043C\u0438\u0441\u0442\u0438\u0446\u0438\u0437\u043C,
    \u0441\u0442\u0440\u043E\u0433\u0430\u044F \u043B\u043E\u0433\u0438\u043A\u0430
    \u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u043C\u0435\u043A\u0430\u043B\u043A\u0430. \u041D\u0430\u0434\u0435\u044E\u0441\u044C,
    \u044D\u0442\u0438 \u0434\u0435\u0442\u0430\u043B\u0438 \u043F\u043E\u043C\u043E\u0433\u043B\u0438
    \u0443\u0432\u0438\u0434\u0435\u0442\u044C \u0432 \u041F\u0430\u0441\u043A\u0430\u043B\u0435
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430,
    \u043D\u043E \u0438 \u0436\u0438\u0432\u043E\u0433\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    \u0441\u043E \u0441\u0432\u043E\u0438\u043C\u0438 \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0441\u0442\u044F\u043C\u0438
    \u0438 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043C\u0438."
