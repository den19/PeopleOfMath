  shortBioRu: "\u0411\u043B\u0435\u0437 \u041F\u0430\u0441\u043A\u0430\u0301\u043B\u044C\_\u2014
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A, \u0444\u0438\u0437\u0438\u043A, \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u043E\u0440,
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444 \u0438 \u0442\u0435\u043E\u043B\u043E\u0433.
    \u041A\u043B\u0430\u0441\u0441\u0438\u043A \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u044B, \u043E\u0434\u0438\u043D
    \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430, \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439 \u0438
    \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C \u043F\u0435\u0440\u0432\u044B\u0445
    \u043E\u0431\u0440\u0430\u0437\u0446\u043E\u0432 \u0441\u0447\u0451\u0442\u043D\u043E\u0439
    \u0442\u0435\u0445\u043D\u0438\u043A\u0438, \u0430\u0432\u0442\u043E\u0440 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0433\u043E
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0438."
