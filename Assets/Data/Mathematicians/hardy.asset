  achievementsRu: "\u0414\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u0413\u043E\u0434\u0444\u0440\u0438
    \u0425\u0430\u0440\u043E\u043B\u0434\u0430 \u0425\u0430\u0440\u0434\u0438 \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0442
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0441\u043B\u0435\u0434 \u0432 \u043D\u0430\u0443\u043A\u0435. \u0415\u0433\u043E
    \u0432\u043A\u043B\u0430\u0434 \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439.  ### \U0001F9EC
    \u0420\u0435\u0444\u043E\u0440\u043C\u0430 \u0431\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438  \u041F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u043E\u0434\u043D\u043E \u0438\u0437 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0439 \u0425\u0430\u0440\u0434\u0438
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430, \u0430 \u043F\u043E\u043B\u043D\u043E\u0435
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u043F\u043E\u0434\u0445\u043E\u0434\u0430 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0432 \u0412\u0435\u043B\u0438\u043A\u043E\u0431\u0440\u0438\u0442\u0430\u043D\u0438\u0438.
    \u0414\u043E \u0425\u0430\u0440\u0434\u0438 \u0431\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0448\u043A\u043E\u043B\u0430 \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0430\u0441\u044C
    \u043F\u043E\u0434 \u0441\u0438\u043B\u044C\u043D\u044B\u043C \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C
    \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u0439 \u0418\u0441\u0430\u0430\u043A\u0430
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u0438 \u0431\u044B\u043B\u0430 \u0432
    \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0430
    \u043D\u0430 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u043D\u0430 \u0433\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0443.
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B\u0441\u044F
    \u043A\u0430\u043A \u043D\u0430\u0431\u043E\u0440 \u043F\u0440\u0430\u0432\u0438\u043B
    \u0438 \u043F\u0440\u0438\u0435\u043C\u043E\u0432 \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0437\u0430\u0434\u0430\u0447. 
    \u0425\u0430\u0440\u0434\u0438, \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u044B\u0439
    \u0441\u0442\u0440\u043E\u0433\u0438\u043C \xAB\u041A\u0443\u0440\u0441\u043E\u043C
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430\xBB \u041A\u0430\u043C\u0438\u043B\u044F
    \u0416\u043E\u0440\u0434\u0430\u043D\u0430, \u043F\u0440\u0438\u0432\u043D\u0435\u0441
    \u0432 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043A\u043E\u043D\u0442\u0438\u043D\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C \u0438 \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434. \u0421\u0432\u043E\u044E \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u0443\u044E
    \u0440\u043E\u043B\u044C \u043E\u043D \u0437\u0430\u043A\u0440\u0435\u043F\u0438\u043B
    \u0438\u0437\u0434\u0430\u043D\u0438\u0435\u043C \u0432 1908 \u0433\u043E\u0434\u0443
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0430 **\xAB\u041A\u0443\u0440\u0441
    \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB**
    (*A Course of Pure Mathematics*). \u042D\u0442\u0430 \u043A\u043D\u0438\u0433\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u043E\u0439 \u043D\u0430
    \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u043C \u044F\u0437\u044B\u043A\u0435,
    \u0433\u0434\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 (\u043F\u0440\u0435\u0434\u0435\u043B\u044B,
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u044C,
    \u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u044C \u0440\u044F\u0434\u043E\u0432)
    \u0438\u0437\u043B\u0430\u0433\u0430\u043B\u0441\u044F \u0441 \u0431\u0435\u0441\u043A\u043E\u043C\u043F\u0440\u043E\u043C\u0438\u0441\u0441\u043D\u043E\u0439
    \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C\u044E, \u0447\u0442\u043E
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435.  ### \U0001F91D
    \u041B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u043E\u0435 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u043F\u0440\u043E\u0440\u044B\u0432\u044B 
    \u0425\u0430\u0440\u0434\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0434\u0432\u0443\u043C\u044F \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C\u0438
    \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0438\u043C\u0438 \u0441\u043E\u044E\u0437\u0430\u043C\u0438
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    **\u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441 \u0414\u0436. \u0418. \u041B\u0438\u0442\u043B\u0432\u0443\u0434\u043E\u043C** 
    \u041D\u0430\u0447\u0438\u043D\u0430\u044F \u0441 1911 \u0433\u043E\u0434\u0430,
    \u0438\u0445 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043F\u0440\u043E\u0434\u043B\u0438\u043B\u043E\u0441\u044C 35 \u043B\u0435\u0442
    \u0438 \u0441\u0442\u0430\u043B\u043E \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u0445
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 XX \u0432\u0435\u043A\u0430.
    \u0412 \u0441\u0440\u0435\u0434\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0445\u043E\u0434\u0438\u043B\u0430 \u0448\u0443\u0442\u043A\u0430, \u0447\u0442\u043E
    \u0432 \u0410\u043D\u0433\u043B\u0438\u0438 \u0436\u0438\u0432\u0443\u0442 \u0442\u0440\u0438
    \u0432\u0435\u043B\u0438\u043A\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:
    \u0425\u0430\u0440\u0434\u0438, \u041B\u0438\u0442\u043B\u0432\u0443\u0434 \u0438
    \u0425\u0430\u0440\u0434\u0438-\u041B\u0438\u0442\u043B\u0432\u0443\u0434, \u043F\u0440\u0438\u0447\u0435\u043C
    \u0442\u0440\u0435\u0442\u0438\u0439 \u0438\u0437 \u043D\u0438\u0445 \u2014 \u0441\u0430\u043C\u044B\u0439
    \u0432\u0435\u043B\u0438\u043A\u0438\u0439. \u0418\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u044B\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F \u043E\u0445\u0432\u0430\u0442\u0438\u043B\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439: 
    *   **\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B \u0438 \u043C\u0435\u0442\u043E\u0434
    \u043A\u0440\u0443\u0433\u043E\u0432**: \u0412\u043C\u0435\u0441\u0442\u0435
    \u043E\u043D\u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438
    \u043C\u043E\u0449\u043D\u044B\u0439 **\u043C\u0435\u0442\u043E\u0434 \u0425\u0430\u0440\u0434\u0438-\u041B\u0438\u0442\u043B\u0432\u0443\u0434\u0430**
    (\u0442\u0430\u043A\u0436\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u0430\u043A \xAB\u043A\u0440\u0443\u0433\u043E\u0432\u043E\u0439 \u043C\u0435\u0442\u043E\u0434\xBB),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0430\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0430\u0434\u0434\u0438\u0442\u0438\u0432\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B.
    \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u043C \u0443\u0441\u043F\u0435\u0445\u043E\u043C
    \u044D\u0442\u043E\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u0430 \u0441\u0442\u0430\u043B
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441
    \u0432 **\u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0435 \u0412\u0430\u0440\u0438\u043D\u0433\u0430**
    (\u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B \u0432 \u0432\u0438\u0434\u0435 \u0441\u0443\u043C\u043C\u044B
    \u0441\u0442\u0435\u043F\u0435\u043D\u0435\u0439). *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0438 \u0420\u0438\u043C\u0430\u043D\u0430
    \u0438 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B**:
    \u041E\u043D\u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438 \u0440\u044F\u0434
    \u0432\u0430\u0436\u043D\u044B\u0445 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432
    \u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B \u0438
    \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B\u0438 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0443\u0441\u043B\u043E\u0432\u043D\u044B\u0445 \u0433\u0438\u043F\u043E\u0442\u0435\u0437,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    **\u043F\u0435\u0440\u0432\u0443\u044E \u0438 \u0432\u0442\u043E\u0440\u0443\u044E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u0425\u0430\u0440\u0434\u0438-\u041B\u0438\u0442\u043B\u0432\u0443\u0434\u0430**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440
    \u0441\u0442\u0438\u043C\u0443\u043B\u0438\u0440\u0443\u044E\u0442 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. *  
    **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437**: \u0418\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B \u0442\u0430\u043A\u0436\u0435 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u044B \u0434\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441 \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0440\u044F\u0434\u0430\u043C\u0438, \u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B\u043C\u0438
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u044F\u043C\u0438
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u043D\u0435\u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432. 
    **\u0421\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0421\u0440\u0438\u043D\u0438\u0432\u0430\u0441\u044B
    \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430**  \u041A\u043E\u0433\u0434\u0430
    \u0432 1913 \u0433\u043E\u0434\u0443 \u0425\u0430\u0440\u0434\u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043F\u0438\u0441\u044C\u043C\u043E \u043E\u0442 \u043D\u0438\u043A\u043E\u043C\u0443
    \u043D\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u043A\u043B\u0435\u0440\u043A\u0430 \u0441 \u0434\u043B\u0438\u043D\u043D\u044B\u043C
    \u0441\u043F\u0438\u0441\u043A\u043E\u043C \u0442\u0435\u043E\u0440\u0435\u043C,
    \u043E\u043D \u0441\u0440\u0430\u0437\u0443 \u0440\u0430\u0441\u043F\u043E\u0437\u043D\u0430\u043B
    \u0432 \u043D\u0451\u043C \u0433\u0435\u043D\u0438\u044F. \u042D\u0442\u043E
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0441\u0430\u043C\u043E\u0433\u043E
    \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430 \u0425\u0430\u0440\u0434\u0438
    \u0441\u0447\u0438\u0442\u0430\u043B **\u0441\u0432\u043E\u0438\u043C \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C
    \u0432\u043A\u043B\u0430\u0434\u043E\u043C \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443**.
    \u0418\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \u043F\u0440\u0438\u0432\u0435\u043B\u0430 \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    \u043E\u0434\u043D\u0438\u0445 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0445
    \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B. 
    *   **\u0424\u043E\u0440\u043C\u0443\u043B\u0430 \u0425\u0430\u0440\u0434\u0438-\u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430
    \u0434\u043B\u044F \u0447\u0438\u0441\u043B\u0430 \u0440\u0430\u0437\u0431\u0438\u0435\u043D\u0438\u0439**:
    \u0414\u043B\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u0438 `p(n)`, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u043E\u0434\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u0435\u0442 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441\u043F\u043E\u0441\u043E\u0431\u043E\u0432 \u0440\u0430\u0437\u0431\u0438\u0442\u044C
    \u0447\u0438\u0441\u043B\u043E `n` \u043D\u0430 \u0441\u0443\u043C\u043C\u0443
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445 \u0441\u043B\u0430\u0433\u0430\u0435\u043C\u044B\u0445,
    \u043E\u043D\u0438 \u0432\u044B\u0432\u0435\u043B\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443. \u042D\u0442\u0430 \u0444\u043E\u0440\u043C\u0443\u043B\u0430,
    \u043F\u043E\u0440\u0430\u0436\u0430\u044E\u0449\u0430\u044F \u0441\u0432\u043E\u0435\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E, \u0434\u0430\u043B\u0430
    \u043C\u043E\u0449\u043D\u044B\u0439 \u0442\u043E\u043B\u0447\u043E\u043A \u0434\u043B\u044F
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F \u0432\u0441\u0435\u0439 \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438. \u041F\u043E\u0437\u0436\u0435 \u043E\u043D\u0430
    \u043D\u0430\u0448\u043B\u0430 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0435
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u044F \u0432 \u0444\u0438\u0437\u0438\u043A\u0435
    \u0434\u043B\u044F \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0442\u0435\u0440\u043C\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0432 \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0425\u0430\u0440\u0434\u0438-\u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430**:
    \u0415\u0449\u0451 \u043E\u0434\u043D\u0430 \u0438\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0430,
    \u0447\u0442\u043E \u0447\u0438\u0441\u043B\u043E `\u03C9(n)` \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0434\u0435\u043B\u0438\u0442\u0435\u043B\u0435\u0439
    \u0447\u0438\u0441\u043B\u0430 `n` \xAB\u0432 \u0441\u0440\u0435\u0434\u043D\u0435\u043C\xBB
    \u0432\u0435\u0434\u0451\u0442 \u0441\u0435\u0431\u044F \u043A\u0430\u043A `log
    log n`.  ### \U0001F9EC \u041D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u044E:
    \u0437\u0430\u043A\u043E\u043D \u0425\u0430\u0440\u0434\u0438-\u0412\u0430\u0439\u043D\u0431\u0435\u0440\u0433\u0430 
    \u0412 1908 \u0433\u043E\u0434\u0443 \u0425\u0430\u0440\u0434\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0451\u043D\u043D\u044B\u043C
    \u043F\u0430\u0446\u0438\u0444\u0438\u0441\u0442\u043E\u043C \u0438 \u043F\u0440\u0435\u0437\u0438\u0440\u0430\u043B
    \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u0440\u0435\u0448\u0438\u043B \u0437\u0430\u0434\u0430\u0447\u0443, \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u043D\u0443\u044E
    \u0435\u043C\u0443 \u0434\u0440\u0443\u0433\u043E\u043C-\u0433\u0435\u043D\u0435\u0442\u0438\u043A\u043E\u043C
    \u0420\u0435\u0434\u0436\u0438\u043D\u0430\u043B\u044C\u0434\u043E\u043C \u041F\u0430\u043D\u043D\u0435\u0442\u0442\u043E\u043C.
    \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C \u0441\u0442\u0430\u043B
    **\u0437\u0430\u043A\u043E\u043D \u0425\u0430\u0440\u0434\u0438-\u0412\u0430\u0439\u043D\u0431\u0435\u0440\u0433\u0430**
    \u2014 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043F\u043E\u043F\u0443\u043B\u044F\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u0433\u0435\u043D\u0435\u0442\u0438\u043A\u0438. \u042D\u0442\u043E\u0442 \u0437\u0430\u043A\u043E\u043D
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442, \u043A\u0430\u043A \u0447\u0430\u0441\u0442\u043E\u0442\u044B
    \u0430\u043B\u043B\u0435\u043B\u0435\u0439 \u0438 \u0433\u0435\u043D\u043E\u0442\u0438\u043F\u043E\u0432
    \u0432 \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u043F\u0430\u043D\u043C\u0438\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043E\u043F\u0443\u043B\u044F\u0446\u0438\u0438 \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u044B\u043C\u0438 \u0438\u0437
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F \u0432 \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0435
    \u043F\u0440\u0438 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0438
    \u044D\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u0445 \u0444\u0430\u043A\u0442\u043E\u0440\u043E\u0432.
    \u0421\u0430\u043C \u0425\u0430\u0440\u0434\u0438 \u0441\u0447\u0438\u0442\u0430\u043B
    \u044D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0442\u0440\u0438\u0432\u0438\u0430\u043B\u044C\u043D\u044B\u043C,
    \u043D\u043E \u0434\u043B\u044F \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438
    \u043E\u043D\u043E \u0441\u0442\u0430\u043B\u043E \u0431\u0430\u0437\u043E\u0432\u044B\u043C. 
    ### \U0001F4DA \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0438 \xAB\u0410\u043F\u043E\u043B\u043E\u0433\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\xBB  \u0412 1940
    \u0433\u043E\u0434\u0443, \u0432 \u0440\u0430\u0437\u0433\u0430\u0440 \u0412\u0442\u043E\u0440\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B, \u0425\u0430\u0440\u0434\u0438
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u044D\u0441\u0441\u0435 **\xAB\u0410\u043F\u043E\u043B\u043E\u0433\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\xBB** (*A Mathematician's
    Apology*), \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043B\u0443\u0447\u0448\u0438\u0445
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0439 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430.
    \u0412 \u044D\u0442\u043E\u0439 \u043F\u0440\u043E\u043D\u0438\u0437\u0430\u043D\u043D\u043E\u0439
    \u043C\u0435\u043B\u0430\u043D\u0445\u043E\u043B\u0438\u0435\u0439 \u043A\u043D\u0438\u0433\u0435
    \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u043D\u0430
    \u043F\u0440\u0438\u0440\u043E\u0434\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438: 
    *   **\u0417\u0430\u0449\u0438\u0442\u0430 \u0447\u0438\u0441\u0442\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438**: \u0425\u0430\u0440\u0434\u0438
    \u0433\u043E\u0440\u044F\u0447\u043E \u043E\u0442\u0441\u0442\u0430\u0438\u0432\u0430\u043B
    \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u043D\u0435 \u0438\u043C\u0435\u044E\u0449\u0435\u0439 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u044F, \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044F:
    \"\u042F \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0434\u0435\u043B\u0430\u043B
    \u043D\u0438\u0447\u0435\u0433\u043E '\u043F\u043E\u043B\u0435\u0437\u043D\u043E\u0433\u043E'.
    \u041D\u0438 \u043E\u0434\u043D\u043E \u043C\u043E\u0451 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u043D\u0435 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u043E \u0438 \u043D\u0435
    \u043C\u043E\u0433\u043B\u043E \u0431\u044B \u043F\u0440\u0438\u043D\u0435\u0441\u0442\u0438...
    \u043D\u0438 \u043C\u0430\u043B\u0435\u0439\u0448\u0435\u0433\u043E \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u044F
    \u0432 \u0431\u043B\u0430\u0433\u043E\u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E
    \u044D\u0442\u043E\u0433\u043E \u043C\u0438\u0440\u0430\". *   **\u041A\u0440\u0430\u0441\u043E\u0442\u0430
    \u043A\u0430\u043A \u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0439 \u0438\u0441\u0442\u0438\u043D\u044B**:
    \u041E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0430\u044F \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u2014 \u0432 \u0435\u0451
    \u044D\u0441\u0442\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043A\u0440\u0430\u0441\u043E\u0442\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D \u0441\u0442\u0430\u0432\u0438\u043B
    \u0432 \u043E\u0434\u0438\u043D \u0440\u044F\u0434 \u0441 \u0436\u0438\u0432\u043E\u043F\u0438\u0441\u044C\u044E
    \u0438 \u043F\u043E\u044D\u0437\u0438\u0435\u0439. \u041F\u043E \u0435\u0433\u043E
    \u043C\u043D\u0435\u043D\u0438\u044E, \u0447\u0438\u0441\u0442\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0442\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B, \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0432\u044B\u0441\u0448\u0438\u043C \u043F\u0440\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u0435\u043C
    \u044D\u0442\u043E\u0439 \u043A\u0440\u0430\u0441\u043E\u0442\u044B.  ### \U0001F3C6
    \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u0417\u0430 \u0441\u0432\u043E\u0438 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u043D\u0430\u0433\u0440\u0430\u0434,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u0443\u044E
    \u043C\u0435\u0434\u0430\u043B\u044C (1920), \u043C\u0435\u0434\u0430\u043B\u044C
    \u0414\u0435 \u041C\u043E\u0440\u0433\u0430\u043D\u0430 (1929), \u043C\u0435\u0434\u0430\u043B\u044C
    \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440\u0430 (1940) \u0438 \u0432\u044B\u0441\u0448\u0443\u044E
    \u043D\u0430\u0433\u0440\u0430\u0434\u0443 \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430
    \u2014 **\u043C\u0435\u0434\u0430\u043B\u044C \u041A\u043E\u043F\u043B\u0438
    (1947)**. \u041E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D
    \u0447\u043B\u0435\u043D\u043E\u043C \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430,
    \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u0410\u041D \u0421\u0421\u0421\u0420 \u0438 \u043C\u043D\u043E\u0433\u0438\u0445
    \u0434\u0440\u0443\u0433\u0438\u0445 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u043C\u0438\u0440\u0430.  \u041E\u0431\u0449\u0435\u0435 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0435\u0433\u043E \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0439
    (\u0441\u0442\u0430\u0442\u0435\u0439 \u0438 \u043A\u043D\u0438\u0433) \u043F\u0440\u0435\u0432\u044B\u0448\u0430\u0435\u0442
    300, \u0447\u0442\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443\u0435\u0442
    \u043E\u0431 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u043E\u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0433\u043B\u0443\u0431\u0438\u043D\u0435 \u0435\u0433\u043E \u0443\u043C\u0430.
    \u0415\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0436\u0438\u0432\u0435\u0442
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0432 \u0442\u0435\u043E\u0440\u0435\u043C\u0430\u0445,
    \u043D\u043E\u0441\u044F\u0449\u0438\u0445 \u0435\u0433\u043E \u0438\u043C\u044F,
    \u043D\u043E \u0438 \u0432 \u0441\u0430\u043C\u043E\u043C \u0434\u0443\u0445\u0435
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0433\u0434\u0435 \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C \u0438
    \u043A\u0440\u0430\u0441\u043E\u0442\u0430 \u0438\u0434\u0443\u0442 \u0440\u0443\u043A\u0430
    \u043E\u0431 \u0440\u0443\u043A\u0443."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0413\u043E\u0434\u0444\u0440\u0438 \u0425\u0430\u0440\u043E\u043B\u0434\u0430
    \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B\u0430 \u0441\u0442\u043E\u043B\u044C
    \u0436\u0435 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E\u0439 \u0438 \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0439,
    \u043A\u0430\u043A \u0438 \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0433\u0435\u043D\u0438\u0439. \u0415\u0441\u043B\u0438 \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
    \u043A\u0440\u0430\u0442\u043A\u043E, \u043E\u043D \u0431\u044B\u043B \u043E\u0447\u0435\u043D\u044C
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0431\u044B\u043B \u0436\u0435\u043D\u0430\u0442 \u0438 \u043D\u0435
    \u0438\u043C\u0435\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0432\u044F\u0437\u0435\u0439. \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0439
    \u0438 \u0432\u0441\u0435\u043F\u043E\u0433\u043B\u043E\u0449\u0430\u044E\u0449\u0435\u0439
    \u0441\u0442\u0440\u0430\u0441\u0442\u044C\u044E \u0431\u044B\u043B\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430,
    \u0430 \u0432\u0441\u0435 \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0435,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0441\u043B\u043E\u0432\u043D\u043E\u0441\u0442\u0438, \u0447\u0430\u0441\u0442\u043E
    \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C \u0435\u043C\u0443 \u0432\u0442\u043E\u0440\u043E\u0441\u0442\u0435\u043F\u0435\u043D\u043D\u044B\u043C. 
    ### \U0001F575\uFE0F\u200D\u2642\uFE0F \u0417\u0430\u0442\u0432\u043E\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0438 \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0441\u0442\u044C 
    \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B \u043A\u0440\u0430\u0439\u043D\u0435
    \u0437\u0430\u0441\u0442\u0435\u043D\u0447\u0438\u0432 \u0438 \u043E\u0431\u043B\u0430\u0434\u0430\u043B
    \u0446\u0435\u043B\u044B\u043C \u0440\u044F\u0434\u043E\u043C \u043F\u0440\u0438\u0447\u0443\u0434,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u0435\u043B\u0430\u043B\u0438
    \u0435\u0433\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439 \u0444\u0438\u0433\u0443\u0440\u043E\u0439
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435:  *   **\u041D\u0435\u043D\u0430\u0432\u0438\u0441\u0442\u044C
    \u043A \u0437\u0435\u0440\u043A\u0430\u043B\u0430\u043C \u0438 \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u044F\u043C:**
    \u041E\u043D \u043D\u0435 \u0432\u044B\u043D\u043E\u0441\u0438\u043B \u0441\u0432\u043E\u0435\u0433\u043E
    \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044F \u0438, \u0432\u0445\u043E\u0434\u044F
    \u0432 \u0433\u043E\u0441\u0442\u0438\u043D\u0438\u0447\u043D\u044B\u0439 \u043D\u043E\u043C\u0435\u0440,
    \u043F\u0435\u0440\u0432\u044B\u043C \u0434\u0435\u043B\u043E\u043C \u043D\u0430\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043B
    \u043F\u043E\u043B\u043E\u0442\u0435\u043D\u0446\u0435 \u043D\u0430 \u0432\u0441\u0435
    \u0437\u0435\u0440\u043A\u0430\u043B\u0430. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u043F\u0430\u0442\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u0431\u043E\u044F\u043B\u0441\u044F, \u0447\u0442\u043E \u0435\u0433\u043E \u0441\u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0440\u0443\u044E\u0442.
    \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u0447\u0442\u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0432\u0441\u0435\u0433\u043E \u043F\u044F\u0442\u044C \u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0445
    \u0441\u043D\u0438\u043C\u043A\u043E\u0432, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u043D \u0437\u0430\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D. *  
    **\u0410\u0442\u0435\u0438\u0437\u043C \u0438 \"\u0438\u0433\u0440\u0430 \u0441
    \u0411\u043E\u0433\u043E\u043C\":** \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B
    \u0443\u0431\u0435\u0436\u0434\u0451\u043D\u043D\u044B\u043C \u0430\u0442\u0435\u0438\u0441\u0442\u043E\u043C,
    \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F \u043F\u043E\u0441\u0435\u0449\u0430\u0442\u044C
    \u0447\u0430\u0441\u043E\u0432\u043D\u044E \u0434\u0430\u0436\u0435 \u0434\u043B\u044F
    \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445 \u0446\u0435\u0440\u0435\u043C\u043E\u043D\u0438\u0439
    \u0438 \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u044D\u0442\u043E
    \"\u0447\u0451\u0440\u043D\u043E-\u0431\u0435\u043B\u043E\u0435\" \u0440\u0435\u0448\u0435\u043D\u0438\u0435,
    \u043F\u0440\u0438\u043D\u044F\u0442\u043E\u0435 \u0438\u043C \u0435\u0449\u0451
    \u0432 \u044E\u043D\u043E\u0441\u0442\u0438. \u041E\u0434\u043D\u0430\u043A\u043E
    \u044D\u0442\u043E \u043D\u0435 \u043C\u0435\u0448\u0430\u043B\u043E \u0435\u043C\u0443
    \u0432\u0435\u0441\u0442\u0438 \u0437\u0430\u0431\u0430\u0432\u043D\u0443\u044E
    \"\u0438\u0433\u0440\u0443\" \u0441 \u0411\u043E\u0433\u043E\u043C, \u0432 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043E\u043D \u043D\u0435 \u0432\u0435\u0440\u0438\u043B.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044F\u0441\u044C
    \u0438\u0437 \u0414\u0430\u043D\u0438\u0438, \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u043E\u0442\u043A\u0440\u044B\u0442\u043A\u0443 \u0441 \u0437\u0430\u044F\u0432\u043B\u0435\u043D\u0438\u0435\u043C,
    \u0447\u0442\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u0420\u0438\u043C\u0430\u043D\u0430, \u043F\u043E\u043B\u0430\u0433\u0430\u044F,
    \u0447\u0442\u043E \u0411\u043E\u0433 \u043D\u0435 \u0434\u0430\u0441\u0442 \u0435\u0433\u043E
    \u043A\u043E\u0440\u0430\u0431\u043B\u044E \u0443\u0442\u043E\u043D\u0443\u0442\u044C
    \u0438 \u043B\u0438\u0448\u0438\u0442\u044C \u043C\u0438\u0440 \u0442\u0430\u043A\u043E\u0439
    \u0432\u0435\u043B\u0438\u043A\u043E\u0439 \u0441\u043B\u0430\u0432\u044B. \u0412
    \u0434\u0440\u0443\u0433\u043E\u043C \u0441\u043B\u0443\u0447\u0430\u0435 \u043E\u043D
    \u0431\u0440\u0430\u043B \u043D\u0430 \u043A\u0440\u0438\u043A\u0435\u0442\u043D\u044B\u0435
    \u043C\u0430\u0442\u0447\u0438 \"\u0430\u043D\u0442\u0438-\u0431\u043E\u0436\u044C\u044E
    \u0431\u0430\u0442\u0430\u0440\u0435\u044E\" (\u0441\u0432\u0438\u0442\u0435\u0440\u0430,
    \u0437\u043E\u043D\u0442 \u0438 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B),
    \u043D\u0430\u0434\u0435\u044F\u0441\u044C, \u0447\u0442\u043E \u0411\u043E\u0433
    \u043F\u043E\u0448\u043B\u0451\u0442 \u0445\u043E\u0440\u043E\u0448\u0443\u044E
    \u043F\u043E\u0433\u043E\u0434\u0443, \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043C\u0435\u0448\u0430\u0442\u044C
    \u0435\u043C\u0443 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C.  ### \U0001F48E
    \u0421\u0430\u043C\u0430\u044F \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u043D\u0430\u044F
    \u0441\u0432\u044F\u0437\u044C: \u0421\u0440\u0438\u043D\u0438\u0432\u0430\u0441\u0430
    \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D  \u0425\u043E\u0442\u044F
    \u0443 \u0425\u0430\u0440\u0434\u0438 \u043D\u0435 \u0431\u044B\u043B\u043E \u0441\u0435\u043C\u044C\u0438
    \u0432 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u043C
    \u0441\u043C\u044B\u0441\u043B\u0435, \u0432 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438
    \u0431\u044B\u043B\u0430 \u043E\u0434\u043D\u0430 \u0441\u0432\u044F\u0437\u044C,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D \u0441\u0430\u043C \u043D\u0430\u0437\u0432\u0430\u043B
    \"\u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439\".
    \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u0432\u0441\u0442\u0440\u0435\u0447\u0430
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \u0441 \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C-\u0441\u0430\u043C\u043E\u0443\u0447\u043A\u043E\u0439
    **\u0421\u0440\u0438\u043D\u0438\u0432\u0430\u0441\u043E\u0439 \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u043E\u043C**.
    \u041A\u043E\u0433\u0434\u0430 \u0432 1913 \u0433\u043E\u0434\u0443 \u0425\u0430\u0440\u0434\u0438
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043E\u0442 \u043D\u0438\u043A\u043E\u043C\u0443
    \u043D\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u043A\u043B\u0435\u0440\u043A\u0430
    \u043F\u0438\u0441\u044C\u043C\u043E \u0441 \u0434\u043B\u0438\u043D\u043D\u044B\u043C
    \u0441\u043F\u0438\u0441\u043A\u043E\u043C \u0444\u043E\u0440\u043C\u0443\u043B,
    \u043E\u043D \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E \u0440\u0430\u0441\u043F\u043E\u0437\u043D\u0430\u043B
    \u0432 \u043D\u0451\u043C \u0433\u0435\u043D\u0438\u044F. \u042D\u0442\u043E
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043E\u043D \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B \u043A\u0430\u043A
    **\"\u043E\u0434\u043D\u043E \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u043E\u0438\u0441\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0432
    \u043C\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438\"** (the one romantic
    incident in my life). \u0417\u0430\u0431\u043E\u0442\u0430 \u043E \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0435
    \u0438 \u0438\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0430\u044F
    \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \u0441\u0442\u0430\u043B\u0438 \u0434\u043B\u044F \u0425\u0430\u0440\u0434\u0438
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u043B\u0438\u0447\u043D\u044B\u043C
    \u0438 \u0437\u043D\u0430\u0447\u0438\u043C\u044B\u043C \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u043D\u0438\u0435\u043C. 
    ### \U0001F465 \u041A\u0440\u0443\u0433 \u043E\u0431\u0449\u0435\u043D\u0438\u044F
    \u0438 \u0432\u0437\u0433\u043B\u044F\u0434\u044B  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0441\u0442\u044C,
    \u0425\u0430\u0440\u0434\u0438 \u043D\u0435 \u0431\u044B\u043B \u043F\u043E\u043B\u043D\u044B\u043C
    \u043E\u0442\u0448\u0435\u043B\u044C\u043D\u0438\u043A\u043E\u043C. \u041E\u043D
    \u0432\u0445\u043E\u0434\u0438\u043B \u0432 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    **\u0433\u0440\u0443\u043F\u043F\u0443 \u0411\u043B\u0443\u043C\u0441\u0431\u0435\u0440\u0438**
    \u2014 \u043B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u0438\u0439 \u043A\u0440\u0443\u0436\u043E\u043A
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u043E\u0432
    \u0438 \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u043E\u0432. \u0412 \u0440\u0430\u0437\u043D\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u0435\u0433\u043E \u0431\u043B\u0438\u0437\u043A\u0438\u043C\u0438
    \u0434\u0440\u0443\u0437\u044C\u044F\u043C\u0438 \u0431\u044B\u043B\u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444
    **\u0414\u0436\u043E\u0440\u0434\u0436 \u041C\u0443\u0440**, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444 **\u0411\u0435\u0440\u0442\u0440\u0430\u043D
    \u0420\u0430\u0441\u0441\u0435\u043B**, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0441\u0442 **\u0414\u0436\u043E\u043D
    \u041C\u0435\u0439\u043D\u0430\u0440\u0434 \u041A\u0435\u0439\u043D\u0441**. 
    \u041E\u043D \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0451\u043D\u043D\u044B\u043C
    **\u043F\u0430\u0446\u0438\u0444\u0438\u0441\u0442\u043E\u043C**. \u0412\u043E
    \u0432\u0440\u0435\u043C\u044F \u041F\u0435\u0440\u0432\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u043E\u043D \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0421\u043E\u044E\u0437\u0435 \u0434\u0435\u043C\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044F, \u0430 \u0432 1930-\u0445 \u0433\u043E\u0434\u0430\u0445
    \u2014 \u0432 \u0421\u043E\u044E\u0437\u0435 \u0437\u0430 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u0432\u043E\u0431\u043E\u0434\u0443. \u0415\u0433\u043E \u0441\u043E\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438 \u0430\u043D\u0442\u0438\u0432\u043E\u0435\u043D\u043D\u044B\u0435 \u0432\u0437\u0433\u043B\u044F\u0434\u044B
    \u0447\u0430\u0441\u0442\u043E \u0434\u0435\u043B\u0430\u043B\u0438 \u0435\u0433\u043E
    \u0431\u0435\u043B\u043E\u0439 \u0432\u043E\u0440\u043E\u043D\u043E\u0439 \u0432
    \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u0442\u0438\u0432\u043D\u043E\u043C
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435.  ### \u2764\uFE0F \u0418\u0442\u043E\u0433:
    \"\u0416\u0438\u0437\u043D\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\" 
    \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B \u0441\u0435\u0431\u044F \u043D\u0430\u0443\u043A\u0435.
    \u0415\u0433\u043E \"\u043B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C\"
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E \u0441\u0442\u0440\u0430\u0441\u0442\u0438
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u0440\u0430\u0441\u043E\u0442\u0435, \u043E \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0437\u0430\u0445 \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438-\u0435\u0434\u0438\u043D\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438
    (\u0442\u0430\u043A\u0438\u043C\u0438 \u043A\u0430\u043A \u041B\u0438\u0442\u043B\u0432\u0443\u0434
    \u0438 \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D) \u0438 \u043E
    \u044F\u0440\u043A\u043E \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u043D\u044B\u0445,
    \u0438\u043D\u043E\u0433\u0434\u0430 \u043F\u043E\u0447\u0442\u0438 \u0433\u0440\u043E\u0442\u0435\u0441\u043A\u043D\u044B\u0445,
    \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0441\u0442\u044F\u0445.
    \u041E\u043D \u0431\u044B\u043B \u0441\u043B\u043E\u0436\u043D\u043E\u0439, \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0439
    \u0444\u0438\u0433\u0443\u0440\u043E\u0439, \u0447\u044C\u044F \u043F\u043E\u0434\u043B\u0438\u043D\u043D\u0430\u044F
    \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u044C
    \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0430
    \u043D\u0435 \u043D\u0430 \u043B\u044E\u0434\u0435\u0439 \u0432 \u0431\u044B\u0442\u043E\u0432\u043E\u043C
    \u0441\u043C\u044B\u0441\u043B\u0435, \u0430 \u043D\u0430 \u043C\u0438\u0440
    \u0438\u0434\u0435\u0439 \u0438 \u0447\u0438\u0441\u0435\u043B, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043D \u0442\u0430\u043A \u043B\u044E\u0431\u0438\u043B \u0438 \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u0441\u043B\u0443\u0436\u0438\u043B."
  personalLifeEn: 
  shortBioRu: "\u0413\u043E\u0434\u0444\u0440\u0438 \u0425\u0430\u0440\u043E\u043B\u0434
    \u0425\u0430\u0440\u0434\u0438 (1877\u20131947) \u2014 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 XX \u0432\u0435\u043A\u0430,
    \u043B\u0438\u0434\u0435\u0440 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0433\u043E \u0443\u043C\u0430,
    \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u043E\u0439 \u043F\u0440\u0435\u0434\u0430\u043D\u043D\u043E\u0441\u0442\u0438
    \u043D\u0430\u0443\u043A\u0435, \u0442\u0440\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0434\u0440\u0443\u0436\u0431\u044B \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445
    \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439 \u043E \u043F\u0440\u0438\u0440\u043E\u0434\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  \u0412\u043E\u0442
    \u043E\u0447\u0435\u043D\u044C \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u0413\u043E\u0434\u0444\u0440\u0438
    \u0425\u0430\u0440\u043E\u043B\u0434\u0430 \u0425\u0430\u0440\u0434\u0438.  ###
    \U0001F9EC \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B \u0438
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 (1877\u20131900) 
    - **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0434\u0435\u0442\u0441\u0442\u0432\u043E:** \u0425\u0430\u0440\u0434\u0438
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 7 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    1877 \u0433\u043E\u0434\u0430 \u0432 \u041A\u0440\u0430\u043D\u043B\u0438, \u0433\u0440\u0430\u0444\u0441\u0442\u0432\u043E
    \u0421\u0443\u0440\u0440\u0435\u0439, \u0432 \u0441\u0435\u043C\u044C\u0435 \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0445
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439. \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u0410\u0439\u0437\u0435\u043A \u0425\u0430\u0440\u0434\u0438, \u0431\u044B\u043B
    \u043A\u0430\u0437\u043D\u0430\u0447\u0435\u0435\u043C \u0438 \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C
    \u0440\u0438\u0441\u043E\u0432\u0430\u043D\u0438\u044F, \u0430 \u043C\u0430\u0442\u044C,
    \u0421\u043E\u0444\u0438\u044F, \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B\u0430.
    \u041E\u0431\u0430 \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u044F \u043E\u0431\u043B\u0430\u0434\u0430\u043B\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044F\u043C\u0438,
    \u043D\u043E \u043D\u0435 \u0438\u043C\u0435\u043B\u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u043B\u0430\u043D\u0442\u044B \u0425\u0430\u0440\u0434\u0438 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C
    \u0440\u0430\u043D\u043E: \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u0434\u0432\u0443\u0445 \u043B\u0435\u0442 \u043E\u043D \u043F\u0438\u0441\u0430\u043B
    \u0447\u0438\u0441\u043B\u0430 \u0434\u043E \u043C\u0438\u043B\u043B\u0438\u043E\u043D\u043E\u0432,
    \u0430 \u0432 \u0446\u0435\u0440\u043A\u0432\u0438 \u0440\u0430\u0437\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F,
    \u0440\u0430\u0437\u043B\u0430\u0433\u0430\u044F \u043D\u043E\u043C\u0435\u0440\u0430
    \u043F\u0441\u0430\u043B\u043C\u043E\u0432 \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u044B\u0435
    \u043C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u0438. - **\u0428\u043A\u043E\u043B\u0430
    \u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u0443\u0441\u043F\u0435\u0445\u0438:**
    \u0414\u043E 12 \u043B\u0435\u0442 \u043E\u043D \u0443\u0447\u0438\u043B\u0441\u044F
    \u0432 \u0448\u043A\u043E\u043B\u0435 \u041A\u0440\u0430\u043D\u043B\u0438, \u0430
    \u0432 1889 \u0433\u043E\u0434\u0443 \u0432\u044B\u0438\u0433\u0440\u0430\u043B
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E \u0434\u043B\u044F \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
    \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439 \u0412\u0438\u043D\u0447\u0435\u0441\u0442\u0435\u0440-\u043A\u043E\u043B\u043B\u0435\u0434\u0436.
    \u0412\u0438\u043D\u0447\u0435\u0441\u0442\u0435\u0440 \u0441\u043B\u0430\u0432\u0438\u043B\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u043E\u0439, \u043D\u043E
    \u0441\u0430\u043C \u0425\u0430\u0440\u0434\u0438 \u043D\u0435 \u043B\u044E\u0431\u0438\u043B
    \u044D\u0442\u043E \u0443\u0447\u0435\u0431\u043D\u043E\u0435 \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0438\u0437-\u0437\u0430 \u0441\u0443\u0440\u043E\u0432\u043E\u0439 \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u044B.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C
    \u043E\u043D \u0434\u043E\u0431\u0438\u043B\u0441\u044F \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u0443\u0441\u043F\u0435\u0445\u043E\u0432 \u0438 \u0432 1896 \u0433\u043E\u0434\u0443
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E
    \u0434\u043B\u044F \u0443\u0447\u0435\u0431\u044B \u0432 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0435
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430. - **\u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436
    \u0438 \"\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0422\u0440\u0438\u043F\u043E\u0441\":** \u0412 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435
    \u0425\u0430\u0440\u0434\u0438 \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F
    \u0441 \u0440\u0443\u0442\u0438\u043D\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439
    \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0438 \u043A \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0430\u043C,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u044B\u043B\u0430 \u043D\u0430\u0446\u0435\u043B\u0435\u043D\u0430
    \u043D\u0430 \u0437\u0430\u0443\u0447\u0438\u0432\u0430\u043D\u0438\u0435 \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0438\u0435\u043C\u043E\u0432, \u0430 \u043D\u0435 \u043D\u0430
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0435
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430. \u042D\u0442\u043E \u0435\u0433\u043E
    \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043B\u043E, \u0438
    \u043E\u043D \u0434\u0430\u0436\u0435 \u043F\u043E\u0434\u0443\u043C\u044B\u0432\u0430\u043B
    \u043E \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0435 \u043D\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u044E.
    \u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u043C \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C
    \u0441\u0442\u0430\u043B\u043E \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E
    \u0441 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u041E\u0433\u0430\u0441\u0442\u0435\u0441\u043E\u043C
    \u041B\u0430\u0432\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0441\u043E\u0432\u0435\u0442\u043E\u0432\u0430\u043B
    \u0435\u043C\u0443 \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u044C \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \"\u041A\u0443\u0440\u0441 \u0430\u043D\u0430\u043B\u0438\u0437\u0430\" \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u041A\u0430\u043C\u0438\u043B\u044F
    \u0416\u043E\u0440\u0434\u0430\u043D\u0430. \u042D\u0442\u0430 \u043A\u043D\u0438\u0433\u0430
    \u043E\u0442\u043A\u0440\u044B\u043B\u0430 \u0425\u0430\u0440\u0434\u0438 \u0433\u043B\u0430\u0437\u0430
    \u043D\u0430 \u0442\u043E, \"\u0447\u0442\u043E \u043D\u0430 \u0441\u0430\u043C\u043E\u043C
    \u0434\u0435\u043B\u0435 \u0437\u043D\u0430\u0447\u0438\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\".    
    \u0412 1898 \u0433\u043E\u0434\u0443 \u043E\u043D \u0437\u0430\u043D\u044F\u043B
    \u0447\u0435\u0442\u0432\u0435\u0440\u0442\u043E\u0435 \u043C\u0435\u0441\u0442\u043E
    \u043D\u0430 \u0432\u044B\u043F\u0443\u0441\u043A\u043D\u044B\u0445 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0430\u0445
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0422\u0440\u0438\u043F\u043E\u0441\u0430, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0432\u0441\u0435\u0433\u0434\u0430 \u0440\u0430\u0437\u0434\u0440\u0430\u0436\u0430\u043B\u043E,
    \u0442\u0430\u043A \u043A\u0430\u043A \u043E\u043D \u0441\u0447\u0438\u0442\u0430\u043B,
    \u0447\u0442\u043E \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u043B \u0431\u044B\u0442\u044C
    \u043F\u0435\u0440\u0432\u044B\u043C. \u0412 1900 \u0433\u043E\u0434\u0443 \u0425\u0430\u0440\u0434\u0438
    \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C
    \u0441\u043E\u0432\u0435\u0442\u0430 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430
    \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0440\u0435\u043C\u0438\u044E
    \u0421\u043C\u0438\u0442\u0430 (\u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0414\u0436\u0435\u0439\u043C\u0441\u043E\u043C \u0414\u0436\u0438\u043D\u0441\u043E\u043C). 
    ### \U0001F468\u200D\U0001F3EB \u041D\u0430\u0447\u0430\u043B\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B
    \u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0447\u0435\u0431\u043D\u0438\u043A
    (1900\u20131911)  - **\u041F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435
    \u0438 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F:**
    \u0421 1900 \u0433\u043E\u0434\u0430 \u0425\u0430\u0440\u0434\u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043D\u0430 \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0435, \u0430
    \u0441 1906 \u0433\u043E\u0434\u0430 \u0441\u0442\u0430\u043B \u043B\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u0441 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u043D\u0430\u0433\u0440\u0443\u0437\u043A\u043E\u0439
    (\u0432\u0441\u0435\u0433\u043E 6 \u0447\u0430\u0441\u043E\u0432 \u0432 \u043D\u0435\u0434\u0435\u043B\u044E),
    \u0447\u0442\u043E \u0434\u0430\u0432\u0430\u043B\u043E \u0435\u043C\u0443 \u043C\u043D\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0434\u043B\u044F \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439.
    \u0412 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0440\u0430\u0431\u043E\u0442 \u043F\u043E \u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438
    \u0440\u044F\u0434\u043E\u0432 \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u0432,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0435\u0433\u043E
    \u0438\u0437\u0431\u0440\u0430\u043D\u0438\u044E \u0432 \u0447\u043B\u0435\u043D\u044B
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u0432 1910 \u0433\u043E\u0434\u0443.
    - **\xAB\u041A\u0443\u0440\u0441 \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB:**
    \u0412 1908 \u0433\u043E\u0434\u0443 \u0432\u044B\u0448\u043B\u043E, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0435 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u2014
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A \xAB\u041A\u0443\u0440\u0441 \u0447\u0438\u0441\u0442\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB (*A Course of
    Pure Mathematics*). \u042D\u0442\u0430 \u043A\u043D\u0438\u0433\u0430 \u0441\u0442\u0430\u043B\u0430
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0439.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043F\u0435\u0440\u0432\u044B\u043C
    \u0441\u0442\u0440\u043E\u0433\u0438\u043C \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C
    \u043E\u0441\u043D\u043E\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 (\u043F\u0440\u0435\u0434\u0435\u043B\u044B,
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u044C,
    \u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u044C) \u043D\u0430 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435, \u0430\u0434\u0430\u043F\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u043C
    \u0434\u043B\u044F \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432. \u0414\u043E
    \u044D\u0442\u043E\u0433\u043E \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0431\u044B\u043B\u0430
    \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0430
    \u043D\u0430 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u043A
    \u0444\u0438\u0437\u0438\u043A\u0435, \u0438 \u0425\u0430\u0440\u0434\u0438 \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C
    \u2014 \u044D\u0442\u043E \u043E\u0441\u043D\u043E\u0432\u0430 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430.
    \u041F\u043E\u0437\u0436\u0435 \u043E\u043D \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u043B
    \u0441\u0435\u0431\u044F \u0441 \"\u043C\u0438\u0441\u0441\u0438\u043E\u043D\u0435\u0440\u043E\u043C,
    \u0433\u043E\u0432\u043E\u0440\u044F\u0449\u0438\u043C \u0441 \u043A\u0430\u043D\u043D\u0438\u0431\u0430\u043B\u0430\u043C\u0438\",
    \u043F\u044B\u0442\u0430\u044F\u0441\u044C \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u044C
    \u0438\u0434\u0435\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0431\u044B\u043B\u0438
    \u0434\u043B\u044F \u0432\u0441\u0435\u0445 \u043D\u043E\u0432\u044B\u043C\u0438. 
    ### \U0001F91D \u0412\u0435\u043B\u0438\u043A\u043E\u0435 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E:
    \u041B\u0438\u0442\u043B\u0432\u0443\u0434 \u0438 \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D
    (1911\u20131920)  \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0441\u0442\u0430\u043B \u0441\u0430\u043C\u044B\u043C \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C
    \u0438 \u043F\u0440\u043E\u0441\u043B\u0430\u0432\u0438\u043B \u0425\u0430\u0440\u0434\u0438
    \u043D\u0430 \u0432\u0435\u0441\u044C \u043C\u0438\u0440.  - **\u0421\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u0414\u0436. \u0418. \u041B\u0438\u0442\u043B\u0432\u0443\u0434\u043E\u043C:**
    \u041D\u0430\u0447\u0438\u043D\u0430\u044F \u0441 1911 \u0433\u043E\u0434\u0430
    \u043D\u0430\u0447\u0430\u043B\u043E\u0441\u044C \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u043E\u0435
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0425\u0430\u0440\u0434\u0438 \u0441 \u0414\u0436\u043E\u043D\u043E\u043C \u0418\u0434\u0435\u043D\u0437\u043E\u0440\u043E\u043C
    \u041B\u0438\u0442\u043B\u0432\u0443\u0434\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043F\u0440\u043E\u0434\u043B\u0438\u043B\u043E\u0441\u044C 35 \u043B\u0435\u0442.
    \u0418\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u0435\u0441\u043D\u043E\u0439, \u0447\u0442\u043E \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043C\u0438\u0440\u0435 \u0445\u043E\u0434\u0438\u043B\u0430 \u0448\u0443\u0442\u043A\u0430,
    \u0447\u0442\u043E \u0432 \u0410\u043D\u0433\u043B\u0438\u0438 \u0436\u0438\u0432\u0443\u0442
    \u0442\u0440\u0438 \u0432\u0435\u043B\u0438\u043A\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:
    \u0425\u0430\u0440\u0434\u0438, \u041B\u0438\u0442\u043B\u0432\u0443\u0434 \u0438
    \u0425\u0430\u0440\u0434\u0438-\u041B\u0438\u0442\u043B\u0432\u0443\u0434, \u043F\u0440\u0438\u0447\u0435\u043C
    \u0442\u0440\u0435\u0442\u0438\u0439 \u0438\u0437 \u043D\u0438\u0445 \u2014 \u0441\u0430\u043C\u044B\u0439
    \u0432\u0435\u043B\u0438\u043A\u0438\u0439. \u041E\u043D\u0438 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441\u043E\u0437\u0434\u0430\u043B\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B,
    \u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u043E\u043C \u0430\u043D\u0430\u043B\u0438\u0437\u0435,
    \u0441\u0443\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438 \u0440\u0430\u0441\u0445\u043E\u0434\u044F\u0449\u0438\u0445\u0441\u044F
    \u0440\u044F\u0434\u043E\u0432 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u0440\u044F\u0434\u043E\u0432
    \u0424\u0443\u0440\u044C\u0435. \u0421\u0430\u043C \u0425\u0430\u0440\u0434\u0438
    \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B, \u0447\u0442\u043E \u041B\u0438\u0442\u043B\u0432\u0443\u0434
    \u043E\u0431\u043B\u0430\u0434\u0430\u043B \u0431\u043E\u043B\u044C\u0448\u0438\u043C\u0438
    \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438 \u043D\u0430\u0432\u044B\u043A\u0430\u043C\u0438,
    \u0430 \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0441\u044F
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0438 \u0438 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u043C
    \u0441\u0442\u0438\u043B\u0435 \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u044F.
    - **\u041E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0421\u0440\u0438\u043D\u0438\u0432\u0430\u0441\u044B
    \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430:** \u0412
    1913 \u0433\u043E\u0434\u0443 \u0425\u0430\u0440\u0434\u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043F\u0438\u0441\u044C\u043C\u043E \u043E\u0442 \u043D\u0438\u043A\u043E\u043C\u0443
    \u043D\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u043A\u043B\u0435\u0440\u043A\u0430
    \u0438\u0437 \u0418\u043D\u0434\u0438\u0438, \u0421\u0440\u0438\u043D\u0438\u0432\u0430\u0441\u044B
    \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430, \u0441 \u0434\u043B\u0438\u043D\u043D\u044B\u043C
    \u0441\u043F\u0438\u0441\u043A\u043E\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u043E\u0440\u043C\u0443\u043B. \u0414\u0432\u0430 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043D\u0435 \u0437\u0430\u043C\u0435\u0442\u0438\u043B\u0438 \u0433\u0435\u043D\u0438\u044F,
    \u043D\u043E \u0425\u0430\u0440\u0434\u0438 \u0441\u0440\u0430\u0437\u0443 \u043F\u043E\u043D\u044F\u043B,
    \u0447\u0442\u043E \u0438\u043C\u0435\u0435\u0442 \u0434\u0435\u043B\u043E \u0441
    \u043D\u0435\u043E\u0431\u044B\u0447\u0430\u0439\u043D\u044B\u043C \u0442\u0430\u043B\u0430\u043D\u0442\u043E\u043C.
    \u041E\u043D \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436 \u0432 1914 \u0433\u043E\u0434\u0443,
    \u0438 \u043D\u0430\u0447\u0430\u043B\u043E\u0441\u044C \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0425\u0430\u0440\u0434\u0438 \u043F\u043E\u0437\u0436\u0435
    \u043D\u0430\u0437\u0432\u0430\u043B \"\u043E\u0434\u043D\u0438\u043C \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0441\u043B\u0443\u0447\u0430\u0435\u043C \u0432 \u043C\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438\".
    \u041E\u043D\u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B\u0438
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442, \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0444\u043E\u0440\u043C\u0443\u043B\u0443
    \u0434\u043B\u044F \u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u043A\u0438
    \u0447\u0438\u0441\u043B\u0430 \u0440\u0430\u0437\u0431\u0438\u0435\u043D\u0438\u0439
    **p(n)**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u044B\u043B\u0430
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0442\u043E\u0447\u043D\u043E\u0439.
    \u0425\u0430\u0440\u0434\u0438 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0430\u043B \u0441 \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u043E\u043C,
    \u043D\u043E \u0438 \u043F\u043E\u043C\u043E\u0433 \u0435\u043C\u0443 \u0432\u043E\u0441\u043F\u043E\u043B\u043D\u0438\u0442\u044C
    \u043F\u0440\u043E\u0431\u0435\u043B\u044B \u0432 \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0438, \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C \u0441\u0442\u0430\u0440\u0430\u044F\u0441\u044C \u043D\u0435
    \u043F\u043E\u0434\u0430\u0432\u0438\u0442\u044C \u0435\u0433\u043E \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u0433\u0435\u043D\u0438\u0439. \u042D\u0442\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u2014 \u043E\u0434\u043D\u0430 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.  ### \U0001F468\u200D\U0001F393
    \u041E\u043A\u0441\u0444\u043E\u0440\u0434, \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D
    \u0438 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0432
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436 (1919\u20131942)  - **\u041F\u0435\u0440\u0432\u0430\u044F
    \u043C\u0438\u0440\u043E\u0432\u0430\u044F \u0432\u043E\u0439\u043D\u0430:**
    \u0412\u043E\u0439\u043D\u0430 \u0441\u0442\u0430\u043B\u0430 \u0442\u044F\u0436\u0435\u043B\u044B\u043C
    \u043F\u0435\u0440\u0438\u043E\u0434\u043E\u043C \u0434\u043B\u044F \u0425\u0430\u0440\u0434\u0438.
    \u041E\u043D \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0451\u043D\u043D\u044B\u043C
    \u043F\u0430\u0446\u0438\u0444\u0438\u0441\u0442\u043E\u043C \u0438 \u043D\u0435
    \u0440\u0430\u0437\u0434\u0435\u043B\u044F\u043B \u043F\u0430\u0442\u0440\u0438\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u0430
    \u043A\u043E\u043B\u043B\u0435\u0433. \u041E\u043D \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0435
    \u0443\u0432\u0430\u0436\u0430\u043B \u043D\u0435\u043C\u0435\u0446\u043A\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443 \u0438 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u0443
    \u0438 \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u0432\u0441\u0442\u0443\u043F\u0430\u0442\u044C
    \u0432 \u0432\u043E\u0439\u043D\u0443 \u043D\u0435 \u0441\u0442\u043E\u0438\u043B\u043E.
    \u041E\u043D \u043D\u0435 \u043F\u0440\u043E\u0448\u0435\u043B \u0432\u043E\u0435\u043D\u043D\u0443\u044E
    \u0441\u043B\u0443\u0436\u0431\u0443 \u043F\u043E \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u0438\u043C
    \u043F\u043E\u043A\u0430\u0437\u0430\u043D\u0438\u044F\u043C, \u043D\u043E \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u0435\u0431\u044F \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435
    \u043D\u0435\u0443\u044E\u0442\u043D\u043E. - **\u041E\u043A\u0441\u0444\u043E\u0440\u0434:**
    \u0412 1919 \u0433\u043E\u0434\u0443 \u0425\u0430\u0440\u0434\u0438 \u0441 \u0440\u0430\u0434\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u043A\u0438\u043D\u0443\u043B \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436,
    \u043F\u0440\u0438\u043D\u044F\u0432 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    (\u0421\u0430\u0432\u0438\u043B\u044C\u0441\u043A\u043E\u0433\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430)
    \u0432 \u041E\u043A\u0441\u0444\u043E\u0440\u0434\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435.
    \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 (\u0434\u043E 1931
    \u0433\u043E\u0434\u0430) \u043E\u043D \u0441\u0447\u0438\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u0445
    \u0438 \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0432 \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438. \u041E\u043D
    \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u0438\u043B\u044C\u043D\u0443\u044E
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u0438 \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u0447\u0430\u0441\u0442\u044C \u0441\u0432\u043E\u0438\u0445
    \u043B\u0443\u0447\u0448\u0438\u0445 \u0440\u0430\u0431\u043E\u0442 \u0432 \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u0441\u0442\u0432\u0435
    \u0441 \u041B\u0438\u0442\u043B\u0432\u0443\u0434\u043E\u043C, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0442\u043E \u0447\u0442\u043E \u043E\u043D\u0438 \u0436\u0438\u043B\u0438
    \u0432 \u0440\u0430\u0437\u043D\u044B\u0445 \u0433\u043E\u0440\u043E\u0434\u0430\u0445.
    - **\u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D:** \u0412 1928\u20131929
    \u0433\u043E\u0434\u0430\u0445 \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u043E\u0435\u0437\u0434\u043A\u0443 \u0432 \u0421\u0428\u0410, \u0433\u0434\u0435
    \u0447\u0438\u0442\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438 \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u0438
    \u041A\u0430\u043B\u0438\u0444\u043E\u0440\u043D\u0438\u0439\u0441\u043A\u043E\u043C
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435, \u043E\u0431\u043C\u0435\u043D\u044F\u0432\u0448\u0438\u0441\u044C
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044F\u043C\u0438 \u0441 \u041E\u0441\u0432\u0430\u043B\u044C\u0434\u043E\u043C
    \u0412\u0435\u0431\u043B\u0435\u043D\u043E\u043C. - **\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436:** \u0412 1931 \u0433\u043E\u0434\u0443
    \u0425\u0430\u0440\u0434\u0438 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436, \u0437\u0430\u043D\u044F\u0432
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u0447\u0438\u0441\u0442\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0421\u044D\u0434\u043B\u0435\u0440\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u0434\u043E \u0432\u044B\u0445\u043E\u0434\u0430 \u043D\u0430 \u043F\u0435\u043D\u0441\u0438\u044E
    \u0432 1942 \u0433\u043E\u0434\u0443. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E \u043E\u043D \u0431\u044B\u043B
    \u043D\u0435\u0434\u043E\u0432\u043E\u043B\u0435\u043D \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435\u043C
    \u0432 \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438, \u043E\u043D \u0441\u0447\u0438\u0442\u0430\u043B
    \u044D\u0442\u0443 \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u0441\u0430\u043C\u043E\u0439
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0439 \u0432 \u0410\u043D\u0433\u043B\u0438\u0438
    \u0438 \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0435\u043B \u043E\u0441\u0442\u0430\u0442\u044C\u0441\u044F
    \u0432 \u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0435 \u0434\u043E \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0438. 
    ### \U0001F58B \u041F\u043E\u0437\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \xAB\u0410\u043F\u043E\u043B\u043E\u0433\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\xBB
    (1940\u20131947)  - **\u0412\u0442\u043E\u0440\u0430\u044F \u043C\u0438\u0440\u043E\u0432\u0430\u044F
    \u0432\u043E\u0439\u043D\u0430 \u0438 \u0431\u043E\u043B\u0435\u0437\u043D\u044C:**
    \u0412\u0442\u043E\u0440\u0430\u044F \u043C\u0438\u0440\u043E\u0432\u0430\u044F
    \u0432\u043E\u0439\u043D\u0430, \u043A\u0430\u043A \u0438 \u043F\u0435\u0440\u0432\u0430\u044F,
    \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430 \u0425\u0430\u0440\u0434\u0438
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0435 \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u0435.
    \u041E\u043D \u0442\u044F\u0436\u0435\u043B\u043E \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u043B
    \u043D\u043E\u0432\u043E\u0435 \u0431\u0435\u0437\u0443\u043C\u0438\u0435 \u0432\u043E\u0439\u043D\u044B.
    \u0412 1939 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    62 \u043B\u0435\u0442, \u043E\u043D \u043F\u0435\u0440\u0435\u043D\u0435\u0441
    \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u044B\u0439 \u043F\u0440\u0438\u0441\u0442\u0443\u043F,
    \u043F\u043E\u0441\u043B\u0435 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0435\u0433\u043E \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0438 \u0443\u043C\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u0441\u0442\u0430\u043B\u043E \u0443\u0445\u0443\u0434\u0448\u0430\u0442\u044C\u0441\u044F.
    - **\xAB\u0410\u043F\u043E\u043B\u043E\u0433\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\xBB:**
    \u0412 1940 \u0433\u043E\u0434\u0443, \u043D\u0430 \u043F\u0438\u043A\u0435 \u043E\u0442\u0447\u0430\u044F\u043D\u0438\u044F,
    \u0425\u0430\u0440\u0434\u0438 \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u044E
    \u0441\u0430\u043C\u0443\u044E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0443\u044E
    \u043D\u0435-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u2014 \xAB\u0410\u043F\u043E\u043B\u043E\u0433\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\xBB (*A Mathematician's
    Apology*). \u042D\u0442\u043E \u044D\u0441\u0441\u0435, \u043F\u0440\u043E\u043D\u0438\u0437\u0430\u043D\u043D\u043E\u0435
    \u043C\u0435\u043B\u0430\u043D\u0445\u043E\u043B\u0438\u0435\u0439, \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u0437\u0430\u0449\u0438\u0442\u043E\u0439
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u043C \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0412 \u043D\u0435\u043C \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0442\u0435\u0437\u0438\u0441: \"\u042F \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0434\u0435\u043B\u0430\u043B \u043D\u0438\u0447\u0435\u0433\u043E
    '\u043F\u043E\u043B\u0435\u0437\u043D\u043E\u0433\u043E'. \u041D\u0438 \u043E\u0434\u043D\u043E
    \u043C\u043E\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043D\u0435
    \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u043E \u0438 \u043D\u0435 \u043C\u043E\u0433\u043B\u043E
    \u0431\u044B \u043F\u0440\u0438\u043D\u0435\u0441\u0442\u0438, \u044F\u0432\u043D\u043E
    \u0438\u043B\u0438 \u043D\u0435\u044F\u0432\u043D\u043E, \u043A \u0434\u043E\u0431\u0440\u0443
    \u0438\u043B\u0438 \u043A\u043E \u0437\u043B\u0443, \u043D\u0438 \u043C\u0430\u043B\u0435\u0439\u0448\u0435\u0433\u043E
    \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u044F \u0432 \u0431\u043B\u0430\u0433\u043E\u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0435
    \u044D\u0442\u043E\u0433\u043E \u043C\u0438\u0440\u0430\". \u041E\u043D \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0435
    \u0432\u0435\u0440\u0438\u043B, \u0447\u0442\u043E \u0438\u0441\u0442\u0438\u043D\u043D\u0430\u044F
    \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u2014 \u0432 \u0435\u0435 \u043A\u0440\u0430\u0441\u043E\u0442\u0435, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u043B \u0441 \u0436\u0438\u0432\u043E\u043F\u0438\u0441\u044C\u044E
    \u0438 \u043F\u043E\u044D\u0437\u0438\u0435\u0439, \u0438 \u0447\u0442\u043E
    \u043F\u043E\u043B\u0435\u0437\u043D\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    (\u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u0430\u044F) \u0447\u0430\u0441\u0442\u043E
    \u0431\u044B\u0432\u0430\u0435\u0442 \"\u0442\u0440\u0438\u0432\u0438\u0430\u043B\u044C\u043D\u043E\u0439\"
    \u0438 \"\u0443\u0440\u043E\u0434\u043B\u0438\u0432\u043E\u0439\". - **\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B:** \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B
    \u0443\u0431\u0435\u0436\u0434\u0451\u043D\u043D\u044B\u043C \u0430\u0442\u0435\u0438\u0441\u0442\u043E\u043C,
    \u043D\u043E \u0443 \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u0430 \u043E\u0441\u043E\u0431\u0430\u044F
    \"\u0438\u0433\u0440\u0430 \u0441 \u0411\u043E\u0433\u043E\u043C\". \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044F\u0441\u044C \u0438\u0437
    \u0414\u0430\u043D\u0438\u0438, \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u043E\u0442\u043A\u0440\u044B\u0442\u043A\u0443, \u0447\u0442\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443 \u0420\u0438\u043C\u0430\u043D\u0430,
    \u0441\u0447\u0438\u0442\u0430\u044F, \u0447\u0442\u043E \u0411\u043E\u0433 \u043D\u0435
    \u0434\u0430\u0441\u0442 \u0435\u043C\u0443 \u0443\u0442\u043E\u043D\u0443\u0442\u044C,
    \u0447\u0442\u043E\u0431\u044B \u043D\u0435 \u043B\u0438\u0448\u0438\u0442\u044C
    \u043C\u0438\u0440 \u0442\u0430\u043A\u043E\u0439 \u0441\u043B\u0430\u0432\u044B.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0431\u0440\u0430\u043B \u0441 \u0441\u043E\u0431\u043E\u0439
    \u043D\u0430 \u043A\u0440\u0438\u043A\u0435\u0442\u043D\u044B\u0435 \u043C\u0430\u0442\u0447\u0438
    \xAB\u0430\u043D\u0442\u0438-\u0431\u043E\u0436\u044C\u044E \u0431\u0430\u0442\u0430\u0440\u0435\u044E\xBB
    (\u0441\u0432\u0438\u0442\u0435\u0440\u0430, \u0437\u043E\u043D\u0442 \u0438
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B \u0434\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B),
    \u043F\u043E\u043B\u0430\u0433\u0430\u044F, \u0447\u0442\u043E \u0411\u043E\u0433
    \u043F\u043E\u0448\u043B\u0435\u0442 \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u0443\u044E
    \u043F\u043E\u0433\u043E\u0434\u0443, \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043C\u0435\u0448\u0430\u0442\u044C
    \u0435\u043C\u0443 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C. - **\u0421\u043C\u0435\u0440\u0442\u044C
    \u0438 \u043D\u0430\u0433\u0440\u0430\u0434\u044B:** \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u043D\u0435\u0434\u0435\u043B\u0438 \u0436\u0438\u0437\u043D\u0438 \u043E\u043D
    \u0431\u044B\u043B \u0440\u0430\u0434 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0432\u044B\u0441\u0448\u0443\u044E \u043D\u0430\u0433\u0440\u0430\u0434\u0443
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u2014 \u043C\u0435\u0434\u0430\u043B\u044C
    \u041A\u043E\u043F\u043B\u0438 (1947). \u0414\u043E \u044D\u0442\u043E\u0433\u043E
    \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u043C\u0435\u0434\u0430\u043B\u0438
    (1920), \u043C\u0435\u0434\u0430\u043B\u0438 \u0421\u0438\u043B\u044C\u0432\u0435\u0441\u0442\u0440\u0430
    (1940), \u043C\u0435\u0434\u0430\u043B\u0438 \u0414\u0435 \u041C\u043E\u0440\u0433\u0430\u043D\u0430
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 (1929) \u0438 \u0438\u0437\u0431\u0440\u0430\u043D
    \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u0410\u041D \u0421\u0421\u0421\u0420. \u0425\u0430\u0440\u0434\u0438 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    1 \u0434\u0435\u043A\u0430\u0431\u0440\u044F 1947 \u0433\u043E\u0434\u0430 \u0432
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435.  ### \U0001F4DD \u041B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435 \u0444\u0430\u043A\u0442\u044B 
    - **\u042D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0441\u0442\u044C:**
    \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B \u043A\u0440\u0430\u0439\u043D\u0435
    \u0437\u0430\u0441\u0442\u0435\u043D\u0447\u0438\u0432 \u0438 \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u0435\u043D.
    \u041E\u043D \u0442\u0435\u0440\u043F\u0435\u0442\u044C \u043D\u0435 \u043C\u043E\u0433
    \u0441\u0432\u043E\u0435 \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0438, \u0432\u043E\u0439\u0434\u044F \u0432 \u0433\u043E\u0441\u0442\u0438\u043D\u0438\u0447\u043D\u044B\u0439
    \u043D\u043E\u043C\u0435\u0440, \u043F\u0435\u0440\u0432\u044B\u043C \u0434\u0435\u043B\u043E\u043C
    \u043D\u0430\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043B \u043F\u043E\u043B\u043E\u0442\u0435\u043D\u0446\u0435
    \u043D\u0430 \u0432\u0441\u0435 \u0437\u0435\u0440\u043A\u0430\u043B\u0430. \u041E\u043D
    \u0442\u0430\u043A\u0436\u0435 \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B,
    \u043A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0440\u043E\u0432\u0430\u043B\u0438,
    \u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u0432\u0441\u0435\u0433\u043E
    \u043F\u044F\u0442\u044C \u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0445
    \u0441\u043D\u0438\u043C\u043A\u043E\u0432. - **\u0421\u0442\u0440\u0430\u0441\u0442\u044C
    \u043A \u043A\u0440\u0438\u043A\u0435\u0442\u0443:** \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0441\u0442\u0440\u0430\u0441\u0442\u044C\u044E \u0432\u043D\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0434\u043B\u044F \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B \u043A\u0440\u0438\u043A\u0435\u0442.
    \u041E\u043D \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0431\u043E\u043B\u0435\u043B\u044C\u0449\u0438\u043A\u043E\u043C, \u043D\u043E
    \u0438 \u043E\u0442\u043B\u0438\u0447\u043D\u044B\u043C \u0438\u0433\u0440\u043E\u043A\u043E\u043C
    \u0438 \u0442\u043E\u043D\u043A\u0438\u043C \u0437\u043D\u0430\u0442\u043E\u043A\u043E\u043C
    \u044D\u0442\u043E\u0439 \u0438\u0433\u0440\u044B. \u0415\u0433\u043E \u0440\u0430\u0441\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u0434\u043D\u044F \u0431\u044B\u043B\u043E \u043F\u043E\u0434\u0447\u0438\u043D\u0435\u043D\u043E
    \u043A\u0440\u0438\u043A\u0435\u0442\u043D\u043E\u043C\u0443 \u0441\u0435\u0437\u043E\u043D\u0443.
    - **\u0412\u0437\u0433\u043B\u044F\u0434\u044B:** \u0425\u0430\u0440\u0434\u0438
    \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0451\u043D\u043D\u044B\u043C
    \u0430\u0442\u0435\u0438\u0441\u0442\u043E\u043C \u0438 \u043F\u0430\u0446\u0438\u0444\u0438\u0441\u0442\u043E\u043C.
    \u041E\u043D \u0441\u0438\u043C\u043F\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0431\u0435\u0434\u043D\u044B\u043C \u0438 \u043D\u0435\u0434\u043E\u043B\u044E\u0431\u043B\u0438\u0432\u0430\u043B
    \xAB\u043D\u0430\u0434\u0443\u0442\u044B\u0445\xBB \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u0435\u043B\u0435\u0439
    \u0431\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u0438\u0441\u0442\u0435\u0431\u043B\u0438\u0448\u043C\u0435\u043D\u0442\u0430
    \u2014 \u0435\u043F\u0438\u0441\u043A\u043E\u043F\u043E\u0432, \u0441\u0443\u0434\u0435\u0439
    \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u043E\u0432. \u0414\u043E\u043B\u0433\u0438\u0435
    \u0433\u043E\u0434\u044B \u043E\u043D \u0431\u044B\u043B \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u0410\u0441\u0441\u043E\u0446\u0438\u0430\u0446\u0438\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442\u043D\u0438\u043A\u043E\u0432, \u043F\u043E \u0441\u0443\u0442\u0438,
    \u043F\u0440\u043E\u0444\u0441\u043E\u044E\u0437\u0430 \u0443\u0447\u0435\u043D\u044B\u0445.
    - **\u0412\u043A\u043B\u0430\u0434 \u0432 \u0433\u0435\u043D\u0435\u0442\u0438\u043A\u0443:**
    \u0412 1908 \u0433\u043E\u0434\u0443 \u0425\u0430\u0440\u0434\u0438 \u0432\u044B\u0432\u0435\u043B
    \u0431\u0430\u0437\u043E\u0432\u044B\u0439 \u0437\u0430\u043A\u043E\u043D \u043F\u043E\u043F\u0443\u043B\u044F\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u0433\u0435\u043D\u0435\u0442\u0438\u043A\u0438, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u0430\u043A \u0437\u0430\u043A\u043E\u043D \u0425\u0430\u0440\u0434\u0438-\u0412\u0430\u0439\u043D\u0431\u0435\u0440\u0433\u0430,
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0449\u0438\u0439 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0433\u0435\u043D\u043E\u0432 \u0432 \u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u043F\u043E\u043F\u0443\u043B\u044F\u0446\u0438\u0438. \u0421\u0430\u043C \u043E\u043D
    \u0441\u0447\u0438\u0442\u0430\u043B \u044D\u0442\u0443 \u0440\u0430\u0431\u043E\u0442\u0443
    \u043D\u0435\u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439,
    \u043D\u043E \u0434\u043B\u044F \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438
    \u043E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0413\u043E\u0434\u0444\u0440\u0438
    \u0425\u0430\u0440\u043E\u043B\u0434\u0430 \u0425\u0430\u0440\u0434\u0438 \u2014
    \u044D\u0442\u043E \u043A\u043B\u0430\u0434\u0435\u0437\u044C \u043F\u0440\u0438\u0447\u0443\u0434,
    \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0445 \u043F\u0440\u0438\u0432\u044B\u0447\u0435\u043A
    \u0438 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439. \u041E\u043D \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0434\u0435\u043B\u0430\u043B
    \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E\u043C.
    \u0412\u043E\u0442 \u0441\u0430\u043C\u0430\u044F \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F
    \u043A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u044F \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u043E \xAB\u043A\u043E\u0440\u043E\u043B\u0435
    \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB. 
    ### 1. \U0001F3AD \u041F\u0430\u0442\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043D\u0435\u043D\u0430\u0432\u0438\u0441\u0442\u044C \u043A \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0432\u043D\u0435\u0448\u043D\u043E\u0441\u0442\u0438 \u042D\u0442\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0435\u0433\u043E \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0441\u0442\u044C.
    \u0425\u0430\u0440\u0434\u0438 \u0438\u0441\u043F\u044B\u0442\u044B\u0432\u0430\u043B
    \u043F\u043E\u0447\u0442\u0438 \u043C\u0430\u043D\u0438\u0430\u043A\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0442\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u043A \u0441\u0432\u043E\u0435\u043C\u0443
    \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044E. *   **\u0412\u043E\u0439\u043D\u0430
    \u0441 \u0437\u0435\u0440\u043A\u0430\u043B\u0430\u043C\u0438:** \u0412\u0445\u043E\u0434\u044F
    \u0432 \u043B\u044E\u0431\u043E\u0439 \u0433\u043E\u0441\u0442\u0438\u043D\u0438\u0447\u043D\u044B\u0439
    \u043D\u043E\u043C\u0435\u0440 \u0438\u043B\u0438 \u043D\u043E\u0432\u0443\u044E
    \u043A\u043E\u043C\u043D\u0430\u0442\u0443, \u043E\u043D \u043F\u0435\u0440\u0432\u044B\u043C
    \u0434\u0435\u043B\u043E\u043C \u043C\u0435\u0442\u043E\u0434\u0438\u0447\u043D\u043E
    \u043D\u0430\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043B \u043F\u043E\u043B\u043E\u0442\u0435\u043D\u0446\u0430,
    \u043F\u043B\u0430\u0442\u043A\u0438 \u0438\u043B\u0438 \u043B\u044E\u0431\u0443\u044E
    \u0442\u043A\u0430\u043D\u044C \u043D\u0430 **\u0432\u0441\u0435 \u0437\u0435\u0440\u043A\u0430\u043B\u0430**
    \u0431\u0435\u0437 \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F.
    \u041E\u043D \u043D\u0435 \u043C\u043E\u0433 \u0432\u044B\u043D\u043E\u0441\u0438\u0442\u044C
    \u0432\u0438\u0434\u0430 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u043B\u0438\u0446\u0430. *   **\u0424\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438:**
    \u042D\u0442\u0430 \u043D\u0435\u043D\u0430\u0432\u0438\u0441\u0442\u044C \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u043B\u0430\u0441\u044C
    \u0438 \u043D\u0430 \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438.
    \u041E\u043D \u0438\u0437\u0431\u0435\u0433\u0430\u043B \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043E\u0432
    \u0441 \u0442\u0430\u043A\u0438\u043C \u0443\u043F\u043E\u0440\u0441\u0442\u0432\u043E\u043C,
    \u0447\u0442\u043E \u0432\u043E \u0432\u0441\u0435\u043C \u043C\u0438\u0440\u0435
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C **\u0432\u0441\u0435\u0433\u043E
    \u043F\u044F\u0442\u044C \u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0445
    \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0439** \u0425\u0430\u0440\u0434\u0438,
    \u0438 \u043D\u0438 \u043E\u0434\u043D\u043E\u0439 \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0442\u0443\u0434\u0438\u0439\u043D\u043E\u0439.  ### 2. \U0001F64F \u0410\u0442\u0435\u0438\u0441\u0442,
    \u0438\u0433\u0440\u0430\u0432\u0448\u0438\u0439 \u0441 \u0411\u043E\u0433\u043E\u043C
    \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u0438 \u0434\u0430\u0436\u0435 \u0432\u043E\u0438\u043D\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u043C
    \u0430\u0442\u0435\u0438\u0441\u0442\u043E\u043C. \u041E\u043D \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F
    \u043F\u043E\u0441\u0435\u0449\u0430\u0442\u044C \u0446\u0435\u0440\u043A\u043E\u0432\u043D\u044B\u0435
    \u0441\u043B\u0443\u0436\u0431\u044B \u043F\u043E \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u043F\u043E\u0432\u043E\u0434\u0430\u043C. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u0430\u0442\u0435\u0438\u0437\u043C \u0431\u044B\u043B \u043D\u0435
    \u0441\u043A\u0443\u0447\u043D\u044B\u043C \u043E\u0442\u0440\u0438\u0446\u0430\u043D\u0438\u0435\u043C,
    \u0430 \u0432\u0435\u0441\u0435\u043B\u043E\u0439 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439
    \u0438\u0433\u0440\u043E\u0439. \u041E\u043D \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u0443\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u043F\u0430\u0440\u0438 \u0441 \u041D\u0435\u0431\u0435\u0441\u0430\u043C\u0438: 
    *   **\u041F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0438\u0437
    \u0414\u0430\u043D\u0438\u0438:** \u041F\u043E\u0441\u043B\u0435 \u0432\u0438\u0437\u0438\u0442\u0430
    \u043A \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C \u0432 \u041A\u043E\u043F\u0435\u043D\u0433\u0430\u0433\u0435\u043D,
    \u043F\u0435\u0440\u0435\u0434 \u043E\u0442\u043F\u043B\u044B\u0442\u0438\u0435\u043C
    \u043D\u0430 \u043A\u043E\u0440\u0430\u0431\u043B\u0435, \u0425\u0430\u0440\u0434\u0438
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B \u0432 \u0410\u043D\u0433\u043B\u0438\u044E
    \u0442\u0435\u043B\u0435\u0433\u0440\u0430\u043C\u043C\u0443 \u0441\u043E \u0441\u043B\u043E\u0432\u0430\u043C\u0438:
    *\xAB\u042F \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u0420\u0438\u043C\u0430\u043D\u0430\xBB*. \u041E\u043D \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0430\u043B
    \u0442\u0430\u043A: \u0435\u0441\u043B\u0438 \u0411\u043E\u0433 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442,
    \u041E\u043D \u043D\u0435 \u0434\u043E\u043F\u0443\u0441\u0442\u0438\u0442, \u0447\u0442\u043E\u0431\u044B
    \u043A\u043E\u0440\u0430\u0431\u043B\u044C \u0437\u0430\u0442\u043E\u043D\u0443\u043B,
    \u0438\u0431\u043E \u0442\u043E\u0433\u0434\u0430 \u043C\u0438\u0440 \u043B\u0438\u0448\u0438\u0442\u0441\u044F
    \u0441\u043B\u0430\u0432\u044B \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430.
    \u041A\u043E\u0440\u0430\u0431\u043B\u044C, \u0440\u0430\u0437\u0443\u043C\u0435\u0435\u0442\u0441\u044F,
    \u0431\u043B\u0430\u0433\u043E\u043F\u043E\u043B\u0443\u0447\u043D\u043E \u043F\u0440\u0438\u0431\u044B\u043B
    \u0432 \u043F\u043E\u0440\u0442. *   **\xAB\u0410\u043D\u0442\u0438-\u0431\u043E\u0436\u044C\u044F
    \u0431\u0430\u0442\u0430\u0440\u0435\u044F\xBB:** \u041E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u044F\u0441\u044C
    \u043D\u0430 \u0441\u0442\u0430\u0434\u0438\u043E\u043D \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
    \u043A\u0440\u0438\u043A\u0435\u0442 (\u0435\u0433\u043E \u0432\u0442\u043E\u0440\u0443\u044E
    \u0441\u0442\u0440\u0430\u0441\u0442\u044C), \u0425\u0430\u0440\u0434\u0438 \u0432\u0441\u0435\u0433\u0434\u0430
    \u0431\u0440\u0430\u043B \u0441 \u0441\u043E\u0431\u043E\u0439 \u0442\u0449\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0443\u043F\u0430\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0439 \u043F\u043E\u0440\u0442\u0444\u0435\u043B\u044C
    \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044F\u043C\u0438, \u0437\u043E\u043D\u0442
    \u0438 \u0448\u0435\u0440\u0441\u0442\u044F\u043D\u043E\u0439 \u0441\u0432\u0438\u0442\u0435\u0440.
    \u041E\u043D \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u043B \u044D\u0442\u043E
    \u0442\u0430\u043A: \u0435\u0441\u043B\u0438 \u0411\u043E\u0433 \u0435\u0441\u0442\u044C
    \u0438 \u0445\u043E\u0447\u0435\u0442 \u043F\u043E\u043C\u0435\u0448\u0430\u0442\u044C
    \u0435\u043C\u0443 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C, \u041E\u043D
    \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E \u043F\u043E\u0448\u043B\u0435\u0442
    \u0434\u043E\u0436\u0434\u044C, \u0447\u0442\u043E\u0431\u044B \u0425\u0430\u0440\u0434\u0438
    \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0434\u043E\u043C\u0430 \u0438 \u0441\u0435\u043B
    \u0437\u0430 \u0441\u0442\u043E\u043B. \u0411\u0435\u0440\u044F \u0441 \u0441\u043E\u0431\u043E\u0439
    \u0437\u043E\u043D\u0442 \u0438 \u0441\u0432\u0438\u0442\u0435\u0440, \u0425\u0430\u0440\u0434\u0438
    \u043A\u0430\u043A \u0431\u044B \u0433\u043E\u0432\u043E\u0440\u0438\u043B: \xAB\u042F
    \u0433\u043E\u0442\u043E\u0432 \u043A \u0434\u043E\u0436\u0434\u044E, \u0442\u0430\u043A
    \u0447\u0442\u043E \u0434\u0430\u0432\u0430\u0439, \u0413\u043E\u0441\u043F\u043E\u0434\u0438,
    \u0434\u0435\u043B\u0430\u0439 \u0441\u0432\u043E\u044E \u043F\u043E\u0433\u043E\u0434\u0443
    \u2014 \u044F \u0432\u0441\u0435 \u0440\u0430\u0432\u043D\u043E \u0431\u0443\u0434\u0443
    \u043D\u0430\u0441\u043B\u0430\u0436\u0434\u0430\u0442\u044C\u0441\u044F \u043C\u0430\u0442\u0447\u0435\u043C\xBB. 
    ### 3. \U0001F3CF \u0412\u0442\u043E\u0440\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u2014 \u043A\u0440\u0438\u043A\u0435\u0442 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u043E\u0439
    \u0438 \u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u0441\u0442\u0440\u0430\u0441\u0442\u044C\u044E,
    \u043D\u043E \u043A\u0440\u0438\u043A\u0435\u0442 \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u0442\u0432\u0435\u0440\u0434\u043E\u0435 \u0432\u0442\u043E\u0440\u043E\u0435
    \u043C\u0435\u0441\u0442\u043E. *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A-\u0441\u043F\u043E\u0440\u0442\u0441\u043C\u0435\u043D:**
    \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0431\u043E\u043B\u0435\u043B\u044C\u0449\u0438\u043A\u043E\u043C, \u043E\u043D
    \u0441\u0430\u043C \u0438\u0433\u0440\u0430\u043B \u0432 \u043A\u0440\u0438\u043A\u0435\u0442
    \u043D\u0430 \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E \u043F\u0440\u0438\u043B\u0438\u0447\u043D\u043E\u043C
    \u0443\u0440\u043E\u0432\u043D\u0435. \u041E\u043D \u0431\u044B\u043B \u043E\u0442\u043B\u0438\u0447\u043D\u044B\u043C
    \u043F\u043E\u043B\u0435\u0432\u044B\u043C \u0438\u0433\u0440\u043E\u043A\u043E\u043C
    \u0438 \u0431\u044D\u0442\u0441\u043C\u0435\u043D\u043E\u043C \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B
    \u0438\u0433\u0440\u0430\u0442\u044C \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0445
    \u043C\u0430\u0442\u0447\u0430\u0445 \u0434\u0430\u0436\u0435 \u0432 \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E
    \u0437\u0440\u0435\u043B\u043E\u043C \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435.
    *   **\u042D\u043A\u0441\u043F\u0435\u0440\u0442:** \u041E\u043D \u0437\u043D\u0430\u043B
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0443 \u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u0430
    \u0438\u0433\u0440\u044B \u0434\u043E\u0441\u043A\u043E\u043D\u0430\u043B\u044C\u043D\u043E.
    \u0421\u0432\u043E\u0438\u043C \u0434\u0440\u0443\u0437\u044C\u044F\u043C (\u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u041A\u0435\u0439\u043D\u0441\u0430 \u0438 \u041B\u0438\u0442\u043B\u0432\u0443\u0434\u0430)
    \u043E\u043D \u0447\u0430\u0441\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u043B,
    \u0447\u0442\u043E \u0432 \u0436\u0438\u0437\u043D\u0438 \u0435\u0441\u0442\u044C
    \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u0432\u0430 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0445
    \u0443\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u044F: \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u0438 \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C \u0445\u043E\u0440\u043E\u0448\u0438\u0439
    \u043A\u0440\u0438\u043A\u0435\u0442. *   **\u0420\u0430\u0441\u043F\u0438\u0441\u0430\u043D\u0438\u0435:**
    \u041F\u043B\u0430\u043D\u0438\u0440\u0443\u044F \u0441\u0432\u043E\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443, \u043E\u043D \u0432\u0441\u0435\u0433\u0434\u0430
    \u0441\u0432\u0435\u0440\u044F\u043B\u0441\u044F \u0441 \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u0435\u043C
    \u043A\u0440\u0438\u043A\u0435\u0442\u043D\u044B\u0445 \u043C\u0430\u0442\u0447\u0435\u0439.
    \u041B\u0435\u0442\u043D\u0438\u0435 \u0441\u0435\u043C\u0435\u0441\u0442\u0440\u044B
    \u0431\u044B\u043B\u0438 \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u043C\u0435\u043D\u0435\u0435
    \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u044B \u0432 \u043F\u043B\u0430\u043D\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043F\u043E\u0442\u043E\u043C\u0443
    \u0447\u0442\u043E \u043E\u043D \u0432\u0441\u0435 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B
    \u043D\u0430 \u0441\u0442\u0430\u0434\u0438\u043E\u043D\u0435 \xAB\u041B\u043E\u0440\u0434\u0441\xBB. 
    ### 4. \U0001F91D \u0421\u0443\u0434\u044C\u0431\u043E\u043D\u043E\u0441\u043D\u043E\u0435
    \u043F\u0438\u0441\u044C\u043C\u043E \u0438 12 \u0431\u0430\u043B\u043B\u043E\u0432
    \u0418\u0441\u0442\u043E\u0440\u0438\u044F \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430 \u043F\u043E\u043B\u043D\u0430
    \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0437\u043C\u0430. *   \u0425\u0430\u0440\u0434\u0438
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0438\u0441\u044C\u043C\u043E
    \u043E\u0442 \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u043E\u0433\u043E \u043A\u043B\u0435\u0440\u043A\u0430
    \u0441 \u0432\u043E\u0440\u043E\u0445\u043E\u043C \u0444\u043E\u0440\u043C\u0443\u043B.
    \u041C\u043D\u043E\u0433\u0438\u0435 \u0438\u0437 \u043D\u0438\u0445 \u0431\u044B\u043B\u0438
    \u043D\u0435\u0432\u0435\u0440\u043D\u044B \u0438\u043B\u0438 \u043F\u043B\u043E\u0445\u043E
    \u0437\u0430\u043F\u0438\u0441\u0430\u043D\u044B. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0425\u0430\u0440\u0434\u0438 \u043D\u0435 \u0432\u044B\u0431\u0440\u043E\u0441\u0438\u043B
    \u043F\u0438\u0441\u044C\u043C\u043E. \u0412\u043C\u0435\u0441\u0442\u0435 \u0441
    \u041B\u0438\u0442\u043B\u0432\u0443\u0434\u043E\u043C \u043E\u043D\u0438 \u0441\u0442\u0430\u043B\u0438
    \u0440\u0430\u0437\u0431\u0438\u0440\u0430\u0442\u044C \u0435\u0433\u043E \u0438
    \u043D\u0430\u0442\u043A\u043D\u0443\u043B\u0438\u0441\u044C \u043D\u0430 \u043E\u0434\u043D\u0443
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443, \u043A\u0430\u0441\u0430\u044E\u0449\u0443\u044E\u0441\u044F
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445 \u0440\u044F\u0434\u043E\u0432.
    *   \u0425\u0430\u0440\u0434\u0438 \u043F\u043E\u0437\u0436\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B\u0441\u044F,
    \u0447\u0442\u043E \u043E\u0434\u043D\u043E\u0433\u043E \u0432\u0437\u0433\u043B\u044F\u0434\u0430
    \u043D\u0430 \u044D\u0442\u0443 \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0431\u044B\u043B\u043E
    \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E, \u0447\u0442\u043E\u0431\u044B
    \u043F\u043E\u043D\u044F\u0442\u044C \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0430\u0432\u0442\u043E\u0440\u0430. \u041E\u043D \u043D\u0435 \u0432\u0438\u0434\u0435\u043B
    \u043F\u043E\u0434\u043E\u0431\u043D\u044B\u0445 \u0444\u043E\u0440\u043C\u0443\u043B
    \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D \u042D\u0439\u043B\u0435\u0440\u0430
    \u0438 \u042F\u043A\u043E\u0431\u0438. \u0425\u0430\u0440\u0434\u0438 \u043E\u0446\u0435\u043D\u0438\u043B
    \u0442\u0430\u043B\u0430\u043D\u0442 \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430
    **\xAB\u043F\u043E \u0448\u043A\u0430\u043B\u0435 \u043E\u0442 0 \u0434\u043E
    100 \u0432 12 \u0431\u0430\u043B\u043B\u043E\u0432\xBB** (\u043E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u0413\u0430\u0443\u0441\u0441 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0431\u044B 100, \u042D\u0439\u043B\u0435\u0440 \u2014 90, \u0430 \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D
    \u2014 100, \u043D\u043E \u0438\u0437-\u0437\u0430 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u044F
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F \u2014 50).
    \u041F\u043E\u0437\u0436\u0435 \u043E\u043D \u0433\u043E\u0432\u043E\u0440\u0438\u043B,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u2014 \u044D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430. 
    ### 5. \U0001F691 \u0422\u0430\u043A\u0441\u0438 \u0438 \u0447\u0438\u0441\u043B\u043E
    1729 \u0421\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0431\u0430\u0439\u043A\u0430 \u043E \u0425\u0430\u0440\u0434\u0438 \u0438 \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0435.
    *   \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u0425\u0430\u0440\u0434\u0438
    \u043D\u0430\u0432\u0435\u0449\u0430\u043B \u0431\u043E\u043B\u044C\u043D\u043E\u0433\u043E
    \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430 \u0432 \u0441\u0430\u043D\u0430\u0442\u043E\u0440\u0438\u0438
    \u0432 \u041F\u0430\u0442\u043D\u0438. \u041F\u043E\u0434\u044A\u0435\u0437\u0436\u0430\u044F
    \u043D\u0430 \u0442\u0430\u043A\u0441\u0438, \u0425\u0430\u0440\u0434\u0438 \u043E\u0442\u043C\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u043D\u043E\u043C\u0435\u0440 \u043C\u0430\u0448\u0438\u043D\u044B
    \u0431\u044B\u043B \u043E\u0447\u0435\u043D\u044C \u0441\u043A\u0443\u0447\u043D\u044B\u043C
    \u2014 **1729**. *   \u0412\u043E\u0439\u0434\u044F \u0432 \u043F\u0430\u043B\u0430\u0442\u0443,
    \u043E\u043D \u0441\u043A\u0430\u0437\u0430\u043B \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0443:
    \xAB\u041C\u043D\u0435 \u043A\u0430\u0436\u0435\u0442\u0441\u044F, \u044D\u0442\u043E
    \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E \u0441\u043A\u0443\u0447\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E\xBB. \u041D\u0430 \u0447\u0442\u043E \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u0431\u043B\u0430\u0434\u0430\u043B
    \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0435\u0439 \u0432 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B, \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E
    \u043E\u0442\u0432\u0435\u0442\u0438\u043B: \xAB\u041D\u0435\u0442, \u0425\u0430\u0440\u0434\u0438,
    \u044D\u0442\u043E \u043E\u0447\u0435\u043D\u044C \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E! \u042D\u0442\u043E \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0435
    \u0447\u0438\u0441\u043B\u043E, \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043C\u043E\u0436\u043D\u043E
    \u0432\u044B\u0440\u0430\u0437\u0438\u0442\u044C \u043A\u0430\u043A \u0441\u0443\u043C\u043C\u0443
    \u0434\u0432\u0443\u0445 \u043A\u0443\u0431\u043E\u0432 \u0434\u0432\u0443\u043C\u044F
    \u0440\u0430\u0437\u043D\u044B\u043C\u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u0430\u043C\u0438\xBB.    
    \u0422\u043E \u0435\u0441\u0442\u044C:     \\( 1^3 + 12^3 = 1729 \\)     \\(
    9^3 + 10^3 = 1729 \\)     \u0421 \u0442\u0435\u0445 \u043F\u043E\u0440 \u0447\u0438\u0441\u043B\u043E
    1729 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E
    \u043A\u0430\u043A **\xAB\u0447\u0438\u0441\u043B\u043E \u0425\u0430\u0440\u0434\u0438
    \u2014 \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430\xBB**
    (\u0438\u043B\u0438 \u0442\u0430\u043A\u0441\u0438-\u0447\u0438\u0441\u043B\u043E). 
    ### 6. \U0001F4DA \xAB\u0410\u043F\u043E\u043B\u043E\u0433\u0438\u044F\xBB \u043A\u0430\u043A
    \u043F\u0440\u0435\u0434\u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0435 \u043F\u0438\u0441\u044C\u043C\u043E
    \u0425\u0430\u0440\u0434\u0438 \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u043A\u043D\u0438\u0433\u0443
    \xAB\u0410\u043F\u043E\u043B\u043E\u0433\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\xBB
    \u0432 1940 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u0435\u043C\u0443
    \u0431\u044B\u043B\u043E 62 \u0433\u043E\u0434\u0430. *   \u041E\u043D \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B
    \u0441\u0432\u043E\u044E \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u044C \u0438
    \u0443\u0433\u0430\u0441\u0430\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0435\u0439 \u0441
    \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u043D\u043D\u043E\u0439 \u043E\u0441\u0442\u0440\u043E\u0442\u043E\u0439.
    \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0441\u0442\u0430\u0440\u0435\u044E\u0442 \u0440\u0430\u043D\u044C\u0448\u0435
    \u0434\u0440\u0443\u0433\u0438\u0445 \u0443\u0447\u0435\u043D\u044B\u0445, \u0438
    \u0438\u0445 \u043B\u0443\u0447\u0448\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043F\u0440\u0438\u0445\u043E\u0434\u044F\u0442\u0441\u044F \u043D\u0430 \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u044C.
    *   \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u044D\u0442\u0443
    \u043A\u043D\u0438\u0433\u0443 \u043A\u0430\u043A \u043F\u0440\u043E\u0449\u0430\u043B\u044C\u043D\u043E\u0435
    \u043F\u0438\u0441\u044C\u043C\u043E, \u043F\u043E\u043B\u0430\u0433\u0430\u044F,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0431\u0443\u0434\u0435\u0442 \u0435\u0433\u043E
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u043C \u0441\u043B\u043E\u0432\u043E\u043C
    \u043F\u0435\u0440\u0435\u0434 \u0443\u0445\u043E\u0434\u043E\u043C \u0438\u0437
    \u0436\u0438\u0437\u043D\u0438 (\u0445\u043E\u0442\u044F \u043E\u043D \u043F\u0440\u043E\u0436\u0438\u043B
    \u0435\u0449\u0435 7 \u043B\u0435\u0442). \u0418\u043C\u0435\u043D\u043D\u043E
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u043A\u043D\u0438\u0433\u0430 \u043F\u0440\u043E\u043D\u0438\u0437\u0430\u043D\u0430
    \u0442\u0430\u043A\u0438\u043C \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C
    \u043F\u0435\u0441\u0441\u0438\u043C\u0438\u0437\u043C\u043E\u043C \u0438 \u043C\u0435\u043B\u0430\u043D\u0445\u043E\u043B\u0438\u0435\u0439.
    \u041E\u043D \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u043B \u0441\u0435\u0431\u044F
    \u0441\u043E \u0441\u0442\u0430\u0440\u0435\u044E\u0449\u0438\u043C \u0441\u043F\u043E\u0440\u0442\u0441\u043C\u0435\u043D\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0443\u0436\u0435 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
    \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u043B\u0443\u0447\u0448\u0438\u0439
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442.  ### 7. \U0001F4BC \u041F\u0435\u0434\u0430\u043D\u0442\u0438\u0437\u043C
    \u0432 \u0440\u0430\u0441\u043F\u0438\u0441\u0430\u043D\u0438\u0438 \u0425\u0430\u0440\u0434\u0438
    \u0431\u044B\u043B \u043E\u0434\u0435\u0440\u0436\u0438\u043C \u0440\u0430\u0441\u043F\u043E\u0440\u044F\u0434\u043A\u043E\u043C
    \u0434\u043D\u044F. *   \u041E\u043D \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u043D\u043E\u0441\u0438\u043B \u0447\u0430\u0441\u043E\u0432, \u043D\u043E
    \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u0437\u043D\u0430\u043B \u0432\u0440\u0435\u043C\u044F
    \u0441 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E \u0434\u043E \u043C\u0438\u043D\u0443\u0442\u044B
    \u043F\u043E \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044E \u0441\u0432\u043E\u0435\u0433\u043E
    \u0442\u0435\u043B\u0430 \u0438 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u043C
    \u043E\u0449\u0443\u0449\u0435\u043D\u0438\u044F\u043C. \u0413\u043E\u0432\u043E\u0440\u044F\u0442,
    \u043E\u043D \u043C\u043E\u0433 \u0441\u043A\u0430\u0437\u0430\u0442\u044C \u043A\u043E\u043B\u043B\u0435\u0433\u0435:
    \xAB\u0421\u0435\u0439\u0447\u0430\u0441 \u0440\u043E\u0432\u043D\u043E 3:15\xBB,
    \u2014 \u0438 \u0447\u0430\u0441\u044B \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B\u0438
    \u044D\u0442\u043E. *   \u041E\u043D \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u0442\u0435\u043B\u0435\u0444\u043E\u043D\u043E\u043C, \u0441\u0447\u0438\u0442\u0430\u044F
    \u044D\u0442\u043E \u0432\u0442\u043E\u0440\u0436\u0435\u043D\u0438\u0435\u043C
    \u0432 \u043B\u0438\u0447\u043D\u043E\u0435 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E.
    \u0412\u0441\u044E \u0441\u0432\u043E\u044E \u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0446\u0438\u044E
    \u043E\u043D \u0432\u0435\u043B \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0447\u0435\u0440\u0435\u0437 \u043F\u0438\u0441\u044C\u043C\u0430 \u0438 \u0437\u0430\u043F\u0438\u0441\u043A\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u0435\u0440\u0435\u0434\u0430\u0432\u0430\u043B
    \u0447\u0435\u0440\u0435\u0437 \u0441\u043B\u0443\u0433 \u0438\u043B\u0438 \u043A\u043E\u043B\u043B\u0435\u0433. 
    ### 8. \U0001F3AF \u041F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u0430\u044F
    \u0431\u0435\u0441\u043F\u043E\u043B\u0435\u0437\u043D\u043E\u0441\u0442\u044C
    \u0425\u0430\u0440\u0434\u0438 \u0433\u043E\u0440\u0434\u0438\u043B\u0441\u044F
    \u0442\u0435\u043C, \u0447\u0442\u043E \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E \u0431\u0435\u0441\u043F\u043E\u043B\u0435\u0437\u043D\u0430
    \u0434\u043B\u044F \u0432\u043E\u0435\u043D\u043D\u044B\u0445 \u0438 \u043F\u0440\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u044B\u0445
    \u043D\u0443\u0436\u0434. *   \u041A\u043E\u0433\u0434\u0430 \u0432 \u041F\u0435\u0440\u0432\u0443\u044E
    \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0432\u043E\u0439\u043D\u0443 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u041B\u044E\u0434\u0432\u0438\u0433
    \u041F\u0440\u0430\u043D\u0434\u0442\u043B\u044C \u043D\u0430\u0447\u0430\u043B
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u043D\u0430 \u0432\u043E\u0435\u043D\u043D\u0443\u044E
    \u0430\u0432\u0438\u0430\u0446\u0438\u044E, \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B
    \u0432 \u0443\u0436\u0430\u0441\u0435. \u041E\u043D \u0440\u0430\u0434\u043E\u0432\u0430\u043B\u0441\u044F,
    \u0447\u0442\u043E \u0442\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B
    \u043D\u0435\u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043C\u0430 \u0432 \u0431\u0430\u043B\u043B\u0438\u0441\u0442\u0438\u043A\u0435.
    *   \u0410\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u044B\u043C \u0443\u0434\u0430\u0440\u043E\u043C
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0441\u0442\u0430\u043B\u043E \u0442\u043E,
    \u0447\u0442\u043E \u0432 \u0433\u043E\u0434\u044B \u0412\u0442\u043E\u0440\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B \u0435\u0433\u043E
    \u043B\u044E\u0431\u0438\u043C\u0443\u044E \xAB\u0447\u0438\u0441\u0442\u0443\u044E\xBB
    \u0442\u0435\u043E\u0440\u0438\u044E \u0447\u0438\u0441\u0435\u043B \u043D\u0430\u0447\u0430\u043B\u0438
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C \u0434\u043B\u044F \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    (\u0432\u0437\u043B\u043E\u043C \u043A\u043E\u0434\u0430 \xAB\u042D\u043D\u0438\u0433\u043C\u044B\xBB).
    \u0425\u043E\u0442\u044F \u0441\u0430\u043C \u043E\u043D \u043D\u0435 \u0438\u043C\u0435\u043B
    \u043A \u044D\u0442\u043E\u043C\u0443 \u043F\u0440\u044F\u043C\u043E\u0433\u043E
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F, \u0441\u0430\u043C \u0444\u0430\u043A\u0442
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0435\u0433\u043E \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0435
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F \u043F\u043E\u0448\u043B\u0438
    \u043D\u0430 \u043F\u043E\u043B\u044C\u0437\u0443 \u0432\u043E\u0435\u043D\u043D\u044B\u043C,
    \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B \u0435\u0433\u043E \u0432 \u043E\u0442\u0447\u0430\u044F\u043D\u0438\u0435. 
    ### 9. \U0001F393 \u0415\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0438
    \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u043C
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C,
    \u043D\u043E \u0434\u0435\u043B\u0430\u043B \u044D\u0442\u043E \u043D\u0430 \u0441\u0432\u043E\u0438\u0445
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445. *   \u041E\u043D \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B
    \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u0442\u044C \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0435
    \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u044B (\u0422\u0440\u0438\u043F\u043E\u0441),
    \u0441\u0447\u0438\u0442\u0430\u044F \u0438\u0445 \xAB\u043E\u0445\u043E\u0442\u043E\u0439
    \u043D\u0430 \u043A\u0440\u044B\u0441\xBB, \u043D\u043E \u043F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u043D \u0440\u0435\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u044F,
    \u0441\u0434\u0435\u043B\u0430\u0432 \u0435\u0435 \u0431\u043E\u043B\u0435\u0435
    \u0441\u0442\u0440\u043E\u0433\u043E\u0439. *   \u0421\u0440\u0435\u0434\u0438
    \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432 \u0431\u044B\u043B\u0430
    **\u041C\u044D\u0440\u0438 \u041A\u0430\u0440\u0442\u0440\u0430\u0439\u0442**
    \u2014 \u043E\u0434\u043D\u0430 \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u0436\u0435\u043D\u0449\u0438\u043D-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u0434\u043E\u0431\u0438\u0432\u0448\u0438\u0445\u0441\u044F \u043C\u0438\u0440\u043E\u0432\u043E\u0433\u043E
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u043E\u0437\u0436\u0435 \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439 \u2014 \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430. \u0425\u0430\u0440\u0434\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0441\u044F \u043A \u043D\u0435\u0439
    \u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435\u043C,
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E
    \u0432 \u0442\u0435 \u0433\u043E\u0434\u044B \u0436\u0435\u043D\u0449\u0438\u043D\u044B-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0431\u044B\u043B\u0438 \u0440\u0435\u0434\u043A\u043E\u0441\u0442\u044C\u044E. 
    ### 10. \U0001F4D6 \xAB\u0410\u043F\u043E\u043B\u043E\u0433\u0438\u044F\xBB \u2014
    \u0431\u0435\u0441\u0442\u0441\u0435\u043B\u043B\u0435\u0440 \u041C\u0430\u043B\u043E
    \u043A\u0442\u043E \u0437\u043D\u0430\u0435\u0442, \u0447\u0442\u043E \xAB\u0410\u043F\u043E\u043B\u043E\u0433\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\xBB \u0441\u0442\u0430\u043B\u0430
    \u0431\u0435\u0441\u0442\u0441\u0435\u043B\u043B\u0435\u0440\u043E\u043C \u043D\u0435
    \u0441\u0440\u0435\u0434\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u0430 \u0441\u0440\u0435\u0434\u0438 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u043E\u0440\u043E\u0432
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u0432. \u042D\u0442\u0430
    \u043A\u043D\u0438\u0433\u0430 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0431\u0440\u0430\u0437\u0446\u043E\u043C \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u0439
    \u043F\u0440\u043E\u0437\u044B XX \u0432\u0435\u043A\u0430. \u0415\u0435 \u0445\u0432\u0430\u043B\u0438\u043B\u0438
    \u0437\u0430 \u0441\u0442\u0438\u043B\u044C, \u0438\u0440\u043E\u043D\u0438\u044E
    \u0438 \u0447\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C. \u0421\u0430\u043C
    \u0425\u0430\u0440\u0434\u0438, \u0431\u0443\u0434\u0443\u0447\u0438 \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u043C,
    \u0431\u044B\u043B \u0431\u044B \u0443\u0434\u0438\u0432\u043B\u0435\u043D, \u0447\u0442\u043E
    \u0435\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435
    \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F \u0447\u0438\u0442\u0430\u044E\u0442
    \u043B\u044E\u0434\u0438, \u0434\u0430\u043B\u0435\u043A\u0438\u0435 \u043E\u0442
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u0432 \u0438 \u0440\u044F\u0434\u043E\u0432. 
    \u042D\u0442\u0430 \u043A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u044F \u0444\u0430\u043A\u0442\u043E\u0432
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442, \u0447\u0442\u043E
    \u0425\u0430\u0440\u0434\u0438 \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \xAB\u0441\u0443\u0445\u0438\u043C \u0443\u0447\u0435\u043D\u044B\u043C\xBB,
    \u0430 \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u044B\u043C,
    \u0438\u0440\u043E\u043D\u0438\u0447\u043D\u044B\u043C \u0438 \u0434\u043E \u043A\u0440\u0430\u0439\u043D\u043E\u0441\u0442\u0438
    \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u043E\u0436\u0438\u043B
    \u0441\u0432\u043E\u044E \u0436\u0438\u0437\u043D\u044C \u043F\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C,
    \u043E\u0447\u0435\u043D\u044C \u0441\u0442\u0440\u043E\u0433\u0438\u043C \u043F\u0440\u0430\u0432\u0438\u043B\u0430\u043C."
