  shortBioRu: "\u0413\u043E\u0301\u0434\u0444\u0440\u0438 \u0425\u0430\u0301\u0440\u043E\u043B\u0434
    \u0425\u0430\u0301\u0440\u0434\u0438\_\u2014 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0441\u0432\u043E\u0438\u043C\u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043C\u0438
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B \u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0430\u043D\u0430\u043B\u0438\u0437\u0435. \u0412 \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438
    \u043E\u043D \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0417\u0430\u043A\u043E\u043D\u043E\u043C
    \u0425\u0430\u0440\u0434\u0438\_\u2014 \u0412\u0430\u0439\u043D\u0431\u0435\u0440\u0433\u0430,
    \u044F\u0432\u043B\u044F\u044E\u0449\u0438\u043C\u0441\u044F \u0431\u0430\u0437\u043E\u0432\u044B\u043C
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u043E\u043C \u043F\u043E\u043F\u0443\u043B\u044F\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u0433\u0435\u043D\u0435\u0442\u0438\u043A\u0438. \u0412 \u0434\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u0435
    \u043A \u0435\u0433\u043E \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\u043C,
    \u0435\u0433\u043E \u043F\u043E\u043C\u043D\u044F\u0442 \u0437\u0430 \u0435\u0433\u043E
    \u044D\u0441\u0441\u0435 1940\_\u0433\u043E\u0434\u0430 \u043E\u0431 \u044D\u0441\u0442\u0435\u0442\u0438\u043A\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043F\u043E\u0434
    \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435\u043C \xAB\u0410\u043F\u043E\u043B\u043E\u0433\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\xBB. \u0425\u0430\u0440\u0434\u0438
    \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0421\u0440\u0438\u043D\u0438\u0432\u0430\u0441\u044B \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430."
