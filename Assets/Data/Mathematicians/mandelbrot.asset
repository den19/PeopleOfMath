    \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C \"\u043F\u043E\u043F-\u0430\u0440\u0442\u0430\"
    1970-\u0445 \u0438 1980-\u0445 \u0433\u043E\u0434\u043E\u0432. \u041E\u043D\u0438
    \u0443\u043A\u0440\u0430\u0448\u0430\u043B\u0438 \u0437\u0430\u0441\u0442\u0430\u0432\u043A\u0438
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u0432, \u0444\u0443\u0442\u0431\u043E\u043B\u043A\u0438
    \u0438 \u0434\u0430\u0436\u0435 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u043B\u0438
    \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u0439 \u0441\u043F\u0435\u0446\u044D\u0444\u0444\u0435\u043A\u0442\u043E\u0432
    \u0432 \u043A\u0438\u043D\u043E (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0434\u043B\u044F \"\u0417\u0432\u0451\u0437\u0434\u043D\u044B\u0445 \u0432\u043E\u0439\u043D\").
    *   **\u041A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u044B\u0439 \u0444\u0435\u043D\u043E\u043C\u0435\u043D:**
