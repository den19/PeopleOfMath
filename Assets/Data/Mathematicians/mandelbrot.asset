    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u0443\u044E \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0441\u0430\u043C\u043E\u043F\u043E\u0434\u043E\u0431\u0438\u0435 \u0433\u0440\u0430\u043D\u0438\u0446\u044B
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 . *   **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435:**
    \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C
