    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 . \u0418\u043C\u0435\u043D\u043D\u043E
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u0430\u044F \u0433\u0440\u0430\u0444\u0438\u043A\u0430
    \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u0430 \u0441\u043B\u043E\u0436\u043D\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u0432 **\u0437\u0430\u0432\u043E\u0440\u0430\u0436\u0438\u0432\u0430\u044E\u0449\u0443\u044E
