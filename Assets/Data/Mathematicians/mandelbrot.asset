    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0440\u0430\u0431\u043E\u0442
    \u043F\u043E \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0435 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0441\u0442\u0438, \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0445
    \u0435\u0449\u0435 \u0432 1960-\u0445 \u0433\u043E\u0434\u0430\u0445 \u0438 \u0441\u0442\u0430\u0432\u0448\u0438\u0445
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F \u043C\u043D\u043E\u0433\u0438\u0445
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0445
    \u0442\u0435\u043E\u0440\u0438\u0439 .  ### \U0001F3DB\uFE0F \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0438 \u0432\u043B\u0438\u044F\u043D\u0438\u0435  \u0417\u0430 \u0441\u0432\u043E\u0438
    \u0440\u0430\u0431\u043E\u0442\u044B \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0432\u044B\u0441\u0448\u0435\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435. \u041E\u043D \u0431\u044B\u043B
    \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D **\u041F\u0440\u0435\u043C\u0438\u0438
    \u0412\u043E\u043B\u044C\u0444\u0430 \u043F\u043E \u0444\u0438\u0437\u0438\u043A\u0435**
    (1993) \u0438 **\u041F\u0440\u0435\u043C\u0438\u0438 \u042F\u043F\u043E\u043D\u0438\u0438**
    (2003) . \u0415\u0433\u043E \u0438\u0434\u0435\u0438 \u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u043D\u043E \u0438 \u043D\u0430 \u0444\u0438\u0437\u0438\u043A\u0443, \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u044E,
    \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0443, \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u0443\u044E
    \u0433\u0440\u0430\u0444\u0438\u043A\u0443 \u0438 \u0434\u0430\u0436\u0435 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E.
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0437\u0430
    \u0432\u043D\u0435\u0448\u043D\u0438\u043C \u0445\u0430\u043E\u0441\u043E\u043C
    \u043F\u0440\u0438\u0440\u043E\u0434\u044B \u0441\u0442\u043E\u0438\u0442 \u0441\u0442\u0440\u043E\u0433\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u043E\u0440\u044F\u0434\u043E\u043A, \u0430 \u0434\u043B\u044F \u0435\u0433\u043E
    \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u043D\u0443\u0436\u0435\u043D
    \u043D\u043E\u0432\u044B\u0439 \u044F\u0437\u044B\u043A \u2014 \u044F\u0437\u044B\u043A
    \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u043E\u0432."
  achievementsEn: 
  personalLifeRu: "\u0411\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u0411\u0435\u043D\u0443\u0430
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430 \u2014
    \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u043E\u0448\u0451\u043B
    \u0447\u0435\u0440\u0435\u0437 \u0442\u044F\u0436\u0435\u043B\u0435\u0439\u0448\u0438\u0435
    \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u044F, \u0447\u0442\u043E\u0431\u044B
    \u0432 \u0438\u0442\u043E\u0433\u0435 \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C
    \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u043A\u0430\u0440\u0442\u0438\u043D\u0443
    \u043C\u0438\u0440\u0430, \u043E\u0441\u0442\u0430\u0432\u0430\u044F\u0441\u044C
    \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u0432\u043E\u043B\u044C\u043D\u043E\u0434\u0443\u043C\u0446\u0435\u043C
    \u0438 \u0431\u0443\u043D\u0442\u0430\u0440\u0451\u043C.  ### \U0001F9EC \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0441\u0435\u043C\u044C\u044F. \u0412\u043B\u0438\u044F\u043D\u0438\u0435
    \u0434\u044F\u0434\u0438-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 
    \u0411\u0435\u043D\u0443\u0430 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **20 \u043D\u043E\u044F\u0431\u0440\u044F
    1924 \u0433\u043E\u0434\u0430 \u0432 \u0412\u0430\u0440\u0448\u0430\u0432\u0435,
    \u041F\u043E\u043B\u044C\u0448\u0430**. \u0415\u0433\u043E \u0441\u0435\u043C\u044C\u044F
    \u0431\u044B\u043B\u0430 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0439,
    \u0440\u043E\u0434\u043E\u043C \u0438\u0437 \u041B\u0438\u0442\u0432\u044B. \u041E\u0442\u0435\u0446,
    \u041A\u0430\u0440\u043B \u0421\u043E\u043B\u043E\u043C\u043E\u043D\u043E\u0432\u0438\u0447
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0439\u0442, \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0442\u043E\u0440\u0433\u043E\u0432\u043B\u0435\u0439 \u043E\u0434\u0435\u0436\u0434\u043E\u0439,
    \u0430 \u043C\u0430\u0442\u044C, \u0411\u0435\u043B\u043B\u0430 \u041B\u0443\u0440\u044C\u0435,
    \u0431\u044B\u043B\u0430 \u0432\u0440\u0430\u0447\u043E\u043C.  \u041E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0435\u0433\u043E \u0441\u0443\u0434\u044C\u0431\u0443
    \u0438 \u043C\u0438\u0440\u043E\u0432\u043E\u0437\u0437\u0440\u0435\u043D\u0438\u0435
    \u043E\u043A\u0430\u0437\u0430\u043B \u0434\u044F\u0434\u044F, **\u0428\u043E\u043B\u0435\u043C
    (\u0421\u043E\u043B\u0435\u043C) \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0439\u0442**
    \u2014 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0433\u0440\u0443\u043F\u043F\u044B \xAB\u041D\u0438\u043A\u043E\u043B\u044F
    \u0411\u0443\u0440\u0431\u0430\u043A\u0438\xBB, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u0440\u043E\u043F\u0430\u0433\u0430\u043D\u0434\u0438\u0440\u043E\u0432\u0430\u043B\u0430
    \u0441\u0442\u0440\u043E\u0433\u0443\u044E, \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u0443\u044E
    \u0438 \u043B\u0438\u0448\u0451\u043D\u043D\u0443\u044E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043D\u0430\u0433\u043B\u044F\u0434\u043D\u043E\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0434\u044F\u0434\u044F \u0432\u0437\u044F\u043B
    \u043D\u0430 \u0441\u0435\u0431\u044F \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435
    \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u043A\u0430, \u043D\u043E \u043F\u0440\u0438\u0432\u0438\u0432\u0430\u043B
    \u0435\u043C\u0443 \u0441\u0443\u0433\u0443\u0431\u043E \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0435
    \u0432\u0438\u0434\u0435\u043D\u0438\u0435, \u0447\u0442\u043E \u0432 \u0438\u0442\u043E\u0433\u0435
    \u0441\u043F\u0440\u043E\u0432\u043E\u0446\u0438\u0440\u043E\u0432\u0430\u043B\u043E
    \u0443 \u0411\u0435\u043D\u0443\u0430 \u043E\u0431\u0440\u0430\u0442\u043D\u0443\u044E
    \u0440\u0435\u0430\u043A\u0446\u0438\u044E \u0438 \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043C\u0435\u0442\u043E\u0434\u0430\u043C.  ### \U0001F468\u200D\U0001F469\u200D\U0001F466
    \u0414\u0435\u0442\u0441\u0442\u0432\u043E, \u0432\u043E\u0439\u043D\u0430 \u0438
    \u043F\u043E\u0431\u0435\u0433 \u043E\u0442 \u043D\u0430\u0446\u0438\u0441\u0442\u043E\u0432 
    \u0412 1936 \u0433\u043E\u0434\u0443, \u043F\u0440\u0435\u0434\u0432\u0438\u0434\u044F
    \u0443\u0433\u0440\u043E\u0437\u0443 \u0441\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u044B
    \u043D\u0430\u0446\u0438\u0441\u0442\u0441\u043A\u043E\u0439 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438,
    \u0441\u0435\u043C\u044C\u044F \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u0430
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E \u0438 \u043F\u043E\u0441\u0435\u043B\u0438\u043B\u0430\u0441\u044C
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435. \u0421 \u043D\u0430\u0447\u0430\u043B\u043E\u043C
    \u0412\u0442\u043E\u0440\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u0438 \u043E\u043A\u043A\u0443\u043F\u0430\u0446\u0438\u0435\u0439
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u044B
    \u0431\u0435\u0436\u0430\u043B\u0438 \u043D\u0430 \u044E\u0433 \u0441\u0442\u0440\u0430\u043D\u044B,
    \u0432 \u0433\u043E\u0440\u043E\u0434\u043E\u043A **\u0422\u044E\u043B\u044C**.
    \u0422\u0430\u043C \u0436\u0438\u0437\u043D\u044C \u0441\u0435\u043C\u044C\u0438
    \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u0430 \u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0435\u0439,
    \u0438 \u0411\u0435\u043D\u0443\u0430 \u043D\u0435 \u0440\u0430\u0437 \u0431\u044B\u043B
    \u043D\u0430 \u0432\u043E\u043B\u043E\u0441\u043E\u043A \u043E\u0442 \u0433\u0438\u0431\u0435\u043B\u0438.
    \u0415\u0433\u043E \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0431\u044B\u043B\u043E
    \u043F\u0440\u0435\u0440\u0432\u0430\u043D\u043E, \u0438 \u043E\u043D \u0447\u0430\u0441\u0442\u043E
    \u043F\u0435\u0440\u0435\u0431\u0438\u0432\u0430\u043B\u0441\u044F \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u043C\u0438
    \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u043A\u0430\u043C\u0438, \u0431\u044B\u043B
    \u043A\u043E\u043D\u044E\u0445\u043E\u043C \u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C
    \u0441\u043B\u0435\u0441\u0430\u0440\u044F.  \u041A\u0430\u043A \u043D\u0438
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u043E,
    \u0438\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u0438 \u0433\u043E\u0434\u044B
    \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u043D\u043E\u0433\u043E \u0441\u0430\u043C\u043E\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u0438 \u0435\u0433\u043E
    \u043A\u0430\u043A \u0443\u0447\u0451\u043D\u043E\u0433\u043E. \u041E\u043D \u043F\u043E\u0437\u0436\u0435
    \u0433\u043E\u0432\u043E\u0440\u0438\u043B, \u0447\u0442\u043E \u043D\u0435\u0440\u0435\u0433\u0443\u043B\u044F\u0440\u043D\u043E\u0435
    \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435 \u0434\u0430\u043B\u043E \u0435\u043C\u0443
    \u0441\u0432\u043E\u0431\u043E\u0434\u0443 \u043C\u044B\u0441\u043B\u0438\u0442\u044C
    \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u043E \u0438
    \u0440\u0430\u0437\u0432\u0438\u043B\u043E \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0435
    **\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435**. \u0421\u0432\u043E\u0439
    \u0434\u0430\u0440 \u043E\u043D \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u0443\u0436\u0435 \u0442\u043E\u0433\u0434\u0430, \u0440\u0435\u0448\u0430\u044F
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0441\u043F\u043E\u0441\u043E\u0431\u043E\u043C, \u0447\u0442\u043E \u0432\u044B\u0437\u044B\u0432\u0430\u043B\u043E
    \u0443\u0434\u0438\u0432\u043B\u0435\u043D\u0438\u0435 \u0443 \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439. 
    ### \U0001F393 \u0423\u0447\u0451\u0431\u0430: \u0411\u0443\u043D\u0442 \u043F\u0440\u043E\u0442\u0438\u0432
    \u0411\u0443\u0440\u0431\u0430\u043A\u0438 \u0438 \u043F\u0443\u0442\u044C \u0432
    \u043D\u0430\u0443\u043A\u0443  \u041F\u043E\u0441\u043B\u0435 \u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438 \u0432 1944 \u0433\u043E\u0434\u0443
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u041F\u0430\u0440\u0438\u0436. \u0415\u0433\u043E \u043F\u0443\u0442\u044C
    \u0432 \u0432\u044B\u0441\u0448\u0443\u044E \u043D\u0430\u0443\u043A\u0443 \u0431\u044B\u043B
    \u0442\u0435\u0440\u043D\u0438\u0441\u0442\u044B\u043C:  *   **\u041E\u0442\u043A\u0430\u0437
    \u043E\u0442 \u042D\u043A\u043E\u043B\u044C \u041D\u043E\u0440\u043C\u0430\u043B\u044C:**
    \u041F\u043E \u0441\u043E\u0432\u0435\u0442\u0443 \u0434\u044F\u0434\u0438 \u043E\u043D
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E
    \u0412\u044B\u0441\u0448\u0443\u044E \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 (\xC9cole Normale Sup\xE9rieure), \u043E\u043F\u043B\u043E\u0442
    \u0433\u0440\u0443\u043F\u043F\u044B \u0411\u0443\u0440\u0431\u0430\u043A\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u0432\u0448\u0438\u0441\u044C
    \u0432 \u0438\u0445 \u0434\u043E\u0433\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043F\u043E\u0434\u0445\u043E\u0434\u0435 \u0438 \u0432\u0440\u0430\u0436\u0434\u0435\u0431\u043D\u043E\u0441\u0442\u0438
    \u043A \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0411\u0435\u043D\u0443\u0430
    \u043F\u043E\u043A\u0438\u043D\u0443\u043B \u0435\u0451 **\u0432\u0441\u0435\u0433\u043E
    \u0447\u0435\u0440\u0435\u0437 \u043E\u0434\u0438\u043D \u0434\u0435\u043D\u044C**.
    \u041F\u043E\u0437\u0436\u0435 \u043E\u043D \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B\u0441\u044F,
    \u0447\u0442\u043E \u0434\u044F\u0434\u044F \u0441\u0430\u043C \u043F\u043E\u043C\u043E\u0433
    \u0435\u043C\u0443 \u043E\u0441\u043E\u0437\u043D\u0430\u0442\u044C, \u0447\u0442\u043E
    \"\u044D\u0442\u043E \u0432\u043E\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0433\u0440\u0443\u043F\u043F\u0430 \u0441 \u0441\u0438\u043B\u044C\u043D\u044B\u043C\u0438
    \u043F\u0440\u0435\u0434\u0440\u0430\u0441\u0441\u0443\u0434\u043A\u0430\u043C\u0438
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\".
    *   **\u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0448\u043A\u043E\u043B\u0430:** \u0412 1945\u20131947 \u0433\u043E\u0434\u0430\u0445
    \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0431\u043E\u043B\u0435\u0435
    \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u0443\u044E \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435, \u0433\u0434\u0435
    \u0443\u0447\u0438\u043B\u0441\u044F \u0443 \u0442\u0430\u043A\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u043A\u0430\u043A \u0413\u0430\u0441\u0442\u043E\u043D \u0416\u044E\u043B\u0438\u0430
    \u0438 \u041F\u043E\u043B\u044C \u041B\u0435\u0432\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u0441\u0438\u043B\u044C\u043D\u043E
    \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0438 \u043D\u0430 \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B. *   **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0432 \u0421\u0428\u0410 \u0438 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0430\u044F
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C:** \u0417\u0430\u0442\u0435\u043C
    \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432
    \u0421\u0428\u0410, \u043F\u043E\u043B\u0443\u0447\u0438\u0432 \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430 \u043F\u043E \u0430\u044D\u0440\u043E\u043D\u0430\u0432\u0442\u0438\u043A\u0435
    \u0432 **\u041A\u0430\u043B\u0438\u0444\u043E\u0440\u043D\u0438\u0439\u0441\u043A\u043E\u043C
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435** (1947\u20131949). \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E, \u0432 1952 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u0432 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. \u0415\u0433\u043E
    \u0442\u0435\u043C\u0430 \u0431\u044B\u043B\u0430 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u0430
    \u0434\u043B\u044F \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u2014 \u043E\u043D\u0430 \u043A\u0430\u0441\u0430\u043B\u0430\u0441\u044C \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u0447\u0430\u0441\u0442\u043E\u0442 \u0441\u043B\u043E\u0432 \u0432 \u044F\u0437\u044B\u043A\u0435
    (\u0437\u0430\u043A\u043E\u043D \u0426\u0438\u043F\u0444\u0430-\u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430). 
    ### \U0001F4BC \u0420\u0430\u0431\u043E\u0442\u0430 \u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438  \u041A\u0430\u0440\u044C\u0435\u0440\u0430
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B\u0430\u0441\u044C
    \u0432\u043D\u0435 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u044B\u0445
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0443\u0433\u043E\u0432, \u0447\u0442\u043E \u043F\u043E\u0440\u043E\u0439
    \u0432\u044B\u0437\u044B\u0432\u0430\u043B\u043E \u043D\u0435\u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0435: 
    *   **\u041D\u0430\u0443\u0447\u043D\u044B\u0439 \u0430\u0443\u0442\u0441\u0430\u0439\u0434\u0435\u0440:**
    \u041E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438,
    \u0432 \u0416\u0435\u043D\u0435\u0432\u0435 (\u0433\u0434\u0435 \u0432 **1955
    \u0433\u043E\u0434\u0443 \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430
    \u0410\u043B\u044C\u0435\u0442\u0442 \u041A\u0430\u0433\u0430\u043D** ) \u0438
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435, \u0433\u0434\u0435
    \u0431\u044B\u043B \u043F\u043E\u0441\u0442\u0434\u043E\u043A\u043E\u043C \u0443
    **\u0414\u0436\u043E\u043D\u0430 \u0444\u043E\u043D \u041D\u0435\u0439\u043C\u0430\u043D\u0430**.
    \u0415\u0433\u043E \u044D\u043A\u043B\u0435\u043A\u0442\u0438\u0447\u043D\u044B\u0435
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B \u043D\u0435 \u0432\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438\u0441\u044C
    \u0432 \u0440\u0430\u043C\u043A\u0438 \"\u0447\u0438\u0441\u0442\u043E\u0439\"
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. *   **\u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442
    \u0441 \u0434\u044F\u0434\u0435\u0439:** \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0434\u044F\u0434\u0435\u0439 \u0428\u043E\u043B\u0435\u043C\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E-\u043F\u0440\u0435\u0436\u043D\u0435\u043C\u0443
    \u0431\u044B\u043B \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C,
    \u0438\u0441\u043F\u043E\u0440\u0442\u0438\u043B\u0438\u0441\u044C. \u041A\u043E\u0433\u0434\u0430
    \u0411\u0435\u043D\u0443\u0430 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0442\u0435\u043C\u0443 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C
    \u0434\u044F\u0434\u0435 \"\u0435\u0440\u0443\u043D\u0434\u043E\u0439\", \u0442\u043E\u0442
    \u0432 \u0441\u0435\u0440\u0434\u0446\u0430\u0445 \u0432\u044B\u0443\u0434\u0438\u043B
    \u0438\u0437 \u043C\u0443\u0441\u043E\u0440\u043D\u043E\u0439 \u043A\u043E\u0440\u0437\u0438\u043D\u044B
    \u0438\u0441\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0435 \u043B\u0438\u0441\u0442\u044B
    \u0438 \u0441\u043A\u0430\u0437\u0430\u043B: \xAB\u042D\u0442\u043E \u0442\u0435\u0431\u0435,
    \u0442\u0435\u0431\u0435, \u0441\u0443\u0434\u044F \u043F\u043E \u0432\u0441\u0435\u043C\u0443,
    \u043F\u043E\u043D\u0440\u0430\u0432\u0438\u0442\u0441\u044F\xBB. \u0412 \u044D\u0442\u0438\u0445
    \u043B\u0438\u0441\u0442\u0430\u0445 \u043E\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C
    \u0438\u0434\u0435\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u0437\u0436\u0435
    \u043F\u0440\u0438\u0432\u0435\u043B\u0438 \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u043E\u0432.
    *   **\"\u0417\u043E\u043B\u043E\u0442\u043E\u0439 \u0432\u0435\u043A\" \u0432
    IBM:** \u0412 **1958 \u0433\u043E\u0434\u0443** \u043E\u043D \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0421\u0428\u0410 \u0438
    \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0432 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 **IBM \u0432 \u0419\u043E\u0440\u043A\u0442\u0430\u0443\u043D\u0435**.
    IBM \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430
    \u0435\u043C\u0443 \u043F\u043E\u0447\u0442\u0438 \u043F\u043E\u043B\u043D\u0443\u044E
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u0432\u043E\u0431\u043E\u0434\u0443, \u0447\u0442\u043E \u0431\u044B\u043B\u043E
    \u043D\u0435\u043C\u044B\u0441\u043B\u0438\u043C\u043E \u0434\u043B\u044F \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u041E\u043D
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u0432\u0441\u0451
    \u043F\u043E\u0434\u0440\u044F\u0434 \u2014 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0443,
    \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u043A\u0443, \u0442\u0443\u0440\u0431\u0443\u043B\u0435\u043D\u0442\u043D\u043E\u0441\u0442\u044C,
    \u2014 \u0438 \u0438\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C, \u0438\u043C\u0435\u044F
    \u0434\u043E\u0441\u0442\u0443\u043F \u043A \u043C\u043E\u0449\u043D\u044B\u043C
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u0430\u043C, \u043E\u043D
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0441\u0432\u043E\u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F. *   **\u041F\u043E\u0437\u0434\u043D\u0435\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435:** \u0412 1987 \u0433\u043E\u0434\u0443,
    \u043F\u043E\u0441\u043B\u0435 \u0443\u0445\u043E\u0434\u0430 \u0438\u0437 IBM,
    \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C
    \u0432 **\u0419\u0435\u043B\u044C\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435**,
    \u0438 \u043B\u0438\u0448\u044C \u0432 **1999 \u0433\u043E\u0434\u0443, \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 75 \u043B\u0435\u0442**, \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0432\u043E\u044E \u043F\u0435\u0440\u0432\u0443\u044E \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u2014 \u0421\u0442\u0435\u0440\u043B\u0438\u043D\u0433\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A.  ### \U0001F56F\uFE0F \u0421\u043C\u0435\u0440\u0442\u044C 
    \u0411\u0435\u043D\u0443\u0430 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F **14 \u043E\u043A\u0442\u044F\u0431\u0440\u044F
    2010 \u0433\u043E\u0434\u0430** \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435,
    \u0448\u0442\u0430\u0442 \u041C\u0430\u0441\u0441\u0430\u0447\u0443\u0441\u0435\u0442\u0441,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 85 \u043B\u0435\u0442
    \u043E\u0442 \u0440\u0430\u043A\u0430 \u043F\u043E\u0434\u0436\u0435\u043B\u0443\u0434\u043E\u0447\u043D\u043E\u0439
    \u0436\u0435\u043B\u0435\u0437\u044B."
  personalLifeEn: 
  shortBioRu: "**\u0411\u0435\u043D\u0443\u0430 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442
    (1924\u20132010)** \u2014 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439
    \u0438 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u0438\u0437\u043C\u0435\u043D\u0438\u043B
    \u043D\u0430\u0448\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043E \u0444\u043E\u0440\u043C\u0435 \u0438 \u0445\u0430\u043E\u0441\u0435,
    \u0441\u043E\u0437\u0434\u0430\u0432 \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E. \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C
    \u0438 \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0431\u044B\u043B\u0438 \u043D\u0435
    \u043C\u0435\u043D\u0435\u0435 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B,
    \u0447\u0435\u043C \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u0435 \u0438\u043C
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B, \u0438 \u043E\u043D \u0447\u0430\u0441\u0442\u043E
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F \"\u0447\u0443\u0434\u0430\u043A\u043E\u043C\"
    \u0432 \u0433\u043B\u0430\u0437\u0430\u0445 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0438\u0441\u0442\u0435\u0431\u043B\u0438\u0448\u043C\u0435\u043D\u0442\u0430. 
    ### \U0001F9EC \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u0441\u0435\u043C\u044C\u044F 
    \u0411\u0435\u043D\u0443\u0430 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **20 \u043D\u043E\u044F\u0431\u0440\u044F
    1924 \u0433\u043E\u0434\u0430** \u0432 \u0412\u0430\u0440\u0448\u0430\u0432\u0435,
    \u041F\u043E\u043B\u044C\u0448\u0430, \u0432 \u0441\u0435\u043C\u044C\u0435 \u043B\u0438\u0442\u043E\u0432\u0441\u043A\u0438\u0445
    \u0435\u0432\u0440\u0435\u0435\u0432.  *   **\u0421\u0435\u043C\u044C\u044F:**
    \u0415\u0433\u043E \u043C\u0430\u0442\u044C, \u0411\u0435\u043B\u043B\u0430 \u041B\u0443\u0440\u044C\u0435,
    \u0431\u044B\u043B\u0430 \u0432\u0440\u0430\u0447\u043E\u043C, \u0430 \u043E\u0442\u0435\u0446,
    \u041A\u0430\u0440\u043B \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442,
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0442\u043E\u0440\u0433\u043E\u0432\u043B\u0435\u0439
    \u043E\u0434\u0435\u0436\u0434\u043E\u0439. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043A\u043B\u044E\u0447\u0435\u0432\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0411\u0435\u043D\u0443\u0430 \u043E\u043A\u0430\u0437\u0430\u043B
    \u0435\u0433\u043E \u0434\u044F\u0434\u044F, **\u0428\u043E\u043B\u0435\u043C
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0439\u0442** \u2014
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u044B \"\u041D\u0438\u043A\u043E\u043B\u044F \u0411\u0443\u0440\u0431\u0430\u043A\u0438\".
    *   **\u041F\u0435\u0440\u0435\u0435\u0437\u0434 \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E:**
    \u0412 1936 \u0433\u043E\u0434\u0443, \u043F\u0440\u0435\u0434\u0432\u0438\u0434\u044F
    \u0443\u0433\u0440\u043E\u0437\u0443 \u0441\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u044B
    \u043D\u0430\u0446\u0438\u0441\u0442\u0441\u043A\u043E\u0439 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438,
    \u0441\u0435\u043C\u044C\u044F \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u0430
    \u0438\u0437 \u041F\u043E\u043B\u044C\u0448\u0438 \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E
    \u0438 \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435.  ### \U0001F9D1\u200D\U0001F393
    \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0438 \u0432\u043E\u0439\u043D\u0430 
    \u0412 \u0433\u043E\u0434\u044B \u0412\u0442\u043E\u0440\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u0436\u0438\u0437\u043D\u044C \u0441\u0435\u043C\u044C\u0438
    \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u043E \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430\u0441\u044C. 
    *   **\u0411\u0435\u0433\u0441\u0442\u0432\u043E \u043E\u0442 \u0432\u043E\u0439\u043D\u044B:**
    \u041F\u043E\u0441\u043B\u0435 \u043D\u0430\u0447\u0430\u043B\u0430 \u043E\u043A\u043A\u0443\u043F\u0430\u0446\u0438\u0438
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u044B \u0431\u0435\u0436\u0430\u043B\u0438
    \u043D\u0430 \u044E\u0433 \u0424\u0440\u0430\u043D\u0446\u0438\u0438, \u0432
    \u0433\u043E\u0440\u043E\u0434\u043E\u043A **\u0422\u044E\u043B\u044C**. \u0422\u0430\u043C
    \u0411\u0435\u043D\u0443\u0430 \u043F\u043E\u0448\u0435\u043B \u0432 \u0448\u043A\u043E\u043B\u0443,
    \u043D\u043E \u0435\u0433\u043E \u0443\u0441\u043F\u0435\u0445\u0438 \u0431\u044B\u043B\u0438
    \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u043C\u0438. \u0421\u043E\u043E\u0431\u0449\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043A 16 \u0433\u043E\u0434\u0430\u043C \u043E\u043D \u0435\u0434\u0432\u0430
    \u0437\u043D\u0430\u043B \u0430\u043B\u0444\u0430\u0432\u0438\u0442 \u0438 \u0442\u0430\u0431\u043B\u0438\u0446\u0443
    \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u044F \u0434\u043E \u043F\u044F\u0442\u0438.
    *   **\u041F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435:** \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u0438 \u0441 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u0443\u0447\u0435\u0431\u043E\u0439, \u0443 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0434\u0430\u0440, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043D\u0430 **\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
    \u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0438**. \u041E\u043D
    \u043C\u043E\u0433 \u0440\u0435\u0448\u0430\u0442\u044C \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0441\u043F\u043E\u0441\u043E\u0431\u043E\u043C, \u0447\u0442\u043E \u0431\u044B\u043B\u043E
    \u043E\u0447\u0435\u043D\u044C \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E.
    *   **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:** \u041F\u043E\u0441\u043B\u0435
    \u0432\u043E\u0439\u043D\u044B, \u0432 1945\u20131947 \u0433\u043E\u0434\u0430\u0445,
    \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E
    **\u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435**,
    \u0433\u0434\u0435 \u0443\u0447\u0438\u043B\u0441\u044F \u0443 \u0442\u0430\u043A\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u043A\u0430\u043A
    \u0413\u0430\u0441\u0442\u043E\u043D \u0416\u044E\u043B\u0438\u0430 \u0438 \u041F\u043E\u043B\u044C
    \u041B\u0435\u0432\u0438. \u0417\u0430\u0442\u0435\u043C \u043E\u043D \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u0421\u0428\u0410 \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430 \u043F\u043E \u0430\u044D\u0440\u043E\u043D\u0430\u0432\u0442\u0438\u043A\u0435
    \u0432 **\u041A\u0430\u043B\u0438\u0444\u043E\u0440\u043D\u0438\u0439\u0441\u043A\u043E\u043C
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435** (1947\u20131949). \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E, \u0432 1952 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u0432 **\u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435**. 
    ### \U0001F52C \u041F\u0443\u0442\u044C \u0432 \u043D\u0430\u0443\u043A\u0435:
    \u043E\u0442 \"\u0438\u0437\u0433\u043E\u044F\" \u0434\u043E \u043E\u0442\u0446\u0430
    \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u043E\u0432  \u0415\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B\u0430\u0441\u044C \u043D\u0435\u0442\u0440\u0438\u0432\u0438\u0430\u043B\u044C\u043D\u043E,
    \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u044F \u0433\u0440\u0430\u043D\u0438\u0446\u044B
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D.  *   **\u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u0441\u0435\u043C\u044C\u044F:** \u0421 1949
    \u043F\u043E 1958 \u0433\u043E\u0434 \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 (CNRS)
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438. \u0412 \u044D\u0442\u043E\u0442
    \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D \u043F\u0440\u043E\u0432\u0435\u043B
    \u0433\u043E\u0434 \u0432 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435
    \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0432
    \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435, \u0433\u0434\u0435 \u0435\u0433\u043E
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C \u0431\u044B\u043B
    **\u0414\u0436\u043E\u043D \u0444\u043E\u043D \u041D\u0435\u0439\u043C\u0430\u043D**.
    \u0412 1955 \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 **\u0410\u043B\u044C\u0435\u0442\u0442 \u041A\u0430\u0433\u0430\u043D**.
    *   **\u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u0439 \u043C\u043E\u043C\u0435\u043D\u0442:
    IBM (1958):** \u0412 1958 \u0433\u043E\u0434\u0443 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442
    \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u0421\u0428\u0410 \u0438 \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0443
    \u0432 **\u043D\u0430\u0443\u0447\u043D\u043E-\u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 IBM \u0432 \u0419\u043E\u0440\u043A\u0442\u0430\u0443\u043D\u0435**.
    IBM \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430
    \u0435\u043C\u0443 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u0435 \u0443\u0441\u043B\u043E\u0432\u0438\u044F:
    \u0434\u043E\u0441\u0442\u0443\u043F \u043A \u043C\u043E\u0449\u043D\u044B\u043C
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u0430\u043C \u0438 \u0441\u0432\u043E\u0431\u043E\u0434\u0443
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\u043C\u0438,
    \u0434\u0430\u043B\u0435\u043A\u043E \u0432\u044B\u0445\u043E\u0434\u044F\u0449\u0438\u043C\u0438
    \u0437\u0430 \u0440\u0430\u043C\u043A\u0438 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u0438.
    \u0412 IBM \u043E\u043D \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    35 \u043B\u0435\u0442, \u0441\u0442\u0430\u0432 IBM Fellow \u0432 1974 \u0433\u043E\u0434\u0443.
    *   **\u041C\u0435\u0436\u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0430\u0440\u043D\u043E\u0441\u0442\u044C:**
    \u0420\u0430\u0431\u043E\u0442\u0430\u044F \u0432 IBM, \u043E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u043A\u0443,
    \u0442\u0435\u043E\u0440\u0438\u044E \u0438\u0433\u0440, \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0443,
    \u0430\u044D\u0440\u043E\u043D\u0430\u0432\u0442\u0438\u043A\u0443, \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u044E,
    \u0444\u0438\u0437\u0438\u043E\u043B\u043E\u0433\u0438\u044E, \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044E
    \u0438 \u0444\u0438\u0437\u0438\u043A\u0443. \u0415\u0433\u043E \u043F\u043E\u0434\u0445\u043E\u0434
    \u0431\u044B\u043B \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u044B\u043C:
    \"\u042F \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u043C\u043E\u0438\u043C
    \u0438\u043D\u0441\u0442\u0438\u043D\u043A\u0442\u0430\u043C...\".  ### \U0001F4A1
    \u0413\u043B\u0430\u0432\u043D\u044B\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0438\u0434\u0435\u0438 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430
    \u0440\u043E\u0436\u0434\u0430\u043B\u0438\u0441\u044C \u043D\u0430 \u0441\u0442\u044B\u043A\u0435
    \u043D\u0430\u0443\u043A.  *   **\u042D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0430:**
    \u0418\u0437\u0443\u0447\u0430\u044F \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0443
    \u0446\u0435\u043D \u043D\u0430 \u0445\u043B\u043E\u043F\u043E\u043A \u0437\u0430
    100 \u043B\u0435\u0442, \u043E\u043D \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B,
    \u0447\u0442\u043E \u0438\u0445 \u0445\u0430\u043E\u0442\u0438\u0447\u043D\u044B\u0435
    \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u044F \u043F\u043E\u0434\u0447\u0438\u043D\u044F\u044E\u0442\u0441\u044F
    \u0441\u043A\u0440\u044B\u0442\u043E\u043C\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u043F\u043E\u0440\u044F\u0434\u043A\u0443, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0435 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u043C\u0438 \u043A\u0440\u0438\u0432\u044B\u043C\u0438.
    \u041E\u043D \u043D\u0430\u0448\u0435\u043B **\u0441\u0430\u043C\u043E\u043F\u043E\u0434\u043E\u0431\u0438\u0435**
    \u0432 \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u044F\u0445 \u0446\u0435\u043D,
    \u0441\u0434\u0435\u043B\u0430\u0432 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0432 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0435.
    *   **\u0412\u043E\u043F\u0440\u043E\u0441 \u043E \u0434\u043B\u0438\u043D\u0435
    \u0431\u0435\u0440\u0435\u0433\u043E\u0432\u043E\u0439 \u043B\u0438\u043D\u0438\u0438:**
    \u0412 1967 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0442\u0430\u0442\u044C\u044E *\"\u041A\u0430\u043A\u043E\u0432\u0430
    \u0434\u043B\u0438\u043D\u0430 \u043F\u043E\u0431\u0435\u0440\u0435\u0436\u044C\u044F
    \u0412\u0435\u043B\u0438\u043A\u043E\u0431\u0440\u0438\u0442\u0430\u043D\u0438\u0438?\"*,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u043B\u0430 \u043E\u0442\u043F\u0440\u0430\u0432\u043D\u043E\u0439
    \u0442\u043E\u0447\u043A\u043E\u0439 \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u0438.
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0434\u043B\u0438\u043D\u0430
    \u043F\u043E\u0431\u0435\u0440\u0435\u0436\u044C\u044F \u0437\u0430\u0432\u0438\u0441\u0438\u0442
    \u043E\u0442 \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u0430 \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F,
    \u0438 \u044D\u0442\u043E\u0442 \u0444\u0430\u043A\u0442 \u043C\u043E\u0436\u043D\u043E
    \u043E\u043F\u0438\u0441\u0430\u0442\u044C \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043D\u043E\u0432\u043E\u0433\u043E \u0442\u0438\u043F\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.
    *   **\u0422\u0435\u0440\u043C\u0438\u043D \"\u0424\u0440\u0430\u043A\u0442\u0430\u043B\":**
    \u0412 1975 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B
    \u0441\u043B\u043E\u0432\u043E **\"\u0444\u0440\u0430\u043A\u0442\u0430\u043B\"**
    (\u043E\u0442 \u043B\u0430\u0442. *fractus* \u2014 \"\u0441\u043B\u043E\u043C\u0430\u043D\u043D\u044B\u0439,
    \u0440\u0430\u0437\u0431\u0438\u0442\u044B\u0439\") \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0438\u0433\u0443\u0440, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u0431\u043B\u0430\u0434\u0430\u044E\u0442
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C **\u0441\u0430\u043C\u043E\u043F\u043E\u0434\u043E\u0431\u0438\u044F**
    (\u043A\u0430\u0436\u0434\u0430\u044F \u0447\u0430\u0441\u0442\u044C \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u0435\u0442
    \u0446\u0435\u043B\u043E\u0435). *   **\"\u0424\u0440\u0430\u043A\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u043F\u0440\u0438\u0440\u043E\u0434\u044B\"
    (1982):** \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u0430\u044F \u043A\u043D\u0438\u0433\u0430.
    \u041E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043D\u043E\u0432\u044B\u0439 \u0432\u0437\u0433\u043B\u044F\u0434 \u043D\u0430
    \u043F\u0440\u0438\u0440\u043E\u0434\u0443: \"\u041E\u0431\u043B\u0430\u043A\u0430
    \u2014 \u043D\u0435 \u0441\u0444\u0435\u0440\u044B, \u0433\u043E\u0440\u044B
    \u2014 \u043D\u0435 \u043A\u043E\u043D\u0443\u0441\u044B, \u0431\u0435\u0440\u0435\u0433\u043E\u0432\u044B\u0435
    \u043B\u0438\u043D\u0438\u0438 \u2014 \u043D\u0435 \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u0438...\",
    \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044F, \u0447\u0442\u043E \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u044B
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u0443\u0440\u044C\u0435\u0437\u044B, \u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430
    \u043C\u0438\u0440\u0430. *   **\u041C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430:** \u041D\u0430
    \u043E\u0441\u043D\u043E\u0432\u0435 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u0432
    IBM \u043E\u043D \u0432\u0438\u0437\u0443\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0442\u0435\u043F\u0435\u0440\u044C
    \u043D\u043E\u0441\u0438\u0442 \u0435\u0433\u043E \u0438\u043C\u044F. \u0425\u043E\u0442\u044F
    \u0435\u0433\u043E \u0438\u0437\u0443\u0447\u0430\u043B\u0438 \u0438 \u0434\u043E
    \u043D\u0435\u0433\u043E (\u041F\u044C\u0435\u0440 \u0424\u0430\u0442\u0443,
    \u0413\u0430\u0441\u0442\u043E\u043D \u0416\u044E\u043B\u0438\u0430), \u0438\u043C\u0435\u043D\u043D\u043E
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u043E\u0439 \u0433\u0440\u0430\u0444\u0438\u043A\u0438
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B \u0435\u0433\u043E \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0443\u044E
    \u043A\u0440\u0430\u0441\u043E\u0442\u0443 \u0438 \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C,
    \u0441\u0434\u0435\u043B\u0430\u0432 \u0435\u0433\u043E \u0441\u0430\u043C\u044B\u043C
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u043E\u043C
    \u0432 \u043C\u0438\u0440\u0435.  ### \U0001F3DB\uFE0F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u0412 1987 \u0433\u043E\u0434\u0443 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442
    \u0443\u0448\u0435\u043B \u0438\u0437 IBM \u0438 \u043D\u0430\u0447\u0430\u043B
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C \u0432 **\u0419\u0435\u043B\u044C\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435**, \u0433\u0434\u0435
    \u0432 1999 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    75 \u043B\u0435\u0442, \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0432\u043E\u044E
    \u043F\u0435\u0440\u0432\u0443\u044E \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u2014 \u0421\u0442\u0435\u0440\u043B\u0438\u043D\u0433\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A.  \u041E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043D\u0430\u0433\u0440\u0430\u0434,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u041F\u0440\u0435\u043C\u0438\u044E
    \u0412\u043E\u043B\u044C\u0444\u0430 \u043F\u043E \u0444\u0438\u0437\u0438\u043A\u0435
    (1993) \u0438 \u041F\u0440\u0435\u043C\u0438\u044E \u042F\u043F\u043E\u043D\u0438\u0438
    (2003). **\u0411\u0435\u043D\u0443\u0430 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 14 \u043E\u043A\u0442\u044F\u0431\u0440\u044F
    2010 \u0433\u043E\u0434\u0430** \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435,
    \u0448\u0442\u0430\u0442 \u041C\u0430\u0441\u0441\u0430\u0447\u0443\u0441\u0435\u0442\u0441,
    \u043E\u0442 \u0440\u0430\u043A\u0430 \u043F\u043E\u0434\u0436\u0435\u043B\u0443\u0434\u043E\u0447\u043D\u043E\u0439
    \u0436\u0435\u043B\u0435\u0437\u044B. \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E \u0442\u043E\u043C,
    \u043A\u0430\u043A \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u043E\u0435
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0435, \u0441\u043C\u0435\u043B\u043E\u0441\u0442\u044C
    \u0438 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0435 \u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u043C\u043E\u0433\u0443\u0442 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043E\u0442\u043A\u0440\u044B\u0442\u044C \u043D\u043E\u0432\u0443\u044E \u043E\u0431\u043B\u0430\u0441\u0442\u044C
    \u043D\u0430\u0443\u043A\u0438, \u043D\u043E \u0438 \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C
    \u043D\u0430\u0448\u0435 \u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u0435
    \u0432\u0441\u0435\u0433\u043E \u043E\u043A\u0440\u0443\u0436\u0430\u044E\u0449\u0435\u0433\u043E
    \u043C\u0438\u0440\u0430."
  shortBioEn: 
  interestingFactsRu: "\u0411\u0435\u043D\u0443\u0430 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u043D\u043E
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043F\u043E\u043B\u043D\u044B\u043C
    \u0437\u0430\u0433\u0430\u0434\u043E\u043A \u0438 \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u0445
    \u0447\u0435\u0440\u0442. \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u0438
    \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u043E \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445,
    \u0430 \u043F\u043E\u0440\u043E\u0439 \u0438 \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439.  ### \U0001F9E9 \"\u0424\u0440\u0430\u043A\u0442\u0430\u043B\u044C\u043D\u043E\u0435\"
    \u0438\u043C\u044F: \u0421\u0435\u043A\u0440\u0435\u0442 \u0431\u0443\u043A\u0432\u044B
    \"\u0411\"  \u041F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u044B\u0439
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043A\u0443\u0440\u044C\u0451\u0437
    \u0441\u0432\u044F\u0437\u0430\u043D \u0441 \u0435\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C.
    \u041F\u043E\u043B\u043D\u043E\u0435 \u0438\u043C\u044F \u0443\u0447\u0451\u043D\u043E\u0433\u043E
    \u2014 **\u0411\u0435\u043D\u0443\u0430 \u0411. \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442**.
    \u0418\u043D\u0438\u0446\u0438\u0430\u043B \"\u0411.\" \u0432 \u0435\u0433\u043E
    \u0438\u043C\u0435\u043D\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043D
    \u0441\u0430\u043C \u0434\u043E\u0431\u0430\u0432\u0438\u043B, \u043D\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0441\u043E\u043A\u0440\u0430\u0449\u0435\u043D\u0438\u0435\u043C \u043A\u0430\u043A\u043E\u0433\u043E-\u043B\u0438\u0431\u043E
    \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0433\u043E \u0438\u043C\u0435\u043D\u0438. 
    \u042D\u0442\u043E \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0448\u0443\u0442\u043A\u0443, \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E
    \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u0443\u044E\u0449\u0443\u044E
    \u0441\u0443\u0442\u044C \u0435\u0433\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F.
    \u041D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441 \"\u0427\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442
    \u0441\u0440\u0435\u0434\u043D\u044F\u044F \u0431\u0443\u043A\u0432\u0430 \xAB\u0411\xBB
    \u0432 \u0438\u043C\u0435\u043D\u0438 \u0411\u0435\u043D\u0443\u0430 \u0411.
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430?\" \u0441\u043B\u0435\u0434\u0443\u0435\u0442
    \u043E\u0442\u0432\u0435\u0442: \"\u0411\u0435\u043D\u0443\u0430 \u0411. \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\".
    \u0422\u0430\u043A \u0435\u0433\u043E \u0438\u043C\u044F \u0441\u0442\u0430\u043B\u043E
    **\u0440\u0435\u043A\u0443\u0440\u0441\u0438\u0432\u043D\u044B\u043C \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u043E\u043C**:
    \u0447\u0430\u0441\u0442\u044C \u0438\u043C\u0435\u043D\u0438 (\"\u0411.\") \u043E\u0442\u0441\u044B\u043B\u0430\u0435\u0442
    \u043A \u0446\u0435\u043B\u043E\u043C\u0443, \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u044F
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u0443\u044E \u043F\u0435\u0442\u043B\u044E
    \u0441\u0430\u043C\u043E\u043F\u043E\u0434\u043E\u0431\u0438\u044F.  ### \U0001F9E0
    \u042D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u0435
    \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0438 \u0438 \"\u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0435
    \u0445\u0443\u043B\u0438\u0433\u0430\u043D\u0441\u0442\u0432\u043E\"  \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442
    \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0438\u043C
    \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u043C
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0435\u043C \u0438 \u043D\u0435\u0443\u0441\u0442\u0443\u043F\u0447\u0438\u0432\u044B\u043C
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C.  *   **\u0411\u043E\u0440\u0435\u0446
    \u0441 \u043F\u0440\u0430\u0432\u0438\u043B\u0430\u043C\u0438:** \u041E\u043D
    \u0442\u0435\u0440\u043F\u0435\u0442\u044C \u043D\u0435 \u043C\u043E\u0433 \u0443\u0437\u043A\u0443\u044E
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u044E
    \u0438 \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0432\u043E\u0438\u043C \u0438\u043D\u0441\u0442\u0438\u043D\u043A\u0442\u0430\u043C.
    \u041E\u043D \u043C\u043E\u0433 \u0431\u0440\u043E\u0441\u0438\u0442\u044C \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u043D\u0430 \u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0435, \u0447\u0442\u043E\u0431\u044B
    \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u0442\u044C\u0441\u044F \u0432 \u043D\u043E\u0432\u0443\u044E
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C, \u0433\u0434\u0435 \u043E\u043D \u043D\u0438\u0447\u0435\u0433\u043E
    \u043D\u0435 \u0437\u043D\u0430\u043B. \u0415\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u0447\u0430\u0441\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438
    \u0435\u043C\u0443: \"\u041E\u0441\u0442\u0435\u043F\u0435\u043D\u0438\u0441\u044C,
    \u043E\u0441\u0442\u0430\u0432\u0430\u0439\u0441\u044F \u0432 \u043E\u0434\u043D\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438\", \u043D\u043E \u043E\u043D \u0431\u044B\u043B
    \u043F\u0440\u043E\u0441\u0442\u043E \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0438\u0442\u044C \u043E\u0442 \u043E\u0434\u043D\u043E\u0433\u043E
    \u043A \u0434\u0440\u0443\u0433\u043E\u043C\u0443. *   **\u041D\u0435\u0443\u0434\u043E\u0431\u043D\u044B\u0439
    \u043F\u0430\u0441\u0441\u0430\u0436\u0438\u0440:** \u041E\u0434\u043D\u0430\u0436\u0434\u044B,
    \u043D\u0430\u0445\u043E\u0434\u044F\u0441\u044C \u0432 \u0442\u0430\u043A\u0441\u0438
    \u0432 \u041C\u0430\u043D\u0445\u044D\u0442\u0442\u0435\u043D\u0435, \u043E\u043D
    \u043F\u0440\u0438\u043D\u044F\u043B\u0441\u044F \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u0442\u044C
