  achievementsRu: "\u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0411\u0435\u043D\u0443\u0430 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043D\u043E\u0432\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0430 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439 \u043F\u0435\u0440\u0435\u0441\u043C\u043E\u0442\u0440
    \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442 \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u0439
    \u043C\u0438\u0440. \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u043C\u043E\u0436\u043D\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0432\u0437\u0430\u0438\u043C\u043E\u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u0445
    \u0438\u0434\u0435\u0439.  ### \U0001F9EC \"\u0424\u0440\u0430\u043A\u0442\u0430\u043B\":
    \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u043D\u043E\u0432\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430 \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u043F\u0440\u0438\u0440\u043E\u0434\u044B  \u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430
    \u2014 \u0432\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0438 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0430\u0446\u0438\u044F
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F **\u0444\u0440\u0430\u043A\u0442\u0430\u043B**
    \u0432 1975 \u0433\u043E\u0434\u0443 .  *   **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0442\u0435\u0440\u043C\u0438\u043D\u0430 \u0438 \u0435\u0433\u043E \u0441\u0443\u0442\u044C:**
    \u0422\u0435\u0440\u043C\u0438\u043D \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D
    \u043E\u0442 \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u043E\u0433\u043E \u043F\u0440\u0438\u043B\u0430\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    *fractus* (\xAB\u0441\u043B\u043E\u043C\u0430\u043D\u043D\u044B\u0439, \u0440\u0430\u0437\u0431\u0438\u0442\u044B\u0439\xBB),
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u043E\u0433\u043E \u043E\u0442
    \u0433\u043B\u0430\u0433\u043E\u043B\u0430 *frangere* (\xAB\u043B\u043E\u043C\u0430\u0442\u044C\xBB).
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442 \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u0438\u0432\u0430\u043B,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0441\u043B\u043E\u0432\u043E \u0434\u043E\u043B\u0436\u043D\u043E
    \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0430\u0442\u044C \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \xAB\u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0441\u0442\u044C\xBB,
    \u043D\u043E \u0438 **\xAB\u043D\u0435\u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0444\u043E\u0440\u043C\u044B\xBB** . \u041A\u043B\u044E\u0447\u0435\u0432\u043E\u0435
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u0430
    \u2014 **\u0441\u0430\u043C\u043E\u043F\u043E\u0434\u043E\u0431\u0438\u0435**:
    \u043E\u0434\u043D\u0430 \u0438 \u0442\u0430 \u0436\u0435 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430
    \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u0435\u0442\u0441\u044F \u0432 \u0440\u0430\u0437\u043D\u044B\u0445
    \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u0430\u0445 . *   **\u0421\u043C\u0435\u043D\u0430
    \u043F\u0430\u0440\u0430\u0434\u0438\u0433\u043C\u044B:** \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442
    \u0431\u0440\u043E\u0441\u0438\u043B \u0432\u044B\u0437\u043E\u0432 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F, \u043F\u043E \u0435\u0433\u043E \u043C\u043D\u0435\u043D\u0438\u044E,
    \u043D\u0435 \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0442 \u0434\u043B\u044F
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F \u043F\u0440\u0438\u0440\u043E\u0434\u044B.
    \u0415\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u0444\u0440\u0430\u0437\u0430: **\xAB\u041E\u0431\u043B\u0430\u043A\u0430 \u2014
    \u043D\u0435 \u0441\u0444\u0435\u0440\u044B, \u0433\u043E\u0440\u044B \u2014
    \u043D\u0435 \u043A\u043E\u043D\u0443\u0441\u044B, \u0431\u0435\u0440\u0435\u0433\u043E\u0432\u044B\u0435
    \u043B\u0438\u043D\u0438\u0438 \u2014 \u043D\u0435 \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u0438...\xBB**
    \u0441\u0442\u0430\u043B\u0430 \u043C\u0430\u043D\u0438\u0444\u0435\u0441\u0442\u043E\u043C
    \u043D\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    . \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \u0448\u0435\u0440\u043E\u0445\u043E\u0432\u0430\u0442\u043E\u0441\u0442\u044C,
    \u0438\u0437\u0440\u0435\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u044C \u0438
    \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0441\u0442\u044C
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0435
    \u0434\u0435\u0444\u0435\u043A\u0442\u044B, \u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u043F\u0440\u0438\u0440\u043E\u0434\u043D\u044B\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432 .  ### \U0001F4D0 \"\u0414\u043B\u0438\u043D\u0430
    \u0431\u0435\u0440\u0435\u0433\u043E\u0432\u043E\u0439 \u043B\u0438\u043D\u0438\u0438\"
    \u0438 \u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C 
    \u041E\u0434\u043D\u0438\u043C \u0438\u0437 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u0432, \u043F\u0440\u0438\u0432\u0435\u0434\u0448\u0438\u0445
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430 \u043A
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u0442\u0435\u043E\u0440\u0438\u0438,
    \u0441\u0442\u0430\u043B\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u043D\u0430\u0434,
    \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C \u0431\u044B, \u043F\u0440\u043E\u0441\u0442\u044B\u043C
    \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u043C.  *   **\u041F\u0440\u043E\u0431\u043B\u0435\u043C\u0430:**
    \u0412 1967 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0442\u0430\u0442\u044C\u044E \xAB\u041A\u0430\u043A\u043E\u0432\u0430
    \u0434\u043B\u0438\u043D\u0430 \u043F\u043E\u0431\u0435\u0440\u0435\u0436\u044C\u044F
    \u0412\u0435\u043B\u0438\u043A\u043E\u0431\u0440\u0438\u0442\u0430\u043D\u0438\u0438?\xBB.
    \u041E\u0442\u0432\u0435\u0442 \u0431\u044B\u043B \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u0435\u043D:
    **\u0434\u043B\u0438\u043D\u0430 \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u043E\u0442
    \u0442\u043E\u0433\u043E, \u043A\u0430\u043A\u043E\u0439 \u043B\u0438\u043D\u0435\u0439\u043A\u043E\u0439
    \u0432\u044B \u0438\u0437\u043C\u0435\u0440\u044F\u0435\u0442\u0435**. \u0427\u0435\u043C
    \u043C\u0435\u043D\u044C\u0448\u0435 \u043C\u0430\u0441\u0448\u0442\u0430\u0431,
    \u0442\u0435\u043C \u0431\u043E\u043B\u044C\u0448\u0435 \u0434\u0435\u0442\u0430\u043B\u0435\u0439
    (\u0431\u0443\u0445\u0442, \u043C\u044B\u0441\u043E\u0432, \u043A\u0430\u043C\u043D\u0435\u0439)
    \u0432\u044B \u0443\u0447\u0438\u0442\u044B\u0432\u0430\u0435\u0442\u0435 \u0438
    \u0442\u0435\u043C \u0434\u043B\u0438\u043D\u043D\u0435\u0435 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
    \u0431\u0435\u0440\u0435\u0433\u043E\u0432\u0430\u044F \u043B\u0438\u043D\u0438\u044F,
    \u0441\u0442\u0440\u0435\u043C\u044F\u0441\u044C \u043A \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438
    . *   **\u0420\u0435\u0448\u0435\u043D\u0438\u0435 \u0447\u0435\u0440\u0435\u0437
    \u0434\u0440\u043E\u0431\u043D\u0443\u044E \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C:**
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442 \u0440\u0430\u0437\u0432\u0438\u043B
    \u0438\u0434\u0435\u0438 \u041B\u044C\u044E\u0438\u0441\u0430 \u0424\u0440\u0430\u044F
    \u0420\u0438\u0447\u0430\u0440\u0434\u0441\u043E\u043D\u0430 \u0438 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0438\u0437\u043C\u0435\u0440\u044F\u0442\u044C \u043D\u0435 \u0434\u043B\u0438\u043D\u0443,
    \u0430 **\u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C**
    \u0442\u0430\u043A\u0438\u0445 \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432.
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0433\u043B\u0430\u0434\u043A\u043E\u0439
    \u043B\u0438\u043D\u0438\u0438 (\u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C
    1) \u0438\u043B\u0438 \u0433\u043B\u0430\u0434\u043A\u043E\u0439 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    (\u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C 2), \u0431\u0435\u0440\u0435\u0433\u043E\u0432\u0430\u044F
    \u043B\u0438\u043D\u0438\u044F \u0438\u043C\u0435\u0435\u0442 **\u0434\u0440\u043E\u0431\u043D\u0443\u044E
    \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C** \u043C\u0435\u0436\u0434\u0443
    1 \u0438 2 . \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C
    \u043F\u043E\u0431\u0435\u0440\u0435\u0436\u044C\u044F \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438
    \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u043E\u043A\u043E\u043B\u043E
    1.52. \u042D\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442, \u0447\u0442\u043E
    \u043E\u043D\u0430 \xAB\u0437\u0430\u043F\u043E\u043B\u043D\u044F\u0435\u0442\xBB
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E \u0441\u0438\u043B\u044C\u043D\u0435\u0435,
    \u0447\u0435\u043C \u043B\u0438\u043D\u0438\u044F, \u043D\u043E \u0441\u043B\u0430\u0431\u0435\u0435,
    \u0447\u0435\u043C \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u044C.  ###
    \U0001F4BB \u0412\u0438\u0437\u0443\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438: \u041C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430  \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0432 \u0442\u0435\u043E\u0440\u0438\u0438,
    \u043D\u043E \u0438 \u0432 \u0441\u043F\u043E\u0441\u043E\u0431\u0435 \u043F\u043E\u0434\u0430\u0447\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0434\u0435\u0439.  *   **\u041E\u0442 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u0438
    \u043A \u043E\u0431\u0440\u0430\u0437\u0443:** \u0421\u0430\u043C\u0430\u044F
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F \u0432\u0438\u0437\u0443\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u044F
    \u2014 **\u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430**
    \u2014 \u043D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435 \u043D\u0435
    \u0431\u044B\u043B\u043E \u0435\u0433\u043E \u0447\u0438\u0441\u0442\u044B\u043C
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\u043C. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    (\u0413\u0430\u0441\u0442\u043E\u043D \u0416\u044E\u043B\u0438\u0430, \u041F\u044C\u0435\u0440
    \u0424\u0430\u0442\u0443) \u0438\u0437\u0443\u0447\u0430\u043B\u0438 \u0435\u0433\u043E
