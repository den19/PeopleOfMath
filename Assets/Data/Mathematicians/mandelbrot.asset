    \u0438\u0445 \u0434\u043B\u044F \u0432\u0438\u0437\u0443\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438
    \u0438\u0442\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u043E\u0433\u043E \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0430
    \\( z \\to z^2 + c \\), \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435
