    \u041D\u0430 \u0437\u0430\u043C\u0435\u0447\u0430\u043D\u0438\u0435, \u0447\u0442\u043E
    \u043E\u043D \u043F\u044B\u0442\u0430\u0435\u0442\u0441\u044F \u0440\u0435\u0448\u0438\u0442\u044C
    \u0437\u0430\u0434\u0430\u0447\u0443 \u043A\u043E\u043C\u043C\u0438\u0432\u043E\u044F\u0436\u0451\u0440\u0430
    \u043D\u0430 \u0437\u0430\u0434\u043D\u0435\u043C \u0441\u0438\u0434\u0435\u043D\u044C\u0435,
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442 \u0440\u0430\u0441\u0441\u043C\u0435\u044F\u043B\u0441\u044F
    \u0438 \u043E\u0442\u0432\u0435\u0442\u0438\u043B: \"\u042F \u0443\u0436\u0435
    \u0440\u0435\u0448\u0438\u043B \u0435\u0451\". \u0415\u0433\u043E \u0434\u0435\u0432\u0438\u0437\u043E\u043C
    \u0431\u044B\u043B\u043E \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C \"\u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u043E\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435\" \u0441 \u043C\u0438\u043D\u0438\u043C\u0443\u043C\u043E\u043C
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0439. *   **\u0411\u0443\u043D\u0442\u0430\u0440\u044C
    \u043E\u0442 \u043D\u0430\u0443\u043A\u0438:** \u041E\u043D \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E
    \u0441\u043F\u043E\u0440\u0438\u043B \u0441 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0438\u0441\u0442\u0435\u0431\u043B\u0438\u0448\u043C\u0435\u043D\u0442\u043E\u043C,
    \u0437\u0430 \u0447\u0442\u043E \u0435\u0433\u043E \"\u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E
    \u043E\u0441\u043A\u043E\u0440\u0431\u043B\u044F\u043B\u0438, \u0433\u043E\u0432\u043E\u0440\u044F,
    \u0447\u0442\u043E \u0442\u043E, \u0447\u0442\u043E \u044F \u0434\u0435\u043B\u0430\u044E,
    \u2014 \u044D\u0442\u043E \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u0439
    \u0441\u043A\u0430\u043D\u0434\u0430\u043B\". \u0421\u0432\u043E\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    \u0432 IBM \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043A\u0430\u043A \u0431\u0430\u0437\u0443 \u0434\u043B\u044F \u0442\u043E\u0433\u043E,
    \u0447\u0442\u043E\u0431\u044B \"\u0434\u0440\u0430\u0437\u043D\u0438\u0442\u044C
    \u0432\u044B\u0441\u043E\u043A\u043E\u043C\u0435\u0440\u043D\u044B\u0435 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043D\u043E\u0441\u044B\" \u0438 \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u044E \u043F\u0440\u0430\u0432\u043E\u0442\u0443 \u0432 \u0442\u0435\u0447\u0435\u043D\u0438\u0435
    \u043F\u043E\u043B\u0443\u0432\u0435\u043A\u0430.  ### \U0001F3AD \u0424\u0440\u0430\u043A\u0442\u0430\u043B\u044B
    \u0432 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435, \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0435
    \u0438 \u0437\u0430 \u0435\u0451 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438 
    \u0418\u0434\u0435\u0438 \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442\u0430
    \u0431\u044B\u0441\u0442\u0440\u043E \u0432\u044B\u0448\u043B\u0438 \u0437\u0430
    \u043F\u0440\u0435\u0434\u0435\u043B\u044B \u0441\u0443\u0445\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u043D\u0430\u0448\u043B\u0438 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E\u0435
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435:  *   **\u041F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C
