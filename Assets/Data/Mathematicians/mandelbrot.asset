    \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438 \xAB\u0447\u0438\u0441\u0442\u043E\u0439\xBB
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043F\u0440\u043E\u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u0432
    \u0438\u0445 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C. 
    *   **\u0424\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0435 \u0440\u044B\u043D\u043A\u0438:**
    \u041E\u043D \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u044F
    \u0446\u0435\u043D \u043D\u0430 \u0445\u043B\u043E\u043F\u043E\u043A \u0437\u0430
    100 \u043B\u0435\u0442 \u0438\u043C\u0435\u044E\u0442 **\u0441\u0430\u043C\u043E\u043F\u043E\u0434\u043E\u0431\u043D\u0443\u044E
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0443**: \u0434\u043D\u0435\u0432\u043D\u044B\u0435
    \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u044F \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435\u043E\u0442\u043B\u0438\u0447\u0438\u043C\u044B \u043E\u0442 \u0433\u043E\u0434\u043E\u0432\u044B\u0445
    . \u042D\u0442\u043E \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u043B\u043E
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043C\u043E\u0434\u0435\u043B\u044F\u043C \u0438 \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u043A \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044E, \u0447\u0442\u043E
