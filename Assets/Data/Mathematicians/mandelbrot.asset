    \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u0431\u043E\u043B\u0435\u0435 \xAB\u0434\u0438\u043A\u0438\u0435\xBB
    \u0438 \u043F\u043E\u0434\u0432\u0435\u0440\u0436\u0435\u043D\u044B \u0440\u0438\u0441\u043A\u0430\u043C,
    \u0447\u0435\u043C \u0441\u0447\u0438\u0442\u0430\u043B\u043E\u0441\u044C . *  
    **\u0414\u0440\u0443\u0433\u0438\u0435 \u043F\u0440\u0438\u043C\u0435\u0440\u044B:**
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442 \u0438\u043B\u0438
    \u0435\u0433\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0438
    \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0438 \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B \u043F\u043E\u0432\u0441\u0435\u043C\u0435\u0441\u0442\u043D\u043E:
    \u0432 **\u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0435 \u043B\u0435\u0433\u043A\u0438\u0445
    \u0438 \u043A\u0440\u043E\u0432\u0435\u043D\u043E\u0441\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B**
    (\u0431\u0440\u043E\u043D\u0445\u0438\u0430\u043B\u044C\u043D\u043E\u0435 \u0434\u0435\u0440\u0435\u0432\u043E,
    \u0441\u0435\u0442\u044C \u0441\u043E\u0441\u0443\u0434\u043E\u0432) , \u0432
    **\u044F\u0437\u044B\u043A\u043E\u0437\u043D\u0430\u043D\u0438\u0438** (\u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0447\u0430\u0441\u0442\u043E\u0442\u044B \u0441\u043B\u043E\u0432 \u0432 \u0442\u0435\u043A\u0441\u0442\u0435)
    , \u0432 \u0430\u043D\u0430\u043B\u0438\u0437\u0435 **\u0432\u043E\u0434\u043D\u043E\u0433\u043E
    \u0440\u0435\u0436\u0438\u043C\u0430 \u041D\u0438\u043B\u0430** , \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    **\u0442\u0443\u0440\u0431\u0443\u043B\u0435\u043D\u0442\u043D\u043E\u0441\u0442\u0438** 
    \u0438 \u0434\u0430\u0436\u0435 \u0432 \u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0438
    \u043E\u0432\u043E\u0449\u0435\u0439, \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A
    \u0431\u0440\u043E\u043A\u043A\u043E\u043B\u0438 .  ### \U0001F4DA \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B  \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
    \u0441\u0432\u043E\u0438\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0431\u0440\u043E\u0442 \u0438\u0437\u043B\u043E\u0436\u0438\u043B
    \u0432 \u0440\u044F\u0434\u0435 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442, \u0441\u0440\u0435\u0434\u0438 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u0441\u043E\u0431\u043E\u0435 \u043C\u0435\u0441\u0442\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u044E\u0442: 
    1.  **\xAB\u0424\u0440\u0430\u043A\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u043F\u0440\u0438\u0440\u043E\u0434\u044B\xBB
    (The Fractal Geometry of Nature, 1982)** \u2014 \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u0430\u044F
    \u0438 \u0441\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u043A\u043D\u0438\u0433\u0430, \u0441\u0442\u0430\u0432\u0448\u0430\u044F \u043C\u0430\u043D\u0438\u0444\u0435\u0441\u0442\u043E\u043C
    \u043D\u043E\u0432\u043E\u0439 \u043D\u0430\u0443\u043A\u0438. \u0412 \u043D\u0435\u0439
    \u043E\u043D \u0441\u043E\u0431\u0440\u0430\u043B \u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0438\u0434\u0435\u0438, \u0441\u043D\u0430\u0431\u0434\u0438\u0432
    \u0438\u0445 \u0431\u043E\u0433\u0430\u0442\u044B\u043C \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u043C . 2.  **\xAB(\u041D\u0435)\u043F\u043E\u0441\u043B\u0443\u0448\u043D\u044B\u0435
    \u0440\u044B\u043D\u043A\u0438: \u0444\u0440\u0430\u043A\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F \u0432 \u0444\u0438\u043D\u0430\u043D\u0441\u0430\u0445\xBB
