  achievementsRu: "\u0418\u043E\u0433\u0430\u043D\u043D \u041A\u0435\u043F\u043B\u0435\u0440
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0430\u0432\u0442\u043E\u0440
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445 \u0437\u0430\u043A\u043E\u043D\u043E\u0432,
    \u043D\u043E \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u043C\u0435\u043B\u043E \u0437\u0430\u043C\u0435\u043D\u0438\u043B \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u0435
    \u043A\u0440\u0443\u0433\u0438 \u043D\u0430 \u044D\u043B\u043B\u0438\u043F\u0441\u044B,
    \u0437\u0430\u043B\u043E\u0436\u0438\u0432 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442
    \u0434\u043B\u044F \u0432\u0441\u0435\u0439 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438 \u0438 \u0444\u0438\u0437\u0438\u043A\u0438.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u0432 \u043D\u0430\u0443\u043A\u0443
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u0435\u043D,
    \u043D\u043E \u0442\u0440\u0438 \u0437\u0430\u043A\u043E\u043D\u0430 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442 \u0441\u0442\u0430\u043B\u0438 \u0435\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435\u043C,
    \u0441\u0434\u0435\u043B\u0430\u0432\u0448\u0438\u043C \u0433\u0435\u043B\u0438\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0442\u0435\u043E\u0440\u0438\u0435\u0439, \u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0449\u0435\u0439
    \u043C\u043E\u0434\u0435\u043B\u044C\u044E \u043C\u0438\u0440\u0430.  ### \U0001FA90
    \u0422\u0440\u0438 \u0437\u0430\u043A\u043E\u043D\u0430 \u043D\u0435\u0431\u0435\u0441\u043D\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438: \u041E\u0442 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u043A \u0444\u0438\u0437\u0438\u043A\u0435  \u042D\u0442\u0438 \u0442\u0440\u0438
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0441\u0442\u0430\u043B\u0438 \u0438\u0442\u043E\u0433\u043E\u043C
    \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0435\u0439 \u0438 \u043A\u0440\u043E\u043F\u043E\u0442\u043B\u0438\u0432\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B \u041A\u0435\u043F\u043B\u0435\u0440\u0430
    \u043D\u0430\u0434 \u0442\u043E\u0447\u043D\u0435\u0439\u0448\u0438\u043C\u0438
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F\u043C\u0438 \u0422\u0438\u0445\u043E
    \u0411\u0440\u0430\u0433\u0435, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0437\u0430 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435\u043C \u041C\u0430\u0440\u0441\u0430,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043D\u0438\u043A\u0430\u043A \u043D\u0435
    \u0432\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u043E\u0441\u044C \u0432 \u0434\u0440\u0435\u0432\u043D\u044E\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u0445
    \u043A\u0440\u0443\u0433\u043E\u0432.  *   **\u041F\u0435\u0440\u0432\u044B\u0439
    \u0437\u0430\u043A\u043E\u043D (\u0417\u0430\u043A\u043E\u043D \u044D\u043B\u043B\u0438\u043F\u0441\u043E\u0432)**,
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0432 1609 \u0433\u043E\u0434\u0443 \u0432 \u043A\u043D\u0438\u0433\u0435 \xAB\u041D\u043E\u0432\u0430\u044F
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F\xBB, \u0433\u043B\u0430\u0441\u0438\u0442:
    **\u041A\u0430\u0436\u0434\u0430\u044F \u043F\u043B\u0430\u043D\u0435\u0442\u0430
    \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F \u043F\u043E \u044D\u043B\u043B\u0438\u043F\u0441\u0443,
    \u0432 \u043E\u0434\u043D\u043E\u043C \u0438\u0437 \u0444\u043E\u043A\u0443\u0441\u043E\u0432
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u0421\u043E\u043B\u043D\u0446\u0435**. \u042D\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E
    \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439 \u043E\u0442\u043A\u0430\u0437
    \u043E\u0442 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F, \u0447\u0442\u043E
    \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u0435 \u0442\u0435\u043B\u0430 \u043E\u0431\u044F\u0437\u0430\u043D\u044B
    \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u044B\u043C
    \u043A\u0440\u0443\u0433\u0430\u043C. \u0421\u043E\u043B\u043D\u0446\u0435 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B\u043E
    \u0431\u044B\u0442\u044C \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u043C\u0438\u0440\u0430,
    \u0441\u043C\u0435\u0441\u0442\u0438\u0432\u0448\u0438\u0441\u044C \u0432 \u0444\u043E\u043A\u0443\u0441
    \u043E\u0440\u0431\u0438\u0442\u044B.  *   **\u0412\u0442\u043E\u0440\u043E\u0439
    \u0437\u0430\u043A\u043E\u043D (\u0417\u0430\u043A\u043E\u043D \u043F\u043B\u043E\u0449\u0430\u0434\u0435\u0439)**
    \u0431\u044B\u043B \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D
    \u0432 \u0442\u043E\u0439 \u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0435 \u0438
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442 \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438 \u043F\u043B\u0430\u043D\u0435\u0442\u044B:
    **\u0420\u0430\u0434\u0438\u0443\u0441-\u0432\u0435\u043A\u0442\u043E\u0440 \u043F\u043B\u0430\u043D\u0435\u0442\u044B
    (\u043B\u0438\u043D\u0438\u044F, \u0441\u043E\u0435\u0434\u0438\u043D\u044F\u044E\u0449\u0430\u044F
    \u0435\u0435 \u0441 \u0421\u043E\u043B\u043D\u0446\u0435\u043C) \u0437\u0430
    \u0440\u0430\u0432\u043D\u044B\u0435 \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043A\u0438
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442
    \u0440\u0430\u0432\u043D\u044B\u0435 \u043F\u043B\u043E\u0449\u0430\u0434\u0438**.
    \u041E\u0442\u0441\u044E\u0434\u0430 \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u043E,
    \u0447\u0442\u043E \u043F\u043B\u0430\u043D\u0435\u0442\u0430 \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F
    \u0431\u044B\u0441\u0442\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043E \u0432
    \u043F\u0435\u0440\u0438\u0433\u0435\u043B\u0438\u0438 (\u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u0439
    \u043A \u0421\u043E\u043B\u043D\u0446\u0443 \u0442\u043E\u0447\u043A\u0435) \u0438
    \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u0435\u0435 \u2014 \u0432 \u0430\u0444\u0435\u043B\u0438\u0438
    (\u0441\u0430\u043C\u043E\u0439 \u0443\u0434\u0430\u043B\u0435\u043D\u043D\u043E\u0439
    \u0442\u043E\u0447\u043A\u0435).  *   **\u0422\u0440\u0435\u0442\u0438\u0439
    \u0437\u0430\u043A\u043E\u043D (\u0413\u0430\u0440\u043C\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0437\u0430\u043A\u043E\u043D)**, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0432 1619 \u0433\u043E\u0434\u0443 \u0432 \u0442\u0440\u0443\u0434\u0435 \xAB\u0413\u0430\u0440\u043C\u043E\u043D\u0438\u044F
    \u043C\u0438\u0440\u0430\xBB, \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B
    \u0435\u0434\u0438\u043D\u0443\u044E \u0441\u0432\u044F\u0437\u044C \u0434\u043B\u044F
    \u0432\u0441\u0435\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B: **\u041A\u0432\u0430\u0434\u0440\u0430\u0442\u044B
    \u043F\u0435\u0440\u0438\u043E\u0434\u043E\u0432 \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442 \u0432\u043E\u043A\u0440\u0443\u0433 \u0421\u043E\u043B\u043D\u0446\u0430
    \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F \u043A\u0430\u043A \u043A\u0443\u0431\u044B
    \u0431\u043E\u043B\u044C\u0448\u0438\u0445 \u043F\u043E\u043B\u0443\u043E\u0441\u0435\u0439
    \u0438\u0445 \u043E\u0440\u0431\u0438\u0442**. \u042D\u0442\u043E\u0442 \u0437\u0430\u043A\u043E\u043D
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u0442\u044C
    \u043E\u0440\u0431\u0438\u0442\u044B \u043B\u044E\u0431\u044B\u0445 \u043F\u043B\u0430\u043D\u0435\u0442
    \u0438 \u0434\u0430\u0436\u0435 \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u043E\u0432,
    \u043D\u043E \u0435\u0433\u043E \u0438\u0441\u0442\u0438\u043D\u043D\u044B\u0439
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0441\u043C\u044B\u0441\u043B
    \u0431\u044B\u043B \u0440\u0430\u0441\u043A\u0440\u044B\u0442 \u043F\u043E\u0437\u0436\u0435. 
    \u042D\u0442\u0438 \u0442\u0440\u0438 \u0437\u0430\u043A\u043E\u043D\u0430 \u0441\u0442\u0430\u043B\u0438
    \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0435\u043C \u043A\u0438\u043D\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u0430\u0440\u0442\u0438\u043D\u044B \u0421\u043E\u043B\u043D\u0435\u0447\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u0438 \u043F\u043E\u0437\u0436\u0435
    \u043F\u043E\u0441\u043B\u0443\u0436\u0438\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u043E\u0439
    \u0434\u043B\u044F \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u0418\u0441\u0430\u0430\u043A\u043E\u043C
    \u041D\u044C\u044E\u0442\u043E\u043D\u043E\u043C \u0437\u0430\u043A\u043E\u043D\u0430
    \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0433\u043E \u0442\u044F\u0433\u043E\u0442\u0435\u043D\u0438\u044F. 
    ### \U0001F4A1 \u041E\u043F\u0442\u0438\u043A\u0430 \u0438 \u0444\u0438\u0437\u0438\u043A\u0430:
    \u041E\u0442 \u0433\u043B\u0430\u0437\u0430 \u0434\u043E \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u0430 
    \u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B
    \u041A\u0435\u043F\u043B\u0435\u0440\u0430 \u0432\u044B\u0445\u043E\u0434\u0438\u043B\u0438
    \u0434\u0430\u043B\u0435\u043A\u043E \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u044B
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438. \u0415\u0433\u043E
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043E\u043F\u0442\u0438\u043A\u0443 \u0442\u0430\u043A\u0436\u0435
    \u0441\u0442\u0430\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C: 
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0437\u0440\u0435\u043D\u0438\u044F**:
    \u0412 1604 \u0433\u043E\u0434\u0443 \u0432 \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435
    \xAB\u0414\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u044F \u043A \u0412\u0438\u0442\u0435\u043B\u043B\u0438\u044E\xBB
    \u043E\u043D \u043F\u0435\u0440\u0432\u044B\u043C \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E
    \u043E\u043F\u0438\u0441\u0430\u043B \u0444\u0438\u0437\u0438\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C \u0437\u0440\u0435\u043D\u0438\u044F,
    \u043F\u043E\u043A\u0430\u0437\u0430\u0432, \u0447\u0442\u043E \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0441\u0442\u0440\u043E\u0438\u0442\u0441\u044F \u043D\u0430 \u0441\u0435\u0442\u0447\u0430\u0442\u043A\u0435
    \u0433\u043B\u0430\u0437\u0430. *   **\u0417\u0430\u043A\u043E\u043D \u043E\u0441\u0432\u0435\u0449\u0435\u043D\u043D\u043E\u0441\u0442\u0438**:
    \u0412 \u0442\u043E\u0439 \u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0435 \u043E\u043D
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u0430\u043A\u043E\u043D, \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443 \u043E\u0441\u0432\u0435\u0449\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u043E\u0431\u0440\u0430\u0442\u043D\u043E \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0443 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    \u0434\u043E \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430 \u0441\u0432\u0435\u0442\u0430.
    *   **\u0422\u0435\u043B\u0435\u0441\u043A\u043E\u043F \u041A\u0435\u043F\u043B\u0435\u0440\u0430**:
    \u0412 1611 \u0433\u043E\u0434\u0443 \u0432 \u0440\u0430\u0431\u043E\u0442\u0435
    \xAB\u0414\u0438\u043E\u043F\u0442\u0440\u0438\u043A\u0430\xBB \u043E\u043D \u043E\u043F\u0438\u0441\u0430\u043B
    \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u043D\u0443\u044E
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044E \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u0430
    \u0441 \u0434\u0432\u0443\u043C\u044F \u0434\u0432\u043E\u044F\u043A\u043E\u0432\u044B\u043F\u0443\u043A\u043B\u044B\u043C\u0438
    \u043B\u0438\u043D\u0437\u0430\u043C\u0438. \u042D\u0442\u0430 \u0441\u0445\u0435\u043C\u0430,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F \u043A\u0430\u043A \u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0442\u0440\u0443\u0431\u0430 \u041A\u0435\u043F\u043B\u0435\u0440\u0430, \u0434\u0430\u0432\u0430\u043B\u0430
    \u0431\u043E\u043B\u044C\u0448\u0435\u0435 \u043F\u043E\u043B\u0435 \u0437\u0440\u0435\u043D\u0438\u044F
    \u0438 \u0441\u0442\u0430\u043B\u0430 \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437\u043E\u043C
    \u0432\u0441\u0435\u0445 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0440\u0435\u0444\u0440\u0430\u043A\u0442\u043E\u0440\u043E\u0432. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u043F\u0440\u0438\u043B\u0438\u0432\u043E\u0432**: \u041E\u043D \u0432\u044B\u0441\u043A\u0430\u0437\u0430\u043B
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u0443\u044E \u0434\u043E\u0433\u0430\u0434\u043A\u0443,
    \u0447\u0442\u043E \u043F\u0440\u0438\u043B\u0438\u0432\u044B \u0438 \u043E\u0442\u043B\u0438\u0432\u044B
    \u0432 \u043E\u043A\u0435\u0430\u043D\u0430\u0445 \u0432\u044B\u0437\u044B\u0432\u0430\u044E\u0442\u0441\u044F
    \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u043C
    \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435\u043C \u041B\u0443\u043D\u044B. 
    ### \U0001F58B\uFE0F \u0413\u043B\u0430\u0432\u043D\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B: \u041A\u043D\u0438\u0433\u0438, \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0438\u0435
    \u043C\u0438\u0440  \u041F\u043E\u043C\u0438\u043C\u043E \u0443\u043F\u043E\u043C\u044F\u043D\u0443\u0442\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442, \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0432\u043A\u043B\u044E\u0447\u0430\u0435\u0442
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432:  *   **\xAB\u0421\u043E\u043A\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u043A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u043E\u0432\u043E\u0439 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438\xBB
    (1618\u20131622)**: \u042D\u0442\u043E\u0442 \u0442\u0440\u0435\u0445\u0442\u043E\u043C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u0441\u0442\u0430\u043B \u043B\u0443\u0447\u0448\u0438\u043C
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u043C \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u0442\u043E\u0439 \u044D\u043F\u043E\u0445\u0438. \u0412 \u043D\u0435\u043C
    \u041A\u0435\u043F\u043B\u0435\u0440 \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u044B\u0435 \u0434\u0432\u0430
    \u0437\u0430\u043A\u043E\u043D\u0430 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043C\u044B
    \u043A\u043E \u0432\u0441\u0435\u043C \u043F\u043B\u0430\u043D\u0435\u0442\u0430\u043C,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0417\u0435\u043C\u043B\u044E, \u0430
    \u0442\u0440\u0435\u0442\u0438\u0439 \u2014 \u0434\u0430\u0436\u0435 \u043A \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430\u043C
    \u042E\u043F\u0438\u0442\u0435\u0440\u0430. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0437\u0430 \u044D\u0442\u0443 \u043A\u043D\u0438\u0433\u0443 \u0412\u0430\u0442\u0438\u043A\u0430\u043D
    \u0432\u043D\u0435\u0441 \u0435\u0435 \u0432 \xAB\u0418\u043D\u0434\u0435\u043A\u0441
    \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043D\u044B\u0445 \u043A\u043D\u0438\u0433\xBB.
    *   **\xAB\u0420\u0443\u0434\u043E\u043B\u044C\u0444\u043E\u0432\u044B \u0442\u0430\u0431\u043B\u0438\u0446\u044B\xBB
    (1627)**: \u0418\u0442\u043E\u0433 22-\u043B\u0435\u0442\u043D\u0435\u0439 \u0440\u0430\u0431\u043E\u0442\u044B,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0431\u044B\u043B\u0438 \u0441\u043E\u0431\u0440\u0430\u043D\u044B
    \u0441\u0430\u043C\u044B\u0435 \u0442\u043E\u0447\u043D\u044B\u0435 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    \u041E\u043D\u0438 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u0438 \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u0442\u044C
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u043F\u043B\u0430\u043D\u0435\u0442
    \u0441 \u043D\u0435\u0432\u0438\u0434\u0430\u043D\u043D\u043E\u0439 \u0440\u0430\u043D\u0435\u0435
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E \u0438 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0438\u0441\u044C
    \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u043C \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u0432
    \u0438 \u043C\u043E\u0440\u0435\u043F\u043B\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0434\u043E \u043D\u0430\u0447\u0430\u043B\u0430 XIX \u0432\u0435\u043A\u0430.
    *   **\xAB\u0421\u0442\u0435\u0440\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    \u0432\u0438\u043D\u043D\u044B\u0445 \u0431\u043E\u0447\u0435\u043A\xBB (1615)**:
    \u0412 \u044D\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 \u043E\u043D
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u0441\u0432\u043E\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u043A \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0435 \u0438 \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B
    \u043E\u0431\u044A\u0435\u043C\u044B \u0442\u0435\u043B, \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u044B\u0445
    \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435\u043C \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0435\u0447\u0435\u043D\u0438\u0439. \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u0432\u0430\u0436\u043D\u044B\u043C \u0448\u0430\u0433\u043E\u043C \u0432 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0438
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F.  ### \U0001F30C
    \u0418\u0442\u043E\u0433: \u041A\u0435\u043F\u043B\u0435\u0440 \u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u043D\u0430\u0443\u043A\u0430  \u041A\u0435\u043F\u043B\u0435\u0440 \u0441\u0442\u043E\u044F\u043B
    \u043D\u0430 \u043F\u0435\u0440\u0435\u043F\u0443\u0442\u044C\u0435 \u044D\u043F\u043E\u0445:
    \u043C\u0438\u0441\u0442\u0438\u043A, \u0432\u0435\u0440\u0438\u0432\u0448\u0438\u0439
    \u0432 \u0447\u0438\u0441\u043B\u043E\u0432\u0443\u044E \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u044E
    \u043C\u0438\u0440\u0430, \u0438 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u0442\u043E\u0440,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0446\u0435\u043D\u043E\u0439 \u043D\u0435\u0438\u043C\u043E\u0432\u0435\u0440\u043D\u044B\u0445
    \u0443\u0441\u0438\u043B\u0438\u0439 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B
    \u043F\u043E\u044D\u0437\u0438\u044E \u043A\u043E\u0441\u043C\u043E\u0441\u0430
    \u0432 \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C. \u041E\u043D \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u043B \u0437\u0430\u043A\u043E\u043D\u044B
    \u2014 \u043E\u043D \u043F\u0435\u0440\u0432\u044B\u043C \u0437\u0430\u0433\u043E\u0432\u043E\u0440\u0438\u043B
    \u043E \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0441\u0438\u043B\u0435,
    \u0438\u0441\u0445\u043E\u0434\u044F\u0449\u0435\u0439 \u043E\u0442 \u0421\u043E\u043B\u043D\u0446\u0430,
    \u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \u043E \u043F\u0440\u0438\u0447\u0438\u043D\u043D\u043E\u0441\u0442\u0438 \u0432
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438, \u0447\u0435\u043C,
    \u043F\u043E \u0441\u0443\u0442\u0438, \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u043B
    \u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u0435 \u043D\u0435\u0431\u0435\u0441\u043D\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438. \u0415\u0433\u043E \u0432\u0435\u0440\u0430
    \u0432 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0439
    \u0437\u0430\u043A\u043E\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438,
    \u0434\u0430\u0436\u0435 \u0432 \u0441\u0430\u043C\u044B\u0445 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u0445
    \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u0445,
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0437\u0432\u0430\u043D\u0430 \u0410\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C \xAB\u043D\u0435\u0441\u0440\u0430\u0432\u043D\u0435\u043D\u043D\u043E\u0439\xBB."
  achievementsEn: 
  personalLifeRu: "\u0416\u0438\u0437\u043D\u044C \u0418\u043E\u0433\u0430\u043D\u043D\u0430
    \u041A\u0435\u043F\u043B\u0435\u0440\u0430 \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439 \u0441\u0442\u043E\u0439\u043A\u043E\u0441\u0442\u0438
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E \u0432\u044B\u0442\u0430\u0449\u0438\u043B
    \u0441\u0435\u0431\u044F \u0438\u0437 \u043D\u0438\u0449\u0435\u0442\u044B \u0438
    \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u0439, \u0447\u0442\u043E\u0431\u044B
    \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443\u0442\u044C \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0430 \u043E
    \u043A\u043E\u0441\u043C\u043E\u0441\u0435. \u0417\u0430 \u0441\u0442\u0440\u043E\u0433\u0438\u043C\u0438
    \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u043C\u0438 \u0441\u043A\u0440\u044B\u0432\u0430\u043B\u0430\u0441\u044C
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F, \u043F\u043E\u043B\u043D\u0430\u044F
    \u0441\u043A\u0438\u0442\u0430\u043D\u0438\u0439 \u0438 \u043F\u043E\u0442\u0435\u0440\u044C
    \u0441\u0443\u0434\u044C\u0431\u0430.   \u0414\u0430\u0432\u0430\u0439\u0442\u0435
    \u043F\u0440\u043E\u0441\u043B\u0435\u0434\u0438\u043C \u0435\u0435 \u0448\u0430\u0433
    \u0437\u0430 \u0448\u0430\u0433\u043E\u043C, \u0432 \u043C\u0435\u043B\u044C\u0447\u0430\u0439\u0448\u0438\u0445
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0441\u0442\u044F\u0445.  ###
    \U0001F476 \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435, \u0434\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    (1571\u20131584)  \u0418\u043E\u0433\u0430\u043D\u043D \u041A\u0435\u043F\u043B\u0435\u0440
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 27 \u0434\u0435\u043A\u0430\u0431\u0440\u044F
    1571 \u0433\u043E\u0434\u0430 \u0432 \u0438\u043C\u043F\u0435\u0440\u0441\u043A\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u0435 **\u0412\u0430\u0439\u043B\u044C-\u0434\u0435\u0440-\u0428\u0442\u0430\u0434\u0442**
    (\u043D\u044B\u043D\u0435 \u0437\u0435\u043C\u043B\u044F \u0411\u0430\u0434\u0435\u043D-\u0412\u044E\u0440\u0442\u0435\u043C\u0431\u0435\u0440\u0433,
    \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044F). \u041E\u043D \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0441\u0432\u0435\u0442 \u043D\u0435\u0434\u043E\u043D\u043E\u0448\u0435\u043D\u043D\u044B\u043C,
    \u0447\u0435\u0440\u0435\u0437 7 \u043C\u0435\u0441\u044F\u0446\u0435\u0432 \u043F\u043E\u0441\u043B\u0435
    \u0437\u0430\u0447\u0430\u0442\u0438\u044F. \u042D\u0442\u043E \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u043E\u0442\u0440\u0430\u0437\u0438\u043B\u043E\u0441\u044C \u043D\u0430 \u0435\u0433\u043E
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435: \u043E\u043D \u0431\u044B\u043B
    \u0445\u0440\u0443\u043F\u043A\u0438\u043C, \u0447\u0430\u0441\u0442\u043E \u0431\u043E\u043B\u0435\u043B,
    \u0438\u043C\u0435\u043B \u0441\u043B\u0430\u0431\u043E\u0435 \u0437\u0440\u0435\u043D\u0438\u0435
    (\u0431\u043B\u0438\u0437\u043E\u0440\u0443\u043A\u043E\u0441\u0442\u044C \u0438
    \u0434\u0435\u0444\u0435\u043A\u0442\u044B \u0437\u0440\u0435\u043D\u0438\u044F
    \u0438\u0437-\u0437\u0430 \u043F\u0435\u0440\u0435\u043D\u0435\u0441\u0435\u043D\u043D\u043E\u0439
    \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u043E\u0441\u043F\u044B) \u0438
    \u043F\u043E\u0432\u0440\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u0435 \u0440\u0443\u043A\u0438,
    \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u043B\u043E \u0435\u0433\u043E \u043D\u0435\u043F\u0440\u0438\u0433\u043E\u0434\u043D\u044B\u043C
    \u0434\u043B\u044F \u043A\u0440\u043E\u043F\u043E\u0442\u043B\u0438\u0432\u044B\u0445
    \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u0439.  \u0415\u0433\u043E
    \u0434\u0435\u0434, **\u0417\u0435\u0431\u043E\u043B\u044C\u0434 \u041A\u0435\u043F\u043B\u0435\u0440**,
    \u0431\u044B\u043B \u0431\u0443\u0440\u0433\u043E\u043C\u0438\u0441\u0442\u0440\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u0430, \u043D\u043E \u043A \u043C\u043E\u043C\u0435\u043D\u0442\u0443
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0418\u043E\u0433\u0430\u043D\u043D\u0430
    \u0441\u0435\u043C\u044C\u044F \u043E\u0431\u0435\u0434\u043D\u0435\u043B\u0430.
    \u041E\u0442\u0435\u0446, **\u0413\u0435\u043D\u0440\u0438\u0445 \u041A\u0435\u043F\u043B\u0435\u0440**,
    \u0431\u044B\u043B \u0431\u0440\u043E\u0434\u044F\u0447\u0438\u043C \u043D\u0430\u0435\u043C\u043D\u0438\u043A\u043E\u043C-\u043B\u0430\u043D\u0434\u0441\u043A\u043D\u0435\u0445\u0442\u043E\u043C,
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0432\u0441\u043F\u044B\u043B\u044C\u0447\u0438\u0432\u044B\u043C
    \u0438 \u0433\u0440\u0443\u0431\u044B\u043C. \u041C\u0430\u0442\u044C, **\u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0430
    \u0413\u0443\u043B\u044C\u0434\u0435\u043D\u043C\u0430\u043D\u043D**, \u0431\u044B\u043B\u0430
    \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u0442\u0440\u0430\u043A\u0442\u0438\u0440\u0449\u0438\u043A\u0430.
    \u041E\u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430 \u0446\u0435\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0435\u0439
    \u0438 \u0442\u0440\u0430\u0432\u043D\u0438\u0446\u0435\u0439, \u0441\u043E\u0431\u0438\u0440\u0430\u043B\u0430
    \u0442\u0440\u0430\u0432\u044B \u0438 \u0433\u043E\u0442\u043E\u0432\u0438\u043B\u0430
    \u0441\u043D\u0430\u0434\u043E\u0431\u044C\u044F, \u0447\u0442\u043E \u043F\u043E\u0437\u0436\u0435
    \u0441\u044B\u0433\u0440\u0430\u0435\u0442 \u0440\u043E\u043A\u043E\u0432\u0443\u044E
    \u0440\u043E\u043B\u044C. \u041A\u043E\u0433\u0434\u0430 \u0418\u043E\u0433\u0430\u043D\u043D\u0443
    \u0431\u044B\u043B\u043E 5 \u043B\u0435\u0442, \u043E\u0442\u0435\u0446 \u0443\u0448\u0435\u043B
    \u0438\u0437 \u0434\u043E\u043C\u0430, \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0432\u0448\u0438\u0441\u044C
    \u0432 \u043E\u0447\u0435\u0440\u0435\u0434\u043D\u043E\u0439 \u0432\u043E\u0435\u043D\u043D\u044B\u0439
    \u043F\u043E\u0445\u043E\u0434 \u0432 \u041D\u0438\u0434\u0435\u0440\u043B\u0430\u043D\u0434\u044B,
    \u0438 \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    (\u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043F\u043E\u0433\u0438\u0431). \u041C\u0430\u043B\u044C\u0447\u0438\u043A\u0430
    \u043E\u0442\u0434\u0430\u043B\u0438 \u043D\u0430 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0435
    \u0434\u0435\u0434\u0443 \u043F\u043E \u043C\u0430\u0442\u0435\u0440\u0438\u043D\u0441\u043A\u043E\u0439
    \u043B\u0438\u043D\u0438\u0438.   \u0421 \u0440\u0430\u043D\u043D\u0435\u0433\u043E
    \u0434\u0435\u0442\u0441\u0442\u0432\u0430 \u043E\u043D \u043F\u043E\u0440\u0430\u0436\u0430\u043B
    \u043E\u043A\u0440\u0443\u0436\u0430\u044E\u0449\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044F\u043C\u0438.
    \u0420\u0430\u0431\u043E\u0442\u0430\u044F \u0432 \u0442\u0440\u0430\u043A\u0442\u0438\u0440\u0435
    \u0434\u0435\u0434\u0430, \u043C\u0430\u043B\u044C\u0447\u0438\u043A \u0432 \u0443\u043C\u0435
    \u0440\u0435\u0448\u0430\u043B \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438
    \u0434\u043B\u044F \u043F\u043E\u0441\u0435\u0442\u0438\u0442\u0435\u043B\u0435\u0439,
    \u0438 \u0442\u0435 \u0434\u0430\u0432\u0430\u043B\u0438 \u0435\u043C\u0443 \u043D\u0430
    \u0447\u0430\u0439. \u0412 1577 \u0433\u043E\u0434\u0443 \u043C\u0430\u0442\u044C
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0430 \u0435\u043C\u0443 \u0441 \u0431\u0430\u043B\u043A\u043E\u043D\u0430
    **\u0411\u043E\u043B\u044C\u0448\u0443\u044E \u043A\u043E\u043C\u0435\u0442\u0443**,
    \u0430 \u0432 1580 \u0433\u043E\u0434\u0443 \u043E\u043D\u0438 \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u043B\u0438
    \u043B\u0443\u043D\u043D\u043E\u0435 \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u0435
    \u2013 \u044D\u0442\u0438 \u0441\u043E\u0431\u044B\u0442\u0438\u044F \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B\u0438
    \u0432 \u043D\u0435\u043C \u043F\u043E\u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0439
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441 \u043A \u043D\u0435\u0431\u0443. 
    ### \U0001F393 \u0423\u0447\u0451\u0431\u0430 (1584\u20131594)  \u0412 1584 \u0433\u043E\u0434\u0443
    \u041A\u0435\u043F\u043B\u0435\u0440 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 **\u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u0432 \u0410\u0434\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0435**,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E
    **\u0432\u044B\u0441\u0448\u0443\u044E \u0448\u043A\u043E\u043B\u0443 \u0432
    \u041C\u0430\u0443\u043B\u044C\u0431\u0440\u043E\u043D\u043D\u0435**. \u041E\u0431\u0443\u0447\u0435\u043D\u0438\u0435
    \u0431\u044B\u043B\u043E \u0441\u0443\u0440\u043E\u0432\u044B\u043C, \u0430 \u0436\u0438\u0437\u043D\u044C
    \u2014 \u043F\u043E\u043B\u0443\u0433\u043E\u043B\u043E\u0434\u043D\u043E\u0439,
    \u043D\u043E \u043E\u043D \u0443\u0447\u0438\u043B\u0441\u044F \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435. 
    \u0412 1589 \u0433\u043E\u0434\u0443 \u043E\u043D \u0432\u044B\u0438\u0433\u0440\u0430\u043B
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E (\u0437\u0435\u043C\u0435\u043B\u044C\u043D\u0443\u044E
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E \u0433\u0435\u0440\u0446\u043E\u0433\u0430
    \u0412\u044E\u0440\u0442\u0435\u043C\u0431\u0435\u0440\u0433\u0441\u043A\u043E\u0433\u043E)
    \u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 **\u0422\u044E\u0431\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442** \u2014 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u0446\u0435\u043D\u0442\u0440\u043E\u0432
    \u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0441\u043A\u043E\u0439 \u0443\u0447\u0435\u043D\u043E\u0441\u0442\u0438.
    \u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043E\u043D \u0438\u0437\u0443\u0447\u0430\u043B
    \u044D\u0442\u0438\u043A\u0443, \u0434\u0438\u0430\u043B\u0435\u043A\u0442\u0438\u043A\u0443
    \u0438 \u0440\u0438\u0442\u043E\u0440\u0438\u043A\u0443, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0443\u0433\u043B\u0443\u0431\u0438\u043B\u0441\u044F \u0432 \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044E,
    \u0433\u043E\u0442\u043E\u0432\u044F\u0441\u044C \u0441\u0442\u0430\u0442\u044C
    \u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0441\u043A\u0438\u043C \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u043E\u043C.
    \u0415\u0433\u043E \u0443\u0441\u043F\u0435\u0445\u0438 \u0431\u044B\u043B\u0438
    \u0441\u0442\u043E\u043B\u044C \u0432\u0435\u043B\u0438\u043A\u0438, \u0447\u0442\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u043F\u0440\u043E\u0434\u043B\u0435\u0432\u0430\u043B
    \u0435\u043C\u0443 \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E.  \u0418\u043C\u0435\u043D\u043D\u043E
    \u0432 \u0422\u044E\u0431\u0438\u043D\u0433\u0435\u043D\u0435 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u0435\u043B
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043D\u044B\u0439 \u043C\u043E\u043C\u0435\u043D\u0442.
    \u0415\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0441\u0442\u0430\u043B
    **\u041C\u0438\u0445\u0430\u044D\u043B\u044C \u041C\u0451\u0441\u0442\u043B\u0438\u043D**.
    \u041C\u0451\u0441\u0442\u043B\u0438\u043D \u0442\u0430\u0439\u043D\u043E (\u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443
    \u044D\u0442\u043E \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u0437\u0430\u043F\u0440\u0435\u0449\u0430\u043B\u043E\u0441\u044C \u0446\u0435\u0440\u043A\u043E\u0432\u044C\u044E)
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B \u041A\u0435\u043F\u043B\u0435\u0440\u0430
    \u0441 \u0433\u0435\u043B\u0438\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439 **\u041D\u0438\u043A\u043E\u043B\u0430\u044F
    \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430**. \u041A\u0435\u043F\u043B\u0435\u0440
    \u0431\u044B\u043B \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E \u043F\u043E\u043A\u043E\u0440\u0435\u043D:
    \u043E\u043D \u0443\u0432\u0438\u0434\u0435\u043B \u0432 \u0433\u0435\u043B\u0438\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0437\u043C\u0435
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0440\u044E\u043A, \u0430 \u0431\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u043F\u043B\u0430\u043D.   ### \U0001F3EB \u0420\u0430\u0431\u043E\u0442\u0430.
    \u0413\u0440\u0430\u0446 (1594\u20131600): \u041F\u0435\u0440\u0432\u044B\u0439
    \u0431\u0440\u0430\u043A \u0438 \"\u0422\u0430\u0439\u043D\u0430 \u043C\u0438\u0440\u043E\u0437\u0434\u0430\u043D\u0438\u044F\" 
    \u0412 1594 \u0433\u043E\u0434\u0443, \u043D\u0435 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0432
    \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043A\u0443\u0440\u0441\u0430 (\u0435\u043C\u0443 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0433\u043E\u0434), \u041A\u0435\u043F\u043B\u0435\u0440
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E\u0435
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435. \u041F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u0441\u043A\u0430\u044F
    \u0448\u043A\u043E\u043B\u0430 \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 **\u0413\u0440\u0430\u0446**
    (\u0410\u0432\u0441\u0442\u0440\u0438\u044F) \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B\u0430
    \u043F\u0440\u0438\u0441\u043B\u0430\u0442\u044C \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u041A\u0435\u043F\u043B\u0435\u0440
    \u043D\u0435 \u0445\u043E\u0442\u0435\u043B \u0435\u0445\u0430\u0442\u044C, \u043D\u043E
    \u0446\u0435\u0440\u043A\u043E\u0432\u043D\u044B\u0435 \u0432\u043B\u0430\u0441\u0442\u0438
    \u043D\u0430\u0441\u0442\u043E\u044F\u043B\u0438.  \u0412 **\u0413\u0440\u0430\u0446\u0435**
    \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C \u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C. \u0415\u043C\u0443 \u0431\u044B\u043B\u043E 23
    \u0433\u043E\u0434\u0430. \u0417\u0430\u0440\u043F\u043B\u0430\u0442\u0430 \u0431\u044B\u043B\u0430
    \u043C\u0438\u0437\u0435\u0440\u043D\u043E\u0439, \u0438 \u043E\u043D \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E
    \u043F\u043E\u0434\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043B \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C
    \u0433\u043E\u0440\u043E\u0441\u043A\u043E\u043F\u043E\u0432 (\u043A\u043E\u0442\u043E\u0440\u044B\u0435,
    \u043F\u043E \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C\u0443
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044E, \u0431\u044B\u043B\u0438
    \"\u0434\u0435\u0448\u0435\u0432\u043A\u043E\u0439\", \u043D\u043E \u043F\u0440\u0438\u043D\u043E\u0441\u0438\u043B\u0438
    \u0434\u0435\u043D\u044C\u0433\u0438).   \u0418\u043C\u0435\u043D\u043D\u043E
    \u0437\u0434\u0435\u0441\u044C, 19 \u0438\u044E\u043B\u044F 1595 \u0433\u043E\u0434\u0430,
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043B\u0435\u043A\u0446\u0438\u0438
    \u043E \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F\u0445 \u043F\u043B\u0430\u043D\u0435\u0442,
    \u0435\u0433\u043E \u043E\u0441\u0435\u043D\u0438\u043B\u0430 \u0438\u0434\u0435\u044F,
    \u0447\u0442\u043E \u043C\u0435\u0436\u0434\u0443 \u043E\u0440\u0431\u0438\u0442\u0430\u043C\u0438
    \u043F\u043B\u0430\u043D\u0435\u0442 \u0432\u043B\u043E\u0436\u0435\u043D\u044B
    \u043F\u044F\u0442\u044C \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0445
    \u043F\u043B\u0430\u0442\u043E\u043D\u043E\u0432\u044B\u0445 \u0442\u0435\u043B.
    \u042D\u0442\u0430 \u0438\u0434\u0435\u044F \u043B\u0435\u0433\u043B\u0430 \u0432
    \u043E\u0441\u043D\u043E\u0432\u0443 \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u043E\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430 **\xAB\u0422\u0430\u0439\u043D\u0430 \u043C\u0438\u0440\u043E\u0437\u0434\u0430\u043D\u0438\u044F\xBB
    (Mysterium Cosmographicum)**, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u043E\u0433\u043E
    \u0432 1596 \u0433\u043E\u0434\u0443. \u041A\u043D\u0438\u0433\u0430 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430
    \u0435\u043C\u0443 \u043F\u0435\u0440\u0432\u0443\u044E \u0441\u043B\u0430\u0432\u0443,
    \u0445\u043E\u0442\u044F \u0440\u0430\u0441\u0447\u0435\u0442\u044B \u0431\u044B\u043B\u0438
    \u043D\u0435\u0442\u043E\u0447\u043D\u044B.  \u0412 1597 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u0411\u0430\u0440\u0431\u0430\u0440\u0435
    \u041C\u044E\u043B\u043B\u0435\u0440**. \u042D\u0442\u043E \u0431\u044B\u043B
    \u0431\u0440\u0430\u043A \u043D\u0435 \u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E \u043B\u044E\u0431\u0432\u0438, \u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438:
    \u0411\u0430\u0440\u0431\u0430\u0440\u0430 \u0431\u044B\u043B\u0430 23-\u043B\u0435\u0442\u043D\u0435\u0439
    \u0441\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0432\u0434\u043E\u0432\u043E\u0439 \u0441 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u0439
    \u0434\u043E\u0447\u0435\u0440\u044C\u044E. \u0415\u0435 \u043E\u0442\u0435\u0446,
    \u0418\u043E\u0430\u0445\u0438\u043C \u041C\u044E\u043B\u043B\u0435\u0440, \u0431\u044B\u043B
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0431\u0440\u0430\u043A\u0430 \u0441 \u0431\u0435\u0434\u043D\u044B\u043C
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C, \u043D\u043E \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F
    \"\u0422\u0430\u0439\u043D\u044B\" \u043F\u0435\u0440\u0435\u0443\u0431\u0435\u0434\u0438\u043B\u0430
    \u0435\u0433\u043E. \u0412 \u044D\u0442\u043E\u043C \u0431\u0440\u0430\u043A\u0435
    \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u043F\u044F\u0442\u0435\u0440\u043E
    \u0434\u0435\u0442\u0435\u0439, \u043D\u043E \u0432\u044B\u0436\u0438\u043B\u0438
    \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u0432\u043E\u0435 \u2014 \u0441\u044B\u043D
    \u0413\u0435\u043D\u0440\u0438\u0445 \u0438 \u0434\u043E\u0447\u044C \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0430.
    \u041E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435 \u0443\u043C\u0435\u0440\u043B\u0438
    \u0432\u043E \u043C\u043B\u0430\u0434\u0435\u043D\u0447\u0435\u0441\u0442\u0432\u0435
    \u043E\u0442 \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u0439.  \u0412 1598 \u0433\u043E\u0434\u0443
    \u0432 \u0413\u0440\u0430\u0446\u0435 \u043D\u0430\u0447\u0430\u043B\u0438\u0441\u044C
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435 \u0433\u043E\u043D\u0435\u043D\u0438\u044F.
    \u041A\u043E\u043D\u0442\u0440\u0440\u0435\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F
    \u043B\u0438\u0448\u0430\u043B\u0430 \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u043E\u0432
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0435\u0439. \u041A\u0435\u043F\u043B\u0435\u0440\u0430
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u043B\u0438 \u0438\u0437 \u0441\u043F\u0438\u0441\u043A\u043E\u0432
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u0439,
    \u0438 \u043E\u043D \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0431\u0435\u0437
    \u0440\u0430\u0431\u043E\u0442\u044B.   ### \U0001F451 \u0420\u0430\u0431\u043E\u0442\u0430.
    \u041F\u0440\u0430\u0433\u0430 (1600\u20131612): \u0421\u0441\u043E\u0440\u044B
    \u0438 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u0422\u0438\u0445\u043E \u0411\u0440\u0430\u0433\u0435  \u041E\u0441\u0442\u0430\u0432\u0448\u0438\u0441\u044C
    \u0431\u0435\u0437 \u0441\u0440\u0435\u0434\u0441\u0442\u0432, \u041A\u0435\u043F\u043B\u0435\u0440
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432 **\u041F\u0440\u0430\u0433\u0443**,
    \u043A \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u043C\u0443 \u0434\u0430\u0442\u0441\u043A\u043E\u043C\u0443
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0443 **\u0422\u0438\u0445\u043E
    \u0411\u0440\u0430\u0433\u0435**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u043B\u0443\u0436\u0438\u043B \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u043F\u0440\u0438
    \u0420\u0443\u0434\u043E\u043B\u044C\u0444\u0435 II. \u041E\u043D\u0438 \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B\u0438\u0441\u044C
    \u0432 1600 \u0433\u043E\u0434\u0443.  \u0418\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0431\u044B\u043B\u0438 **\u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u043E
    \u0441\u043B\u043E\u0436\u043D\u044B\u043C\u0438**.   - **\u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440
    \u0422\u0438\u0445\u043E:** \u0411\u0440\u0430\u0433\u0435 \u0431\u044B\u043B
    \u0434\u0432\u043E\u0440\u044F\u043D\u0438\u043D\u043E\u043C, \u0431\u043E\u0433\u0430\u0442\u044B\u043C,
    \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u043C
    (\u0441 \u0437\u043E\u043B\u043E\u0442\u044B\u043C \u043F\u0440\u043E\u0442\u0435\u0437\u043E\u043C
    \u043D\u043E\u0441\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043D
    \u043D\u043E\u0441\u0438\u043B \u043F\u043E\u0441\u043B\u0435 \u0434\u0443\u044D\u043B\u0438),
    \u043F\u0440\u0438\u0432\u044B\u043A\u0448\u0438\u043C \u043A \u0440\u043E\u0441\u043A\u043E\u0448\u0438
    \u0438 \u043F\u043E\u043A\u043B\u043E\u043D\u0435\u043D\u0438\u044E. - **\u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440
    \u041A\u0435\u043F\u043B\u0435\u0440\u0430:** \u0411\u0435\u0434\u043D\u044B\u0439,
    \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u043D\u043D\u044B\u0439, \u0432\u0441\u043F\u044B\u043B\u044C\u0447\u0438\u0432\u044B\u0439,
    \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439,
    \u043D\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439.  \u0422\u0438\u0445\u043E
    \u0440\u0435\u0432\u043D\u043E\u0441\u0442\u043D\u043E \u043E\u0431\u0435\u0440\u0435\u0433\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0431\u0435\u0441\u0446\u0435\u043D\u043D\u044B\u0435
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F (\u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0434\u0430\u043D\u043D\u044B\u0435 \u043E \u041C\u0430\u0440\u0441\u0435) \u0438
    \u043D\u0435 \u0445\u043E\u0442\u0435\u043B \u0434\u0435\u043B\u0438\u0442\u044C\u0441\u044F
    \u0438\u043C\u0438 \u0441 \u043C\u043E\u043B\u043E\u0434\u044B\u043C \u043A\u043E\u043D\u043A\u0443\u0440\u0435\u043D\u0442\u043E\u043C.
    \u041A\u0435\u043F\u043B\u0435\u0440 \u0436\u0438\u043B \u0432 \u041F\u0440\u0430\u0433\u0435
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432 \u043D\u0438\u0449\u0435\u0442\u0435,
    \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044F \u0441\u0435\u0431\u044F \u0443\u043D\u0438\u0436\u0435\u043D\u043D\u044B\u043C
    \u0441\u043B\u0443\u0433\u043E\u0439. \u041A\u0435\u043F\u043B\u0435\u0440 \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0422\u0438\u0445\u043E \u0433\u043D\u0435\u0432\u043D\u043E\u0435 \u043F\u0438\u0441\u044C\u043C\u043E,
    \u0433\u0434\u0435 \u043E\u0431\u0432\u0438\u043D\u0438\u043B \u0435\u0433\u043E
    \u0432 \u0441\u043A\u0430\u0440\u0435\u0434\u043D\u043E\u0441\u0442\u0438 \u0438
    \u0434\u0435\u0441\u043F\u043E\u0442\u0438\u0437\u043C\u0435, \u0438 \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0443\u0448\u0435\u043B. \u041E\u0434\u043D\u0430\u043A\u043E \u0447\u0435\u0440\u0435\u0437
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0435\u0441\u044F\u0446\u0435\u0432
    \u041A\u0435\u043F\u043B\u0435\u0440 \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u0431\u044B\u043B \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F, \u043F\u0440\u0438\u0437\u043D\u0430\u0432,
    \u0447\u0442\u043E \u043D\u0438\u0433\u0434\u0435 \u043D\u0435 \u0441\u043C\u043E\u0436\u0435\u0442
    \u043D\u0430\u0439\u0442\u0438 \u043B\u0443\u0447\u0448\u0438\u0445 \u0434\u0430\u043D\u043D\u044B\u0445
    \u0434\u043B\u044F \u0441\u0432\u043E\u0438\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. 
    \u0418\u0445 \u043F\u0440\u0438\u043C\u0438\u0440\u0435\u043D\u0438\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u043E\u0441\u044C,
    \u043D\u043E \u0434\u043B\u0438\u043B\u043E\u0441\u044C \u043D\u0435\u0434\u043E\u043B\u0433\u043E.
    **24 \u043E\u043A\u0442\u044F\u0431\u0440\u044F 1601 \u0433\u043E\u0434\u0430**
    \u0422\u0438\u0445\u043E \u0411\u0440\u0430\u0433\u0435 \u0441\u043A\u043E\u0440\u043E\u043F\u043E\u0441\u0442\u0438\u0436\u043D\u043E
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F (\u043F\u043E \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u0432\u0435\u0440\u0441\u0438\u0439, \u043E\u0442 \u0440\u0430\u0437\u0440\u044B\u0432\u0430
    \u043C\u043E\u0447\u0435\u0432\u043E\u0433\u043E \u043F\u0443\u0437\u044B\u0440\u044F,
    \u043F\u043E \u0434\u0440\u0443\u0433\u043E\u0439 \u2014 \u043E\u0442 \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F,
    \u0445\u043E\u0442\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F \u0432\u043E\u043B\u043E\u0441
    \u0422\u0438\u0445\u043E \u044D\u0442\u0443 \u0432\u0435\u0440\u0441\u0438\u044E
    \u043D\u0435 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044E\u0442).  
    \u041F\u0435\u0440\u0435\u0434 \u0441\u043C\u0435\u0440\u0442\u044C\u044E \u0422\u0438\u0445\u043E
    \u043F\u0435\u0440\u0435\u0434\u0430\u043B \u041A\u0435\u043F\u043B\u0435\u0440\u0443
    \u0441\u0432\u043E\u0438 \u0434\u0430\u043D\u043D\u044B\u0435 \u0438 \u043D\u0430\u0437\u043D\u0430\u0447\u0438\u043B
    \u0435\u0433\u043E \u0441\u0432\u043E\u0438\u043C \u043F\u0440\u0435\u0435\u043C\u043D\u0438\u043A\u043E\u043C
    \u043D\u0430 \u043F\u043E\u0441\u0442\u0443 **\u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430**. \u041A\u0435\u043F\u043B\u0435\u0440
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u0441\u0442\u0443\u043F
    \u043A \u0430\u0440\u0445\u0438\u0432\u0430\u043C, \u043D\u043E \u0441\u0435\u043C\u044C\u044F
    \u0422\u0438\u0445\u043E \u0434\u043E\u043B\u0433\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0441\u0443\u0434\u0438\u043B\u0430\u0441\u044C \u0441 \u043D\u0438\u043C \u0437\u0430
    \u043F\u0440\u0430\u0432\u043E \u043E\u0431\u043B\u0430\u0434\u0430\u043D\u0438\u044F
    \u0442\u0430\u0431\u043B\u0438\u0446\u0430\u043C\u0438, \u0438 \u043E\u043D \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u0431\u044B\u043B \u0432\u044B\u043A\u0443\u043F\u0430\u0442\u044C \u0434\u0430\u043D\u043D\u044B\u0435
    \u0443 \u043D\u0430\u0441\u043B\u0435\u0434\u043D\u0438\u043A\u043E\u0432.  \u0418\u043C\u0435\u043D\u043D\u043E
    \u0432 \u041F\u0440\u0430\u0433\u0435, \u043E\u0431\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u044F
    \u0434\u0430\u043D\u043D\u044B\u0435 \u041C\u0430\u0440\u0441\u0430, \u041A\u0435\u043F\u043B\u0435\u0440
    \u043C\u0435\u0436\u0434\u0443 1601 \u0438 1609 \u0433\u043E\u0434\u0430\u043C\u0438
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0441\u0432\u043E\u0438\u0445
    \u043F\u0435\u0440\u0432\u044B\u0445 \u0434\u0432\u0443\u0445 \u0437\u0430\u043A\u043E\u043D\u043E\u0432.
    \u0412 \u041F\u0440\u0430\u0433\u0435 \u0436\u0435 \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0442\u0440\u0443\u0434\u044B \u043F\u043E \u043E\u043F\u0442\u0438\u043A\u0435
    \u0438 \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F.  \u0412 1611 \u0433\u043E\u0434\u0443
    \u0432 \u041F\u0440\u0430\u0433\u0435 \u0441\u043B\u0443\u0447\u0438\u043B\u0430\u0441\u044C
    \u0441\u0435\u0440\u0438\u044F \u0443\u0434\u0430\u0440\u043E\u0432 \u0441\u0443\u0434\u044C\u0431\u044B:
    \u0443\u043C\u0435\u0440 \u0435\u0433\u043E \u043B\u044E\u0431\u0438\u043C\u044B\u0439
    \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439 \u0441\u044B\u043D \u0424\u0440\u0438\u0434\u0440\u0438\u0445,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0442\u044F\u0436\u0435\u043B\u043E \u0437\u0430\u0431\u043E\u043B\u0435\u043B\u0430
    \u0438 \u0432\u0441\u043A\u043E\u0440\u0435 \u0443\u043C\u0435\u0440\u043B\u0430
    \u0435\u0433\u043E \u0436\u0435\u043D\u0430 \u0411\u0430\u0440\u0431\u0430\u0440\u0430
    \u043E\u0442 \u0441\u044B\u043F\u043D\u043E\u0433\u043E \u0442\u0438\u0444\u0430.
    \u0418\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440 \u0420\u0443\u0434\u043E\u043B\u044C\u0444
    II, \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C \u041A\u0435\u043F\u043B\u0435\u0440\u0430,
    \u0441\u043E\u0448\u0435\u043B \u0441 \u0443\u043C\u0430 \u0438 \u0431\u044B\u043B
    \u0441\u0432\u0435\u0440\u0433\u043D\u0443\u0442 \u0431\u0440\u0430\u0442\u043E\u043C.
    \u041A\u0435\u043F\u043B\u0435\u0440 \u043E\u0441\u0442\u0430\u043B\u0441\u044F
    \u0431\u0435\u0437 \u0437\u0430\u0449\u0438\u0442\u044B \u0438 \u0431\u0435\u0437
    \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044F.  ### \U0001F4DC
    \u0420\u0430\u0431\u043E\u0442\u0430. \u041B\u0438\u043D\u0446 (1612\u20131626):
    \u0412\u0442\u043E\u0440\u043E\u0439 \u0431\u0440\u0430\u043A, \u043F\u0440\u043E\u0446\u0435\u0441\u0441
    \u043E \u043A\u043E\u043B\u0434\u043E\u0432\u0441\u0442\u0432\u0435 \u0438 \"\u0413\u0430\u0440\u043C\u043E\u043D\u0438\u044F
    \u043C\u0438\u0440\u0430\"  \u0412 1612 \u0433\u043E\u0434\u0443 \u041A\u0435\u043F\u043B\u0435\u0440
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0433\u043E\u0440\u043E\u0434
    **\u041B\u0438\u043D\u0446**, \u043F\u043E\u043B\u0443\u0447\u0438\u0432 \u043C\u0435\u0441\u0442\u043E
    \u043F\u0440\u043E\u0432\u0438\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0412\u0435\u0440\u0445\u043D\u0435\u0439
    \u0410\u0432\u0441\u0442\u0440\u0438\u0438. \u042D\u0442\u043E \u0431\u044B\u043B
    \u043C\u0435\u043D\u0435\u0435 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439,
    \u043D\u043E \u0431\u043E\u043B\u0435\u0435 \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u044B\u0439
    \u043F\u043E\u0441\u0442.  \u0412 1613 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439
    \u0440\u0430\u0437 \u043D\u0430 **\u0421\u044E\u0437\u0430\u043D\u043D\u0435
    \u0420\u043E\u0439\u0442\u0438\u043D\u0433\u0435\u0440**, \u0434\u043E\u0447\u0435\u0440\u0438
    \u0440\u0435\u0437\u0447\u0438\u043A\u0430 \u043F\u043E \u0434\u0435\u0440\u0435\u0432\u0443.
    \u042D\u0442\u043E\u0442 \u0431\u0440\u0430\u043A \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C, \u0421\u044E\u0437\u0430\u043D\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0437\u0430\u0431\u043E\u0442\u043B\u0438\u0432\u043E\u0439,
    \u043D\u043E \u0438 \u0432 \u044D\u0442\u043E\u043C \u0431\u0440\u0430\u043A\u0435
    \u0438\u0437 \u0441\u0435\u043C\u0438 \u0440\u043E\u0434\u0438\u0432\u0448\u0438\u0445\u0441\u044F
    \u0434\u0435\u0442\u0435\u0439 \u0432\u044B\u0436\u0438\u043B\u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0434\u0432\u043E\u0435.  \u0421\u0430\u043C\u0430\u044F \u0442\u0435\u043C\u043D\u0430\u044F
    \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0430 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438
    \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0443\u043B\u0430\u0441\u044C \u0432
    1615 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E
    \u043C\u0430\u0442\u044C, **\u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0430
    \u041A\u0435\u043F\u043B\u0435\u0440**, \u0431\u044B\u043B\u0430 \u0430\u0440\u0435\u0441\u0442\u043E\u0432\u0430\u043D\u0430
    \u043F\u043E \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u044E \u0432 **\u043A\u043E\u043B\u0434\u043E\u0432\u0441\u0442\u0432\u0435**.
    \u041A\u0442\u043E-\u0442\u043E \u0438\u0437 \u0441\u043E\u0441\u0435\u0434\u0435\u0439
    \u043E\u0431\u0432\u0438\u043D\u0438\u043B \u0435\u0435 \u0432 \u0442\u043E\u043C,
    \u0447\u0442\u043E \u043E\u043D\u0430 \u043F\u0440\u0438\u0433\u043E\u0442\u043E\u0432\u0438\u043B\u0430
    \"\u0434\u044C\u044F\u0432\u043E\u043B\u044C\u0441\u043A\u043E\u0435 \u0437\u0435\u043B\u044C\u0435\".
    \u041D\u0430\u0447\u0430\u043B\u0441\u044F \u0441\u0443\u0434\u0435\u0431\u043D\u044B\u0439
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441, \u0434\u043B\u0438\u0432\u0448\u0438\u0439\u0441\u044F
    \u0446\u0435\u043B\u044B\u0445 6 \u043B\u0435\u0442 (\u0434\u043E 1621 \u0433\u043E\u0434\u0430).
    \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0435 \u0433\u0440\u043E\u0437\u0438\u043B\u0430
    \u043A\u0430\u0437\u043D\u044C \u0447\u0435\u0440\u0435\u0437 \u0441\u043E\u0436\u0436\u0435\u043D\u0438\u0435.  
    \u041A\u0435\u043F\u043B\u0435\u0440 \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E
    \u043F\u0440\u0435\u0440\u0432\u0430\u043B \u0432\u0441\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0437\u0430\u043D\u044F\u0442\u0438\u044F \u0438 \u0431\u0440\u043E\u0441\u0438\u043B
    \u0432\u0441\u0435 \u0441\u0438\u043B\u044B \u043D\u0430 \u0437\u0430\u0449\u0438\u0442\u0443
    \u043C\u0430\u0442\u0435\u0440\u0438. \u041E\u043D \u043B\u0438\u0447\u043D\u043E
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u044E\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u043E\u0437\u0440\u0430\u0436\u0435\u043D\u0438\u044F, \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B
    \u043F\u0435\u0440\u0435\u0441\u043C\u043E\u0442\u0440\u0430 \u0434\u0435\u043B\u0430,
    \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u0430\u043B \u0430\u0434\u0432\u043E\u043A\u0430\u0442\u043E\u0432
    \u0438 \u0434\u0430\u0436\u0435 \u043F\u0435\u0440\u0435\u0432\u0435\u0437 \u043C\u0430\u0442\u044C
    \u0432 \u041B\u0438\u043D\u0446, \u0447\u0442\u043E\u0431\u044B \u043E\u043D\u0430
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0434 \u0435\u0433\u043E \u043F\u0440\u0438\u0441\u043C\u043E\u0442\u0440\u043E\u043C.
    \u0412 1621 \u0433\u043E\u0434\u0443, \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0435\u0433\u043E \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u043C
    \u0443\u0441\u0438\u043B\u0438\u044F\u043C \u0438 \u044E\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438\u0437\u0432\u043E\u0440\u043E\u0442\u043B\u0438\u0432\u043E\u0441\u0442\u0438,
    \u0441\u0443\u0434 \u043E\u043F\u0440\u0430\u0432\u0434\u0430\u043B \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0443.
    \u041E\u0434\u043D\u0430\u043A\u043E \u043F\u043E\u0441\u043B\u0435 \u043F\u044B\u0442\u043E\u043A
    \u0438 \u0434\u043E\u043B\u0433\u043E\u0433\u043E \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F
    \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0441\u043B\u043E\u043C\u043B\u0435\u043D\u0430
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438 \u0438 \u0443\u043C\u0435\u0440\u043B\u0430
    \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043C\u0435\u0441\u044F\u0446\u0435\u0432 \u043F\u043E\u0441\u043B\u0435 \u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0435\u043D\u0438\u044F. 
    \u0412 \u044D\u0442\u043E\u0442 \u0436\u0435 \u0442\u044F\u0436\u0435\u043B\u044B\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 (1619) \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0439
    \u0442\u0440\u0443\u0434 **\xAB\u0413\u0430\u0440\u043C\u043E\u043D\u0438\u044F
    \u043C\u0438\u0440\u0430\xBB**, \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0438\u0439
    \u0422\u0440\u0435\u0442\u0438\u0439 \u0437\u0430\u043A\u043E\u043D \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442.  \u0412 1626 \u0433\u043E\u0434\u0443,
    \u0432 \u0440\u0430\u0437\u0433\u0430\u0440 \u0422\u0440\u0438\u0434\u0446\u0430\u0442\u0438\u043B\u0435\u0442\u043D\u0435\u0439
    \u0432\u043E\u0439\u043D\u044B, \u041B\u0438\u043D\u0446 \u0431\u044B\u043B \u043E\u0441\u0430\u0436\u0434\u0435\u043D,
    \u0433\u043E\u0440\u043E\u0434 \u0432\u0437\u0431\u0443\u043D\u0442\u043E\u0432\u0430\u043B\u0441\u044F,
    \u0438 \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u043E\u0432
    \u0438\u0437\u0433\u043D\u0430\u043B\u0438. \u041A\u0435\u043F\u043B\u0435\u0440
    \u0441 \u0441\u0435\u043C\u044C\u0435\u0439 \u0431\u0435\u0436\u0430\u043B, \u043E\u0441\u0442\u0430\u0432\u0438\u0432
    \u043F\u043E\u0447\u0442\u0438 \u0432\u0441\u0435 \u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u043E. 
    ### \U0001F6B6\u200D\u2642\uFE0F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u0441\u043C\u0435\u0440\u0442\u044C (1626\u20131630) 
    \u0421\u0435\u043C\u044C\u044F \u041A\u0435\u043F\u043B\u0435\u0440\u0430 \u0436\u0438\u043B\u0430
    \u0432 \u0441\u043A\u0438\u0442\u0430\u043D\u0438\u044F\u0445. \u041E\u043D \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 **\u0423\u043B\u044C\u043C**, \u0433\u0434\u0435 \u0432 1627 \u0433\u043E\u0434\u0443
    \u043D\u0430\u043A\u043E\u043D\u0435\u0446 \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B
    \u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u0438
    \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B \u2014 **\xAB\u0420\u0443\u0434\u043E\u043B\u044C\u0444\u043E\u0432\u044B
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B\xBB**, \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u044B\u0435
    \u0432 \u0447\u0435\u0441\u0442\u044C \u043F\u043E\u043A\u043E\u0439\u043D\u043E\u0433\u043E
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430 \u0420\u0443\u0434\u043E\u043B\u044C\u0444\u0430.
    \u0417\u0430 \u044D\u0442\u0443 \u0440\u0430\u0431\u043E\u0442\u0443 \u0435\u043C\u0443
    \u043F\u043E\u043B\u0430\u0433\u0430\u043B\u043E\u0441\u044C \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043E\u0437\u043D\u0430\u0433\u0440\u0430\u0436\u0434\u0435\u043D\u0438\u0435
    \u043E\u0442 \u043A\u0430\u0437\u043D\u044B, \u043D\u043E \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0441\u043A\u0430\u044F
    \u043A\u0430\u0437\u043D\u0430 \u0431\u044B\u043B\u0430 \u043F\u0443\u0441\u0442\u0430
    \u0438\u0437-\u0437\u0430 \u0432\u043E\u0439\u043D\u044B.  \u041E\u0442\u0447\u0430\u044F\u0432\u0448\u0438\u0441\u044C
    \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0434\u0435\u043D\u044C\u0433\u0438,
    \u0432 1628 \u0433\u043E\u0434\u0443 \u041A\u0435\u043F\u043B\u0435\u0440 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u043D\u0430 \u0441\u043B\u0443\u0436\u0431\u0443 \u043A \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u043C\u0443
    \u043F\u043E\u043B\u043A\u043E\u0432\u043E\u0434\u0446\u0443 **\u0410\u043B\u044C\u0431\u0440\u0435\u0445\u0442\u0443
    \u0444\u043E\u043D \u0412\u0430\u043B\u043B\u0435\u043D\u0448\u0442\u0435\u0439\u043D\u0443**
    \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 **\u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u043E\u0433\u043E
    \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0430**. \u041F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u0433\u043E\u0440\u043E\u0434 **\u0421\u0430\u0433\u0430\u043D** (\u0421\u0438\u043B\u0435\u0437\u0438\u044F,
    \u043D\u044B\u043D\u0435 \u041F\u043E\u043B\u044C\u0448\u0430). \u041A\u0435\u043F\u043B\u0435\u0440
    \u043F\u0440\u0435\u0437\u0438\u0440\u0430\u043B \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u044E
    \u043A\u0430\u043A \u043D\u0430\u0443\u043A\u0443, \u043D\u043E \u043A\u0430\u043A
    \u0440\u0435\u043C\u0435\u0441\u043B\u043E \u043E\u043D\u0430 \u043A\u043E\u0440\u043C\u0438\u043B\u0430
    \u0435\u0433\u043E. \u041E\u043D \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B
    \u0433\u043E\u0440\u043E\u0441\u043A\u043E\u043F\u044B \u0434\u043B\u044F \u0412\u0430\u043B\u043B\u0435\u043D\u0448\u0442\u0435\u0439\u043D\u0430,
    \u0445\u043E\u0442\u044F \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0439 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435
    \u043F\u0438\u0441\u0430\u043B, \u0447\u0442\u043E \"\u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u044F
    \u2014 \u0433\u043B\u0443\u043F\u0430\u044F \u0434\u043E\u0447\u043A\u0430 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438,
    \u043D\u043E \u0431\u0435\u0437 \u043D\u0435\u0435 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F,
    \u043A\u0430\u043A \u043C\u0430\u0442\u044C, \u0443\u043C\u0435\u0440\u043B\u0430
    \u0431\u044B \u0441 \u0433\u043E\u043B\u043E\u0434\u0443\".  \u0412 \u043E\u043A\u0442\u044F\u0431\u0440\u0435
    1630 \u0433\u043E\u0434\u0430, \u043D\u0430\u0434\u0435\u044F\u0441\u044C \u0432\u0441\u0435-\u0442\u0430\u043A\u0438
    \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0447\u0430\u0441\u0442\u044C
    \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u044C\u044F \u0443 \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430,
    \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432
    \u0420\u0435\u0433\u0435\u043D\u0441\u0431\u0443\u0440\u0433. 15 \u043D\u043E\u044F\u0431\u0440\u044F
    \u043E\u043D \u043F\u0440\u0438\u0431\u044B\u043B \u0432 \u0433\u043E\u0440\u043E\u0434.
    \u041E\u043D \u0441\u0438\u043B\u044C\u043D\u043E \u043F\u0440\u043E\u0441\u0442\u0443\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0434\u043E\u0440\u043E\u0433\u0435, \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C
    \u043B\u0438\u0445\u043E\u0440\u0430\u0434\u043A\u0430. **15 \u043D\u043E\u044F\u0431\u0440\u044F
    1630 \u0433\u043E\u0434\u0430** \u0418\u043E\u0433\u0430\u043D\u043D \u041A\u0435\u043F\u043B\u0435\u0440
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 \u0433\u043E\u0441\u0442\u0438\u043D\u0438\u0446\u0435
    \u0432 \u0420\u0435\u0433\u0435\u043D\u0441\u0431\u0443\u0440\u0433\u0435, \u043D\u0435
    \u0434\u043E\u0436\u0438\u0432 \u0434\u043E 59 \u043B\u0435\u0442.   \u0411\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E
    \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0434\u043D\u0435\u0439 \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    \u0433\u0440\u043E\u0431\u043D\u0438\u0446\u0430, \u0433\u0434\u0435 \u0435\u0433\u043E
    \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0438\u043B\u0438, \u0431\u044B\u043B\u0430
    \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u0430 \u0430\u0440\u043C\u0438\u0435\u0439
    \u0448\u0432\u0435\u0434\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u044F
    \u0413\u0443\u0441\u0442\u0430\u0432\u0430-\u0410\u0434\u043E\u043B\u044C\u0444\u0430
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0422\u0440\u0438\u0434\u0446\u0430\u0442\u0438\u043B\u0435\u0442\u043D\u0435\u0439
    \u0432\u043E\u0439\u043D\u044B, \u0438 \u0442\u043E\u0447\u043D\u043E\u0435 \u043C\u0435\u0441\u0442\u043E
    \u0435\u0433\u043E \u0437\u0430\u0445\u043E\u0440\u043E\u043D\u0435\u043D\u0438\u044F
    \u0443\u0442\u0435\u0440\u044F\u043D\u043E \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430.
    \u0421\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C \u043B\u0438\u0448\u044C
    \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0440\u0443\u0447\u043D\u043E
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u043D\u0430\u044F \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u044F: 
    > *\xAB\u042F \u043C\u0435\u0440\u0438\u043B \u043D\u0435\u0431\u0435\u0441\u0430,
    \u0442\u0435\u043F\u0435\u0440\u044C \u043C\u0435\u0440\u044F\u044E \u0442\u0435\u043D\u0438.
    / \u0414\u0443\u0445\u043E\u043C \u0431\u044B\u043B \u044F \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u043C,
    \u0442\u0435\u043B\u043E \u0437\u0434\u0435\u0441\u044C \u043F\u043E\u043A\u043E\u0438\u0442\u0441\u044F
    \u0437\u0435\u043C\u043D\u043E\u0435\xBB.*  ### \U0001F91D \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438 
    - **\u041C\u0438\u0445\u0430\u044D\u043B\u044C \u041C\u0451\u0441\u0442\u043B\u0438\u043D**
    (\u0443\u0447\u0438\u0442\u0435\u043B\u044C): \u0421\u0430\u043C\u0430\u044F
    \u0442\u0435\u043F\u043B\u0430\u044F, \u043F\u043E\u0447\u0442\u0438 \u0441\u044B\u043D\u043E\u0432\u044C\u044F
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F. \u041C\u0451\u0441\u0442\u043B\u0438\u043D
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B \u041A\u0435\u043F\u043B\u0435\u0440\u0430
    \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C, \u043E\u043D\u0438 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438\u0441\u044C,
    \u0438 \u041A\u0435\u043F\u043B\u0435\u0440 \u0432\u0441\u0435\u0433\u0434\u0430
    \u0441 \u0431\u043B\u0430\u0433\u043E\u0433\u043E\u0432\u0435\u043D\u0438\u0435\u043C
    \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B \u043E \u043D\u0435\u043C.
    - **\u0422\u0438\u0445\u043E \u0411\u0440\u0430\u0433\u0435** (\u0441\u0442\u0430\u0440\u0448\u0438\u0439
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430): \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u043E\u0442 \"\u0445\u043E\u043B\u043E\u0434\u043D\u043E\u0439 \u0432\u043E\u0439\u043D\u044B\"
    \u0434\u043E \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u044E\u0437\u0430. \u041D\u0435\u043D\u0430\u0432\u0438\u0441\u0442\u044C
    \u043A \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0443 \u0434\u0440\u0443\u0433
    \u0434\u0440\u0443\u0433\u0430 \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0430\u043B\u0430\u0441\u044C
    \u0441 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435\u043C \u043A \u0434\u0430\u043D\u043D\u044B\u043C
    \u0434\u0440\u0443\u0433 \u0434\u0440\u0443\u0433\u0430. \u0411\u0435\u0437 \u0422\u0438\u0445\u043E
    \u043D\u0435 \u0431\u044B\u043B\u043E \u0431\u044B \u0437\u0430\u043A\u043E\u043D\u043E\u0432
    \u041A\u0435\u043F\u043B\u0435\u0440\u0430, \u0431\u0435\u0437 \u041A\u0435\u043F\u043B\u0435\u0440\u0430
    \u0434\u0430\u043D\u043D\u044B\u0435 \u0422\u0438\u0445\u043E \u0442\u0430\u043A
    \u0438 \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C \u0431\u044B \u0433\u0440\u0443\u0434\u043E\u0439
    \u0446\u0438\u0444\u0440. - **\u0413\u0430\u043B\u0438\u043B\u0435\u043E \u0413\u0430\u043B\u0438\u043B\u0435\u0439**
    (\u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A): \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0437\u0430\u043E\u0447\u043D\u044B\u0435 \u0438 \u043A\u0440\u0430\u0439\u043D\u0435
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u043D\u044B\u0435. \u041A\u0435\u043F\u043B\u0435\u0440
    \u043F\u043E\u0441\u043B\u0430\u043B \u0413\u0430\u043B\u0438\u043B\u0435\u044E
    \u0432 \u043F\u043E\u0434\u0430\u0440\u043E\u043A \u0441\u0432\u043E\u044E \"\u0422\u0430\u0439\u043D\u0443\",
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u0435\u0433\u043E \u0445\u0432\u0430\u043B\u0438\u043B,
    \u043D\u043E \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u0442\u044C
    \u0437\u0430\u043A\u043E\u043D\u044B \u041A\u0435\u043F\u043B\u0435\u0440\u0430
    (\u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F \u043D\u0430 \u043F\u043E\u0437\u0438\u0446\u0438\u044F\u0445
    \u043A\u0440\u0443\u0433\u043E\u0432\u044B\u0445 \u043E\u0440\u0431\u0438\u0442).
    \u041A\u0435\u043F\u043B\u0435\u0440 \u043F\u0440\u043E\u0441\u0438\u043B \u0443
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u0435\u0433\u043E \u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0442\u0440\u0443\u0431\u0443, \u043D\u043E \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0441\u0442\u0440\u0443\u0441\u0438\u043B \u0438 \u043D\u0435 \u043F\u043E\u0434\u0435\u043B\u0438\u043B\u0441\u044F
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0435\u0439. \u041A\u0435\u043F\u043B\u0435\u0440
    \u0437\u043B\u0438\u043B\u0441\u044F \u043D\u0430 \u043D\u0435\u0433\u043E \u0437\u0430
    \u0442\u0440\u0443\u0441\u043E\u0441\u0442\u044C (\u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0441\u043A\u0440\u044B\u0432\u0430\u043B \u0441\u0432\u043E\u0438 \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F),
    \u0445\u043E\u0442\u044F \u0438 \u0432\u043E\u0441\u0445\u0438\u0449\u0430\u043B\u0441\u044F
    \u0435\u0433\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F\u043C\u0438
    \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u043E\u0432 \u042E\u043F\u0438\u0442\u0435\u0440\u0430.
    - **\u0418\u0441\u0430\u0430\u043A \u041D\u044C\u044E\u0442\u043E\u043D** (\u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C):
    \u041E\u043D\u0438 \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u043B\u0438\u0441\u044C
    (\u041D\u044C\u044E\u0442\u043E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0433\u043E\u0434 \u0441\u043C\u0435\u0440\u0442\u0438 \u041A\u0435\u043F\u043B\u0435\u0440\u0430).
    \u041E\u0434\u043D\u0430\u043A\u043E \u041D\u044C\u044E\u0442\u043E\u043D \u0434\u043E\u0441\u043A\u043E\u043D\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u0443\u0447\u0438\u043B \u0442\u0440\u0443\u0434\u044B \u041A\u0435\u043F\u043B\u0435\u0440\u0430
    \u0438, \u0432\u044B\u0432\u0435\u0434\u044F \u0437\u0430\u043A\u043E\u043D \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0433\u043E
    \u0442\u044F\u0433\u043E\u0442\u0435\u043D\u0438\u044F, \u043F\u0440\u044F\u043C\u043E
    \u0441\u0441\u044B\u043B\u0430\u043B\u0441\u044F \u043D\u0430 \"\u0442\u0440\u0438
    \u0437\u0430\u043A\u043E\u043D\u0430 \u041A\u0435\u043F\u043B\u0435\u0440\u0430\"
    \u043A\u0430\u043A \u043D\u0430 \u044D\u043C\u043F\u0438\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0431\u0430\u0437\u0443 \u0434\u043B\u044F \u0441\u0432\u043E\u0435\u0439 \u0442\u0435\u043E\u0440\u0438\u0438."
  personalLifeEn: 
  shortBioRu: "\u0418\u043E\u0433\u0430\u043D\u043D \u041A\u0435\u043F\u043B\u0435\u0440
    (1571\u20131630) \u2014 \u0444\u0438\u0433\u0443\u0440\u0430, \u0441\u0442\u043E\u044F\u0449\u0430\u044F
    \u043D\u0430 \u0441\u0442\u044B\u043A\u0435 \u044D\u043F\u043E\u0445. \u0415\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043E \u0442\u043E\u043C, \u043A\u0430\u043A \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0439 \u0447\u0435\u043B\u043E\u0432\u0435\u043A
    \u0441 \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u0441\u043A\u043B\u0430\u0434\u043E\u043C
    \u0443\u043C\u0430, \u0432\u043E\u043E\u0440\u0443\u0436\u0435\u043D\u043D\u044B\u0439
    \u0442\u0435\u0440\u043F\u0435\u043D\u0438\u0435\u043C \u0438 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E,
    \u0437\u0430\u043C\u0435\u043D\u0438\u043B \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u0435
    \u043A\u0440\u0443\u0433\u0438 \u043D\u0430 \u044D\u043B\u043B\u0438\u043F\u0441\u044B
    \u0438 \u0442\u0435\u043C \u0441\u0430\u043C\u044B\u043C \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438, \u0441\u043E\u0437\u0434\u0430\u0432
    \u043E\u0441\u043D\u043E\u0432\u0443 \u0434\u043B\u044F \u0437\u0430\u043A\u043E\u043D\u0430
    \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0433\u043E \u0442\u044F\u0433\u043E\u0442\u0435\u043D\u0438\u044F
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430.  ### \U0001F9EC \u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B: \u0411\u043E\u043B\u0435\u0437\u043D\u0438, \u0431\u0435\u0434\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043F\u0435\u0440\u0432\u044B\u0439 \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u0437\u0432\u0435\u0437\u0434\u0430\u043C  \u0418\u043E\u0433\u0430\u043D\u043D
    \u041A\u0435\u043F\u043B\u0435\u0440 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    27 \u0434\u0435\u043A\u0430\u0431\u0440\u044F 1571 \u0433\u043E\u0434\u0430 \u0432
    \u0438\u043C\u043F\u0435\u0440\u0441\u043A\u043E\u043C \u0433\u043E\u0440\u043E\u0434\u0435
    \u0412\u0430\u0439\u043B\u044C-\u0434\u0435\u0440-\u0428\u0442\u0430\u0434\u0442
    (\u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E \u043E\u0442 \u0428\u0442\u0443\u0442\u0433\u0430\u0440\u0442\u0430)
    \u0432 \u043E\u0431\u0435\u0434\u043D\u0435\u0432\u0448\u0435\u0439 \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u0441\u043A\u043E\u0439
    \u0441\u0435\u043C\u044C\u0435. \u0415\u0433\u043E \u0434\u0435\u0442\u0441\u0442\u0432\u043E
    \u0431\u044B\u043B\u043E \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u043E \u0431\u0435\u0434\u043D\u043E\u0441\u0442\u044C\u044E
    \u0438 \u0431\u043E\u043B\u0435\u0437\u043D\u044F\u043C\u0438. \u041E\u0442\u0435\u0446,
    \u0413\u0435\u043D\u0440\u0438\u0445 \u041A\u0435\u043F\u043B\u0435\u0440, \u0431\u044B\u043B
    \u043D\u0430\u0435\u043C\u043D\u0438\u043A\u043E\u043C \u0438 \u043F\u043E\u043A\u0438\u043D\u0443\u043B
    \u0441\u0435\u043C\u044C\u044E, \u043A\u043E\u0433\u0434\u0430 \u0418\u043E\u0433\u0430\u043D\u043D\u0443
    \u0431\u044B\u043B\u043E \u043F\u044F\u0442\u044C \u043B\u0435\u0442 (\u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043E\u043D \u043F\u043E\u0433\u0438\u0431 \u043D\u0430 \u0432\u043E\u0439\u043D\u0435).
    \u041C\u0430\u0442\u044C, \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0430 \u0413\u0443\u043B\u044C\u0434\u0435\u043D\u043C\u0430\u043D\u043D,
    \u0434\u043E\u0447\u044C \u0442\u0440\u0430\u043A\u0442\u0438\u0440\u0449\u0438\u043A\u0430,
    \u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043B\u0430 \u043D\u0430
    \u0436\u0438\u0437\u043D\u044C \u043A\u0430\u043A \u0446\u0435\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0430
    \u0438 \u0442\u0440\u0430\u0432\u043D\u0438\u0446\u0430. \u041F\u043E\u0437\u0436\u0435,
    \u0432 \u0442\u044F\u0436\u0435\u043B\u044B\u0439 \u0434\u043B\u044F \u0441\u0435\u043C\u044C\u0438
    \u043F\u0435\u0440\u0438\u043E\u0434, \u0435\u0435 \u043E\u0431\u0432\u0438\u043D\u0438\u043B\u0438
    \u0432 \u043A\u043E\u043B\u0434\u043E\u0432\u0441\u0442\u0432\u0435, \u0438 \u041A\u0435\u043F\u043B\u0435\u0440\u0443
    \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C \u043F\u0440\u0438\u043B\u043E\u0436\u0438\u0442\u044C
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435 \u0443\u0441\u0438\u043B\u0438\u044F,
    \u0447\u0442\u043E\u0431\u044B \u0441\u043F\u0430\u0441\u0442\u0438 \u0435\u0435
    \u043E\u0442 \u043A\u043E\u0441\u0442\u0440\u0430.  \u0420\u043E\u0434\u0438\u0432\u0448\u0438\u0439\u0441\u044F
    \u043D\u0435\u0434\u043E\u043D\u043E\u0448\u0435\u043D\u043D\u044B\u043C \u0438
    \u043E\u0441\u043B\u0430\u0431\u043B\u0435\u043D\u043D\u044B\u043C, \u043E\u043D
    \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u043F\u0435\u0440\u0435\u043D\u0435\u0441
    \u043E\u0441\u043F\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u043E\u0441\u043B\u0430\u0431\u0438\u043B\u0430 \u0435\u0433\u043E \u0437\u0440\u0435\u043D\u0438\u0435
    \u0438 \u043F\u043E\u0432\u0440\u0435\u0434\u0438\u043B\u0430 \u0440\u0443\u043A\u0438,
    \u0441\u0434\u0435\u043B\u0430\u0432 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u0443 \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u0435\u043B\u044F-\u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430.
    \u041E\u0434\u043D\u0430\u043A\u043E \u044D\u0442\u043E \u043A\u043E\u043C\u043F\u0435\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043B\u043E\u0441\u044C
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u043C \u0443\u043C\u043E\u043C.
    \u0415\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u0431\u044B\u043B\u0438
    \u0441\u0442\u043E\u043B\u044C \u043E\u0447\u0435\u0432\u0438\u0434\u043D\u044B,
    \u0447\u0442\u043E \u043E\u043D \u0447\u0430\u0441\u0442\u043E \u043F\u043E\u0440\u0430\u0436\u0430\u043B
    \u0438\u043C\u0438 \u043F\u043E\u0441\u0435\u0442\u0438\u0442\u0435\u043B\u0435\u0439
    \u0432 \u0433\u043E\u0441\u0442\u0438\u043D\u0438\u0446\u0435 \u0434\u0435\u0434\u0430.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441 \u043A \u043D\u0435\u0431\u0443 \u043F\u0440\u043E\u0441\u043D\u0443\u043B\u0441\u044F
    \u0440\u0430\u043D\u043E: \u0432 1577 \u0433\u043E\u0434\u0443 \u043C\u0430\u0442\u044C
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0430 \u0435\u043C\u0443 \u0412\u0435\u043B\u0438\u043A\u0443\u044E
    \u043A\u043E\u043C\u0435\u0442\u0443, \u0430 \u0432 1580 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u043B \u043B\u0443\u043D\u043D\u043E\u0435
    \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u0435.  ### \U0001F393 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u0422\u044E\u0431\u0438\u043D\u0433\u0435\u043D\u0430: \u0412\u0441\u0442\u0440\u0435\u0447\u0430
    \u0441 \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439 \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430 
    \u0412 1589 \u0433\u043E\u0434\u0443 \u041A\u0435\u043F\u043B\u0435\u0440 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0422\u044E\u0431\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u0433\u0434\u0435
    \u0438\u0437\u0443\u0447\u0430\u043B \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E
    \u0438 \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044E, \u0433\u043E\u0442\u043E\u0432\u044F\u0441\u044C
    \u0441\u0442\u0430\u0442\u044C \u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0441\u043A\u0438\u043C
    \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u043E\u043C. \u041E\u043D
    \u0431\u044B\u043B \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u043C \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C,
    \u0438 \u0435\u0433\u043E \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E
    \u043F\u0440\u043E\u0434\u043B\u0435\u0432\u0430\u043B\u0438 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F \u0443\u0441\u043F\u0435\u0445\u0430\u043C.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \u0422\u044E\u0431\u0438\u043D\u0433\u0435\u043D\u0435
    \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E \u0441\u043E\u0431\u044B\u0442\u0438\u0435,
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0432\u0448\u0435\u0435 \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C: \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u041C\u0438\u0445\u0430\u044D\u043B\u044C
    \u041C\u0451\u0441\u0442\u043B\u0438\u043D, \u0442\u0430\u0439\u043D\u044B\u0439
    \u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043A \u0433\u0435\u043B\u0438\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0437\u043C\u0430,
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B \u041A\u0435\u043F\u043B\u0435\u0440\u0430
    \u0441 \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439 \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430.
    \u041A\u0435\u043F\u043B\u0435\u0440 \u0441\u0440\u0430\u0437\u0443 \u0441\u0442\u0430\u043B
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C \u043A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430\u043D\u0446\u0435\u043C,
    \u0432\u0438\u0434\u044F \u0432 \u044D\u0442\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u0435
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0443\u0434\u043E\u0431\u043D\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043C\u043E\u0434\u0435\u043B\u044C, \u0430 \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0431\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0437\u0430\u043C\u044B\u0441\u043B\u0430.  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0436\u0435\u043B\u0430\u043D\u0438\u0435 \u0441\u0442\u0430\u0442\u044C
    \u043F\u0430\u0441\u0442\u043E\u0440\u043E\u043C, \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u0441\u043B\u043E\u0436\u0438\u043B\u0430\u0441\u044C \u0438\u043D\u0430\u0447\u0435.
    \u0412 1594 \u0433\u043E\u0434\u0443, \u0435\u0449\u0435 \u0434\u043E \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u044F
    \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F, \u0435\u0433\u043E
    \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u043E\u0432\u0430\u043B\u0438
    \u043D\u0430 \u043C\u0435\u0441\u0442\u043E \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u0432 \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 \u0432 \u0413\u0440\u0430\u0446\u0435 (\u0410\u0432\u0441\u0442\u0440\u0438\u044F).
    \u0415\u043C\u0443 \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C \u043F\u0440\u0438\u043D\u044F\u0442\u044C
    \u044D\u0442\u043E \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435. 
    ### \U0001F4D0 \u0413\u0440\u0430\u0446 (1594\u20131600): \xAB\u041A\u043E\u0441\u043C\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0430\u0439\u043D\u0430\xBB \u0438 \u0431\u0440\u0430\u043A  \u0412 \u0413\u0440\u0430\u0446\u0435
    \u041A\u0435\u043F\u043B\u0435\u0440 \u043D\u0430\u0447\u0430\u043B \u0441\u0432\u043E\u044E
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0443\u044E
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C. \u0417\u0434\u0435\u0441\u044C
    \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u0440\u0430\u043D\u043D\u0435\u0435 \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u0435.
    19 \u0438\u044E\u043B\u044F 1595 \u0433\u043E\u0434\u0430, \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u044F
    \u043D\u0430 \u0443\u0440\u043E\u043A\u0435 \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F
    \u042E\u043F\u0438\u0442\u0435\u0440\u0430 \u0438 \u0421\u0430\u0442\u0443\u0440\u043D\u0430,
    \u043E\u043D \u0437\u0430\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0435
    \u043C\u043D\u043E\u0433\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0438
    \u043C\u043E\u0433\u0443\u0442 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C
    \u043E\u0440\u0431\u0438\u0442\u044B \u043F\u043B\u0430\u043D\u0435\u0442. \u0420\u0430\u0437\u0432\u0438\u0432
    \u044D\u0442\u0443 \u0438\u0434\u0435\u044E, \u043E\u043D \u043F\u0440\u0438\u0448\u0435\u043B
    \u043A \u0432\u044B\u0432\u043E\u0434\u0443, \u0447\u0442\u043E \u043C\u0435\u0436\u0434\u0443
    \u0448\u0435\u0441\u0442\u044C\u044E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C\u0438
    \u0442\u043E\u0433\u0434\u0430 \u043F\u043B\u0430\u043D\u0435\u0442\u0430\u043C\u0438
    (\u043E\u0442 \u041C\u0435\u0440\u043A\u0443\u0440\u0438\u044F \u0434\u043E \u0421\u0430\u0442\u0443\u0440\u043D\u0430)
    \u043D\u0430\u0445\u043E\u0434\u044F\u0442\u0441\u044F \u043F\u044F\u0442\u044C
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0445 \u043F\u043B\u0430\u0442\u043E\u043D\u043E\u0432\u044B\u0445
    \u0442\u0435\u043B. \u0412\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0435 \u0434\u0440\u0443\u0433
    \u0432 \u0434\u0440\u0443\u0433\u0430, \u043E\u043D\u0438 \u0437\u0430\u0434\u0430\u044E\u0442
    \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F \u043C\u0435\u0436\u0434\u0443
    \u043F\u043B\u0430\u043D\u0435\u0442\u043D\u044B\u043C\u0438 \u0441\u0444\u0435\u0440\u0430\u043C\u0438.
    \u0412 1596 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434 \u043F\u043E\u0434 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435\u043C
    \xAB\u0422\u0430\u0439\u043D\u0430 \u043C\u0438\u0440\u043E\u0437\u0434\u0430\u043D\u0438\u044F\xBB
    (*Mysterium Cosmographicum*). \u0425\u043E\u0442\u044F \u043F\u043E\u0437\u0436\u0435
    \u043E\u043D \u043F\u0440\u0438\u0437\u043D\u0430\u043B, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0440\u0430\u0441\u0447\u0435\u0442\u044B \u0431\u044B\u043B\u0438 \u043D\u0435\u0442\u043E\u0447\u043D\u044B,
    \u044D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430
    \u0435\u043C\u0443 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0430 \u0435\u0433\u043E
    \u043A\u0430\u043A \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u043E\u0433\u043E
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430.  \u0412 \u044D\u0442\u043E
    \u0436\u0435 \u0432\u0440\u0435\u043C\u044F \u041A\u0435\u043F\u043B\u0435\u0440
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F. \u0415\u0433\u043E \u0438\u0437\u0431\u0440\u0430\u043D\u043D\u0438\u0446\u0435\u0439
    \u0441\u0442\u0430\u043B\u0430 \u0411\u0430\u0440\u0431\u0430\u0440\u0430 \u041C\u044E\u043B\u043B\u0435\u0440,
    23-\u043B\u0435\u0442\u043D\u044F\u044F \u0441\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0432\u0434\u043E\u0432\u0430. \u0415\u0435 \u043E\u0442\u0435\u0446 \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u0431\u044B\u043B \u043F\u0440\u043E\u0442\u0438\u0432 \u0431\u0440\u0430\u043A\u0430
    \u0441 \u0431\u0435\u0434\u043D\u044B\u043C \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C,
    \u043D\u043E \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u0435 \u0431\u044B\u043B\u043E
    \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043E \u043F\u043E\u0441\u043B\u0435
    \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438 \xAB\u0422\u0430\u0439\u043D\u044B
    \u043C\u0438\u0440\u043E\u0437\u0434\u0430\u043D\u0438\u044F\xBB. \u0412 \u044D\u0442\u043E\u043C
    \u0431\u0440\u0430\u043A\u0435 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C
    \u043F\u044F\u0442\u0435\u0440\u043E \u0434\u0435\u0442\u0435\u0439, \u043D\u043E
    \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u0432\u043E\u0435 \u043F\u0435\u0440\u0435\u0436\u0438\u043B\u0438
    \u043C\u043B\u0430\u0434\u0435\u043D\u0447\u0435\u0441\u0442\u0432\u043E \u2014
    \u0442\u044F\u0436\u0435\u043B\u0430\u044F \u043F\u043E\u0442\u0435\u0440\u044F,
    \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0432\u0448\u0430\u044F
    \u041A\u0435\u043F\u043B\u0435\u0440\u0430 \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C. 
    ### \U0001F451 \u041F\u0440\u0430\u0433\u0430 (1600\u20131612): \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0422\u0438\u0445\u043E \u0411\u0440\u0430\u0433\u0435 \u0438 \xAB\u041D\u043E\u0432\u0430\u044F
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F\xBB  \u0420\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435
    \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u043E\u0432 \u0432
    \u0413\u0440\u0430\u0446\u0435 \u0432\u044B\u043D\u0443\u0434\u0438\u043B\u0438
    \u041A\u0435\u043F\u043B\u0435\u0440\u0430 \u0432 1600 \u0433\u043E\u0434\u0443
    \u043F\u043E\u043A\u0438\u043D\u0443\u0442\u044C \u0433\u043E\u0440\u043E\u0434.
    \u041E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432
    \u041F\u0440\u0430\u0433\u0443, \u043A \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u043C\u0443
    \u0434\u0430\u0442\u0441\u043A\u043E\u043C\u0443 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0443
    \u0422\u0438\u0445\u043E \u0411\u0440\u0430\u0433\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B\u043B \u0438\u043C\u043F\u0435\u0440\u0441\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u043F\u0440\u0438 \u0434\u0432\u043E\u0440\u0435 \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430
    \u0420\u0443\u0434\u043E\u043B\u044C\u0444\u0430 II.  \u0421\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0431\u044B\u043B\u043E \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u044B\u043C.
    \u0422\u0438\u0445\u043E \u0440\u0435\u0432\u043D\u043E\u0441\u0442\u043D\u043E
    \u043E\u0431\u0435\u0440\u0435\u0433\u0430\u043B \u0441\u0432\u043E\u0438 \u0431\u0435\u0441\u0446\u0435\u043D\u043D\u044B\u0435
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0434\u0430\u043D\u043D\u044B\u0435 \u043E \u041C\u0430\u0440\u0441\u0435, \u0438
    \u043D\u0435 \u0441\u043F\u0435\u0448\u0438\u043B \u0434\u0435\u043B\u0438\u0442\u044C\u0441\u044F
    \u0438\u043C\u0438 \u0441 \u041A\u0435\u043F\u043B\u0435\u0440\u043E\u043C. \u041E\u043D
    \u043F\u043E\u0440\u0443\u0447\u0438\u043B \u043C\u043E\u043B\u043E\u0434\u043E\u043C\u0443
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0443 \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u0443\u044E
    \u0437\u0430\u0434\u0430\u0447\u0443 \u2014 \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u044C
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u041C\u0430\u0440\u0441\u0430.
    \u0412\u0441\u043A\u043E\u0440\u0435 \u043F\u043E\u0441\u043B\u0435 \u0438\u0445
    \u0432\u0441\u0442\u0440\u0435\u0447\u0438, \u0432 1601 \u0433\u043E\u0434\u0443,
    \u0422\u0438\u0445\u043E \u0411\u0440\u0430\u0433\u0435 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E
    \u0443\u043C\u0435\u0440. \u041A\u0435\u043F\u043B\u0435\u0440, \u043A \u0435\u0433\u043E
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u043C\u0443 \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u043D\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u043E\u043B\u043D\u043E\u0433\u043E
    \u0434\u043E\u0441\u0442\u0443\u043F\u0430 \u043A \u0434\u0430\u043D\u043D\u044B\u043C
    \u0441\u0440\u0430\u0437\u0443, \u043D\u043E \u0437\u0430\u043D\u044F\u043B \u043C\u0435\u0441\u0442\u043E
    \u0422\u0438\u0445\u043E \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430.  \u0418\u043C\u0435\u043D\u043D\u043E
    \u0432 \u041F\u0440\u0430\u0433\u0435, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u0431\u0435\u0441\u0446\u0435\u043D\u043D\u044B\u0435, \u0442\u043E\u0447\u043D\u0435\u0439\u0448\u0438\u0435
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F \u0422\u0438\u0445\u043E
    \u0411\u0440\u0430\u0433\u0435, \u041A\u0435\u043F\u043B\u0435\u0440 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0441\u0432\u043E\u0435 \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435.
    \u041C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0438\u0435 \u043F\u043E\u043F\u044B\u0442\u043A\u0438
    \u043F\u043E\u0434\u043E\u0433\u043D\u0430\u0442\u044C \u043E\u0440\u0431\u0438\u0442\u0443
    \u041C\u0430\u0440\u0441\u0430 \u043F\u043E\u0434 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u0439
    \u043A\u0440\u0443\u0433 (\u0434\u0430\u0436\u0435 \u0441 \u0443\u0447\u0435\u0442\u043E\u043C
    \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0441\u0438\u0442\u0435\u0442\u0430)
    \u043D\u0435 \u0443\u0434\u0430\u0432\u0430\u043B\u0438\u0441\u044C. \u0420\u0430\u0437\u043D\u0438\u0446\u0430
    \u043C\u0435\u0436\u0434\u0443 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u0438
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F\u043C\u0438 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0430
    \u0432\u0441\u0435\u0433\u043E 8 \u0443\u0433\u043B\u043E\u0432\u044B\u0445 \u043C\u0438\u043D\u0443\u0442
    \u2014 \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u044B
    \u0441\u043F\u0438\u0441\u0430\u043B\u0438 \u0431\u044B \u043D\u0430 \u043F\u043E\u0433\u0440\u0435\u0448\u043D\u043E\u0441\u0442\u044C.
    \u041D\u043E \u041A\u0435\u043F\u043B\u0435\u0440, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D \u0432 \u0431\u0435\u0437\u0443\u043F\u0440\u0435\u0447\u043D\u043E\u0441\u0442\u0438
    \u0434\u0430\u043D\u043D\u044B\u0445 \u0422\u0438\u0445\u043E, \u043F\u043E\u043D\u044F\u043B,
    \u0447\u0442\u043E \u043E\u0448\u0438\u0431\u043A\u0430 \u043D\u0435 \u0432 \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F\u0445,
    \u0430 \u0432 \u0441\u0430\u043C\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438. 
    \u0412 1609 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 magnum opus \u2014 \xAB\u041D\u043E\u0432\u0443\u044E
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044E\xBB (*Astronomia
    Nova*), \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0434\u0432\u0430 \u043F\u0435\u0440\u0432\u044B\u0445 \u0437\u0430\u043A\u043E\u043D\u0430
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u043F\u043B\u0430\u043D\u0435\u0442: 
    1.  **\u041F\u0435\u0440\u0432\u044B\u0439 \u0437\u0430\u043A\u043E\u043D (\u0417\u0430\u043A\u043E\u043D
    \u044D\u043B\u043B\u0438\u043F\u0441\u043E\u0432):** \u041A\u0430\u0436\u0434\u0430\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442\u0430 \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F
    \u043F\u043E \u044D\u043B\u043B\u0438\u043F\u0441\u0443, \u0432 \u043E\u0434\u043D\u043E\u043C
    \u0438\u0437 \u0444\u043E\u043A\u0443\u0441\u043E\u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u0421\u043E\u043B\u043D\u0446\u0435.
    2.  **\u0412\u0442\u043E\u0440\u043E\u0439 \u0437\u0430\u043A\u043E\u043D (\u0417\u0430\u043A\u043E\u043D
    \u043F\u043B\u043E\u0449\u0430\u0434\u0435\u0439):** \u0420\u0430\u0434\u0438\u0443\u0441-\u0432\u0435\u043A\u0442\u043E\u0440
    \u043F\u043B\u0430\u043D\u0435\u0442\u044B (\u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0430\u0435\u043C\u0430\u044F
    \u043B\u0438\u043D\u0438\u044F, \u0441\u043E\u0435\u0434\u0438\u043D\u044F\u044E\u0449\u0430\u044F
    \u0421\u043E\u043B\u043D\u0446\u0435 \u0438 \u043F\u043B\u0430\u043D\u0435\u0442\u0443)
    \u0437\u0430 \u0440\u0430\u0432\u043D\u044B\u0435 \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043A\u0438
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442
    \u0440\u0430\u0432\u043D\u044B\u0435 \u043F\u043B\u043E\u0449\u0430\u0434\u0438.
    \u042D\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E, \u0447\u0442\u043E
    \u043F\u043B\u0430\u043D\u0435\u0442\u0430 \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F
    \u0431\u044B\u0441\u0442\u0440\u0435\u0435, \u043A\u043E\u0433\u0434\u0430 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u0431\u043B\u0438\u0436\u0435 \u043A \u0421\u043E\u043B\u043D\u0446\u0443, \u0438
    \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u0435\u0435 \u2014 \u043A\u043E\u0433\u0434\u0430
    \u0434\u0430\u043B\u044C\u0448\u0435.  \u041F\u043E\u043C\u0438\u043C\u043E \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438,
    \u0432 \u041F\u0440\u0430\u0433\u0435 \u041A\u0435\u043F\u043B\u0435\u0440 \u043F\u0440\u043E\u0432\u0435\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F \u0432
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043E\u043F\u0442\u0438\u043A\u0438.
    \u0412 1604 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0442\u0440\u0443\u0434 \xAB\u0414\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u044F
    \u043A \u0412\u0438\u0442\u0435\u043B\u043B\u0438\u044E\xBB, \u0433\u0434\u0435
    \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C
    \u0437\u0440\u0435\u043D\u0438\u044F, \u043F\u043E\u043A\u0430\u0437\u0430\u0432,
    \u0447\u0442\u043E \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0444\u043E\u0440\u043C\u0438\u0440\u0443\u0435\u0442\u0441\u044F \u043D\u0430
    \u0441\u0435\u0442\u0447\u0430\u0442\u043A\u0435 \u0433\u043B\u0430\u0437\u0430,
    \u0438 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u0430\u043A\u043E\u043D \u0443\u0431\u044B\u0432\u0430\u043D\u0438\u044F
    \u043E\u0441\u0432\u0435\u0449\u0435\u043D\u043D\u043E\u0441\u0442\u0438 \u043E\u0431\u0440\u0430\u0442\u043D\u043E
    \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0443 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F.
    \u0412 1611 \u0433\u043E\u0434\u0443 \u0432\u044B\u0448\u043B\u0430 \u0435\u0433\u043E
    \xAB\u0414\u0438\u043E\u043F\u0442\u0440\u0438\u043A\u0430\xBB, \u0433\u0434\u0435
    \u043E\u043D \u043E\u043F\u0438\u0441\u0430\u043B \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F \u0441 \u0434\u0432\u0443\u043C\u044F
    \u0432\u044B\u043F\u0443\u043A\u043B\u044B\u043C\u0438 \u043B\u0438\u043D\u0437\u0430\u043C\u0438
    (\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F \u0442\u0440\u0443\u0431\u0430
    \u041A\u0435\u043F\u043B\u0435\u0440\u0430), \u0441\u0442\u0430\u0432\u0448\u0438\u0439
    \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0440\u0435\u0444\u0440\u0430\u043A\u0442\u043E\u0440\u043E\u0432.  \u0412 1611
    \u0433\u043E\u0434\u0443 \u0443\u043C\u0435\u0440\u043B\u0430 \u0435\u0433\u043E
    \u0436\u0435\u043D\u0430 \u0411\u0430\u0440\u0431\u0430\u0440\u0430. \u0412 1612
    \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430 \u0420\u0443\u0434\u043E\u043B\u044C\u0444\u0430
    II, \u041A\u0435\u043F\u043B\u0435\u0440 \u043F\u043E\u043A\u0438\u043D\u0443\u043B
    \u041F\u0440\u0430\u0433\u0443.  ### \U0001F52D \u041B\u0438\u043D\u0446 \u0438
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    (1612\u20131630): \u0417\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0435
    \u0442\u0440\u0443\u0434\u043E\u0432 \u0438 \u0431\u043E\u0440\u044C\u0431\u0430
    \u0437\u0430 \u0436\u0438\u0437\u043D\u044C  \u041A\u0435\u043F\u043B\u0435\u0440
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u041B\u0438\u043D\u0446,
    \u0433\u0434\u0435 \u0437\u0430\u043D\u044F\u043B \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u043E\u0432\u0438\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430. \u042D\u0442\u043E\u0442
    \u043F\u0435\u0440\u0438\u043E\u0434 \u0431\u044B\u043B \u043E\u0437\u043D\u0430\u043C\u0435\u043D\u043E\u0432\u0430\u043D
    \u043A\u0430\u043A \u0432\u0435\u043B\u0438\u043A\u0438\u043C\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438
    \u0441\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u044F\u043C\u0438, \u0442\u0430\u043A
    \u0438 \u043B\u0438\u0447\u043D\u044B\u043C\u0438 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F\u043C\u0438.
    \u0412 1613 \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439 \u0440\u0430\u0437 \u043D\u0430
    \u0421\u044E\u0437\u0430\u043D\u043D\u0435 \u0420\u043E\u0439\u0442\u0438\u043D\u0433\u0435\u0440.
    \u041E\u0442 \u0434\u0432\u0443\u0445 \u0431\u0440\u0430\u043A\u043E\u0432 \u0443
    \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u043E 12 \u0434\u0435\u0442\u0435\u0439,
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0432\u044B\u0436\u0438\u043B\u0438
    \u043B\u0438\u0448\u044C \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0435.  \u0412
    1615\u20131617 \u0433\u043E\u0434\u0430\u0445 \u0440\u0430\u0437\u0440\u0430\u0437\u0438\u043B\u0441\u044F
    \u0441\u043A\u0430\u043D\u0434\u0430\u043B: \u043C\u0430\u0442\u044C \u041A\u0435\u043F\u043B\u0435\u0440\u0430,
    \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0443, \u043E\u0431\u0432\u0438\u043D\u0438\u043B\u0438
    \u0432 \u043A\u043E\u043B\u0434\u043E\u0432\u0441\u0442\u0432\u0435. \u041A\u0435\u043F\u043B\u0435\u0440
    \u043B\u0438\u0447\u043D\u043E \u0432\u0437\u044F\u043B\u0441\u044F \u0437\u0430
    \u0435\u0435 \u0437\u0430\u0449\u0438\u0442\u0443 \u0438 \u043F\u043E\u0441\u043B\u0435
    \u0434\u043E\u043B\u0433\u0438\u0445 \u0438 \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0441\u0443\u0434\u0435\u0431\u043D\u044B\u0445 \u0442\u044F\u0436\u0431 \u0434\u043E\u0431\u0438\u043B\u0441\u044F
    \u0435\u0435 \u043E\u043F\u0440\u0430\u0432\u0434\u0430\u043D\u0438\u044F.  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u044D\u0442\u0438 \u043F\u043E\u0442\u0440\u044F\u0441\u0435\u043D\u0438\u044F,
    \u041A\u0435\u043F\u043B\u0435\u0440 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C. \u0412 1619 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \xAB\u0413\u0430\u0440\u043C\u043E\u043D\u0438\u044E \u043C\u0438\u0440\u0430\xBB
    (*Harmonices Mundi*), \u0433\u0434\u0435 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u0442\u0440\u0435\u0442\u0438\u0439, \u0441\u0430\u043C\u044B\u0439
    \u043E\u0431\u0449\u0438\u0439 \u0437\u0430\u043A\u043E\u043D \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442:  3.  **\u0422\u0440\u0435\u0442\u0438\u0439
    \u0437\u0430\u043A\u043E\u043D (\u0413\u0430\u0440\u043C\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0437\u0430\u043A\u043E\u043D):** \u041A\u0432\u0430\u0434\u0440\u0430\u0442\u044B
    \u043F\u0435\u0440\u0438\u043E\u0434\u043E\u0432 \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442 \u0432\u043E\u043A\u0440\u0443\u0433 \u0421\u043E\u043B\u043D\u0446\u0430
    \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F \u043A\u0430\u043A \u043A\u0443\u0431\u044B
    \u0431\u043E\u043B\u044C\u0448\u0438\u0445 \u043F\u043E\u043B\u0443\u043E\u0441\u0435\u0439
    \u0438\u0445 \u043E\u0440\u0431\u0438\u0442.  \u0412 1621 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B \u0441\u0432\u043E\u0439
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A \xAB\u0421\u043E\u043A\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u043A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u043E\u0432\u043E\u0439 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438\xBB,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0437\u0430\u043A\u043E\u043D\u044B \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043C\u044B
    \u043A\u043E \u0432\u0441\u0435\u043C \u043F\u043B\u0430\u043D\u0435\u0442\u0430\u043C
    \u0438 \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430\u043C.  \u0412 1626 \u0433\u043E\u0434\u0443,
    \u0438\u0437-\u0437\u0430 \u0422\u0440\u0438\u0434\u0446\u0430\u0442\u0438\u043B\u0435\u0442\u043D\u0435\u0439
    \u0432\u043E\u0439\u043D\u044B \u0438 \u0443\u0441\u0438\u043B\u0435\u043D\u0438\u044F
    \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0440\u0435\u0430\u043A\u0446\u0438\u0438,
    \u041A\u0435\u043F\u043B\u0435\u0440 \u0431\u044B\u043B \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u043F\u043E\u043A\u0438\u043D\u0443\u0442\u044C \u041B\u0438\u043D\u0446. \u041E\u043D
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0423\u043B\u044C\u043C,
    \u0433\u0434\u0435 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B \u0441\u0432\u043E\u0439
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0432\u0435\u043B\u0438\u043A\u0438\u0439
    \u0442\u0440\u0443\u0434 \u2014 \xAB\u0420\u0443\u0434\u043E\u043B\u044C\u0444\u043E\u0432\u044B
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B\xBB (\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u044B
    \u0432 1627 \u0433\u043E\u0434\u0443). \u042D\u0442\u043E \u0431\u044B\u043B\u0438
    \u0441\u0430\u043C\u044B\u0435 \u0442\u043E\u0447\u043D\u044B\u0435 \u043D\u0430
    \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B, \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0432\u0448\u0438\u0435
    \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u0442\u044C \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u043F\u043B\u0430\u043D\u0435\u0442 \u043D\u0430 \u043C\u043D\u043E\u0433\u043E
    \u043B\u0435\u0442 \u0432\u043F\u0435\u0440\u0435\u0434.  \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0436\u0438\u0437\u043D\u0438 \u041A\u0435\u043F\u043B\u0435\u0440
    \u043F\u0440\u043E\u0432\u0435\u043B \u0432 \u0441\u043A\u0438\u0442\u0430\u043D\u0438\u044F\u0445
    \u0432 \u043F\u043E\u0438\u0441\u043A\u0430\u0445 \u0441\u0440\u0435\u0434\u0441\u0442\u0432
    \u043A \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044E.
    \u0412 1628 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u043E\u043C
    \u0443 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E \u043F\u043E\u043B\u043A\u043E\u0432\u043E\u0434\u0446\u0430
    \u0410\u043B\u044C\u0431\u0440\u0435\u0445\u0442\u0430 \u0444\u043E\u043D \u0412\u0430\u043B\u043B\u0435\u043D\u0448\u0442\u0435\u0439\u043D\u0430,
    \u0436\u0438\u043B \u0432 \u0421\u0430\u0433\u0430\u043D\u0435 (\u043D\u044B\u043D\u0435
    \u0416\u0430\u0433\u0430\u043D\u044C, \u041F\u043E\u043B\u044C\u0448\u0430).
    \u041F\u044B\u0442\u0430\u044F\u0441\u044C \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0434\u0435\u043D\u044C\u0433\u0438, \u043F\u0440\u0438\u0447\u0438\u0442\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u0435\u043C\u0443 \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0430\u0434
    \u0442\u0430\u0431\u043B\u0438\u0446\u0430\u043C\u0438, \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u0420\u0435\u0433\u0435\u043D\u0441\u0431\u0443\u0440\u0433, \u0433\u0434\u0435
    15 \u043D\u043E\u044F\u0431\u0440\u044F 1630 \u0433\u043E\u0434\u0430 \u0437\u0430\u0431\u043E\u043B\u0435\u043B
    \u0432 \u043F\u0443\u0442\u0438 \u0438 \u0443\u043C\u0435\u0440.  \u041D\u0430
    \u0435\u0433\u043E \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u0438 \u0432\u044B\u0431\u0438\u0442\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0440\u0443\u0447\u043D\u043E
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u043D\u043E\u0435 \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u044F:
    **\xAB\u042F \u043C\u0435\u0440\u0438\u043B \u043D\u0435\u0431\u0435\u0441\u0430,
    \u0442\u0435\u043F\u0435\u0440\u044C \u043C\u0435\u0440\u044F\u044E \u0442\u0435\u043D\u0438.
    / \u0414\u0443\u0445\u043E\u043C \u0431\u044B\u043B \u044F \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u043C,
    \u0442\u0435\u043B\u043E \u0437\u0434\u0435\u0441\u044C \u043F\u043E\u043A\u043E\u0438\u0442\u0441\u044F
    \u0437\u0435\u043C\u043D\u043E\u0435\xBB**."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0418\u043E\u0433\u0430\u043D\u043D\u0430
    \u041A\u0435\u043F\u043B\u0435\u0440\u0430 \u2014 \u044D\u0442\u043E \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0443\u0445\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0438 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438, \u043D\u043E \u0438
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435, \u043F\u043E\u0440\u043E\u0439
    \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0435, \u0430 \u0438\u043D\u043E\u0433\u0434\u0430
    \u0438 \u0448\u043E\u043A\u0438\u0440\u0443\u044E\u0449\u0438\u0435 \u0438\u0441\u0442\u043E\u0440\u0438\u0438.
    \u041E\u043D \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043C\u043E\u0433 \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C
    \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0433\u0438\u043C\u043D
    \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439 \u0438 \u0442\u0443\u0442
    \u0436\u0435 \u0437\u0430\u043D\u044F\u0442\u044C\u0441\u044F \u043F\u043E\u0434\u0441\u0447\u0435\u0442\u043E\u043C
    \u043E\u0431\u044A\u0435\u043C\u043E\u0432 \u0432\u0438\u043D\u043D\u044B\u0445
    \u0431\u043E\u0447\u0435\u043A, \u0447\u0442\u043E\u0431\u044B \u0441\u0432\u0435\u0441\u0442\u0438
    \u043A\u043E\u043D\u0446\u044B \u0441 \u043A\u043E\u043D\u0446\u0430\u043C\u0438.  
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u044F\u0440\u043A\u0438\u0435,
    \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0435 \u0438 \u043C\u0430\u043B\u043E\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438,
    \u0441\u043E\u0431\u0440\u0430\u043D\u043D\u044B\u0435 \u0432 \u0434\u0435\u0442\u0430\u043B\u044F\u0445. 
    ### \U0001F52E 1. \u0413\u043E\u0440\u043E\u0441\u043A\u043E\u043F, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043D \u0441\u0430\u043C \u0441\u0435\u0431\u0435 \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    (\u0438 \u0441\u0431\u044B\u043B\u0441\u044F) \u041A\u0435\u043F\u043B\u0435\u0440,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u043E\u043C, \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0433\u043E\u0440\u043E\u0441\u043A\u043E\u043F, \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0439
    \u0438\u043C \u0441\u0430\u043C\u0438\u043C \u0432 1597 \u0433\u043E\u0434\u0443.
    \u0427\u0442\u043E \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u2014 \u043E\u043D \u043E\u043F\u0438\u0441\u0430\u043B \u0432 \u043D\u0435\u043C
    \u0441\u0432\u043E\u044E \u0431\u0443\u0434\u0443\u0449\u0443\u044E \u0436\u0438\u0437\u043D\u044C
    \u0441 \u043F\u0443\u0433\u0430\u044E\u0449\u0435\u0439 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E,
    \u043D\u043E \u043D\u0435 \u043A\u0430\u043A \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u0435\u0434\u0432\u0438\u0434\u0435\u043D\u0438\u0435, \u0430 \u043A\u0430\u043A
    \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u0430\u043C\u043E\u0430\u043D\u0430\u043B\u0438\u0437.  \u041E\u043D \u0437\u0430\u043F\u0438\u0441\u0430\u043B,
    \u0447\u0442\u043E \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u043F\u043E\u0434
    \u0437\u043D\u0430\u043A\u043E\u043C \u0412\u043E\u0434\u043E\u043B\u0435\u044F,
    \u0438 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043B: *\xAB\u0412
    \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B \u043E\u043D \u0431\u0443\u0434\u0435\u0442
    \u0436\u0438\u0442\u044C \u0432 \u043A\u0440\u0430\u0439\u043D\u0435\u0439 \u0431\u0435\u0434\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043D\u0443\u0436\u0434\u0435... \u0415\u0433\u043E \u0436\u0435\u043D\u0443
    \u0431\u0443\u0434\u0443\u0442 \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u0442\u044C,
    \u0430 \u0434\u0435\u0442\u0435\u0439 \u0436\u0434\u0443\u0442 \u043D\u0435\u0441\u0447\u0430\u0441\u0442\u044C\u044F\xBB*.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u043D\u0430\u043F\u0438\u0441\u0430\u043B,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u0431\u0443\u0434\u0435\u0442
    \u043F\u043E\u043B\u043D\u0430 \xAB\u0441\u043F\u0435\u0448\u043D\u044B\u0445
    \u043E\u0442\u044A\u0435\u0437\u0434\u043E\u0432 \u0438 \u043E\u043F\u0430\u0441\u043D\u044B\u0445
    \u0434\u043E\u0440\u043E\u0433\xBB. \u0412\u0441\u0435 \u044D\u0442\u043E \u0441\u0431\u044B\u043B\u043E\u0441\u044C
    \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043E\u043D \u0434\u043E\u0431\u0430\u0432\u0438\u043B, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u0430\u044F \u043F\u043B\u0430\u043D\u0435\u0442\u0430
    (\u041C\u0435\u0440\u043A\u0443\u0440\u0438\u0439) \u0434\u0430\u0440\u0443\u0435\u0442
    \u0435\u043C\u0443 \u043E\u0441\u0442\u0440\u044B\u0439 \u0443\u043C, \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B\u0439
    \xAB\u0440\u0430\u0441\u043A\u0443\u0441\u0438\u0442\u044C \u043B\u044E\u0431\u043E\u0439
    \u043E\u0431\u043C\u0430\u043D\xBB, \u2014 \u044D\u0442\u0438\u043C \u0434\u0430\u0440\u043E\u043C
    \u043E\u043D \u0441\u043F\u0430\u0441 \u0441\u0432\u043E\u044E \u043C\u0430\u0442\u044C
    \u043E\u0442 \u043A\u043E\u0441\u0442\u0440\u0430.  ### \U0001F377 2. \u041F\u043E\u0447\u0435\u043C\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438\u0437\u0443\u0447\u0430\u043B
    \u0432\u0438\u043D\u043D\u044B\u0435 \u0431\u043E\u0447\u043A\u0438 \u0412 1613
    \u0433\u043E\u0434\u0443 \u041A\u0435\u043F\u043B\u0435\u0440 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439 \u0440\u0430\u0437 \u043D\u0430
    \u0421\u044E\u0437\u0430\u043D\u043D\u0435 \u0420\u043E\u0439\u0442\u0438\u043D\u0433\u0435\u0440.
    \u0421\u0432\u0430\u0434\u044C\u0431\u0430 \u0431\u044B\u043B\u0430 \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0439,
    \u0438 \u043D\u0430 \u043F\u0440\u0430\u0437\u0434\u043D\u0438\u043A\u0435 \u0432\u043E\u0437\u043D\u0438\u043A
    \u0441\u043F\u043E\u0440 \u043C\u0435\u0436\u0434\u0443 \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0430\u043C\u0438
    \u0432\u0438\u043D\u043E\u043C. \u041A\u0435\u043F\u043B\u0435\u0440 \u0437\u0430\u043C\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u0432\u0438\u043D\u043E\u0434\u0435\u043B\u044B \u0432 \u0410\u0432\u0441\u0442\u0440\u0438\u0438
    \u0438\u0437\u043C\u0435\u0440\u044F\u044E\u0442 \u043E\u0431\u044A\u0435\u043C
    \u0431\u043E\u0447\u0435\u043A, \u043F\u0440\u043E\u0441\u0442\u043E \u0437\u0430\u0441\u043E\u0432\u044B\u0432\u0430\u044F
    \u043F\u0430\u043B\u043A\u0443 \u0432 \u0437\u0430\u043B\u0438\u0432\u043D\u043E\u0435
    \u043E\u0442\u0432\u0435\u0440\u0441\u0442\u0438\u0435 \u043F\u043E \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u0438,
    \u0438 \u043D\u0435 \u043C\u043E\u0433\u0443\u0442 \u043F\u043E\u043D\u044F\u0442\u044C,
    \u043F\u043E\u0447\u0435\u043C\u0443 \u0432 \u043E\u0434\u043D\u0438\u0445 \u0431\u043E\u0447\u043A\u0430\u0445
    \u0431\u043E\u043B\u044C\u0448\u0435 \u0432\u0438\u043D\u0430, \u0447\u0435\u043C
    \u0432 \u0434\u0440\u0443\u0433\u0438\u0445 \u043F\u0440\u0438 \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u044B\u0445
    \u0437\u0430\u043C\u0435\u0440\u0430\u0445.  \u041A\u0435\u043F\u043B\u0435\u0440
    \u0441\u0435\u043B \u0437\u0430 \u0440\u0430\u0441\u0447\u0435\u0442\u044B \u0438
    \u0432 1615 \u0433\u043E\u0434\u0443 \u0438\u0437\u0434\u0430\u043B \u0442\u0440\u0430\u043A\u0442\u0430\u0442
    **\xAB\u041D\u043E\u0432\u0430\u044F \u0441\u0442\u0435\u0440\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    \u0432\u0438\u043D\u043D\u044B\u0445 \u0431\u043E\u0447\u0435\u043A\xBB**. \u042D\u0442\u043E
    \u0431\u044B\u043B \u0447\u0438\u0441\u0442\u043E \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u043E\u0439
    \u0442\u0440\u0443\u0434, \u0433\u0434\u0435 \u043E\u043D \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u044B\u0432\u0435\u043B, \u043A\u0430\u043A \u0444\u043E\u0440\u043C\u0430
    \u0431\u043E\u0447\u043A\u0438 \u0432\u043B\u0438\u044F\u0435\u0442 \u043D\u0430
    \u043E\u0431\u044A\u0435\u043C. \u041D\u043E \u0441\u0430\u043C\u043E\u0435 \u0441\u043C\u0435\u0448\u043D\u043E\u0435,
    \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C
    \u044D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434 \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u043A\u0430\u043A \u043F\u0440\u0435\u0434\u0442\u0435\u0447\u0430 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u2014 \u043E\u043D
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u043C\u0435\u0442\u043E\u0434\u044B
    \xAB\u043D\u0435\u0434\u0435\u043B\u0438\u043C\u044B\u0445\xBB, \u0447\u0442\u043E\u0431\u044B
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u044C \u043E\u0431\u044A\u0435\u043C\u044B
    \u0442\u0435\u043B \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F. \u0422\u043E
    \u0435\u0441\u0442\u044C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439
    \u0432\u044B\u0441\u0448\u0438\u0439 \u043C\u0430\u0442\u0430\u043D \u0432\u044B\u0440\u043E\u0441
    \u0438\u0437 \u0436\u0435\u043B\u0430\u043D\u0438\u044F \u043D\u0435 \u0434\u0430\u0442\u044C
    \u0430\u0432\u0441\u0442\u0440\u0438\u0439\u0441\u043A\u0438\u043C \u0442\u0440\u0430\u043A\u0442\u0438\u0440\u0449\u0438\u043A\u0430\u043C
    \u0441\u0435\u0431\u044F \u043E\u0431\u043C\u0430\u043D\u0443\u0442\u044C.  ###
    \U0001F319 3. \u041F\u0438\u0441\u0430\u0442\u0435\u043B\u044C-\u0444\u0430\u043D\u0442\u0430\u0441\u0442,
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0432\u0448\u0438\u0439 \u043B\u044E\u0434\u0435\u0439
    \u043D\u0430 \u041B\u0443\u043D\u0443 \u0437\u0430 300 \u043B\u0435\u0442 \u0434\u043E
    \u0416\u044E\u043B\u044F \u0412\u0435\u0440\u043D\u0430 \u0412 1634 \u0433\u043E\u0434\u0443
    (\u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u041A\u0435\u043F\u043B\u0435\u0440\u0430) \u0431\u044B\u043B \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D
    \u0435\u0433\u043E \u0444\u0430\u043D\u0442\u0430\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0440\u043E\u043C\u0430\u043D **\xAB\u0421\u043E\u043D\xBB (Somnium)**. \u041A\u0435\u043F\u043B\u0435\u0440
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0435\u0433\u043E \u0435\u0449\u0435
    \u0432 \u0441\u0442\u0443\u0434\u0435\u043D\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B, \u043D\u043E \u0440\u0435\u0434\u0430\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043B
    \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C.   \u0412 \u0441\u044E\u0436\u0435\u0442\u0435
    \u044E\u043D\u043E\u0448\u0430 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0434\u0443\u0445\u043E\u0432 \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043D\u0430 \u041B\u0443\u043D\u0443. \u041A\u0435\u043F\u043B\u0435\u0440 \u0441
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0434\u043B\u044F XVII \u0432\u0435\u043A\u0430 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u043E\u043F\u0438\u0441\u0430\u043B:  - \u041A\u0430\u043A \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
    \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u044F \u043F\u0440\u0438
    \u0443\u0434\u0430\u043B\u0435\u043D\u0438\u0438 \u043E\u0442 \u0417\u0435\u043C\u043B\u0438.
    - \u041A\u0430\u043A \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442 \u0417\u0435\u043C\u043B\u044F
    \u0441 \u041B\u0443\u043D\u044B (\u043E\u043D\u0430 \u043A\u0430\u0436\u0435\u0442\u0441\u044F
    \u0433\u0438\u0433\u0430\u043D\u0442\u0441\u043A\u0438\u043C \u0441\u0432\u0435\u0442\u0438\u043B\u043E\u043C).
    - \u041E\u0433\u0440\u043E\u043C\u043D\u044B\u0435 \u043F\u0435\u0440\u0435\u043F\u0430\u0434\u044B
    \u0442\u0435\u043C\u043F\u0435\u0440\u0430\u0442\u0443\u0440 \u043D\u0430 \u041B\u0443\u043D\u0435
    (\u043E\u043D \u0437\u043D\u0430\u043B, \u0447\u0442\u043E \u043D\u0430 \u043E\u0441\u0432\u0435\u0449\u0435\u043D\u043D\u043E\u0439
    \u0441\u0442\u043E\u0440\u043E\u043D\u0435 \u043D\u0435\u0432\u044B\u043D\u043E\u0441\u0438\u043C\u044B\u0439
    \u0436\u0430\u0440, \u0430 \u043D\u0430 \u0442\u0435\u043D\u0435\u0432\u043E\u0439
    \u2014 \u043B\u0435\u0434\u044F\u043D\u043E\u0439 \u0445\u043E\u043B\u043E\u0434).
    - \u0418 \u0434\u0430\u0436\u0435 \u044F\u0432\u043B\u0435\u043D\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043C\u044B \u0441\u0435\u0433\u043E\u0434\u043D\u044F
    \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C **\xAB\u0443\u0433\u043B\u0435\u0440\u043E\u0434\u043D\u044B\u043C
    \u0448\u043E\u0432\u0438\u043D\u0438\u0437\u043C\u043E\u043C\xBB**: \u043E\u043D
    \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u043B, \u0447\u0442\u043E
    \u043B\u0443\u043D\u0430\u0442\u0438\u043A\u0438 (\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0430,
    \u0436\u0438\u0432\u0443\u0449\u0438\u0435 \u043D\u0430 \u041B\u0443\u043D\u0435)
    \u043C\u043E\u0433\u0443\u0442 \u0431\u044B\u0442\u044C \u0441\u0434\u0435\u043B\u0430\u043D\u044B
    \u043D\u0435 \u0438\u0437 \u043F\u043B\u043E\u0442\u0438 \u0438 \u043A\u0440\u043E\u0432\u0438,
    \u0430 \u0438\u0437 \u0434\u0440\u0443\u0433\u043E\u0439 \u0441\u0443\u0431\u0441\u0442\u0430\u043D\u0446\u0438\u0438,
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u0438\u0445 \u043C\u0438\u0440
    \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0445\u043E\u043B\u043E\u0434\u0435\u043D
    \u0434\u043B\u044F \u043D\u0430\u0448\u0435\u0439 \u0444\u043E\u0440\u043C\u044B
    \u0436\u0438\u0437\u043D\u0438.  \u0420\u043E\u043C\u0430\u043D \u0447\u0443\u0442\u044C
    \u043D\u0435 \u0441\u0442\u043E\u0438\u043B \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u0440\u0438
    \u0436\u0438\u0437\u043D\u0438: \u0432 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0438
    \u041A\u0435\u043F\u043B\u0435\u0440 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u043C\u0430\u0442\u044C \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0447\u0438\u0446\u044B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \"\u0432\u044B\u0437\u044B\u0432\u0430\u0435\u0442 \u0434\u0435\u043C\u043E\u043D\u043E\u0432\".
    \u0418\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u0430 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C
    \u043F\u043E\u0441\u043B\u0443\u0436\u0438\u043B\u0430 \u043A\u043E\u0441\u0432\u0435\u043D\u043D\u044B\u043C
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u043F\u0440\u043E\u0442\u0438\u0432 \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u044B
    \u043D\u0430 \u0441\u0443\u0434\u0435 \u043F\u043E \u0434\u0435\u043B\u0443 \u043E
    \u043A\u043E\u043B\u0434\u043E\u0432\u0441\u0442\u0432\u0435.  ### \u2694\uFE0F
    4. \u0421\u0441\u043E\u0440\u0430 \u0441 \u0422\u0438\u0445\u043E \u0411\u0440\u0430\u0433\u0435:
    \u0414\u0443\u044D\u043B\u044C \u043D\u0430 \u043F\u0438\u0441\u044C\u043C\u0430\u0445
    \u0418\u0445 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043D\u0430\u0447\u0430\u043B\u043E\u0441\u044C \u0441 \u0433\u0440\u043E\u043C\u043A\u043E\u0433\u043E
    \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u0430. \u041F\u0440\u0438\u0435\u0445\u0430\u0432
    \u0432 \u041F\u0440\u0430\u0433\u0443 \u043A \u0422\u0438\u0445\u043E \u0411\u0440\u0430\u0433\u0435,
    \u041A\u0435\u043F\u043B\u0435\u0440 \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u0435\u0431\u044F \u0443\u043D\u0438\u0436\u0435\u043D\u043D\u044B\u043C:
    \u0435\u043C\u0443 \u043F\u043B\u0430\u0442\u0438\u043B\u0438 \u043C\u0435\u043D\u044C\u0448\u0435
    \u0441\u043B\u0443\u0433, \u0430 \u0434\u043E\u0441\u0442\u0443\u043F \u043A
    \u0442\u0430\u0431\u043B\u0438\u0446\u0430\u043C \u041C\u0430\u0440\u0441\u0430
    \u0431\u044B\u043B \u0437\u0430\u043A\u0440\u044B\u0442.   \u0412 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0434\u043D\u0435\u0439 \u041A\u0435\u043F\u043B\u0435\u0440 \u0432\u043F\u0430\u043B
    \u0432 \u044F\u0440\u043E\u0441\u0442\u044C \u0438 \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0422\u0438\u0445\u043E \u043F\u0438\u0441\u044C\u043C\u043E, \u0433\u0434\u0435
    \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E \u043E\u0431\u0432\u0438\u043D\u0438\u043B
    \u0435\u0433\u043E \u0432 \u043C\u043E\u0448\u0435\u043D\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0435.
    \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B, \u0447\u0442\u043E \u0422\u0438\u0445\u043E
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442 \u0435\u0433\u043E,
    \u043A\u0430\u043A \xAB\u043F\u0440\u043E\u0441\u0442\u043E\u0439 \u043C\u043E\u043B\u043E\u0442
    \u0434\u043B\u044F \u0440\u0430\u0441\u043A\u0430\u043B\u044B\u0432\u0430\u043D\u0438\u044F
    \u043A\u0430\u043C\u043D\u0435\u0439\xBB, \u0438 \u0447\u0442\u043E \u043E\u043D,
    \u041A\u0435\u043F\u043B\u0435\u0440, \u0443\u0435\u0437\u0436\u0430\u0435\u0442.
    \u041E\u043D \u0443\u043F\u0430\u043A\u043E\u0432\u0430\u043B \u0432\u0435\u0449\u0438
    \u0438 \u0443\u0448\u0435\u043B \u043F\u0435\u0448\u043A\u043E\u043C \u0438\u0437
    \u041F\u0440\u0430\u0433\u0438.  \u0422\u0438\u0445\u043E, \u043F\u043E\u043D\u044F\u0432,
    \u0447\u0442\u043E \u0442\u0435\u0440\u044F\u0435\u0442 \u0433\u0435\u043D\u0438\u044F,
    \u0431\u0440\u043E\u0441\u0438\u043B\u0441\u044F \u0432\u0434\u043E\u0433\u043E\u043D\u043A\u0443.
    \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u041A\u0435\u043F\u043B\u0435\u0440\u0443
    \u0443\u043D\u0438\u0436\u0435\u043D\u043D\u043E\u0435 \u043F\u043E\u043A\u0430\u044F\u043D\u043D\u043E\u0435
    \u043F\u0438\u0441\u044C\u043C\u043E \u0438 \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B
    \u0435\u0433\u043E \u043E\u0431\u0440\u0430\u0442\u043D\u043E \u043D\u0430 \u0443\u043B\u0443\u0447\u0448\u0435\u043D\u043D\u044B\u0445
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445. \u041A\u0435\u043F\u043B\u0435\u0440
    \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F, \u043D\u043E \u0432 \u0442\u0435\u0447\u0435\u043D\u0438\u0435
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u043D\u0435\u0434\u0435\u043B\u044C
    \u043E\u043D\u0438 \u043D\u0435 \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u043B\u0438,
    \u043E\u0431\u0449\u0430\u044F\u0441\u044C \u0442\u043E\u043B\u044C\u043A\u043E
    \u0437\u0430\u043F\u0438\u0441\u043A\u0430\u043C\u0438, \u043F\u043E\u043A\u0430
    \u0422\u0438\u0445\u043E \u043D\u0435 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0435\u043C\u0443 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E \u043F\u043E\u0436\u0430\u0442\u044C
    \u0440\u0443\u043A\u0443 \u0432 \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0438
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430.   ### \U0001F927
    5. \u0421\u043C\u0435\u0440\u0442\u044C \u0422\u0438\u0445\u043E \u0411\u0440\u0430\u0433\u0435
    \u0438 \"\u0432\u0438\u043D\u043E\u0432\u0430\u0442\u044B\u0439\" \u041A\u0435\u043F\u043B\u0435\u0440
    \u0422\u0438\u0445\u043E \u0411\u0440\u0430\u0433\u0435 \u0443\u043C\u0435\u0440
    \u043F\u0440\u0438 \u043E\u0447\u0435\u043D\u044C \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0445
    \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u0445.
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u0443\u0436\u0438\u043D\u0430 \u0443
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430 \u0420\u0443\u0434\u043E\u043B\u044C\u0444\u0430
    II \u0435\u043C\u0443 \u0431\u044B\u043B\u043E \u043D\u0435\u0443\u0434\u043E\u0431\u043D\u043E
    \u0432\u044B\u0445\u043E\u0434\u0438\u0442\u044C \u0438\u0437-\u0437\u0430 \u0441\u0442\u043E\u043B\u0430
    (\u044D\u0442\u043E \u0441\u0447\u0438\u0442\u0430\u043B\u043E\u0441\u044C \u0434\u0443\u0440\u043D\u044B\u043C
    \u0442\u043E\u043D\u043E\u043C), \u0438 \u043E\u043D \u0442\u0435\u0440\u043F\u0435\u043B,
    \u043D\u0435 \u0441\u0445\u043E\u0434\u044F \u0432 \u0442\u0443\u0430\u043B\u0435\u0442.
    \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C \u0434\u043E\u043C\u043E\u0439,
    \u043E\u043D \u0443\u0436\u0435 \u043D\u0435 \u043C\u043E\u0433 \u043C\u043E\u0447\u0438\u0442\u044C\u0441\u044F,
    \u043D\u0430\u0447\u0430\u043B\u0441\u044F \u0443\u0440\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043A\u0440\u0438\u0437\u0438\u0441, \u0438 \u043E\u043D \u0443\u043C\u0435\u0440
    \u0447\u0435\u0440\u0435\u0437 11 \u0434\u043D\u0435\u0439.  \u041D\u043E \u043A\u0443\u0440\u044C\u0435\u0437
    \u0432 \u0434\u0440\u0443\u0433\u043E\u043C: **\u041A\u0435\u043F\u043B\u0435\u0440
    \u0434\u043E\u043B\u0433\u0438\u0435 \u0433\u043E\u0434\u044B \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u0432\u0430\u043B\u0441\u044F
    \u0432 \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u0435**. \u041F\u043E\u0447\u0435\u043C\u0443?
    \u041F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u0441\u0440\u0430\u0437\u0443
    \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u0445\u043E\u0440\u043E\u043D \u0422\u0438\u0445\u043E
    \u041A\u0435\u043F\u043B\u0435\u0440 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0435\u0433\u043E \u043F\u043E\u0441\u0442 \u0438 \u0435\u0433\u043E \u0430\u0440\u0445\u0438\u0432\u044B.
    \u0413\u043E\u0432\u043E\u0440\u0438\u043B\u0438, \u0447\u0442\u043E \u041A\u0435\u043F\u043B\u0435\u0440
    \u043C\u043E\u0433 \u043F\u043E\u0434\u0441\u044B\u043F\u0430\u0442\u044C \u044F\u0434,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0434\u0430\u043D\u043D\u044B\u0435 \u0431\u044B\u0441\u0442\u0440\u0435\u0435.
    \u0422\u043E\u043B\u044C\u043A\u043E \u0432 2010 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430
    \u044D\u043A\u0441\u0433\u0443\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u043E\u0441\u0442\u0430\u043D\u043A\u0438 \u0422\u0438\u0445\u043E \u0411\u0440\u0430\u0433\u0435,
    \u0445\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0430\u043D\u0430\u043B\u0438\u0437
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0440\u0442\u0443\u0442\u0438
    \u0432 \u043D\u0438\u0445 \u043D\u0435 \u0431\u044B\u043B\u043E (\u0432\u043E\u043F\u0440\u0435\u043A\u0438
    \u0441\u043B\u0443\u0445\u0430\u043C), \u0438 \u0432\u0435\u0440\u0441\u0438\u044F
    \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u0430 \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u0430. \u041A\u0435\u043F\u043B\u0435\u0440
    \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E \u0440\u0435\u0430\u0431\u0438\u043B\u0438\u0442\u0438\u0440\u043E\u0432\u0430\u043D. 
    ### \U0001F3A8 6. \u041E\u043D \u0431\u044B\u043B \u043F\u043E\u044D\u0442\u043E\u043C
    \u0438 \u0441\u043E\u0447\u0438\u043D\u044F\u043B \u043C\u0443\u0437\u044B\u043A\u0443
    \u0441\u0444\u0435\u0440 \u041A\u0435\u043F\u043B\u0435\u0440 \u0432\u0435\u0440\u0438\u043B,
    \u0447\u0442\u043E \u043F\u043B\u0430\u043D\u0435\u0442\u044B \u043F\u043E\u044E\u0442.
    \u0412 \u0441\u0432\u043E\u0435\u0439 \u043A\u043D\u0438\u0433\u0435 \xAB\u0413\u0430\u0440\u043C\u043E\u043D\u0438\u044F
    \u043C\u0438\u0440\u0430\xBB (1619) \u043E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0434\u0430\u043B \u0442\u0440\u0435\u0442\u0438\u0439 \u0437\u0430\u043A\u043E\u043D,
    \u043D\u043E \u0438 \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043F\u0435\u0440\u0435\u043B\u043E\u0436\u0438\u0442\u044C
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u043F\u043B\u0430\u043D\u0435\u0442
    \u043D\u0430 \u043D\u043E\u0442\u044B.   \u041E\u043D \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B,
    \u0447\u0442\u043E \u0417\u0435\u043C\u043B\u044F \u043F\u043E\u0435\u0442 \u043D\u043E\u0442\u044B
    \xAB\u041C\u0438-\u0424\u0430-\u041C\u0438\xBB (\u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443
    \u0435\u0451 \u043E\u0440\u0431\u0438\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F),
    \u0430 \u0421\u0430\u0442\u0443\u0440\u043D \u0434\u0430\u0435\u0442 \u0431\u0430\u0441\u043E\u0432\u044B\u0439
    \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B. \u041A\u0435\u043F\u043B\u0435\u0440
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E \u0434\u0443\u0448\u0430
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0430\u044F \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u0430
    \u0441\u043B\u044B\u0448\u0430\u0442\u044C \u044D\u0442\u0443 \u043C\u0443\u0437\u044B\u043A\u0443,
    \u043D\u043E \u044D\u0442\u043E \u043D\u0435 \u0437\u0432\u0443\u043A \u0432
    \u043F\u0440\u0438\u0432\u044B\u0447\u043D\u043E\u043C \u0441\u043C\u044B\u0441\u043B\u0435,
    \u0430 \xAB\u0433\u0430\u0440\u043C\u043E\u043D\u0438\u044F \u0440\u0430\u0437\u0443\u043C\u0430\xBB.
    \u042D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434 \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u043C \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0434\u043E\u043B\u0433\u043E \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B\u0438
    \u043A\u0430\u043A \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0431\u0440\u0435\u0434, \u0430 \u043D\u0435 \u043A\u0430\u043A \u043D\u0430\u0443\u043A\u0443. 
    ### \U0001F47B 7. \u041E\u043D \u0434\u0432\u0430\u0436\u0434\u044B \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043B
    \u0441\u0432\u043E\u044E \u0441\u043C\u0435\u0440\u0442\u044C (\u0438 \u043E\u0431\u0430
    \u0440\u0430\u0437\u0430 \u043E\u0448\u0438\u0431\u0441\u044F) \u0411\u0443\u0434\u0443\u0447\u0438
    \u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u044B\u043C \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u043E\u043C
    \u0412\u0430\u043B\u043B\u0435\u043D\u0448\u0442\u0435\u0439\u043D\u0430, \u041A\u0435\u043F\u043B\u0435\u0440
    \u043E\u0434\u043D\u0430\u0436\u0434\u044B (\u0432 1627 \u0433\u043E\u0434\u0443)
    \u043D\u0430\u0447\u0435\u0440\u0442\u0438\u043B \u0433\u043E\u0440\u043E\u0441\u043A\u043E\u043F
    \u0434\u043B\u044F \u0441\u0430\u043C\u043E\u0433\u043E \u0441\u0435\u0431\u044F
    \u043D\u0430 1634 \u0433\u043E\u0434. \u041E\u043D \u0440\u0435\u0448\u0438\u043B,
    \u0447\u0442\u043E \u0443\u043C\u0440\u0435\u0442 \u0432 \u043C\u0430\u0435 1634
    \u0433\u043E\u0434\u0430. \u041E\u0434\u043D\u0430\u043A\u043E \u043E\u043D \u0443\u043C\u0435\u0440
    \u0432 1630 \u0433\u043E\u0434\u0443, \u043D\u0435 \u0434\u043E\u0436\u0438\u0432
    4 \u0433\u043E\u0434\u0430.  \u041D\u043E \u0435\u0441\u0442\u044C \u0431\u043E\u043B\u0435\u0435
    \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439:
    \u0437\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0435\u0441\u044F\u0446\u0435\u0432
    \u0434\u043E \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439 \u043A\u043E\u043D\u0447\u0438\u043D\u044B,
    \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u044F\u0441\u044C \u0432 \u043F\u0443\u0442\u044C
    \u0432 \u0420\u0435\u0433\u0435\u043D\u0441\u0431\u0443\u0440\u0433 (\u0433\u0434\u0435
    \u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F), \u043E\u043D,
    \u043F\u0440\u043E\u0435\u0437\u0436\u0430\u044F \u0447\u0435\u0440\u0435\u0437
    \u043C\u043E\u0441\u0442, \u0441\u0438\u043B\u044C\u043D\u043E \u0438\u0441\u043F\u0443\u0433\u0430\u043B\u0441\u044F
    \u0433\u0440\u043E\u0437\u044B \u0438 \u0441\u043A\u0430\u0437\u0430\u043B \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430\u043C:
    *\xAB\u0412\u043E\u0442, \u044D\u0442\u043E \u0437\u043D\u0430\u043A. \u041C\u043D\u0435
    \u043A\u0430\u0436\u0435\u0442\u0441\u044F, \u044F \u0441\u043A\u043E\u0440\u043E
    \u0443\u043C\u0440\u0443. \u041D\u043E \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u044F \u0434\u043E\u043B\u0436\u0435\u043D \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u044C
    \u0440\u0430\u0441\u0447\u0435\u0442\u044B\xBB*. \u041E\u043D \u043E\u0448\u0438\u0431\u0441\u044F
    \u0432 \u0434\u0430\u0442\u0435, \u043D\u043E \u043D\u0435 \u0432 \u0444\u0430\u0442\u0430\u043B\u044C\u043D\u043E\u043C
    \u0438\u0441\u0445\u043E\u0434\u0435 \u043F\u043E\u0435\u0437\u0434\u043A\u0438. 
    ### \U0001FAA6 8. \u0421\u0430\u0440\u043A\u0430\u0441\u0442\u0438\u0447\u043D\u0430\u044F
    \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u044F (\u0432\u043C\u0435\u0441\u0442\u043E
    \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u044F) \u0415\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u0430
    \u0431\u044B\u043B\u0430 \u0443\u0442\u0435\u0440\u044F\u043D\u0430 \u0447\u0435\u0440\u0435\u0437
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0434\u043D\u0435\u0439
    \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u0445\u043E\u0440\u043E\u043D \u2014
    \u0430\u0440\u043C\u0438\u044F \u0448\u0432\u0435\u0434\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u044F \u0441\u0440\u0430\u0432\u043D\u044F\u043B\u0430
    \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435 \u0441 \u0437\u0435\u043C\u043B\u0435\u0439.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C
    \u0441\u0442\u0438\u0445\u043E\u0442\u0432\u043E\u0440\u0435\u043D\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u041A\u0435\u043F\u043B\u0435\u0440
    \u0441\u043E\u0447\u0438\u043D\u0438\u043B \u0434\u043B\u044F \u0441\u0432\u043E\u0435\u0433\u043E
    \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u043D\u043E\u0433\u043E \u043A\u0430\u043C\u043D\u044F
    \u0437\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043B\u0435\u0442
    \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438. \u042D\u0442\u043E \u0431\u044B\u043B\u0430
    \u0435\u0434\u043A\u0430\u044F \u0438\u0440\u043E\u043D\u0438\u044F \u043D\u0430\u0434
    \u0441\u0432\u043E\u0435\u0439 \u0431\u043B\u0438\u0437\u043E\u0440\u0443\u043A\u043E\u0441\u0442\u044C\u044E: 
    > *\xAB\u042F, \u0418\u043E\u0433\u0430\u043D\u043D \u041A\u0435\u043F\u043B\u0435\u0440,
    \u043C\u0435\u0440\u0438\u043B \u043D\u0435\u0431\u0435\u0441\u0430, \u043D\u043E
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u043C\u0435\u0440\u044F\u044E \u0442\u0435\u043D\u0438
    \u0437\u0435\u043C\u043D\u044B\u0435. / \u0422\u0430\u043C, \u043D\u0430\u0432\u0435\u0440\u0445\u0443,
    \u044F \u0436\u0438\u043B \u0434\u0443\u0445\u043E\u043C, \u0437\u0434\u0435\u0441\u044C
    \u0436\u0435 \u043F\u043E\u043A\u043E\u0438\u0442\u0441\u044F \u043B\u0438\u0448\u044C
    \u0442\u0435\u043B\u0435\u0441\u043D\u0430\u044F \u043E\u0431\u043E\u043B\u043E\u0447\u043A\u0430\xBB.* 
    \u041D\u043E \u0432 \u0447\u0435\u0440\u043D\u043E\u0432\u0438\u043A\u0430\u0445
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C \u0432\u0442\u043E\u0440\u0430\u044F,
    \u0431\u043E\u043B\u0435\u0435 \u044F\u0437\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0432\u0435\u0440\u0441\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u043D\u0435 \u0440\u0435\u0448\u0438\u043B\u0441\u044F \u0432\u044B\u0433\u0440\u0430\u0432\u0438\u0440\u043E\u0432\u0430\u0442\u044C:
    > *\xAB\u0412\u043E\u0442 \u043B\u0435\u0436\u0438\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0435\u0432\u0437\u043E\u0448\u0435\u043B
    \u0432\u0441\u0435\u0445, \u043D\u043E \u0433\u0440\u043E\u0448 \u0435\u043C\u0443
    \u0446\u0435\u043D\u0430, \u0438\u0431\u043E \u043E\u043D \u043D\u0435 \u0443\u043C\u0435\u043B
    \u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0442\u044C \u0434\u0435\u043D\u044C\u0433\u0438\xBB.* 
    ### \U0001F52D 9. \u0422\u0435\u043B\u0435\u0441\u043A\u043E\u043F, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0435 \u043C\u043E\u0433\u043B\u0438 \u043F\u043E\u0432\u0442\u043E\u0440\u0438\u0442\u044C
    10 \u043B\u0435\u0442 \u0412 1611 \u0433\u043E\u0434\u0443 \u041A\u0435\u043F\u043B\u0435\u0440
    \u043E\u043F\u0438\u0441\u0430\u043B \u0441\u0445\u0435\u043C\u0443 \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u0430
    \u0441 \u0434\u0432\u0443\u043C\u044F \u0432\u044B\u043F\u0443\u043A\u043B\u044B\u043C\u0438
    \u043B\u0438\u043D\u0437\u0430\u043C\u0438. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0432 \u0435\u0433\u043E \u0447\u0435\u0440\u0442\u0435\u0436\u0435 \u0431\u044B\u043B\u043E
    \u043E\u0434\u043D\u043E \"\u043D\u043E\": \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0432 \u043D\u0435\u043C \u043F\u043E\u043B\u0443\u0447\u0430\u043B\u043E\u0441\u044C
    \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443\u0442\u044B\u043C \u0432\u0432\u0435\u0440\u0445
    \u043D\u043E\u0433\u0430\u043C\u0438.   \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u0432\u044B\u0441\u043C\u0435\u044F\u043B\u0438 \u0435\u0433\u043E. \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u044B
    \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438: *\xAB\u041A\u0442\u043E \u0437\u0430\u0445\u043E\u0447\u0435\u0442
    \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C \u043D\u0430 \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443\u0442\u044B\u0435
    \u0437\u0432\u0435\u0437\u0434\u044B? \u042D\u0442\u043E \u0431\u0435\u0441\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u043D\u043E!\xBB*.
    \u0418\u0437-\u0437\u0430 \u044D\u0442\u043E\u0433\u043E \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F
    \u041A\u0435\u043F\u043B\u0435\u0440\u0430 \u043D\u0435 \u0441\u0442\u0440\u043E\u0438\u043B\u0438
    \u043F\u043E\u0447\u0442\u0438 10 \u043B\u0435\u0442. \u0422\u043E\u043B\u044C\u043A\u043E
    \u043A\u043E\u0433\u0434\u0430 \u043F\u043E\u043D\u044F\u043B\u0438, \u0447\u0442\u043E
    \u0434\u043B\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443\u0442\u043E\u0435 \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u043D\u0435 \u0438\u043C\u0435\u0435\u0442 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    (\u0432 \u043A\u043E\u0441\u043C\u043E\u0441\u0435 \u043D\u0435\u0442 \"\u0432\u0435\u0440\u0445\u0430\"
    \u0438 \"\u043D\u0438\u0437\u0430\"), \u044D\u0442\u0443 \u0441\u0445\u0435\u043C\u0443
    \u0432\u0437\u044F\u043B\u0438 \u0437\u0430 \u043E\u0441\u043D\u043E\u0432\u0443
    \u0432\u0441\u0435 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438
    \u043C\u0438\u0440\u0430.   ### \u2712\uFE0F 10. \u0415\u0433\u043E \u0441\u043F\u0430\u0441\u043B\u0430...
    \u043E\u043F\u0435\u0447\u0430\u0442\u043A\u0430 \u0432 \u0442\u0438\u0442\u0443\u043B\u0435
    \u041A\u043E\u0433\u0434\u0430 \u0432 \u0413\u0440\u0430\u0446\u0435 \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C
    \u041A\u043E\u043D\u0442\u0440\u0440\u0435\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F,
    \u0432\u0441\u0435 \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u0441\u043A\u0438\u0435
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F \u0431\u044B\u043B\u0438 \u0443\u0432\u043E\u043B\u0435\u043D\u044B.
    \u041A\u0435\u043F\u043B\u0435\u0440\u0443 \u0442\u043E\u0436\u0435 \u043F\u0440\u0438\u043A\u0430\u0437\u0430\u043B\u0438
    \u043F\u043E\u043A\u0438\u043D\u0443\u0442\u044C \u0433\u043E\u0440\u043E\u0434.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0432 \u0435\u0433\u043E \u0443\u0432\u043E\u043B\u044C\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0431\u0443\u043C\u0430\u0433\u0435 \u043F\u043E \u043E\u0448\u0438\u0431\u043A\u0435
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B\u0438, \u0447\u0442\u043E \u043E\u043D
    \u0443\u0435\u0437\u0436\u0430\u0435\u0442 \u0434\u043B\u044F \xAB\u0443\u043B\u0443\u0447\u0448\u0435\u043D\u0438\u044F
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F\xBB (*Sanitatis causa*), \u0430
    \u043D\u0435 \u043F\u043E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u043C
    \u043C\u043E\u0442\u0438\u0432\u0430\u043C.  \u042D\u0442\u0430 \u0431\u044E\u0440\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043E\u043F\u0435\u0447\u0430\u0442\u043A\u0430 \u0441\u044B\u0433\u0440\u0430\u043B\u0430
    \u0440\u0435\u0448\u0430\u044E\u0449\u0443\u044E \u0440\u043E\u043B\u044C: \u043F\u043E\u0437\u0436\u0435,
    \u043A\u043E\u0433\u0434\u0430 \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u043B\u0430\u0441\u0442\u0438 \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0438\u0441\u044C
    \u043E\u0431\u044A\u044F\u0432\u0438\u0442\u044C \u0435\u0433\u043E \u0438\u0437\u0433\u043D\u0430\u043D\u043D\u0438\u043A\u043E\u043C-\u0435\u0440\u0435\u0442\u0438\u043A\u043E\u043C,
    \u043E\u043D \u043F\u0440\u0435\u0434\u044A\u044F\u0432\u0438\u043B \u044D\u0442\u0443
    \u0431\u0443\u043C\u0430\u0433\u0443. \u0424\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E
    \u043E\u043D \u043D\u0435 \u0431\u044B\u043B \u043B\u0438\u0448\u0435\u043D \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438
    \u0437\u0430 \u0432\u0435\u0440\u0443, \u0430 \u043F\u0440\u043E\u0441\u0442\u043E
    \"\u0443\u0435\u0445\u0430\u043B \u043B\u0435\u0447\u0438\u0442\u044C\u0441\u044F\",
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u043E\u043D \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B
    \u043F\u0440\u0430\u0432\u043E \u043D\u0430 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0438 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u0435 \u043F\u0435\u043D\u0441\u0438\u0438. 
    ---  \u041A\u0430\u043A \u0432\u0438\u0434\u0438\u0442\u0435, \u041A\u0435\u043F\u043B\u0435\u0440
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \"\u0441\u043A\u0443\u0447\u043D\u044B\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C\" \u0441 \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u043C\u0438.
    \u041E\u043D \u0431\u044B\u043B \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u0438\u0441\u0442\u043E\u043C,
    \u0444\u0430\u043D\u0442\u0430\u0441\u0442\u043E\u043C, \u043F\u043E\u044D\u0442\u043E\u043C,
    \u043D\u0435\u043C\u043D\u043E\u0433\u043E \u0441\u043A\u0443\u043F\u044B\u043C,
    \u043A\u0440\u0430\u0439\u043D\u0435 \u043D\u0435\u0443\u0434\u0430\u0447\u043B\u0438\u0432\u044B\u043C
    \u0432 \u0431\u044B\u0442\u0443, \u043D\u043E \u043F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u0430\u0436\u0435 \u0432 \u043D\u0438\u0449\u0435\u0442\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u043B
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E \u044E\u043C\u043E\u0440\u0430."
