  achievementsRu: "\u041C\u0430\u0440\u0438\u0430\u043C \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u0440\u0430\u0431\u043E\u0442\u0430\u044F
    \u043D\u0430 \u0441\u0442\u044B\u043A\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438 \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438.
    \u0415\u0451 \u0432\u043A\u043B\u0430\u0434 \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u043D\u0430 \u0434\u0432\u0435 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438: \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432 \u043C\u043E\u0434\u0443\u043B\u0435\u0439
    \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u044B\u0445 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439,
    \u0433\u0434\u0435 \u043E\u043D\u0430 \u0440\u0435\u0448\u0438\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0438 \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435
    \u0431\u0438\u043B\u044C\u044F\u0440\u0434\u043E\u0432, \u043A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u0435\u0439
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u0442\u0430\u043B\u0430 \xAB\u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043C\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043F\u0430\u043B\u043E\u0447\u043A\u0435\xBB. 
    ### \U0001F4D0 \u041F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430
    \u043C\u043E\u0434\u0443\u043B\u0435\u0439 \u0438 \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F  \u042D\u0442\u0430 \u043E\u0431\u043B\u0430\u0441\u0442\u044C
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0439
    \u0432 \u0435\u0451 \u043A\u0430\u0440\u044C\u0435\u0440\u0435. \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u0432\u043A\u043B\u044E\u0447\u0430\u044E\u0442: 
    *   **\u0424\u043E\u0440\u043C\u0443\u043B\u0430 \u0434\u043B\u044F \u043E\u0431\u044A\u0451\u043C\u0430
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432 \u043C\u043E\u0434\u0443\u043B\u0435\u0439**:
    \u0412 \u0434\u0432\u0443\u0445 \u0441\u0432\u043E\u0438\u0445 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442\u0430\u0445 2007 \u0433\u043E\u0434\u0430 \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u0432\u044B\u0432\u0435\u043B\u0430 \u044F\u0432\u043D\u0443\u044E \u0440\u0435\u043A\u0443\u0440\u0441\u0438\u0432\u043D\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0434\u043B\u044F \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u043E\u0431\u044A\u0451\u043C\u0430 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430
    \u043C\u043E\u0434\u0443\u043B\u0435\u0439 \\( \\mathcal{M}_{g,n}(L) \\) \u2014
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430 \u0432\u0441\u0435\u0445
    \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u044B\u0445 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439
    \u0440\u043E\u0434\u0430 \\( g \\) \u0441 \\( n \\) \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0433\u0440\u0430\u043D\u0438\u0447\u043D\u044B\u043C\u0438 \u043A\u043E\u043C\u043F\u043E\u043D\u0435\u043D\u0442\u0430\u043C\u0438
    \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u0439 \u0434\u043B\u0438\u043D\u044B
    \\( L \\). \u0420\u0430\u043D\u0435\u0435 \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0431\u044B\u043B\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B \u043B\u0438\u0448\u044C
    \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u0435 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B,
    \u0438 \u0435\u0451 \u0444\u043E\u0440\u043C\u0443\u043B\u0430 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0430
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u0442\u044C \u044D\u0442\u0438 \u043E\u0431\u044A\u0451\u043C\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u043E\u0439
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0422\u0435\u0439\u0445\u043C\u044E\u043B\u043B\u0435\u0440\u0430.
    \u041E\u043D\u0430 \u0434\u043E\u043A\u0430\u0437\u0430\u043B\u0430, \u0447\u0442\u043E
    \u044D\u0442\u0438 \u043E\u0431\u044A\u0451\u043C\u044B \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u043F\u043E\u043B\u0438\u043D\u043E\u043C\u0430\u043C\u0438 \u043E\u0442 \u0434\u043B\u0438\u043D
    \u0433\u0440\u0430\u043D\u0438\u0446, \u0430 \u0438\u0445 \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u044B
    \u0441\u0432\u044F\u0437\u0430\u043D\u044B \u0441 \u0447\u0438\u0441\u043B\u0430\u043C\u0438
    \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0439 \u043D\u0430
    \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u043C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435 \u043C\u043E\u0434\u0443\u043B\u0435\u0439. 
    *   **\u041D\u043E\u0432\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u0412\u0438\u0442\u0442\u0435\u043D\u0430**:
    \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u0441\u0432\u043E\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0434\u043B\u044F \u043E\u0431\u044A\u0451\u043C\u043E\u0432,
    \u043E\u043D\u0430 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B\u0430
    \u043D\u043E\u0432\u043E\u0435, \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u0412\u0438\u0442\u0442\u0435\u043D\u0430
    (\u043F\u0435\u0440\u0432\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442 \u041C\u0430\u043A\u0441\u0438\u043C\u0443
    \u041A\u043E\u043D\u0446\u0435\u0432\u0438\u0447\u0443). \u042D\u0442\u0430 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u0435\u0442 \u0447\u0438\u0441\u043B\u0430
    \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0439 \u043D\u0430
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430\u0445
    \u043C\u043E\u0434\u0443\u043B\u0435\u0439 \u0441 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439
    \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u0435\u0439 \u0438 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432 \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435.  *   **\u0410\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u043A\u0430
    \u0447\u0438\u0441\u043B\u0430 \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445**:
    \u0412 \u0441\u0432\u043E\u0435\u0439 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438
    (2004) \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442\u0430\u0445 \u043E\u043D\u0430 \u0440\u0435\u0448\u0438\u043B\u0430
    \u0437\u0430\u0434\u0430\u0447\u0443 \u043F\u043E\u0434\u0441\u0447\u0451\u0442\u0430
    \u0447\u0438\u0441\u043B\u0430 \\( N(X, L) \\) \u043F\u0440\u043E\u0441\u0442\u044B\u0445
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0445 \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    (\u043D\u0435 \u0438\u043C\u0435\u044E\u0449\u0438\u0445 \u0441\u0430\u043C\u043E\u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u0439)
    \u043D\u0430 \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438 \\( X \\),
    \u0434\u043B\u0438\u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043D\u0435
    \u043F\u0440\u0435\u0432\u044B\u0448\u0430\u0435\u0442 \\( L \\). \u041E\u043D\u0430
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B\u0430, \u0447\u0442\u043E \u044D\u0442\u043E
    \u0447\u0438\u0441\u043B\u043E \u0440\u0430\u0441\u0442\u0451\u0442 \u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043A\u0430\u043A:     \\( N(X, L) \\sim c(X) \\cdot L^{6g-6} \\) \u043F\u0440\u0438
    \\( L \\to \\infty \\), \u0433\u0434\u0435 \\( c(X) \\) \u2014 \u043A\u043E\u043D\u0441\u0442\u0430\u043D\u0442\u0430,
    \u0437\u0430\u0432\u0438\u0441\u044F\u0449\u0430\u044F \u043E\u0442 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438.    
    \u042D\u0442\u043E\u0442 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0440\u043E\u0441\u0442
    \u0447\u0438\u0441\u043B\u0430 \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u0435\u0435,
    \u0447\u0435\u043C \u0440\u043E\u0441\u0442 \u0432\u0441\u0435\u0445 \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    (\u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u044D\u043A\u0441\u043F\u043E\u043D\u0435\u043D\u0446\u0438\u0430\u043B\u0435\u043D),
    \u0447\u0442\u043E \u043E\u0442\u0440\u0430\u0436\u0430\u0435\u0442 \u0441\u043B\u043E\u0436\u043D\u0443\u044E
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0443 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u043F\u0435\u0442\u0435\u043B\u044C
    \u043D\u0430 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438. 
    ### \U0001FA84 \xAB\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E \u043C\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u0430\u043B\u043E\u0447\u043A\u0435\xBB \u0438 \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0430 
    \u042D\u0442\u043E \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u0435\u0442 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
