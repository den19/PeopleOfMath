  achievementsEn: 
  personalLifeRu: "\u041C\u0430\u0440\u0438\u0430\u043C \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438,
    \u043F\u0440\u0438 \u0432\u0441\u0435\u0439 \u0441\u0432\u043E\u0435\u0439 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438,
    \u0431\u044B\u043B\u0430 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u043D\u044B\u043C,
    \u0441\u0442\u043E\u0439\u043A\u0438\u043C \u0438 \u043E\u0447\u0435\u043D\u044C
    \u043B\u0438\u0447\u043D\u044B\u043C \u0432 \u0441\u0432\u043E\u0435\u043C \u043F\u043E\u0434\u0445\u043E\u0434\u0435
    \u043A \u043D\u0430\u0443\u043A\u0435. \u0415\u0435 \u0436\u0438\u0437\u043D\u044C
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E \u0442\u043E\u043C,
    \u043A\u0430\u043A \u0441\u0442\u0440\u0430\u0441\u0442\u044C \u0438 \u0443\u043F\u043E\u0440\u0441\u0442\u0432\u043E,
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0430 \u0431\u043B\u0438\u0437\u043A\u0438\u0445
    \u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C \u0432\u0438\u0434\u0435\u0442\u044C
    \u043A\u0440\u0430\u0441\u043E\u0442\u0443 \u0432 \u0441\u043B\u043E\u0436\u043D\u043E\u043C
    \u043F\u0440\u0438\u0432\u0435\u043B\u0438 \u043A \u0432\u0435\u0440\u0448\u0438\u043D\u0430\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C
    \u043D\u0435\u0434\u043E\u0441\u0442\u0438\u0436\u0438\u043C\u044B\u043C\u0438. 
    ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466 \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435,
    \u0441\u0435\u043C\u044C\u044F \u0438 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F
    \u041C\u0430\u0440\u0438\u0430\u043C \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C **12 \u043C\u0430\u044F 1977
    \u0433\u043E\u0434\u0430** \u0432 \u0422\u0435\u0433\u0435\u0440\u0430\u043D\u0435,
    \u0418\u0440\u0430\u043D, \u0438 \u0431\u044B\u043B\u0430 \u0447\u0435\u0442\u0432\u0435\u0440\u0442\u044B\u043C
    \u0440\u0435\u0431\u0435\u043D\u043A\u043E\u043C \u0432 \u0441\u0435\u043C\u044C\u0435.
    \u0415\u0435 \u043E\u0442\u0435\u0446, \u0410\u0445\u043C\u0430\u0434 \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438,
    \u0431\u044B\u043B \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C-\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u043A\u043E\u043C.
    \u0412 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u043E\u043D\u0430 \u043C\u0435\u0447\u0442\u0430\u043B\u0430
    \u043D\u0435 \u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u0430 \u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0435 \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u044F
    \u0438 \u043E\u0431\u043E\u0436\u0430\u043B\u0430 \u0447\u0438\u0442\u0430\u0442\u044C
    \u0440\u043E\u043C\u0430\u043D\u044B, \u0447\u0442\u043E \u0440\u0430\u0437\u0432\u0438\u043B\u043E
    \u0435\u0435 \u0431\u043E\u0433\u0430\u0442\u043E\u0435 \u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441 \u043A \u043D\u0430\u0443\u043A\u0435
    \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B \u0435\u0435 \u0441\u0442\u0430\u0440\u0448\u0438\u0439
    \u0431\u0440\u0430\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u043B
    \u0435\u0439 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u043E \u0442\u043E\u043C,
    \u043A\u0430\u043A \u041A\u0430\u0440\u043B \u0413\u0430\u0443\u0441\u0441 \u0432
    \u044E\u043D\u043E\u0441\u0442\u0438 \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E
    \u0441\u043B\u043E\u0436\u0438\u043B \u0447\u0438\u0441\u043B\u0430 \u043E\u0442
    1 \u0434\u043E 100, \u0438 \u044D\u0442\u043E \u0443\u0432\u043B\u0435\u043A\u043B\u043E
    \u0435\u0435.  ### \U0001F3EB \u0428\u043A\u043E\u043B\u044C\u043D\u044B\u0435
    \u0433\u043E\u0434\u044B: \u043F\u0443\u0442\u044C \u043E\u0442 \u043D\u0435\u0443\u0432\u0435\u0440\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u0434\u043E \u0437\u043E\u043B\u043E\u0442\u0430 \u043E\u043B\u0438\u043C\u043F\u0438\u0430\u0434
    \u0412 \u0448\u0435\u0441\u0442\u043E\u043C \u043A\u043B\u0430\u0441\u0441\u0435,
    \u043A\u043E\u0433\u0434\u0430 \u041C\u0430\u0440\u0438\u0430\u043C \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B\u0430
    \u0432 \u044D\u043B\u0438\u0442\u043D\u0443\u044E \u0448\u043A\u043E\u043B\u0443
    \u0424\u0430\u0440\u0437\u0430\u043D\u0435\u0433\u0430\u043D \u0434\u043B\u044F
    \u043E\u0434\u0430\u0440\u0435\u043D\u043D\u044B\u0445 \u0434\u0435\u0432\u043E\u0447\u0435\u043A,
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043F\u043E\u0441\u0447\u0438\u0442\u0430\u043B,
    \u0447\u0442\u043E \u0435\u0439 \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0435\u0439. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439 \u0433\u043E\u0434
    \u0441\u043C\u0435\u043D\u0438\u043B\u0441\u044F \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0432\u0435\u0440\u0438\u043B
    \u0432 \u043D\u0435\u0435, \u0438 \u0442\u0430\u043B\u0430\u043D\u0442 \u041C\u0430\u0440\u0438\u0430\u043C
    \u0440\u0430\u0441\u043A\u0440\u044B\u043B\u0441\u044F.  \u0412 \u0448\u043A\u043E\u043B\u0435
    \u043E\u043D\u0430 \u043F\u043E\u0434\u0440\u0443\u0436\u0438\u043B\u0430\u0441\u044C
    \u0441 \u0420\u043E\u0439\u0435\u0439 \u0411\u0435\u0445\u0435\u0448\u0442\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0442\u0430\u043A\u0436\u0435 \u0441\u0442\u0430\u043B\u0430
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C.
    \u0412\u043C\u0435\u0441\u0442\u0435 \u043E\u043D\u0438 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043B\u0438
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0432 \u0448\u043A\u043E\u043B\u0435 \u043A\u0440\u0443\u0436\u043E\u043A
    \u043F\u043E \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0435
    \u0434\u043B\u044F \u0434\u0435\u0432\u043E\u0447\u0435\u043A. \u0418\u0445 \u0443\u043F\u043E\u0440\u0441\u0442\u0432\u043E
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0442\u043E\u043C\u0443, \u0447\u0442\u043E
    \u0432 1994 \u0433\u043E\u0434\u0443 \u043E\u043D\u0438 \u0441\u0442\u0430\u043B\u0438
    \u043F\u0435\u0440\u0432\u044B\u043C\u0438 \u0434\u0435\u0432\u0443\u0448\u043A\u0430\u043C\u0438
    \u0432 \u0441\u0431\u043E\u0440\u043D\u043E\u0439 \u0418\u0440\u0430\u043D\u0430
    \u043D\u0430 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u0435. \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u043B\u0430 \u0442\u0430\u043C \u0437\u043E\u043B\u043E\u0442\u0443\u044E
    \u043C\u0435\u0434\u0430\u043B\u044C, \u043D\u0430\u0431\u0440\u0430\u0432 41
    \u0431\u0430\u043B\u043B \u0438\u0437 42, \u0430 \u0432 1995 \u0433\u043E\u0434\u0443
    \u043F\u043E\u0432\u0442\u043E\u0440\u0438\u043B\u0430 \u0443\u0441\u043F\u0435\u0445,
    \u043F\u043E\u043B\u0443\u0447\u0438\u0432 \u0432\u0442\u043E\u0440\u0443\u044E
    \u0437\u043E\u043B\u043E\u0442\u0443\u044E \u043C\u0435\u0434\u0430\u043B\u044C
    \u0441 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u043C
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C \u0432 42
    \u0431\u0430\u043B\u043B\u0430.  ### \U0001F393 \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u043D\u0430\u0447\u0430\u043B\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u043F\u0443\u0442\u0438 \u0412 1999 \u0433\u043E\u0434\u0443 \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u043E\u043A\u043E\u043D\u0447\u0438\u043B\u0430 \u0422\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0438\u043C\u0435\u043D\u0438
    \u0428\u0430\u0440\u0438\u0444\u0430 \u0432 \u0422\u0435\u0433\u0435\u0440\u0430\u043D\u0435
    \u0441\u043E \u0441\u0442\u0435\u043F\u0435\u043D\u044C\u044E \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430.
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u0443\u0447\u0435\u0431\u044B \u043E\u043D\u0430
    \u043F\u0435\u0440\u0435\u0436\u0438\u043B\u0430 \u0442\u044F\u0436\u0435\u043B\u0443\u044E
    \u0430\u0432\u0430\u0440\u0438\u044E: \u0432 1998 \u0433\u043E\u0434\u0443 \u0430\u0432\u0442\u043E\u0431\u0443\u0441
    \u0441 \u043E\u0434\u043D\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A\u0430\u043C\u0438
    \u0443\u043F\u0430\u043B \u0432 \u043E\u0432\u0440\u0430\u0433, \u0441\u0435\u043C\u044C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u043F\u043E\u0433\u0438\u0431\u043B\u0438,
    \u043D\u043E \u041C\u0430\u0440\u0438\u0430\u043C \u0447\u0443\u0434\u043E\u043C
    \u0432\u044B\u0436\u0438\u043B\u0430.  \u0412 \u0442\u043E\u043C \u0436\u0435
    1999 \u0433\u043E\u0434\u0443 \u043E\u043D\u0430 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u0421\u0428\u0410 \u0434\u043B\u044F \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
    \u0432 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u0443\u0440\u0443 \u0413\u0430\u0440\u0432\u0430\u0440\u0434\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430. \u0415\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C
    \u0441\u0442\u0430\u043B **\u041A\u0451\u0440\u0442\u0438\u0441 \u041C\u0430\u043A\u043C\u0443\u043B\u043B\u0435\u043D**,
    \u0441\u0430\u043C \u043B\u0430\u0443\u0440\u0435\u0430\u0442 \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438.  ### \U0001F52C \u0420\u0430\u0431\u043E\u0442\u0430
    \u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438
    \u0412 2004 \u0433\u043E\u0434\u0443 \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u0437\u0430\u0449\u0438\u0442\u0438\u043B\u0430
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u0432 \u0413\u0430\u0440\u0432\u0430\u0440\u0434\u0435. \u041F\u043E\u0441\u043B\u0435
    \u044D\u0442\u043E\u0433\u043E \u043E\u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u0430
    \u0441 2008 \u0433\u043E\u0434\u0430 \u0441\u0442\u0430\u043B\u0430 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432 \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435.  \u0412
    \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434\u0435 \u043E\u043D\u0430 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0430\u0441\u044C
    \u0441\u043E \u0441\u0432\u043E\u0438\u043C \u0431\u0443\u0434\u0443\u0449\u0438\u043C
    \u043C\u0443\u0436\u0435\u043C, **\u042F\u043D\u043E\u043C \u0412\u043E\u043D\u0434\u0440\u0430\u043A\u043E\u043C**,
    \u0443\u0447\u0435\u043D\u044B\u043C \u0447\u0435\u0448\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F,
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u043E\u043C \u0432
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0438.
    \u041E\u043D\u0438 \u043F\u043E\u0436\u0435\u043D\u0438\u043B\u0438\u0441\u044C
    \u0432 2009 \u0433\u043E\u0434\u0443, \u0430 \u0432 2011 \u0433\u043E\u0434\u0443
    \u0443 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u0434\u043E\u0447\u044C
    **\u0410\u043D\u0430\u0445\u0438\u0442\u0430**. \u0412\u043E\u043D\u0434\u0440\u0430\u043A
    \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B \u043E \u0435\u0435 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439
    \u0446\u0435\u043B\u0435\u0443\u0441\u0442\u0440\u0435\u043C\u043B\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u0434\u0430\u0436\u0435 \u0432 \u043C\u0435\u043B\u043E\u0447\u0430\u0445: \u043E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0435\u0439
    \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0443\u044E \u043F\u0440\u043E\u0431\u0435\u0436\u043A\u0443,
    \u043D\u043E \u0447\u0435\u0440\u0435\u0437 \u043F\u043E\u043B\u0442\u043E\u0440\u0430
    \u0447\u0430\u0441\u0430 \u043E\u043D \u0432\u044B\u0434\u043E\u0445\u0441\u044F,
    \u0430 \u043E\u043D\u0430 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B\u0430
    \u0431\u0435\u0436\u0430\u0442\u044C \u0432 \u0442\u043E\u043C \u0436\u0435 \u0442\u0435\u043C\u043F\u0435. 
    \u041A\u043E\u043B\u043B\u0435\u0433\u0438 \u043E\u0442\u043C\u0435\u0447\u0430\u043B\u0438
    \u0435\u0435 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C,
    \u043D\u043E \u0438 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0443\u044E
    \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u044C. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u041C\u0430\u043D\u0436\u0443\u043B \u0411\u0445\u0430\u0440\u0433\u0430\u0432\u0430,
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u043E\u043D\u0430 \u043F\u043E\u043B\u0443\u0447\u0430\u043B\u0430 \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E, \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B
    \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439:
    \u043D\u0430 \u0446\u0435\u0440\u0435\u043C\u043E\u043D\u0438\u0438 \u043C\u0435\u0434\u0430\u043B\u0438
    \u043F\u0435\u0440\u0435\u043F\u0443\u0442\u0430\u043B\u0438, \u0438 \u0443 \u043A\u0430\u0436\u0434\u043E\u0433\u043E
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C \u0447\u0443\u0436\u0430\u044F.
    \u041E\u043D\u0438 \u0441 \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0440\u0435\u0448\u0438\u043B\u0438
    \u044D\u0442\u0443 \"\u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u043D\u0443\u044E
    \u0437\u0430\u0434\u0430\u0447\u0443\", \u043E\u0431\u043C\u0435\u043D\u044F\u0432\u0448\u0438\u0441\u044C
    \u043C\u0435\u0434\u0430\u043B\u044F\u043C\u0438 \u0438 \u0434\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u0432\u0448\u0438\u0441\u044C
    \u043E \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C \u043E\u0431\u043C\u0435\u043D\u0435,
    \u0447\u0442\u043E\u0431\u044B \u0432\u0441\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438
    \u0441\u0432\u043E\u0438 \u043D\u0430\u0433\u0440\u0430\u0434\u044B.  \u0415\u0435
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043D\u0430\u0434 \xAB\u0442\u0435\u043E\u0440\u0435\u043C\u043E\u0439
    \u043E \u043C\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043F\u0430\u043B\u043E\u0447\u043A\u0435\xBB
    \u0441 \u0410\u043B\u0435\u043A\u0441\u043E\u043C \u042D\u0441\u043A\u0438\u043D\u043E\u043C
    \u0431\u044B\u043B\u0430 \u043E\u043F\u0438\u0441\u0430\u043D\u0430 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438
    \u043A\u0430\u043A \xAB\u043D\u0430\u0443\u0447\u043D\u0430\u044F \u0444\u0430\u043D\u0442\u0430\u0441\u0442\u0438\u043A\u0430\xBB;
    \u043E\u043D\u0430 \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439
    \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0435\u043D\u043D\u043E\u0441\u0442\u0438,
    \u043D\u043E \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438, \u043F\u043E
    \u0441\u043B\u043E\u0432\u0430\u043C \u042D\u0441\u043A\u0438\u043D\u0430, \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u043F\u0430\u043D\u0438\u043A\u043E\u0432\u0430\u043B\u0430, \u0434\u0430\u0436\u0435
    \u043A\u043E\u0433\u0434\u0430 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
    \u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C \u043D\u0435\u0434\u043E\u0441\u0442\u0438\u0436\u0438\u043C\u044B\u043C\u0438. 
    ### \U0001F396 \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435: \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F \u0412 2014 \u0433\u043E\u0434\u0443 \u041C\u0430\u0440\u0438\u0430\u043C
    \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438 \u0441\u0442\u0430\u043B\u0430
    \u043F\u0435\u0440\u0432\u043E\u0439 \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439
    \u0438 \u043F\u0435\u0440\u0432\u044B\u043C \u0438\u0440\u0430\u043D\u0446\u0435\u043C,
    \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D\u043D\u044B\u043C **\u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438** \u2014 \u0441\u0430\u043C\u043E\u0439
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0439 \u043D\u0430\u0433\u0440\u0430\u0434\u044B
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0432\u0440\u0443\u0447\u0430\u0435\u0442\u0441\u044F \u0440\u0430\u0437 \u0432
    \u0447\u0435\u0442\u044B\u0440\u0435 \u0433\u043E\u0434\u0430 \u0443\u0447\u0435\u043D\u044B\u043C
    \u043D\u0435 \u0441\u0442\u0430\u0440\u0448\u0435 40 \u043B\u0435\u0442.  \u041F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0438\u0437\u0432\u0435\u0441\u0442\u0438\u0435 \u043E \u043F\u0440\u0435\u043C\u0438\u0438
    \u043F\u043E \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u043D\u043E\u0439
    \u043F\u043E\u0447\u0442\u0435, \u043E\u043D\u0430 \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u043F\u0440\u0438\u043D\u044F\u043B\u0430 \u0435\u0433\u043E \u0437\u0430 \u0448\u0443\u0442\u043A\u0443.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0431\u043E\u043B\u0435\u0437\u043D\u044C,
    \u043E\u043D\u0430 \u0441\u043C\u043E\u0433\u043B\u0430 \u043F\u0440\u0438\u0435\u0445\u0430\u0442\u044C
    \u043D\u0430 \u0446\u0435\u0440\u0435\u043C\u043E\u043D\u0438\u044E \u0432\u0440\u0443\u0447\u0435\u043D\u0438\u044F
    \u0432 \u0421\u0435\u0443\u043B. \u0413\u0440\u0443\u043F\u043F\u0430 \u0436\u0435\u043D\u0449\u0438\u043D-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0434\u0430\u0436\u0435 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043B\u0430
    \u0434\u043B\u044F \u043D\u0435\u0435 \u043D\u0435\u0433\u043B\u0430\u0441\u043D\u0443\u044E
    \u043E\u0445\u0440\u0430\u043D\u0443, \"\u0449\u0438\u0442 \u041C.\u041C.\",
    \u0447\u0442\u043E\u0431\u044B \u043E\u0433\u0440\u0430\u0434\u0438\u0442\u044C
    \u043E\u0442 \u0438\u0437\u043B\u0438\u0448\u043D\u0435\u0433\u043E \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u044F
    \u043F\u0440\u0435\u0441\u0441\u044B \u0438 \u043F\u043E\u043C\u043E\u0447\u044C
    \u0435\u0439 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E \u043D\u0430\u0441\u043B\u0430\u0434\u0438\u0442\u044C\u0441\u044F
    \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C.  ### \u2626\uFE0F \u0411\u043E\u043B\u0435\u0437\u043D\u044C
    \u0438 \u0441\u043C\u0435\u0440\u0442\u044C \u0412 2013 \u0433\u043E\u0434\u0443,
    \u043D\u0435\u0437\u0430\u0434\u043E\u043B\u0433\u043E \u0434\u043E \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F
    \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438,
    \u0443 \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438 \u0434\u0438\u0430\u0433\u043D\u043E\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    **\u0440\u0430\u043A \u0433\u0440\u0443\u0434\u0438**. \u041E\u043D\u0430 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u043D\u0430\u0434 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u0434\u0430\u0436\u0435 \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0442\u044F\u0436\u0435\u043B\u043E\u0433\u043E
    \u043B\u0435\u0447\u0435\u043D\u0438\u044F.  \u041A 2017 \u0433\u043E\u0434\u0443
    \u0431\u043E\u043B\u0435\u0437\u043D\u044C \u0434\u0430\u043B\u0430 \u043C\u0435\u0442\u0430\u0441\u0442\u0430\u0437\u044B
    \u0432 \u043F\u0435\u0447\u0435\u043D\u044C \u0438 \u043A\u043E\u0441\u0442\u043D\u044B\u0439
    \u043C\u043E\u0437\u0433. \u041C\u0430\u0440\u0438\u0430\u043C \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C **14 \u0438\u044E\u043B\u044F
    2017 \u0433\u043E\u0434\u0430** \u0432 \u041C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 40 \u043B\u0435\u0442."
  personalLifeEn: 
  shortBioRu: "\u041C\u0430\u0440\u0438\u0430\u043C \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u2014 \u0438\u0440\u0430\u043D\u0441\u043A\u0438\u0439 \u0438 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0436\u0435\u043D\u0449\u0438\u043D\u0430 \u0438 \u043F\u0435\u0440\u0432\u044B\u0439
    \u0438\u0440\u0430\u043D\u0435\u0446, \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D\u043D\u044B\u0435
    \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    (2014) \u0437\u0430 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u044B\u0445 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439
    \u0438 \u0442\u0435\u043E\u0440\u0438\u044E \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432
    \u0438\u0445 \u043C\u043E\u0434\u0443\u043B\u0435\u0439. \u0415\u0451 \u0436\u0438\u0437\u043D\u044C
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0430\u043B\u0430\u043D\u0442\u0430, \u043F\u0440\u0435\u043E\u0434\u043E\u043B\u0435\u043D\u0438\u044F
    \u0438 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u0440\u0430\u043D\u043D\u0435\u0433\u043E
    \u0443\u0445\u043E\u0434\u0430, \u043D\u043E \u0435\u0451 \u0440\u0430\u0431\u043E\u0442\u0430
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u0442\u044C
    \u0443\u0447\u0451\u043D\u044B\u0445 \u043F\u043E \u0432\u0441\u0435\u043C\u0443
    \u043C\u0438\u0440\u0443.  ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u043F\u0443\u0442\u044C \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 
    \u041C\u0430\u0440\u0438\u0430\u043C \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C 3 \u0438\u043B\u0438 12 \u043C\u0430\u044F
    1977 \u0433\u043E\u0434\u0430 \u0432 \u0422\u0435\u0433\u0435\u0440\u0430\u043D\u0435,
    \u0418\u0440\u0430\u043D. \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0447\u0435\u0442\u0432\u0435\u0440\u0442\u044B\u043C
    \u0440\u0435\u0431\u0435\u043D\u043A\u043E\u043C \u0432 \u0441\u0435\u043C\u044C\u0435
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430-\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u043A\u0430
    \u0410\u0445\u043C\u0430\u0434\u0430 \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u0438 \u0417\u0430\u0445\u0440\u044B \u0425\u0430\u0433\u0438\u0433\u0438. \u0421
    \u0440\u0430\u043D\u043D\u0438\u0445 \u043B\u0435\u0442 \u041C\u0430\u0440\u0438\u0430\u043C
    \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0430\u0441\u044C \u0447\u0442\u0435\u043D\u0438\u0435\u043C
    \u0438 \u043C\u0435\u0447\u0442\u0430\u043B\u0430 \u0441\u0442\u0430\u0442\u044C
    \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u0435\u043C. \u0418\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u043F\u0440\u043E\u0441\u043D\u0443\u043B\u0441\u044F
    \u0432 \u043D\u0435\u0439 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0441\u0442\u0430\u0440\u0448\u0435\u043C\u0443 \u0431\u0440\u0430\u0442\u0443,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B
    \u0435\u0439 \u043E\u0431 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F\u0445
    \u041A\u0430\u0440\u043B\u0430 \u0413\u0430\u0443\u0441\u0441\u0430.  \u0412
    \u0448\u043A\u043E\u043B\u0435 \u0424\u0430\u0440\u0437\u0430\u043D\u0435\u0433\u0430\u043D,
    \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u043E\u0439
    \u0434\u043B\u044F \u043E\u0434\u0430\u0440\u0451\u043D\u043D\u044B\u0445 \u0434\u0435\u0432\u043E\u0447\u0435\u043A,
    \u0435\u0451 \u043F\u0443\u0442\u044C \u043D\u0435 \u0431\u044B\u043B \u043F\u0440\u043E\u0441\u0442\u044B\u043C:
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u0443 \u043D\u0435\u0451
    \u043D\u0435\u0442 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0435\u0439
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0441\u043C\u0435\u043D\u0430 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044F
    \u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0430 \u043F\u043E\u0434\u0440\u0443\u0433\u0438
    \u0420\u043E\u0438 \u0411\u0435\u0445\u0435\u0448\u0442\u0438 \u043F\u043E\u043C\u043E\u0433\u043B\u0438
    \u0435\u0439 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u0440\u0435\u043E\u0434\u043E\u043B\u0435\u0442\u044C
    \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u044F, \u043D\u043E \u0438 \u0434\u043E\u0431\u0438\u0442\u044C\u0441\u044F
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F \u0443\u0441\u043F\u0435\u0445\u043E\u0432.
    \u0423\u0436\u0435 \u0432 \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0435 \u0433\u043E\u0434\u044B
    \u043E\u043D\u0430 \u043D\u0430\u0447\u0430\u043B\u0430 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\u043C\u0438,
    \u0430 \u0435\u0451 \u043F\u0435\u0440\u0432\u0430\u044F \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430, \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u0430\u044F
    \u0432 \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u0441\u0442\u0432\u0435, \u0431\u044B\u043B\u0430
    \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0433\u0440\u0430\u0444\u043E\u0432.  ### \U0001F3C5 \u041E\u043B\u0438\u043C\u043F\u0438\u0439\u0441\u043A\u0438\u0435
    \u043F\u043E\u0431\u0435\u0434\u044B \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 
    \u0412 1994 \u0438 1995 \u0433\u043E\u0434\u0430\u0445 \u041C\u0430\u0440\u0438\u0430\u043C
    \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u043E\u0439 \u0438\u0440\u0430\u043D\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u0446\u0435\u0439, \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u0432\u0448\u0435\u0439
    \u0437\u043E\u043B\u043E\u0442\u044B\u0435 \u043C\u0435\u0434\u0430\u043B\u0438
    \u043D\u0430 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u0435, \u043F\u0440\u0438\u0447\u0451\u043C
    \u0432 1995 \u0433\u043E\u0434\u0443 \u043E\u043D\u0430 \u0440\u0435\u0448\u0438\u043B\u0430
    \u0432\u0441\u0435 \u0437\u0430\u0434\u0430\u0447\u0438 \u0441 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u043C
    \u0431\u0430\u043B\u043B\u043E\u043C. \u0415\u0451 \u0442\u0430\u043B\u0430\u043D\u0442
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u0438 \u0432 \u0440\u0435\u0448\u0435\u043D\u0438\u0438
    \u0441\u043B\u043E\u0436\u043D\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0438
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0440\u0430\u0441\u043A\u0440\u0430\u0441\u043A\u0438
    \u0433\u0440\u0430\u0444\u043E\u0432, \u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D\u0430 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0440\u0438\u0437 \u0432 10 \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432
    \u043E\u0442 \u0441\u0432\u043E\u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u0430. 
    \u0412 1999 \u0433\u043E\u0434\u0443 \u043E\u043D\u0430 \u043E\u043A\u043E\u043D\u0447\u0438\u043B\u0430
    \u0422\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0438\u043C\u0435\u043D\u0438
    \u0428\u0430\u0440\u0438\u0444\u0430 \u0432 \u0422\u0435\u0433\u0435\u0440\u0430\u043D\u0435
    \u0441\u043E \u0441\u0442\u0435\u043F\u0435\u043D\u044C\u044E \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u0412
    \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u043E\u043D\u0430 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u0421\u0428\u0410 \u0434\u043B\u044F \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0435\u043D\u0438\u044F
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F. \u0412 2004
    \u0433\u043E\u0434\u0443 \u0432 \u0413\u0430\u0440\u0432\u0430\u0440\u0434\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u043F\u043E\u0434
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C \u041A\u0451\u0440\u0442\u0438\u0441\u0430
    \u041C\u0430\u043A\u043C\u0443\u043B\u043B\u0435\u043D\u0430 \u043E\u043D\u0430
    \u0437\u0430\u0449\u0438\u0442\u0438\u043B\u0430 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u0440\u0430\u0437\u0443 \u0431\u044B\u043B\u0430 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0430
    \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u043E\u0439.  ### \U0001F52C
    \u041D\u0430\u0443\u0447\u043D\u0430\u044F \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F 
    \u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B
    \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438 \u043B\u0435\u0436\u0430\u043B\u0438
    \u043D\u0430 \u0441\u0442\u044B\u043A\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E, \u0442\u0435\u043E\u0440\u0438\u0438
    \u0422\u0435\u0439\u0445\u043C\u044E\u043B\u043B\u0435\u0440\u0430, \u044D\u0440\u0433\u043E\u0434\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0438 \u0441\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u0415\u0451 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438 \u043F\u043E\u0434\u0445\u043E\u0434
    \u043A \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u044B\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439 \u0438
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432 \u0438\u0445
    \u043C\u043E\u0434\u0443\u043B\u0435\u0439. \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0432\u0435\u0445\u0438 \u0435\u0451 \u043A\u0430\u0440\u044C\u0435\u0440\u044B: 
    *   **2004\u20132008**: \u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0439
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u0430\u0442 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430
    \u041A\u043B\u044D\u044F \u0438 \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442-\u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. *  
    **\u0421 2008**: \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432 \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. *  
    **2014**: \u0421\u0442\u0430\u043B\u0430 \u043B\u0430\u0443\u0440\u0435\u0430\u0442\u043E\u043C
    \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    \u2014 \u0441\u0430\u043C\u043E\u0439 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0439
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u0432\u0440\u0443\u0447\u0430\u0435\u043C\u043E\u0439 \u0443\u0447\u0451\u043D\u044B\u043C
    \u0434\u043E 40 \u043B\u0435\u0442. \u041D\u0430\u0433\u0440\u0430\u0434\u0430
    \u0431\u044B\u043B\u0430 \u043F\u0440\u0438\u0441\u0443\u0436\u0434\u0435\u043D\u0430
    \u0437\u0430 \xAB\u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0443
    \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u044B\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439 \u0438
    \u0442\u0435\u043E\u0440\u0438\u044E \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432
    \u0438\u0445 \u043C\u043E\u0434\u0443\u043B\u0435\u0439\xBB.  \u041F\u043E\u043C\u0438\u043C\u043E
    \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438,
    \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D\u0430
    \u041F\u0440\u0435\u043C\u0438\u0438 \u0411\u043B\u044E\u043C\u0435\u043D\u0442\u0430\u043B\u044F
    (2009), \u041F\u0440\u0435\u043C\u0438\u0438 \u0420\u0443\u0444\u044C \u0421\u0430\u0442\u0442\u0435\u0440
    (2013) \u0438 \u041F\u0440\u0435\u043C\u0438\u0438 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430
    \u041A\u043B\u044D\u044F (2014). \u0412 2016 \u0433\u043E\u0434\u0443 \u0435\u0451
    \u0438\u0437\u0431\u0440\u0430\u043B\u0438 \u0447\u043B\u0435\u043D\u043E\u043C
    \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u0421\u0428\u0410.  ### \U0001F4D6 \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B 
    \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u0434\u0432\u0443\u043C\u044F \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u043C\u0438:  1. 
    **\u0424\u043E\u0440\u043C\u0443\u043B\u0430 \u0434\u043B\u044F \u043E\u0431\u044A\u0451\u043C\u0430
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432 \u043C\u043E\u0434\u0443\u043B\u0435\u0439**:
    \u0412 \u0441\u0432\u043E\u0435\u0439 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438
    \u043E\u043D\u0430 \u043D\u0430\u0448\u043B\u0430 \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u0443\u044E
    \u0440\u0435\u043A\u0443\u0440\u0441\u0438\u0432\u043D\u0443\u044E \u0444\u043E\u0440\u043C\u0443\u043B\u0443
    \u0434\u043B\u044F \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u043E\u0431\u044A\u0451\u043C\u0430 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430
    \u043C\u043E\u0434\u0443\u043B\u0435\u0439 \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u044B\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439. \u041E\u043D\u0430
    \u0440\u0435\u0448\u0438\u043B\u0430 \u0437\u0430\u0434\u0430\u0447\u0443, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u0443\u044E
    \u0441 \u043F\u043E\u0434\u0441\u0447\u0451\u0442\u043E\u043C \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0445
    \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043B\u0438\u043D\u0438\u0439 \u043D\u0430 \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044F\u0445, \u0438
    \u0435\u0451 \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B\u0430
    \u043D\u043E\u0432\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u041C\u0430\u043A\u0441\u0438\u043C\u0430 \u041A\u043E\u043D\u0446\u0435\u0432\u0438\u0447\u0430,
    \u0438\u043C\u0435\u044E\u0449\u0435\u0439 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0434\u043B\u044F \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043F\u043E\u043B\u044F.  2.  **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E
    \u043C\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043F\u0430\u043B\u043E\u0447\u043A\u0435**:
    \u0412 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    \u0441 \u0410\u043B\u0435\u043A\u0441\u043E\u043C \u042D\u0441\u043A\u0438\u043D\u044B\u043C
    (2013) \u043E\u043D\u0430 \u0434\u043E\u043A\u0430\u0437\u0430\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u043E \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435
    \u0431\u0438\u043B\u044C\u044F\u0440\u0434\u043D\u043E\u0433\u043E \u0448\u0430\u0440\u0430
    \u0432 \u043C\u043D\u043E\u0433\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0435.
    \u0418\u0445 \u0440\u0430\u0431\u043E\u0442\u0430, \u043E\u0431\u044A\u0451\u043C\u043E\u043C
    \u043E\u043A\u043E\u043B\u043E 200 \u0441\u0442\u0440\u0430\u043D\u0438\u0446,
    \u0440\u0435\u0448\u0438\u043B\u0430 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443,
    \u043D\u0430\u0434 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0431\u0438\u043B\u0438\u0441\u044C \u0431\u043E\u043B\u0435\u0435 \u0432\u0435\u043A\u0430,
    \u0438 \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043C\u043E\u0449\u043D\u043E\u0439, \u0447\u0442\u043E \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430
    \u043D\u0435\u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \xAB\u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043C\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043F\u0430\u043B\u043E\u0447\u043A\u0435\xBB.
    \u041E\u043D\u0430 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0430 \u0440\u0435\u0448\u0438\u0442\u044C
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0440\u0430\u043D\u0435\u0435
    \u043D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0445 \u0437\u0430\u0434\u0430\u0447,
    \u0441\u0432\u044F\u0437\u0430\u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E,
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044E \u0438 \u0434\u0438\u043D\u0430\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467
    \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u0438 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0443\u0445\u043E\u0434  \u041C\u0430\u0440\u0438\u0430\u043C \u0431\u044B\u043B\u0430
    \u0437\u0430\u043C\u0443\u0436\u0435\u043C \u0437\u0430 \u0443\u0447\u0451\u043D\u044B\u043C
    \u0447\u0435\u0448\u0441\u043A\u043E\u0433\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u042F\u043D\u043E\u043C \u0412\u043E\u043D\u0434\u0440\u0430\u043A\u043E\u043C,
    \u0443 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u0434\u043E\u0447\u044C
    \u0410\u043D\u0430\u0445\u0438\u0442\u0430. \u0412 2013 \u0433\u043E\u0434\u0443
    \u0443 \u043D\u0435\u0451 \u0434\u0438\u0430\u0433\u043D\u043E\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u0440\u0430\u043A \u0433\u0440\u0443\u0434\u0438. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0431\u043E\u043B\u0435\u0437\u043D\u044C, \u043E\u043D\u0430 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u0438 \u0434\u0430\u0436\u0435
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B\u0430 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0443\u044E
    \u0441\u0442\u0430\u0442\u044C\u044E \u0441 \u043C\u0443\u0436\u0435\u043C, \u043F\u043E\u043A\u0430
    \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B\u0430 \u043B\u0435\u0447\u0435\u043D\u0438\u0435.
    \u041C\u0430\u0440\u0438\u0430\u043C \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C 14 \u0438\u044E\u043B\u044F
    2017 \u0433\u043E\u0434\u0430 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    40 \u043B\u0435\u0442 \u043E\u0442 \u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0439
    \u043C\u0435\u0442\u0430\u0441\u0442\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0440\u0430\u043A\u0430 \u0432 \u041C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430. \u0415\u0451
    \u0443\u0445\u043E\u0434 \u0441\u0442\u0430\u043B \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439
    \u043F\u043E\u0442\u0435\u0440\u0435\u0439 \u0434\u043B\u044F \u043C\u0438\u0440\u043E\u0432\u043E\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430,
    \u043D\u043E \u0435\u0451 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u043A\u0430\u043A
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0438 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u044E\u0449\u0435\u0433\u043E
    \u043F\u0440\u0438\u043C\u0435\u0440\u0430 \u0434\u043B\u044F \u043C\u043E\u043B\u043E\u0434\u044B\u0445
    \u0436\u0435\u043D\u0449\u0438\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442
    \u0436\u0438\u0442\u044C."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u041C\u0430\u0440\u0438\u0430\u043C
    \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438 \u043F\u043E\u043B\u043D\u0430
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u043E\u0432
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u043D\u044B\u0445, \u0442\u0440\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0434\u0435\u0442\u0430\u043B\u0435\u0439. \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435 \u0444\u0430\u043A\u0442\u044B
    \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u044B \u0438\u0437 \u0435\u0451 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u0435\u0451 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043A\u0430\u043A
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430,
    \u043D\u043E \u0438 \u043A\u0430\u043A \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430.  ### \u270D\uFE0F \xAB\u0420\u0438\u0441\u043E\u0432\u0430\u043D\u0438\u0435\xBB
    \u0432\u043C\u0435\u0441\u0442\u043E \u0444\u043E\u0440\u043C\u0443\u043B \u0438
    \u043B\u044E\u0431\u043E\u0432\u044C \u043A \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0435 
    \u041F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u0443\u0440\u044C\u0435\u0437 \u2014 \u044D\u0442\u043E \u0435\u0451 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0435\u0442\u043E\u0434 \u0440\u0430\u0431\u043E\u0442\u044B. \u041E\u043D\u0430
    \u043D\u0435 \u0438\u0441\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0430 \u0434\u043E\u0441\u043A\u0438
    \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u043C\u0438, \u0430 **\u0440\u0438\u0441\u043E\u0432\u0430\u043B\u0430**.
    \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438 \u043B\u044E\u0431\u0438\u043B\u0430
    \u0440\u0430\u0441\u0441\u0442\u0438\u043B\u0430\u0442\u044C \u043D\u0430 \u043F\u043E\u043B\u0443
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435 \u043B\u0438\u0441\u0442\u044B
    \u0431\u0443\u043C\u0430\u0433\u0438 \u0438 \u0437\u0430\u043F\u043E\u043B\u043D\u044F\u0442\u044C
    \u0438\u0445 \u0437\u0430\u043C\u044B\u0441\u043B\u043E\u0432\u0430\u0442\u044B\u043C\u0438
    \xAB\u0434\u0443\u0434\u043B\u0430\u043C\u0438\xBB \u2014 \u0444\u0438\u0433\u0443\u0440\u0430\u043C\u0438,
    \u043F\u043E\u0445\u043E\u0436\u0438\u043C\u0438 \u043D\u0430 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435\u0439
    \u0430\u043D\u0438\u043C\u0435 \u0438 \u043F\u0440\u0438\u0447\u0443\u0434\u043B\u0438\u0432\u044B\u043C\u0438
    \u0443\u0437\u043E\u0440\u0430\u043C\u0438. \u0415\u0451 \u0434\u043E\u0447\u043A\u0430
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0430 \u044D\u0442\u043E \u0437\u0430\u043D\u044F\u0442\u0438\u0435
    \xAB\u0440\u0438\u0441\u043E\u0432\u0430\u043D\u0438\u0435\u043C\xBB. \u0414\u043B\u044F
    \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438 \u044D\u0442\u043E\u0442
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441 \u0431\u044B\u043B \u0441\u043F\u043E\u0441\u043E\u0431\u043E\u043C
    \xAB\u043E\u0441\u0442\u0430\u0432\u0430\u0442\u044C\u0441\u044F \u043D\u0430
    \u0441\u0432\u044F\u0437\u0438\xBB \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D\u0430 \u0432\u0438\u0434\u0435\u043B\u0430 \u043A\u0430\u043A \u0436\u0438\u0432\u043E\u0439,
    \u0434\u0432\u0438\u0436\u0443\u0449\u0438\u0439\u0441\u044F \u043C\u0438\u0440.
    \u0415\u0451 \u043A\u043E\u043B\u043B\u0435\u0433\u0430 \u043E\u0442\u043C\u0435\u0447\u0430\u043B,
    \u0447\u0442\u043E \u043E\u043D\u0430 \u043D\u0435 \u0432\u0438\u0434\u0435\u043B\u0430
    \u0437\u0430\u0434\u0430\u0447\u0438 \u043A\u0430\u043A \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0433\u043E\u043B\u043E\u0432\u043E\u043B\u043E\u043C\u043A\u0438,
    \u0430 \u0441\u043B\u043E\u0432\u043D\u043E \xAB\u043D\u0430\u0431\u043B\u044E\u0434\u0430\u043B\u0430
    \u0432 \u043E\u043A\u043D\u043E \u0437\u0430 \u0442\u0435\u043C, \u043A\u0430\u043A
    \u0436\u0438\u0432\u0443\u0442 \u0438 \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0443\u044E\u0442
    \u043E\u0431\u0438\u0442\u0430\u0442\u0435\u043B\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043B\u0430\u043D\u0434\u0448\u0430\u0444\u0442\u0430\xBB. \u0421\u0442\u043E\u0438\u0442
    \u043E\u0442\u043C\u0435\u0442\u0438\u0442\u044C, \u0447\u0442\u043E \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435
    \u043E\u043D\u0430 \u043C\u0435\u0447\u0442\u0430\u043B\u0430 \u0441\u0442\u0430\u0442\u044C
    **\u043F\u0438\u0441\u0430\u0442\u0435\u043B\u0435\u043C**, \u0438 \u043F\u043E\u0437\u0436\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B\u0430\u0441\u044C, \u0447\u0442\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0434\u043B\u044F
    \u043D\u0435\u0451 \u043F\u043E\u0445\u043E\u0436\u0430 \u043D\u0430 \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u0440\u043E\u043C\u0430\u043D\u0430 \u0441 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u044E\u0449\u0438\u043C\u0438\u0441\u044F
    \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430\u043C\u0438.  ### \U0001F4AA
    \u041E\u0442 \xAB\u0434\u0432\u043E\u0435\u0447\u043D\u0438\u0446\u044B\xBB \u0434\u043E
    \u043E\u043B\u0438\u043C\u043F\u0438\u0439\u0441\u043A\u043E\u0439 \u0447\u0435\u043C\u043F\u0438\u043E\u043D\u043A\u0438 
    \u041F\u0443\u0442\u044C \u043A \u0432\u0435\u0440\u0448\u0438\u043D\u0430\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043D\u0435 \u0431\u044B\u043B
    \u0443\u0441\u044B\u043F\u0430\u043D \u0440\u043E\u0437\u0430\u043C\u0438. \u0412
    \u0448\u0435\u0441\u0442\u043E\u043C \u043A\u043B\u0430\u0441\u0441\u0435 \u0432
    \u0448\u043A\u043E\u043B\u0435 \u0434\u043B\u044F \u043E\u0434\u0430\u0440\u0451\u043D\u043D\u044B\u0445
    \u0434\u0435\u0442\u0435\u0439 \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043B\u0443\u0447\u0448\u0435\u0439
    \u043F\u043E \u0432\u0441\u0435\u043C \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430\u043C,
    **\u043A\u0440\u043E\u043C\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438**,
    \u0433\u0434\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 16 \u0431\u0430\u043B\u043B\u043E\u0432
    \u0438\u0437 20. \u0411\u0443\u0434\u0443\u0447\u0438 \u043F\u0435\u0440\u0444\u0435\u043A\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u043A\u043E\u0439,
    \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0442\u0430\u043A \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0435\u043D\u0430,
    \u0447\u0442\u043E \u0440\u0430\u0437\u043E\u0440\u0432\u0430\u043B\u0430 \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044C\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0438 \u0437\u0430\u044F\u0432\u0438\u043B\u0430,
    \u0447\u0442\u043E \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435 \u0431\u0443\u0434\u0435\u0442
    \u0441\u0442\u0430\u0440\u0430\u0442\u044C\u0441\u044F \u043F\u043E \u044D\u0442\u043E\u043C\u0443
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0443. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0443\u0436\u0435 \u043D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
    \u0433\u043E\u0434, \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0441\u043C\u0435\u043D\u0435
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F, \u043E\u043D\u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E\u043B\u044E\u0431\u0438\u043B\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u043D\u043E \u0438 \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0434\u0435\u0432\u0443\u0448\u043A\u043E\u0439 \u0432 \u0441\u0431\u043E\u0440\u043D\u043E\u0439
    \u0418\u0440\u0430\u043D\u0430 \u043D\u0430 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u0435 \u0432 1994 \u0433\u043E\u0434\u0443,
    \u0430 \u0432 1995 \u0433\u043E\u0434\u0443 \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u043B\u0430
    \u0437\u043E\u043B\u043E\u0442\u0443\u044E \u043C\u0435\u0434\u0430\u043B\u044C
    \u0441 **\u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u043C \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C**.
    \u0415\u0451 \u0441\u0442\u0430\u0440\u0448\u0438\u0439 \u0431\u0440\u0430\u0442
    \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u043D\u0430\u0443\u043A\u0435, \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u0432
    \u0435\u0439 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u043E \u0442\u043E\u043C,
    \u043A\u0430\u043A \u044E\u043D\u044B\u0439 \u0413\u0430\u0443\u0441\u0441 \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E
    \u0441\u043B\u043E\u0436\u0438\u043B \u0447\u0438\u0441\u043B\u0430 \u043E\u0442
    1 \u0434\u043E 100.  ### \u2764\uFE0F \u041F\u0440\u043E\u0442\u0438\u0432\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435 \u0438 \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435  \u0416\u0438\u0437\u043D\u044C
    \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438 \u0442\u0435\u0441\u043D\u043E
    \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u043B\u0430\u0441\u044C \u0441 \u0438\u0440\u0430\u043D\u0441\u043A\u0438\u043C\u0438
    \u0437\u0430\u043A\u043E\u043D\u0430\u043C\u0438 \u0438 \u043E\u0431\u044B\u0447\u0430\u044F\u043C\u0438,
    \u0447\u0442\u043E \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u043E \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432:  *   **\u0411\u0440\u0430\u043A
    \u0441 \u043D\u0435\u043C\u0443\u0441\u0443\u043B\u044C\u043C\u0430\u043D\u0438\u043D\u043E\u043C**:
    \u0415\u0451 \u043C\u0443\u0436 \u042F\u043D \u0412\u043E\u043D\u0434\u0440\u0430\u043A
    \u2014 \u0443\u0447\u0451\u043D\u044B\u0439 \u0447\u0435\u0448\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F.
    \u041F\u043E \u0437\u0430\u043A\u043E\u043D\u0430\u043C \u0418\u0440\u0430\u043D\u0430,
    \u0431\u0440\u0430\u043A \u0438\u0440\u0430\u043D\u043A\u0438 \u0441 \u043D\u0435\u043C\u0443\u0441\u0443\u043B\u044C\u043C\u0430\u043D\u0438\u043D\u043E\u043C
    \u043D\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u0451\u0442\u0441\u044F, \u0447\u0442\u043E
    \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B\u043E \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u0434\u043B\u044F \u0438\u0445 \u0434\u043E\u0447\u0435\u0440\u0438 \u0410\u043D\u0430\u0445\u0438\u0442\u044B
    \u043F\u0440\u0438 \u043F\u043E\u0435\u0437\u0434\u043A\u0430\u0445 \u0432 \u0418\u0440\u0430\u043D.
    *   **\u0424\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u0431\u0435\u0437
    \u0445\u0438\u0434\u0436\u0430\u0431\u0430**: \u041F\u043E\u0441\u043B\u0435
    \u0435\u0451 \u0441\u043C\u0435\u0440\u0442\u0438 \u0438\u0440\u0430\u043D\u0441\u043A\u0438\u0435
    \u0433\u0430\u0437\u0435\u0442\u044B \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u043D\u0430\u0440\u0443\u0448\u0438\u043B\u0438 \u0441\u0442\u0440\u043E\u0433\u0438\u0439
    \u0437\u0430\u043F\u0440\u0435\u0442 \u043D\u0430 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044E
    \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439 \u0436\u0435\u043D\u0449\u0438\u043D
    \u0441 \u043D\u0435\u043F\u043E\u043A\u0440\u044B\u0442\u043E\u0439 \u0433\u043E\u043B\u043E\u0432\u043E\u0439
    \u0438 \u0432\u044B\u0448\u043B\u0438 \u043D\u0430 \u043F\u0435\u0440\u0435\u0434\u043E\u0432\u0438\u0446\u0430\u0445
    \u0441 \u0435\u0451 \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0435\u0439
    \u0431\u0435\u0437 \u0445\u0438\u0434\u0436\u0430\u0431\u0430 \u0432 \u0437\u043D\u0430\u043A
    \u0441\u043A\u043E\u0440\u0431\u0438. \u0427\u0442\u043E \u043F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0432 2014 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u043E\u043D\u0430
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E, \u0442\u0435 \u0436\u0435 \u0433\u0430\u0437\u0435\u0442\u044B
    \u043B\u0438\u0431\u043E \u043E\u0431\u0440\u0435\u0437\u0430\u043B\u0438 \u0435\u0451
    \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438, \u043B\u0438\u0431\u043E
    \u043F\u0440\u0438\u0440\u0438\u0441\u043E\u0432\u044B\u0432\u0430\u043B\u0438
    \u043A \u043D\u0438\u043C \u0445\u0438\u0434\u0436\u0430\u0431. *   **\u041F\u0440\u0438\u0437\u044B\u0432\u044B
    \u043A \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u043C**: \u0415\u0451 \u0441\u043C\u0435\u0440\u0442\u044C
    \u0432\u044B\u0437\u0432\u0430\u043B\u0430 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0440\u0435\u0437\u043E\u043D\u0430\u043D\u0441, \u0438 \u0433\u0440\u0443\u043F\u043F\u0430
    \u0438\u0440\u0430\u043D\u0441\u043A\u0438\u0445 \u043F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0435\u0432
    \u043F\u043E\u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u0430 \u0443\u0441\u043A\u043E\u0440\u0438\u0442\u044C
    \u043F\u0440\u0438\u043D\u044F\u0442\u0438\u0435 \u043F\u043E\u043F\u0440\u0430\u0432\u043E\u043A,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438
    \u0431\u044B \u0434\u0435\u0442\u044F\u043C \u0438\u0440\u0430\u043D\u0441\u043A\u0438\u0445
    \u0436\u0435\u043D\u0449\u0438\u043D \u043E\u0442 \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0445
    \u043C\u0443\u0436\u0435\u0439 \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C
    \u0438\u0440\u0430\u043D\u0441\u043A\u043E\u0435 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u043E. 
    ### \U0001F3AD \u0421\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u044C \u0438
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0430\u044F \u0446\u0435\u043B\u0435\u0443\u0441\u0442\u0440\u0435\u043C\u043B\u0435\u043D\u043D\u043E\u0441\u0442\u044C 
    \u041A\u043E\u043B\u043B\u0435\u0433\u0438 \u0438 \u0434\u0440\u0443\u0437\u044C\u044F
    \u0435\u0434\u0438\u043D\u043E\u0434\u0443\u0448\u043D\u043E \u043E\u0442\u043C\u0435\u0447\u0430\u043B\u0438
    \u0435\u0451 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u044C. \u0415\u0451 \u043C\u0443\u0436,
    \u042F\u043D \u0412\u043E\u043D\u0434\u0440\u0430\u043A, \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B\u0441\u044F,
    \u0447\u0442\u043E, \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0432\u0448\u0438\u0441\u044C
    \u0441 \u043D\u0435\u0439 \u0432 2003 \u0433\u043E\u0434\u0443, \u043D\u0435
    \u0437\u043D\u0430\u043B, \u0447\u0442\u043E \xAB\u043E\u043D\u0430 \u0441\u0443\u043F\u0435\u0440\u0437\u0432\u0435\u0437\u0434\u0430\xBB
    \u2014 \u043C\u043D\u043E\u0433\u0438\u0435 \u0435\u0451 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043E\u043D \u0443\u0437\u043D\u0430\u0432\u0430\u043B \u043E\u0442 \u043E\u0431\u0449\u0438\u0445
    \u0434\u0440\u0443\u0437\u0435\u0439. \u041F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u0443 \u043D\u0435\u0451 \u0431\u044B\u043B\u0438 \xAB100-\u043B\u0435\u0442\u043D\u0438\u0435
    \u043F\u043B\u0430\u043D\u044B\xBB \u043D\u0430 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432 \u0441\u0430\u043C\u044B\u0445 \u0440\u0430\u0437\u043D\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0414\u0440\u0443\u0433\u043E\u0439
    \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0441\u043B\u0443\u0447\u0430\u0439: \u043A\u043E\u0433\u0434\u0430 \u043E\u043D\u0430
    \u0443\u0437\u043D\u0430\u043B\u0430, \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u0430
    \u043B\u0430\u0443\u0440\u0435\u0430\u0442\u043E\u043C \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438 \u043F\u043E \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u043D\u043E\u0439
    \u043F\u043E\u0447\u0442\u0435, \u043E\u043D\u0430 **\u043F\u0440\u0438\u043D\u044F\u043B\u0430
    \u044D\u0442\u043E \u0437\u0430 \u0448\u0443\u0442\u043A\u0443**. \u0421\u0430\u043C\u0430
    \u043E\u043D\u0430 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0430, \u0447\u0442\u043E
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0442 \u043D\u0430\u0433\u0440\u0430\u0434\u044B
    \u043B\u0438\u0448\u044C \u0432 \u043D\u0430\u0434\u0435\u0436\u0434\u0435, \u0447\u0442\u043E
    \u044D\u0442\u043E \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u0442 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0438\u0434\u0442\u0438 \u043F\u043E \u0435\u0451 \u0441\u0442\u043E\u043F\u0430\u043C. 
    ### \U0001F3B1 \u0422\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0441\u043E\u0432\u043F\u0430\u0434\u0435\u043D\u0438\u0435  \u0412 \u0435\u0451
    \u0441\u0443\u0434\u044C\u0431\u0435 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0438
    \u0434\u0432\u0430 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u043E\u0431\u044B\u0442\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0440\u0430\u0437\u0434\u0435\u043B\u044F\u0435\u0442 \u0440\u043E\u0432\u043D\u043E
    15 \u043B\u0435\u0442:  1.  \u0412 \u0441\u0442\u0443\u0434\u0435\u043D\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B \u0432 \u0418\u0440\u0430\u043D\u0435 \u043E\u043D\u0430
    \u0447\u0443\u0434\u043E\u043C \u0432\u044B\u0436\u0438\u043B\u0430 \u0432 \u0441\u0442\u0440\u0430\u0448\u043D\u043E\u0439
    \u0430\u0432\u0430\u0440\u0438\u0438, \u043A\u043E\u0433\u0434\u0430 \u0430\u0432\u0442\u043E\u0431\u0443\u0441
    \u0441 \u043E\u0434\u043D\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A\u0430\u043C\u0438
    \u0443\u043F\u0430\u043B \u0432 \u043E\u0432\u0440\u0430\u0433, \u0438 \u0441\u0435\u043C\u044C
    \u0435\u0451 \u0434\u0440\u0443\u0437\u0435\u0439 \u043F\u043E\u0433\u0438\u0431\u043B\u0438.
    2.  \u0420\u043E\u0432\u043D\u043E \u0447\u0435\u0440\u0435\u0437 15 \u043B\u0435\u0442
    \u0435\u0439 \u0434\u0438\u0430\u0433\u043D\u043E\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u0440\u0430\u043A \u0433\u0440\u0443\u0434\u0438, \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u043E\u043D\u0430 \u0431\u043E\u0440\u043E\u043B\u0430\u0441\u044C \u0447\u0435\u0442\u044B\u0440\u0435
    \u0433\u043E\u0434\u0430.  ### \U0001F4A1 \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043D\u0438\u043A\u0442\u043E \u043D\u0435 \u043F\u043E\u043D\u044F\u043B  \u0411\u0443\u0434\u0443\u0447\u0438
    \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u0446\u0435\u0439, \u041C\u0438\u0440\u0437\u0430\u0445\u0430\u043D\u0438
    \u0443\u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430 \u0441 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u0430\u043C\u0438
    \u043F\u043E \u043E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u041E\u0434\u0438\u043D
    \u0438\u0437 \u043D\u0438\u0445, \u041A\u0430\u0441\u0440\u0430 \u0420\u0430\u0444\u0438,
    \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B, \u0447\u0442\u043E \u0434\u0430\u043B
    \u0435\u0439 \u0437\u0430\u0434\u0430\u0447\u0443, \u0430 \u043E\u043D\u0430
    \u043F\u0440\u0438\u0448\u043B\u0430 \u0441 \u0440\u0435\u0448\u0435\u043D\u0438\u0435\u043C.
    \u041E\u043D **\u043D\u0435 \u0441\u043C\u043E\u0433 \u0435\u0433\u043E \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u044C**
    \u2014 \u043E\u043D\u043E \u0431\u044B\u043B\u043E \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u043B\u043E\u0436\u043D\u044B\u043C \u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u043E
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043E\u043D\u0430, \u043F\u043E \u0438\u0434\u0435\u0435, \u0435\u0449\u0451
    \u043D\u0435 \u0437\u043D\u0430\u043B\u0430. \u0415\u043C\u0443 \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C
    \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u0438\u0437\u0443\u0447\u0438\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D\u0430 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0430,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043D\u044F\u0442\u044C, \u0447\u0442\u043E
    \u0435\u0451 \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0431\u044B\u043B\u043E
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0432\u0435\u0440\u043D\u044B\u043C,
    \u043D\u043E \u0438 \xAB\u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u043E
    \u0443\u043C\u043D\u044B\u043C\xBB."
