  shortBioRu: "\u041A\u0443\u0440\u0442 \u0424\u0440\u0438\u0301\u0434\u0440\u0438\u0445
    \u0413\u0451\u0434\u0435\u043B\u044C\_\u2014 \u0430\u0432\u0441\u0442\u0440\u0438\u0439\u0441\u043A\u0438\u0439
    \u043B\u043E\u0433\u0438\u043A, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u041D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u043C\u0438
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u043D\u044B\u043C\u0438 \u0438\u043C
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430\u043C\u0438 \u043E \u043D\u0435\u043F\u043E\u043B\u043D\u043E\u0442\u0435,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043E\u0431 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u043C\u044B\u0441\u043B\u0438\u0442\u0435\u043B\u0435\u0439 XX\_\u0432\u0435\u043A\u0430."
