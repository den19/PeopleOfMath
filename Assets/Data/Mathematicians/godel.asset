  achievementsRu: "\u041F\u043E\u043C\u0438\u043C\u043E \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u0442\u0435\u043E\u0440\u0435\u043C
    \u043E \u043D\u0435\u043F\u043E\u043B\u043D\u043E\u0442\u0435, \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u041A\u0443\u0440\u0442\u0430
    \u0413\u0451\u0434\u0435\u043B\u044F \u0432\u043A\u043B\u044E\u0447\u0430\u0435\u0442
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0438
    \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0420\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0438\u043C
    \u0438\u0445 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E.  ### \U0001F3D7\uFE0F
    \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439  \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u043C
    \u0432\u043A\u043B\u0430\u0434\u043E\u043C \u0413\u0451\u0434\u0435\u043B\u044F
    \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    \u0441\u0442\u0430\u043B\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438 **\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432**, \u0447\u0430\u0441\u0442\u043E
    \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0430\u0435\u043C\u043E\u0439 \u043A\u0430\u043A
    \u043A\u043B\u0430\u0441\u0441 `L`. \u042D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u0430\u044F \u0438\u0434\u0435\u044F,
    \u0430 \u0441\u0442\u0440\u043E\u0433\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u0430\u044F
    \u0438\u0435\u0440\u0430\u0440\u0445\u0438\u044F \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432,
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u0430\u044F \"\u0441\u043D\u0438\u0437\u0443
    \u0432\u0432\u0435\u0440\u0445\":  1.  \u041D\u0430\u0447\u0438\u043D\u0430\u0435\u043C
    \u0441 \u043F\u0443\u0441\u0442\u043E\u0433\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430.
    2.  \u041D\u0430 \u043A\u0430\u0436\u0434\u043E\u043C \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C
    \u0448\u0430\u0433\u0435 \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u0435\u043C
    \u0432\u0441\u0435 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u043E\u0436\u043D\u043E **\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0444\u043E\u0440\u043C\u0443\u043B
    \u043B\u043E\u0433\u0438\u043A\u0438 \u043F\u0435\u0440\u0432\u043E\u0433\u043E
    \u043F\u043E\u0440\u044F\u0434\u043A\u0430**, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u0443\u0436\u0435 \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u044B\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430. 3.  \u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u043C
    \u044D\u0442\u043E\u0442 \u043F\u0440\u043E\u0446\u0435\u0441\u0441 \u0434\u043B\u044F
    \u0432\u0441\u0435\u0445 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445
    \u043F\u043E\u0440\u044F\u0434\u043A\u043E\u0432\u044B\u0445 \u0447\u0438\u0441\u0435\u043B. 
    \u0412 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435 \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442\u0441\u044F
    \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u0430\u044F `L`, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F **\u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0439
    \u043C\u043E\u0434\u0435\u043B\u044C\u044E \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432 \u0426\u0435\u0440\u043C\u0435\u043B\u043E-\u0424\u0440\u0435\u043D\u043A\u0435\u043B\u044F**
    (ZF) \u0438 \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442 \u0437\u0430\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\u043C\u0438.  ### \U0001F6E1\uFE0F
    \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0441\u0442\u0438 
    \u0413\u043B\u0430\u0432\u043D\u043E\u0439 \u0446\u0435\u043B\u044C\u044E \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F
    \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439 `L` \u0431\u044B\u043B\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0434\u0432\u0443\u0445 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C, \u0441\u0442\u043E\u044F\u0432\u0448\u0438\u0445
    \u043F\u0435\u0440\u0435\u0434 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    \u0432 \u043D\u0430\u0447\u0430\u043B\u0435 XX \u0432\u0435\u043A\u0430. \u0413\u0451\u0434\u0435\u043B\u044C
    \u0434\u043E\u0431\u0438\u043B\u0441\u044F \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0433\u043E
    \u0443\u0441\u043F\u0435\u0445\u0430:  *   **\u0410\u043A\u0441\u0438\u043E\u043C\u0430
    \u0432\u044B\u0431\u043E\u0440\u0430:** \u0413\u0451\u0434\u0435\u043B\u044C
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0432 \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u043E\u0439
    \u0438\u043C \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439 `L` \u0430\u043A\u0441\u0438\u043E\u043C\u0430
    \u0432\u044B\u0431\u043E\u0440\u0430 (AC) \u0432\u0441\u0435\u0433\u0434\u0430
    \u0438\u0441\u0442\u0438\u043D\u043D\u0430. \u0418\u0437 \u044D\u0442\u043E\u0433\u043E
    \u0441\u043B\u0435\u0434\u0443\u0435\u0442, \u0447\u0442\u043E \u0435\u0441\u043B\u0438
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430 ZF \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u0430,
    \u0442\u043E \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u0430
    \u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u0430 **ZFC** (ZF + \u0430\u043A\u0441\u0438\u043E\u043C\u0430
    \u0432\u044B\u0431\u043E\u0440\u0430). \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C,
    \u0434\u043E\u0431\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u044D\u0442\u043E\u0439
    \u0430\u043A\u0441\u0438\u043E\u043C\u044B \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
    \u043F\u0440\u0438\u0432\u0435\u0441\u0442\u0438 \u043A \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u044E,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043D\u0435 \u0431\u044B\u043B\u043E
    \u0438\u0437\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E.  *   **\u041A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C-\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430:**
    \u0415\u0449\u0435 \u0431\u043E\u043B\u0435\u0435 \u0437\u043D\u0430\u0447\u0438\u043C\u044B\u043C
    \u0431\u044B\u043B\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0432 \u044D\u0442\u043E\u0439
    \u0436\u0435 \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439 `L` \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0435\u0442\u0441\u044F
    \u0438 **\u043E\u0431\u043E\u0431\u0449\u0435\u043D\u043D\u0430\u044F \u043A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C-\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430**
    (GCH). \u042D\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E, \u0447\u0442\u043E
    GCH \u0442\u0430\u043A\u0436\u0435 \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u0430
    \u0441 \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u043C\u0438 ZF.  \u0418\u0442\u043E\u0433
    \u044D\u0442\u0438\u0445 \u0434\u0432\u0443\u0445 \u0440\u0430\u0431\u043E\u0442
    \u0431\u044B\u043B \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D
    \u0432 \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u0438 **\"The Consistency
    of the Continuum Hypothesis\"**, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0432 1940 \u0433\u043E\u0434\u0443. \u0413\u0451\u0434\u0435\u043B\u044C \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043D\u0438 \u0430\u043A\u0441\u0438\u043E\u043C\u0430 \u0432\u044B\u0431\u043E\u0440\u0430,
    \u043D\u0438 \u043A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C-\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u043D\u0435 \u043C\u043E\u0433\u0443\u0442 \u0431\u044B\u0442\u044C \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u044B
    \u0432 \u0440\u0430\u043C\u043A\u0430\u0445 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432,
    \u0435\u0441\u043B\u0438 \u043E\u043D\u0430 \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u0430. 
    ### \U0001F570\uFE0F \u041E\u0442 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u043A \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438: \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u043E\u0439
    \u043F\u0443\u0442\u044C  \u041F\u0443\u0442\u044C \u043A \u044D\u0442\u0438\u043C
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430\u043C \u0431\u044B\u043B
    \u0434\u043E\u043B\u0433\u0438\u043C \u0438 \u0442\u0435\u0440\u043D\u0438\u0441\u0442\u044B\u043C.
    \u041F\u0435\u0440\u0432\u044B\u0435 \u0438\u0434\u0435\u0438 \u0438 \u043D\u0430\u0431\u0440\u043E\u0441\u043A\u0438
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u043F\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C \u0443 \u0413\u0451\u0434\u0435\u043B\u044F
    \u0435\u0449\u0435 \u0432 **1935 \u0433\u043E\u0434\u0443** \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0435\u0433\u043E \u0432\u0438\u0437\u0438\u0442\u0430 \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E \u043F\u043B\u0430\u043D\u044B
    \u043D\u0430\u0440\u0443\u0448\u0438\u043B \u0442\u044F\u0436\u0435\u043B\u044B\u0439
    \u043D\u0435\u0440\u0432\u043D\u044B\u0439 \u0441\u0440\u044B\u0432 \u0432 \u043A\u043E\u043D\u0446\u0435
    \u0442\u043E\u0433\u043E \u0436\u0435 \u0433\u043E\u0434\u0430.  *   **\u0417\u0430\u0434\u0435\u0440\u0436\u043A\u0430:**
    \u0418\u0437-\u0437\u0430 \u0431\u043E\u043B\u0435\u0437\u043D\u0438 \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439
    \u0440\u0435\u0430\u0431\u0438\u043B\u0438\u0442\u0430\u0446\u0438\u0438 \u0413\u0451\u0434\u0435\u043B\u044C
    \u0441\u043C\u043E\u0433 \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
    \u043A \u044D\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 \u043B\u0438\u0448\u044C
    \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043B\u0435\u0442. *   **\u0420\u0435\u0448\u0430\u044E\u0449\u0438\u0439 \u043C\u043E\u043C\u0435\u043D\u0442:**
    \u041A\u043B\u044E\u0447\u0435\u0432\u043E\u0435 \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u0435,
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0432\u0448\u0435\u0435 \u0435\u043C\u0443
    \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u044C \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0434\u043B\u044F \u043A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C-\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B,
    \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B\u043E, \u043F\u043E \u0435\u0433\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u0441\u043B\u043E\u0432\u0430\u043C,
    **\"\u043D\u043E\u0447\u044C\u044E \u0441 14 \u043D\u0430 15 \u0438\u044E\u043D\u044F
    1937 \u0433\u043E\u0434\u0430\"**.  \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C,
    \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0440\u0438\u0443\u043C\u0444
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438, \u043D\u043E \u0438 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439 \u043D\u0430\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438
    \u043F\u0435\u0440\u0435\u0434 \u043B\u0438\u0446\u043E\u043C \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0445
    \u043B\u0438\u0447\u043D\u044B\u0445 \u0438 \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u0435\u0439. \u042D\u0442\u0438
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438
    \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0442\u043E\u0447\u043A\u0443 \u0432 \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0438\u0445
    \u0434\u0435\u0431\u0430\u0442\u0430\u0445 \u043E \u0441\u0442\u0430\u0442\u0443\u0441\u0435
    \u0430\u043A\u0441\u0438\u043E\u043C\u044B \u0432\u044B\u0431\u043E\u0440\u0430
    \u0438 \u043A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C-\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B,
    \u043F\u043E\u043A\u0430\u0437\u0430\u0432, \u0447\u0442\u043E \u0438\u0445 \u043D\u0435\u043B\u044C\u0437\u044F
    \u043D\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C, \u043D\u0438 \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u044C,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u043E\u0431\u0449\u0435\u043F\u0440\u0438\u043D\u044F\u0442\u044B\u0435
    \u0430\u043A\u0441\u0438\u043E\u043C\u044B."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u041A\u0443\u0440\u0442\u0430 \u0413\u0451\u0434\u0435\u043B\u044F \u2014 \u044D\u0442\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u043E\u0432:
    \u0433\u043E\u043B\u043E\u0432\u043E\u043A\u0440\u0443\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u0432\u0437\u043B\u0435\u0442\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u043E\u0441\u0435\u0434\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441 \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439 \u043B\u0438\u0447\u043D\u043E\u0439
    \u0434\u0440\u0430\u043C\u043E\u0439, \u0438 \u0432\u0441\u0435\u043F\u043E\u0433\u043B\u043E\u0449\u0430\u044E\u0449\u0435\u0439
    \u043B\u044E\u0431\u0432\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u0430\u0441\u044C
    \u0432 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u043B\u0438\u043D\u0438\u044E \u043E\u0431\u043E\u0440\u043E\u043D\u044B \u043F\u0440\u043E\u0442\u0438\u0432
    \u0440\u0430\u0437\u0440\u0443\u0448\u0430\u044E\u0449\u0435\u0433\u043E \u043F\u0441\u0438\u0445\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043D\u0435\u0434\u0443\u0433\u0430. \u042D\u0442\u043E \u0440\u0430\u0441\u0441\u043A\u0430\u0437
    \u043E \u0441\u043B\u043E\u0436\u043D\u043E\u043C \u0433\u0435\u043D\u0438\u0438
    \u0438 \u0436\u0435\u043D\u0449\u0438\u043D\u0435, \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0432\u0448\u0435\u0439
    \u0435\u043C\u0443 \u0436\u0438\u0437\u043D\u044C.  ### \U0001F496 \u0410\u0434\u0435\u043B\u044C:
    \u0418\u0441\u0442\u043E\u0440\u0438\u044F \u0432\u043E\u043F\u0440\u0435\u043A\u0438
    \u0432\u0441\u0435\u043C\u0443  \u0421\u0430\u043C\u043E\u0439 \u044F\u0440\u043A\u043E\u0439
    \u0438 \u0432\u0430\u0436\u043D\u043E\u0439 \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0435\u0439
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438 \u0413\u0451\u0434\u0435\u043B\u044F
    \u0441\u0442\u0430\u043B \u0435\u0433\u043E \u0431\u0440\u0430\u043A \u0441 **\u0410\u0434\u0435\u043B\u044C
    \u041F\u043E\u0440\u043A\u0435\u0440\u0442** (\u0432 \u0434\u0435\u0432\u0438\u0447\u0435\u0441\u0442\u0432\u0435
    \u041D\u0438\u043C\u0431\u0443\u0440\u0441\u043A\u0438). \u0418\u0445 \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E
    \u0432 1927 \u0433\u043E\u0434\u0443 \u0432 \u0432\u0435\u043D\u0441\u043A\u043E\u043C
    \u043D\u043E\u0447\u043D\u043E\u043C \u043A\u043B\u0443\u0431\u0435, \u0433\u0434\u0435
    \u0410\u0434\u0435\u043B\u044C \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430
    \u0442\u0430\u043D\u0446\u043E\u0432\u0449\u0438\u0446\u0435\u0439, \u0431\u044B\u043B\u043E
    \u043F\u043E\u0447\u0442\u0438 \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u044C\u043D\u044B\u043C:
    \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043D\u0430 \u0448\u0435\u0441\u0442\u044C
    \u043B\u0435\u0442 \u0441\u0442\u0430\u0440\u0448\u0435, \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0430
    \u0438\u0437 \u0434\u0440\u0443\u0433\u043E\u0439 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0440\u0435\u0434\u044B \u0438 \u043A \u0442\u043E\u043C\u0443 \u043C\u043E\u043C\u0435\u043D\u0442\u0443
    \u0443\u0436\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0430 \u0432 \u0431\u0440\u0430\u043A\u0435. 
    \u0421\u0435\u043C\u044C\u044F \u0413\u0451\u0434\u0435\u043B\u044F, \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u0432\u0448\u0430\u044F
    \u043A \u0431\u043B\u0430\u0433\u043E\u043F\u043E\u043B\u0443\u0447\u043D\u043E\u0439
    \u0431\u0443\u0440\u0436\u0443\u0430\u0437\u043D\u043E\u0439 \u0441\u0440\u0435\u0434\u0435,
    \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435 \u043E\u0434\u043E\u0431\u0440\u044F\u043B\u0430 \u044D\u0442\u043E\u0442
    \u0441\u043E\u044E\u0437. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430
    \u044D\u0442\u043E, \u0413\u0451\u0434\u0435\u043B\u044C \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u043D\u0435\u043F\u0440\u0435\u043A\u043B\u043E\u043D\u0435\u043D. \u041F\u043E\u0441\u043B\u0435
    \u0440\u0430\u0437\u0432\u043E\u0434\u0430 \u0410\u0434\u0435\u043B\u044C \u043E\u043D\u0438
    \u0441\u043C\u043E\u0433\u043B\u0438 \u043F\u043E\u0436\u0435\u043D\u0438\u0442\u044C\u0441\u044F
    \u0442\u043E\u043B\u044C\u043A\u043E \u0432 1938 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430
    \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044F
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u0441\u0442\u0430\u043B\u0430 \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439.
    \u042D\u0442\u043E\u0442 \u0431\u0440\u0430\u043A \u0441\u0442\u0430\u043B \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u043B\u0438\u0447\u043D\u044B\u043C \u0432\u044B\u0431\u043E\u0440\u043E\u043C,
    \u0430 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C \u0430\u043A\u0442\u043E\u043C
    \u0432\u043E\u043B\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B
    \u0432\u0441\u044E \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C.  ### \u2694\uFE0F \u0411\u0438\u0442\u0432\u0430
    \u0441 \u043F\u0430\u0440\u0430\u043D\u043E\u0439\u0435\u0439: \u0436\u0435\u043D\u0430
    \u0438 \u0441\u0438\u0434\u0435\u043B\u043A\u0430 \u0432 \u043E\u0434\u043D\u043E\u043C
    \u043B\u0438\u0446\u0435  \u0412\u0437\u0430\u0438\u043C\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0413\u0451\u0434\u0435\u043B\u044F \u0438 \u0410\u0434\u0435\u043B\u044C \u043D\u0435\u043B\u044C\u0437\u044F
    \u0431\u044B\u043B\u043E \u043D\u0430\u0437\u0432\u0430\u0442\u044C \u043E\u0431\u044B\u0447\u043D\u044B\u043C\u0438.
    \u0421 \u0441\u0430\u043C\u043E\u0433\u043E \u043D\u0430\u0447\u0430\u043B\u0430
    \u0438\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438,
    \u0435\u0449\u0435 \u0432 1930-\u0445 \u0433\u043E\u0434\u0430\u0445, \u0443
    \u0413\u0451\u0434\u0435\u043B\u044F \u043D\u0430\u0447\u0430\u043B\u0438 \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u0442\u044C\u0441\u044F
    \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043A\u0438
    \u043F\u0441\u0438\u0445\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430.
    \u041E\u043D \u0441\u0442\u0440\u0430\u0434\u0430\u043B \u043E\u0442 \u0438\u043F\u043E\u0445\u043E\u043D\u0434\u0440\u0438\u0438
    \u0438 \u0442\u044F\u0436\u0435\u043B\u043E\u0439 \u043F\u0430\u0440\u0430\u043D\u043E\u0439\u0438.
    \u0413\u043B\u0430\u0432\u043D\u044B\u043C \u043D\u0430\u0432\u044F\u0437\u0447\u0438\u0432\u044B\u043C
    \u0441\u0442\u0440\u0430\u0445\u043E\u043C \u0443\u0447\u0435\u043D\u043E\u0433\u043E
    \u0441\u0442\u0430\u043B \u0441\u0442\u0440\u0430\u0445 \u0431\u044B\u0442\u044C
    \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u043C.  \u042D\u0442\u043E\u0442
    \u0441\u0442\u0440\u0430\u0445 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B
    \u0431\u044B\u0442 \u0432 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0443\u044E
    \u0431\u043E\u0440\u044C\u0431\u0443. \u0410\u0434\u0435\u043B\u044C \u0441\u0442\u0430\u043B\u0430
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0436\u0435\u043D\u043E\u0439,
    \u0430 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u0413\u0451\u0434\u0435\u043B\u044C \u0434\u043E\u0432\u0435\u0440\u044F\u043B.
    \u041E\u043D \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F
    \u043E\u0442 \u043B\u044E\u0431\u043E\u0439 \u0435\u0434\u044B, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D\u0430 \u043B\u0438\u0447\u043D\u043E \u043D\u0435 \u043F\u0440\u043E\u0431\u043E\u0432\u0430\u043B\u0430
    \u043F\u0440\u0438 \u043D\u0435\u043C. \u0415\u0433\u043E \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u043B\u0430\u0441\u044C
    \u0438 \u043D\u0430 \u043E\u043A\u0440\u0443\u0436\u0430\u044E\u0449\u0438\u0435
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B: \u0432 \u0438\u0445 \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435 \u043F\u043E \u0435\u0433\u043E
    \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043D\u0438\u044E \u0431\u044B\u043B\u0438
    \u0443\u0434\u0430\u043B\u0435\u043D\u044B \u0445\u043E\u043B\u043E\u0434\u0438\u043B\u044C\u043D\u0438\u043A
    \u0438 \u0440\u0430\u0434\u0438\u0430\u0442\u043E\u0440, \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u043D \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u0432\u0430\u043B \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A
    \u043E\u0442\u0440\u0430\u0432\u043B\u044F\u044E\u0449\u0438\u0445 \u0433\u0430\u0437\u043E\u0432. 
    \u0410\u0434\u0435\u043B\u044C \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B\u0430
    \u0441\u0432\u043E\u044E \u0436\u0438\u0437\u043D\u044C \u0443\u0445\u043E\u0434\u0443
    \u0437\u0430 \u043C\u0443\u0436\u0435\u043C. \u0412 \u043F\u0435\u0440\u0438\u043E\u0434\u044B
    \u0442\u044F\u0436\u0435\u043B\u044B\u0445 \u043A\u0440\u0438\u0437\u0438\u0441\u043E\u0432,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432 \u043A\u043E\u043D\u0446\u0435
    \u0436\u0438\u0437\u043D\u0438, \u043A\u043E\u0433\u0434\u0430 \u043F\u0430\u0440\u0430\u043D\u043E\u0439\u044F
    \u0441\u0442\u0430\u043B\u0430 \u0441\u043E\u043F\u0440\u043E\u0432\u043E\u0436\u0434\u0430\u0442\u044C\u0441\u044F
    \u0433\u0430\u043B\u043B\u044E\u0446\u0438\u043D\u0430\u0446\u0438\u044F\u043C\u0438,
    \u043E\u043D\u0430 \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u043B\u0430 \u0440\u043E\u043B\u044C
    \u0441\u0438\u0434\u0435\u043B\u043A\u0438, \u043A\u043E\u0440\u043C\u0438\u043B\u0430
    \u043C\u0443\u0436\u0430 \u0441 \u043B\u043E\u0436\u043A\u0438 \u0438 \u043F\u044B\u0442\u0430\u043B\u0430\u0441\u044C
    \u043E\u0433\u0440\u0430\u0434\u0438\u0442\u044C \u0435\u0433\u043E \u043E\u0442
    \u0432\u043D\u0435\u0448\u043D\u0435\u0433\u043E \u043C\u0438\u0440\u0430. \u0423
    \u043F\u0430\u0440\u044B \u043D\u0435 \u0431\u044B\u043B\u043E \u0434\u0435\u0442\u0435\u0439,
    \u0438, \u043F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C,
    \u0413\u0451\u0434\u0435\u043B\u044C \u043D\u0435 \u0445\u043E\u0442\u0435\u043B
    \u0434\u0435\u043B\u0438\u0442\u044C \u0437\u0430\u0431\u043E\u0442\u0443 \u0436\u0435\u043D\u044B
    \u043D\u0438 \u0441 \u043A\u0435\u043C. \u0412\u0441\u044F \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u0430\u044F
    \u0410\u0434\u0435\u043B\u044C \u0441\u0443\u0437\u0438\u043B\u0430\u0441\u044C
    \u0434\u043E \u0437\u0430\u0431\u043E\u0442\u044B \u043E \u0441\u0432\u043E\u0435\u043C
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u043C, \u043D\u043E \u0431\u043E\u043B\u044C\u043D\u043E\u043C
    \u043C\u0443\u0436\u0435.  ### \U0001F9E0 \u041A\u0440\u0443\u0433 \u0434\u0440\u0443\u0437\u0435\u0439
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0443\u0434\u0430\u0440 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0441\u0442\u044C,
    \u0443 \u0413\u0451\u0434\u0435\u043B\u044F \u0431\u044B\u043B\u0438 \u0431\u043B\u0438\u0437\u043A\u0438\u0435
    \u0434\u0440\u0443\u0437\u044C\u044F. \u041D\u0430\u0438\u0431\u043E\u043B\u0435\u0435
    \u0437\u043D\u0430\u0447\u0438\u043C\u043E\u0439 \u0434\u043B\u044F \u043D\u0435\u0433\u043E
    \u0441\u0442\u0430\u043B\u0430 \u0434\u0440\u0443\u0436\u0431\u0430 \u0441 **\u0410\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C** \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435.
    \u0418\u0445 \u0435\u0436\u0435\u0434\u043D\u0435\u0432\u043D\u044B\u0435 \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0438
    \u043A \u0434\u043E\u043C\u0443 \u0441\u0442\u0430\u043B\u0438 \u043B\u0435\u0433\u0435\u043D\u0434\u043E\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430. \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D,
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0441\u0432\u043E\u0439
    \u0436\u0438\u0437\u043D\u0435\u0440\u0430\u0434\u043E\u0441\u0442\u043D\u044B\u0439
    \u0438 \u043E\u0431\u0449\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440,
    \u043D\u0430\u0445\u043E\u0434\u0438\u043B \u0432 \u0413\u0451\u0434\u0435\u043B\u0435
    \u0431\u043B\u0438\u0437\u043A\u043E\u0433\u043E \u043F\u043E \u0434\u0443\u0445\u0443
    \u043C\u044B\u0441\u043B\u0438\u0442\u0435\u043B\u044F. \u041E\u043D \u0436\u0435
    \u043F\u043E\u043C\u043E\u0433 \u0435\u043C\u0443 \u0432 1940 \u0433\u043E\u0434\u0443
    \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043C\u0435\u0441\u0442\u043E
    \u0432 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D
    \u0432\u044B\u0441\u043E\u043A\u043E \u0446\u0435\u043D\u0438\u043B \u043E\u0431\u0449\u0435\u043D\u0438\u0435
    \u0441 \u0413\u0451\u0434\u0435\u043B\u0435\u043C, \u0438 \u0435\u0433\u043E
    \u0441\u043C\u0435\u0440\u0442\u044C \u0432 1955 \u0433\u043E\u0434\u0443 \u0441\u0442\u0430\u043B\u0430
    \u0434\u043B\u044F \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0442\u044F\u0436\u0435\u043B\u044B\u043C
    \u0443\u0434\u0430\u0440\u043E\u043C.  \u0415\u0449\u0435 \u043E\u0434\u043D\u0438\u043C
    \u0431\u043B\u0438\u0437\u043A\u0438\u043C \u0434\u0440\u0443\u0433\u043E\u043C
    \u0431\u044B\u043B \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0441\u0442 **\u041E\u0441\u043A\u0430\u0440
    \u041C\u043E\u0440\u0433\u0435\u043D\u0448\u0442\u0435\u0440\u043D**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B \u0441\u0435\u043C\u044C\u0435
    \u043E\u0433\u0440\u043E\u043C\u043D\u0443\u044E \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0443,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435,
    \u0441\u0430\u043C\u044B\u0435 \u0442\u044F\u0436\u0435\u043B\u044B\u0435 \u0433\u043E\u0434\u044B. 
    \u0422\u0440\u0430\u0433\u0435\u0434\u0438\u044F \u0440\u0430\u0437\u044B\u0433\u0440\u0430\u043B\u0430\u0441\u044C
    \u0432 1977 \u0433\u043E\u0434\u0443. \u041B\u0435\u0442\u043E\u043C \u044D\u0442\u043E\u0433\u043E
    \u0433\u043E\u0434\u0430 \u0410\u0434\u0435\u043B\u044C \u0431\u044B\u043B\u0430
    \u0433\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u0430
    \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0435\u0441\u044F\u0446\u0435\u0432,
    \u0430 \u0432 \u043A\u043E\u043D\u0446\u0435 \u0438\u044E\u043B\u044F \u0443\u043C\u0435\u0440
    \u0435\u0433\u043E \u0434\u0440\u0443\u0433 \u041C\u043E\u0440\u0433\u0435\u043D\u0448\u0442\u0435\u0440\u043D.
    \u041B\u0438\u0448\u0438\u0432\u0448\u0438\u0441\u044C \u0434\u0432\u0443\u0445
    \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u043E\u043F\u043E\u0440, \u0413\u0451\u0434\u0435\u043B\u044C
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u043B\u0441\u044F
    \u0432 \u043F\u0443\u0447\u0438\u043D\u0443 \u043F\u0430\u0440\u0430\u043D\u043E\u0439\u0438.
    \u0411\u0435\u0437 \u0436\u0435\u043D\u044B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043C\u043E\u0433\u043B\u0430 \u0431\u044B \"\u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0442\u044C\"
    \u0435\u0433\u043E \u0435\u0434\u0443, \u043E\u043D \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B \u0435\u0441\u0442\u044C. \u0423
    \u043D\u0435\u0433\u043E \u0440\u0430\u0437\u0432\u0438\u043B\u0430\u0441\u044C
    \u0442\u044F\u0436\u0435\u043B\u0430\u044F \u0430\u043D\u043E\u0440\u0435\u043A\u0441\u0438\u044F.
    14 \u044F\u043D\u0432\u0430\u0440\u044F 1978 \u0433\u043E\u0434\u0430 \u041A\u0443\u0440\u0442
    \u0413\u0451\u0434\u0435\u043B\u044C \u0443\u043C\u0435\u0440 \u0432 \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u0435
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435 \u043E\u0442 \u0438\u0441\u0442\u043E\u0449\u0435\u043D\u0438\u044F.
    \u0415\u0433\u043E \u0432\u0435\u0441 \u043D\u0430 \u043C\u043E\u043C\u0435\u043D\u0442
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B
    \u0432\u0441\u0435\u0433\u043E 29 \u043A\u0438\u043B\u043E\u0433\u0440\u0430\u043C\u043C\u043E\u0432.
    \u041F\u0440\u0438\u0447\u0438\u043D\u043E\u0439 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0441\u0442\u0430\u043B\u0430 \"\u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C
    \u043F\u0438\u0442\u0430\u043D\u0438\u044F \u0438 \u0438\u0441\u0442\u043E\u0449\u0435\u043D\u0438\u0435\",
    \u0432\u044B\u0437\u0432\u0430\u043D\u043D\u044B\u0435 \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E\u043C
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438."
  personalLifeEn: 
  shortBioRu: "\u041A\u0443\u0440\u0442 \u0424\u0440\u0438\u0434\u0440\u0438\u0445
    \u0413\u0451\u0434\u0435\u043B\u044C (1906\u20131978) \u2014 \u0430\u0432\u0441\u0442\u0440\u0438\u0439\u0441\u043A\u0438\u0439
    \u0438 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u0439
    \u043B\u043E\u0433\u0438\u043A, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444, \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043F\u043E \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u043B\u043E\u0433\u0438\u043A\u0435 \u043F\u043E \u0441\u0432\u043E\u0435\u043C\u0443
    \u0432\u043B\u0438\u044F\u043D\u0438\u044E \u0441\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043C\u044B
    \u0441 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430. \u0413\u043B\u0430\u0432\u043D\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0413\u0451\u0434\u0435\u043B\u044F
    \u2014 **\u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u043D\u0435\u043F\u043E\u043B\u043D\u043E\u0442\u0435**
    \u2014 \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u043E
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043E \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u0445 \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C \u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044F\u0445
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u044F.  ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435 
    \u0413\u0451\u0434\u0435\u043B\u044C \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    28 \u0430\u043F\u0440\u0435\u043B\u044F 1906 \u0433\u043E\u0434\u0430 \u0432
    \u043C\u043E\u0440\u0430\u0432\u0441\u043A\u043E\u043C \u0433\u043E\u0440\u043E\u0434\u0435
    \u0411\u0440\u044E\u043D\u043D (\u043D\u044B\u043D\u0435 \u0411\u0440\u043D\u043E,
    \u0427\u0435\u0445\u0438\u044F), \u0432 \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0439
    \u0441\u0435\u043C\u044C\u0435. \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u0420\u0443\u0434\u043E\u043B\u044C\u0444 \u0413\u0451\u0434\u0435\u043B\u044C,
    \u0431\u044B\u043B \u0441\u043E\u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0435\u043C
    \u0442\u0435\u043A\u0441\u0442\u0438\u043B\u044C\u043D\u043E\u0439 \u0444\u0430\u0431\u0440\u0438\u043A\u0438,
    \u0447\u0442\u043E \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u043B\u043E
    \u0441\u0435\u043C\u044C\u0435 \u043A\u043E\u043C\u0444\u043E\u0440\u0442\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C. \u0421 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
    \u041A\u0443\u0440\u0442 \u043E\u0442\u043B\u0438\u0447\u0430\u043B\u0441\u044F
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0441\u0442\u044C\u044E, \u0438\u043F\u043E\u0445\u043E\u043D\u0434\u0440\u0438\u0435\u0439
    \u0438 \u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u043E\u0439
    \u043C\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E.
    \u0415\u0433\u043E \u0434\u0430\u0436\u0435 \u043F\u0440\u043E\u0437\u0432\u0430\u043B\u0438
    \xABder Herr Warum\xBB (\xAB\u0413\u043E\u0441\u043F\u043E\u0434\u0438\u043D
    \u041F\u043E\u0447\u0435\u043C\u0443\xBB) \u0437\u0430 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0435
    \u0432\u043E\u043F\u0440\u043E\u0441\u044B \u043E\u0431 \u043E\u0441\u043D\u043E\u0432\u0430\u0445
    \u0432\u0435\u0449\u0435\u0439. \u041E\u043D \u0440\u0430\u043D\u043E \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u043A \u044F\u0437\u044B\u043A\u0430\u043C:
    \u043F\u043E\u043C\u0438\u043C\u043E \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0433\u043E,
    \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u043B
    \u043F\u043E-\u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438 \u0438 \u043F\u043E-\u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438. 
    \u0412 1923 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0412\u0435\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u0433\u0434\u0435 \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u0438\u0437\u0443\u0447\u0430\u043B
    \u0444\u0438\u0437\u0438\u043A\u0443, \u043D\u043E \u043F\u043E\u0434 \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C
    \u043A\u0443\u0440\u0441\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438 \u0438 \u0438\u0434\u0435\u0439 \u0411\u0435\u0440\u0442\u0440\u0430\u043D\u0430
    \u0420\u0430\u0441\u0441\u0435\u043B\u0430 \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u043B\u0441\u044F
    \u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443. \u041A\u043B\u044E\u0447\u0435\u0432\u0443\u044E
    \u0440\u043E\u043B\u044C \u0432 \u0435\u0433\u043E \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438
    \u0441\u044B\u0433\u0440\u0430\u043B\u043E \u0443\u0447\u0430\u0441\u0442\u0438\u0435
    \u0432 \u0441\u0435\u043C\u0438\u043D\u0430\u0440\u0430\u0445 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E
    **\u0412\u0435\u043D\u0441\u043A\u043E\u0433\u043E \u043A\u0440\u0443\u0436\u043A\u0430**
    \u2014 \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u0432
    \u0438 \u0443\u0447\u0435\u043D\u044B\u0445-\u043D\u0435\u043E\u043F\u043E\u0437\u0438\u0442\u0438\u0432\u0438\u0441\u0442\u043E\u0432.
    \u0425\u043E\u0442\u044F \u0413\u0451\u0434\u0435\u043B\u044C \u043F\u043E\u0441\u0435\u0449\u0430\u043B
    \u0435\u0433\u043E \u0437\u0430\u0441\u0435\u0434\u0430\u043D\u0438\u044F, \u043E\u043D
    \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0441\u044F
    \u043A \u0438\u0445 \u0432\u0437\u0433\u043B\u044F\u0434\u0430\u043C, \u043D\u0430\u0445\u043E\u0434\u044F
    \u043E\u0431\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u044F \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C\u0438.  ### \U0001F4A1 \u0422\u0440\u0438\u0443\u043C\u0444
    \u0438 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F: \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u043E \u043D\u0435\u043F\u043E\u043B\u043D\u043E\u0442\u0435  \u0413\u043B\u0430\u0432\u043D\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0413\u0451\u0434\u0435\u043B\u044F \u0431\u044B\u043B\u0438 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u044B
    \u0432 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E \u043C\u043E\u043B\u043E\u0434\u043E\u043C
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435.  *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043F\u043E\u043B\u043D\u043E\u0442\u0435 (1930):** \u0412 \u0441\u0432\u043E\u0435\u0439
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438 \u0413\u0451\u0434\u0435\u043B\u044C
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043B\u043E\u0433\u0438\u043A\u0430
    \u043F\u0440\u0435\u0434\u0438\u043A\u0430\u0442\u043E\u0432 \u043F\u0435\u0440\u0432\u043E\u0433\u043E
    \u043F\u043E\u0440\u044F\u0434\u043A\u0430 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043F\u043E\u043B\u043D\u043E\u0439: \u043B\u044E\u0431\u0430\u044F \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u0438\u0441\u0442\u0438\u043D\u043D\u0430\u044F \u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u0430
    \u0432 \u0440\u0430\u043C\u043A\u0430\u0445 \u044D\u0442\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B.
    \u042D\u0442\u043E \u0431\u044B\u043B \u0432\u0430\u0436\u043D\u044B\u0439 \xAB\u043E\u043F\u0442\u0438\u043C\u0438\u0441\u0442\u0438\u0447\u043D\u044B\u0439\xBB
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442, \u0443\u043A\u0440\u0435\u043F\u0438\u0432\u0448\u0438\u0439
    \u043F\u043E\u0437\u0438\u0446\u0438\u0438 \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043C\u0430. 
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u043D\u0435\u043F\u043E\u043B\u043D\u043E\u0442\u0435
    (1931):** 7 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F 1930 \u0433\u043E\u0434\u0430
    \u043D\u0430 \u043A\u043E\u043D\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0438
    \u0432 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0435 24-\u043B\u0435\u0442\u043D\u0438\u0439
    \u0413\u0451\u0434\u0435\u043B\u044C \u0441\u0434\u0435\u043B\u0430\u043B \u0441\u0435\u043D\u0441\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439
    \u0434\u043E\u043A\u043B\u0430\u0434, \u0430 \u0432 1931 \u0433\u043E\u0434\u0443
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0442\u0430\u0442\u044C\u044E,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0430
    \u044D\u0444\u0444\u0435\u043A\u0442 \u0440\u0430\u0437\u043E\u0440\u0432\u0430\u0432\u0448\u0435\u0439\u0441\u044F
    \u0431\u043E\u043C\u0431\u044B. **\u041F\u0435\u0440\u0432\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043D\u0435\u043F\u043E\u043B\u043D\u043E\u0442\u0435** \u0433\u043B\u0430\u0441\u0438\u0442:
    \u0432 \u043B\u044E\u0431\u043E\u0439 \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0439
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u0435,
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0435\u0439 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0443
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B,
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E
    \u043D\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C, \u043D\u0438 \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u044C
    \u0432 \u0440\u0430\u043C\u043A\u0430\u0445 \u044D\u0442\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B.
    \u0418\u043D\u044B\u043C\u0438 \u0441\u043B\u043E\u0432\u0430\u043C\u0438, \u043B\u044E\u0431\u0430\u044F
    \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E \u0441\u043B\u043E\u0436\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E
    \u043D\u0435\u043F\u043E\u043B\u043D\u0430.  **\u0412\u0442\u043E\u0440\u0430\u044F
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u043E \u043D\u0435\u043F\u043E\u043B\u043D\u043E\u0442\u0435**
    \u043D\u0430\u043D\u043E\u0441\u0438\u043B\u0430 \u0435\u0449\u0435 \u0431\u043E\u043B\u0435\u0435
    \u0441\u043E\u043A\u0440\u0443\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0443\u0434\u0430\u0440 \u043F\u043E \u0430\u043C\u0431\u0438\u0446\u0438\u043E\u0437\u043D\u043E\u0439
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0435 \u0414\u0430\u0432\u0438\u0434\u0430
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u0435\u0435 \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0441\u0442\u044C.
    \u0413\u0451\u0434\u0435\u043B\u044C \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E **\u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0441\u0442\u044C
    \u0442\u0430\u043A\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043D\u0435
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u0430
    \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430\u043C\u0438 \u0441\u0430\u043C\u043E\u0439
    \u044D\u0442\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B**. \u042D\u0442\u043E
    \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E, \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u0441\u043B\u0443\u0436\u0438\u0442\u044C
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u0431\u0435\u0437\u0443\u043F\u0440\u0435\u0447\u043D\u044B\u043C
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C.  ### \U0001F6E4\uFE0F
    \u042D\u043C\u0438\u0433\u0440\u0430\u0446\u0438\u044F \u0438 \u0436\u0438\u0437\u043D\u044C
    \u0432 \u0421\u0428\u0410  \u041F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044F \u0432 \u0415\u0432\u0440\u043E\u043F\u0435
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430 \u0440\u0435\u0448\u0430\u044E\u0449\u0435\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0436\u0438\u0437\u043D\u044C
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E. \u0412 1938 \u0433\u043E\u0434\u0443,
    \u043F\u043E\u0441\u043B\u0435 \u0430\u043D\u0448\u043B\u044E\u0441\u0430 (\u043F\u0440\u0438\u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F
    \u0410\u0432\u0441\u0442\u0440\u0438\u0438 \u043A \u043D\u0430\u0446\u0438\u0441\u0442\u0441\u043A\u043E\u0439
    \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438), \u0413\u0451\u0434\u0435\u043B\u044C
    \u043F\u043E\u0442\u0435\u0440\u044F\u043B \u0440\u0430\u0431\u043E\u0442\u0443
    \u0438 \u0431\u044B\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u043D \u0433\u043E\u0434\u043D\u044B\u043C
    \u043A \u0432\u043E\u0435\u043D\u043D\u043E\u0439 \u0441\u043B\u0443\u0436\u0431\u0435.
    \u0412 \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u0410\u0434\u0435\u043B\u044C
    \u041F\u043E\u0440\u043A\u0435\u0440\u0442, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u0442\u0430\u043B\u0430 \u0435\u0433\u043E \u0432\u0435\u0440\u043D\u043E\u0439
    \u0441\u043F\u0443\u0442\u043D\u0438\u0446\u0435\u0439 \u0438 \u043E\u043F\u043E\u0440\u043E\u0439
    \u043D\u0430 \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C.  \u0412 1940
    \u0433\u043E\u0434\u0443, \u043E\u043F\u0430\u0441\u0430\u044F\u0441\u044C \u043F\u0440\u0438\u0437\u044B\u0432\u0430,
    \u0413\u0451\u0434\u0435\u043B\u044C \u0441 \u0436\u0435\u043D\u043E\u0439 \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u0432 \u0421\u0428\u0410. \u041F\u0443\u0442\u044C \u0431\u044B\u043B \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u043C:
    \u0438\u0437-\u0437\u0430 \u0432\u043E\u0435\u043D\u043D\u044B\u0445 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439
    \u0432 \u0410\u0442\u043B\u0430\u043D\u0442\u0438\u043A\u0435 \u043E\u043D\u0438
    \u0434\u043E\u0431\u0440\u0430\u043B\u0438\u0441\u044C \u0447\u0435\u0440\u0435\u0437
    \u0421\u0421\u0421\u0420 \u043F\u043E \u0422\u0440\u0430\u043D\u0441\u0441\u0438\u0431\u0438\u0440\u0441\u043A\u043E\u0439
    \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430\u043B\u0438 \u0438 \u042F\u043F\u043E\u043D\u0438\u044E.
    \u0412 \u0410\u043C\u0435\u0440\u0438\u043A\u0435 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u043C
    \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0432
    \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435, \u0433\u0434\u0435 \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0436\u0438\u0437\u043D\u0438. \u0417\u0434\u0435\u0441\u044C
    \u043E\u043D \u043F\u043E\u0434\u0440\u0443\u0436\u0438\u043B\u0441\u044F \u0441
    \u0410\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C,
    \u0438 \u0438\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u044B\u0435
    \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0438 \u0441\u0442\u0430\u043B\u0438
    \u043B\u0435\u0433\u0435\u043D\u0434\u043E\u0439 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0430. 
    \u0412 1948 \u0433\u043E\u0434\u0443 \u0413\u0451\u0434\u0435\u043B\u044C \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0435 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u043E.
    \u041D\u0430 \u0441\u043E\u0431\u0435\u0441\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0438
    \u043E\u043D, \u043A \u0443\u0436\u0430\u0441\u0443 \u0434\u0440\u0443\u0437\u0435\u0439,
    \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u0441\u0443\u0434\u044C\u0435, \u0447\u0442\u043E \u0438\u0437 \u041A\u043E\u043D\u0441\u0442\u0438\u0442\u0443\u0446\u0438\u0438
    \u0421\u0428\u0410 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u0441\u043B\u0435\u0434\u0443\u0435\u0442
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u044F
    \u0434\u0438\u043A\u0442\u0430\u0442\u0443\u0440\u044B. \u0422\u043E\u043B\u044C\u043A\u043E
    \u0432\u043C\u0435\u0448\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043F\u043E\u0440\u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439 (\u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430
    \u0438 \u041C\u043E\u0440\u0433\u0435\u043D\u0448\u0442\u0435\u0440\u043D\u0430)
    \u043F\u043E\u043C\u043E\u0433\u043B\u043E \u0431\u043B\u0430\u0433\u043E\u043F\u043E\u043B\u0443\u0447\u043D\u043E
    \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u044C \u043F\u0440\u043E\u0446\u0435\u0434\u0443\u0440\u0443. 
    ### \u2728 \u0414\u0440\u0443\u0433\u0438\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B  \u0412\u043B\u0438\u044F\u043D\u0438\u0435
    \u0413\u0451\u0434\u0435\u043B\u044F \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u043B\u043E\u0433\u0438\u043A\u043E\u0439. \u041E\u043D \u0432\u043D\u0435\u0441
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432,
    \u0434\u043E\u043A\u0430\u0437\u0430\u0432 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u0438\u043C\u043E\u0441\u0442\u044C
    \u0430\u043A\u0441\u0438\u043E\u043C\u044B \u0432\u044B\u0431\u043E\u0440\u0430
    \u0438 \u043A\u043E\u043D\u0442\u0438\u043D\u0443\u0443\u043C-\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B
    \u0441 \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u0426\u0435\u0440\u043C\u0435\u043B\u043E-\u0424\u0440\u0435\u043D\u043A\u0435\u043B\u044F.
    \u041E\u0431\u0441\u0443\u0436\u0434\u0430\u044F \u0441 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0444\u0438\u0437\u0438\u043A\u0438,
    \u0413\u0451\u0434\u0435\u043B\u044C \u0432 1949 \u0433\u043E\u0434\u0443 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u043E\u0431\u0449\u0435\u0439 \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0434\u043E\u043F\u0443\u0441\u043A\u0430\u043B\u043E
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0445 \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043F\u043E\u0434\u043E\u0431\u043D\u044B\u0445
    \u043B\u0438\u043D\u0438\u0439 \u2014 \u0442\u043E \u0435\u0441\u0442\u044C \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0439
    \u0432\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u042D\u0442\u0430 \u043C\u043E\u0434\u0435\u043B\u044C,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F \u043A\u0430\u043A **\u0412\u0441\u0435\u043B\u0435\u043D\u043D\u0430\u044F
    \u0413\u0451\u0434\u0435\u043B\u044F**, \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430
    \u0435\u043C\u0443 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u0432\u0441\u043A\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E \u0432 1951 \u0433\u043E\u0434\u0443.  ###
    \U0001F9E0 \u0422\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0438\u043D\u0430\u043B  \u0412\u0441\u044E \u0436\u0438\u0437\u043D\u044C
    \u0413\u0451\u0434\u0435\u043B\u044C \u0441\u0442\u0440\u0430\u0434\u0430\u043B
    \u043E\u0442 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0445 \u043F\u0441\u0438\u0445\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432. \u0423\u0436\u0435
    \u0432 1930-\u0445 \u0433\u043E\u0434\u0430\u0445 \u0443 \u043D\u0435\u0433\u043E
    \u043D\u0430\u0447\u0430\u043B\u0438\u0441\u044C \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u044B
    \u0442\u044F\u0436\u0435\u043B\u043E\u0439 \u0438\u043F\u043E\u0445\u043E\u043D\u0434\u0440\u0438\u0438
    \u0438 \u043F\u0430\u0440\u0430\u043D\u043E\u0438\u0434\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u0442\u0440\u0430\u0445\u0438 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0431\u043E\u044F\u0437\u043D\u044C \u0431\u044B\u0442\u044C \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u043C).
    \u0412 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435 \u043E\u043D \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F
    \u043E\u0442 \u0435\u0434\u044B, \u043F\u0440\u0438\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u043D\u043E\u0439
    \u043D\u0435 \u0435\u0433\u043E \u0436\u0435\u043D\u043E\u0439, \u0430 \u0432\u043E
    \u0432\u0440\u0435\u043C\u044F \u043F\u0440\u0435\u0431\u044B\u0432\u0430\u043D\u0438\u044F
    \u0432 \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u0435 \u0432 1970-\u0445 \u0433\u043E\u0434\u0430\u0445
    \u0443 \u043D\u0435\u0433\u043E \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u043B\u0438\u0441\u044C
    \u0433\u0430\u043B\u043B\u044E\u0446\u0438\u043D\u0430\u0446\u0438\u0438.  \u0422\u0440\u0430\u0433\u0435\u0434\u0438\u044F
    \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B\u0430 \u0432 \u043A\u043E\u043D\u0446\u0435
    \u0436\u0438\u0437\u043D\u0438. \u0415\u0433\u043E \u0436\u0435\u043D\u0430 \u0410\u0434\u0435\u043B\u044C
    \u0442\u044F\u0436\u0435\u043B\u043E \u0437\u0430\u0431\u043E\u043B\u0435\u043B\u0430
    \u0438 \u0431\u044B\u043B\u0430 \u0433\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u0430,
    \u0430 \u0432 \u0438\u044E\u043B\u0435 1977 \u0433\u043E\u0434\u0430 \u0443\u043C\u0435\u0440
    \u0438\u0445 \u0431\u043B\u0438\u0437\u043A\u0438\u0439 \u0434\u0440\u0443\u0433
    \u041E\u0441\u043A\u0430\u0440 \u041C\u043E\u0440\u0433\u0435\u043D\u0448\u0442\u0435\u0440\u043D.
    \u041B\u0438\u0448\u0438\u0432\u0448\u0438\u0441\u044C \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u043E\u043F\u043E\u0440, \u0413\u0451\u0434\u0435\u043B\u044C, \u0441\u0442\u0440\u0430\u0434\u0430\u044F
    \u043E\u0442 \u043F\u0430\u0440\u0430\u043D\u043E\u0439\u0438 \u0438 \u0430\u043D\u043E\u0440\u0435\u043A\u0441\u0438\u0438,
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B
    \u0435\u0441\u0442\u044C, \u0431\u043E\u044F\u0441\u044C \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F.
    \u0412 \u0434\u0435\u043A\u0430\u0431\u0440\u0435 1977 \u0433\u043E\u0434\u0430
    \u043E\u043D \u0431\u044B\u043B \u0433\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D,
    \u043D\u043E \u0431\u044B\u043B\u043E \u0443\u0436\u0435 \u043F\u043E\u0437\u0434\u043D\u043E.
    \u041A\u0443\u0440\u0442 \u0413\u0451\u0434\u0435\u043B\u044C \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435 14 \u044F\u043D\u0432\u0430\u0440\u044F
    1978 \u0433\u043E\u0434\u0430 \u043E\u0442 \u0438\u0441\u0442\u043E\u0449\u0435\u043D\u0438\u044F."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u041A\u0443\u0440\u0442\u0430
    \u0413\u0451\u0434\u0435\u043B\u044F \u043F\u043E\u043B\u043D\u0430 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u044F\u0440\u043A\u043E \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u0443\u044E\u0442
    \u0435\u0433\u043E \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u0433\u0435\u043D\u0438\u0439 \u0438 \u0441\u043B\u043E\u0436\u043D\u044B\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440. \u0412\u043E\u0442 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0437 \u043D\u0438\u0445.  ### \U0001F9D2 \u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435 \"\u0413\u043E\u0441\u043F\u043E\u0434\u0438\u043D
    \u041F\u043E\u0447\u0435\u043C\u0443\"  \u0421 \u0440\u0430\u043D\u043D\u0438\u0445
    \u043B\u0435\u0442 \u0413\u0451\u0434\u0435\u043B\u044C \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B
    \u043D\u0435\u0443\u0442\u043E\u043B\u0438\u043C\u0443\u044E \u0436\u0430\u0436\u0434\u0443
    \u0437\u043D\u0430\u043D\u0438\u0439 \u0438 \u0434\u043E\u0442\u043E\u0448\u043D\u043E\u0441\u0442\u044C.
    \u0415\u0433\u043E \u043B\u044E\u0431\u043E\u0432\u044C \u043A \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u043C
    \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u043C \u043E\u0431 \u043E\u0441\u043D\u043E\u0432\u0430\u0445
    \u0432\u0435\u0449\u0435\u0439 \u0431\u044B\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u0435\u043B\u0438\u043A\u0430, \u0447\u0442\u043E \u0432 \u0441\u0435\u043C\u044C\u0435
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430 \u043B\u0430\u0441\u043A\u043E\u0432\u043E
    \u043F\u0440\u043E\u0437\u0432\u0430\u043B\u0438 **\"der Herr Warum\"** \u2014
    \"\u0413\u043E\u0441\u043F\u043E\u0434\u0438\u043D \u041F\u043E\u0447\u0435\u043C\u0443\".
    \u042D\u0442\u043E \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E
    \u043E\u0442\u0440\u0430\u0436\u0430\u043B\u043E \u0435\u0433\u043E \u0431\u0443\u0434\u0443\u0449\u0443\u044E
    \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u043A\u0430\u0440\u044C\u0435\u0440\u0443,
    \u0432\u0435\u0434\u044C \u043E\u043D \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u0436\u0438\u0437\u043D\u044C \u043F\u043E\u0438\u0441\u043A\u0443 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043E\u0441\u043D\u043E\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u043B\u043E\u0433\u0438\u043A\u0438.  ### \U0001F4DC \u0422\u0430\u0439\u043D\u0430
    \"\u041B\u0430\u0437\u0435\u0439\u043A\u0438 \u0413\u0451\u0434\u0435\u043B\u044F\" 
    \u041F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0438 \u0437\u0430\u0431\u0430\u0432\u043D\u0430\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u0435\u043C
    \u0413\u0451\u0434\u0435\u043B\u0435\u043C \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u0430 \u0432 1947
    \u0433\u043E\u0434\u0443.  *   **\u041A\u043E\u043D\u0441\u0442\u0438\u0442\u0443\u0446\u0438\u043E\u043D\u043D\u044B\u0439
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441:** \u0413\u043E\u0442\u043E\u0432\u044F\u0441\u044C
    \u043A \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0443 \u043D\u0430 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u043E,
    \u0413\u0451\u0434\u0435\u043B\u044C, \u043F\u043E \u0441\u0432\u043E\u0435\u043C\u0443
    \u043E\u0431\u044B\u043A\u043D\u043E\u0432\u0435\u043D\u0438\u044E, \u0434\u043E\u0441\u043A\u043E\u043D\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u0443\u0447\u0438\u043B \u041A\u043E\u043D\u0441\u0442\u0438\u0442\u0443\u0446\u0438\u044E
    \u0421\u0428\u0410 \u0438, \u043A \u0441\u0432\u043E\u0435\u043C\u0443 \u0443\u0436\u0430\u0441\u0443,
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B \u0432 \u043D\u0435\u0439
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E \"\u043B\u0430\u0437\u0435\u0439\u043A\u0443\".
    \u041E\u043D \u043F\u0440\u0438\u0448\u0435\u043B \u043A \u0432\u044B\u0432\u043E\u0434\u0443,
    \u0447\u0442\u043E \u044D\u0442\u043E\u0442 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u043A
    **\u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u043B\u0435\u0433\u0430\u043B\u044C\u043D\u043E \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0442\u044C
    \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0443\u044E \u0440\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0443
    \u0432 \u0434\u0438\u043A\u0442\u0430\u0442\u0443\u0440\u0443**. *   **\u0422\u0440\u0435\u0432\u043E\u0433\u0430
    \u0434\u0440\u0443\u0437\u0435\u0439:** \u0421\u0432\u043E\u0438\u043C \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\u043C
    \u043E\u043D \u043F\u043E\u0434\u0435\u043B\u0438\u043B\u0441\u044F \u0441 \u0434\u0440\u0443\u0437\u044C\u044F\u043C\u0438
    \u2014 \u0410\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C
    \u0438 \u041E\u0441\u043A\u0430\u0440\u043E\u043C \u041C\u043E\u0440\u0433\u0435\u043D\u0448\u0442\u0435\u0440\u043D\u043E\u043C.
    \u0422\u0435 \u043F\u0440\u0438\u0448\u043B\u0438 \u0432 \u0443\u0436\u0430\u0441,
    \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E \u0437\u043D\u0430\u044F
    \u043F\u0435\u0434\u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0438 \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0413\u0451\u0434\u0435\u043B\u044F. \u041E\u043D\u0438 \u0431\u043E\u044F\u043B\u0438\u0441\u044C,
    \u0447\u0442\u043E \u043D\u0430 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0435
    \u043E\u043D \u043D\u0430\u0447\u043D\u0435\u0442 \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u044D\u0442\u043E \u0441\u0443\u0434\u044C\u0435, \u0447\u0442\u043E \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u043E
    \u0431\u044B \u043F\u043E\u0434 \u0443\u0433\u0440\u043E\u0437\u0443 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u0435
    \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u0430. *   **\u041F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0430\u0442\u0430\u043A\u0430 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430:**
    \u041F\u043E \u0434\u043E\u0440\u043E\u0433\u0435 \u0432 \u0441\u0443\u0434 \u041C\u043E\u0440\u0433\u0435\u043D\u0448\u0442\u0435\u0440\u043D
    \u0441\u0438\u0434\u0435\u043B \u0437\u0430 \u0440\u0443\u043B\u0435\u043C, \u0430
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u043D\u043E
    \u043E\u0442\u0432\u043B\u0435\u043A\u0430\u043B \u0413\u0451\u0434\u0435\u043B\u044F
    \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440\u0430\u043C\u0438 \u043D\u0430
    \u043E\u0442\u0432\u043B\u0435\u0447\u0435\u043D\u043D\u044B\u0435 \u0442\u0435\u043C\u044B,
    \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043E\u0431 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0440\u0443\u0441\u0441\u043A\u043E\u0439 \u0446\u0435\u0440\u043A\u0432\u0438,
    \u0447\u0442\u043E\u0431\u044B \u0432\u044B\u0431\u0438\u0442\u044C \u0438\u0437
    \u0433\u043E\u043B\u043E\u0432\u044B \u043C\u044B\u0441\u043B\u0438 \u043E \u041A\u043E\u043D\u0441\u0442\u0438\u0442\u0443\u0446\u0438\u0438.
    *   **\u0418\u043D\u0446\u0438\u0434\u0435\u043D\u0442 \u0432 \u0441\u0443\u0434\u0435:**
    \u041E\u0434\u043D\u0430\u043A\u043E \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0430 \u0441\u0443\u0434\u044C\u044F
    \u0441\u043F\u0440\u043E\u0441\u0438\u043B \u0413\u0451\u0434\u0435\u043B\u044F,
    \u043A\u0430\u043A\u043E\u0435 \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0431\u044B\u043B\u043E \u0432 \u0410\u0432\u0441\u0442\u0440\u0438\u0438. \u0413\u0451\u0434\u0435\u043B\u044C
    \u0447\u0435\u0441\u0442\u043D\u043E \u043E\u0442\u0432\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u0440\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430
    \u0431\u044B\u043B\u0430 \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0435\u043D\u0430
    \u0432 \u0434\u0438\u043A\u0442\u0430\u0442\u0443\u0440\u0443. \u041A\u043E\u0433\u0434\u0430
    \u0441\u0443\u0434\u044C\u044F \u0437\u0430\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E
    \u0432 \u0421\u0428\u0410 \u0442\u0430\u043A\u043E\u0435 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0413\u0451\u0434\u0435\u043B\u044C \u0432\u043E\u0441\u043A\u043B\u0438\u043A\u043D\u0443\u043B:
    **\"\u041E, \u0434\u0430, \u044F \u043C\u043E\u0433\u0443 \u044D\u0442\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C!\"** \u041A \u0441\u0447\u0430\u0441\u0442\u044C\u044E,
    \u0441\u0443\u0434\u044C\u044F \u0431\u044B\u043B \u0437\u043D\u0430\u043A\u043E\u043C
    \u0441 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C \u0438, \u043D\u0435
    \u0436\u0435\u043B\u0430\u044F \u0432\u0432\u044F\u0437\u044B\u0432\u0430\u0442\u044C\u0441\u044F
    \u0432 \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u044E, \u0431\u044B\u0441\u0442\u0440\u043E
    \u043F\u0435\u0440\u0435\u0432\u0435\u043B \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440
    \u0432 \u0434\u0440\u0443\u0433\u043E\u0435 \u0440\u0443\u0441\u043B\u043E. 
    \u0422\u043E\u0447\u043D\u0430\u044F \u043F\u0440\u0438\u0440\u043E\u0434\u0430
    \u044D\u0442\u043E\u0439 \"\u043B\u0430\u0437\u0435\u0439\u043A\u0438\" \u0442\u0430\u043A
    \u0438 \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C \u043D\u0435\u0440\u0430\u0437\u0433\u0430\u0434\u0430\u043D\u043D\u043E\u0439,
    \u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u0441\u043F\u043E\u0440\u044F\u0442
    \u043E \u043D\u0435\u0439 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440. 
    ### \U0001F3B2 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u0435\u0440\u0438\u043B \u0432 \u043F\u0440\u0438\u0432\u0438\u0434\u0435\u043D\u0438\u044F? 
    \u0413\u0451\u0434\u0435\u043B\u044C \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    **\u043F\u043B\u0430\u0442\u043E\u043D\u0438\u043A\u043E\u043C** \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u041E\u043D \u0432\u0435\u0440\u0438\u043B, \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0431\u044A\u0435\u043A\u0442\u044B (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0447\u0438\u0441\u043B\u0430 \u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430)
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442 \u0440\u0435\u0430\u043B\u044C\u043D\u043E
    \u0438 \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E \u043E\u0442
    \u043D\u0430\u0448\u0435\u0433\u043E \u0441\u043E\u0437\u043D\u0430\u043D\u0438\u044F,
    \u043F\u043E\u0434\u043E\u0431\u043D\u043E \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u043C\u0438\u0440\u0443. \u041C\u044B \u043D\u0435 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0435\u043C
    \u0438\u0445, \u0430 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u043C,
    \u043A\u0430\u043A \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u044E\u0442 \u043D\u043E\u0432\u044B\u0435
    \u0432\u0438\u0434\u044B \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445. \u0411\u043E\u043B\u0435\u0435
    \u0442\u043E\u0433\u043E, \u043E\u043D \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D,
    \u0447\u0442\u043E \u0443 \u043D\u0430\u0441 \u0435\u0441\u0442\u044C \u043E\u0441\u043E\u0431\u0430\u044F
    \"\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u044F\", \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0430\u044F
    \"\u0432\u0438\u0434\u0435\u0442\u044C\" \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0441\u0442\u044C
    \u0430\u043A\u0441\u0438\u043E\u043C. \u0412 \u043A\u0430\u043A\u043E\u043C-\u0442\u043E
    \u0441\u043C\u044B\u0441\u043B\u0435 \u044D\u0442\u043E \u043C\u043E\u0436\u043D\u043E
    \u043D\u0430\u0437\u0432\u0430\u0442\u044C \u0432\u0435\u0440\u043E\u0439 \u0432
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u043C\u0438\u0440\u0430 \u0438\u0434\u0435\u0439, \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u0435\u0442
    \u0435\u0433\u043E \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u043F\u043E\u0447\u0442\u0438
    \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438 \u0434\u043B\u044F
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u043F\u0440\u043E\u0441\u043B\u0430\u0432\u0438\u0432\u0448\u0435\u0433\u043E\u0441\u044F
    \u0441\u0442\u0440\u043E\u0433\u0438\u043C\u0438 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C\u0438. 
    ### \U0001F570\uFE0F \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u0430\u044F,
    \u0433\u0434\u0435 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435
    \u0432\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438  \u0412 1949 \u0433\u043E\u0434\u0443,
    \u0432 \u043F\u043E\u0434\u0430\u0440\u043E\u043A \u043D\u0430 70-\u043B\u0435\u0442\u0438\u0435
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430, \u0413\u0451\u0434\u0435\u043B\u044C
    \u043F\u0440\u0435\u043F\u043E\u0434\u043D\u0435\u0441 \u0435\u043C\u0443 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0439
    \u0441\u044E\u0440\u043F\u0440\u0438\u0437. \u041E\u043D \u043D\u0430\u0448\u0435\u043B
    \u0442\u043E\u0447\u043D\u043E\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u043E\u0431\u0449\u0435\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u043E
    **\u0432\u0440\u0430\u0449\u0430\u044E\u0449\u0443\u044E\u0441\u044F \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u0443\u044E**.
    \u0412 \u044D\u0442\u043E\u0439 \u043C\u043E\u0434\u0435\u043B\u0438, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439
    \u043A\u0430\u043A **\"\u0412\u0441\u0435\u043B\u0435\u043D\u043D\u0430\u044F
    \u0413\u0451\u0434\u0435\u043B\u044F\"**, \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438
    \u0441\u0432\u0435\u0442\u0430 \u0438 \u043C\u0430\u0442\u0435\u0440\u0438\u0438
    \u0437\u0430\u043A\u0440\u0443\u0447\u0438\u0432\u0430\u043B\u0438\u0441\u044C
    \u0442\u0430\u043A \u0441\u0438\u043B\u044C\u043D\u043E, \u0447\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B\u0438
    **\u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043F\u043E\u0434\u043E\u0431\u043D\u044B\u0435
    \u043B\u0438\u043D\u0438\u0438**. \u041F\u0440\u043E\u0449\u0435 \u0433\u043E\u0432\u043E\u0440\u044F,
    \u0432 \u0442\u0430\u043A\u043E\u0439 \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043C\u043E\u0436\u043D\u043E
    \u0431\u044B\u043B\u043E \u0431\u044B \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C\u0441\u044F
    \u0432 \u043F\u0440\u043E\u0448\u043B\u043E\u0435. \u0425\u043E\u0442\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0438,
    \u0447\u0442\u043E \u043D\u0430\u0448\u0430 \u0440\u0435\u0430\u043B\u044C\u043D\u0430\u044F
    \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u0430\u044F \u043D\u0435 \u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F
    \u0442\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u044D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u0440\u043E\u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u0430
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0443\u044E \u0433\u043B\u0443\u0431\u0438\u043D\u0443
    \u0438 \u0441\u043C\u0435\u043B\u043E\u0441\u0442\u044C \u0435\u0433\u043E \u043C\u044B\u0441\u043B\u0438.
    \u0417\u0430 \u044D\u0442\u043E\u0442 \u0432\u043A\u043B\u0430\u0434 \u043E\u043D
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0435\u0440\u0432\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E \u0410\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430 \u0432 1951 \u0433\u043E\u0434\u0443. 
    ### \U0001F4AC \u0412\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430  \u041E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0442\u0435\u0445, \u043A\u0442\u043E \u043B\u0438\u0447\u043D\u043E
    \u043E\u0431\u0449\u0430\u043B\u0441\u044F \u0441 \u0413\u0451\u0434\u0435\u043B\u0435\u043C,
    \u0431\u044B\u043B \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u044C-\u0444\u0430\u043D\u0442\u0430\u0441\u0442
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A **\u0420\u0443\u0434\u0438
    \u0420\u0430\u043A\u0435\u0440**. \u0412 1972 \u0433\u043E\u0434\u0443, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u043E\u043C, \u043E\u043D \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0440\u0430\u0437 \u043F\u043E\u0441\u0435\u0449\u0430\u043B \u0413\u0451\u0434\u0435\u043B\u044F
    \u0432 \u0435\u0433\u043E \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0441\u043A\u043E\u043C
    \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u0435.  *   **\u0410\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0430:**
    \u041A\u0430\u0431\u0438\u043D\u0435\u0442 \u0413\u0451\u0434\u0435\u043B\u044F
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0438\u043B \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0435
    \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u0438\u0435 \u2014 \u043E\u043D
    \u0431\u044B\u043B \u043F\u043E\u043B\u0443\u0442\u0435\u043C\u043D\u044B\u043C,
    \u0441 \u043A\u043E\u0432\u0440\u0430\u043C\u0438 \u0438 \u043C\u044F\u0433\u043A\u043E\u0439
    \u043C\u0435\u0431\u0435\u043B\u044C\u044E. \u041D\u0430 \u043F\u0443\u0441\u0442\u043E\u043C
    \u0441\u0442\u043E\u043B\u0435 \u0441\u0442\u043E\u044F\u043B \u043F\u0443\u0441\u0442\u043E\u0439
    \u0441\u0442\u0430\u043A\u0430\u043D \u0438\u0437-\u043F\u043E\u0434 \u043C\u043E\u043B\u043E\u043A\u0430.
    *   **\u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440:** \u0420\u0430\u043A\u0435\u0440
    \u0437\u0430\u043F\u043E\u043C\u043D\u0438\u043B \u0435\u0433\u043E **\u0432\u044B\u0441\u043E\u043A\u0438\u0439,
    \u043F\u0435\u0432\u0443\u0447\u0438\u0439 \u0433\u043E\u043B\u043E\u0441** \u0438
    \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0439, \u0441\u043B\u043E\u0436\u043D\u043E
    \u0440\u0438\u0442\u043C\u0438\u0447\u043D\u044B\u0439 \u0441\u043C\u0435\u0445.
    \u0420\u0430\u0437\u0433\u043E\u0432\u043E\u0440 \u0441 \u0413\u0451\u0434\u0435\u043B\u0435\u043C,
    \u043F\u043E \u0435\u0433\u043E \u0441\u043B\u043E\u0432\u0430\u043C, \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u043B
    **\u0442\u0435\u043B\u0435\u043F\u0430\u0442\u0438\u044E** \u2014 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0431\u044B\u0441\u0442\u0440\u043E \u0438 \u0442\u043E\u0447\u043D\u043E \u0442\u043E\u0442
    \u0441\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u043B \u043B\u044E\u0431\u0443\u044E
    \u043C\u044B\u0441\u043B\u044C \u0441\u043E\u0431\u0435\u0441\u0435\u0434\u043D\u0438\u043A\u0430.
    *   **\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441 \u0441\u0432\u043E\u0431\u043E\u0434\u044B
    \u0432\u043E\u043B\u0438:** \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u0438\u0445
    \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0439 \u0413\u0451\u0434\u0435\u043B\u044C
    \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0430\u043B \u043E \u0441\u0432\u043E\u0431\u043E\u0434\u0435
    \u0432\u043E\u043B\u0438 \u0438 \u043F\u0440\u0435\u0434\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438.
    \u041E\u043D \u043F\u043E\u043B\u0430\u0433\u0430\u043B, \u0447\u0442\u043E \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u0430
    \u043F\u043E\u043B\u043D\u0430\u044F \u0442\u0435\u043E\u0440\u0438\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043C\u043E\u0436\u0435\u0442 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u0432\u0441\u0435 \u043D\u0430\u0448\u0438 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F.
    \u041D\u043E \u0435\u0441\u043B\u0438 \"\u043E\u0437\u043E\u0440\u043D\u043E\u0439\"
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0443\u0437\u043D\u0430\u0435\u0442
    \u044D\u0442\u0443 \u0442\u0435\u043E\u0440\u0438\u044E, \u043E\u043D \u0441\u043C\u043E\u0436\u0435\u0442
    \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u043D\u0430\u043E\u0431\u043E\u0440\u043E\u0442,
    \u0447\u0442\u043E\u0431\u044B \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u044C
    \u0435\u0435. \u0413\u0451\u0434\u0435\u043B\u044C \u043F\u0440\u0438\u0448\u0435\u043B
    \u043A \u0443\u0442\u0435\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u043C\u0443
    \u0432\u044B\u0432\u043E\u0434\u0443: **\"\u0422\u0435\u043E\u0440\u0438\u044F
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442, \u043D\u043E \u043D\u0438
    \u043E\u0434\u0438\u043D \u043E\u0437\u043E\u0440\u043D\u043E\u0439 \u0447\u0435\u043B\u043E\u0432\u0435\u043A
    \u043D\u0435 \u0443\u0437\u043D\u0430\u0435\u0442 \u043E \u043D\u0435\u0439\"**. 
    ### \U0001F37D\uFE0F \u0422\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0438\u043D\u0430\u043B \u0438 \u0441\u043C\u0435\u0440\u0442\u044C \u043E\u0442
    \u0441\u0442\u0440\u0430\u0445\u0430  \u0421\u0430\u043C\u0430\u044F \u043F\u0435\u0447\u0430\u043B\u044C\u043D\u0430\u044F
    \u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F \u0434\u0435\u0442\u0430\u043B\u044C
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438
    \u2014 \u044D\u0442\u043E \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u043C\u0435\u0440\u0442\u044C. \u0412\u0441\u044E \u0436\u0438\u0437\u043D\u044C
    \u0413\u0451\u0434\u0435\u043B\u044C \u0441\u0442\u0440\u0430\u0434\u0430\u043B
    \u043E\u0442 \u0442\u044F\u0436\u0435\u043B\u043E\u0439 \u043F\u0430\u0440\u0430\u043D\u043E\u0439\u0438,
    \u0438 \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u043D\u0430\u0432\u044F\u0437\u0447\u0438\u0432\u044B\u043C
    \u0441\u0442\u0440\u0430\u0445\u043E\u043C \u0431\u044B\u043B \u0441\u0442\u0440\u0430\u0445
    \u0431\u044B\u0442\u044C \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u043C.
    \u041E\u043D \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F
    \u043E\u0442 \u043B\u044E\u0431\u043E\u0439 \u0435\u0434\u044B, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043D\u0435 \u043F\u0440\u043E\u0431\u043E\u0432\u0430\u043B\u0430 \u043B\u0438\u0447\u043D\u043E
    \u0435\u0433\u043E \u0436\u0435\u043D\u0430 \u0410\u0434\u0435\u043B\u044C. 
    \u0412 \u043A\u043E\u043D\u0446\u0435 1977 \u0433\u043E\u0434\u0430 \u0410\u0434\u0435\u043B\u044C
    \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E \u0437\u0430\u0431\u043E\u043B\u0435\u043B\u0430
    \u0438 \u043F\u043E\u043F\u0430\u043B\u0430 \u0432 \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u0443
    \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0435\u0441\u044F\u0446\u0435\u0432.
    \u041B\u0438\u0448\u0438\u0432\u0448\u0438\u0441\u044C \u0441\u0432\u043E\u0435\u0439
    \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439 \"\u0434\u0435\u0433\u0443\u0441\u0442\u0430\u0442\u043E\u0440\u0448\u0438\",
    \u0413\u0451\u0434\u0435\u043B\u044C \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B \u0435\u0441\u0442\u044C, \u0443\u043C\u0435\u0440\u0435\u0432
    \u043E\u0442 \u0438\u0441\u0442\u043E\u0449\u0435\u043D\u0438\u044F \u0432 \u044F\u043D\u0432\u0430\u0440\u0435
    1978 \u0433\u043E\u0434\u0430. \u041D\u0430 \u043C\u043E\u043C\u0435\u043D\u0442
    \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u043D \u0432\u0435\u0441\u0438\u043B
    \u0432\u0441\u0435\u0433\u043E \u043E\u043A\u043E\u043B\u043E **29-30 \u043A\u0438\u043B\u043E\u0433\u0440\u0430\u043C\u043C\u043E\u0432**."
