  achievementsRu: "\u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u042F\u043A\u043E\u0431\u0430 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435 \u043E\u0433\u0440\u043E\u043C\u043D\u043E
    \u0438 \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u0441\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u041E\u043D \u0431\u044B\u043B
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445,
    \u043A\u0442\u043E \u043E\u0441\u043E\u0437\u043D\u0430\u043B \u043C\u043E\u0449\u044C
    \u043D\u043E\u0432\u043E\u0433\u043E \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430, \u0438 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u0435\u0433\u043E \u0434\u043B\u044F
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u043A\u0430\u043A \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445,
    \u0442\u0430\u043A \u0438 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447. \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439.  ### \U0001F4CA
    \u0422\u0435\u043E\u0440\u0438\u044F \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439:
    \xAB\u0417\u043E\u043B\u043E\u0442\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430\xBB
    \u0438 \xAB\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0439\xBB 
    \u042D\u0442\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u0434\u0435\u0442\u0438\u0449\u0435
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438, \u043F\u0440\u0438\u043D\u0435\u0441\u0448\u0435\u0435
    \u0435\u043C\u0443 \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0441\u043B\u0430\u0432\u0443.
    \u0415\u0433\u043E magnum opus, \u0442\u0440\u0430\u043A\u0442\u0430\u0442 **\xABArs
    Conjectandi\xBB (\xAB\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0439\xBB)**,
    \u0431\u044B\u043B \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D
    \u0435\u0433\u043E \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u043A\u043E\u043C
    \u0432 1713 \u0433\u043E\u0434\u0443, \u0447\u0435\u0440\u0435\u0437 \u0432\u043E\u0441\u0435\u043C\u044C
    \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E. \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0441\u0442\u0430\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u0432\u0441\u0435\u0439 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439
    \u0438 \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438.  \u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0435
    \u043C\u0435\u0441\u0442\u043E \u0432 \u043A\u043D\u0438\u0433\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    **\u0437\u0430\u043A\u043E\u043D\u0430 \u0431\u043E\u043B\u044C\u0448\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0430\u043C \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438 \u0441 \u0433\u043E\u0440\u0434\u043E\u0441\u0442\u044C\u044E
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0441\u0432\u043E\u0435\u0439 \xAB\u0417\u043E\u043B\u043E\u0442\u043E\u0439
    \u0442\u0435\u043E\u0440\u0435\u043C\u043E\u0439\xBB. \u0412 \u0441\u0432\u043E\u0435\u0439
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435 \u0441 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0435\u043C
    \u043E\u043D \u043E\u0442\u043C\u0435\u0447\u0430\u043B, \u0447\u0442\u043E \u0445\u043E\u0442\u044F
    \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u043E \xAB\u043A\u0430\u0436\u0434\u044B\u0439
    \u0433\u043B\u0443\u043F\u0435\u0446\xBB \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0441 \u0440\u043E\u0441\u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0430
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u0439 \u043E\u0448\u0438\u0431\u043A\u0430
    \u0443\u043C\u0435\u043D\u044C\u0448\u0430\u0435\u0442\u0441\u044F, \u0434\u0430\u0442\u044C
    \u044D\u0442\u043E\u043C\u0443 \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u2014 \u0437\u0430\u0434\u0430\u0447\u0430 \u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u043E\u0439
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438.  *   **\u0421\u0443\u0442\u044C
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B**: \u041E\u043D\u0430 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u043F\u0440\u0438 \u043C\u043D\u043E\u0433\u043E\u043A\u0440\u0430\u0442\u043D\u043E\u043C
    \u043F\u043E\u0432\u0442\u043E\u0440\u0435\u043D\u0438\u0438 \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u044B\u0445
    \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u0439 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043F\u043E\u0434\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043D\u0438\u0438
    \u043C\u043E\u043D\u0435\u0442\u044B) \u0447\u0430\u0441\u0442\u043E\u0442\u0430
    \u043D\u0430\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0441\u043E\u0431\u044B\u0442\u0438\u044F (\u0432\u044B\u043F\u0430\u0434\u0435\u043D\u0438\u044F
    \xAB\u043E\u0440\u043B\u0430\xBB) \u0441\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u043F\u043E \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0438
    \u043A \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0438. \u041F\u0440\u043E\u0449\u0435
    \u0433\u043E\u0432\u043E\u0440\u044F, \u0447\u0435\u043C \u0431\u043E\u043B\u044C\u0448\u0435
    \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u0439, \u0442\u0435\u043C \u0431\u043B\u0438\u0436\u0435
    \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0435\u043C\u0430\u044F \u0434\u043E\u043B\u044F
    \u0443\u0441\u043F\u0435\u0445\u043E\u0432 \u043A \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0439
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0438 `p`. *   **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435**:
    \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u043F\u0435\u0440\u0432\u0430\u044F
    \u0441\u0442\u0440\u043E\u0433\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0430 \u0438\u0434\u0435\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0440\u0430\u043D\u0435\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u043B\u0438\u0448\u044C \u043D\u0430 \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u043E\u043C
    \u0443\u0440\u043E\u0432\u043D\u0435. \u041E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F \u0432\u0441\u0435\u0445
    \u0431\u0443\u0434\u0443\u0449\u0438\u0445 \u043C\u0435\u0442\u043E\u0434\u043E\u0432
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0432\u044B\u0432\u043E\u0434\u0430 \u0438 \u0432\u044B\u0431\u043E\u0440\u043E\u0447\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. \u0412
    \u0435\u0433\u043E \u0447\u0435\u0441\u0442\u044C \u043D\u0430\u0437\u0432\u0430\u043D\u044B
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u044F
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439:
    **\u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u044F \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438**
    (\u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u044B\u0445 \u043E\u043F\u044B\u0442\u043E\u0432
    \u0441 \u0434\u0432\u0443\u043C\u044F \u0438\u0441\u0445\u043E\u0434\u0430\u043C\u0438),
    **\u0441\u0445\u0435\u043C\u0430 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438**
    \u0438 **\u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438**.  \u041A\u0440\u043E\u043C\u0435
    \u0442\u043E\u0433\u043E, \xABArs Conjectandi\xBB \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0430
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439 \u0430\u043D\u0430\u043B\u0438\u0437
    \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0438,
    \u0442\u0435\u043E\u0440\u0438\u044E \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A
    \u0438 \u0441\u043E\u0447\u0435\u0442\u0430\u043D\u0438\u0439, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439 \u043A
    \u0430\u0437\u0430\u0440\u0442\u043D\u044B\u043C \u0438\u0433\u0440\u0430\u043C
    \u0438 \u043C\u043E\u0440\u0430\u043B\u044C\u043D\u044B\u043C \u043E\u0436\u0438\u0434\u0430\u043D\u0438\u044F\u043C. 
    ### \U0001F4D0 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437: \u043F\u0435\u0440\u0432\u043E\u043F\u0440\u043E\u0445\u043E\u0434\u0435\u0446
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E
    \u043C\u0430\u043B\u044B\u0445  \u042F\u043A\u043E\u0431 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u0438 \u0441\u0430\u043C\u044B\u0445 \u0430\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u0432
    \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u043E\u0432
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435.  *   **\u0422\u0435\u0440\u043C\u0438\u043D
    \xAB\u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B\xBB**: \u0412 1690 \u0433\u043E\u0434\u0443,
    \u0432 \u0440\u0430\u0431\u043E\u0442\u0435, \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0435 \u043E \u043A\u0440\u0438\u0432\u043E\u0439
    \u0440\u0430\u0432\u043D\u043E\u0433\u043E \u0441\u043F\u0443\u0441\u043A\u0430
    (\u0438\u0437\u043E\u0445\u0440\u043E\u043D\u0435), \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0443\u043F\u043E\u0442\u0440\u0435\u0431\u0438\u043B \u0432 \u043F\u0435\u0447\u0430\u0442\u0438
    \u0442\u0435\u0440\u043C\u0438\u043D **\xAB\u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\xBB**
    \u0432 \u0435\u0433\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0441\u043C\u044B\u0441\u043B\u0435. \u042D\u0442\u043E \u0431\u044B\u043B\u043E
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C \u0448\u0430\u0433\u043E\u043C
    \u0432 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0438 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430 \u0430\u043D\u0430\u043B\u0438\u0437\u0430. *  
    **\u0412\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0435 \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435**:
    \u0412\u043C\u0435\u0441\u0442\u0435 \u0441\u043E \u0441\u0432\u043E\u0438\u043C
    \u0431\u0440\u0430\u0442\u043E\u043C \u0418\u043E\u0433\u0430\u043D\u043D\u043E\u043C
    \u043E\u043D \u0441\u0442\u043E\u044F\u043B \u0443 \u0438\u0441\u0442\u043E\u043A\u043E\u0432
    \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F. \u0412 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u043E\u043D \u0432\u043D\u0435\u0441 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    **\u0438\u0437\u043E\u043F\u0435\u0440\u0438\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0438** (\u043F\u043E\u0438\u0441\u043A \u0444\u0438\u0433\u0443\u0440\u044B
    \u0441 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u043F\u043B\u043E\u0449\u0430\u0434\u044C\u044E \u043F\u0440\u0438 \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u043C
    \u043F\u0435\u0440\u0438\u043C\u0435\u0442\u0440\u0435) \u0438 \u0437\u0430\u0434\u0430\u0447\u0438
    \u043E **\u0431\u0440\u0430\u0445\u0438\u0441\u0442\u043E\u0445\u0440\u043E\u043D\u0435**
    (\u043A\u0440\u0438\u0432\u043E\u0439 \u0441\u043A\u043E\u0440\u0435\u0439\u0448\u0435\u0433\u043E
    \u0441\u043F\u0443\u0441\u043A\u0430). *   **\u0414\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438**:
    \u0412 1696 \u0433\u043E\u0434\u0443 \u043E\u043D \u0440\u0435\u0448\u0438\u043B
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \u0432\u0438\u0434\u0430
    `y' = p(x)y + q(x)y^n`, \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0441 \u0442\u0435\u0445
    \u043F\u043E\u0440 \u043D\u043E\u0441\u0438\u0442 \u0435\u0433\u043E \u0438\u043C\u044F.
    \u042D\u0442\u043E \u0432\u0430\u0436\u043D\u044B\u0439 \u043A\u043B\u0430\u0441\u0441
    \u043D\u0435\u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0445 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439, \u0441\u0432\u043E\u0434\u044F\u0449\u0438\u0439\u0441\u044F
    \u043A \u043B\u0438\u043D\u0435\u0439\u043D\u043E\u043C\u0443. *   **\u0420\u044F\u0434\u044B**:
    \u041E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0441 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u043C\u0438
    \u0440\u044F\u0434\u0430\u043C\u0438. \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    **\u0440\u0430\u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u044C \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0440\u044F\u0434\u0430** `\u2211 1/n` (\u0445\u043E\u0442\u044F \u044D\u0442\u043E
    \u0431\u044B\u043B\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u0438
    \u0434\u043E \u043D\u0435\u0433\u043E) \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u044C \u0440\u044F\u0434\u0430
    `\u2211 1/n\xB2`, \u043F\u043E\u043A\u0430\u0437\u0430\u0432, \u0447\u0442\u043E
    \u043E\u043D \u0441\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u043A \u0447\u0438\u0441\u043B\u0443,
    \u043C\u0435\u043D\u044C\u0448\u0435\u043C\u0443 2 (\u0435\u0433\u043E \u0442\u043E\u0447\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u043F\u043E\u0437\u0434\u043D\u0435\u0435
    \u043D\u0430\u0448\u0435\u043B \u042D\u0439\u043B\u0435\u0440).  ### \U0001F9EE
    \u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B: \u0427\u0438\u0441\u043B\u0430
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438  \u0412 \u0445\u043E\u0434\u0435
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0441\u0443\u043C\u043C
    \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u044B\u0445 \u0441\u0442\u0435\u043F\u0435\u043D\u0435\u0439
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B
    (`1^k + 2^k +... + n^k`) \u042F\u043A\u043E\u0431 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u043E\u0442\u043A\u0440\u044B\u043B \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0433\u0440\u0430\u044E\u0442
    \u0432\u0430\u0436\u043D\u0443\u044E \u0440\u043E\u043B\u044C \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0430\u043D\u0430\u043B\u0438\u0437\u0435 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B. \u042D\u0442\u0438 \u0447\u0438\u0441\u043B\u0430
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435
    **\u0447\u0438\u0441\u0435\u043B \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438**.
    \u041E\u043D\u0438 \u043F\u043E\u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0432 \u0440\u0430\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0438 \u043C\u043D\u043E\u0433\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0432 \u0440\u044F\u0434\u044B \u0438
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F \u0432
    \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u0445 \u0441\u0443\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u042D\u0439\u043B\u0435\u0440\u0430-\u041C\u0430\u043A\u043B\u043E\u0440\u0435\u043D\u0430). 
    ### \U0001F4C8 \u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u0438 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u043A\u0440\u0438\u0432\u044B\u0445  \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u0432\u043D\u0435\u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435 \u0441\u0432\u043E\u0439\u0441\u0442\u0432
    \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445 \u043A\u0440\u0438\u0432\u044B\u0445. 
    *   **\u041B\u0435\u043C\u043D\u0438\u0441\u043A\u0430\u0442\u0430 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438**:
    \u0412 1694 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0438\u0441\u0430\u043B
    \u0438 \u0432\u0432\u0435\u043B \u0432 \u0440\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0435\u043D\u0438\u0435
    \u043A\u0440\u0438\u0432\u0443\u044E, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043D\u0430\u0437\u0432\u0430\u043B **\u043B\u0435\u043C\u043D\u0438\u0441\u043A\u0430\u0442\u043E\u0439**
    (\u043E\u0442 \u0433\u0440\u0435\u0447. \xAB\u043B\u0435\u043D\u0442\u0430\xBB).
    \u042D\u0442\u043E \u043F\u043B\u043E\u0441\u043A\u0430\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0440\u0438\u0432\u0430\u044F, \u0438\u043C\u0435\u044E\u0449\u0430\u044F
    \u0444\u043E\u0440\u043C\u0443 \xAB\u0432\u043E\u0441\u044C\u043C\u0435\u0440\u043A\u0438\xBB
    \u0438\u043B\u0438 \u0441\u0438\u043C\u0432\u043E\u043B\u0430 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438.
    \u041E\u043D \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u0435\u0435
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430, \u0445\u043E\u0442\u044F \u0438
    \u043D\u0435 \u0437\u043D\u0430\u043B, \u0447\u0442\u043E \u0431\u043E\u043B\u0435\u0435
    \u043E\u0431\u0449\u0438\u0439 \u0441\u043B\u0443\u0447\u0430\u0439 \u044D\u0442\u043E\u0439
    \u043A\u0440\u0438\u0432\u043E\u0439 \u0438\u0437\u0443\u0447\u0430\u043B\u0441\u044F
    \u041A\u0430\u0441\u0441\u0438\u043D\u0438. *   **\u0426\u0435\u043F\u043D\u0430\u044F
    \u043B\u0438\u043D\u0438\u044F**: \u0412 1691 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0440\u0435\u0448\u0438\u043B \u0437\u0430\u0434\u0430\u0447\u0443 \u043E \u0444\u043E\u0440\u043C\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0442
    \u043E\u0434\u043D\u043E\u0440\u043E\u0434\u043D\u0430\u044F \u0442\u044F\u0436\u0435\u043B\u0430\u044F
    \u043D\u0438\u0442\u044C, \u043F\u043E\u0434\u0432\u0435\u0448\u0435\u043D\u043D\u0430\u044F
    \u0437\u0430 \u0434\u0432\u0430 \u043A\u043E\u043D\u0446\u0430. \u042D\u0442\u0430
    \u043A\u0440\u0438\u0432\u0430\u044F, \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u0430\u044F
    **\u0446\u0435\u043F\u043D\u043E\u0439 \u043B\u0438\u043D\u0438\u0435\u0439**,
    \u0438\u043C\u0435\u0435\u0442 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0432 \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435
    \u0438 \u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u0443\u0440\u0435 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0434\u043B\u044F \u0440\u0430\u0441\u0447\u0435\u0442\u0430 \u0444\u043E\u0440\u043C
    \u0430\u0440\u043E\u043A \u0438 \u0432\u0438\u0441\u044F\u0447\u0438\u0445 \u043C\u043E\u0441\u0442\u043E\u0432).
    *   **\u041B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u043F\u0438\u0440\u0430\u043B\u044C**: \u041E\u043D \u0431\u044B\u043B
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u043C \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C
    \u044D\u0442\u043E\u0439 \u043A\u0440\u0438\u0432\u043E\u0439 \u2014 \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u0442\u044C
    \u0441\u0432\u043E\u044E \u0444\u043E\u0440\u043C\u0443 \u043F\u0440\u0438 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F\u0445
    (\u043F\u043E\u0434\u043E\u0431\u0438\u0438), \u2014 \u0447\u0442\u043E \u0437\u0430\u0432\u0435\u0449\u0430\u043B
    \u0438\u0437\u043E\u0431\u0440\u0430\u0437\u0438\u0442\u044C \u0435\u0451 \u043D\u0430
    \u0441\u0432\u043E\u0435\u043C \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u043D\u043E\u043C
    \u043A\u0430\u043C\u043D\u0435 \u0441 \u043D\u0430\u0434\u043F\u0438\u0441\u044C\u044E
    **\xABEADEM MUTATA RESURGO\xBB** (\xAB\u0418\u0437\u043C\u0435\u043D\u0435\u043D\u043D\u0430\u044F,
    \u044F \u0432\u043D\u043E\u0432\u044C \u0432\u043E\u0441\u043A\u0440\u0435\u0441\u0430\u044E\xBB).
    \u041F\u043E \u0438\u0440\u043E\u043D\u0438\u0438 \u0441\u0443\u0434\u044C\u0431\u044B,
    \u043D\u0430 \u0435\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u0435 \u043F\u043E
    \u043E\u0448\u0438\u0431\u043A\u0435 \u0432\u044B\u0441\u0435\u043A\u043B\u0438
    \u0441\u043F\u0438\u0440\u0430\u043B\u044C \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430.
    *   **\u042D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044B**: \u0412 1694 \u0433\u043E\u0434\u0443,
    \u0440\u0430\u0431\u043E\u0442\u0430\u044F \u043D\u0430\u0434 \u0437\u0430\u0434\u0430\u0447\u0435\u0439
    \u043E\u0431 \u0438\u0437\u0433\u0438\u0431\u0435 \u0443\u043F\u0440\u0443\u0433\u043E\u0439
    \u0431\u0430\u043B\u043A\u0438 (`elastica`) \u0438 \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u044F
    \u0434\u043B\u0438\u043D\u0443 \u0434\u0443\u0433\u0438 \u043B\u0435\u043C\u043D\u0438\u0441\u043A\u0430\u0442\u044B,
    \u043E\u043D \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F \u0441
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430\u043C\u0438 \u0432\u0438\u0434\u0430
    `\u222B dt/\u221A(1 - t\u2074)`. \u041E\u043D \u043F\u0435\u0440\u0432\u044B\u043C
    \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u044D\u0442\u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044B
    \u043D\u0435 \u0432\u044B\u0440\u0430\u0436\u0430\u044E\u0442\u0441\u044F \u0447\u0435\u0440\u0435\u0437
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u044B\u0435 \u0444\u0443\u043D\u043A\u0446\u0438\u0438,
    \u043F\u043E\u043B\u043E\u0436\u0438\u0432 \u043D\u0430\u0447\u0430\u043B\u043E
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E \u0442\u0435\u043E\u0440\u0438\u0438
    **\u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u0432** \u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u0439. 
    ### \U0001F4B0 \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0447\u0438\u0441\u043B\u0430
    e  \u0412 1683 \u0433\u043E\u0434\u0443, \u0437\u0430\u0434\u043E\u043B\u0433\u043E
    \u0434\u043E \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u042D\u0439\u043B\u0435\u0440
    \u0434\u0430\u043B \u0435\u043C\u0443 \u0431\u0443\u043A\u0432\u0435\u043D\u043D\u043E\u0435
    \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435, \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u043E\u0442\u043A\u0440\u044B\u043B \u043A\u043E\u043D\u0441\u0442\u0430\u043D\u0442\u0443
    **`e`**. \u041E\u043D \u0441\u0434\u0435\u043B\u0430\u043B \u044D\u0442\u043E,
    \u0438\u0437\u0443\u0447\u0430\u044F \u0437\u0430\u0434\u0430\u0447\u0443 \u043E
    **\u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u043C \u043D\u0430\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0438
    \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u043F\u0440\u043E\u0446\u0435\u043D\u0442\u043E\u0432**
    \u0438 \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u044F
    \u043F\u0440\u0435\u0434\u0435\u043B \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u044F
    `lim (n\u2192\u221E) (1 + 1/n)^n`.  ### \U0001F30C \u0424\u0438\u0437\u0438\u043A\u0430
    \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430  \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u043B
    \u0441\u0432\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0430\u043B\u0430\u043D\u0442 \u043A \u0437\u0430\u0434\u0430\u0447\u0430\u043C
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438 \u0438 \u0444\u0438\u0437\u0438\u043A\u0438.
    \u041E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u0430\u0434 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435\u043C
    \u0446\u0435\u043D\u0442\u0440\u0430 \u043A\u0430\u0447\u0430\u043D\u0438\u044F
    \u0442\u0435\u043B, \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0441\u043E\u043F\u0440\u043E\u0442\u0438\u0432\u043B\u0435\u043D\u0438\u0435
    \u0442\u0435\u043B \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u043E\u0439 \u0444\u043E\u0440\u043C\u044B
    \u043F\u0440\u0438 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438 \u0432 \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0438
    \u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0435
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435 \u043A \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E
    \u043C\u043E\u0441\u0442\u043E\u0432.  \u0415\u0441\u043B\u0438 \u0443 \u0432\u0430\u0441
    \u0435\u0441\u0442\u044C \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0432\u043E\u043F\u0440\u043E\u0441\u044B \u043F\u043E \u043B\u044E\u0431\u043E\u043C\u0443
    \u0438\u0437 \u044D\u0442\u0438\u0445 \u0430\u0441\u043F\u0435\u043A\u0442\u043E\u0432,
    \u044F \u0433\u043E\u0442\u043E\u0432 \u043E\u0442\u0432\u0435\u0442\u0438\u0442\u044C
    \u043D\u0430 \u043D\u0438\u0445 \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E."
  achievementsEn: 
  personalLifeRu: "\u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430
    \u0442\u043E, \u0447\u0442\u043E \u042F\u043A\u043E\u0431 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u0432 \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u043D\u0435 \u0431\u044B\u043B\u043E \u0433\u0440\u043E\u043C\u043A\u0438\u0445
    \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u043E\u0432 \u0438\u043B\u0438 \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439. \u041E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430, \u043F\u043E \u0431\u043E\u043B\u044C\u0448\u0435\u0439
    \u0447\u0430\u0441\u0442\u0438, \u043D\u0430\u0443\u043A\u0435 \u0438 \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u044B\u043C
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u043C \u0441 \u0441\u0435\u043C\u044C\u0435\u0439,
    \u0432 \u043F\u0435\u0440\u0432\u0443\u044E \u043E\u0447\u0435\u0440\u0435\u0434\u044C
    \u2013 \u0441 \u043C\u043B\u0430\u0434\u0448\u0438\u043C \u0431\u0440\u0430\u0442\u043E\u043C
    \u0418\u043E\u0433\u0430\u043D\u043D\u043E\u043C.  \u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438: 
    ### \U0001F48D \u0421\u0435\u043C\u044C\u044F \u0438 \u0431\u0440\u0430\u043A 
    \u0421\u0435\u043C\u0435\u0439\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u042F\u043A\u043E\u0431\u0430 \u0441\u043B\u043E\u0436\u0438\u043B\u0430\u0441\u044C
    \u0432\u043F\u043E\u043B\u043D\u0435 \u043E\u0431\u044B\u0447\u043D\u043E \u0434\u043B\u044F
    \u0441\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0431\u044E\u0440\u0433\u0435\u0440\u0430 \u0411\u0430\u0437\u0435\u043B\u044F
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.  *   **\u0416\u0435\u043D\u0438\u0442\u044C\u0431\u0430:**
    \u0412 1684 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    30 \u043B\u0435\u0442, \u042F\u043A\u043E\u0431 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u042E\u0434\u0438\u0442
    \u0428\u0442\u0443\u043F\u0430\u043D\u0443\u0441** (Judith Stupanus). \u041E\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u0441\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0430\u043F\u0442\u0435\u043A\u0430\u0440\u044F , \u0442\u043E \u0435\u0441\u0442\u044C
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0430 \u0438\u0437
    \u0442\u043E\u0433\u043E \u0436\u0435 \u043A\u0440\u0443\u0433\u0430 \u0431\u0430\u0437\u0435\u043B\u044C\u0441\u043A\u043E\u0439
    \u044D\u043B\u0438\u0442\u044B, \u0447\u0442\u043E \u0438 \u0441\u0435\u043C\u044C\u044F
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438. *   **\u0414\u0435\u0442\u0438:**
    \u0412 \u0431\u0440\u0430\u043A\u0435 \u0443 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C
    \u0434\u0432\u043E\u0435 \u0434\u0435\u0442\u0435\u0439 \u2013 \u0441\u044B\u043D
    \u0438 \u0434\u043E\u0447\u044C.     *   \u0421\u044B\u043D\u0430 \u043D\u0430\u0437\u0432\u0430\u043B\u0438
    **\u041D\u0438\u043A\u043E\u043B\u0430\u0443\u0441\u043E\u043C** \u0432 \u0447\u0435\u0441\u0442\u044C
    \u043E\u0442\u0446\u0430 \u042F\u043A\u043E\u0431\u0430.     *   \u0427\u0442\u043E
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u043F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0434\u043B\u044F \u0434\u0438\u043D\u0430\u0441\u0442\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u0438\u0445 \u0434\u0435\u0442\u0438 **\u043D\u0435 \u043F\u043E\u0448\u043B\u0438
    \u043F\u043E \u0441\u0442\u043E\u043F\u0430\u043C \u043E\u0442\u0446\u0430**
    \u0438 \u043D\u0435 \u0441\u0442\u0430\u043B\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438.
    \u0421\u044B\u043D, \u041D\u0438\u043A\u043E\u043B\u0430\u0443\u0441, \u043F\u043E\u0448\u0435\u043B
    \u043F\u043E \u043F\u0443\u0442\u0438 \u0434\u0435\u0434\u0430 \u0438 \u0441\u0442\u0430\u043B
    \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u0438\u043C \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u043E\u043C
    \u0438 \u043C\u0430\u0441\u0442\u0435\u0440\u043E\u043C \u0433\u0438\u043B\u044C\u0434\u0438\u0438
    \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u043E\u0432.  \u0415\u0433\u043E
    \u0436\u0435\u043D\u0430 \u0438 \u0434\u0435\u0442\u0438 \u043F\u0435\u0440\u0435\u0436\u0438\u043B\u0438
    \u0435\u0433\u043E, \u0438 \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u043D\u0438
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0438 \u043F\u0430\u043C\u044F\u0442\u043D\u0438\u043A
    \u043D\u0430 \u0435\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u0435, \u043D\u0430\u0434\u043F\u0438\u0441\u044C
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0437\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u043B\u0430\u0441\u044C
    \u0441\u043B\u043E\u0432\u0430\u043C\u0438: *\xAB...\u0441\u043E\u043E\u0440\u0443\u0436\u0435\u043D
    \u043E\u043F\u0435\u0447\u0430\u043B\u0435\u043D\u043D\u044B\u043C \u0441\u0443\u043F\u0440\u0443\u0433\u043E\u043C
    \u0438 \u0434\u0435\u0442\u044C\u043C\u0438, \u0442\u043E\u0441\u043A\u0443\u044E\u0449\u0438\u043C\u0438
    \u043F\u043E \u043C\u0443\u0436\u0443 \u0438 \u043E\u0442\u0446\u0443\xBB*. 
    ### \U0001F624 \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441
    \u0431\u0440\u0430\u0442\u043E\u043C \u0418\u043E\u0433\u0430\u043D\u043D\u043E\u043C:
    \u043E\u0442 \u0443\u0447\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043A \u0432\u0440\u0430\u0436\u0434\u0435  \u042D\u0442\u043E \u0431\u044B\u043B\u0430
    \u0441\u0430\u043C\u0430\u044F \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u0430\u044F
    \u0438 \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u043D\u043D\u0430\u044F \u0447\u0430\u0441\u0442\u044C
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F, \u043A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u0448\u0438\u0440\u043E\u043A\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430.
    \u0418\u0445 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043F\u0435\u0440\u0435\u0440\u043E\u0441\u043B\u043E \u0432 \u043E\u0436\u0435\u0441\u0442\u043E\u0447\u0435\u043D\u043D\u0443\u044E
    \u043A\u043E\u043D\u043A\u0443\u0440\u0435\u043D\u0446\u0438\u044E \u0438 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u0443\u044E
    \u0432\u0440\u0430\u0436\u0434\u0443.  1.  **\u041D\u0430\u0447\u0430\u043B\u043E
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0439:** \u042F\u043A\u043E\u0431
    \u0431\u044B\u043B \u043D\u0430 12 \u043B\u0435\u0442 \u0441\u0442\u0430\u0440\u0448\u0435
    \u0441\u0432\u043E\u0435\u0433\u043E \u0431\u0440\u0430\u0442\u0430 \u0418\u043E\u0433\u0430\u043D\u043D\u0430.
    \u041F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u0438\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0431\u044B\u043B\u0438
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u043C\u0438 \u0443\u0447\u0438\u0442\u0435\u043B\u044F
    \u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u0430: \u042F\u043A\u043E\u0431 \u043E\u0431\u0443\u0447\u0430\u043B
    \u043C\u043B\u0430\u0434\u0448\u0435\u0433\u043E \u0431\u0440\u0430\u0442\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. 2.  **\u041F\u0440\u0438\u0447\u0438\u043D\u044B
    \u0440\u0430\u0437\u0440\u044B\u0432\u0430:** \u0421\u043E\u043F\u0435\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0432\u043E\u0437\u043D\u0438\u043A\u043B\u043E, \u043A\u043E\u0433\u0434\u0430
    \u0418\u043E\u0433\u0430\u043D\u043D \u0434\u043E\u0441\u0442\u0438\u0433 \u0443\u0440\u043E\u0432\u043D\u044F,
    \u0441\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043C\u043E\u0433\u043E
    \u0441 \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u043E\u043C \u0431\u0440\u0430\u0442\u0430.
    \u041F\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u043E\u0431\u0430 \u043E\u0431\u043B\u0430\u0434\u0430\u043B\u0438 \u0441\u043B\u043E\u0436\u043D\u044B\u043C\u0438
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0430\u043C\u0438. \u042F\u043A\u043E\u0431\u0430
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438 \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    \u0447\u0443\u0432\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E,
    \u0440\u0430\u0437\u0434\u0440\u0430\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438 \u043E\u0441\u0442\u0440\u043E \u043D\u0443\u0436\u0434\u0430\u044E\u0449\u0435\u0433\u043E\u0441\u044F
    \u0432 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0438, \u0442\u043E\u0433\u0434\u0430
    \u043A\u0430\u043A \u0418\u043E\u0433\u0430\u043D\u043D \u0431\u044B\u043B \u0445\u0432\u0430\u0441\u0442\u043B\u0438\u0432
    \u0438 \u0430\u043C\u0431\u0438\u0446\u0438\u043E\u0437\u0435\u043D.     *  
    \u0421\u0438\u0442\u0443\u0430\u0446\u0438\u044E \u0443\u0441\u0443\u0433\u0443\u0431\u043B\u044F\u043B\u0430
    \u0437\u0430\u0432\u0438\u0441\u0442\u044C: \u042F\u043A\u043E\u0431, \u043A\u0430\u043A
    \u0441\u0442\u0430\u0440\u0448\u0438\u0439, \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E \u0438 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432 \u0411\u0430\u0437\u0435\u043B\u0435, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0418\u043E\u0433\u0430\u043D\u043D, \u043F\u043E-\u0432\u0438\u0434\u0438\u043C\u043E\u043C\u0443,
    \u0445\u043E\u0442\u0435\u043B \u0431\u044B \u0437\u0430\u043D\u044F\u0442\u044C
    \u0441\u0430\u043C.     *   \u0418\u0445 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u044B\u0435
    \u0441\u043F\u043E\u0440\u044B, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u043F\u043E\u0441\u043B\u0435 1697 \u0433\u043E\u0434\u0430, \u0431\u044B\u043B\u0438
    \u0445\u043E\u0440\u043E\u0448\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B
    \u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043A\u0440\u0443\u0433\u0430\u0445.
    \u041E\u043D\u0438 \u043E\u0431\u043C\u0435\u043D\u0438\u0432\u0430\u043B\u0438\u0441\u044C
    \u043A\u043E\u043B\u043A\u0438\u043C\u0438 \u0441\u0442\u0430\u0442\u044C\u044F\u043C\u0438,
    \u0431\u0440\u043E\u0441\u0430\u043B\u0438 \u0434\u0440\u0443\u0433 \u0434\u0440\u0443\u0433\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u044B\u0437\u043E\u0432\u044B, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
    \u0438 \u0443\u043D\u0438\u0437\u0438\u0442\u044C \u0441\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430. 
    \u042D\u0442\u043E\u0442 \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u043E\u043C\u0440\u0430\u0447\u0438\u043B
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u042F\u043A\u043E\u0431\u0430. \u0418\u0440\u043E\u043D\u0438\u044F
    \u0441\u0443\u0434\u044C\u0431\u044B \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E
    \u0418\u043E\u0433\u0430\u043D\u043D \u0441\u043C\u0435\u043D\u0438\u043B \u0435\u0433\u043E
    \u043D\u0430 \u043F\u043E\u0441\u0442\u0443 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432 \u0411\u0430\u0437\u0435\u043B\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u0441\u0442\u0430\u0440\u0448\u0435\u0433\u043E
    \u0431\u0440\u0430\u0442\u0430 \u0432 1705 \u0433\u043E\u0434\u0443."
  personalLifeEn: 
  shortBioRu: "\u042F\u043A\u043E\u0431 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u2014 \u0448\u0432\u0435\u0439\u0446\u0430\u0440\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043E\u0434\u0438\u043D \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430. \u041E\u043D \u0431\u044B\u043B \u0441\u0442\u0430\u0440\u0448\u0438\u043C
    \u0431\u0440\u0430\u0442\u043E\u043C \u0418\u043E\u0433\u0430\u043D\u043D\u0430
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438, \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F, \u0438 \u0434\u044F\u0434\u0435\u0439
    \u0414\u0430\u043D\u0438\u0438\u043B\u0430 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438. 
    \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u0430\u044F \u043D\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445.  ### \U0001F9EC
    \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B  \u042F\u043A\u043E\u0431
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    **6 \u044F\u043D\u0432\u0430\u0440\u044F 1655 \u0433\u043E\u0434\u0430** (\u043F\u043E
    \u0441\u0442\u0430\u0440\u043E\u043C\u0443 \u0441\u0442\u0438\u043B\u044E \u2014
    27 \u0434\u0435\u043A\u0430\u0431\u0440\u044F 1654 \u0433\u043E\u0434\u0430)
    \u0432 \u0411\u0430\u0437\u0435\u043B\u0435, \u0428\u0432\u0435\u0439\u0446\u0430\u0440\u0438\u044F.
    \u041E\u043D \u0431\u044B\u043B \u0441\u044B\u043D\u043E\u043C \u043F\u0440\u0435\u0443\u0441\u043F\u0435\u0432\u0430\u044E\u0449\u0435\u0433\u043E
    \u0444\u0430\u0440\u043C\u0430\u0446\u0435\u0432\u0442\u0430 \u041D\u0438\u043A\u043E\u043B\u0430\u044F
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438 \u0438 \u041C\u0430\u0440\u0433\u0430\u0440\u0435\u0442
    \u0428\u0451\u043D\u0430\u0443\u044D\u0440, \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0432\u0448\u0435\u0439
    \u0438\u0437 \u0441\u0435\u043C\u044C\u0438 \u0431\u0430\u043D\u043A\u0438\u0440\u043E\u0432
    \u0438 \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u0438\u0445 \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u043E\u0432. 
    \u0421\u0435\u043C\u044C\u044F \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438,
    \u0438\u043C\u0435\u0432\u0448\u0430\u044F \u0444\u043B\u0430\u043C\u0430\u043D\u0434\u0441\u043A\u0438\u0435
    \u043A\u043E\u0440\u043D\u0438, \u0431\u0435\u0436\u0430\u043B\u0430 \u0432 \u0411\u0430\u0437\u0435\u043B\u044C
    \u043E\u0442 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0445
    \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    \u0438\u0441\u043F\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u0433\u0435\u0440\u0446\u043E\u0433\u0430
    \u0410\u043B\u044C\u0431\u044B \u0432 1583 \u0433\u043E\u0434\u0443. \u041E\u0442\u0435\u0446
    \u042F\u043A\u043E\u0431\u0430 \u0431\u044B\u043B \u0432\u0438\u0434\u043D\u044B\u043C
    \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0438\u043D\u043E\u043C \u0411\u0430\u0437\u0435\u043B\u044F,
    \u0447\u043B\u0435\u043D\u043E\u043C \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u0432\u0435\u0442\u0430 \u0438 \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u043C. 
    \u0412\u043E\u043F\u0440\u0435\u043A\u0438 \u0436\u0435\u043B\u0430\u043D\u0438\u044E
    \u043E\u0442\u0446\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0433\u043E\u0442\u043E\u0432\u0438\u043B
    \u0435\u0433\u043E \u043A \u0434\u0443\u0445\u043E\u0432\u043D\u043E\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u0435,
    \u042F\u043A\u043E\u0431 \u0442\u0430\u0439\u043D\u043E \u0443\u0432\u043B\u0435\u043A\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439. \u041E\u043D
    \u0438\u0437\u0443\u0447\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u043E \u0441 \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0438\u0435\u043C.
    \u0412 1671 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C **\u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438**, \u0430 \u0432 1676
    \u2014 \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u043B\u0438\u0446\u0435\u043D\u0446\u0438\u0430\u0442\u0430
    \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0438\u044F \u0432 \u0411\u0430\u0437\u0435\u043B\u044C\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. \u0417\u0430
    \u0432\u0440\u0435\u043C\u044F \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u044F
    \u043E\u043D \u043E\u0432\u043B\u0430\u0434\u0435\u043B \u043F\u044F\u0442\u044C\u044E
    \u044F\u0437\u044B\u043A\u0430\u043C\u0438: \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u043C,
    \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u043C, \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u043C,
    \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u0438\u043C \u0438 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u043C. 
    ### \U0001F30D \u0413\u043E\u0434\u044B \u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0438\u0439
    \u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u044F  \u0412
    1676\u20131680 \u0433\u043E\u0434\u0430\u0445 \u042F\u043A\u043E\u0431 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E \u043F\u043E\u0435\u0437\u0434\u043A\u0443
    \u043F\u043E \u0415\u0432\u0440\u043E\u043F\u0435, \u0440\u0430\u0431\u043E\u0442\u0430\u044F
    \u0447\u0430\u0441\u0442\u043D\u044B\u043C \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C
    \u0432 \u0416\u0435\u043D\u0435\u0432\u0435 \u0438 \u0424\u0440\u0430\u043D\u0446\u0438\u0438,
    \u0433\u0434\u0435 \u0438\u0437\u0443\u0447\u0430\u043B \u0438\u0434\u0435\u0438
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438
    \u041D\u0438\u043A\u043E\u043B\u044F \u041C\u0430\u043B\u044C\u0431\u0440\u0430\u043D\u0448\u0430. 
    \u0412 1681\u20131682 \u0433\u043E\u0434\u0430\u0445 \u043E\u043D \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u044F\u043B
    \u043D\u043E\u0432\u043E\u0435 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435,
    \u043F\u043E\u0441\u0435\u0442\u0438\u0432 \u041D\u0438\u0434\u0435\u0440\u043B\u0430\u043D\u0434\u044B
    \u0438 \u0410\u043D\u0433\u043B\u0438\u044E. \u0422\u0430\u043C \u043E\u043D
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F \u0438
    \u0437\u0430\u0432\u044F\u0437\u0430\u043B \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443
    \u0441 \u0432\u0435\u0434\u0443\u0449\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438: **\u0425\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u043E\u043C
    \u0413\u044E\u0439\u0433\u0435\u043D\u0441\u043E\u043C, \u0420\u043E\u0431\u0435\u0440\u0442\u043E\u043C
    \u0411\u043E\u0439\u043B\u0435\u043C \u0438 \u0420\u043E\u0431\u0435\u0440\u0442\u043E\u043C
    \u0413\u0443\u043A\u043E\u043C**. \u042D\u0442\u0438 \u043F\u043E\u0435\u0437\u0434\u043A\u0438
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0440\u0430\u0441\u0448\u0438\u0440\u0438\u043B\u0438
    \u0435\u0433\u043E \u043A\u0440\u0443\u0433\u043E\u0437\u043E\u0440 \u0438 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u044B \u043D\u0430 \u0432\u0441\u044E
    \u0436\u0438\u0437\u043D\u044C.  ### \U0001F4DA \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430  \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C
    \u0432 \u0411\u0430\u0437\u0435\u043B\u044C \u0432 1683 \u0433\u043E\u0434\u0443,
    \u042F\u043A\u043E\u0431 \u043D\u0430\u0447\u0430\u043B \u0447\u0438\u0442\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u0438 \u043F\u043E \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435 \u0432 \u0411\u0430\u0437\u0435\u043B\u044C\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. \u0412
    1684 \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 **\u042E\u0434\u0438\u0442 \u0428\u0442\u0443\u043F\u0430\u043D\u0443\u0441**,
    \u043E\u0442 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0443 \u043D\u0435\u0433\u043E
    \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C \u0441\u044B\u043D \u0438 \u0434\u043E\u0447\u044C.
    \u0415\u0433\u043E \u0434\u0435\u0442\u0438, \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0447\u043B\u0435\u043D\u043E\u0432 \u0441\u0435\u043C\u044C\u0438 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438,
    \u043D\u0435 \u043F\u043E\u0448\u043B\u0438 \u043F\u043E \u0441\u0442\u043E\u043F\u0430\u043C
    \u043E\u0442\u0446\u0430.  \u0412 1687 \u0433\u043E\u0434\u0443 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E
    \u043A\u043B\u044E\u0447\u0435\u0432\u043E\u0435 \u0441\u043E\u0431\u044B\u0442\u0438\u0435
    \u0432 \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0435: \u043E\u043D
    \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D **\u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438** \u0411\u0430\u0437\u0435\u043B\u044C\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0438
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B \u044D\u0442\u0443 \u043A\u0430\u0444\u0435\u0434\u0440\u0443
    \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0441\u0432\u043E\u0438\u0445 \u0434\u043D\u0435\u0439. 
    ### \U0001F52D \u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  \u041D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u042F\u043A\u043E\u0431\u0430
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438 \u0431\u044B\u043B\u0430 \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u043E\u0439 \u0438
    \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u043B\u0430 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439.  *   **\u041E\u0441\u0432\u043E\u0435\u043D\u0438\u0435
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430**:
    \u0412 1687 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u043F\u0435\u0440\u0432\u044B\u043C \u043C\u0435\u043C\u0443\u0430\u0440\u043E\u043C
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430 \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E (1684 \u0433\u043E\u0434)
    \u0438 \u043D\u0430\u0447\u0430\u043B \u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u0441\u0432\u0430\u0438\u0432\u0430\u0442\u044C. \u041E\u0442\u0432\u0435\u0442
    \u043E\u0442 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430 \u043D\u0430 \u0437\u0430\u043F\u0440\u043E\u0441\u044B
    \u043E \u0440\u0430\u0437\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u044F\u0445
    \u043F\u0440\u0438\u0448\u0435\u043B \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0435\u0440\u0435\u0437
    \u0442\u0440\u0438 \u0433\u043E\u0434\u0430, \u043D\u043E \u043A \u0442\u043E\u043C\u0443
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u042F\u043A\u043E\u0431 \u0443\u0436\u0435
    \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u0432\u043B\u0430\u0434\u0435\u043B \u043D\u043E\u0432\u044B\u043C \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435\u043C
    \u0438 \u043D\u0430\u0447\u0430\u043B \u043E\u0431\u0443\u0447\u0430\u0442\u044C
    \u0435\u043C\u0443 \u0441\u0432\u043E\u0435\u0433\u043E \u0431\u0440\u0430\u0442\u0430
    \u0418\u043E\u0433\u0430\u043D\u043D\u0430. \u042F\u043A\u043E\u0431, \u0418\u043E\u0433\u0430\u043D\u043D
    \u0438 \u041B\u0435\u0439\u0431\u043D\u0438\u0446 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043B\u0438
    \u0442\u0440\u0438\u0443\u043C\u0432\u0438\u0440\u0430\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0430 20 \u043B\u0435\u0442 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  *   **\u0412\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0442\u0435\u0440\u043C\u0438\u043D\u0430 \xAB\u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\xBB**:
    \u0412 1690 \u0433\u043E\u0434\u0443 \u0432 \u0440\u0430\u0431\u043E\u0442\u0435,
    \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0435
    \u043E \u043A\u0440\u0438\u0432\u043E\u0439 \u0440\u0430\u0432\u043D\u043E\u0433\u043E
    \u0441\u043F\u0443\u0441\u043A\u0430 (\u0438\u0437\u043E\u0445\u0440\u043E\u043D\u0435),
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438 \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0443\u043F\u043E\u0442\u0440\u0435\u0431\u0438\u043B \u0432 \u043F\u0435\u0447\u0430\u0442\u0438
    \u0442\u0435\u0440\u043C\u0438\u043D **\xAB\u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\xBB**
    \u0432 \u0435\u0433\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0438, \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u0432\u0430\u0436\u043D\u043E\u0439 \u0432\u0435\u0445\u043E\u0439 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  *   **\u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u043A\u0440\u0438\u0432\u044B\u0445**: \u041E\u043D \u0432\u043D\u0435\u0441
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E, \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0432
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430 \u043C\u043D\u043E\u0433\u0438\u0445
    \u043A\u0440\u0438\u0432\u044B\u0445. \u0415\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C
    \u043D\u0430\u0437\u0432\u0430\u043D\u0430 **\u043B\u0435\u043C\u043D\u0438\u0441\u043A\u0430\u0442\u0430
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438**. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435\u043C
    \u0446\u0438\u043A\u043B\u043E\u0438\u0434\u044B \u0438 **\u0446\u0435\u043F\u043D\u043E\u0439
    \u043B\u0438\u043D\u0438\u0438**. \u041E\u0441\u043E\u0431\u0443\u044E \u043B\u044E\u0431\u043E\u0432\u044C
    \u042F\u043A\u043E\u0431 \u043F\u0438\u0442\u0430\u043B \u043A **\u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u043F\u0438\u0440\u0430\u043B\u0438**, \u0432\u043E\u0441\u0445\u0438\u0449\u0430\u044F\u0441\u044C
    \u0435\u0435 \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C \u0441\u0430\u043C\u043E\u043F\u043E\u0434\u043E\u0431\u0438\u044F
    \u2014 \u043E\u0441\u0442\u0430\u0432\u0430\u0442\u044C\u0441\u044F \u043D\u0435\u0438\u0437\u043C\u0435\u043D\u043D\u043E\u0439
    \u043F\u0440\u0438 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F\u0445. 
    *   **\u0427\u0438\u0441\u043B\u043E e**: \u0412 1683 \u0433\u043E\u0434\u0443,
    \u0438\u0441\u0441\u043B\u0435\u0434\u0443\u044F \u0437\u0430\u0434\u0430\u0447\u0443
    \u043E \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u043F\u0440\u043E\u0446\u0435\u043D\u0442\u0430\u0445,
    \u043E\u043D \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B \u043F\u0440\u0435\u0434\u0435\u043B
    `lim (1 + 1/n)^n`, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0441\u0442\u0430\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u043A\u0430\u043A
    \u0447\u0438\u0441\u043B\u043E `e`.  *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439**: \u042D\u0442\u043E,
    \u043F\u043E\u0436\u0430\u043B\u0443\u0439, \u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0435
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435.
    \u041E\u043D \u0432\u0432\u0435\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 \u043F\u043E\u043D\u044F\u0442\u0438\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434,
    **\xAB\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0439\xBB**
    (`Ars Conjectandi`), \u0431\u044B\u043B \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D
    \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E, \u0432 1713 \u0433\u043E\u0434\u0443.
    \u0412 \u044D\u0442\u043E\u0439 \u043A\u043D\u0438\u0433\u0435 \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0447\u0430\u0441\u0442\u043D\u044B\u0439
    \u0441\u043B\u0443\u0447\u0430\u0439 **\u0437\u0430\u043A\u043E\u043D\u0430 \u0431\u043E\u043B\u044C\u0448\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B** (\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u0430\u043A **\u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438**),
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u0432\u0441\u0435\u0439 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438. \u0412 \u0435\u0433\u043E
    \u0447\u0435\u0441\u0442\u044C \u043D\u0430\u0437\u0432\u0430\u043D\u044B **\u0447\u0438\u0441\u043B\u0430
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438** \u0438 \u0432\u0430\u0436\u043D\u043E\u0435
    \u0432 \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0435
    **\u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438**.  *   **\u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435**:
    \u0412 1699 \u0433\u043E\u0434\u0443 \u042F\u043A\u043E\u0431 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u0441\u0442\u0430\u043B \u0447\u043B\u0435\u043D\u043E\u043C \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A, \u0430
    \u0432 1701 \u0433\u043E\u0434\u0443 \u2014 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A.  ###
    \u2694\uFE0F \u0421\u043E\u043F\u0435\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u0431\u0440\u0430\u0442\u043E\u043C  \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u042F\u043A\u043E\u0431\u0430 \u0441 \u043C\u043B\u0430\u0434\u0448\u0438\u043C
    \u0431\u0440\u0430\u0442\u043E\u043C \u0418\u043E\u0433\u0430\u043D\u043D\u043E\u043C
    \u0438\u0437\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E \u0431\u044B\u043B\u0438
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E\u043C,
    \u043D\u043E \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C \u043F\u0435\u0440\u0435\u0440\u043E\u0441\u043B\u0438
    \u0432 \u043E\u0436\u0435\u0441\u0442\u043E\u0447\u0435\u043D\u043D\u043E\u0435
    \u0441\u043E\u043F\u0435\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E.
    \u0411\u0438\u043E\u0433\u0440\u0430\u0444\u044B \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442
    \u042F\u043A\u043E\u0431\u0430 \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    \u0447\u0443\u0432\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E,
    \u0440\u0430\u0437\u0434\u0440\u0430\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E,
    \u0430\u0433\u0440\u0435\u0441\u0441\u0438\u0432\u043D\u043E\u0433\u043E \u0438
    \u043C\u0441\u0442\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E, \u0447\u0442\u043E
    \u043D\u0435\u0438\u0437\u0431\u0435\u0436\u043D\u043E \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B\u043E
    \u043A \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0430\u043C \u0441 \u043D\u0435
    \u043C\u0435\u043D\u0435\u0435 \u0430\u043C\u0431\u0438\u0446\u0438\u043E\u0437\u043D\u044B\u043C
    \u0431\u0440\u0430\u0442\u043E\u043C. \u0418\u0445 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u044B\u0435
    \u0441\u043F\u043E\u0440\u044B, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u043F\u043E\u0441\u043B\u0435 \u043F\u0435\u0440\u0435\u0435\u0437\u0434\u0430
    \u0418\u043E\u0433\u0430\u043D\u043D\u0430 \u0432 \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u044E
    \u0432 1695 \u0433\u043E\u0434\u0443, \u0441\u0442\u0430\u043B\u0438 \u0448\u0438\u0440\u043E\u043A\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B \u0438, \u043F\u043E \u043C\u043D\u0435\u043D\u0438\u044E
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432, \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u043C\u0443
    \u0440\u0430\u0437\u0440\u044B\u0432\u0443 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0439
    \u0432 1697 \u0433\u043E\u0434\u0443.  ### \U0001F56F\uFE0F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0435 
    \u0412 1692 \u0433\u043E\u0434\u0443 \u0443 \u042F\u043A\u043E\u0431\u0430 \u043F\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C
    \u043F\u0435\u0440\u0432\u044B\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043A\u0438
    \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437\u0430. \u0411\u043E\u043B\u0435\u0437\u043D\u044C
    \u043F\u043E\u0434\u0442\u0430\u0447\u0438\u0432\u0430\u043B\u0430 \u0435\u0433\u043E
    \u0441\u0438\u043B\u044B \u0432 \u0442\u0435\u0447\u0435\u043D\u0438\u0435 \u043C\u043D\u043E\u0433\u0438\u0445
    \u043B\u0435\u0442, \u0438 \u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    **16 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1705 \u0433\u043E\u0434\u0430**
    \u0432 \u0411\u0430\u0437\u0435\u043B\u0435. \u041F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u043E\u043D \u0431\u044B\u043B \u0432 \u0411\u0430\u0437\u0435\u043B\u044C\u0441\u043A\u043E\u043C
    \u0441\u043E\u0431\u043E\u0440\u0435.  \u0421\u043B\u0435\u0434\u0443\u044F \u0435\u0433\u043E
    \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u044E, \u043D\u0430 \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u0438
    \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u043B\u0430 \u0431\u044B\u0442\u044C
    \u0432\u044B\u0440\u0435\u0437\u0430\u043D\u0430 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u043F\u0438\u0440\u0430\u043B\u044C \u0441 \u043D\u0430\u0434\u043F\u0438\u0441\u044C\u044E
    \u043D\u0430 \u043B\u0430\u0442\u044B\u043D\u0438: **\xABEADEM MUTATA RESURGO\xBB**
    (\xAB\u0418\u0437\u043C\u0435\u043D\u0435\u043D\u043D\u0430\u044F, \u044F \u0432\u043D\u043E\u0432\u044C
    \u0432\u043E\u0441\u043A\u0440\u0435\u0441\u0430\u044E\xBB), \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0437\u0438\u0440\u0443\u044E\u0449\u0435\u0439
    \u0432\u0435\u0447\u043D\u043E\u0441\u0442\u044C \u0438 \u0432\u043E\u0441\u043A\u0440\u0435\u0441\u0435\u043D\u0438\u0435.
    \u041E\u0434\u043D\u0430\u043A\u043E \u043F\u043E \u0438\u0440\u043E\u043D\u0438\u0438
    \u0441\u0443\u0434\u044C\u0431\u044B \u0438\u043B\u0438 \u043F\u043E \u043D\u0435\u0437\u043D\u0430\u043D\u0438\u044E,
    \u043A\u0430\u043C\u0435\u043D\u0449\u0438\u043A\u0438 \u0438\u0437\u043E\u0431\u0440\u0430\u0437\u0438\u043B\u0438
    \u043D\u0430 \u0435\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u0435 \u0430\u0440\u0445\u0438\u043C\u0435\u0434\u043E\u0432\u0443,
    \u0430 \u043D\u0435 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u043F\u0438\u0440\u0430\u043B\u044C.  \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u042F\u043A\u043E\u0431\u0430 \u0435\u0433\u043E \u043A\u0430\u0444\u0435\u0434\u0440\u0443
    \u0432 \u0411\u0430\u0437\u0435\u043B\u044C\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0437\u0430\u043D\u044F\u043B \u0435\u0433\u043E \u0431\u0440\u0430\u0442 \u0418\u043E\u0433\u0430\u043D\u043D.
    \u0412 \u0447\u0435\u0441\u0442\u044C \u0431\u0440\u0430\u0442\u044C\u0435\u0432
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438 \u043D\u0430\u0437\u0432\u0430\u043D
    \u043A\u0440\u0430\u0442\u0435\u0440 \u043D\u0430 \u041B\u0443\u043D\u0435."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u042F\u043A\u043E\u0431\u0430
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438 \u2014 \u044D\u0442\u043E \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0435\u0440\u0435\u0434\u0430 \u0441\u0443\u0445\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439, \u043D\u043E \u0438
    \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F, \u043F\u043E\u043B\u043D\u0430\u044F
    \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u044B\u0445 \u0434\u0435\u0442\u0430\u043B\u0435\u0439,
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445 \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439
    \u0438 \u0434\u0430\u0436\u0435 \u0442\u0440\u0430\u0433\u0438\u043A\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0448\u0438\u0431\u043E\u043A. \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435
    \u044F\u0440\u043A\u0438\u0435 \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438: 
    ### \U0001F9F2 \xAB\u0423\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0441\u043F\u0438\u0440\u0430\u043B\u044C\xBB \u0438 \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u0430\u044F
    \u0438\u0440\u043E\u043D\u0438\u044F  \u041F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0438 \u0442\u0440\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442 \u0441\u0432\u044F\u0437\u0430\u043D \u0441 \u0435\u0433\u043E
    \u043B\u044E\u0431\u043E\u0432\u044C\u044E \u043A **\u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u043F\u0438\u0440\u0430\u043B\u0438**. \u042F\u043A\u043E\u0431 \u0431\u044B\u043B
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D
    \u0435\u0435 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u043C \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C
    \u2014 \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u0442\u044C \u0441\u0432\u043E\u044E
    \u0444\u043E\u0440\u043C\u0443 \u043F\u0440\u0438 \u043B\u044E\u0431\u044B\u0445
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F\u0445
    \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u0430 (\u0441\u0430\u043C\u043E\u043F\u043E\u0434\u043E\u0431\u0438\u0435),
    \u2014 \u0447\u0442\u043E \u043D\u0430\u0437\u0432\u0430\u043B \u0435\u0435 **Spira
    mirabilis** (\xAB\u0423\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0441\u043F\u0438\u0440\u0430\u043B\u044C\xBB) .  \u041E\u043D \u0437\u0430\u0432\u0435\u0449\u0430\u043B
    \u0432\u044B\u0441\u0435\u0447\u044C \u044D\u0442\u0443 \u0441\u043F\u0438\u0440\u0430\u043B\u044C
    \u043D\u0430 \u0441\u0432\u043E\u0435\u043C \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u0438
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u0434\u0435\u0432\u0438\u0437\u043E\u043C
    \u043D\u0430 \u043B\u0430\u0442\u044B\u043D\u0438: **\xABEADEM MUTATA RESURGO\xBB**
    . \u042D\u0442\u0430 \u0444\u0440\u0430\u0437\u0430 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0438\u0442\u0441\u044F
    \u043A\u0430\u043A *\xAB\u0418\u0437\u043C\u0435\u043D\u0435\u043D\u043D\u0430\u044F,
    \u044F \u0432\u043D\u043E\u0432\u044C \u0432\u043E\u0441\u043A\u0440\u0435\u0441\u0430\u044E\xBB*
    \u0438\u043B\u0438 *\xAB\u0425\u043E\u0442\u044F \u0438 \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0438\u0441\u044C,
    \u044F \u0432\u043E\u0441\u0441\u0442\u0430\u044E \u0442\u043E\u0439 \u0436\u0435
    \u0441\u0430\u043C\u043E\u0439\xBB* . \u0414\u043B\u044F \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u044D\u0442\u043E \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043E\u0431\u044A\u0435\u043A\u0442, \u0430 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0441\u0438\u043C\u0432\u043E\u043B \u0441\u0442\u043E\u0439\u043A\u043E\u0441\u0442\u0438,
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u0441\u0442\u0432\u0430 \u0432 \u043D\u0435\u0432\u0437\u0433\u043E\u0434\u0430\u0445
    \u0438 \u0434\u0430\u0436\u0435 \u0432\u043E\u0441\u043A\u0440\u0435\u0441\u0435\u043D\u0438\u044F
    \u0434\u0443\u0448\u0438 \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    .  \u041E\u0434\u043D\u0430\u043A\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0440\u0430\u0441\u043F\u043E\u0440\u044F\u0434\u0438\u043B\u0430\u0441\u044C
    \u0438\u043D\u0430\u0447\u0435. \u041F\u043E \u0438\u0440\u043E\u043D\u0438\u0438
    \u0441\u0443\u0434\u044C\u0431\u044B (\u0438\u043B\u0438 \u0438\u0437-\u0437\u0430
    \u043D\u0435\u0432\u0435\u0436\u0435\u0441\u0442\u0432\u0430 \u043A\u0430\u043C\u0435\u043D\u0449\u0438\u043A\u043E\u0432),
    \u043D\u0430 \u0435\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u0435 \u0432 \u0411\u0430\u0437\u0435\u043B\u044C\u0441\u043A\u043E\u043C
    \u0441\u043E\u0431\u043E\u0440\u0435 \u0431\u044B\u043B\u0430 \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u0430
    \u0432\u043E\u0432\u0441\u0435 \u043D\u0435 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F,
    \u0430 **\u0430\u0440\u0445\u0438\u043C\u0435\u0434\u043E\u0432\u0430 \u0441\u043F\u0438\u0440\u0430\u043B\u044C**
    . \u042D\u0442\u043E \u043B\u0438\u0448\u0430\u0435\u0442 \u043D\u0430\u0434\u043F\u0438\u0441\u044C
    \u0435\u0451 \u0441\u0430\u043A\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043C\u044B\u0441\u043B\u0430, \u0442\u0430\u043A \u043A\u0430\u043A \u0430\u0440\u0445\u0438\u043C\u0435\u0434\u043E\u0432\u0430
    \u0441\u043F\u0438\u0440\u0430\u043B\u044C \u043D\u0435 \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C \u0441\u0430\u043C\u043E\u043F\u043E\u0434\u043E\u0431\u0438\u044F.
    \u0412\u0435\u043B\u0438\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0441\u0442\u0430\u043B \u0436\u0435\u0440\u0442\u0432\u043E\u0439 \u0434\u043E\u0441\u0430\u0434\u043D\u043E\u0439
    \u043E\u0448\u0438\u0431\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F,
    \u043E\u0434\u043D\u0430\u043A\u043E, \u0441\u0434\u0435\u043B\u0430\u043B\u0430
    \u044D\u0442\u0443 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u0435\u0449\u0435
    \u0431\u043E\u043B\u0435\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439
    .  ### \U0001F4B0 \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0447\u0438\u0441\u043B\u0430
    **e** \u0432 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0435 \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439
    \u043E \u0434\u0435\u043D\u044C\u0433\u0430\u0445  \u0412 1683 \u0433\u043E\u0434\u0443
    \u042F\u043A\u043E\u0431 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438, \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u044F\u044F
    \u043E \u0437\u0430\u0434\u0430\u0447\u0435 **\u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0433\u043E
    \u043D\u0430\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u043F\u0440\u043E\u0446\u0435\u043D\u0442\u043E\u0432**, \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0435\u0449\u0435 \u043E\u0434\u043D\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 .  \u041E\u043D \u0437\u0430\u0434\u0430\u043B\u0441\u044F
    \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u043C: \u0447\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u043E\u0439\u0434\u0435\u0442,
    \u0435\u0441\u043B\u0438 \u043F\u0440\u043E\u0446\u0435\u043D\u0442\u044B \u043F\u043E
    \u0432\u043A\u043B\u0430\u0434\u0443 \u043D\u0430\u0447\u0438\u0441\u043B\u044F\u0442\u044C
    \u043D\u0435 \u0440\u0430\u0437 \u0432 \u0433\u043E\u0434, \u0430 \u0447\u0430\u0449\u0435
    \u2014 \u0435\u0436\u0435\u043C\u0435\u0441\u044F\u0447\u043D\u043E, \u0435\u0436\u0435\u0434\u043D\u0435\u0432\u043D\u043E,
    \u0435\u0436\u0435\u0447\u0430\u0441\u043D\u043E? \u0412 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0435
    \u0441\u0432\u043E\u0438\u0445 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439
    \u043E\u043D \u043D\u0430\u0442\u043A\u043D\u0443\u043B\u0441\u044F \u043D\u0430
    \u043F\u0440\u0435\u0434\u0435\u043B \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    `lim (n\u2192\u221E) (1 + 1/n)^n` . \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u044D\u0442\u043E\u0442
    \u043F\u0440\u0435\u0434\u0435\u043B \u043B\u0435\u0436\u0438\u0442 \u043C\u0435\u0436\u0434\u0443
    2,5 \u0438 3 , \u0438 \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0442\u043A\u0440\u044B\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u043A\u043E\u043D\u0441\u0442\u0430\u043D\u0442\u0443 **e** (~2.71828\u2026),
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043F\u043E\u0437\u0436\u0435 \u043D\u0430\u0437\u0432\u0430\u043B
    \u0438 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u041B\u0435\u043E\u043D\u0430\u0440\u0434 \u042D\u0439\u043B\u0435\u0440 . 
    ### \U0001F4D6 \xAB\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0439\xBB
    \u2014 \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434, \u0443\u0432\u0438\u0434\u0435\u0432\u0448\u0438\u0439
    \u0441\u0432\u0435\u0442 \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 
    \u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434 \u0432\u0441\u0435\u0439
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438, \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439 **\xABArs
    Conjectandi\xBB (\xAB\u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0439\xBB)**
    , \u043D\u0435 \u0431\u044B\u043B\u0430 \u0438\u0437\u0434\u0430\u043D\u0430
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u0443\u0447\u0435\u043D\u043E\u0433\u043E.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430
    \u0435\u0433\u043E \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u043A\u043E\u043C
    **\u041D\u0438\u043A\u043E\u043B\u0430\u0435\u043C \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438**
    \u0432 1713 \u0433\u043E\u0434\u0443, \u0447\u0435\u0440\u0435\u0437 \u0432\u043E\u0441\u0435\u043C\u044C
    \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    . \u0412 \u044D\u0442\u043E\u0439 \u043A\u043D\u0438\u0433\u0435 \u043E\u043D,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u043F\u0435\u0440\u0432\u044B\u0439
    \u0432\u0430\u0440\u0438\u0430\u043D\u0442 **\u0437\u0430\u043A\u043E\u043D\u0430
    \u0431\u043E\u043B\u044C\u0448\u0438\u0445 \u0447\u0438\u0441\u0435\u043B** \u2014
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u0441\u0430\u043C \u0441 \u0433\u043E\u0440\u0434\u043E\u0441\u0442\u044C\u044E
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0441\u0432\u043E\u0435\u0439 \xAB\u0417\u043E\u043B\u043E\u0442\u043E\u0439
    \u0442\u0435\u043E\u0440\u0435\u043C\u043E\u0439\xBB .  ### \U0001F4DA \u0421\u0430\u043C\u043E\u0443\u0447\u043A\u0430
    \u0438 \u043F\u043E\u043B\u0438\u0433\u043B\u043E\u0442  \u042F\u043A\u043E\u0431
    \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438 \u2014 \u044F\u0440\u043A\u0438\u0439
    \u043F\u0440\u0438\u043C\u0435\u0440 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0448\u0435\u043B \u043D\u0430\u043F\u0435\u0440\u0435\u043A\u043E\u0440
    \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u043C \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u044F\u043C.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446 \u0433\u043E\u0442\u043E\u0432\u0438\u043B
    \u0435\u0433\u043E \u043A \u043A\u0430\u0440\u044C\u0435\u0440\u0435 \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0430,
    \u043D\u043E \u042F\u043A\u043E\u0431, \u0432\u043E\u043F\u0440\u0435\u043A\u0438
    \u0436\u0435\u043B\u0430\u043D\u0438\u044E \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u0439,
    \u0442\u0430\u0439\u043D\u043E \u0443\u0432\u043B\u0435\u043A\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0435\u0439, \u043E\u0441\u0432\u043E\u0438\u0432
    \u0438\u0445 \u0432 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    . \u041F\u0440\u0438 \u044D\u0442\u043E\u043C \u043E\u043D \u0431\u044B\u043B
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D:
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u043E\u043D \u043E\u0432\u043B\u0430\u0434\u0435\u043B **\u043F\u044F\u0442\u044C\u044E
    \u044F\u0437\u044B\u043A\u0430\u043C\u0438** \u2014 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u043C,
    \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u043C, \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u043C,
    \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u0438\u043C \u0438 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u043C
    \u2014 \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    .  ### \U0001F315 \u041B\u0443\u043D\u043D\u044B\u0439 \u043A\u0440\u0430\u0442\u0435\u0440
    \u0438 \u0442\u0440\u0430\u043C\u0432\u0430\u0439\u043D\u044B\u0435 \u043F\u0443\u0442\u0438 
    *   **\u041F\u0430\u043C\u044F\u0442\u044C \u043D\u0430 \u043D\u0435\u0431\u0435\u0441\u0430\u0445:**
    \u0412 \u0447\u0435\u0441\u0442\u044C \u042F\u043A\u043E\u0431\u0430 \u0438 \u0435\u0433\u043E
    \u0431\u0440\u0430\u0442\u0430 \u0418\u043E\u0433\u0430\u043D\u043D\u0430 \u043D\u0430\u0437\u0432\u0430\u043D
    **\u043A\u0440\u0430\u0442\u0435\u0440 \u043D\u0430 \u041B\u0443\u043D\u0435**
    \u2014 \u043A\u0440\u0430\u0442\u0435\u0440 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    (Bernoulli) . *   **\u041F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:** \u041A\u0440\u0438\u0432\u0430\u044F
    **\u043B\u0435\u043C\u043D\u0438\u0441\u043A\u0430\u0442\u0430 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438**,
    \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u0430\u044F \u0432 \u0435\u0433\u043E
    \u0447\u0435\u0441\u0442\u044C, \u043D\u0430\u0448\u043B\u0430 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E\u0435
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0432 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0438\u0438.
    \u0415\u0435 \u0444\u043E\u0440\u043C\u0430 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u043F\u0440\u0438 \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438
    \u0442\u0440\u0430\u043C\u0432\u0430\u0439\u043D\u044B\u0445 \u043F\u0443\u0442\u0435\u0439
    \u043D\u0430 \u0443\u0447\u0430\u0441\u0442\u043A\u0430\u0445 \u0441 \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u0430\u043C\u0438
    \u043C\u0430\u043B\u043E\u0433\u043E \u0440\u0430\u0434\u0438\u0443\u0441\u0430
    .  \u042D\u0442\u0438 \u0444\u0430\u043A\u0442\u044B \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442,
    \u0447\u0442\u043E \u042F\u043A\u043E\u0431 \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0432\u0435\u043B\u0438\u043A\u0438\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u043D\u043E
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0441 \u043F\u043E\u044D\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0443\u0448\u043E\u0439, \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C \u044E\u043C\u043E\u0440\u0430
    (\u043F\u0443\u0441\u0442\u044C \u0438 \u043D\u0435\u043F\u0440\u0435\u0434\u043D\u0430\u043C\u0435\u0440\u0435\u043D\u043D\u044B\u043C,
    \u0432 \u0441\u043B\u0443\u0447\u0430\u0435 \u0441 \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u0435\u043C)
    \u0438 \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u043C \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0435\u043C,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u043E
    \u0435\u043C\u0443 \u0432\u0438\u0434\u0435\u0442\u044C \u0441\u0432\u044F\u0437\u044C
    \u043C\u0435\u0436\u0434\u0443 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u043C\u0438
    \u0447\u0438\u0441\u043B\u0430\u043C\u0438 \u0438 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u044C\u044E."
