    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0432 \u043E\u043F\u0442\u0438\u043A\u0435
    \u0437\u0435\u0440\u043A\u0430\u043B. \u041A\u043E\u0433\u0434\u0430 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u043E\u0440\u0431\u0438\u0442\u0430 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0447\u0430\u0441\u0442\u0438\u0446\u044B \u0432 \u0437\u0430\u0434\u0430\u0447\u0435
    \u0434\u0432\u0443\u0445 \u0442\u0435\u043B \u0435\u0441\u0442\u044C \u043E\u0434\u043D\u043E
    \u0438\u0437 \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u0435\u0447\u0435\u043D\u0438\u0439,
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441 \u043A \u0434\u0430\u043D\u043D\u044B\u043C
    \u043A\u0440\u0438\u0432\u044B\u043C \u0440\u0435\u0437\u043A\u043E \u0432\u043E\u0437\u0440\u043E\u0441,
    \u0438 \u0442\u0440\u0443\u0434\u044B \u0410\u043F\u043E\u043B\u043B\u043E\u043D\u0438\u044F
    \u0431\u044B\u043B\u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0435\u043D\u044B
    \u043D\u0430 \u043D\u043E\u0432\u043E\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
