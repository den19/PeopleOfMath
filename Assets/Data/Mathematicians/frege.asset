    \u0447\u0438\u0441\u043B\u0430 \u0447\u0435\u0440\u0435\u0437 \u043A\u043B\u0430\u0441\u0441\u044B
    | \u0414\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0438 \u043E \u043F\u0440\u0438\u0440\u043E\u0434\u0435
