  achievementsRu: "\u0412\u043A\u043B\u0430\u0434 \u0413\u043E\u0442\u043B\u043E\u0431\u0430
    \u0424\u0440\u0435\u0433\u0435 \u0432 \u043D\u0430\u0443\u043A\u0443 \u0447\u0430\u0441\u0442\u043E
    \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u044E\u0442 \u043F\u043E \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u0443
    \u0441 \u0432\u043A\u043B\u0430\u0434\u043E\u043C \u0415\u0432\u043A\u043B\u0438\u0434\u0430
    \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0438\u043B\u0438
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u0432 \u0444\u0438\u0437\u0438\u043A\u0443.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0441\u043B\u0438 \u041D\u044C\u044E\u0442\u043E\u043D
    \u0438 \u0415\u0432\u043A\u043B\u0438\u0434 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u0432\u0448\u0435\u0435
    \u0437\u043D\u0430\u043D\u0438\u0435, \u0442\u043E \u0424\u0440\u0435\u0433\u0435
    **\u0441\u043E\u0437\u0434\u0430\u043B \u0437\u0430\u043D\u043E\u0432\u043E \u0446\u0435\u043B\u0443\u044E
    \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0443**
    \u2014 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043B\u043E\u0433\u0438\u043A\u0443 \u2014 \u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0441\u0440\u0430\u0437\u0443 \u0434\u043B\u044F
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439:
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u044F\u0437\u044B\u043A\u0430,
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    \u0438 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u044B\u0445
    \u043D\u0430\u0443\u043A.  \u0427\u0442\u043E\u0431\u044B \u043F\u043E\u043D\u044F\u0442\u044C
    \u0433\u043B\u0443\u0431\u0438\u043D\u0443 \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434\u0430,
    \u043D\u0443\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043D\u0430 \u043F\u044F\u0442\u044C \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u043E\u0432\u043D\u0435\u0439. \u041D\u0438\u0436\u0435 \u2014 \u0441\u0430\u043C\u043E\u0435
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0435 \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u0438\u0437 \u043D\u0438\u0445. 
    ---  ### 1. \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F \u0432 \u043B\u043E\u0433\u0438\u043A\u0435:
    \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043B\u043E\u0433\u0438\u043A\u0438
    \u043F\u0440\u0435\u0434\u0438\u043A\u0430\u0442\u043E\u0432 (\u0418\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u0439, 1879)  \u0414\u043E \u0424\u0440\u0435\u0433\u0435
    \u043B\u043E\u0433\u0438\u043A\u0430 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u043F\u043E\u0447\u0442\u0438 \u0432 \u043D\u0435\u0438\u0437\u043C\u0435\u043D\u043D\u043E\u043C
    \u0432\u0438\u0434\u0435 2000 \u043B\u0435\u0442 (\u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D
    \u0410\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u044F). \u0410\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u0435\u0432\u0430
    \u0441\u0438\u043B\u043B\u043E\u0433\u0438\u0441\u0442\u0438\u043A\u0430 \u0443\u043C\u0435\u043B\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u0441 \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u044F\u043C\u0438
    (\xAB\u0412\u0441\u0435 \u043B\u044E\u0434\u0438 \u0441\u043C\u0435\u0440\u0442\u043D\u044B\xBB),
    \u043D\u043E \u0431\u044B\u043B\u0430 \u0431\u0435\u0441\u0441\u0438\u043B\u044C\u043D\u0430
    \u043F\u0435\u0440\u0435\u0434 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F\u043C\u0438
    \u0441 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u043C\u0438 (\xAB\u0410
    \u0431\u043E\u043B\u044C\u0448\u0435 \u0412\xBB), \u0441 \u043A\u0440\u0430\u0442\u043D\u044B\u043C\u0438
    \u043A\u0432\u0430\u043D\u0442\u043E\u0440\u0430\u043C\u0438 (\xAB\u041A\u0430\u0436\u0434\u044B\u0439
    \u043B\u044E\u0431\u0438\u0442 \u043A\u043E\u0433\u043E-\u0442\u043E\xBB) \u0438\u043B\u0438
    \u0441 \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C\u0438.  **\u0427\u0442\u043E
    \u0441\u0434\u0435\u043B\u0430\u043B \u0424\u0440\u0435\u0433\u0435:**  - **\u0412\u0432\u0435\u043B
    \u043A\u0432\u0430\u043D\u0442\u043E\u0440\u044B (\u2200 \u0438 \u2203).** \u042D\u0442\u043E
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u044F
    \u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0438
    \u0438 \u0432\u0441\u0435\u043E\u0431\u0449\u043D\u043E\u0441\u0442\u0438. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0444\u0440\u0430\u0437\u0443 \xAB\u0414\u043B\u044F \u043A\u0430\u0436\u0434\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 X \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0447\u0438\u0441\u043B\u043E Y, \u0431\u043E\u043B\u044C\u0448\u0435\u0435
    X\xBB \u043C\u043E\u0436\u043D\u043E \u0431\u044B\u043B\u043E \u0437\u0430\u043F\u0438\u0441\u0430\u0442\u044C
    \u0441\u0442\u0440\u043E\u0433\u043E\u0439 \u0444\u043E\u0440\u043C\u0443\u043B\u043E\u0439.
    - **\u0421\u043E\u0437\u0434\u0430\u043B \u043F\u0440\u043E\u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0443\u044E
    \u043B\u043E\u0433\u0438\u043A\u0443** (\u043B\u043E\u0433\u0438\u043A\u0443
    \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043D\u0438\u0439) \u0441
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u044F\u043C\u0438 \u043E\u0442\u0440\u0438\u0446\u0430\u043D\u0438\u044F,
    \u0438\u043C\u043F\u043B\u0438\u043A\u0430\u0446\u0438\u0438, \u043A\u043E\u043D\u044A\u044E\u043D\u043A\u0446\u0438\u0438
    \u0438 \u0434\u0438\u0437\u044A\u044E\u043D\u043A\u0446\u0438\u0438, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u044F\u0437\u044B\u043A (\u0434\u0432\u0443\u043C\u0435\u0440\u043D\u0443\u044E
    \u0437\u0430\u043F\u0438\u0441\u044C, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B \xABBegriffsschrift\xBB \u2014
    \xAB\u0418\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u0439\xBB).
    - **\u0412\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \"\u0444\u0443\u043D\u043A\u0446\u0438\u044F\"
    \u0432 \u043B\u043E\u0433\u0438\u043A\u0443.** \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u043B\u043E\u0436\u0438\u0442\u044C
    \u043D\u0430 **\u0444\u0443\u043D\u043A\u0446\u0438\u044E** (\u0442\u043E, \u0447\u0442\u043E
    \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F \u043F\u043E\u0441\u043B\u0435
    \u0443\u0434\u0430\u043B\u0435\u043D\u0438\u044F \u0438\u043C\u0435\u043D\u0438)
    \u0438 **\u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442** (\u0438\u043C\u044F).
    \u042D\u0442\u043E \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u043E
    \u043E\u0442\u043B\u0438\u0447\u0430\u043B\u043E\u0441\u044C \u043E\u0442 \u0430\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0441\u0445\u0435\u043C\u044B \xAB\u0441\u0443\u0431\u044A\u0435\u043A\u0442-\u043F\u0440\u0435\u0434\u0438\u043A\u0430\u0442\xBB. 
    > **\u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435:**
    \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u043F\u0435\u0440\u0432\u0430\u044F
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043F\u043E\u043B\u043D\u0430\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0435\u0434\u0443\u043A\u0446\u0438\u0438, \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u0430\u044F
    \u0434\u043B\u044F \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438
    \u0432\u0441\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    *\u0411\u0435\u0437 \u044D\u0442\u043E\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043D\u0435 \u0431\u044B\u043B\u043E \u0431\u044B \u043D\u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432, \u043D\u0438 \u044F\u0437\u044B\u043A\u043E\u0432
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F,
    \u043D\u0438 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0430.*  ---  ### 2. \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438: \u041B\u043E\u0433\u0438\u0446\u0438\u0437\u043C
    \u0438 \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C
    \u0447\u0438\u0441\u0435\u043B (\u041E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438, 1884)  \u0424\u0440\u0435\u0433\u0435
    \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0432\u043E\u043F\u0440\u043E\u0441:
    *\xAB\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u0447\u0438\u0441\u043B\u043E?\xBB*
    \u0414\u043E \u043D\u0435\u0433\u043E \u041A\u0430\u043D\u0442 \u0441\u0447\u0438\u0442\u0430\u043B,
    \u0447\u0442\u043E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430
    \u0441\u0438\u043D\u0442\u0435\u0442\u0438\u0447\u043D\u0430 (\u0437\u0430\u0432\u0438\u0441\u0438\u0442
    \u043E\u0442 \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0438 \u0432\u0440\u0435\u043C\u0435\u043D\u0438),
    \u0430 \u041C\u0438\u043B\u043B\u044C \u2014 \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u2014 \u044D\u0442\u043E \u044D\u043C\u043F\u0438\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u0435 \u043E\u043F\u044B\u0442\u0430. 
    **\u0412\u043A\u043B\u0430\u0434 \u0424\u0440\u0435\u0433\u0435:**  - **\u041B\u043E\u0433\u0438\u0446\u0438\u0437\u043C
    (\u0442\u0435\u0437\u0438\u0441):** \u041E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u0432\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    (\u0432 \u043F\u0435\u0440\u0432\u0443\u044E \u043E\u0447\u0435\u0440\u0435\u0434\u044C
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430) \u2014 \u044D\u0442\u043E
    \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0443\u0442\u0430\u044F
    \u043B\u043E\u0433\u0438\u043A\u0430. \u0427\u0438\u0441\u043B\u0430 \u2014 \u044D\u0442\u043E
    \u043D\u0435 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u0432 \u0438 \u043D\u0435 \u043F\u0441\u0438\u0445\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0431\u0440\u0430\u0437\u044B \u0432 \u0433\u043E\u043B\u043E\u0432\u0435.
    - **\u041E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u0447\u0438\u0441\u043B\u0430
    \u043A\u0430\u043A \u043A\u043B\u0430\u0441\u0441\u0430 \u044D\u043A\u0432\u0438\u0432\u0430\u043B\u0435\u043D\u0442\u043D\u043E\u0441\u0442\u0438:**
    \u0424\u0440\u0435\u0433\u0435 \u0434\u0430\u043B \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435: *\u0427\u0438\u0441\u043B\u043E
    \u2014 \u044D\u0442\u043E \u043E\u0431\u044A\u0435\u043C \u043F\u043E\u043D\u044F\u0442\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0440\u0430\u0432\u043D\u043E\u043C\u043E\u0449\u043D\u043E
    \u0434\u0430\u043D\u043D\u043E\u043C\u0443 \u043F\u043E\u043D\u044F\u0442\u0438\u044E*.
    \u041F\u0440\u043E\u0449\u0435 \u0433\u043E\u0432\u043E\u0440\u044F, \u0447\u0438\u0441\u043B\u043E
    \xAB2\xBB \u2014 \u044D\u0442\u043E \u043D\u0435 \u0434\u0432\u0430 \u044F\u0431\u043B\u043E\u043A\u0430,
    \u0430 **\u043A\u043B\u0430\u0441\u0441 \u0432\u0441\u0435\u0445 \u043F\u043E\u043D\u044F\u0442\u0438\u0439**,
    \u043F\u043E\u0434 \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u0434\u043F\u0430\u0434\u0430\u0435\u0442
    \u0440\u043E\u0432\u043D\u043E \u0434\u0432\u0430 \u043E\u0431\u044A\u0435\u043A\u0442\u0430.
    \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C
    \u0447\u0438\u0441\u043B\u043E 0, 1 \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0435
    \u0447\u0438\u0441\u043B\u0430 \u0447\u0438\u0441\u0442\u043E \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438,
    \u0431\u0435\u0437 \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u044F \u043A
    \u044D\u043C\u043F\u0438\u0440\u0438\u043A\u0435. - **\u0411\u043E\u0440\u044C\u0431\u0430
    \u0441 \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0437\u043C\u043E\u043C:**
    \u0424\u0440\u0435\u0433\u0435 \u0436\u0435\u0441\u0442\u043A\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0437\u0430\u043A\u043E\u043D\u044B \u043B\u043E\u0433\u0438\u043A\u0438
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u044B
    (\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442 \u0432 \xAB\u0442\u0440\u0435\u0442\u044C\u0435\u043C
    \u043C\u0438\u0440\u0435\xBB \u2014 \u043C\u0438\u0440\u0435 \u043C\u044B\u0441\u043B\u0435\u0439),
    \u0438 \u043D\u0435 \u0437\u0430\u0432\u0438\u0441\u044F\u0442 \u043E\u0442 \u0442\u043E\u0433\u043E,
    \u043A\u0430\u043A \u0434\u0443\u043C\u0430\u0435\u0442 \u0447\u0435\u043B\u043E\u0432\u0435\u043A.
    \u042D\u0442\u043E \u0441\u043F\u0430\u0441\u043B\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043E\u0442 \u0441\u0443\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u0438\u0437\u043C\u0430. 
    > **\u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435:**
    \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u0442\u0440\u043E\u0433\u0443\u044E
    \u043E\u043D\u0442\u043E\u043B\u043E\u0433\u0438\u044E \u0447\u0438\u0441\u0435\u043B,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440
    \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u0435\u0442\u0441\u044F \u0432 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0438 \u0432\u043F\u043B\u043E\u0442\u043D\u0443\u044E
    \u043F\u043E\u0434\u043E\u0448\u0435\u043B \u043A \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u043A\u0435
    \u041F\u0435\u0430\u043D\u043E (\u0445\u043E\u0442\u044F \u0438 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0435\u0435 \u0441\u0432\u043E\u0438\u043C\u0438 \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430\u043C\u0438). 
    ---  ### 3. \u0421\u0435\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0440\u043E\u0440\u044B\u0432: \u0420\u0430\u0437\u043B\u0438\u0447\u0435\u043D\u0438\u0435
    \xAB\u0421\u043C\u044B\u0441\u043B\u0430\xBB \u0438 \xAB\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u044F\xBB
    (1892)  \u042D\u0442\u043E, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0441\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0424\u0440\u0435\u0433\u0435 \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043F\u0435\u0440\u0435\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u0440\u043E\u0432\u0430\u043B
    \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u043A\u0443 \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E
    \u044F\u0437\u044B\u043A\u0430. \u0414\u043E \u0424\u0440\u0435\u0433\u0435 \u0441\u0447\u0438\u0442\u0430\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u0441\u043C\u044B\u0441\u043B \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u2014 \u044D\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0435\u0440\u0435\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432, \u043E \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0438\u0434\u0435\u0442 \u0440\u0435\u0447\u044C.  **\u0414\u0435\u0442\u0430\u043B\u0438
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438:**  - **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    (Bedeutung)** \u2014 \u044D\u0442\u043E \u0441\u0430\u043C \u043E\u0431\u044A\u0435\u043A\u0442,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u0435. \u0414\u043B\u044F \u0438\u043C\u0435\u043D\u0438
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E \u2014
    \u044D\u0442\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0438\u043B\u0438
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442. \u0414\u043B\u044F \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u2014 \u044D\u0442\u043E \u0435\u0433\u043E \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0441\u0442\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 (\u0418\u0441\u0442\u0438\u043D\u0430
    \u0438\u043B\u0438 \u041B\u043E\u0436\u044C). - **\u0421\u043C\u044B\u0441\u043B
    (Sinn)** \u2014 \u044D\u0442\u043E *\u0441\u043F\u043E\u0441\u043E\u0431 \u0434\u0430\u043D\u043D\u043E\u0441\u0442\u0438*
    \u043E\u0431\u044A\u0435\u043A\u0442\u0430, \u0442\u0430 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u043D\u0430\u043C \u0438\u0434\u0435\u043D\u0442\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u044D\u0442\u043E\u0442 \u043E\u0431\u044A\u0435\u043A\u0442.  **\u041A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0440\u0438\u043C\u0435\u0440 \u0424\u0440\u0435\u0433\u0435:** \u0412\u043E\u0437\u044C\u043C\u0435\u043C
    \u0434\u0432\u0430 \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u044F: **\xAB\u0423\u0442\u0440\u0435\u043D\u043D\u044F\u044F
    \u0437\u0432\u0435\u0437\u0434\u0430\xBB** \u0438 **\xAB\u0412\u0435\u0447\u0435\u0440\u043D\u044F\u044F
    \u0437\u0432\u0435\u0437\u0434\u0430\xBB**. \u0418\u0445 *\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435*
    \u043E\u0434\u043D\u043E \u0438 \u0442\u043E \u0436\u0435 (\u043F\u043B\u0430\u043D\u0435\u0442\u0430
    \u0412\u0435\u043D\u0435\u0440\u0430). \u041D\u043E \u0438\u0445 *\u0441\u043C\u044B\u0441\u043B\u044B*
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u0440\u0430\u0437\u043D\u044B\u0435
    (\u043E\u0434\u0438\u043D \u0432\u0438\u0434\u0435\u043D \u0443\u0442\u0440\u043E\u043C,
    \u0434\u0440\u0443\u0433\u043E\u0439 \u0432\u0435\u0447\u0435\u0440\u043E\u043C).
    \u041F\u043E\u044D\u0442\u043E\u043C\u0443 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    *\xAB\u0423\u0442\u0440\u0435\u043D\u043D\u044F\u044F \u0437\u0432\u0435\u0437\u0434\u0430
    = \u0412\u0435\u0447\u0435\u0440\u043D\u044F\u044F \u0437\u0432\u0435\u0437\u0434\u0430\xBB*
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\u043C
    (\u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430), \u0430 \u043D\u0435
    \u043F\u0443\u0441\u0442\u043E\u0439 \u0442\u0430\u0432\u0442\u043E\u043B\u043E\u0433\u0438\u0435\u0439
    *\xAB\u0423\u0442\u0440\u0435\u043D\u043D\u044F\u044F \u0437\u0432\u0435\u0437\u0434\u0430
    = \u0423\u0442\u0440\u0435\u043D\u043D\u044F\u044F \u0437\u0432\u0435\u0437\u0434\u0430\xBB*. 
    **\u0412 \u0447\u0435\u043C \u0435\u0433\u043E \u043F\u0440\u043E\u0440\u044B\u0432:** 
    - \u0412\u0432\u0435\u043B \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043A\u043E\u043D\u0442\u0435\u043A\u0441\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438:
    \u0441\u043B\u043E\u0432\u043E \u0438\u043C\u0435\u0435\u0442 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0432 \u043A\u043E\u043D\u0442\u0435\u043A\u0441\u0442\u0435
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F. - \u0421\u043E\u0437\u0434\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E **\u043A\u043E\u0441\u0432\u0435\u043D\u043D\u043E\u0439
    \u0440\u0435\u0447\u0438**. \u0415\u0441\u043B\u0438 \u043C\u044B \u0433\u043E\u0432\u043E\u0440\u0438\u043C
    \xAB\u041F\u0435\u0442\u044F \u0441\u0447\u0438\u0442\u0430\u0435\u0442, \u0447\u0442\u043E
    \u0412\u0435\u043D\u0435\u0440\u0430 \u2014 \u044D\u0442\u043E \u0443\u0442\u0440\u0435\u043D\u043D\u044F\u044F
    \u0437\u0432\u0435\u0437\u0434\u0430\xBB, \u0442\u043E \u0432 \u044D\u0442\u043E\u043C
    \u043F\u0440\u0438\u0434\u0430\u0442\u043E\u0447\u043D\u043E\u043C \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u0443 \u0441\u043B\u043E\u0432 \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435: \u043E\u043D\u0438 \u043D\u0430\u0447\u0438\u043D\u0430\u044E\u0442
    \u043E\u0437\u043D\u0430\u0447\u0430\u0442\u044C \u0441\u0432\u043E\u0439 *\u0441\u043C\u044B\u0441\u043B*,
    \u0430 \u043D\u0435 \u043F\u0440\u0435\u0434\u043C\u0435\u0442. \u042D\u0442\u043E
    \u0440\u0435\u0448\u0438\u043B\u043E \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443
    \u043F\u0440\u043E\u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A (\u0437\u043D\u0430\u043D\u0438\u0439,
    \u0432\u0435\u0440\u043E\u0432\u0430\u043D\u0438\u0439, \u0436\u0435\u043B\u0430\u043D\u0438\u0439),
    \u043D\u0430\u0434 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0431\u0438\u043B\u0438\u0441\u044C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u044B.  > **\u041D\u0430\u0443\u0447\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435:** \u042D\u0442\u043E \u043E\u0441\u043D\u043E\u0432\u0430
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0435\u043C\u0430\u043D\u0442\u0438\u043A\u0438. \u0411\u0435\u0437 \u044D\u0442\u043E\u0433\u043E
    \u0440\u0430\u0437\u043B\u0438\u0447\u0435\u043D\u0438\u044F \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B
    \u0431\u044B\u043B\u0438 \u0431\u044B \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u044B\u0435
    \u044F\u0437\u044B\u043A\u0438 \u0437\u0430\u043F\u0440\u043E\u0441\u043E\u0432,
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0431\u0430\u0437\u044B
    \u0434\u0430\u043D\u043D\u044B\u0445 \u0438 \u0442\u0435\u043E\u0440\u0438\u044F
    \u0440\u0435\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0438 \u0432 \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u043A\u0435. 
    ---  ### 4. \u041F\u0440\u043E\u0440\u044B\u0432 \u0432 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u044F\u0437\u044B\u043A\u0430: \u0420\u0430\u0437\u043B\u0438\u0447\u0435\u043D\u0438\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F \u0438 \u043E\u0431\u044A\u0435\u043A\u0442\u0430,
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F \u0438 \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442 
    \u0424\u0440\u0435\u0433\u0435 \u0432\u0432\u0435\u043B \u043E\u043D\u0442\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0438\u0435\u0440\u0430\u0440\u0445\u0438\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0435:  - **\u041E\u0431\u044A\u0435\u043A\u0442**
    \u2014 \u044D\u0442\u043E \u0432\u0441\u0435, \u0447\u0442\u043E \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442\u043E\u043C
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438 \u0438 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043F\u0440\u0435\u0434\u0438\u043A\u0430\u0442\u043E\u043C
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \xAB\u0412\u0435\u043D\u0435\u0440\u0430\xBB,
    \xAB\u0447\u0438\u0441\u043B\u043E 2\xBB). - **\u041F\u043E\u043D\u044F\u0442\u0438\u0435
    (\u043A\u043E\u043D\u0446\u0435\u043F\u0442)** \u2014 \u044D\u0442\u043E \u0444\u0443\u043D\u043A\u0446\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0430\u0435\u0442
    \u043E\u0431\u044A\u0435\u043A\u0442\u044B \u0432 \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0441\u0442\u043D\u044B\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F (\u0418\u0441\u0442\u0438\u043D\u0430/\u041B\u043E\u0436\u044C).
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \xAB... \u0435\u0441\u0442\u044C
    \u043F\u043B\u0430\u043D\u0435\u0442\u0430\xBB \u2014 \u044D\u0442\u043E \u043F\u043E\u043D\u044F\u0442\u0438\u0435.
    - **\u0424\u0443\u043D\u043A\u0446\u0438\u044F \u043F\u0435\u0440\u0432\u043E\u0433\u043E
    \u0443\u0440\u043E\u0432\u043D\u044F** \u2014 \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
    \u043A \u043E\u0431\u044A\u0435\u043A\u0442\u0430\u043C. - **\u0424\u0443\u043D\u043A\u0446\u0438\u044F
    \u0432\u0442\u043E\u0440\u043E\u0433\u043E \u0443\u0440\u043E\u0432\u043D\u044F**
    \u2014 \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F \u043A
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C \u043F\u0435\u0440\u0432\u043E\u0433\u043E
    \u0443\u0440\u043E\u0432\u043D\u044F (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043A\u0432\u0430\u043D\u0442\u043E\u0440 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \xAB\u2203x\xBB \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
    \u043A \u043F\u043E\u043D\u044F\u0442\u0438\u044E \xABx \u0435\u0441\u0442\u044C
    \u043F\u043B\u0430\u043D\u0435\u0442\u0430\xBB).  **\u042D\u0442\u043E \u0438\u0437\u0431\u0430\u0432\u0438\u043B\u043E
    \u043B\u043E\u0433\u0438\u043A\u0443 \u043E\u0442 \u043F\u0443\u0442\u0430\u043D\u0438\u0446\u044B:**
    \u0414\u043E \u0424\u0440\u0435\u0433\u0435 \u043C\u043D\u043E\u0433\u0438\u0435
    \u043F\u0443\u0442\u0430\u043B\u0438 \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E
    \u043E\u0431\u044A\u0435\u043A\u0442\u0430 (\u043A\u0430\u043A \xAB\u0431\u044B\u0442\u044C
    \u043B\u043E\u0448\u0430\u0434\u044C\u044E\xBB) \u0441 \u0441\u0430\u043C\u0438\u043C
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u043C. \u0424\u0440\u0435\u0433\u0435
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u044D\u0442\u043E
    \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u043E\u0448\u0438\u0431\u043A\u0438, \u0438 \u0438\u0445 \u0441\u043C\u0435\u0448\u0435\u043D\u0438\u0435
    \u0432\u0435\u0434\u0435\u0442 \u043A \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043C. 
    ---  ### 5. \u041F\u043E\u043F\u044B\u0442\u043A\u0430 \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \xAB\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441
    \u0420\u0430\u0441\u0441\u0435\u043B\u0430\xBB (1893\u20131903)  \u0412 \u0434\u0432\u0443\u0445\u0442\u043E\u043C\u043D\u0438\u043A\u0435
    \xAB\u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0437\u0430\u043A\u043E\u043D\u044B
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\xBB \u0424\u0440\u0435\u0433\u0435
    \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0443\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443,
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043F\u043E \u043F\u0440\u0430\u0432\u0438\u043B\u0430\u043C
    \u0432\u044B\u0432\u043E\u0434\u0430 \u043C\u043E\u0436\u043D\u043E \u0431\u044B\u043B\u043E
    \u0431\u044B \u0434\u0435\u0434\u0443\u0446\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0432\u0441\u044E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0443. 
    **\u0415\u0433\u043E \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0435
    \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0432 \u044D\u0442\u043E\u043C \u0442\u0440\u0443\u0434\u0435:**  - \u0421\u043E\u0437\u0434\u0430\u043B
    **\u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u043A\u0443 \u043E\u0431\u044A\u0435\u043C\u0430
    \u043F\u043E\u043D\u044F\u0442\u0438\u0439** (\u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432). - \u0412\u0432\u0435\u043B
    \u043F\u0440\u0430\u0432\u0438\u043B\u043E, \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0435\u0435
    \u043F\u043E \u043B\u044E\u0431\u043E\u0439 \u0444\u043E\u0440\u043C\u0443\u043B\u0435
    \u0441\u0442\u0440\u043E\u0438\u0442\u044C \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432, \u0435\u0439 \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u044F\u044E\u0449\u0438\u0445
    (\u043D\u0435\u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u043D\u0430\u044F
    \u0441\u0445\u0435\u043C\u0430 \u0432\u044B\u0434\u0435\u043B\u0435\u043D\u0438\u044F). 
    **\u0422\u0440\u0430\u0433\u0435\u0434\u0438\u044F \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434:**  \u041A\u043E\u0433\u0434\u0430 \u0420\u0430\u0441\u0441\u0435\u043B
    \u043F\u0440\u0438\u0441\u043B\u0430\u043B \u0435\u043C\u0443 \u043F\u0438\u0441\u044C\u043C\u043E
    \u0441 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u043E\u043C (\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043B\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0432\u0441\u0435\u0445
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432, \u043D\u0435 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0438\u0445
    \u0441\u0430\u043C\u0438\u0445 \u0441\u0435\u0431\u044F?), \u0424\u0440\u0435\u0433\u0435
    \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u0435\u0433\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u0430
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u0430.
    \u041E\u0434\u043D\u0430\u043A\u043E **\u044D\u0442\u043E \u043F\u043E\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0441\u0442\u0430\u043B\u043E \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C
    \u0432\u043A\u043B\u0430\u0434\u043E\u043C** \u0432 \u043D\u0430\u0443\u043A\u0443: 
    - \u0424\u0440\u0435\u0433\u0435 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E,
    \u0447\u0435\u0441\u0442\u043D\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u043B
    \u043E\u0448\u0438\u0431\u043A\u0443 \u0432 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u043A\u043E \u0432\u0442\u043E\u0440\u043E\u043C\u0443 \u0442\u043E\u043C\u0443,
    \u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043E\u0431\u0440\u0430\u0437\u0446\u043E\u043C
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u044D\u0442\u0438\u043A\u0438. -
    \u0415\u0433\u043E \u043D\u0435\u0443\u0434\u0430\u0447\u0430 \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E
    \u043F\u0440\u0438\u0432\u0435\u043B\u0430 \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    **\u0442\u0435\u043E\u0440\u0438\u0438 \u0442\u0438\u043F\u043E\u0432 \u0420\u0430\u0441\u0441\u0435\u043B\u0430**
    \u0438, \u043F\u043E\u0437\u0436\u0435, \u043A **\u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432
    \u0426\u0435\u0440\u043C\u0435\u043B\u043E-\u0424\u0440\u0435\u043D\u043A\u0435\u043B\u044F
    (ZF)**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u043F\u0430\u0441\u043B\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u043E\u0442 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u043E\u0432.
    - \u041E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043C\u0435\u0442\u043E\u0434\u043E\u043B\u043E\u0433\u0438\u044E
    \u043C\u0435\u0442\u0430\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u2014 \u043D\u0430\u0443\u043A\u0443 \u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u0445,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043F\u043E\u0437\u0436\u0435 \u0440\u0430\u0437\u0432\u0438\u043B
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442.  ---  ### 6. \u0421\u043A\u0440\u044B\u0442\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434: \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043D\u0438\u0439
    \u0438 \u0438\u043C\u043F\u043B\u0438\u043A\u0430\u0442\u0443\u0440\u044B  \u0412
    \u0441\u0432\u043E\u0438\u0445 \u0440\u0430\u0431\u043E\u0442\u0430\u0445 \u0424\u0440\u0435\u0433\u0435
    \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0441\u043E\u0437\u0434\u0430\u043B
    \u043F\u0435\u0440\u0432\u0443\u044E \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0434\u043B\u044F **\u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438** (\u043E\u043D \u043D\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0437\u0430\u043A\u043E\u043D \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u043D\u043E\u0433\u043E
    \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E \u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0432\u044B\u0432\u043E\u0434\u0430\u0445, \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044F,
    \u0447\u0442\u043E \u043C\u043E\u0436\u043D\u043E \u043E\u0431\u043E\u0439\u0442\u0438\u0441\u044C
    \u0431\u0435\u0437 \u043D\u0435\u0433\u043E, \u0447\u0435\u043C \u043F\u043E\u0437\u0436\u0435
    \u0432\u043E\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u0411\u0440\u0430\u0443\u044D\u0440 \u0438 \u0413\u0435\u0439\u0442\u0438\u043D\u0433). 
    \u0422\u0430\u043A\u0436\u0435 \u043E\u043D \u0447\u0435\u0442\u043A\u043E \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F **\u043A\u043E\u043C\u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438**
    (\u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0424\u0440\u0435\u0433\u0435):
    *\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0446\u0435\u043B\u043E\u0433\u043E
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u0435\u0439 \u043E\u0442 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439
    \u0435\u0433\u043E \u0447\u0430\u0441\u0442\u0435\u0439*. \u042D\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u043C
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u043E\u043C \u0433\u0435\u043D\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u043A\u0438 \u041D\u043E\u0430\u043C\u0430
    \u0425\u043E\u043C\u0441\u043A\u043E\u0433\u043E \u0438 \u0432\u0441\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u043E\u0439
    \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0438 \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430 (NLP).  ---  ### 7. \u0412\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 Computer Science (\u0418\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0443) 
    \u0427\u0430\u0441\u0442\u043E \u0437\u0430\u0431\u044B\u0432\u0430\u044E\u0442,
    \u0447\u0442\u043E \u0424\u0440\u0435\u0433\u0435 \u2014 \u043A\u0440\u0435\u0441\u0442\u043D\u044B\u0439
    \u043E\u0442\u0435\u0446 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F: 
    - **\u041B\u044F\u043C\u0431\u0434\u0430-\u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435**
    \u0427\u0435\u0440\u0447\u0430 \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E
    \u0432\u044B\u0440\u043E\u0441\u043B\u043E \u0438\u0437 \u0444\u0440\u0435\u0433\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u0439.
    - \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435 \u044F\u0437\u044B\u043A\u0438
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    (Haskell, Lisp, Prolog) \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442
    \u043B\u043E\u0433\u0438\u043A\u0443 \u043F\u0440\u0435\u0434\u0438\u043A\u0430\u0442\u043E\u0432
    \u0424\u0440\u0435\u0433\u0435. - **\u0421\u0438\u0441\u0442\u0435\u043C\u044B
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0442\u0435\u043E\u0440\u0435\u043C** (Coq, Agda) \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442
    \u0438\u043C\u0435\u043D\u043D\u043E \u0444\u0440\u0435\u0433\u0435\u0432\u0441\u043A\u0438\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434 \u043A \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432 \u0447\u0435\u0440\u0435\u0437
    \u0442\u0438\u043F\u044B \u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u0438. 
    ---  ### \u0420\u0435\u0437\u044E\u043C\u0438\u0440\u0443\u044E\u0449\u0430\u044F
    \u0442\u0430\u0431\u043B\u0438\u0446\u0430 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439
