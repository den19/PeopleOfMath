    | | **\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F** | \u041E\u0442\u043A\u0430\u0437
    \u043E\u0442 \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0437\u043C\u0430,
    \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C
    \u0438\u0441\u0442\u0438\u043D\u044B | \u041E\u0441\u043D\u043E\u0432\u0430 \u0432\u0441\u0435\u0433\u043E
    \u0430\u043D\u0433\u043B\u043E-\u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0433\u043E \u043C\u0435\u0439\u043D\u0441\u0442\u0440\u0438\u043C\u0430
    XX \u0432\u0435\u043A\u0430 |  **\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0438\u0442\u043E\u0433:**
    \u0424\u0440\u0435\u0433\u0435 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0444\u043E\u0440\u043C\u0443\u043B. \u041E\u043D \u0438\u0437\u043C\u0435\u043D\u0438\u043B
    **\u0443\u0433\u043E\u043B \u0437\u0440\u0435\u043D\u0438\u044F** \u043D\u0430
    \u043D\u0430\u0443\u043A\u0443. \u0414\u043E \u043D\u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0434\u0443\u043C\u0430\u043B\u0438 \u043E \u0447\u0438\u0441\u043B\u0430\u0445,
    \u0430 \u043B\u043E\u0433\u0438\u043A\u0438 \u2014 \u043E \u0441\u0438\u043B\u043B\u043E\u0433\u0438\u0437\u043C\u0430\u0445.
    \u041F\u043E\u0441\u043B\u0435 \u0424\u0440\u0435\u0433\u0435 \u0441\u0442\u0430\u043B\u043E
    \u044F\u0441\u043D\u043E: **\u044F\u0437\u044B\u043A \u2014 \u044D\u0442\u043E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u043E
    \u043E\u0431\u0449\u0435\u043D\u0438\u044F, \u044D\u0442\u043E \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435**,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043C\u043E\u0436\u043D\u043E \u0430\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C\u044E. \u0418\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0441\u0434\u0435\u043B\u0430\u043B\u043E
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0439 \u044D\u0440\u0443 \u0446\u0438\u0444\u0440\u043E\u0432\u044B\u0445
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0439."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0413\u043E\u0442\u043B\u043E\u0431\u0430 \u0424\u0440\u0435\u0433\u0435, \u0432
    \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044F, \u0431\u044B\u043B\u0430 \u043E\u043A\u0443\u0442\u0430\u043D\u0430
    \u0442\u0438\u0448\u0438\u043D\u043E\u0439 \u0438 \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u043E\u043C.
    \u0421\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C \u043E\u0447\u0435\u043D\u044C
    \u043C\u0430\u043B\u043E \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u0439, \u043D\u043E
    \u0438\u0437 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0445 \u0444\u0430\u043A\u0442\u043E\u0432
    \u0432\u044B\u0440\u0438\u0441\u043E\u0432\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u043A\u0430\u0440\u0442\u0438\u043D\u0430
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439,
    \u0441\u043E\u0437\u0434\u0430\u0432 \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0439
    \u044F\u0437\u044B\u043A \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u0441\u0442\u0440\u043E\u0433\u0438\u0445 \u0437\u0430\u043A\u043E\u043D\u043E\u0432
    \u043C\u044B\u0441\u043B\u0438, \u0432 \u0441\u0432\u043E\u0435\u0439 \u0447\u0430\u0441\u0442\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F
    \u0441 \u0447\u0435\u0440\u0435\u0434\u043E\u0439 \u0442\u044F\u0436\u0435\u043B\u044B\u0445
    \u0443\u0442\u0440\u0430\u0442.  \u0412\u043E\u0442 \u0447\u0442\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E.  ### \U0001F3E0 \u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u0441\u0435\u043C\u044C\u044F \u0424\u0440\u0435\u0433\u0435
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 8 \u043D\u043E\u044F\u0431\u0440\u044F
    1848 \u0433\u043E\u0434\u0430 \u0432 \u0441\u0435\u043C\u044C\u0435 \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0445
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439. \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    **\u041A\u0430\u0440\u043B \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440
    \u0424\u0440\u0435\u0433\u0435**, \u0438 \u043C\u0430\u0442\u044C, **\u0410\u0432\u0433\u0443\u0441\u0442\u0430
    \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u0438\u043D\u0430 \u0421\u043E\u0444\u0438\u044F
    \u0424\u0440\u0435\u0433\u0435**, \u0432\u043C\u0435\u0441\u0442\u0435 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u043B\u0438
    \u0447\u0430\u0441\u0442\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u043E\u0439
    \u0434\u043B\u044F \u0434\u0435\u0432\u043E\u0447\u0435\u043A \u0432 \u0412\u0438\u0441\u043C\u0430\u0440\u0435.
    \u041E\u0442\u0435\u0446 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 1866 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u0413\u043E\u0442\u043B\u043E\u0431\u0443
    \u0431\u044B\u043B\u043E 18 \u043B\u0435\u0442, \u0430 \u043C\u0430\u0442\u044C
    \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u043B\u0430 \u0448\u043A\u043E\u043B\u0443
    \u0438 \u0443\u043C\u0435\u0440\u043B\u0430 \u0432 1898 \u0433\u043E\u0434\u0443.
    \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u0447\u0442\u043E \u0424\u0440\u0435\u0433\u0435
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0441\u043A\u043E\u0435
    \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0435.  ### \U0001F494
    \u0411\u0440\u0430\u043A \u0438 \u0443\u0442\u0440\u0430\u0442\u0430 \u0434\u0435\u0442\u0435\u0439
    14 \u043C\u0430\u0440\u0442\u0430 1887 \u0433\u043E\u0434\u0430 \u0424\u0440\u0435\u0433\u0435
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u041C\u0430\u0440\u0433\u0430\u0440\u0435\u0442\u0435
    \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0435 \u0421\u043E\u0444\u0438\u0438
    \u0410\u043D\u043D\u0435 \u041B\u0438\u0437\u0435\u0431\u0435\u0440\u0433** (1856\u20131904). 
    \u042D\u0442\u043E\u0442 \u0441\u043E\u044E\u0437 \u0431\u044B\u043B \u043E\u043C\u0440\u0430\u0447\u0435\u043D
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0431\u043E\u043B\u044C\u0448\u0438\u0445
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0439 \u0432 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438:
    **\u0432\u0441\u0435 \u0438\u0445 \u0434\u0435\u0442\u0438 \u0443\u043C\u0438\u0440\u0430\u043B\u0438
    \u0432 \u043C\u043B\u0430\u0434\u0435\u043D\u0447\u0435\u0441\u0442\u0432\u0435
    \u0438\u043B\u0438 \u0432 \u043E\u0447\u0435\u043D\u044C \u0440\u0430\u043D\u043D\u0435\u043C
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435**. \u0422\u043E\u0447\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E \u0434\u0435\u0442\u0435\u0439 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E;
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438 \u0433\u043E\u0432\u043E\u0440\u044F\u0442
    \u043E \xAB\u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445\xBB \u0438\u043B\u0438
    \u043A\u0430\u043A \u043C\u0438\u043D\u0438\u043C\u0443\u043C \u043E \u0434\u0432\u043E\u0438\u0445,
    \u043D\u043E \u0441\u0443\u0434\u044C\u0431\u0430 \u0440\u0430\u0441\u043F\u043E\u0440\u044F\u0434\u0438\u043B\u0430\u0441\u044C
    \u0442\u0430\u043A, \u0447\u0442\u043E \u043D\u0438\u043A\u0442\u043E \u0438\u0437
    \u043D\u0438\u0445 \u043D\u0435 \u043F\u0435\u0440\u0435\u0436\u0438\u043B \u0441\u0432\u043E\u0438\u0445
    \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u0439.  ### \U0001F468\u200D\U0001F466
    \u041F\u0440\u0438\u0435\u043C\u043D\u044B\u0439 \u0441\u044B\u043D \u0412 1905
    \u0433\u043E\u0434\u0443, \u0447\u0435\u0440\u0435\u0437 \u0433\u043E\u0434 \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0436\u0435\u043D\u044B, \u0424\u0440\u0435\u0433\u0435
    \u0432\u0437\u044F\u043B \u043D\u0430 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0435
    \u043F\u0440\u0438\u0435\u043C\u043D\u043E\u0433\u043E \u0441\u044B\u043D\u0430,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043D\u0430\u0437\u0432\u0430\u043B\u0438
    **\u0410\u043B\u044C\u0444\u0440\u0435\u0434**. \u0412\u043E\u0441\u043F\u0438\u0442\u044B\u0432\u0430\u043B
    \u043E\u043D \u0435\u0433\u043E \u043E\u0434\u0438\u043D. \u0410\u043B\u044C\u0444\u0440\u0435\u0434
    \u0432\u044B\u0440\u043E\u0441, \u0441\u0442\u0430\u043B \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C,
    \u043D\u043E \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u0442\u0430\u043A\u0436\u0435
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u043E\u0431\u043E\u0440\u0432\u0430\u043B\u0430\u0441\u044C
    \u2014 \u043E\u043D \u043F\u043E\u0433\u0438\u0431 \u0432 1945 \u0433\u043E\u0434\u0443
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0412\u0442\u043E\u0440\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B.  \u0418\u043C\u0435\u043D\u043D\u043E
    \u0410\u043B\u044C\u0444\u0440\u0435\u0434\u0443 \u0424\u0440\u0435\u0433\u0435
    \u043F\u0435\u0440\u0435\u0434\u0430\u043B \u0441\u0432\u043E\u0438 \u043D\u0435\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0438, \u0441\u043E\u043F\u0440\u043E\u0432\u043E\u0434\u0438\u0432
    \u0438\u0445 \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u043B\u043E\u0432\u0430\u043C\u0438: *\xAB\u042F \u0432\u0435\u0440\u044E,
    \u0437\u0434\u0435\u0441\u044C \u0435\u0441\u0442\u044C \u0432\u0435\u0449\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043A\u043E\u0433\u0434\u0430-\u043D\u0438\u0431\u0443\u0434\u044C
    \u0431\u0443\u0434\u0443\u0442 \u0446\u0435\u043D\u0438\u0442\u044C\u0441\u044F
    \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u0432\u044B\u0448\u0435, \u0447\u0435\u043C
    \u0441\u0435\u0439\u0447\u0430\u0441. \u041F\u043E\u0437\u0430\u0431\u043E\u0442\u044C\u0442\u0435\u0441\u044C,
    \u0447\u0442\u043E\u0431\u044B \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435
    \u043F\u0440\u043E\u043F\u0430\u043B\u043E\xBB*. \u042D\u0442\u0438 \u0431\u0443\u043C\u0430\u0433\u0438,
    \u043A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E, \u0431\u044B\u043B\u0438
    \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u044B \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0431\u043E\u043C\u0431\u0430\u0440\u0434\u0438\u0440\u043E\u0432\u043A\u0438
    \u041C\u044E\u043D\u0441\u0442\u0435\u0440\u0430 \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0432\u043E\u0439\u043D\u044B.  ### \U0001F9D1\u200D\U0001F3EB \u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0421\u0442\u0443\u0434\u0435\u043D\u0442\u044B \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438
    \u0424\u0440\u0435\u0433\u0435 \u043A\u0430\u043A \u043A\u0440\u0430\u0439\u043D\u0435
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0433\u043E, \u0438\u043D\u0442\u0440\u043E\u0432\u0435\u0440\u0442\u043D\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430. \u041D\u0430 \u043B\u0435\u043A\u0446\u0438\u044F\u0445
    \u043E\u043D \u0440\u0435\u0434\u043A\u043E \u0432\u0441\u0442\u0443\u043F\u0430\u043B
    \u0432 \u0434\u0438\u0430\u043B\u043E\u0433, \u0447\u0430\u0441\u0442\u043E \u0441\u0442\u043E\u044F\u043B
    \u043B\u0438\u0446\u043E\u043C \u043A \u0434\u043E\u0441\u043A\u0435, \u0445\u043E\u0442\u044F
    \u0438\u043D\u043E\u0433\u0434\u0430 \u043C\u043E\u0433 \u0431\u044B\u0442\u044C
    \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u044B\u043C \u0438 \u0434\u0430\u0436\u0435
    \u044F\u0437\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E-\u0441\u0430\u0440\u043A\u0430\u0441\u0442\u0438\u0447\u043D\u044B\u043C. 
    \u0412 1918 \u0433\u043E\u0434\u0443 \u043E\u043D \u0432\u044B\u0448\u0435\u043B
    \u043D\u0430 \u043F\u0435\u043D\u0441\u0438\u044E \u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u0411\u0430\u0434-\u041A\u043B\u0430\u0439\u043D\u0435\u043D, \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E
    \u043E\u0442 \u0441\u0432\u043E\u0435\u0433\u043E \u0440\u043E\u0434\u043D\u043E\u0433\u043E
    \u0412\u0438\u0441\u043C\u0430\u0440\u0430. \u041E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    26 \u0438\u044E\u043B\u044F 1925 \u0433\u043E\u0434\u0430 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    76 \u043B\u0435\u0442. \u0415\u0433\u043E \u0432\u0434\u043E\u0432\u0430 \u0438
    \u0434\u0435\u0442\u0438 \u043F\u0435\u0440\u0435\u0436\u0438\u043B\u0438 \u0435\u0433\u043E
    \u043D\u0430 \u043C\u043D\u043E\u0433\u043E \u043B\u0435\u0442.  \u041D\u0430\u0443\u0447\u043D\u044B\u0439
    \u043C\u0438\u0440 \u043F\u0440\u0438\u0437\u043D\u0430\u043B \u0435\u0433\u043E
    \u0433\u0435\u043D\u0438\u0439 \u043B\u0438\u0448\u044C \u0441\u043F\u0443\u0441\u0442\u044F
    \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F, \u0438 \u0424\u0440\u0435\u0433\u0435
    \u043D\u0435 \u0434\u043E\u0436\u0438\u043B \u0434\u043E \u043C\u043E\u043C\u0435\u043D\u0442\u0430,
    \u043A\u043E\u0433\u0434\u0430 \u0443\u0432\u0438\u0434\u0435\u043B \u0442\u0440\u0438\u0443\u043C\u0444
    \u0441\u0432\u043E\u0438\u0445 \u0438\u0434\u0435\u0439."
  personalLifeEn: 
  shortBioRu: "**\u0413\u043E\u0442\u043B\u043E\u0431 \u0424\u0440\u0435\u0433\u0435**
    (\u043F\u043E\u043B\u043D\u043E\u0435 \u0438\u043C\u044F \u2014 \u0424\u0440\u0438\u0434\u0440\u0438\u0445
    \u041B\u044E\u0434\u0432\u0438\u0433 \u0413\u043E\u0442\u043B\u043E\u0431 \u0424\u0440\u0435\u0433\u0435)
    \u2014 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043B\u043E\u0433\u0438\u043A \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0442\u0446\u043E\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438 \u0438 \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A\u043E\u0432
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0438 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u043B\u043E\u0433\u0438\u043A\u0435, \u0441\u0440\u0430\u0432\u043D\u0438\u043C\u0443\u044E
    \u0441 \u0432\u043A\u043B\u0430\u0434\u043E\u043C \u0410\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u044F,
    \u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442
    \u0434\u043B\u044F \u0431\u043E\u043B\u044C\u0448\u0435\u0439 \u0447\u0430\u0441\u0442\u0438
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u044F\u0437\u044B\u043A\u0430
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 XX \u0432\u0435\u043A\u0430. 
    \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u0435\u0433\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u0438 \u043E\u0431\u0437\u043E\u0440 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044F.  ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    (1848\u20131874)  - **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0441\u0435\u043C\u044C\u044F:** \u0424\u0440\u0435\u0433\u0435 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    8 \u043D\u043E\u044F\u0431\u0440\u044F 1848 \u0433\u043E\u0434\u0430 \u0432 \u0433\u043E\u0440\u043E\u0434\u0435
    \u0412\u0438\u0441\u043C\u0430\u0440 (\u041C\u0435\u043A\u043B\u0435\u043D\u0431\u0443\u0440\u0433-\u0428\u0432\u0435\u0440\u0438\u043D,
    \u043D\u044B\u043D\u0435 \u0437\u0435\u043C\u043B\u044F \u041C\u0435\u043A\u043B\u0435\u043D\u0431\u0443\u0440\u0433-\u041F\u0435\u0440\u0435\u0434\u043D\u044F\u044F
    \u041F\u043E\u043C\u0435\u0440\u0430\u043D\u0438\u044F, \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044F).
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u041A\u0430\u0440\u043B \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440
    \u0424\u0440\u0435\u0433\u0435 (1809\u20131866), \u0431\u044B\u043B \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u0447\u0430\u0441\u0442\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u044B \u0434\u043B\u044F
    \u0434\u0435\u0432\u043E\u0447\u0435\u043A. \u041C\u0430\u0442\u044C, \u0410\u0432\u0433\u0443\u0441\u0442\u0430
    \u0424\u0440\u0435\u0433\u0435 (\u0443\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u0430\u044F
    \u0411\u044F\u043B\u043E\u0431\u043B\u043E\u0446\u043A\u0430\u044F), \u0442\u0430\u043A\u0436\u0435
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430 \u0432 \u044D\u0442\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 \u0438 \u0441\u0442\u0430\u043B\u0430 \u0435\u0435
    \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u043C\u0443\u0436\u0430. \u041D\u0435\u043C\u043D\u043E\u0433\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043E \u0435\u0433\u043E \u0431\u0440\u0430\u0442\u0435
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0435 \u0412\u043E\u043B\u044C\u0434\u0435\u043C\u0430\u0440\u0435
    \u0424\u0440\u0435\u0433\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0430\u043B
    \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u043E\u043C. \u0421\u0430\u043C \u0424\u0440\u0435\u0433\u0435,
    \u043F\u043E-\u0432\u0438\u0434\u0438\u043C\u043E\u043C\u0443, \u0431\u044B\u043B
    \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0435\u043D \u043D\u0430
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u0435. - **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:**
    \u0412 1869 \u0433\u043E\u0434\u0443 \u0424\u0440\u0435\u0433\u0435 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0419\u0435\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u0433\u0434\u0435 \u0438\u0437\u0443\u0447\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u0444\u0438\u0437\u0438\u043A\u0443, \u0445\u0438\u043C\u0438\u044E \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E
    (\u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 \u0441\u043B\u0443\u0448\u0430\u043B
    \u043A\u0443\u0440\u0441 \u041A\u0430\u043D\u0442\u0430 \u0443 \u041A\u0443\u043D\u043E
    \u0424\u0438\u0448\u0435\u0440\u0430). \u0427\u0435\u0440\u0435\u0437 \u0434\u0432\u0430
    \u0433\u043E\u0434\u0430 \u043E\u043D \u043F\u0435\u0440\u0435\u0432\u0435\u043B\u0441\u044F
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0446\u0435\u043D\u0442\u0440\u043E\u0432 \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    \u0412 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435 \u043E\u043D
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0444\u0438\u0437\u0438\u043A\u0438
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u0440\u0435\u043B\u0438\u0433\u0438\u0438
    (\u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0413\u0435\u0440\u043C\u0430\u043D\u0430 \u041B\u043E\u0442\u0446\u0435, \u0447\u044C\u0438
    \u0438\u0434\u0435\u0438, \u043A\u0430\u043A \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u043D\u0430 \u043D\u0435\u0433\u043E
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435).
    - **\u041F\u0435\u0440\u0432\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438:** \u0412 1873 \u0433\u043E\u0434\u0443
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435 \u0424\u0440\u0435\u0433\u0435
    \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u043F\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u043D\u0430 \u0442\u0435\u043C\u0443
    \xAB\u041E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0438
    \u043C\u043D\u0438\u043C\u044B\u0445 \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432
    \u043D\u0430 \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438\xBB (\xAB\xDCber
    eine geometrische Darstellung der imagin\xE4ren Gebilde in der Ebene\xBB). \u0412
    1874 \u0433\u043E\u0434\u0443 \u043E\u043D \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u0419\u0435\u043D\u0443, \u0433\u0434\u0435 \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u0444\u0438\u0437\u0438\u043A\u0430
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u042D\u0440\u043D\u0441\u0442\u0430
    \u0410\u0431\u0431\u0435 (\u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0430\u043B
    \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0438 \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u0435\u043C)
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0445\u0430\u0431\u0438\u043B\u0438\u0442\u0430\u0446\u0438\u043E\u043D\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u043F\u0440\u0430\u0432\u043E \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u044F
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. 
    ### \U0001F9D1\u200D\U0001F3EB \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0438 \u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C (1874\u20131925)  - **\u041A\u0430\u0440\u044C\u0435\u0440\u0430
    \u0432 \u0419\u0435\u043D\u0435:** \u041F\u043E\u0447\u0442\u0438 \u0432\u0441\u044F
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0424\u0440\u0435\u0433\u0435 \u0431\u044B\u043B\u0430
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441 \u0419\u0435\u043D\u0441\u043A\u0438\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u043E\u043C.
    \u0412 1874 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u0440\u0438\u0432\u0430\u0442-\u0434\u043E\u0446\u0435\u043D\u0442\u043E\u043C
    (\u044D\u0442\u043E \u0431\u044B\u043B\u0430 \u043D\u0435\u043E\u043F\u043B\u0430\u0447\u0438\u0432\u0430\u0435\u043C\u0430\u044F
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C, \u0438 \u043F\u0435\u0440\u0432\u044B\u0435
    \u0433\u043E\u0434\u044B \u0435\u0433\u043E \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0430
    \u043C\u0430\u0442\u044C), \u0432 1879 \u0433\u043E\u0434\u0443 \u2014 \u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C, \u0430 \u0432
    1896 \u0433\u043E\u0434\u0443 \u2014 \u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C
    \u0433\u043E\u043D\u043E\u0440\u0430\u0440-\u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    (\u043F\u043E\u0447\u0435\u0442\u043D\u044B\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C).
    \u041E\u043D \u0447\u0438\u0442\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438
    \u043F\u043E \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0430\u043C: \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0432\u044B\u0441\u0448\u0435\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0435, \u0442\u0435\u043E\u0440\u0438\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B, \u0430 \u0441 1883 \u0433\u043E\u0434\u0430 \u0442\u0430\u043A\u0436\u0435
    \u043F\u043E \u043B\u043E\u0433\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. - **\u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C:** \u0412 1887 \u0433\u043E\u0434\u0443 \u0424\u0440\u0435\u0433\u0435
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u041C\u0430\u0440\u0433\u0430\u0440\u0435\u0442\u0435
    \u041B\u0438\u0437\u0435\u0431\u0435\u0440\u0433 (1856\u20131904). \u0423 \u043D\u0438\u0445
    \u0431\u044B\u043B\u043E \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0434\u0435\u0442\u0435\u0439, \u043D\u043E, \u043A \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u043C\u0443
    \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E, \u0432\u0441\u0435 \u043E\u043D\u0438
    \u0443\u043C\u0435\u0440\u043B\u0438 \u0432 \u0440\u0430\u043D\u043D\u0435\u043C
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435. \u041F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0436\u0435\u043D\u044B \u0432 1905 \u0433\u043E\u0434\u0443
    \u0424\u0440\u0435\u0433\u0435 \u0443\u0434\u043E\u0447\u0435\u0440\u0438\u043B
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430 \u043F\u043E \u0438\u043C\u0435\u043D\u0438
    \u0410\u043B\u044C\u0444\u0440\u0435\u0434, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C.
    \u041B\u0438\u0447\u043D\u0430\u044F \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F,
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0443\u0441\u0443\u0433\u0443\u0431\u0438\u043B\u0430
    \u0435\u0433\u043E \u0438 \u0431\u0435\u0437 \u0442\u043E\u0433\u043E \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0439
    \u0438 \u043D\u0435\u043E\u0431\u0449\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440. - **\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B:** \u0412 1917 \u0433\u043E\u0434\u0443 \u0424\u0440\u0435\u0433\u0435
    \u0432\u044B\u0448\u0435\u043B \u043D\u0430 \u043F\u0435\u043D\u0441\u0438\u044E
    \u043F\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F
    \u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0411\u0430\u0434-\u041A\u043B\u0430\u0439\u043D\u0435\u043D,
    \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E \u043E\u0442 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0440\u043E\u0434\u043D\u043E\u0433\u043E \u0412\u0438\u0441\u043C\u0430\u0440\u0430.
    \u041E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 26 \u0438\u044E\u043B\u044F
    1925 \u0433\u043E\u0434\u0430 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    76 \u043B\u0435\u0442.  ### \U0001F680 \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0438 \u0442\u0440\u0443\u0434\u044B  \u0422\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0443\u0442\u044C \u0424\u0440\u0435\u0433\u0435 \u043C\u043E\u0436\u043D\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u044D\u0442\u0430\u043F\u043E\u0432, \u043A\u0430\u0436\u0434\u044B\u0439 \u0438\u0437
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043E\u0437\u043D\u0430\u043C\u0435\u043D\u043E\u0432\u0430\u043D
    \u0432\u044B\u0445\u043E\u0434\u043E\u043C \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442.  #### 1. \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043B\u043E\u0433\u0438\u043A\u0438:
    \xAB\u0418\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u0439\xBB
    (1879)  \u0412 \u0441\u0432\u043E\u0435\u0439 \u043F\u0435\u0440\u0432\u043E\u0439
    \u043A\u0440\u0443\u043F\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    \xAB**\u0418\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u0439**\xBB
    (\xABBegriffsschrift\xBB, 1879) \u0424\u0440\u0435\u0433\u0435 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432, \u043F\u043E \u0441\u0443\u0442\u0438 \u0441\u043E\u0437\u0434\u0430\u0432
    **\u043B\u043E\u0433\u0438\u043A\u0443 \u043F\u0440\u0435\u0434\u0438\u043A\u0430\u0442\u043E\u0432**.
    \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0439
    \u044F\u0437\u044B\u043A \u0434\u043B\u044F \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u043A\u043B\u044E\u0447\u0430\u043B: 
    - \u041A\u0432\u0430\u043D\u0442\u043E\u0440\u044B (\u2200 \u2014 \xAB\u0434\u043B\u044F
    \u0432\u0441\u0435\u0445\xBB, \u2203 \u2014 \xAB\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442\xBB),
    \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0430\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043D\u0438\u044F \u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432. - \u0424\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u043B \u0433\u043E\u0440\u0430\u0437\u0434\u043E
    \u0431\u043E\u043B\u0435\u0435 \u043C\u043E\u0449\u043D\u044B\u043C, \u0447\u0435\u043C
    \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u0430\u044F \u0441\u0438\u043B\u043B\u043E\u0433\u0438\u0441\u0442\u0438\u043A\u0430
    \u0410\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u044F. - \u0410\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0434\u043B\u044F \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432. 
    \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u043E\u043B\u043E\u0436\u0438\u043B\u0430
    \u043D\u0430\u0447\u0430\u043B\u043E \u043D\u043E\u0432\u043E\u0439 \u044D\u043F\u043E\u0445\u0435
    \u0432 \u043B\u043E\u0433\u0438\u043A\u0435 \u0438 \u0441\u0442\u0430\u043B\u0430
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F \u0432\u0441\u0435\u0445
    \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0445 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043E\u043A
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. 
    #### 2. \u041B\u043E\u0433\u0438\u0446\u0438\u0437\u043C \u0438 \xAB\u041E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\xBB (1884)  \u0412
    \u043A\u043D\u0438\u0433\u0435 \xAB**\u041E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438**\xBB (\xABDie Grundlagen
    der Arithmetik\xBB, 1884) \u0424\u0440\u0435\u0433\u0435 \u0438\u0437\u043B\u043E\u0436\u0438\u043B
    \u0441\u0432\u043E\u044E \u0433\u043B\u0430\u0432\u043D\u0443\u044E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0443\u044E
    \u0438\u0434\u0435\u044E \u2014 **\u043B\u043E\u0433\u0438\u0446\u0438\u0437\u043C**.
    \u041E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E
    \u0432\u0441\u0435 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u044F
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0447\u0438\u0441\u043B\u043E) \u043C\u043E\u0436\u043D\u043E \u0441\u0432\u0435\u0441\u0442\u0438
    \u043A \u0447\u0438\u0441\u0442\u043E \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F\u043C (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043F\u043E\u043D\u044F\u0442\u0438\u044E \u043A\u043B\u0430\u0441\u0441\u0430
    \u0438\u043B\u0438 \u043E\u0431\u044A\u0435\u043C\u0430 \u043F\u043E\u043D\u044F\u0442\u0438\u044F),
    \u0430 \u0437\u0430\u043A\u043E\u043D\u044B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432\u044B\u0432\u0435\u0441\u0442\u0438 \u0438\u0437 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0430\u043A\u0441\u0438\u043E\u043C. \u0412 \u044D\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    \u043E\u043D \u0442\u0430\u043A\u0436\u0435 \u044F\u0440\u043E\u0441\u0442\u043D\u043E
    \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B \u043F\u0440\u043E\u0442\u0438\u0432
    **\u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0437\u043C\u0430**
    (\u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u043B\u043E\u0433\u0438\u043A\u0438
    \u043A \u0437\u0430\u043A\u043E\u043D\u0430\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F), \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u044F
    \u043D\u0430 \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438
    \u0437\u0430\u043A\u043E\u043D\u043E\u0432 \u043B\u043E\u0433\u0438\u043A\u0438. 
    #### 3. \u0412\u0435\u0440\u0448\u0438\u043D\u0430 \u0441\u0435\u043C\u0430\u043D\u0442\u0438\u043A\u0438:
    \xAB\u041E \u0441\u043C\u044B\u0441\u043B\u0435 \u0438 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0438\xBB
    (1892)  \u0412 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0424\u0440\u0435\u0433\u0435 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0435\u0440\u0438\u044E \u0441\u0442\u0430\u0442\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0442\u0430\u043B\u0438 \u043A\u043B\u0430\u0441\u0441\u0438\u043A\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u044F\u0437\u044B\u043A\u0430.
    \u0412 \u044D\u043F\u043E\u0445\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u0442\u0430\u0442\u044C\u0435
    \xAB**\u041E \u0441\u043C\u044B\u0441\u043B\u0435 \u0438 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0438**\xBB
    (\xAB\xDCber Sinn und Bedeutung\xBB, 1892) \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435 \u0440\u0430\u0437\u043B\u0438\u0447\u0435\u043D\u0438\u0435: 
    - **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435 (Bedeutung):** \u044D\u0442\u043E
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442 (\u043E\u0431\u044A\u0435\u043A\u0442),
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u0438\u043C\u044F. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0434\u043B\u044F
    \u0438\u043C\u0435\u043D \xAB\u0423\u0442\u0440\u0435\u043D\u043D\u044F\u044F
    \u0437\u0432\u0435\u0437\u0434\u0430\xBB \u0438 \xAB\u0412\u0435\u0447\u0435\u0440\u043D\u044F\u044F
    \u0437\u0432\u0435\u0437\u0434\u0430\xBB \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u043E\u0434\u043D\u043E \u0438 \u0442\u043E \u0436\u0435 \u2014 \u043F\u043B\u0430\u043D\u0435\u0442\u0430
    \u0412\u0435\u043D\u0435\u0440\u0430. - **\u0421\u043C\u044B\u0441\u043B (Sinn):**
    \u044D\u0442\u043E \u0441\u043F\u043E\u0441\u043E\u0431, \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0438\u043C\u044F \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u043D\u0430
    \u0441\u0432\u043E\u0439 \u043E\u0431\u044A\u0435\u043A\u0442, \u0442\u0430 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0430
    \u0432 \u0438\u043C\u0435\u043D\u0438. \xAB\u0423\u0442\u0440\u0435\u043D\u043D\u044F\u044F
    \u0437\u0432\u0435\u0437\u0434\u0430\xBB \u0438 \xAB\u0412\u0435\u0447\u0435\u0440\u043D\u044F\u044F
    \u0437\u0432\u0435\u0437\u0434\u0430\xBB \u0438\u043C\u0435\u044E\u0442 \u0440\u0430\u0437\u043D\u044B\u0435
    \u0441\u043C\u044B\u0441\u043B\u044B, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F \xAB\u0423\u0442\u0440\u0435\u043D\u043D\u044F\u044F
    \u0437\u0432\u0435\u0437\u0434\u0430 \u2014 \u044D\u0442\u043E \u0412\u0435\u043D\u0435\u0440\u0430\xBB
    \u0438 \xAB\u0412\u0435\u0447\u0435\u0440\u043D\u044F\u044F \u0437\u0432\u0435\u0437\u0434\u0430
    \u2014 \u044D\u0442\u043E \u0412\u0435\u043D\u0435\u0440\u0430\xBB \u0441\u043E\u043E\u0431\u0449\u0430\u044E\u0442
    \u0440\u0430\u0437\u043D\u0443\u044E \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E. 
    \u042D\u0442\u043E \u0440\u0430\u0437\u043B\u0438\u0447\u0435\u043D\u0438\u0435
    \u0441\u0442\u0430\u043B\u043E \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C
    \u043A\u0430\u043C\u043D\u0435\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0441\u0435\u043C\u0430\u043D\u0442\u0438\u043A\u0438 \u0438 \u043E\u043A\u0430\u0437\u0430\u043B\u043E
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0411. \u0420\u0430\u0441\u0441\u0435\u043B\u0430 \u0438 \u041B.
    \u0412\u0438\u0442\u0433\u0435\u043D\u0448\u0442\u0435\u0439\u043D\u0430.  ####
    4. \xAB\u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0437\u0430\u043A\u043E\u043D\u044B
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\xBB \u0438 \u043A\u0440\u0443\u0448\u0435\u043D\u0438\u0435
    \u043D\u0430\u0434\u0435\u0436\u0434 (1893\u20131903)  \u0414\u0432\u0443\u0445\u0442\u043E\u043C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \xAB**\u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0437\u0430\u043A\u043E\u043D\u044B \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438**\xBB
    (\xABGrundgesetze der Arithmetik\xBB, \u0442. I \u2014 1893, \u0442. II \u2014
    1903) \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u043B \u0441\u0442\u0430\u0442\u044C
    \u043A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u0435\u0439 \u0432\u0441\u0435\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0424\u0440\u0435\u0433\u0435 \u2014 \u0441\u0442\u0440\u043E\u0433\u043E\u0439
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0434\u0435\u0434\u0443\u043A\u0446\u0438\u0435\u0439
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438 \u0438\u0437 \u0435\u0433\u043E
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u043A\u043E\u0433\u0434\u0430 \u0432\u0442\u043E\u0440\u043E\u0439
    \u0442\u043E\u043C \u0443\u0436\u0435 \u0433\u043E\u0442\u043E\u0432\u0438\u043B\u0441\u044F
    \u043A \u043F\u0435\u0447\u0430\u0442\u0438, \u0424\u0440\u0435\u0433\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043F\u0438\u0441\u044C\u043C\u043E \u043E\u0442 \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E
    \u0431\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    **\u0411\u0435\u0440\u0442\u0440\u0430\u043D\u0430 \u0420\u0430\u0441\u0441\u0435\u043B\u0430**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441 \u0432 \u0435\u0433\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u0435
    (\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043A\u0430\u043A **\u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441
    \u0420\u0430\u0441\u0441\u0435\u043B\u0430**). \u0420\u0430\u0441\u0441\u0435\u043B
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u0430
    \u0424\u0440\u0435\u0433\u0435, \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0430\u044F
    \u043D\u0435\u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u043D\u044B\u0439
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0434\u043B\u044F \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432 (\u043A\u043B\u0430\u0441\u0441\u043E\u0432),
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0439. 
    \u0424\u0440\u0435\u0433\u0435 \u0431\u044B\u043B \u043F\u043E\u0442\u0440\u044F\u0441\u0435\u043D.
    \u041E\u043D \u043C\u0443\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u0434\u043E\u0431\u0430\u0432\u0438\u043B \u0432 \u043A\u043E\u043D\u0435\u0446
    \u0432\u0442\u043E\u0440\u043E\u0433\u043E \u0442\u043E\u043C\u0430 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0441 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435\u043C \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430
    \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435\u043C, \u0447\u0442\u043E
    \u0435\u0433\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u043D\u0435\u0441\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u0430.
    \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0434\u043B\u044F \u043D\u0435\u0433\u043E
    \u0442\u044F\u0436\u0435\u043B\u0435\u0439\u0448\u0438\u043C \u0443\u0434\u0430\u0440\u043E\u043C,
    \u0438 \u043E\u043D \u0442\u0430\u043A \u0438 \u043D\u0435 \u0441\u043C\u043E\u0433
    \u043D\u0430\u0439\u0442\u0438 \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F. \u0415\u0433\u043E \u043F\u043E\u043F\u044B\u0442\u043A\u0430
    \u0441\u0432\u0435\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043A \u043B\u043E\u0433\u0438\u043A\u0435 \u043F\u043E\u0442\u0435\u0440\u043F\u0435\u043B\u0430
    \u043A\u0440\u0430\u0445, \u0445\u043E\u0442\u044F \u0435\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u044B
    \u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C \u0432 \u043D\u0430\u0443\u043A\u0435. 
    ### \U0001F4DA \u0412\u043B\u0438\u044F\u043D\u0438\u0435 \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u041F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u0424\u0440\u0435\u0433\u0435
    \u0431\u044B\u043B \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438
    \u0443\u0437\u043A\u043E\u0433\u043E \u043A\u0440\u0443\u0433\u0430 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u043E\u0432,
    \u0430 \u0435\u0433\u043E \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u0447\u0430\u0441\u0442\u043E \u043D\u0435
    \u043F\u043E\u043B\u0443\u0447\u0430\u043B\u0438 \u0434\u043E\u043B\u0436\u043D\u043E\u0439
    \u043E\u0446\u0435\u043D\u043A\u0438. \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E
    \u0438\u0434\u0435\u0438 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u043B\u0438\u0441\u044C
    \u0447\u0435\u0440\u0435\u0437 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432
    \u0438 \u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u0432: 
    - **\u0411\u0435\u0440\u0442\u0440\u0430\u043D \u0420\u0430\u0441\u0441\u0435\u043B
    \u0438 \u0410\u043B\u044C\u0444\u0440\u0435\u0434 \u0423\u0430\u0439\u0442\u0445\u0435\u0434:**
    \u041F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u0440\u0430\u0431\u043E\u0442\u044B \u0424\u0440\u0435\u0433\u0435 \u0438 \u0440\u0430\u0437\u0432\u0438\u043B\u0438
    \u0435\u0433\u043E \u0438\u0434\u0435\u0438 \u0432 \u0441\u0432\u043E\u0435\u043C
    \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u043C
    \u0442\u0440\u0443\u0434\u0435 \xABPrincipia Mathematica\xBB, \u043F\u044B\u0442\u0430\u044F\u0441\u044C
    \u043E\u0431\u043E\u0439\u0442\u0438 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u044B.
    - **\u041B\u044E\u0434\u0432\u0438\u0433 \u0412\u0438\u0442\u0433\u0435\u043D\u0448\u0442\u0435\u0439\u043D:**
    \u0412\u0441\u0442\u0440\u0435\u0447\u0430\u043B\u0441\u044F \u0441 \u0424\u0440\u0435\u0433\u0435
    \u0432 \u0419\u0435\u043D\u0435 \u0432 1911 \u0433\u043E\u0434\u0443 \u043F\u043E
    \u0441\u043E\u0432\u0435\u0442\u0443 \u0420\u0430\u0441\u0441\u0435\u043B\u0430
    \u0438 \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0441\u044F \u043F\u043E\u0434
    \u0441\u0438\u043B\u044C\u043D\u044B\u043C \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C
    \u0435\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u044F\u0437\u044B\u043A\u0430.
    - **\u0420\u0443\u0434\u043E\u043B\u044C\u0444 \u041A\u0430\u0440\u043D\u0430\u043F:**
    \u0411\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0445
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432, \u0441\u043B\u0443\u0448\u0430\u0432\u0448\u0438\u0445
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0424\u0440\u0435\u0433\u0435, \u0438 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0441\u0442\u0430\u043B \u0432\u0438\u0434\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u0412\u0435\u043D\u0441\u043A\u043E\u0433\u043E \u043A\u0440\u0443\u0436\u043A\u0430,
    \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u044F
    \u0435\u0433\u043E \u0438\u0434\u0435\u0438 \u0441\u0440\u0435\u0434\u0438 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u0437\u0438\u0442\u0438\u0432\u0438\u0441\u0442\u043E\u0432. - **\u042D\u0434\u043C\u0443\u043D\u0434
    \u0413\u0443\u0441\u0441\u0435\u0440\u043B\u044C:** \u041F\u043E\u0441\u043B\u0435
    \u043F\u0440\u043E\u0447\u0442\u0435\u043D\u0438\u044F \u0440\u0430\u0431\u043E\u0442
    \u0424\u0440\u0435\u0433\u0435 \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0437\u043C\u0430
    \u0432 \u0441\u0432\u043E\u0435\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438,
    \u0447\u0442\u043E \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u043E \u043D\u0430
    \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435 \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u043E\u043B\u043E\u0433\u0438\u0438. 
    \u041D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u043F\u0440\u0438\u0448\u043B\u043E \u043A \u0424\u0440\u0435\u0433\u0435 \u0443\u0436\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0412\u0442\u043E\u0440\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B, \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u043C \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0430\u043C
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u043B\u0438 \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u0432\u0448\u0438\u0435
    \u0432 \u0421\u0428\u0410 \u043B\u043E\u0433\u0438\u043A\u0438 \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u044B.
    \u0421\u0435\u0433\u043E\u0434\u043D\u044F \u0435\u0433\u043E \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0441\u0447\u0438\u0442\u0430\u044E\u0442 \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043B\u043E\u0433\u0438\u043A\u043E\u0432
    \u0432\u0441\u0435\u0445 \u0432\u0440\u0435\u043C\u0435\u043D \u0438 \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u0438 \u0432 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0434\u043E\u043C\u0438\u043D\u0438\u0440\u0443\u0435\u0442
    \u0432 \u0430\u043D\u0433\u043B\u043E\u044F\u0437\u044B\u0447\u043D\u043E\u043C
    \u043C\u0438\u0440\u0435."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0413\u043E\u0442\u043B\u043E\u0431\u0430
    \u0424\u0440\u0435\u0433\u0435 \u043F\u043E\u043B\u043D\u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u0432,
    \u043D\u043E \u0438 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445,
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438 \u0434\u0430\u0436\u0435 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u0435\u043B\u0430\u044E\u0442 \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0435\u0449\u0435 \u0431\u043E\u043B\u0435\u0435 \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u043E\u0439.
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u043E \u043D\u0435\u043C.  ---  ### \U0001F4D6
    \u0424\u0438\u0433\u0443\u0440\u0430 \u0434\u043B\u044F \u0437\u043D\u0430\u0442\u043E\u043A\u043E\u0432:
    \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043F\u0440\u0438\u0448\u043B\u043E \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u043F\u043E\u0437\u0434\u043D\u043E  \u042D\u0442\u043E \u043E\u0434\u043D\u0430
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0433\u043E\u0440\u044C\u043A\u0438\u0445
    \u0438\u0440\u043E\u043D\u0438\u0447\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u0439
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043D\u0430\u0443\u043A\u0438.
    \u0421\u0435\u0433\u043E\u0434\u043D\u044F \u0424\u0440\u0435\u0433\u0435 \u2014
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0441\u0442\u043E\u043B\u043F\u043E\u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043B\u043E\u0433\u0438\u043A\u0438,
    \u043D\u043E \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u043E\u043D \u0431\u044B\u043B
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438 \u0443\u0437\u043A\u043E\u0433\u043E
    \u043A\u0440\u0443\u0433\u0430 \u0443\u0447\u0435\u043D\u044B\u0445. \u0415\u0433\u043E
    \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u044B\u0439 \u0442\u0440\u0443\u0434
    \xAB\u0418\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u0439\xBB
    (1879) \u0431\u044B\u043B \u0432\u0441\u0442\u0440\u0435\u0447\u0435\u043D \u043A\u0440\u0430\u0439\u043D\u0435
    \u0441\u0434\u0435\u0440\u0436\u0430\u043D\u043D\u043E, \u043C\u043D\u043E\u0433\u0438\u0435
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043D\u0435 \u043F\u043E\u043D\u044F\u043B\u0438 \u0435\u0433\u043E \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u0442\u0432\u0430. 
    \u0415\u0433\u043E \"\u043A\u0440\u0435\u0441\u0442\u043D\u044B\u043C \u043E\u0442\u0446\u043E\u043C\"
    \u0441\u0442\u0430\u043B **\u0411\u0435\u0440\u0442\u0440\u0430\u043D \u0420\u0430\u0441\u0441\u0435\u043B**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432 1903 \u0433\u043E\u0434\u0443
    \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044E
    \u0424\u0440\u0435\u0433\u0435 \u0432 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u043A \u0441\u0432\u043E\u0438\u043C \xAB\u041E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB, \u0441\u0434\u0435\u043B\u0430\u0432
    \u0435\u0435 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u0439 \u0434\u043B\u044F
    \u0448\u0438\u0440\u043E\u043A\u043E\u0439 \u043F\u0443\u0431\u043B\u0438\u043A\u0438.
    \u041D\u0430\u0441\u0442\u043E\u044F\u0449\u0430\u044F \u0441\u043B\u0430\u0432\u0430
    \u043F\u0440\u0438\u0448\u043B\u0430 \u043A \u0424\u0440\u0435\u0433\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E\u0441\u043B\u0435 \u0412\u0442\u043E\u0440\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B, \u043A\u043E\u0433\u0434\u0430 \u043C\u043D\u043E\u0433\u0438\u0435
    \u043B\u043E\u0433\u0438\u043A\u0438 \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u044B,
    \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u0432\u0448\u0438\u0435
    \u0432 \u0421\u0428\u0410 (\u0442\u0430\u043A\u0438\u0435 \u043A\u0430\u043A
    \u0420\u0443\u0434\u043E\u043B\u044C\u0444 \u041A\u0430\u0440\u043D\u0430\u043F,
    \u041A\u0443\u0440\u0442 \u0413\u0451\u0434\u0435\u043B\u044C \u0438 \u0410\u043B\u044C\u0444\u0440\u0435\u0434
    \u0422\u0430\u0440\u0441\u043A\u0438\u0439), \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \u0438\u0434\u0435\u0438 \u0438 \u0441\u0434\u0435\u043B\u0430\u043B\u0438
    \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u0435 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u044B
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442.  \u0421\u0430\u043C \u0424\u0440\u0435\u0433\u0435,
    \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u044F \u0441\u0432\u043E\u0438
    \u043D\u0435\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0438 \u043F\u0440\u0438\u0435\u043C\u043D\u043E\u043C\u0443
    \u0441\u044B\u043D\u0443, \u0441\u043B\u043E\u0432\u043D\u043E \u043F\u0440\u0435\u0434\u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u0443\u044E
    \u0441\u043B\u0430\u0432\u0443, \u043D\u0430\u043F\u0438\u0441\u0430\u0432: **\xAB\u042F
    \u0432\u0435\u0440\u044E, \u0437\u0434\u0435\u0441\u044C \u0435\u0441\u0442\u044C
    \u0432\u0435\u0449\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u0434\u043D\u0430\u0436\u0434\u044B
    \u0431\u0443\u0434\u0443\u0442 \u0446\u0435\u043D\u0438\u0442\u044C\u0441\u044F
    \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u0432\u044B\u0448\u0435, \u0447\u0435\u043C
    \u0441\u0435\u0439\u0447\u0430\u0441. \u041F\u043E\u0437\u0430\u0431\u043E\u0442\u044C\u0442\u0435\u0441\u044C,
    \u0447\u0442\u043E\u0431\u044B \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435
    \u043F\u0440\u043E\u043F\u0430\u043B\u043E\xBB**. \u042D\u0442\u0438 \u0431\u0443\u043C\u0430\u0433\u0438,
    \u0443\u0432\u044B, \u0431\u044B\u043B\u0438 \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u044B
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0431\u043E\u043C\u0431\u0430\u0440\u0434\u0438\u0440\u043E\u0432\u043A\u0438
    \u041C\u044E\u043D\u0441\u0442\u0435\u0440\u0430 \u0432 1945 \u0433\u043E\u0434\u0443. 
    ### \U0001F914 \u0410\u043D\u0430\u043B\u0438\u0442\u0438\u043A \u043D\u0430
    \u043A\u0430\u0444\u0435\u0434\u0440\u0435: \u041B\u0435\u043A\u0446\u0438\u0438-\u0441\u043F\u0435\u043A\u0442\u0430\u043A\u043B\u0438
    \u0441 \u043E\u0434\u043D\u0438\u043C \u0430\u043A\u0442\u0435\u0440\u043E\u043C 
    \u0412\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432
    \u0440\u0438\u0441\u0443\u044E\u0442 \u043E\u0431\u0440\u0430\u0437 \u0424\u0440\u0435\u0433\u0435
    \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u043A\u0440\u0430\u0439\u043D\u0435
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0433\u043E \u0438 \u043D\u0435\u043B\u044E\u0434\u0438\u043C\u043E\u0433\u043E.
    \u0415\u0433\u043E \u043B\u0435\u043A\u0446\u0438\u0438 \u0431\u044B\u043B\u0438,
    \u043F\u043E \u0441\u0443\u0442\u0438, \u043C\u043E\u043D\u043E\u0441\u043F\u0435\u043A\u0442\u0430\u043A\u043B\u044F\u043C\u0438:
    \u043E\u043D \u0441\u0442\u043E\u044F\u043B \u043A \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u0438
    \u0441\u043F\u0438\u043D\u043E\u0439, \u043F\u0438\u0441\u0430\u043B \u043D\u0430
    \u0434\u043E\u0441\u043A\u0435 \u0437\u0430\u043C\u044B\u0441\u043B\u043E\u0432\u0430\u0442\u044B\u0435
    \u0441\u0438\u043C\u0432\u043E\u043B\u044B \u0441\u0432\u043E\u0435\u0439 \u0434\u0432\u0443\u043C\u0435\u0440\u043D\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438 \u0438 \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u043B
    \u0438\u0445, \u043D\u0435 \u0433\u043B\u044F\u0434\u044F \u043D\u0430 \u0441\u043B\u0443\u0448\u0430\u0442\u0435\u043B\u0435\u0439. 
    **\u0420\u0443\u0434\u043E\u043B\u044C\u0444 \u041A\u0430\u0440\u043D\u0430\u043F**,
    \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444, \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B:
    *\xAB\u0424\u0440\u0435\u0433\u0435 \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u043B
    \u0441\u0442\u0430\u0440\u0448\u0435 \u0441\u0432\u043E\u0438\u0445 \u043B\u0435\u0442.
    \u041E\u043D \u0431\u044B\u043B \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u0433\u043E
    \u0440\u043E\u0441\u0442\u0430, \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E
    \u0437\u0430\u0441\u0442\u0435\u043D\u0447\u0438\u0432, \u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u043E
    \u0438\u043D\u0442\u0440\u043E\u0432\u0435\u0440\u0442\u0435\u043D. \u041E\u043D
    \u0440\u0435\u0434\u043A\u043E \u0441\u043C\u043E\u0442\u0440\u0435\u043B \u043D\u0430
    \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u044E. \u041E\u0431\u044B\u0447\u043D\u043E
    \u043C\u044B \u0432\u0438\u0434\u0435\u043B\u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0435\u0433\u043E \u0441\u043F\u0438\u043D\u0443\xBB*. \u041D\u0438\u043A\u0442\u043E
    \u0438\u0437 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0437\u0430\u0434\u0430\u0432\u0430\u043B \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u0432
    \u2014 \u043D\u0438 \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043B\u0435\u043A\u0446\u0438\u0438,
    \u043D\u0438 \u043F\u043E\u0441\u043B\u0435. \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0438 \u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C
    \u043D\u0435\u043C\u044B\u0441\u043B\u0438\u043C\u043E\u0439. \u041B\u0438\u0448\u044C
    \u043D\u0430 \u043E\u0434\u043D\u043E\u043C \u0438\u0437 \u043F\u0440\u043E\u0434\u0432\u0438\u043D\u0443\u0442\u044B\u0445
    \u043A\u0443\u0440\u0441\u043E\u0432, \u0433\u0434\u0435 \u0431\u044B\u043B\u043E
    \u0432\u0441\u0435\u0433\u043E \u0442\u0440\u0438 \u0441\u043B\u0443\u0448\u0430\u0442\u0435\u043B\u044F,
    \u043E\u043D \u043D\u0435\u043C\u043D\u043E\u0433\u043E \xAB\u043E\u0442\u0442\u0430\u044F\u043B\xBB,
    \u043D\u043E \u0432\u043E\u043F\u0440\u043E\u0441\u044B \u0432\u0441\u0435 \u0440\u0430\u0432\u043D\u043E
    \u043D\u0435 \u0437\u0430\u0434\u0430\u0432\u0430\u043B\u0438\u0441\u044C.  ###
    \U0001F9E9 \u041F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0434\u043D\u0435\u0432\u043D\u0438\u043A \u0438 \u0442\u0435\u043D\u044C \u0430\u043D\u0442\u0438\u0441\u0435\u043C\u0438\u0442\u0438\u0437\u043C\u0430 
    \u0417\u0430\u0442\u0432\u043E\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0424\u0440\u0435\u0433\u0435 \u0438\u043C\u0435\u043B\u043E \u0438 \u0431\u043E\u043B\u0435\u0435
    \u043C\u0440\u0430\u0447\u043D\u0443\u044E \u0441\u0442\u043E\u0440\u043E\u043D\u0443.
    \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u0447\u0442\u043E \u043E\u043D
    \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C \u0443\u043B\u044C\u0442\u0440\u0430\u043F\u0440\u0430\u0432\u043E\u0439
    **\xAB\u041E\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u043F\u0430\u0440\u0442\u0438\u0438\xBB** (Vaterlandspartei) \u0438 \u0430\u043D\u0442\u0438\u0441\u0435\u043C\u0438\u0442\u043E\u043C.
    \u0415\u0433\u043E \xAB\u041F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0434\u043D\u0435\u0432\u043D\u0438\u043A\xBB, \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0439
    \u0437\u0430 \u0433\u043E\u0434 \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    (1924), \u043F\u043E\u043B\u043E\u043D \u0448\u043E\u0432\u0438\u043D\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u043F\u0438\u0441\u0435\u0439, \u0433\u0434\u0435 \u043E\u043D,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u0441\u0435\u0442\u043E\u0432\u0430\u043B
    \u043D\u0430 \xAB\u043F\u043E\u0432\u0441\u0435\u043C\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C
    \u0435\u0432\u0440\u0435\u0435\u0432\xBB \u0438 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u0435
    \u0438\u043C\u0438 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u0438\u0445
    \u043F\u0440\u0430\u0432.  \u042D\u0442\u043E \u0437\u043D\u0430\u043D\u0438\u0435,
    \u043F\u043E \u0441\u043B\u043E\u0432\u0430\u043C \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438\u0437 \u0435\u0433\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432
    (\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430
    \u0413\u0435\u0440\u0448\u043E\u043C\u0430 \u0428\u043E\u043B\u0435\u043C\u0430),
    \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0435\u0442, \u043F\u043E\u0447\u0435\u043C\u0443
    \u0434\u0430\u0436\u0435 \u043D\u0435\u0435\u0432\u0440\u0435\u0439\u0441\u043A\u0438\u0435
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B \u043D\u0435 \u0440\u0435\u0448\u0430\u043B\u0438\u0441\u044C
    \u043F\u043E\u0434\u043E\u0439\u0442\u0438 \u043A \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0443
    \u0432\u043D\u0435 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u2014 \u0435\u0433\u043E \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044F
    \u0431\u044B\u043B\u0430 \u043E\u0431\u0449\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430.
    \u041F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0447\u0442\u043E \u0432 \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u043B\u0435\u043A\u0446\u0438\u0439
    \u0424\u0440\u0435\u0433\u0435 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E **\xAB\u043B\u043E\u0433\u0438\u043A\u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0430\u0440\u0438\u0439\u0441\u043A\u0430\u044F, \u043D\u043E \u0434\u0430\u0436\u0435
    \u0438 \u043D\u0430\u0434\u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0430\u044F\xBB**,
    \u043E\u0434\u043D\u0430\u043A\u043E \u043D\u0435\u0439\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430 \u043D\u0435 \u043E\u0442\u043C\u0435\u043D\u044F\u043B\u0430
    \u043F\u0440\u0435\u0434\u0432\u0437\u044F\u0442\u043E\u0441\u0442\u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044F. 
    ### \U0001F94A \u041A\u0440\u0443\u0448\u0435\u043D\u0438\u0435 \u043D\u0430\u0434\u0435\u0436\u0434:
    \u041F\u0438\u0441\u044C\u043C\u043E, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043F\u043E\u0442\u0440\u044F\u0441\u043B\u043E \u0424\u0440\u0435\u0433\u0435 
    \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0441\u0430\u043C\u044B\u0439
    \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u044B\u0439 \u044D\u043F\u0438\u0437\u043E\u0434
    \u0432 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u0424\u0440\u0435\u0433\u0435
    \u2014 \u044D\u0442\u043E \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u0435
    \u0432 1902 \u0433\u043E\u0434\u0443 \u043F\u0438\u0441\u044C\u043C\u0430 \u043E\u0442
    \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E \u0411\u0435\u0440\u0442\u0440\u0430\u043D\u0430
    \u0420\u0430\u0441\u0441\u0435\u043B\u0430, \u043A\u043E\u0433\u0434\u0430 \u0432\u0442\u043E\u0440\u043E\u0439
    \u0442\u043E\u043C \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430 \xAB\u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0437\u0430\u043A\u043E\u043D\u044B \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\xBB
    \u0443\u0436\u0435 \u0431\u044B\u043B \u0432 \u043F\u0435\u0447\u0430\u0442\u0438.
    \u0420\u0430\u0441\u0441\u0435\u043B \u0438\u0437\u043B\u043E\u0436\u0438\u043B
    \u0441\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441 (\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0435
    \u0432\u0441\u0435\u0445 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432, \u043D\u0435
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0438\u0445 \u0441\u0435\u0431\u044F),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0440\u0430\u0437\u0440\u0443\u0448\u0430\u043B
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u0424\u0440\u0435\u0433\u0435, \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u0443\u044E
    \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435 \u043A\u043B\u0430\u0441\u0441\u043E\u0432. 
    **\u0420\u0435\u0430\u043A\u0446\u0438\u044F \u0424\u0440\u0435\u0433\u0435 \u0431\u044B\u043B\u0430
    \u0441\u043E\u043A\u0440\u0443\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439.**
    \u0412 \u043E\u0442\u0432\u0435\u0442\u043D\u043E\u043C \u043F\u0438\u0441\u044C\u043C\u0435
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B: *\xAB\u0412\u0430\u0448\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u044F
    \u0443\u0434\u0438\u0432\u0438\u043B\u043E \u043C\u0435\u043D\u044F \u0441\u0432\u0435\u0440\u0445
    \u043C\u0435\u0440\u044B \u0438, \u044F \u0431\u044B \u0441\u043A\u0430\u0437\u0430\u043B,
    \u043F\u043E\u0447\u0442\u0438 \u043E\u0433\u043B\u0443\u0448\u0438\u043B\u043E,
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u043E\u043D\u043E \u043F\u043E\u043A\u043E\u043B\u0435\u0431\u0430\u043B\u043E
    \u0442\u0443 \u043F\u043E\u0447\u0432\u0443, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u044F \u0445\u043E\u0442\u0435\u043B \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0443. \u2026 \u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430
    \u0448\u0430\u0442\u0430\u0435\u0442\u0441\u044F!\xBB*.  \u041E\u043D \u043C\u0443\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u0434\u043E\u0431\u0430\u0432\u0438\u043B \u0432 \u043A\u043E\u043D\u0435\u0446
    \u0442\u043E\u043C\u0430 \u0441\u043F\u0435\u0448\u043D\u043E\u0435 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0435,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u043F\u0440\u0438\u0437\u043D\u0430\u043B
    \u043E\u0448\u0438\u0431\u043A\u0443. \u0421\u0430\u043C \u0420\u0430\u0441\u0441\u0435\u043B
    \u043F\u043E\u0437\u0436\u0435 \u0432\u043E\u0441\u0445\u0438\u0449\u0430\u043B\u0441\u044F
    \u044D\u0442\u0438\u043C \u043F\u043E\u0441\u0442\u0443\u043F\u043A\u043E\u043C
    \u043A\u0430\u043A \u0430\u043A\u0442\u043E\u043C \u0432\u044B\u0441\u043E\u0447\u0430\u0439\u0448\u0435\u0439
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439
    \u0447\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u0438: *\xAB\u2026 \u043F\u0440\u0438
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u0438\u0438 \u0442\u043E\u0433\u043E,
    \u0447\u0442\u043E \u0435\u0433\u043E \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0435
    \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E, \u043E\u043D \u043E\u0442\u0432\u0435\u0442\u0438\u043B
    \u0441 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u0435\u043C,
    \u044F\u0432\u043D\u043E \u043F\u043E\u0434\u0430\u0432\u043B\u044F\u044F \u043B\u044E\u0431\u043E\u0435
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u044F.
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u043F\u043E\u0447\u0442\u0438 \u0441\u0432\u0435\u0440\u0445\u0447\u0435\u043B\u043E\u0432\u0435\u0447\u043D\u043E\xBB*. 
    ### \u270D\uFE0F \u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u0430\u044F
    \u0438\u0440\u043E\u043D\u0438\u044F: \xAB\u041B\u043E\u0433\u0438\u043A\u0430\xBB
    \u0438\u043B\u0438 \xAB\u0421\u0438\u043B\u0430\u0447 \u0413\u043E\u0442\u043B\u0438\u0431\xBB? 
    \u0417\u0430\u0432\u0435\u0440\u0448\u0438\u043C \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u043C.
    \u041F\u043E\u0438\u0441\u043A \u043F\u043E \u0437\u0430\u043F\u0440\u043E\u0441\u0443
    \"\u0413\u043E\u0442\u043B\u043E\u0431 \u0424\u0440\u0435\u0433\u0435\" \u0438\u043D\u043E\u0433\u0434\u0430
    \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u0442 \u043A \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u043C \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430\u043C.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043A \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0439
    \u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0439 \u0441\u043A\u0430\u0437\u043A\u0435
    **\xAB\u0421\u0438\u043B\u0430\u0447 \u0413\u043E\u0442\u043B\u0438\u0431\xBB**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u0438 \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0435
    \u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u043D\u0435 \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0439 \u0441 \u043D\u0430\u0448\u0438\u043C
    \u0433\u0435\u0440\u043E\u0435\u043C. \u0410 \u0432 \u043E\u0434\u043D\u043E\u043C
    \u0438\u0437 \u043F\u0430\u0441\u0441\u0430\u0436\u0435\u0439 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442\u0441\u044F,
    \u043A\u0430\u043A \u043A\u0442\u043E-\u0442\u043E, \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u0432\u0448\u0438\u0441\u044C
    \u0438\u043C\u0435\u043D\u0435\u043C \"\u0413\u043E\u0442\u043B\u043E\u0431 \u0424\u0440\u0435\u0433\u0435\",
    \u0440\u0430\u0441\u043A\u043B\u0435\u0438\u0432\u0430\u043B \u043F\u043E \u0433\u043E\u0440\u043E\u0434\u0443
    \u043B\u0438\u0441\u0442\u043E\u0432\u043A\u0438 \u0441 \u0443\u0433\u0440\u043E\u0437\u0430\u043C\u0438
    \u043E\u0442 \u0438\u043C\u0435\u043D\u0438... \u0438\u0433\u0443\u0430\u043D\u044B.
    \u042D\u0442\u043E \u044F\u0440\u043A\u0438\u0439 \u043F\u0440\u0438\u043C\u0435\u0440
    \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u0438\u043C\u044F \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E,
    \u043D\u043E \u043C\u0430\u043B\u043E\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430,
    \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C \u043E\u0431\u0440\u0435\u0442\u0430\u0435\u0442
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E, \u043F\u043E\u0440\u043E\u0439
    \u0430\u0431\u0441\u0443\u0440\u0434\u043D\u0443\u044E, \u0436\u0438\u0437\u043D\u044C
    \u0432 \u043F\u043E\u043F-\u043A\u0443\u043B\u044C\u0442\u0443\u0440\u0435 \u0438
    \u0434\u0430\u0436\u0435 \u0432 \u043C\u0430\u0441\u0441\u043E\u0432\u044B\u0445
    \u0440\u043E\u0437\u044B\u0433\u0440\u044B\u0448\u0430\u0445."
