  achievementsRu: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0410\u043B\u044C-\u0425\u043E\u0440\u0435\u0437\u043C\u0438 \u0432 \u043D\u0430\u0443\u043A\u0443
    \u043D\u043E\u0441\u0438\u0442 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439,
    \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435 \u044D\u043F\u043E\u0445\u0430\u043B\u044C\u043D\u044B\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440 \u0438 \u043B\u0435\u0436\u0438\u0442
    \u0441\u0440\u0430\u0437\u0443 \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445. \u0412 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u043E\u043D \u043F\u043E\u0434\u0430\u0440\u0438\u043B \u043C\u0438\u0440\u0443
    \u0434\u0432\u0435 \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0449\u0438\u0435
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u044B: \u0432 \u0441\u0432\u043E\u0435\u043C
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435 \xAB\u041A\u0438\u0442\u0430\u0431
    \u0430\u043B\u044C-\u0434\u0436\u0435\u0431\u0440 \u0432\u0430\u043B\u044C-\u043C\u0443\u043A\u0430\u0431\u0430\u043B\u0430\xBB
    (\u0441\u043E\u043A\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u043E\u0442 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0434\u0430\u043B\u043E \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 **\u0430\u043B\u0433\u0435\u0431\u0440\u0435**)
    \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0432\u044B\u0434\u0435\u043B\u0438\u043B
    \u0435\u0435 \u0432 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443, \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u0432
    \u0438 \u0440\u0435\u0448\u0438\u0432 \u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0435
    \u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u0448\u0435\u0441\u0442\u0438 \u043A\u0430\u043D\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0432\u0438\u0434\u043E\u0432 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0447\u0438\u0441\u0442\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0438\u0435\u043C\u043E\u0432 (\u043F\u0435\u0440\u0435\u043D\u043E\u0441
    \u0447\u043B\u0435\u043D\u043E\u0432 \u0438 \u043F\u0440\u0438\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u043F\u043E\u0434\u043E\u0431\u043D\u044B\u0445), \u0430 \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    \u2014 \xAB\u041A\u043D\u0438\u0433\u0435 \u043E\u0431 \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u043E\u043C
    \u0441\u0447\u0435\u0442\u0435\xBB \u2014 \u043E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B,
    \u0430 \u0441\u0442\u0440\u043E\u0433\u043E \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \u0438 \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u043E \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B
    \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u0443\u044E \u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u043D\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u043D\u0443\u043B\u044F, \u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u044F
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0439 \u0441 \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u0438\u043C\u0438
    \u0446\u0438\u0444\u0440\u0430\u043C\u0438; \u0438\u043C\u0435\u043D\u043D\u043E
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u0438\u043C
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0430\u043C \u044D\u0442\u043E\u0439
    \u043A\u043D\u0438\u0433\u0438 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u043F\u0435\u0440\u0435\u0448\u043B\u0430
    \u043E\u0442 \u043C\u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439 \u043D\u0430 \u0430\u0431\u0430\u043A\u0435
    \u043A \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u043C \xAB\u0430\u0440\u0430\u0431\u0441\u043A\u0438\u043C\xBB
    \u0446\u0438\u0444\u0440\u0430\u043C, \u0430 \u0441\u0430\u043C\u043E \u043B\u0430\u0442\u0438\u043D\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0435
    \u0438\u043C\u044F \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u2014 **Algorithmi**
    \u2014 \u0441\u0442\u0430\u043B\u043E \u043D\u0430\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0438 \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u043E \u0442\u0435\u0440\u043C\u0438\u043D
    **\xAB\u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\xBB**, \u043E\u0437\u043D\u0430\u0447\u0430\u044E\u0449\u0438\u0439
    \u043B\u044E\u0431\u0443\u044E \u0447\u0435\u0442\u043A\u0443\u044E \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439. \u0412 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u043E\u043D \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0437\u0438\u0434\u0436\u0438 (\u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B), \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0438\u0435
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438, \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B
    \u0433\u043E\u0440\u043E\u0434\u043E\u0432 \u0438 \u0434\u0430\u043D\u043D\u044B\u0435
    \u043E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438 \u043F\u043B\u0430\u043D\u0435\u0442,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432\u0435\u043A\u0430\u043C\u0438
    \u0441\u043B\u0443\u0436\u0438\u043B\u0438 \u043D\u0430\u0432\u0438\u0433\u0430\u0442\u043E\u0440\u0430\u043C\u0438
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0430\u043C\u0438 \u0412\u043E\u0441\u0442\u043E\u043A\u0430
    \u0438 \u0417\u0430\u043F\u0430\u0434\u0430, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043B\u0438\u0447\u043D\u043E \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043F\u0440\u043E\u0435\u043A\u0442\u0435 \u043F\u043E \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044E
    \u0434\u0443\u0433\u0438 \u043C\u0435\u0440\u0438\u0434\u0438\u0430\u043D\u0430
    \u043D\u0430 \u0440\u0430\u0432\u043D\u0438\u043D\u0435 \u0421\u0438\u043D\u0434\u0436\u0430\u0440,
    \u0447\u0442\u043E\u0431\u044B \u0443\u0442\u043E\u0447\u043D\u0438\u0442\u044C
    \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u044C \u0417\u0435\u043C\u043B\u0438.
    \u0412 \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u043E\u043D \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u043E
    \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0438 \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u043B
    \xAB\u0413\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u044E\xBB \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F,
    \u0441\u043E\u0437\u0434\u0430\u0432 \u043F\u0435\u0440\u0432\u044B\u0439 \u043D\u0430
    \u0430\u0440\u0430\u0431\u0441\u043A\u043E\u043C \u044F\u0437\u044B\u043A\u0435
    \u0441\u0432\u043E\u0434\u043D\u044B\u0439 \u0430\u0442\u043B\u0430\u0441 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430 (\xAB\u041A\u043D\u0438\u0433\u0430 \u043A\u0430\u0440\u0442\u0438\u043D\u044B
    \u0417\u0435\u043C\u043B\u0438\xBB) \u0441 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u0430\u043C\u0438
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u0441\u043E\u0442\u0435\u043D
    \u043D\u0430\u0441\u0435\u043B\u0435\u043D\u043D\u044B\u0445 \u043F\u0443\u043D\u043A\u0442\u043E\u0432,
    \u0433\u043E\u0440, \u043C\u043E\u0440\u0435\u0439 \u0438 \u043E\u0441\u0442\u0440\u043E\u0432\u043E\u0432,
    \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u0432
    \u043E\u0441\u043D\u043E\u0432\u044B \u0430\u0440\u0430\u0431\u043E\u044F\u0437\u044B\u0447\u043D\u043E\u0439
    \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u0438. \u0422\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0410\u043B\u044C-\u0425\u043E\u0440\u0435\u0437\u043C\u0438,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u043A\u043B\u044E\u0447\u0435\u0432\u043E\u0439
    \u0444\u0438\u0433\u0443\u0440\u043E\u0439 \xAB\u0417\u043E\u043B\u043E\u0442\u043E\u0433\u043E
    \u0432\u0435\u043A\u0430 \u0438\u0441\u043B\u0430\u043C\u0430\xBB, \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u043E\u0431\u0440\u0430\u043B \u0438
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043D\u0438\u044F \u0433\u0440\u0435\u043A\u043E\u0432 \u0438
    \u0438\u043D\u0434\u0438\u0439\u0446\u0435\u0432, \u043D\u043E \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0443\u044E \u043D\u0430\u0443\u0447\u043D\u0443\u044E
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E, \u0441\u043E\u0437\u0434\u0430\u0432
    \u044F\u0437\u044B\u043A (\u0430\u043B\u0433\u0435\u0431\u0440\u0430 \u0438 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u044B),
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u0432\u0441\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u043D\u0430\u0443\u043A\u0430 \u0438 \u0442\u0435\u0445\u043D\u0438\u043A\u0430."
  achievementsEn: 
  personalLifeRu: "\u0414\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u044B\u0445
    \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u0439 \u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0430\u043B\u044C-\u0425\u043E\u0440\u0435\u0437\u043C\u0438
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C \u043A\u0440\u0430\u0439\u043D\u0435
    \u043C\u0430\u043B\u043E, \u0438 \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u0444\u0430\u043A\u0442\u043E\u0432
    \u043D\u043E\u0441\u044F\u0442 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440. \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E
    \u043B\u0438\u0448\u044C, \u0447\u0442\u043E \u0435\u0433\u043E \u043E\u0442\u0446\u0430
    \u0437\u0432\u0430\u043B\u0438 \u041C\u0443\u0441\u0430, \u0430 \u0441\u0430\u043C
    \u043E\u043D, \u0441\u0443\u0434\u044F \u043F\u043E \u0435\u0433\u043E \u0431\u043B\u0430\u0433\u043E\u0447\u0435\u0441\u0442\u0438\u0432\u043E\u043C\u0443
    \u043F\u0440\u0435\u0434\u0438\u0441\u043B\u043E\u0432\u0438\u044E \u043A \xAB\u0410\u043B\u0433\u0435\u0431\u0440\u0435\xBB,
    \u0431\u044B\u043B \u043F\u0440\u0430\u0432\u043E\u0432\u0435\u0440\u043D\u044B\u043C
    \u043C\u0443\u0441\u0443\u043B\u044C\u043C\u0430\u043D\u0438\u043D\u043E\u043C
    \u0441\u0443\u043D\u043D\u0438\u0442\u0441\u043A\u043E\u0433\u043E \u0442\u043E\u043B\u043A\u0430.
    \u042D\u043F\u0438\u0442\u0435\u0442 \xAB\u0430\u043B\u044C-\u041C\u0430\u0434\u0436\u0443\u0441\u0438\xBB
    (\u0442\u043E \u0435\u0441\u0442\u044C \u043C\u0430\u0433), \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0435\u0433\u043E \u0438\u043D\u043E\u0433\u0434\u0430 \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442,
    \u0441\u043A\u043E\u0440\u0435\u0435 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u043A\u0438,
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0431\u044B\u043B\u0438 \u0437\u043E\u0440\u043E\u0430\u0441\u0442\u0440\u0438\u0439\u0441\u043A\u0438\u043C\u0438
    \u0436\u0440\u0435\u0446\u0430\u043C\u0438 \u0438\u0437 \u0425\u043E\u0440\u0435\u0437\u043C\u0430,
    \u043D\u043E \u043D\u0435 \u043E\u0442\u0440\u0430\u0436\u0430\u0435\u0442 \u0435\u0433\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E \u0432\u0435\u0440\u043E\u0438\u0441\u043F\u043E\u0432\u0435\u0434\u0430\u043D\u0438\u044F
    \u0432\u043E \u0432\u0437\u0440\u043E\u0441\u043B\u043E\u043C \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435.
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0435
    \u043E\u0431 \u0443\u0447\u0451\u043D\u043E\u043C \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0445\u0440\u043E\u043D\u0438\u043A\u0430\u0445 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0441\u044F
    \u043A 847 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u043E\u043D
    \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u043F\u0440\u0438 \u043A\u043E\u043D\u0447\u0438\u043D\u0435 \u0445\u0430\u043B\u0438\u0444\u0430
    \u0430\u043B\u044C-\u0412\u0430\u0441\u0438\u043A\u0430, \u0438 \u043F\u0440\u0438\u043D\u044F\u0442\u043E
    \u0441\u0447\u0438\u0442\u0430\u0442\u044C, \u0447\u0442\u043E \u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u043E\u043A\u043E\u043B\u043E 850 \u0433\u043E\u0434\u0430."
  personalLifeEn: 
  shortBioRu: "\u0410\u0431\u0443 \u0410\u0431\u0434\u0430\u043B\u043B\u0430\u0445
    (\u0438\u043B\u0438 \u0410\u0431\u0443 \u0414\u0436\u0430\u0444\u0430\u0440)
    \u041C\u0443\u0445\u0430\u043C\u043C\u0430\u0434 \u0438\u0431\u043D \u041C\u0443\u0441\u0430
    \u0430\u043B\u044C-\u0425\u043E\u0440\u0435\u0437\u043C\u0438 (\u043E\u043A.
    783\u2013\u043E\u043A. 850) \u2014 \u0432\u0435\u043B\u0438\u043A\u0438\u0439
    \u0441\u0440\u0435\u0434\u043D\u0435\u0430\u0437\u0438\u0430\u0442\u0441\u043A\u0438\u0439
    \u0443\u0447\u0435\u043D\u044B\u0439, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C \u0438 \u0433\u0435\u043E\u0433\u0440\u0430\u0444,
    \u0447\u044C\u0438 \u0442\u0440\u0443\u0434\u044B \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u044B \u0430\u043B\u0433\u0435\u0431\u0440\u044B
    \u0438 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0438 \u0417\u0430\u043F\u0430\u0434
    \u0441 \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439
    \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F . \u0420\u043E\u0434\u0438\u0432\u0448\u0438\u0441\u044C
    \u0432 \u0425\u043E\u0440\u0435\u0437\u043C\u0435 (\u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u043D\u0430 \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u0438
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E \u0423\u0437\u0431\u0435\u043A\u0438\u0441\u0442\u0430\u043D\u0430),
    \u043E\u043D, \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B \u0438\u0437 \u0441\u0435\u043C\u044C\u0438
    \u0437\u043E\u0440\u043E\u0430\u0441\u0442\u0440\u0438\u0439\u0441\u043A\u0438\u0445
    \u0436\u0440\u0435\u0446\u043E\u0432 \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u043D\u0430
    \u0440\u043E\u0434\u0438\u043D\u0435, \u043F\u0440\u0435\u0436\u0434\u0435 \u0447\u0435\u043C
    \u0431\u044B\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D \u0432
    \u0411\u0430\u0433\u0434\u0430\u0434 \u043A\u043E \u0434\u0432\u043E\u0440\u0443
    \u0445\u0430\u043B\u0438\u0444\u0430 \u0430\u043B\u044C-\u041C\u0430\u043C\u0443\u043D\u0430.
    \u0412 \u0411\u0430\u0433\u0434\u0430\u0434\u0435 \u0430\u043B\u044C-\u0425\u043E\u0440\u0435\u0437\u043C\u0438
    \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u043B \xAB\u0414\u043E\u043C
    \u043C\u0443\u0434\u0440\u043E\u0441\u0442\u0438\xBB (\xAB\u0411\u0430\u0439\u0442
    \u0430\u043B\u044C-\u0445\u0438\u043A\u043C\u0430\xBB) \u2014 \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u043D\u0430\u0443\u0447\u043D\u044B\u0439 \u0446\u0435\u043D\u0442\u0440 \u0445\u0430\u043B\u0438\u0444\u0430\u0442\u0430,
    \u0433\u0434\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430 \u0431\u043E\u0433\u0430\u0442\u0430\u044F
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0430 \u0438 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u044F.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B:
    \xAB\u041A\u0440\u0430\u0442\u043A\u0443\u044E \u043A\u043D\u0438\u0433\u0443
    \u043E\u0431 \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u044B
    \u0438 \u0430\u043B\u043C\u0443\u043A\u0430\u0431\u0430\u043B\u044B\xBB, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0434\u0430\u043B\u0430 \u0438\u043C\u044F \u043D\u0430\u0443\u043A\u0435 \u0430\u043B\u0433\u0435\u0431\u0440\u0435
    \u0438 \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0438\u0437\u043B\u043E\u0436\u0438\u043B\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0445 \u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439, \u0430 \u0442\u0430\u043A\u0436\u0435
    \xAB\u041A\u043D\u0438\u0433\u0443 \u043E\u0431 \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u043E\u043C
    \u0441\u0447\u0435\u0442\u0435\xBB, \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0443\u044E
    \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u043E\u0439 \u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435 \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0441 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043D\u0443\u043B\u044F. \u041B\u0430\u0442\u0438\u043D\u0441\u043A\u0438\u0435
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u044B \u044D\u0442\u0438\u0445 \u0440\u0430\u0431\u043E\u0442
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0430 \u0438\u043C\u044F \u0443\u0447\u0435\u043D\u043E\u0433\u043E, \u0437\u0430\u043A\u0440\u0435\u043F\u0438\u0432\u0448\u0435\u0435\u0441\u044F
    \u0432 \u043B\u0430\u0442\u0438\u043D\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u0435 \xAB\u0410\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0438\xBB,
    \u0441\u0442\u0430\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u0442\u0435\u0440\u043C\u0438\u043D\u0430 \xAB\u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\xBB,
    \u0430 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u0430
    \xAB\u0430\u043B\u044C-\u0434\u0436\u0435\u0431\u0440\xBB \u0434\u0430\u043B\u043E
    \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \u0430\u043B\u0433\u0435\u0431\u0440\u0435.
    \u041A\u0440\u043E\u043C\u0435 \u0442\u043E\u0433\u043E, \u0430\u043B\u044C-\u0425\u043E\u0440\u0435\u0437\u043C\u0438
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B \u043F\u043E \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    (\u0442\u0430\u0431\u043B\u0438\u0446\u044B \u0437\u0438\u0434\u0436), \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0438 \u0434\u043B\u0438\u043D\u044B
    \u0437\u0435\u043C\u043D\u043E\u0433\u043E \u043C\u0435\u0440\u0438\u0434\u0438\u0430\u043D\u0430
    \u0438 \u0441\u043E\u0437\u0434\u0430\u043B \u043F\u0435\u0440\u0432\u0443\u044E
    \u043D\u0430 \u0430\u0440\u0430\u0431\u0441\u043A\u043E\u043C \u044F\u0437\u044B\u043A\u0435
    \u043A\u043D\u0438\u0433\u0443 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u2014 \xAB\u041A\u043D\u0438\u0433\u0443
    \u043A\u0430\u0440\u0442\u0438\u043D\u044B \u0417\u0435\u043C\u043B\u0438\xBB,
    \u0443\u0442\u043E\u0447\u043D\u0438\u0432 \u0434\u0430\u043D\u043D\u044B\u0435
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F. \u0421\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0443\u0447\u0435\u043D\u044B\u0439 \u043E\u043A\u043E\u043B\u043E 847 \u0433\u043E\u0434\u0430
    \u0432 \u0411\u0430\u0433\u0434\u0430\u0434\u0435 ."
