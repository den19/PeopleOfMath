  achievementsRu: "\u0413\u043E\u0432\u043E\u0440\u044F \u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u0445
    \u0411\u0435\u0440\u043D\u0430\u0440\u0434\u0430 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E,
    \u0432\u0430\u0436\u043D\u043E \u043F\u043E\u043D\u0438\u043C\u0430\u0442\u044C,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043D\u0430\u0431\u043E\u0440 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439,
    \u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0441\u043C\u0435\u043D\u0430 \u043F\u0430\u0440\u0430\u0434\u0438\u0433\u043C\u044B.
    \u041E\u043D \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445,
    \u043A\u0442\u043E \u043D\u0430\u0447\u0430\u043B \u0441\u0442\u0440\u043E\u0438\u0442\u044C
    \u0437\u0434\u0430\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u043B\u043E\u0433\u0438\u043A\u0438 \u043D\u0430 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E
    \u0441\u0442\u0440\u043E\u0433\u043E\u043C, \u043D\u0435 \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u043E\u043C
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0435, \u043D\u0430\u043C\u043D\u043E\u0433\u043E
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432 \u0441\u0432\u043E\u0435 \u0432\u0440\u0435\u043C\u044F. 
    ### \U0001F4D0 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0438 \u0442\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B  \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u043F\u043E \u043F\u0440\u0430\u0432\u0443 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043E\u0442\u0446\u043E\u0432-\u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u0431\u044B\u043B\u0438 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u044B
    \u043F\u0440\u0435\u043E\u0434\u043E\u043B\u0435\u043D\u0438\u044E \u0440\u0430\u0441\u043F\u043B\u044B\u0432\u0447\u0430\u0442\u044B\u0445
    \u043F\u043E\u043D\u044F\u0442\u0438\u0439 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E
    \u043C\u0430\u043B\u044B\u0445 \u0438 \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u044B\u0445
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u043E \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u0438,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0430\u043D\u0430\u043B\u0438\u0437 \u043D\u0430 \u043F\u0440\u043E\u0447\u043D\u0443\u044E
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u043E\u0441\u043D\u043E\u0432\u0443. 
    *   **\u0421\u0442\u0440\u043E\u0433\u043E\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u0438:**
    \u0412 1817 \u0433\u043E\u0434\u0443 \u0432 \u0440\u0430\u0431\u043E\u0442\u0435
    \xAB\u0427\u0438\u0441\u0442\u043E \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\xBB
    \u043E\u043D \u0434\u0430\u043B \u043F\u0435\u0440\u0432\u043E\u0435 \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043F\u043E \u0441\u0443\u0442\u0438 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0442\u0435\u043C \u0441\u0430\u043C\u044B\u043C \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435\u043C,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043C\u044B \u0437\u043D\u0430\u0435\u043C
    \u0438\u0437 \u043A\u0443\u0440\u0441\u0430 \u043C\u0430\u0442\u0430\u043D\u0430\u043B\u0438\u0437\u0430.
    \u041E\u043D\u043E \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043E
    \u0447\u0435\u0440\u0435\u0437 \u043F\u0440\u0438\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442\u0430 `\u03C9`: \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u044C
    `f(x+\u03C9) - f(x)` \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C
    \u0441\u0434\u0435\u043B\u0430\u043D\u0430 \u043C\u0435\u043D\u044C\u0448\u0435
    \u043B\u044E\u0431\u043E\u0439 \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u0439
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u044B, \u0435\u0441\u043B\u0438 `\u03C9`
    \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E \u043C\u0430\u043B\u043E.
    *   **\u041A\u0440\u0438\u0442\u0435\u0440\u0438\u0439 \u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438
    (\u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E-\u041A\u043E\u0448\u0438):**
    \u0412 \u0442\u043E\u0439 \u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0435 1817
    \u0433\u043E\u0434\u0430 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0441\u0442\u0440\u043E\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0439
    \u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438 \u0447\u0438\u0441\u043B\u043E\u0432\u043E\u0439
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u042D\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E \u043D\u0430
    \u0447\u0435\u0442\u044B\u0440\u0435 \u0433\u043E\u0434\u0430 \u0440\u0430\u043D\u044C\u0448\u0435,
    \u0447\u0435\u043C \u0443 \u041A\u043E\u0448\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u0441\u0442\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E\u0442 \u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0439. \u0418\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438
    \u0442\u043E\u0447\u043D\u0435\u0435 \u0431\u044B\u043B\u043E \u0431\u044B \u043D\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u0435\u0433\u043E **\u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0435\u043C \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E-\u041A\u043E\u0448\u0438**.
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u0447\u043D\u043E\u043C
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0438 (\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E):** \u0412 \u0442\u043E\u0439
    \u0436\u0435 \u0437\u043D\u0430\u043A\u043E\u0432\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    1817 \u0433\u043E\u0434\u0430 \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B
    \u043F\u0435\u0440\u0432\u043E\u0435 \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u0442\u043E\u043C, \u0447\u0442\u043E
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u0430\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u044F,
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u044E\u0449\u0430\u044F \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    \u0440\u0430\u0437\u043D\u044B\u0445 \u0437\u043D\u0430\u043A\u043E\u0432 \u043D\u0430
    \u043A\u043E\u043D\u0446\u0430\u0445 \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u0430,
    \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E \u0438\u043C\u0435\u0435\u0442
    \u043A\u043E\u0440\u0435\u043D\u044C \u0432\u043D\u0443\u0442\u0440\u0438 \u044D\u0442\u043E\u0433\u043E
    \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u0430. \u0421\u0435\u0439\u0447\u0430\u0441
    \u044D\u0442\u043E \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043A\u0430\u043A \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E. *   **\xAB\u0418\u0437\u043C\u0435\u0440\u0438\u043C\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430\xBB \u2014 \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B:** \u0421\u0430\u043C\u0430\u044F, \u043F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u0430\u044F
    \u0438 \u043D\u0435\u0434\u043E\u043E\u0446\u0435\u043D\u0435\u043D\u043D\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0431\u044B\u043B\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0430 \u0432 \u043D\u0430\u0447\u0430\u043B\u0435
    1830-\u0445 \u0433\u043E\u0434\u043E\u0432 \u0432 \u0435\u0433\u043E \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0438
    \xAB\u0427\u0438\u0441\u0442\u0430\u044F \u0442\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B\xBB. \u041E\u043D \u043F\u043E\u043D\u044F\u043B
    \u0433\u043B\u0430\u0432\u043D\u0443\u044E \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443 \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438: \u0434\u043B\u044F
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u043D\u0443\u0436\u043D\u043E \u0431\u044B\u043B\u043E \u0438\u043C\u0435\u0442\u044C
    \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B. \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u044F\u043B \u043F\u043E\u043F\u044B\u0442\u043A\u0443
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C \u0442\u0430\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E, \u0441\u043E\u0437\u0434\u0430\u0432 \u0441\u0432\u043E\u0438
    **\xAB\u0438\u0437\u043C\u0435\u0440\u0438\u043C\u044B\u0435 \u0447\u0438\u0441\u043B\u0430\xBB**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0431\u044B\u043B\u0438 \u043F\u043E
    \u0441\u0443\u0442\u0438 \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0435\u0439
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u0438\u0437 \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445.
    \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430, \u043E\u0441\u0442\u0430\u0432\u0448\u0430\u044F\u0441\u044F
    \u0432 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0438, \u043D\u0430\u043C\u043D\u043E\u0433\u043E
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0430 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430,
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u0438 \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u0430,
    \u043F\u043E\u044F\u0432\u0438\u0432\u0448\u0438\u0435\u0441\u044F \u043B\u0438\u0448\u044C
    \u0432 1870-\u0445 \u0433\u043E\u0434\u0430\u0445. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E-\u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u0430:**
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0434\u0430\u043B \u043F\u0435\u0440\u0432\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u0442\u043E\u043C, \u0447\u0442\u043E
    \u0438\u0437 \u043B\u044E\u0431\u043E\u0439 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u043D\u043E\u0439
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0439 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u043C\u043E\u0436\u043D\u043E \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u044C
    \u0441\u0445\u043E\u0434\u044F\u0449\u0443\u044E\u0441\u044F \u043F\u043E\u0434\u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C.
    \u042D\u0442\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0431\u044B\u043B\u043E \u0432\u043D\u043E\u0432\u044C \u043E\u0442\u043A\u0440\u044B\u0442\u043E
    \u0438 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043E
    \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u043E\u043C
    \u043F\u043E\u0437\u0436\u0435, \u0438 \u0442\u0435\u043F\u0435\u0440\u044C \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u043D\u043E\u0441\u0438\u0442 \u0438\u0445 \u043E\u0431\u0449\u0435\u0435 \u0438\u043C\u044F.
    *   **\xAB\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u044B \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E\xBB:**
    \u0412 \u0441\u0432\u043E\u0435\u0439 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 (\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430
    \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E \u0432 1851 \u0433\u043E\u0434\u0443)
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u043F\u0440\u043E\u0432\u0435\u043B
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0439 \u0430\u043D\u0430\u043B\u0438\u0437
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432. \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u0440\u0430\u0432\u043D\u043E\u043C\u043E\u0449\u043D\u043E
    \u0441\u0432\u043E\u0435\u0439 \u0447\u0430\u0441\u0442\u0438 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u0440\u0430\u0432\u043D\u043E\u043C\u043E\u0449\u043D\u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0443 \u0447\u0435\u0442\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B). \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0413\u0435\u043E\u0440\u0433\u0430
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430 \u0438 \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432.  ### \U0001F9E0 \u041B\u043E\u0433\u0438\u043A\u0430
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F \u043D\u0430\u0443\u043A\u0438 
    \u0412 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043B\u043E\u0433\u0438\u043A\u0438
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043D\u0435 \u043C\u0435\u043D\u0435\u0435 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u043F\u0435\u0440\u0435\u0432\u043E\u0440\u043E\u0442, \u0441\u0442\u0430\u0432
    \u043F\u0440\u0435\u0434\u0442\u0435\u0447\u0435\u0439 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u0438 \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u043E\u043B\u043E\u0433\u0438\u0438. 
    *   **\u0410\u043D\u0442\u0438\u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0437\u043C
    \u0438 \xAB\u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u0441\u0430\u043C\u0438 \u043F\u043E \u0441\u0435\u0431\u0435\xBB:** \u0415\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434 \u2014 \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u0442\u043E\u043C\u043D\u043E\u0435
    **\xAB\u041D\u0430\u0443\u043A\u043E\u0443\u0447\u0435\u043D\u0438\u0435\xBB
    (1837)**. \u0412 \u043D\u0435\u043C \u043E\u043D \u043F\u0440\u043E\u0432\u0435\u043B
    \u0447\u0435\u0442\u043A\u0443\u044E \u0433\u0440\u0430\u043D\u0438\u0446\u0443
    \u043C\u0435\u0436\u0434\u0443 \u043B\u043E\u0433\u0438\u043A\u043E\u0439 \u0438
    \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0435\u0439. \u041E\u043D
    \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\xAB\u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u0441\u0430\u043C\u0438 \u043F\u043E \u0441\u0435\u0431\u0435\xBB (Satz an sich)**,
    \u0442\u043E \u0435\u0441\u0442\u044C \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E,
    \u0431\u0435\u0437\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u0441\u043C\u044B\u0441\u043B\u0430 \u0441\u0443\u0436\u0434\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0438\u0441\u0442\u0438\u043D\u0435\u043D
    \u0438\u043B\u0438 \u043B\u043E\u0436\u0435\u043D \u0432\u043D\u0435 \u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u0438
    \u043E\u0442 \u0442\u043E\u0433\u043E, \u0434\u0443\u043C\u0430\u0435\u0442 \u043B\u0438
    \u043E \u043D\u0435\u043C \u043A\u0442\u043E-\u0442\u043E \u0438\u043B\u0438
    \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u0442 \u043B\u0438 \u0435\u0433\u043E
    \u0432\u0441\u043B\u0443\u0445. \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u0430\u044F
    \u0434\u043B\u044F \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0438\u0434\u0435\u044F \"\u043C\u0438\u0440\u0430 3\" (\u043F\u043E \u041F\u043E\u043F\u043F\u0435\u0440\u0443),
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u043B\u0430 \u042D\u0434\u043C\u0443\u043D\u0434\u0430
    \u0413\u0443\u0441\u0441\u0435\u0440\u043B\u044F. *   **\u041B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435 (Ableitbarkeit):**
    \u0412 \u0440\u0430\u043C\u043A\u0430\u0445 \xAB\u041D\u0430\u0443\u043A\u043E\u0443\u0447\u0435\u043D\u0438\u044F\xBB
    \u043E\u043D \u0434\u0430\u043B \u043F\u0435\u0440\u0432\u043E\u0435 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    (\u0432\u044B\u0432\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438). \u0415\u0433\u043E
    \u043C\u0435\u0442\u043E\u0434 \u043E\u0441\u043D\u043E\u0432\u044B\u0432\u0430\u043B\u0441\u044F
    \u043D\u0430 **\u0432\u0430\u0440\u0438\u0430\u0446\u0438\u0438 \u0438\u0434\u0435\u0439**:
    \u0435\u0441\u043B\u0438 \u043F\u0440\u0438 \u0437\u0430\u043C\u0435\u043D\u0435
    \u0432\u0441\u0435\u0445 \u043D\u0435\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u043D\u044F\u0442\u0438\u0439 \u0432 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u043D\u0430 \u043B\u044E\u0431\u044B\u0435 \u0434\u0440\u0443\u0433\u0438\u0435
    \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0441\u0442\u044C \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u0435\u0442\u0441\u044F,
    \u0442\u043E \u044D\u0442\u043E \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u0438\u0441\u0442\u0438\u043D\u043D\u044B\u043C. \u042D\u0442\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043F\u043E\u0447\u0442\u0438 \u0437\u0430 100 \u043B\u0435\u0442 \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u043B\u043E
    \u0441\u0435\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u0438\u0441\u0442\u0438\u043D\u044B
    \u0438 \u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u044F \u0410\u043B\u044C\u0444\u0440\u0435\u0434\u0430
    \u0422\u0430\u0440\u0441\u043A\u043E\u0433\u043E.  ### \U0001F4A1 \u042D\u0442\u0438\u043A\u0430
    \u0438 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u0430\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F 
    \u0412\u0430\u0436\u043D\u043E \u043F\u043E\u043C\u043D\u0438\u0442\u044C, \u0447\u0442\u043E
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0431\u044B\u043B \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \xAB\u0447\u0438\u0441\u0442\u044B\u043C\xBB
    \u0443\u0447\u0435\u043D\u044B\u043C, \u043D\u043E \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u043D\u0440\u0430\u0432\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u0447\u0442\u043E \u043E\u0442\u0440\u0430\u0436\u0430\u043B\u043E\u0441\u044C
    \u043D\u0430 \u0432\u0441\u0435\u0439 \u0435\u0433\u043E \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438. 
    *   **\u0423\u0442\u0438\u043B\u0438\u0442\u0430\u0440\u0438\u0437\u043C:** \u0412
    \u0441\u0432\u043E\u0438\u0445 \u044D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0432\u0437\u0433\u043B\u044F\u0434\u0430\u0445 \u043E\u043D \u043F\u0440\u0438\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0441\u044F
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430 \u0443\u0442\u0438\u043B\u0438\u0442\u0430\u0440\u0438\u0437\u043C\u0430,
    \u0441\u0447\u0438\u0442\u0430\u044F \u0432\u044B\u0441\u0448\u0435\u0439 \u0446\u0435\u043B\u044C\u044E
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F \u0431\u043B\u0430\u0433\u043E
    \u0432\u0441\u0435\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430.
    \u0415\u0433\u043E \u043B\u0438\u0431\u0435\u0440\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u043E-\u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u0441\u0442\u0430\u043B\u0438 \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439
    \u0435\u0433\u043E \u0443\u0432\u043E\u043B\u044C\u043D\u0435\u043D\u0438\u044F
    \u0438 \u0438\u0437\u0433\u043D\u0430\u043D\u0438\u044F \u0438\u0437 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u0432 1819 \u0433\u043E\u0434\u0443.  \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C,
    \u0432\u043A\u043B\u0430\u0434 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u043E\u0433\u0440\u043E\u043C\u0435\u043D \u0438 \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u0435\u043D.
    \u041E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0435\u0448\u0438\u043B
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447; \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u043D\u043E\u0432\u044B\u0439 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0439
    \u0434\u043B\u044F \u0432\u0441\u0435\u0439 \u043D\u0430\u0443\u043A\u0438, \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0432
    \u043C\u043E\u0441\u0442\u044B \u043C\u0435\u0436\u0434\u0443 \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430, \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C\u044E
    \u043B\u043E\u0433\u0438\u043A\u0438 \u0438 \u043D\u0440\u0430\u0432\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0435\u0439. \u0415\u0433\u043E
    \u0438\u0434\u0435\u0438, \u043E\u0431\u043E\u0433\u043D\u0430\u0432 \u0432\u0440\u0435\u043C\u044F
    \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F,
    \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u0438 \u043B\u0438\u0446\u043E
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u043B\u043E\u0433\u0438\u043A\u0438."
  achievementsEn: 
  personalLifeRu: "\u0425\u043E\u0442\u044F \u0411\u0435\u0440\u043D\u0430\u0440\u0434
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0438 \u043D\u0435 \u0431\u044B\u043B
    \u0436\u0435\u043D\u0430\u0442 \u0438 \u043D\u0435 \u0438\u043C\u0435\u043B \u0434\u0435\u0442\u0435\u0439,
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C\u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u043C\u0438:
    \u0441 \u0441\u0435\u043C\u044C\u0435\u0439, \u0441 \u0435\u0434\u0438\u043D\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438
    \u0438 \u0441 \u0432\u0435\u0440\u043E\u0439, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0432 \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C \u0441\u0447\u0435\u0442\u0435
    \u043F\u0440\u0438\u0432\u0435\u043B\u0430 \u0435\u0433\u043E \u043A \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0443
    \u0441 \u0446\u0435\u0440\u043A\u043E\u0432\u043D\u044B\u043C\u0438 \u0438 \u0441\u0432\u0435\u0442\u0441\u043A\u0438\u043C\u0438
    \u0432\u043B\u0430\u0441\u0442\u044F\u043C\u0438. \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u0447\u044C\u0438 \u043B\u0438\u0447\u043D\u044B\u0435 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F
    \u0438 \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u0438
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0438 \u0435\u0433\u043E
    \u0441\u0443\u0434\u044C\u0431\u0443.  ### \U0001F46A \u0421\u0435\u043C\u044C\u044F
    \u0438 \u0434\u0435\u0442\u0441\u0442\u0432\u043E  \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 5 \u043E\u043A\u0442\u044F\u0431\u0440\u044F
    1781 \u0433\u043E\u0434\u0430 \u0432 \u041F\u0440\u0430\u0433\u0435 \u0432 \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0439 \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0435\u043C\u044C\u0435. \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u0411\u0435\u0440\u043D\u0430\u0440\u0434 \u041F\u043E\u043C\u043F\u0435\u0439
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E, \u0431\u044B\u043B \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u043C
    \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0435\u043C \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430\u043C\u0438
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u041F\u0440\u0430\u0433\u0443.
    \u041C\u0430\u0442\u044C, \u041C\u0430\u0440\u0438\u044F \u0421\u0435\u0441\u0438\u043B\u0438\u044F
    \u041C\u0430\u0443\u0440\u0435\u0440, \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0430
    \u0438\u0437 \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u044F\u0437\u044B\u0447\u043D\u043E\u0439
    \u043A\u0443\u043F\u0435\u0447\u0435\u0441\u043A\u043E\u0439 \u0441\u0435\u043C\u044C\u0438
    \u0438 \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B\u0430 \u043D\u0430\u0431\u043E\u0436\u043D\u043E\u0439
    \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u043A\u043E\u0439. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430
    \u0442\u043E, \u0447\u0442\u043E \u0434\u043E\u043C\u0430 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438
    \u043F\u043E-\u043D\u0435\u043C\u0435\u0446\u043A\u0438, \u0447\u0435\u0448\u0441\u043A\u0430\u044F
    \u0441\u0440\u0435\u0434\u0430 \u043E\u043A\u0430\u0437\u0430\u043B\u0430 \u043D\u0430
    \u043D\u0435\u0433\u043E \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435.  \u0411\u0435\u0440\u043D\u0430\u0440\u0434
    \u0431\u044B\u043B \u0447\u0435\u0442\u0432\u0435\u0440\u0442\u044B\u043C \u0438\u0437
    \u0434\u0432\u0435\u043D\u0430\u0434\u0446\u0430\u0442\u0438 \u0434\u0435\u0442\u0435\u0439.
    **\u0422\u0440\u0430\u0433\u0435\u0434\u0438\u044F \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u0438
    \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0430\u0441\u044C \u0432 \u0442\u043E\u043C,
    \u0447\u0442\u043E \u0434\u043E \u0432\u0437\u0440\u043E\u0441\u043B\u043E\u0433\u043E
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0430 \u0434\u043E\u0436\u0438\u043B\u0438
    \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u043D \u0438 \u0435\u0433\u043E \u0431\u0440\u0430\u0442
    \u0418\u043E\u0433\u0430\u043D\u043D** (Johann). \u0415\u0433\u043E \u043E\u0442\u0435\u0446
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0435\u043C,
    \u043D\u043E \u0438 \u0444\u0438\u043B\u0430\u043D\u0442\u0440\u043E\u043F\u043E\u043C
    \u2014 \u043E\u043D \u0431\u044B\u043B \u0434\u0432\u0438\u0436\u0443\u0449\u0435\u0439
    \u0441\u0438\u043B\u043E\u0439 \u0432 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438
    \u043F\u0440\u0430\u0436\u0441\u043A\u043E\u0433\u043E \u043F\u0440\u0438\u044E\u0442\u0430,
    \u0447\u0442\u043E, \u043D\u0435\u0441\u043E\u043C\u043D\u0435\u043D\u043D\u043E,
    \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u043E \u043D\u0430 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0430 \u0441\u0430\u043C\u043E\u0433\u043E
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E.  \u0421\u0430\u043C \u0411\u0435\u0440\u043D\u0430\u0440\u0434
    \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430 \u043E\u0442\u043B\u0438\u0447\u0430\u043B\u0441\u044F
    \u0441\u043B\u0430\u0431\u044B\u043C \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435\u043C
    \u0438 \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C \u0441\u0442\u0440\u0430\u0434\u0430\u043B
    \u043E\u0442 \u043F\u0440\u043E\u0431\u043B\u0435\u043C \u0441 \u0434\u044B\u0445\u0430\u043D\u0438\u0435\u043C. 
    ### \U0001F6E4\uFE0F \u041F\u0443\u0442\u044C \u043A \u0441\u0432\u044F\u0449\u0435\u043D\u0441\u0442\u0432\u0443
    \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0443\u0440\u0435  \u0421 1791
    \u043F\u043E 1796 \u0433\u043E\u0434 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0443\u0447\u0438\u043B\u0441\u044F \u0432 \u043F\u0440\u0430\u0436\u0441\u043A\u043E\u0439
    \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0438 \u043F\u0438\u0430\u0440\u0438\u0441\u0442\u043E\u0432
    \u2014 \u043E\u0440\u0434\u0435\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u0430\u0432\u0430\u043B \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u043E\u0431\u0435\u0442 \u0437\u0430\u0431\u043E\u0442\u0438\u0442\u044C\u0441\u044F
    \u043E \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0438 \u043C\u043E\u043B\u043E\u0434\u0435\u0436\u0438.
    \u042D\u0442\u043E \u0443\u043A\u0440\u0435\u043F\u0438\u043B\u043E \u0432 \u043D\u0435\u043C
    \u043D\u0435 \u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435
    \u0434\u043E\u0433\u043C\u044B, \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0435
    \u043D\u0440\u0430\u0432\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F
    \u0438 \u0432\u0435\u0440\u0443 \u0432 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E\u0441\u0442\u044C. 
    \u0412 1796 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u041A\u0430\u0440\u043B\u043E\u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u0432 \u041F\u0440\u0430\u0433\u0435, \u0438\u0437\u0443\u0447\u0430\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E,
    \u0444\u0438\u0437\u0438\u043A\u0443 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443.
    \u041D\u0430 \u043D\u0435\u0433\u043E \u0441\u0438\u043B\u044C\u043D\u043E \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0438
    \u0442\u0440\u0443\u0434\u044B \u0410\u0431\u0440\u0430\u0445\u0430\u043C\u0430
    \u0413\u043E\u0442\u0442\u0445\u0435\u043B\u044C\u0444\u0430 \u041A\u0435\u0441\u0442\u043D\u0435\u0440\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F
    \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C \u0434\u0430\u0436\u0435
    \u0441\u0430\u043C\u044B\u0435 \xAB\u043E\u0447\u0435\u0432\u0438\u0434\u043D\u044B\u0435\xBB
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u044F.  \u0412 1800
    \u0433\u043E\u0434\u0443, **\u043F\u0440\u043E\u0442\u0438\u0432 \u0432\u043E\u043B\u0438
    \u043E\u0442\u0446\u0430**, \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044E. \u0412 1804 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u043F\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438,
    \u0430 \u0432\u0441\u0435\u0433\u043E \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0430
    \u0434\u043D\u044F \u0431\u044B\u043B \u0440\u0443\u043A\u043E\u043F\u043E\u043B\u043E\u0436\u0435\u043D
    \u0432 \u0441\u0430\u043D \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430. \u0412 1805 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u043D\u0430 \u043D\u0435\u0434\u0430\u0432\u043D\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u0443\u044E
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u0440\u0435\u043B\u0438\u0433\u0438\u0438 \u0432 \u041F\u0440\u0430\u0433\u0435,
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E
    \u0431\u044B\u043B \u0442\u0430\u043A\u0436\u0435 \u043F\u0435\u0440\u0432\u044B\u043C
    \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u043E\u043C \u0438 \u043D\u0430
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    ### \u26A1 \u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u0441 \u0432\u043B\u0430\u0441\u0442\u044F\u043C\u0438
    \u0438 \u043A\u0440\u0443\u0448\u0435\u043D\u0438\u0435 \u043A\u0430\u0440\u044C\u0435\u0440\u044B 
    \u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441 \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0441\u044F
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u043A\u0430\u0444\u0435\u0434\u0440\u0430
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u0440\u0435\u043B\u0438\u0433\u0438\u0438
    \u0431\u044B\u043B\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0430 \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u043E\u043C
    \u0424\u0440\u0430\u043D\u0446\u0435\u043C I \u0434\u043B\u044F \u0443\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0438\u044F
    \u043F\u043E\u0437\u0438\u0446\u0438\u0439 \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0446\u0435\u0440\u043A\u0432\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0441\u0442\u0430\u043B \u043F\u043E\u043B\u043D\u043E\u0439 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C\u044E
    \u0442\u043E\u0433\u043E, \u043D\u0430 \u0447\u0442\u043E \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u043B\u0438
    \u0432\u043B\u0430\u0441\u0442\u0438. \u0415\u0433\u043E \u043B\u0435\u043A\u0446\u0438\u0438
    \u0431\u044B\u043B\u0438 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u044B,
    \u043E\u043D \u043F\u0440\u043E\u043F\u043E\u0432\u0435\u0434\u043E\u0432\u0430\u043B
    \u0438\u0434\u0435\u0438 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E\u0441\u0442\u0438,
    \u043F\u0430\u0446\u0438\u0444\u0438\u0437\u043C\u0430 \u0438 \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B
    \u043C\u0438\u043B\u0438\u0442\u0430\u0440\u0438\u0437\u043C. \u041E\u043D \u043E\u0441\u0443\u0436\u0434\u0430\u043B
    \u0434\u0438\u0441\u043A\u0440\u0438\u043C\u0438\u043D\u0430\u0446\u0438\u044E
    \u0447\u0435\u0448\u0441\u043A\u043E\u0433\u043E \u043D\u0430\u0441\u0435\u043B\u0435\u043D\u0438\u044F
    \u0438 \u0430\u043D\u0442\u0438\u0441\u0435\u043C\u0438\u0442\u0438\u0437\u043C. 
    \u042D\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0442\u043E\u043C\u0443,
    \u0447\u0442\u043E \u043F\u0440\u043E\u0442\u0438\u0432 \u043D\u0435\u0433\u043E
    \u0431\u044B\u043B\u0438 \u0432\u043E\u0437\u0431\u0443\u0436\u0434\u0435\u043D\u044B
    \u0434\u0435\u043B\u0430 \u0432 \u0432\u0435\u043D\u0441\u043A\u043E\u043C \u0441\u0443\u0434\u0435.
    \u0412 \u0434\u0435\u043A\u0430\u0431\u0440\u0435 1819 \u0433\u043E\u0434\u0430
    \u043E\u043D \u0431\u044B\u043B \u043E\u0442\u0441\u0442\u0440\u0430\u043D\u0435\u043D
    \u043E\u0442 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0443\u0440\u044B \u0438
    \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u0435\u043D \u0432 \u0441\u0441\u044B\u043B\u043A\u0443
    \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u044E. \u0412 1821\u20131825 \u0433\u043E\u0434\u0430\u0445
    \u043F\u0440\u043E\u0442\u0438\u0432 \u043D\u0435\u0433\u043E \u0432\u0435\u043B\u0441\u044F
    \u0446\u0435\u0440\u043A\u043E\u0432\u043D\u044B\u0439 \u0441\u0443\u0434 \u043F\u043E
    \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u044E \u0432 \u0435\u0440\u0435\u0441\u0438.
    \u0415\u043C\u0443 \u0431\u044B\u043B\u043E \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043E
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C, \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u0440\u0430\u0431\u043E\u0442\u044B (\u0437\u0430 \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435\u043C
    \u043D\u0435\u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0433\u043E
    \u0438 \u043D\u0435\u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u044F), \u0430 \u0435\u0433\u043E
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430 \u043F\u043E\u0434\u0432\u0435\u0440\u0433\u0430\u043B\u0430\u0441\u044C
    \u0446\u0435\u043D\u0437\u0443\u0440\u0435.  ### \U0001F4DA \u0413\u043E\u0434\u044B
    \u0438\u0437\u0433\u043D\u0430\u043D\u0438\u044F, \u0434\u0440\u0443\u0436\u0431\u0430
    \u0438 \u0441\u043C\u0435\u0440\u0442\u044C  \u0421 1823 \u0433\u043E\u0434\u0430
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0436\u0438\u043B \u043F\u0440\u0435\u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u0432 \u043F\u043E\u043C\u0435\u0441\u0442\u044C\u0435 \u0441\u0432\u043E\u0438\u0445
    \u0434\u0440\u0443\u0437\u0435\u0439 \u0438 \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u0435\u0439,
    \u0441\u0435\u043C\u044C\u0438 \u0413\u043E\u0444\u043C\u0430\u043D, \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435
    \u0422\u0435\u0445\u043E\u0431\u0443\u0437 (Techobuz) \u0432 \u042E\u0436\u043D\u043E\u0439
    \u0411\u043E\u0433\u0435\u043C\u0438\u0438, \u043F\u0440\u043E\u0432\u043E\u0434\u044F
    \u043B\u0435\u0442\u043E \u0443 \u043D\u0438\u0445, \u0430 \u0437\u0438\u043C\u0443
    \u2014 \u0432 \u041F\u0440\u0430\u0433\u0435 \u0443 \u0431\u0440\u0430\u0442\u0430
    \u0418\u043E\u0433\u0430\u043D\u043D\u0430. **\u0419\u043E\u0437\u0435\u0444
    \u0413\u043E\u0444\u043C\u0430\u043D \u0431\u044B\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0440\u0435\u0446\u0435\u043D\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0440\u0430\u0431\u043E\u0442\u044B \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E,
    \u0430 \u0435\u0433\u043E \u0436\u0435\u043D\u0430 \u0410\u043D\u043D\u0430 \u0441\u0442\u0430\u043B\u0430
    \u0431\u043B\u0438\u0437\u043A\u0438\u043C \u0434\u0440\u0443\u0433\u043E\u043C**.
    \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0441\u0430\u043C\u044B\u043C \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C:
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u044E,
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u0438
    \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B.  \u041A\u043E\u0433\u0434\u0430
    \u0410\u043D\u043D\u0430 \u0413\u043E\u0444\u043C\u0430\u043D \u0437\u0430\u0431\u043E\u043B\u0435\u043B\u0430
    \u0432 1841 \u0433\u043E\u0434\u0443, \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u0441\u0435\u043C\u044C\u0435\u0439
    \u0413\u043E\u0444\u043C\u0430\u043D \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u041F\u0440\u0430\u0433\u0443, \u0433\u0434\u0435 \u043E\u043D\u0438
    \u0432\u0441\u0435 \u0436\u0438\u043B\u0438 \u0443 \u0431\u0440\u0430\u0442\u0430
    \u0418\u043E\u0433\u0430\u043D\u043D\u0430 (\u0410\u043D\u043D\u0430 \u0443\u043C\u0435\u0440\u043B\u0430
    \u0432 1842 \u0433\u043E\u0434\u0443). \u0422\u0430\u043C \u043E\u043D \u0441\u043D\u043E\u0432\u0430
    \u0441\u0442\u0430\u043B \u0430\u043A\u0442\u0438\u0432\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u0431\u043E\u0433\u0435\u043C\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u043D\u0430\u0443\u043A \u0438
    \u0434\u0430\u0436\u0435 \u0431\u044B\u043B \u0435\u0433\u043E \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u0432 1842\u20131843 \u0433\u043E\u0434\u0430\u0445.  **\u0411\u0435\u0440\u043D\u0430\u0440\u0434
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 \u041F\u0440\u0430\u0433\u0435 18 \u0434\u0435\u043A\u0430\u0431\u0440\u044F
    1848 \u0433\u043E\u0434\u0430 \u043E\u0442 \u043F\u0440\u043E\u0441\u0442\u0443\u0434\u044B,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0434\u0430\u043B\u0430 \u043E\u0441\u043B\u043E\u0436\u043D\u0435\u043D\u0438\u044F
    \u043D\u0430 \u0435\u0433\u043E \u0441\u043B\u0430\u0431\u044B\u0435 \u043B\u0435\u0433\u043A\u0438\u0435**. 
    ### \u2764\uFE0F \u0424\u0438\u043B\u0430\u043D\u0442\u0440\u043E\u043F\u0438\u044F
    \u0438 \u043B\u0438\u0447\u043D\u044B\u0435 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F 
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0431\u044B\u043B \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0447\u0435\u043D\u044B\u043C, \u043D\u043E
    \u0438 \u0444\u0438\u043B\u0430\u043D\u0442\u0440\u043E\u043F\u043E\u043C. \u0412\u043C\u0435\u0441\u0442\u0435
    \u0441 \u0434\u0440\u0443\u0437\u044C\u044F\u043C\u0438 \u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C\u0438
    \u043E\u043D \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0434\u043E\u043C\u043E\u0432
    \u0434\u043B\u044F \u0431\u0435\u0434\u043D\u044B\u0445, \u043F\u0440\u0438\u044E\u0442\u043E\u0432
    \u0434\u043B\u044F \u0441\u043B\u0435\u043F\u044B\u0445, \u0441\u0441\u0443\u0434\u043D\u044B\u0445
    \u043A\u0430\u0441\u0441 \u0434\u043B\u044F \u0440\u0430\u0431\u043E\u0447\u0435\u0433\u043E
    \u043A\u043B\u0430\u0441\u0441\u0430, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A
    \u0438 \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u044B\u0445 \u0448\u043A\u043E\u043B
    \u0432 \u0441\u0435\u043B\u044C\u0441\u043A\u043E\u0439 \u043C\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u0438.
    \u0415\u0433\u043E \u043B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0434\u0447\u0438\u043D\u0435\u043D\u0430 \u0435\u0433\u043E \u043D\u0440\u0430\u0432\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u043D \u043F\u0440\u0435\u0442\u0432\u043E\u0440\u044F\u043B \u0432 \u0436\u0438\u0437\u043D\u044C,
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438 \u0437\u0430\u043F\u0440\u0435\u0442\u044B. \u041E\u043D \u0431\u044B\u043B
    \xAB\u0432\u0435\u0440\u043D\u044B\u043C \u0441\u044B\u043D\u043E\u043C \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0446\u0435\u0440\u043A\u0432\u0438\xBB, \u043D\u043E \u043F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0441\u0442\u043E\u043C,
    \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u0432\u0448\u0438\u043C\u0441\u044F
    \u043E\u0442\u0440\u0435\u043A\u0430\u0442\u044C\u0441\u044F \u043E\u0442 \u0441\u0432\u043E\u0438\u0445
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u0439."
  personalLifeEn: 
  shortBioRu: "\u0411\u0435\u0440\u043D\u0430\u0440\u0434 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    (Bernard Placidus Johann Nepomuk Bolzano, 1781\u20131848) \u2014 \u0447\u0435\u0448\u0441\u043A\u0438\u0439
    (\u0431\u043E\u0433\u0435\u043C\u0441\u043A\u0438\u0439) \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043B\u043E\u0433\u0438\u043A, \u0444\u0438\u043B\u043E\u0441\u043E\u0444, \u0442\u0435\u043E\u043B\u043E\u0433
    \u0438 \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F,
    \u0447\u044C\u0438 \u0438\u0434\u0435\u0438 \u043D\u0430\u043C\u043D\u043E\u0433\u043E
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438 \u0441\u0432\u043E\u0451
    \u0432\u0440\u0435\u043C\u044F. \u041E\u043D \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C \u0441\u0442\u0430\u043B\u0430
    \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u0435\u043C \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0430 \u043C\u0435\u0436\u0434\u0443
    \u043F\u0435\u0440\u0435\u0434\u043E\u0432\u043E\u0439 \u043C\u044B\u0441\u043B\u044C\u044E
    \u041F\u0440\u043E\u0441\u0432\u0435\u0449\u0435\u043D\u0438\u044F \u0438 \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u0442\u0438\u0432\u043D\u044B\u043C
    \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u0438\u0437\u043C\u043E\u043C \u0410\u0432\u0441\u0442\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u0438\u043C\u043F\u0435\u0440\u0438\u0438.  \u0412 \u044D\u0442\u043E\u043C
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u043C \u043E\u0431\u0437\u043E\u0440\u0435
    \u043C\u044B \u043F\u0440\u043E\u0441\u043B\u0435\u0434\u0438\u043C \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0439 \u043F\u0443\u0442\u044C,
    \u043E\u0442 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0432 \u041F\u0440\u0430\u0433\u0435
    \u0434\u043E \u0438\u0437\u0433\u043D\u0430\u043D\u0438\u044F \u0438 \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0433\u043E
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u043E \u0440\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0438\u043C
    \u0435\u0433\u043E \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u043B\u043E\u0433\u0438\u043A\u0443 \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E. 
    ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B,
    \u0441\u0435\u043C\u044C\u044F \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 
    *   **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0441\u0435\u043C\u044C\u044F:** \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 5 \u043E\u043A\u0442\u044F\u0431\u0440\u044F
    1781 \u0433\u043E\u0434\u0430 \u0432 \u041F\u0440\u0430\u0433\u0435, \u0432 \u0441\u0430\u043C\u043E\u043C
    \u0441\u0435\u0440\u0434\u0446\u0435 \u0411\u043E\u0433\u0435\u043C\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u0442\u0432\u0430 (\u0442\u043E\u0433\u0434\u0430
    \u0447\u0430\u0441\u0442\u044C \u0438\u043C\u043F\u0435\u0440\u0438\u0438 \u0413\u0430\u0431\u0441\u0431\u0443\u0440\u0433\u043E\u0432).
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u0411\u0435\u0440\u043D\u0430\u0440\u0434
    \u041F\u043E\u043C\u043F\u0435\u0439 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E,
    \u0431\u044B\u043B \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u043C
    \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0435\u043C \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430\u043C\u0438
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430, \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u0432\u0448\u0438\u043C
    \u0432 \u041F\u0440\u0430\u0433\u0443, \u0430 \u043C\u0430\u0442\u044C, \u041C\u0430\u0440\u0438\u044F
    \u0421\u0435\u0441\u0438\u043B\u0438\u044F \u041C\u0430\u0443\u0440\u0435\u0440,
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0430 \u0438\u0437
    \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u044F\u0437\u044B\u0447\u043D\u043E\u0439
    \u043F\u0440\u0430\u0436\u0441\u043A\u043E\u0439 \u043A\u0443\u043F\u0435\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0435\u043C\u044C\u0438. \u0420\u043E\u0434\u0438\u0442\u0435\u043B\u0438
    \u0431\u044B\u043B\u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0432\u0435\u0440\u0443\u044E\u0449\u0438\u043C\u0438
    \u043A\u0430\u0442\u043E\u043B\u0438\u043A\u0430\u043C\u0438. \u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u0438\u0437 \u0434\u0432\u0435\u043D\u0430\u0434\u0446\u0430\u0442\u0438 \u0434\u0435\u0442\u0435\u0439
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u0434\u043E \u0432\u0437\u0440\u043E\u0441\u043B\u043E\u0433\u043E
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0430 \u0434\u043E\u0436\u0438\u043B\u0438
    \u0442\u043E\u043B\u044C\u043A\u043E \u0411\u0435\u0440\u043D\u0430\u0440\u0434
    \u0438 \u0435\u0433\u043E \u0431\u0440\u0430\u0442 \u0418\u043E\u0433\u0430\u043D\u043D.
    *   **\u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u0432\u043B\u0438\u044F\u043D\u0438\u0435:**
    \u041D\u0430 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0441\u0438\u043B\u044C\u043D\u043E \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u043E
    \u0431\u043B\u0430\u0433\u043E\u0447\u0435\u0441\u0442\u0438\u0435 \u043E\u0442\u0446\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u0441\u0442\u043E\u044F\u043B \u0443 \u0438\u0441\u0442\u043E\u043A\u043E\u0432
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F \u043F\u0440\u0430\u0436\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u0438\u044E\u0442\u0430, \u0430 \u0442\u0430\u043A\u0436\u0435 \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435
    \u0432 \u041F\u0440\u0430\u0436\u0441\u043A\u043E\u0439 \u043F\u0438\u0430\u0440\u0438\u0441\u0442\u0441\u043A\u043E\u0439
    \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0438 (1791\u20131796). \u041F\u0438\u0430\u0440\u0438\u0441\u0442\u044B
    \u2014 \u043C\u043E\u043D\u0430\u0448\u0435\u0441\u043A\u0438\u0439 \u043E\u0440\u0434\u0435\u043D,
    \u0434\u0430\u0432\u0430\u0432\u0448\u0438\u0439 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u043E\u0431\u0435\u0442 \u0437\u0430\u0431\u043E\u0442\u0438\u0442\u044C\u0441\u044F
    \u043E \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0438 \u043C\u043E\u043B\u043E\u0434\u0435\u0436\u0438.
    \u042D\u0442\u0430 \u0441\u0440\u0435\u0434\u0430 \u0443\u043A\u0440\u0435\u043F\u0438\u043B\u0430
    \u0432 \u044E\u043D\u043E\u043C \u0411\u0435\u0440\u043D\u0430\u0440\u0434\u0435
    \u043D\u0435 \u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435
    \u0434\u043E\u0433\u043C\u044B, \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0435
    \u043D\u0440\u0430\u0432\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F
    \u0438 \u0432\u0435\u0440\u0443 \u0432 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E\u0441\u0442\u044C.
    *   **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B:** \u0412 1796 \u0433\u043E\u0434\u0443 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u043D\u0430 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0439
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442 \u041A\u0430\u0440\u043B\u043E\u0432\u0430
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0432
    \u041F\u0440\u0430\u0433\u0435, \u0433\u0434\u0435 \u0438\u0437\u0443\u0447\u0430\u043B
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E, \u0444\u0438\u0437\u0438\u043A\u0443
    \u0438, \u0447\u0442\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432\u0430\u0436\u043D\u043E,
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443. \u0415\u0433\u043E
    \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u043B\u0438 \u0442\u0440\u0443\u0434\u044B
    \u0410\u0431\u0440\u0430\u0445\u0430\u043C\u0430 \u0413\u043E\u0442\u0442\u0445\u0435\u043B\u044C\u0444\u0430
    \u041A\u0435\u0441\u0442\u043D\u0435\u0440\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u0434\u0430\u0436\u0435 \u0441\u0430\u043C\u044B\u0435 \xAB\u043E\u0447\u0435\u0432\u0438\u0434\u043D\u044B\u0435\xBB
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u044F. \u0412 1800
    \u0433\u043E\u0434\u0443, \u043F\u0440\u043E\u0442\u0438\u0432 \u0432\u043E\u043B\u0438
    \u043E\u0442\u0446\u0430, \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0442\u0430\u043A\u0436\u0435
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044E.
    \u0412 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D
    \u043F\u0438\u0441\u0430\u043B: *\xAB\u041C\u043E\u0435 \u043E\u0441\u043E\u0431\u043E\u0435
    \u0443\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u0435 \u0432
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u043F\u043E\u043A\u043E\u0438\u043B\u043E\u0441\u044C\u2026
    \u043D\u0430 \u0435\u0435 \u0447\u0438\u0441\u0442\u043E \u0443\u043C\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0447\u0430\u0441\u0442\u044F\u0445, \u0438\u043D\u044B\u043C\u0438 \u0441\u043B\u043E\u0432\u0430\u043C\u0438,
    \u044F \u0446\u0435\u043D\u0438\u043B \u043B\u0438\u0448\u044C \u0442\u0443 \u0447\u0430\u0441\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u0431\u044B\u043B\u0430
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0435\u0439\xBB*. \u0412 1804
    \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u043F\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438, \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0432
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u043F\u043E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u0441\u0432\u043E\u0439 \u0432\u0437\u0433\u043B\u044F\u0434
    \u043D\u0430 \u043F\u0440\u0438\u0440\u043E\u0434\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430.
    \u0412\u0441\u0435\u0433\u043E \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0430
    \u0434\u043D\u044F \u043F\u043E\u0441\u043B\u0435 \u0437\u0430\u0449\u0438\u0442\u044B
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438, \u0432 1804
    \u0433\u043E\u0434\u0443, \u043E\u043D \u0431\u044B\u043B \u0440\u0443\u043A\u043E\u043F\u043E\u043B\u043E\u0436\u0435\u043D
    \u0432 \u0441\u0430\u043D \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430.  ### \U0001F3DB\uFE0F
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0438 \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442
    \u0441 \u0432\u043B\u0430\u0441\u0442\u044F\u043C\u0438  *   **\u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0443\u0440\u0430:**
    \u0412 1805 \u0433\u043E\u0434\u0443 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D \u043D\u0430
    \u043D\u043E\u0432\u0443\u044E \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u0440\u0435\u043B\u0438\u0433\u0438\u0438 \u0432 \u041A\u0430\u0440\u043B\u043E\u0432\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E \u043E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u043C \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u043E\u043C
    \u0438 \u043D\u0430 \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u043A\u0430\u0444\u0435\u0434\u0440\u0430
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u0440\u0435\u043B\u0438\u0433\u0438\u0438
    \u0431\u044B\u043B\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0430 \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u043E\u043C
    \u0424\u0440\u0430\u043D\u0446\u0435\u043C I \u0434\u043B\u044F \u0443\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0438\u044F
    \u043F\u043E\u0437\u0438\u0446\u0438\u0439 \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0446\u0435\u0440\u043A\u0432\u0438
    \u0432 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0432\u0435\u0441 \u0438\u0434\u0435\u044F\u043C
    \u041F\u0440\u043E\u0441\u0432\u0435\u0449\u0435\u043D\u0438\u044F. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0441\u0442\u0430\u043B \u043F\u043E\u043B\u043D\u043E\u0439
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C\u044E
    \u0442\u043E\u0433\u043E, \u043D\u0430 \u0447\u0442\u043E \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u043B\u0438
    \u0432\u043B\u0430\u0441\u0442\u0438. \u0415\u0433\u043E \u043B\u0435\u043A\u0446\u0438\u0438
    \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438\u0441\u044C \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u044C\u044E
    \u0443 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432, \u043E\u043D \u0431\u044B\u043B
    \u0438\u0437\u0431\u0440\u0430\u043D \u0434\u0435\u043A\u0430\u043D\u043E\u043C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0433\u043E \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0430
    \u0432 1818 \u0433\u043E\u0434\u0443. *   **\u041B\u0438\u0431\u0435\u0440\u0430\u043B\u044C\u043D\u044B\u0435
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u0438 \u0434\u043E\u043D\u043E\u0441:**
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u043F\u0430\u0446\u0438\u0444\u0438\u0441\u0442\u043E\u043C, \u0443\u0442\u0438\u043B\u0438\u0442\u0430\u0440\u0438\u0441\u0442\u043E\u043C
    \u0438 \u043F\u043E\u0431\u043E\u0440\u043D\u0438\u043A\u043E\u043C \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E\u0441\u0442\u0438.
    \u0412 \u0441\u0432\u043E\u0438\u0445 \u043F\u0440\u043E\u043F\u043E\u0432\u0435\u0434\u044F\u0445
    \u0438 \u043B\u0435\u043A\u0446\u0438\u044F\u0445 \u043E\u043D \u0440\u0435\u0437\u043A\u043E
    \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B \u043C\u0438\u043B\u0438\u0442\u0430\u0440\u0438\u0437\u043C,
    \u0432\u043E\u0439\u043D\u0443 \u0438 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u043D\u0435\u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u043E, \u043F\u0440\u0438\u0437\u044B\u0432\u0430\u044F
    \u043A \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430. \u041E\u043D \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B
    \u0437\u0430 \u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u043E \u0447\u0435\u0448\u0441\u043A\u043E\u0433\u043E
    \u0438 \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0433\u043E \u043D\u0430\u0441\u0435\u043B\u0435\u043D\u0438\u044F
    \u0432 \u0411\u043E\u0433\u0435\u043C\u0438\u0438, \u043E\u0441\u0443\u0436\u0434\u0430\u043B
    \u0430\u043D\u0442\u0438\u0441\u0435\u043C\u0438\u0442\u0438\u0437\u043C \u0438
    \u0437\u0430\u0449\u0438\u0449\u0430\u043B \u043F\u0440\u0430\u0432\u0430 \u043A\u0440\u0435\u0441\u0442\u044C\u044F\u043D.
    \u0422\u0430\u043A\u0438\u0435 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F
    \u0431\u044B\u0441\u0442\u0440\u043E \u0441\u0434\u0435\u043B\u0430\u043B\u0438
    \u0435\u0433\u043E \u0432\u0440\u0430\u0433\u043E\u043C \u0441\u0440\u0435\u0434\u0438
    \u0446\u0435\u0440\u043A\u043E\u0432\u043D\u044B\u0445 \u0438 \u0441\u0432\u0435\u0442\u0441\u043A\u0438\u0445
    \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u043E\u0432.
    \u0412 1816 \u0433\u043E\u0434\u0443 \u0432 \u0412\u0435\u043D\u0441\u043A\u043E\u043C
    \u0441\u0443\u0434\u0435 \u043D\u0430 \u043D\u0435\u0433\u043E \u0443\u0436\u0435
    \u0431\u044B\u043B\u0438 \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u044B \u0434\u0435\u043B\u0430.
    *   **\u0423\u0432\u043E\u043B\u044C\u043D\u0435\u043D\u0438\u0435 \u0438 \u0441\u0441\u044B\u043B\u043A\u0430:**
    \u041A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u0435\u0439 \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0430
    \u0441\u0442\u0430\u043B\u043E \u0434\u0435\u043A\u0430\u0431\u0440\u044C\u0441\u043A\u043E\u0435
    \u0443\u0432\u043E\u043B\u044C\u043D\u0435\u043D\u0438\u0435 1819 \u0433\u043E\u0434\u0430.
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442\u0440\u0435\u0447\u044C\u0441\u044F \u043E\u0442 \u0441\u0432\u043E\u0438\u0445
    \u0432\u0437\u0433\u043B\u044F\u0434\u043E\u0432 \u0438 \u0431\u044B\u043B \u043E\u0442\u0441\u0442\u0440\u0430\u043D\u0435\u043D
    \u043E\u0442 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0443\u0440\u044B. \u0415\u043C\u0443
    \u0431\u044B\u043B\u043E \u043F\u0440\u0435\u0434\u043F\u0438\u0441\u0430\u043D\u043E
    \u0436\u0438\u0442\u044C \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435, \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u0430
    \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F \u0440\u0430\u0431\u043E\u0442
    (\u0437\u0430 \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435\u043C
    \u0442\u0435\u0445, \u0447\u0442\u043E \u043D\u0435 \u043A\u0430\u0441\u0430\u043B\u0438\u0441\u044C
    \u0440\u0435\u043B\u0438\u0433\u0438\u0438 \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u0438)
    \u0438 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0430 \u0446\u0435\u043D\u0437\u0443\u0440\u0430
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0438. \u0412 1821\u20131825
    \u0433\u043E\u0434\u0430\u0445 \u043F\u0440\u043E\u0442\u0438\u0432 \u043D\u0435\u0433\u043E
    \u0432\u0435\u043B\u0441\u044F \u0446\u0435\u0440\u043A\u043E\u0432\u043D\u044B\u0439
    \u0441\u0443\u0434 \u043F\u043E \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u044E
    \u0432 \u0435\u0440\u0435\u0441\u0438. \u041E\u043D \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435
    \u0437\u0430\u0449\u0438\u0449\u0430\u043B \u0441\u0432\u043E\u0438 \u0432\u0437\u0433\u043B\u044F\u0434\u044B,
    \u043D\u043E \u0432 \u0438\u0442\u043E\u0433\u0435 \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u0431\u044B\u043B \u0443\u0439\u0442\u0438 \u0432 \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0443,
    \u0442\u0430\u043A \u0438 \u043D\u0435 \u043E\u0442\u0440\u0435\u043A\u0448\u0438\u0441\u044C
    \u043E\u0442 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u0439.  ### \u231B
    \u0413\u043E\u0434\u044B \u0438\u0437\u0433\u043D\u0430\u043D\u0438\u044F \u0438
    \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0432 \u041F\u0440\u0430\u0433\u0443 
    \u0421 1823 \u0433\u043E\u0434\u0430 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0436\u0438\u043B \u043F\u0440\u0435\u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435 \u0422\u0435\u0445\u043E\u0431\u0443\u0437
    (Techobuz) \u0432 \u042E\u0436\u043D\u043E\u0439 \u0411\u043E\u0433\u0435\u043C\u0438\u0438,
    \u0432 \u0438\u043C\u0435\u043D\u0438\u0438 \u0441\u0432\u043E\u0438\u0445 \u0434\u0440\u0443\u0437\u0435\u0439
    \u0438 \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u0435\u0439,
    \u0441\u0435\u043C\u044C\u0438 \u0413\u043E\u0444\u043C\u0430\u043D. \u041B\u0435\u0442\u043E\u043C
    \u043E\u043D \u0436\u0438\u043B \u0443 \u043D\u0438\u0445, \u0430 \u0437\u0438\u043C\u0443
    \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B \u0432 \u041F\u0440\u0430\u0433\u0435
    \u0443 \u0431\u0440\u0430\u0442\u0430. \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0441\u0442\u0430\u043B \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0441\u0430\u043C\u044B\u043C
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C \u0432
    \u043F\u043B\u0430\u043D\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0438
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445 \u0442\u0440\u0443\u0434\u043E\u0432.
    \u041E\u043D \u0438\u043C\u0435\u043B \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C
    \u0441\u0435\u0431\u044F \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\u043C,
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0437\u0430\u043F\u0440\u0435\u0442\u044B
    \u0438 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u044E. \u0412 1842 \u0433\u043E\u0434\u0443,
    \u043F\u043E\u0441\u043B\u0435 \u0431\u043E\u043B\u0435\u0437\u043D\u0438 \u0410\u043D\u043D\u044B
    \u0413\u043E\u0444\u043C\u0430\u043D, \u043E\u043D \u0432\u043C\u0435\u0441\u0442\u0435
    \u0441 \u0441\u0435\u043C\u044C\u0435\u0439 \u0434\u0440\u0443\u0437\u0435\u0439
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u041F\u0440\u0430\u0433\u0443,
    \u0433\u0434\u0435 \u0441\u043D\u043E\u0432\u0430 \u0441\u0442\u0430\u043B \u0430\u043A\u0442\u0438\u0432\u043D\u044B\u043C
    \u0447\u043B\u0435\u043D\u043E\u043C \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u0431\u043E\u0433\u0435\u043C\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430
    \u043D\u0430\u0443\u043A, \u0438 \u0434\u0430\u0436\u0435 \u0431\u044B\u043B
    \u0435\u0433\u043E \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u0432 1842\u20131843 \u0433\u043E\u0434\u0430\u0445. \u0411\u0435\u0440\u043D\u0430\u0440\u0434
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 \u041F\u0440\u0430\u0433\u0435 18 \u0434\u0435\u043A\u0430\u0431\u0440\u044F
    1848 \u0433\u043E\u0434\u0430 \u043E\u0442 \u043F\u0440\u043E\u0441\u0442\u0443\u0434\u044B,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0434\u0430\u043B\u0430 \u043E\u0441\u043B\u043E\u0436\u043D\u0435\u043D\u0438\u044F
    \u043D\u0430 \u0435\u0433\u043E \u0441\u043B\u0430\u0431\u044B\u0435 \u043B\u0435\u0433\u043A\u0438\u0435. 
    ### \U0001F4D0 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F  \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043F\u0438\u043E\u043D\u0435\u0440\u043E\u0432 \u0432 \u0434\u0435\u043B\u0435
    \u043F\u0440\u0438\u0434\u0430\u043D\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0430\u043D\u0430\u043B\u0438\u0437\u0443 \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u0438.
    \u041E\u043D \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F \u0438\u0437\u0431\u0430\u0432\u0438\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u043E\u0442 \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u044B\u0445
    \u043F\u043E\u043D\u044F\u0442\u0438\u0439 \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0438 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F, \u0441\u043E\u0437\u0434\u0430\u0432
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    (\xAB\u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E\xBB)
    \u043E\u0441\u043D\u043E\u0432\u0443. \u0415\u0433\u043E \u0438\u0434\u0435\u0438
    \u043D\u0430\u043C\u043D\u043E\u0433\u043E \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438
    \u0432\u0440\u0435\u043C\u044F \u0438 \u0431\u044B\u043B\u0438 \u0437\u0430\u043D\u043E\u0432\u043E
    \u043E\u0442\u043A\u0440\u044B\u0442\u044B \u043B\u0438\u0448\u044C \u0441\u043F\u0443\u0441\u0442\u044F
    \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F.  *   **\u0421\u0442\u0440\u043E\u0433\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u043F\u0440\u0435\u0434\u0435\u043B\u0430
    (\u03B5-\u03B4):** \u0412 \u0441\u0432\u043E\u0438\u0445 \u0440\u0430\u0431\u043E\u0442\u0430\u0445,
    \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A *\xABRein analytischer Beweis\xBB*
    (1817), \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0432\u0432\u0435\u043B
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u043F\u0440\u0435\u0434\u0435\u043B\u0430,
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0438\u0434\u0435\u043D\u0442\u0438\u0447\u043D\u043E\u0435
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C\u0443 \u044D\u043F\u0441\u0438\u043B\u043E\u043D-\u0434\u0435\u043B\u044C\u0442\u0430
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044E. \u041E\u043D
    \u043E\u0442\u0432\u0435\u0440\u0433\u0430\u043B \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044E
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E \u043C\u0430\u043B\u044B\u0445
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u0438 \u0441\u0442\u0440\u043E\u0438\u043B \u0430\u043D\u0430\u043B\u0438\u0437
    \u043D\u0430 \u0441\u0442\u0440\u043E\u0433\u043E\u0439 \u0447\u0438\u0441\u043B\u043E\u0432\u043E\u0439
    \u043E\u0441\u043D\u043E\u0432\u0435. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E (\u043E \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u0447\u043D\u043E\u043C
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0438):** \u0412 \u0442\u043E\u0439
    \u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0435 1817 \u0433\u043E\u0434\u0430
    \u043E\u043D \u0434\u0430\u043B \u043F\u0435\u0440\u0432\u043E\u0435 \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u0447\u043D\u043E\u043C
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0442\u0435\u043F\u0435\u0440\u044C \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u043A\u0430\u043A \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E.
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E\u2013\u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u0430:**
    \u042D\u0442\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    (\u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u0438\u0437 \u043B\u044E\u0431\u043E\u0439
    \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u043D\u043E\u0439 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u043C\u043E\u0436\u043D\u043E \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u044C
    \u0441\u0445\u043E\u0434\u044F\u0449\u0443\u044E\u0441\u044F \u043F\u043E\u0434\u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C)
    \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u0430 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0432 \u0435\u0433\u043E \u043D\u0435\u0438\u0437\u0434\u0430\u043D\u043D\u044B\u0445
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u0445.
    \u041A\u0430\u0440\u043B \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0435\u0435 \u043F\u043E\u0437\u0436\u0435, \u0438 \u0434\u043E\u043B\u0433\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u043D\u043E\u0441\u0438\u043B\u0430
    \u0442\u043E\u043B\u044C\u043A\u043E \u0435\u0433\u043E \u0438\u043C\u044F, \u043F\u043E\u043A\u0430
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043D\u0435 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B\u0438
    \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E.
    *   **\u041F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u041A\u043E\u0448\u0438:** \u0412 \u0441\u0432\u043E\u0435\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    1817 \u0433\u043E\u0434\u0430 \u043E\u043D \u0434\u0430\u043B \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u043F\u043E\u0437\u0436\u0435 \u0441\u0442\u0430\u043B\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043A\u0430\u043A \xAB\u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u041A\u043E\u0448\u0438\xBB, \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432
    \u041E\u0433\u044E\u0441\u0442\u0435\u043D\u0430 \u041B\u0443\u0438 \u041A\u043E\u0448\u0438
    \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E \u043D\u0430 \u0447\u0435\u0442\u044B\u0440\u0435
    \u0433\u043E\u0434\u0430. *   **\xAB\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u044B
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E\xBB:**
    \u0412 \u044D\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 (*Paradoxien
    des Unendlichen*, \u0438\u0437\u0434\u0430\u043D\u0430 \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E
    \u0432 1851 \u0433\u043E\u0434\u0443) \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u043F\u0435\u0440\u0432\u044B\u043C \u0432\u0432\u0435\u043B \u0441\u0442\u0440\u043E\u0433\u0438\u0435
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438 \u043D\u0430\u0434 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u043C\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430\u043C\u0438, \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u0432\u0437\u0430\u0438\u043C\u043D\u043E-\u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E
    \u0441\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043E \u0441\u043E
    \u0441\u0432\u043E\u0435\u0439 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0447\u0430\u0441\u0442\u044C\u044E, \u0438 \u0434\u0430\u043B \u043F\u0435\u0440\u0432\u044B\u0435
    \u0438\u0434\u0435\u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u043B\u0438 \u0413\u0435\u043E\u0440\u0433\u0430
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430, \u0420\u0438\u0445\u0430\u0440\u0434\u0430
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430 \u0438 \u0427\u0430\u0440\u043B\u044C\u0437\u0430
    \u0421\u0430\u043D\u0434\u0435\u0440\u0441\u0430 \u041F\u0438\u0440\u0441\u0430. 
    ### \U0001F9E0 \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0435
    \u0438 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0439
    \u0442\u0440\u0443\u0434 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u2014
    \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u0442\u043E\u043C\u043D\u0430\u044F
    **\xAB\u041D\u0430\u0443\u043A\u043E\u0443\u0447\u0435\u043D\u0438\u0435\xBB
    (*Wissenschaftslehre*, 1837)** \u2014 \u044D\u0442\u043E \u043F\u043E\u043F\u044B\u0442\u043A\u0430
    \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u0432\u0441\u0435\u043E\u0431\u044A\u0435\u043C\u043B\u044E\u0449\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u043D\u0430\u0443\u043A\u0438, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u0443\u044E
    \u043D\u0430 \u043B\u043E\u0433\u0438\u043A\u0435 \u0438 \u044D\u043F\u0438\u0441\u0442\u0435\u043C\u043E\u043B\u043E\u0433\u0438\u0438. 
    *   **\u0410\u043D\u0442\u0438\u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0437\u043C:**
    \u041A\u043B\u044E\u0447\u0435\u0432\u0430\u044F \u0438\u0434\u0435\u044F \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u2014 \u0436\u0435\u0441\u0442\u043A\u043E\u0435 \u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043B\u043E\u0433\u0438\u043A\u0438 \u0438 \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0438.
    \u041E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E
    \u0437\u0430\u043A\u043E\u043D\u044B \u043B\u043E\u0433\u0438\u043A\u0438 \u0438
    \u0438\u0441\u0442\u0438\u043D\u044B \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442
    \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u043E, \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E
    \u043E\u0442 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F \u0438 \u044F\u0437\u044B\u043A\u0430.
    \u042D\u0442\u043E \u0440\u0435\u0437\u043A\u043E \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u043E
    \u0441 \u0433\u043E\u0441\u043F\u043E\u0434\u0441\u0442\u0432\u043E\u0432\u0430\u0432\u0448\u0438\u043C
    \u0442\u043E\u0433\u0434\u0430 \u043F\u043E\u0434\u0445\u043E\u0434\u043E\u043C
    \u0438 \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u043B\u043E
    \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u043F\u0440\u0438\u043D\u0446\u0438\u043F
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438. *   **\xAB\u041F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0441\u0430\u043C\u043E \u043F\u043E \u0441\u0435\u0431\u0435\xBB (*Satz an
    sich*):** \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0432\u0432\u0435\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E,
    \u0431\u0435\u0437\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u0438 \u0431\u0435\u0437\u043C\u0435\u0441\u0442\u043D\u043E\u0433\u043E \xAB\u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u0441\u0430\u043C\u043E\u0433\u043E \u043F\u043E \u0441\u0435\u0431\u0435\xBB
    \u2014 \u0441\u043C\u044B\u0441\u043B\u0430 \u0441\u0443\u0436\u0434\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C
    \u0438\u0441\u0442\u0438\u043D\u043D\u044B\u043C \u0438\u043B\u0438 \u043B\u043E\u0436\u043D\u044B\u043C,
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E \u043E\u0442 \u0442\u043E\u0433\u043E,
    \u043C\u044B\u0441\u043B\u0438\u0442 \u043B\u0438 \u0435\u0433\u043E \u043A\u0442\u043E-\u0442\u043E
    \u0438\u043B\u0438 \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u0442.
    \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u0430\u044F
    \u043E\u043D\u0442\u043E\u043B\u043E\u0433\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0430 \u043D\u0430 \u042D\u0434\u043C\u0443\u043D\u0434\u0430
    \u0413\u0443\u0441\u0441\u0435\u0440\u043B\u044F, \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u044F
    \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u043E\u043B\u043E\u0433\u0438\u0438,
    \u0438 \u043C\u043D\u043E\u0433\u0438\u0445 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u0432. *   **\u041B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435 (*Ableitbarkeit*):**
    \u0412 \xAB\u041D\u0430\u0443\u043A\u043E\u0443\u0447\u0435\u043D\u0438\u0438\xBB
    \u043E\u043D \u0434\u0430\u043B \u043E\u0434\u043D\u043E \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0445 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0439
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    (\u0432\u044B\u0432\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438) \u0447\u0435\u0440\u0435\u0437
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u043F\u043E\u0434\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u043F\u0440\u044F\u043C\u044B\u043C
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u043C
    \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u0445 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0439
    \u0410\u043B\u044C\u0444\u0440\u0435\u0434\u0430 \u0422\u0430\u0440\u0441\u043A\u043E\u0433\u043E. 
    ### \U0001F4D6 \u0412\u043A\u043B\u0430\u0434 \u0432 \u0434\u0440\u0443\u0433\u0438\u0435
    \u043D\u0430\u0443\u043A\u0438  *   **\u042D\u0442\u0438\u043A\u0430 \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F:** \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0431\u044B\u043B \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0443\u0442\u0438\u043B\u0438\u0442\u0430\u0440\u0438\u0441\u0442\u043E\u043C.
    \u0415\u0433\u043E \u044D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u043F\u0440\u0438\u043D\u0446\u0438\u043F
    \u0433\u043B\u0430\u0441\u0438\u043B: *\xAB\u0418\u0437 \u0432\u0441\u0435\u0445
    \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0445 \u0442\u0435\u0431\u0435
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439 \u0432\u044B\u0431\u0438\u0440\u0430\u0439
    \u0432\u0441\u0435\u0433\u0434\u0430 \u0442\u043E, \u043A\u043E\u0442\u043E\u0440\u043E\u0435,
    \u0432\u0437\u0432\u0435\u0441\u0438\u0432 \u0432\u0441\u0435 \u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u044F,
    \u0431\u043E\u043B\u0435\u0435 \u0432\u0441\u0435\u0433\u043E \u043F\u043E\u0441\u043B\u0443\u0436\u0438\u0442
    \u0431\u043B\u0430\u0433\u0443 \u0446\u0435\u043B\u043E\u0433\u043E \u0432\u043E
    \u0432\u0441\u0435\u0445 \u0435\u0433\u043E \u0447\u0430\u0441\u0442\u044F\u0445\xBB*.
    \u042D\u0442\u043E \u0431\u044B\u043B \u0434\u043B\u044F \u043D\u0435\u0433\u043E
    \u0441\u043F\u043E\u0441\u043E\u0431 \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u0438 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0440\u0435\u0444\u043E\u0440\u043C\u044B \u0431\u0435\u0437 \u043D\u0430\u0441\u0438\u043B\u0438\u044F.
    *   **\u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F \u0440\u0435\u043B\u0438\u0433\u0438\u0438:**
    \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043C\u043D\u043E\u0433\u043E\u0442\u043E\u043C\u043D\u044B\u0439
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A \u043F\u043E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044E
    (*Lehrbuch der Religionswissenschaft*), \u0433\u0434\u0435 \u043F\u044B\u0442\u0430\u043B\u0441\u044F
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E \u043E\u0441\u043C\u044B\u0441\u043B\u0438\u0442\u044C
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435 \u0434\u043E\u0433\u043C\u0430\u0442\u044B,
    \u0447\u0442\u043E \u0438 \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0443
    \u0441 \u0446\u0435\u0440\u043A\u043E\u0432\u044C\u044E.  ### \U0001F3DB\uFE0F
    \u041F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u041F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0431\u044B\u043B \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0438\u0437\u043E\u043B\u0438\u0440\u043E\u0432\u0430\u043D \u043E\u0442 \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430. \u0415\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B, \u043D\u0430\u043C\u043D\u043E\u0433\u043E
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0438\u0435 \u0432\u0440\u0435\u043C\u044F,
    \u0431\u044B\u043B\u0438 \u043F\u0435\u0440\u0435\u043E\u0442\u043A\u0440\u044B\u0442\u044B
    \u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u044B
    \u0442\u043E\u043B\u044C\u043A\u043E \u0432 1881 \u0433\u043E\u0434\u0443 \u041E\u0442\u0442\u043E
    \u0428\u0442\u043E\u043B\u044C\u0446\u0435\u043C. \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0439 \u0442\u0440\u0443\u0434
    \u0441\u0442\u0430\u043B \u0448\u0438\u0440\u043E\u043A\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044F\u043C,
    \u0442\u0430\u043A\u0438\u043C \u043A\u0430\u043A \u0424\u0440\u0430\u043D\u0446
    \u0411\u0440\u0435\u043D\u0442\u0430\u043D\u043E, \u0430 \u0447\u0435\u0440\u0435\u0437
    \u043D\u0435\u0433\u043E \u2014 \u0413\u0443\u0441\u0441\u0435\u0440\u043B\u044E,
    \u0447\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B\u043E \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    \u043A\u0430\u043A \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u043E\u043B\u043E\u0433\u0438\u0438,
    \u0442\u0430\u043A \u0438 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438. \u0421\u0435\u0433\u043E\u0434\u043D\u044F
    \u043E\u043D \u043F\u0440\u0438\u0437\u043D\u0430\u043D \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u044B\u0441\u043B\u0438\u0442\u0435\u043B\u0435\u0439
    XIX \u0432\u0435\u043A\u0430, \u0447\u044C\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435,
    \u043D\u0430\u0447\u0430\u0432\u0448\u0435\u0435\u0441\u044F \u0442\u043E\u043B\u044C\u043A\u043E
    \u0447\u0435\u0440\u0435\u0437 \u043F\u043E\u043B\u0432\u0435\u043A\u0430 \u043F\u043E\u0441\u043B\u0435
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438, \u043E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u044B\u043C."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0411\u0435\u0440\u043D\u0430\u0440\u0434\u0430
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u043F\u043E\u043B\u043D\u0430
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0439
    \u0438 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0445 \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u0435\u043B\u0430\u044E\u0442
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435
    \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0435\u0439.
    \u0415\u0433\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u2014 \u044D\u0442\u043E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0435\u0440\u0435\u0447\u0435\u043D\u044C
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0437\u0430\u0441\u043B\u0443\u0433,
    \u0430 \u0440\u0430\u0441\u0441\u043A\u0430\u0437 \u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0435,
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0435\u043C \u0441\u0432\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F, \u0447\u044C\u0438 \u0438\u0434\u0435\u0438 \u0431\u044B\u043B\u0438
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B,
    \u0447\u0442\u043E \u0438\u0445 \u043F\u0440\u0438\u0437\u043D\u0430\u043B\u0438
    \u043B\u0438\u0448\u044C \u0441\u043F\u0443\u0441\u0442\u044F \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F. 
    ### \U0001F476 \"\u0413\u043E\u043B\u043E\u0441, \u0432\u043E\u043F\u0438\u044E\u0449\u0438\u0439
    \u0432 \u043F\u0443\u0441\u0442\u044B\u043D\u0435\"  \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u041A\u0430\u0440\u043B
    \u0411\u043E\u0439\u0435\u0440 \u0438 \u0423\u0442\u0430 \u041C\u0435\u0440\u0446\u0431\u0430\u0445
    \u043D\u0430\u0437\u0432\u0430\u043B\u0438 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \"\u0433\u043B\u0430\u0441\u043E\u043C \u0432\u043E\u043F\u0438\u044E\u0449\u0438\u043C
    \u0432 \u043F\u0443\u0441\u0442\u044B\u043D\u0435\". \u042D\u0442\u043E\u0442
    \u0431\u0438\u0431\u043B\u0435\u0439\u0441\u043A\u0438\u0439 \u043E\u0431\u0440\u0430\u0437
    \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442
    \u0435\u0433\u043E \u0441\u0443\u0434\u044C\u0431\u0443: \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
    \u0435\u0433\u043E \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432 \u0431\u044B\u043B\u0438
    **\u0437\u0430\u043D\u043E\u0432\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u044B
    \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438
    \u0441\u043F\u0443\u0441\u0442\u044F \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F**,
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438
    \u043E\u043D\u0438 \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435\u0437\u0430\u043C\u0435\u0447\u0435\u043D\u043D\u044B\u043C\u0438.
    \u041E\u043D \u0441\u043B\u043E\u0432\u043D\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u043B
    \u0438\u0441\u0442\u0438\u043D\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0438\u043A\u0442\u043E \u043D\u0435 \u0431\u044B\u043B \u0433\u043E\u0442\u043E\u0432
    \u0443\u0441\u043B\u044B\u0448\u0430\u0442\u044C.  ### \U0001F52C \u041E\u043F\u0435\u0440\u0435\u0436\u0430\u044F
    \u0432\u0440\u0435\u043C\u044F: \"\u0423\u043A\u0440\u0430\u0434\u0435\u043D\u043D\u044B\u0435\"
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F  \u0421\u043F\u0438\u0441\u043E\u043A
    \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u0440\u0438\u043F\u0438\u0441\u0430\u043B\u0438
    \u0434\u0440\u0443\u0433\u0438\u043C, \u043F\u043E\u0440\u0430\u0436\u0430\u0435\u0442: 
    *   **\u041A\u0440\u0438\u0442\u0435\u0440\u0438\u0439 \u041A\u043E\u0448\u0438:**
    \u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0439
    \u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438 \u0447\u0438\u0441\u043B\u043E\u0432\u043E\u0439
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0435\u0433\u043E\u0434\u043D\u044F
    \u0437\u043D\u0430\u0435\u0442 \u043A\u0430\u0436\u0434\u044B\u0439 \u0441\u0442\u0443\u0434\u0435\u043D\u0442-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0431\u044B\u043B \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E, \u0430 \u043D\u0435 \u041A\u043E\u0448\u0438.
    \u041E\u043D \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u043B\u043B\u0435\u0433\u0443 \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043B\u0435\u0442. *   **\u041D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u0430\u044F,
    \u043D\u043E \u043D\u0438\u0433\u0434\u0435 \u043D\u0435 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0440\u0443\u0435\u043C\u0430\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F:** \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B \u0442\u0430\u043A\u0443\u044E
    \u0444\u0443\u043D\u043A\u0446\u0438\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043B\u043E\u043C\u0430\u0435\u0442 \u043F\u0440\u0438\u0432\u044B\u0447\u043D\u0443\u044E
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u044E, \u0437\u0430 30 \u043B\u0435\u0442
    \u0434\u043E \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u044D\u0442\u043E
    \u0441\u0434\u0435\u043B\u0430\u043B \u041A\u0430\u0440\u043B \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441,
    \u0447\u044C\u0435 \u0438\u043C\u044F \u0442\u0435\u043F\u0435\u0440\u044C \u043F\u0440\u043E\u0447\u043D\u043E
    \u0430\u0441\u0441\u043E\u0446\u0438\u0438\u0440\u0443\u0435\u0442\u0441\u044F
    \u0441 \u044D\u0442\u0438\u043C \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\u043C.
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E-\u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u0430:**
    \u042D\u0442\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0437\u0432\u0430\u043D\u0430 \u0432 \u0447\u0435\u0441\u0442\u044C
    \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u0430, \u043F\u043E\u043A\u0430
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043D\u0435 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B\u0438,
    \u0447\u0442\u043E \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0435\u0435 \u043D\u0430 \u043F\u043E\u043B\u0432\u0435\u043A\u0430 \u0440\u0430\u043D\u044C\u0448\u0435. 
    ### \U0001F4DA \"\u041D\u0430\u0443\u0447\u043D\u043E\u0435\" \u0438\u0441\u0446\u0435\u043B\u0435\u043D\u0438\u0435:
    \u0417\u0430\u0431\u0430\u0432\u043D\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439
    \u0441 \u0415\u0432\u043A\u043B\u0438\u0434\u043E\u043C  \u041E\u0434\u043D\u0430\u0436\u0434\u044B,
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u0430\u043D\u0438\u043A\u0443\u043B
    \u0432 \u041F\u0440\u0430\u0433\u0435, \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0441\u0438\u043B\u044C\u043D\u043E \u0437\u0430\u0431\u043E\u043B\u0435\u043B.
    \u0412\u0441\u0435 \u0442\u0435\u043B\u043E \u043B\u043E\u043C\u0438\u043B\u043E,
    \u0438 \u043E\u043D \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u0442\u0440\u0430\u0448\u043D\u0443\u044E \u0441\u043B\u0430\u0431\u043E\u0441\u0442\u044C.
    \u0416\u0435\u043B\u0430\u044F \u043E\u0431\u043B\u0435\u0433\u0447\u0438\u0442\u044C
    \u0441\u0432\u043E\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435,
    \u043E\u043D \u0432\u0437\u044F\u043B \u0432 \u0440\u0443\u043A\u0438 \"\u041D\u0430\u0447\u0430\u043B\u0430\"
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u0438 \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043B \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u0435
    \u043E \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u0445.
    **\"\u0418\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C,
    \u043F\u0440\u043E\u044F\u0432\u043B\u0435\u043D\u043D\u0430\u044F \u0432 \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430, \u043D\u0430\u043F\u043E\u043B\u043D\u0438\u043B\u0430
    \u043C\u0435\u043D\u044F \u0442\u0430\u043A\u0438\u043C \u0436\u0438\u0432\u044B\u043C
    \u0443\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u0435\u043C,
    \u0447\u0442\u043E \u044F \u0442\u043E\u0442\u0447\u0430\u0441 \u043F\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u0435\u0431\u044F \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u0437\u0434\u043E\u0440\u043E\u0432\u044B\u043C\"**. \u0422\u0430\u043A \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    \u0441\u0442\u0430\u043B\u0430 \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u043B\u0443\u0447\u0448\u0438\u043C
    \u043B\u0435\u043A\u0430\u0440\u0441\u0442\u0432\u043E\u043C!  ### \U0001F46B
    \u0414\u0440\u0443\u0436\u0431\u0430 \u0434\u043B\u0438\u043D\u043E\u044E \u0432
    \u0436\u0438\u0437\u043D\u044C: \u0410\u043D\u043D\u0430 \u0413\u043E\u0444\u043C\u0430\u043D 
    \u0413\u043E\u0434\u044B \u0441\u0441\u044B\u043B\u043A\u0438 \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435
    \u0422\u0435\u0445\u043E\u0431\u0443\u0437 (Techobuz) \u0431\u044B\u043B\u0438
    \u0442\u044F\u0436\u0435\u043B\u044B\u043C \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u0435\u043C,
    \u043D\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u043E\u0431\u0440\u0435\u043B \u043E\u0434\u043D\u0443 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u0432\u0430\u0436\u043D\u044B\u0445 \u0438 \u0442\u0440\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0441\u0432\u044F\u0437\u0435\u0439 \u0432 \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438.
    \u041E\u043D \u0436\u0438\u043B \u0432 \u043F\u043E\u043C\u0435\u0441\u0442\u044C\u0435
    \u0441\u0435\u043C\u044C\u0438 \u0413\u043E\u0444\u043C\u0430\u043D \u0438 \u043F\u043E\u0434\u0440\u0443\u0436\u0438\u043B\u0441\u044F
    \u0441 \u0435\u0433\u043E \u0445\u043E\u0437\u044F\u0439\u043A\u043E\u0439, \u0410\u043D\u043D\u043E\u0439.
    \u041E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0434\u0440\u0443\u0433\u043E\u043C, \u043D\u043E \u0438 \u0441\u043E\u0431\u0435\u0441\u0435\u0434\u043D\u0438\u043A\u043E\u043C,
    \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u043E\u043D \u043C\u043E\u0433
    \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u0442\u044C \u0441\u0432\u043E\u0438
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0435 \u0438\u0434\u0435\u0438. \u042D\u0442\u0430
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F **\u0447\u0438\u0441\u0442\u043E\u0439
    \u043F\u0440\u0435\u0434\u0430\u043D\u043D\u043E\u0441\u0442\u0438 \u0438 \u043F\u043B\u0430\u0442\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u044E\u0431\u0432\u0438** \u0441\u044B\u0433\u0440\u0430\u043B\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u0443\u044E
    \u0440\u043E\u043B\u044C \u0432 \u0435\u0433\u043E \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0435,
    \u0432\u0435\u0434\u044C \u0438\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u0438
    \u0433\u043E\u0434\u044B \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B. 
    ### \U0001F4D6 \u0422\u0440\u0443\u0434 \u0432\u0441\u0435\u0439 \u0436\u0438\u0437\u043D\u0438:
    102 \u0442\u043E\u043C\u0430  \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E
    \u0431\u044B\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C \u0430\u0432\u0442\u043E\u0440\u043E\u043C.
    \u0415\u0433\u043E \u043F\u043E\u043B\u043D\u043E\u0435 \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439 (Bernard-Bolzano-Gesamtausgabe),
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043D\u0430\u0447\u0430\u043B\u0438
    \u0438\u0437\u0434\u0430\u0432\u0430\u0442\u044C \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432 1969 \u0433\u043E\u0434\u0443, \u043D\u0430 \u0441\u0435\u0433\u043E\u0434\u043D\u044F\u0448\u043D\u0438\u0439
    \u0434\u0435\u043D\u044C \u043D\u0430\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u0435\u0442
    **102 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0442\u043E\u043C\u0430**, \u0438 \u0440\u0430\u0431\u043E\u0442\u0430 \u043D\u0430\u0434
    \u043D\u0438\u043C \u0432\u0441\u0435 \u0435\u0449\u0435 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442\u0441\u044F.
    \u042D\u0442\u043E \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u044B\u0439 \u043C\u0430\u0441\u0448\u0442\u0430\u0431
    \u0435\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044F.  ### \U0001F3DB\uFE0F
    \u041F\u0430\u0442\u0440\u0438\u043E\u0442 \u0441 \u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u0431\u0443\u043A\u0432\u044B: \u0421\u0442\u0438\u0445\u0438 \u043E \u0427\u0435\u0445\u0438\u0438 
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u0431\u044B\u043B \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0447\u0435\u043D\u044B\u043C-\u043A\u043E\u0441\u043C\u043E\u043F\u043E\u043B\u0438\u0442\u043E\u043C,
    \u043D\u043E \u0438 \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0438\u043C \u043F\u0430\u0442\u0440\u0438\u043E\u0442\u043E\u043C
    \u0411\u043E\u0433\u0435\u043C\u0438\u0438. \u041E\u043D \u043F\u0438\u0441\u0430\u043B
    \u0441\u0442\u0438\u0445\u0438 \u043D\u0430 \u043B\u0430\u0442\u044B\u043D\u0438,
    \u043F\u0440\u043E\u0441\u043B\u0430\u0432\u043B\u044F\u044F \u0427\u0435\u0445\u0438\u044E,
    \u0438 \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B \u0437\u0430 \u0440\u0430\u0432\u043D\u043E\u043F\u0440\u0430\u0432\u0438\u0435
    \u0447\u0435\u0448\u0441\u043A\u043E\u0433\u043E \u0438 \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0433\u043E
    \u043D\u0430\u0441\u0435\u043B\u0435\u043D\u0438\u044F. \u041E\u043D \u0434\u0430\u0436\u0435
    \u0447\u0438\u0442\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438 \u043E \u0432\u0437\u0430\u0438\u043C\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u0445
    \u0434\u0432\u0443\u0445 \u043D\u0430\u0440\u043E\u0434\u043E\u0432 \u0432 \u0411\u043E\u0433\u0435\u043C\u0438\u0438,
    \u043F\u044B\u0442\u0430\u044F\u0441\u044C \u0441\u043C\u044F\u0433\u0447\u0438\u0442\u044C
    \u043C\u0435\u0436\u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u044F.  ###
    \u2721\uFE0F \u0417\u0430\u0449\u0438\u0442\u043D\u0438\u043A \u0443\u0433\u043D\u0435\u0442\u0435\u043D\u043D\u044B\u0445 
    \u0412 \u044D\u043F\u043E\u0445\u0443, \u043A\u043E\u0433\u0434\u0430 \u0430\u043D\u0442\u0438\u0441\u0435\u043C\u0438\u0442\u0438\u0437\u043C
    \u0431\u044B\u043B \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D,
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B \u043F\u0440\u043E\u0442\u0438\u0432
    \u0434\u0438\u0441\u043A\u0440\u0438\u043C\u0438\u043D\u0430\u0446\u0438\u0438
    \u0435\u0432\u0440\u0435\u0435\u0432. \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B,
    \u0447\u0442\u043E \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0435 \u0441\u0430\u043C\u0438
    \u043D\u0435\u0441\u0443\u0442 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0437\u0430 \u0432\u0440\u0430\u0436\u0434\u0435\u0431\u043D\u043E\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435
    \u043A \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u043C\u0443 \u043D\u0430\u0440\u043E\u0434\u0443,
    \u0438 \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B \u0438\u0445 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u0446\u0438\u0438.  \u0415\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0438\u0434\u0435\u0438, \u0440\u043E\u0436\u0434\u0435\u043D\u043D\u044B\u0435
    \u0432 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438, \u043C\u043E\u0433\u0443\u0442
    \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C \u043C\u0438\u0440, \u0434\u0430\u0436\u0435
    \u0435\u0441\u043B\u0438 \u0438\u0445 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u043F\u0440\u0438\u0445\u043E\u0434\u0438\u0442 \u0447\u0435\u0440\u0435\u0437
    \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0435."
