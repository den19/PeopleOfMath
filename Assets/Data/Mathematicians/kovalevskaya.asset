  achievementsRu: "## \u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u0442\u0440\u0438\u0443\u043C\u0444: \u0437\u0430\u0434\u0430\u0447\u0430 \u043E
    \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438 \u0442\u0432\u0435\u0440\u0434\u043E\u0433\u043E
    \u0442\u0435\u043B\u0430  **\u0421\u0430\u043C\u043E\u0435 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0439**
    \u2014 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 **\u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043B\u0443\u0447\u0430\u044F** \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0441\u0442\u0438
    \u0437\u0430\u0434\u0430\u0447\u0438 \u043E \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
    \u0442\u0432\u0435\u0440\u0434\u043E\u0433\u043E \u0442\u0435\u043B\u0430 \u0432\u043E\u043A\u0440\u0443\u0433
    \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u0438. 
    \u0414\u043E \u043D\u0435\u0435 \u044D\u0442\u0443 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u0437\u0430\u0434\u0430\u0447\u0443 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438
    \u043F\u0440\u043E\u0434\u0432\u0438\u043D\u0443\u043B\u0438 \u043B\u0438\u0448\u044C
    \u041B\u0435\u043E\u043D\u0430\u0440\u0434 \u042D\u0439\u043B\u0435\u0440 \u0438
    \u0416\u043E\u0437\u0435\u0444 \u041B\u0443\u0438 \u041B\u0430\u0433\u0440\u0430\u043D\u0436,
    \u043D\u043E \u043E\u043D\u0438 \u0440\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0435\u043B\u0438
    \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0430\u0441\u0442\u043D\u044B\u0435
    \u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u0447\u043D\u044B\u0435 \u0441\u043B\u0443\u0447\u0430\u0438.
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u043D\u0430\u0448\u043B\u0430
    **\u043D\u043E\u0432\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439 \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u043D\u0435\u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u0447\u043D\u043E\u0433\u043E
    \u0433\u0438\u0440\u043E\u0441\u043A\u043E\u043F\u0430**, \u043A\u043E\u0433\u0434\u0430
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0434\u043E\u0432\u043E\u0434\u0438\u0442\u0441\u044F
    \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0443\u043B\u044C\u0442\u0440\u0430\u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0432\u0440\u0435\u043C\u0435\u043D\u0438. 
    \u0412 **1888 \u0433\u043E\u0434\u0443** \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0430\u044F
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044F \u043D\u0430\u0443\u043A \u043F\u0440\u0438\u0441\u0443\u0434\u0438\u043B\u0430
    \u0435\u0439 **\u043F\u0440\u0435\u043C\u0438\u044E \u0411\u043E\u0440\u0434\u0435\u043D\u0430**
    \u0437\u0430 \u044D\u0442\u0443 \u0440\u0430\u0431\u043E\u0442\u0443, \u043F\u0440\u0438\u0447\u0435\u043C
    \u0441\u0443\u043C\u043C\u0430 \u043F\u0440\u0435\u043C\u0438\u0438 \u0431\u044B\u043B\u0430
    **\u0443\u0434\u0432\u043E\u0435\u043D\u0430** \u0432\u0432\u0438\u0434\u0443
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u0438 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F.
    \u0412 **1889 \u0433\u043E\u0434\u0443** \u0437\u0430 \u0432\u0442\u043E\u0440\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043E \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
    \u0442\u0432\u0435\u0440\u0434\u043E\u0433\u043E \u0442\u0435\u043B\u0430 \u043E\u043D\u0430
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 **\u043F\u0440\u0435\u043C\u0438\u044E
    \u0428\u0432\u0435\u0434\u0441\u043A\u043E\u0439 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A**. 
    ---  ## \u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u041A\u043E\u0448\u0438 \u2014
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0439  \u0415\u0449\u0435
    \u043E\u0434\u043D\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430, \u0432\u043E\u0448\u0435\u0434\u0448\u0430\u044F
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u2014 **\u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F \xAB\u041A
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0432 \u0447\u0430\u0441\u0442\u043D\u044B\u0445
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0445\xBB** (1874). 
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F **\u0434\u043E\u043A\u0430\u0437\u0430\u043B\u0430
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    (\u0433\u043E\u043B\u043E\u043C\u043E\u0440\u0444\u043D\u043E\u0433\u043E) \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0437\u0430\u0434\u0430\u0447\u0438 \u041A\u043E\u0448\u0438** \u0434\u043B\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0441 \u0447\u0430\u0441\u0442\u043D\u044B\u043C\u0438
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u043C\u0438. **\u0421\u0443\u0442\u044C
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B**: \u0435\u0441\u043B\u0438 \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u044B
    \u0432 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u044B
    \u0438 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C\u0438 (\u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043C\u044B
    \u0432 \u0432\u0438\u0434\u0435 \u0441\u0445\u043E\u0434\u044F\u0449\u0435\u0433\u043E\u0441\u044F
    \u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E\u0433\u043E \u0440\u044F\u0434\u0430),
    \u0430 \u0438\u0441\u043A\u043E\u043C\u043E\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0438\u043C\u0435\u0435\u0442 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0442\u043E\u0447\u043A\u0435, \u0442\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0438 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u0432 \u043E\u043A\u0440\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u0438 \u044D\u0442\u043E\u0439
    \u0442\u043E\u0447\u043A\u0438.  \u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u044D\u0442\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0432\u044B\u0445\u043E\u0434\u0438\u0442
    \u0434\u0430\u043B\u0435\u043A\u043E \u0437\u0430 \u0440\u0430\u043C\u043A\u0438
    \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438:
    \u043E\u043D\u0430 \u043B\u0435\u0436\u0438\u0442 \u0432 \u043E\u0441\u043D\u043E\u0432\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0437\u0430\u0434\u0430\u0447 \u0433\u0438\u0434\u0440\u043E\u0433\u0430\u0437\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438,
    \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043C\u0430\u0433\u043D\u0438\u0442\u043D\u044B\u0445
    \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u0439, \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0432
    \u0442\u0435\u043F\u043B\u043E\u043E\u0431\u043C\u0435\u043D\u0430, \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u044F
    \u043F\u043E\u0433\u043E\u0434\u044B, \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u0445 \u0442\u0435\u043B. \u0421 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435\u043C
    \u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445 \u043C\u0435\u0442\u043E\u0434\u043E\u0432
    \u043E\u043D\u0430 \u043F\u0440\u0438\u043E\u0431\u0440\u0435\u043B\u0430 \u043E\u0441\u043E\u0431\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0434\u043B\u044F \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u044B\u0445
    \u0440\u0430\u0441\u0447\u0435\u0442\u043E\u0432.  ---  ## \u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u043A\u043E\u043B\u0435\u0446 \u0421\u0430\u0442\u0443\u0440\u043D\u0430  \u0412
    **1885 \u0433\u043E\u0434\u0443** \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B\u0430 \u0440\u0430\u0431\u043E\u0442\u0443
    **\xAB\u0414\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u044F \u0438 \u0437\u0430\u043C\u0435\u0447\u0430\u043D\u0438\u044F
    \u043A \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044E
    \u041B\u0430\u043F\u043B\u0430\u0441\u0430 \u043E \u0444\u043E\u0440\u043C\u0435
    \u043A\u043E\u043B\u044C\u0446\u0430 \u0421\u0430\u0442\u0443\u0440\u043D\u0430\xBB**. 
    \u041E\u043D\u0430 \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043C\u043E\u0434\u0435\u043B\u044C **\u0443\u0437\u043A\u043E\u0433\u043E \u043A\u043E\u043B\u044C\u0446\u0430
    \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u043E\u0440\u043C\u044B** \u0438 \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u043B\u0430 \u0440\u0430\u0441\u0447\u0435\u0442\u044B
    \u0441 \u0443\u0447\u0435\u0442\u043E\u043C \u043C\u0430\u0441\u0441\u044B \u0441\u0430\u043C\u043E\u0433\u043E
    \u043A\u043E\u043B\u044C\u0446\u0430 (\u0447\u0435\u0433\u043E \u043D\u0435 \u0434\u0435\u043B\u0430\u043B
    \u043D\u0438\u043A\u0442\u043E \u0440\u0430\u043D\u0435\u0435). \u0415\u0439
    \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0432\u0442\u043E\u0440\u043E\u0435 \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u0435
    \u0432 \u0440\u0435\u0448\u0435\u043D\u0438\u0438 \u044D\u0442\u043E\u0439 \u0441\u043B\u043E\u0436\u043D\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0438.  **\u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0432\u044B\u0432\u043E\u0434\u044B** \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    : - \u041A\u043E\u043B\u044C\u0446\u043E \u043C\u043E\u0436\u0435\u0442 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u0432 \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u0440\u0438 \u0441\u0442\u0440\u043E\u0433\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u043C
    \u043D\u0430\u0431\u043E\u0440\u0435 \u043F\u0430\u0440\u0430\u043C\u0435\u0442\u0440\u043E\u0432
    \u2014 \u043B\u044E\u0431\u043E\u0435 \u043E\u0442\u043A\u043B\u043E\u043D\u0435\u043D\u0438\u0435
    \u0432\u0435\u0434\u0435\u0442 \u043A \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u0438\u044E
    - \u0421\u043A\u043E\u0440\u043E\u0441\u0442\u044C \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u043A\u043E\u043B\u044C\u0446\u0430 \u0432 \u043A\u0430\u0436\u0434\u043E\u0439
    \u0442\u043E\u0447\u043A\u0435 \u0434\u043E\u043B\u0436\u043D\u0430 \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u0442\u044C
    \u0441\u043E \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430
    \u043F\u043B\u0430\u043D\u0435\u0442\u044B - \u041E\u043D\u0430 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u043B\u0430
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443 \u041C\u0430\u043A\u0441\u0432\u0435\u043B\u043B\u0430
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u043A\u043E\u043B\u044C\u0446\u0430
    \u043D\u0435 \u043C\u043E\u0433\u0443\u0442 \u0431\u044B\u0442\u044C \u0436\u0438\u0434\u043A\u0438\u043C\u0438
    \u0438 \u0434\u043E\u043B\u0436\u043D\u044B \u0441\u043E\u0441\u0442\u043E\u044F\u0442\u044C
    \u0438\u0437 \u0442\u0432\u0435\u0440\u0434\u044B\u0445 \u0447\u0430\u0441\u0442\u0438\u0446 
    \u042D\u0442\u043E \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u0435
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u043B\u043E\u0441\u044C
    \u0432 XX \u0432\u0435\u043A\u0435, \u043A\u043E\u0433\u0434\u0430 \u043A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u044B \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u0438
    \u0421\u0430\u0442\u0443\u0440\u043D.  ---  ## \u0414\u0440\u0443\u0433\u0438\u0435
    \u0432\u0430\u0436\u043D\u044B\u0435 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F 
    1. **\u0410\u0431\u0435\u043B\u0435\u0432\u044B \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044B**
    \u2014 \u0440\u0435\u0448\u0438\u043B\u0430 \u0437\u0430\u0434\u0430\u0447\u0443
    \u043E \u043F\u0440\u0438\u0432\u0435\u0434\u0435\u043D\u0438\u0438 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043A\u043B\u0430\u0441\u0441\u0430 \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u0432 \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E
    \u0440\u0430\u043D\u0433\u0430 \u043A \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430\u043C.  2. **\u041E\u043F\u0442\u0438\u043A\u0430
    \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u043E\u0432** \u2014 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430
    \u043D\u0430\u0434 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u044F
    \u0438 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \u0441\u0432\u0435\u0442\u0430 \u0432 \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0440\u0435\u0434\u0430\u0445.  3. **\u0422\u0435\u043E\u0440\u0438\u044F
    \u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B\u0430, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u0438\u0437\u0438\u043A\u0430, \u043D\u0435\u0431\u0435\u0441\u043D\u0430\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430**.  ---  ## \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0432 \u0420\u043E\u0441\u0441\u0438\u0438  \u0412 **1889 \u0433\u043E\u0434\u0443**,
    \u043F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E \u043A\u0430\u043A \u0431\u044B\u043B
    \u0440\u0435\u0448\u0435\u043D \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043E\u043F\u0440\u043E\u0441 \u043E \u0434\u043E\u043F\u0443\u0449\u0435\u043D\u0438\u0438
    \u0436\u0435\u043D\u0449\u0438\u043D \u043A \u0438\u0437\u0431\u0440\u0430\u043D\u0438\u044E
    \u0432 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u044E, \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u0441\u0442\u0430\u043B\u0430 **\u043F\u0435\u0440\u0432\u043E\u0439 \u0432
    \u0420\u043E\u0441\u0441\u0438\u0438 \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439
    \u2014 \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A**. 
    ---  ### \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B (\u0441 \u0431\u0438\u0431\u043B\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0435\u0439) 
    | \u0413\u043E\u0434 | \u041D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    | \u041E\u0431\u043B\u0430\u0441\u0442\u044C | |-----|----------------|---------|
    | 1874 | \xABZur Theorie der partiellen Differentialgleichungen\xBB | \u0422\u0435\u043E\u0440\u0438\u044F
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439  | | 1884 | \xAB\xDCber
    die Reduction einer bestimmten Klasse Abel\u2019scher Integrale 3ten Ranges auf
    elliptische Integrale\xBB | \u0410\u0431\u0435\u043B\u0435\u0432\u044B \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044B 
    | | 1885 | \xABZus\xE4tze und Bemerkungen zu Laplace\u2019s Untersuchung \xFCber
    die Gestalt der Saturnsringe\xBB | \u041A\u043E\u043B\u044C\u0446\u0430 \u0421\u0430\u0442\u0443\u0440\u043D\u0430 
    | | 1888 | \xAB\u0417\u0430\u0434\u0430\u0447\u0430 \u043E \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
    \u0442\u0432\u0435\u0440\u0434\u043E\u0433\u043E \u0442\u0435\u043B\u0430 \u043E\u043A\u043E\u043B\u043E
    \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u0438\xBB
    (\u043F\u0440\u0435\u043C\u0438\u044F \u0411\u043E\u0440\u0434\u0435\u043D\u0430)
    | \u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430  | | 1889 | \u041C\u0435\u043C\u0443\u0430\u0440
    \u043E \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438 \u0442\u0432\u0435\u0440\u0434\u043E\u0433\u043E
    \u0442\u0435\u043B\u0430 (\u043F\u0440\u0435\u043C\u0438\u044F \u0428\u0432\u0435\u0434\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438) | \u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430 
    | | 1890 | \xABSur une propri\xE9t\xE9 du syst\xE8me d\u2019equations differentielles
    qui definit la rotation d\u2019un corps solide\xBB | \u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430 
    |  \u0420\u0435\u0444\u0435\u0440\u0430\u0442\u044B \u043D\u0430 \u0435\u0451
    \u0442\u0440\u0443\u0434\u044B \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0438
    \u0442\u0430\u043A\u0438\u0435 \u043A\u043E\u0440\u0438\u0444\u0435\u0438 \u0440\u0443\u0441\u0441\u043A\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438, \u043A\u0430\u043A \u0410.\u0413. \u0421\u0442\u043E\u043B\u0435\u0442\u043E\u0432,
    \u041D.\u0415. \u0416\u0443\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u0438
    \u041F.\u0410. \u041D\u0435\u043A\u0440\u0430\u0441\u043E\u0432."
  achievementsEn: 
  personalLifeRu: "### \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u044E\u043D\u043E\u0441\u0442\u044C 
    \u0421\u043E\u0444\u044C\u044F \u0412\u0430\u0441\u0438\u043B\u044C\u0435\u0432\u043D\u0430
    \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C 15 \u044F\u043D\u0432\u0430\u0440\u044F
    1850 \u0433\u043E\u0434\u0430 \u0432 \u041C\u043E\u0441\u043A\u0432\u0435 \u0432
    \u0441\u0435\u043C\u044C\u0435 \u0433\u0435\u043D\u0435\u0440\u0430\u043B-\u043B\u0435\u0439\u0442\u0435\u043D\u0430\u043D\u0442\u0430
    \u0412\u0430\u0441\u0438\u043B\u0438\u044F \u041A\u043E\u0440\u0432\u0438\u043D-\u041A\u0440\u0443\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0441\u0440\u0435\u0434\u043D\u0438\u043C
    \u0440\u0435\u0431\u0435\u043D\u043A\u043E\u043C: \u0443 \u043D\u0435\u0435 \u0431\u044B\u043B\u0438
    \u0441\u0442\u0430\u0440\u0448\u0430\u044F \u0441\u0435\u0441\u0442\u0440\u0430
    \u0410\u043D\u043D\u0430 \u0438 \u043C\u043B\u0430\u0434\u0448\u0438\u0439 \u0431\u0440\u0430\u0442
    \u0424\u0435\u0434\u043E\u0440. \u0420\u043E\u0434\u0438\u0442\u0435\u043B\u0438,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u043E\u0442\u0435\u0446, \u043E\u0447\u0435\u043D\u044C
    \u0445\u043E\u0442\u0435\u043B\u0438 \u0441\u044B\u043D\u0430, \u0438 \u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u0435
    \u0421\u043E\u0444\u044C\u0438 \u043D\u0435 \u0432\u044B\u0437\u0432\u0430\u043B\u043E
    \u0443 \u043D\u0438\u0445 \u043E\u0441\u043E\u0431\u043E\u0439 \u0440\u0430\u0434\u043E\u0441\u0442\u0438.
    \u0414\u0435\u0432\u043E\u0447\u043A\u0430 \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u0441\u0435\u0431\u044F \u043D\u0435\u043B\u044E\u0431\u0438\u043C\u043E\u0439,
    \u0438\u0437-\u0437\u0430 \u0447\u0435\u0433\u043E \u0440\u0430\u043D\u043E \u0441\u0442\u0430\u043B\u0430
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0439 \u0438 \u0434\u0430\u0436\u0435
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435
    \"\u0434\u0438\u043A\u0430\u0440\u043A\u0430\".  \u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0421\u043E\u0444\u044C\u0438 \u043F\u0440\u043E\u0448\u043B\u043E \u0432 \u0440\u043E\u0434\u043E\u0432\u043E\u043C
    \u0438\u043C\u0435\u043D\u0438\u0438 \u041F\u043E\u043B\u0438\u0431\u0438\u043D\u043E,
    \u043A\u0443\u0434\u0430 \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u043F\u043E\u0441\u043B\u0435 \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0438
    \u043E\u0442\u0446\u0430. \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0434\u0435\u0442\u0435\u0439 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0434\u043E\u043C\u0430\u0448\u043D\u0438\u0439 \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u0418\u043E\u0441\u0438\u0444 \u041C\u0430\u043B\u0435\u0432\u0438\u0447. \u0421\u043E\u0444\u044C\u044F
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0430 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438, \u043E\u0441\u0432\u043E\u0438\u0432
    \u0437\u0430 \u0432\u043E\u0441\u0435\u043C\u044C \u043B\u0435\u0442 \u043F\u043E\u043B\u043D\u044B\u0439
    \u043A\u0443\u0440\u0441 \u043C\u0443\u0436\u0441\u043A\u043E\u0439 \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0438.
    \u0415\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0430\u043B\u0430\u043D\u0442 \u0437\u0430\u043C\u0435\u0442\u0438\u043B
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u041D\u0438\u043A\u043E\u043B\u0430\u0439
    \u0422\u044B\u0440\u0442\u043E\u0432, \u0434\u0440\u0443\u0433 \u043E\u0442\u0446\u0430.
    \u041E\u043D \u0431\u044B\u043B \u0442\u0430\u043A \u043F\u043E\u0440\u0430\u0436\u0435\u043D
    \u0435\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044F\u043C\u0438,
    \u0447\u0442\u043E \u043D\u0430\u0437\u0432\u0430\u043B \u0434\u0435\u0432\u043E\u0447\u043A\u0443
    \"\u043D\u043E\u0432\u044B\u043C \u041F\u0430\u0441\u043A\u0430\u043B\u0435\u043C\"
    \u0438 \u0443\u0431\u0435\u0436\u0434\u0430\u043B \u0433\u0435\u043D\u0435\u0440\u0430\u043B\u0430
    \u0434\u0430\u0442\u044C \u0435\u0439 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435, \u043D\u043E
    \u0431\u0435\u0437\u0443\u0441\u043F\u0435\u0448\u043D\u043E.  \u0423 \u0421\u043E\u0444\u044C\u0438
    \u0431\u044B\u043B\u0430 \u0438 \u0440\u0430\u043D\u043D\u044F\u044F, \u0442\u0440\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u044E\u043D\u043E\u0448\u0435\u0441\u043A\u0430\u044F \u0432\u043B\u044E\u0431\u043B\u0435\u043D\u043D\u043E\u0441\u0442\u044C.
    \u041A\u043E\u0433\u0434\u0430 \u0435\u0439 \u0431\u044B\u043B\u043E 14 \u043B\u0435\u0442,
    \u0432 \u0438\u0445 \u0434\u043E\u043C\u0435 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0440\u0430\u0437 \u0431\u044B\u0432\u0430\u043B \u0424\u0435\u0434\u043E\u0440
    \u0414\u043E\u0441\u0442\u043E\u0435\u0432\u0441\u043A\u0438\u0439, \u0443\u0445\u0430\u0436\u0438\u0432\u0430\u0432\u0448\u0438\u0439
    \u0437\u0430 \u0441\u0442\u0430\u0440\u0448\u0435\u0439 \u0441\u0435\u0441\u0442\u0440\u043E\u0439
    \u0410\u043D\u043D\u043E\u0439. \u0421\u043E\u0444\u044C\u044F \u0431\u044B\u043B\u0430
    \u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0430 \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u0435\u043C
    \u0438 \u043E\u0447\u0435\u043D\u044C \u0441\u0442\u0440\u0430\u0434\u0430\u043B\u0430,
    \u043A\u043E\u0433\u0434\u0430 \u043F\u043E\u043D\u044F\u043B\u0430, \u0447\u0442\u043E
    \u0432\u0441\u0435 \u0435\u0433\u043E \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435
    \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442 \u0441\u0435\u0441\u0442\u0440\u0435. 
    ### \u041F\u0443\u0442\u044C \u043A \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044E
    \u0438 \u0444\u0438\u043A\u0442\u0438\u0432\u043D\u044B\u0439 \u0431\u0440\u0430\u043A 
    \u0412 1860-\u0435 \u0433\u043E\u0434\u044B \u0434\u043B\u044F \u0436\u0435\u043D\u0449\u0438\u043D
    \u0432 \u0420\u043E\u0441\u0441\u0438\u0438 \u0432\u044B\u0441\u0448\u0435\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0431\u044B\u043B\u043E
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E.
    \u0427\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0437\u0430
    \u0433\u0440\u0430\u043D\u0438\u0446\u0435\u0439, \u043D\u0443\u0436\u043D\u043E
    \u0431\u044B\u043B\u043E \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u0435 \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u0439
    \u0438\u043B\u0438 \u043C\u0443\u0436\u0430. \u041E\u0442\u0435\u0446 \u0421\u043E\u0444\u044C\u0438
    \u0431\u044B\u043B \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0440\u043E\u0442\u0438\u0432. \u0422\u043E\u0433\u0434\u0430 \u0441\u0451\u0441\u0442\u0440\u044B
    \u041A\u043E\u0440\u0432\u0438\u043D-\u041A\u0440\u0443\u043A\u043E\u0432\u0441\u043A\u0438\u0435
    \u0440\u0435\u0448\u0438\u043B\u0438 \u043F\u0440\u0438\u0431\u0435\u0433\u043D\u0443\u0442\u044C
    \u043A \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0435 \u0444\u0438\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u0431\u0440\u0430\u043A\u0430.  \u0412\u044B\u0431\u043E\u0440 \u043F\u0430\u043B
    \u043D\u0430 \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E-\u043F\u0430\u043B\u0435\u043E\u043D\u0442\u043E\u043B\u043E\u0433\u0430
    \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440\u0430 \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u043B\u0441\u044F \u0441\u0442\u0430\u0442\u044C
    \u0444\u0438\u043A\u0442\u0438\u0432\u043D\u044B\u043C \u043C\u0443\u0436\u0435\u043C
    \u0410\u043D\u043D\u044B. \u041E\u0434\u043D\u0430\u043A\u043E, \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0432\u0448\u0438\u0441\u044C
    \u0441 \u0421\u043E\u0444\u044C\u0435\u0439, \u043E\u043D \u0432\u043B\u044E\u0431\u0438\u043B\u0441\u044F
    \u0432 \u043D\u0435\u0435 \u0438 \u043D\u0430\u0441\u0442\u043E\u044F\u043B \u043D\u0430
    \u0431\u0440\u0430\u043A\u0435 \u0438\u043C\u0435\u043D\u043D\u043E \u0441 \u043D\u0435\u0439.
    **\u0421\u0432\u0430\u0434\u044C\u0431\u0430 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0430\u0441\u044C
    \u0432 1868 \u0433\u043E\u0434\u0443 \u0432 \u0438\u043C\u0435\u043D\u0438\u0438
    \u041F\u043E\u043B\u0438\u0431\u0438\u043D\u043E**. \u0414\u043B\u044F \u0421\u043E\u0444\u044C\u0438
    \u044D\u0442\u043E\u0442 \u0431\u0440\u0430\u043A \u0434\u043E\u043B\u0433\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u043C, \u0438 \u043E\u043D\u0430
    \u0441\u0447\u0438\u0442\u0430\u043B\u0430 \u043C\u0443\u0436\u0430 \u0441\u043A\u043E\u0440\u0435\u0435
    \u0434\u0440\u0443\u0433\u043E\u043C \u0438 \u0431\u0440\u0430\u0442\u043E\u043C. 
    ### \u0423\u0447\u0451\u0431\u0430 \u0432 \u0415\u0432\u0440\u043E\u043F\u0435
    \u0438 \u0440\u0430\u0431\u043E\u0442\u0430  \u0412 1869 \u0433\u043E\u0434\u0443
    \u0421\u043E\u0444\u044C\u044F \u0441 \u043C\u0443\u0436\u0435\u043C \u0443\u0435\u0445\u0430\u043B\u0430
    \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044E. \u041E\u043D\u0430 **\u0443\u0447\u0438\u043B\u0430\u0441\u044C
    \u0432 \u0413\u0435\u0439\u0434\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435**, \u0441\u043B\u0443\u0448\u0430\u044F
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u0443\u0447\u0435\u043D\u044B\u0445, \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A
    \u0413\u0443\u0441\u0442\u0430\u0432 \u041A\u0438\u0440\u0445\u0433\u043E\u0444
    \u0438 \u0413\u0435\u0440\u043C\u0430\u043D \u0413\u0435\u043B\u044C\u043C\u0433\u043E\u043B\u044C\u0446.
    \u0417\u0430\u0442\u0435\u043C \u043E\u043D\u0430 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u0411\u0435\u0440\u043B\u0438\u043D, \u043D\u043E \u0436\u0435\u043D\u0449\u0438\u043D\u044B
    \u0432 \u043C\u0435\u0441\u0442\u043D\u044B\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u043D\u0435 \u0434\u043E\u043F\u0443\u0441\u043A\u0430\u043B\u0438\u0441\u044C. 
    \u0422\u043E\u0433\u0434\u0430 \u0421\u043E\u0444\u044C\u044F \u043E\u0431\u0440\u0430\u0442\u0438\u043B\u0430\u0441\u044C
    \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E \u043A **\u041A\u0430\u0440\u043B\u0443
    \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u0443**, \u043E\u0434\u043D\u043E\u043C\u0443
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u0427\u0442\u043E\u0431\u044B
    \u0438\u0437\u0431\u0430\u0432\u0438\u0442\u044C\u0441\u044F \u043E\u0442 \u043D\u0430\u0437\u043E\u0439\u043B\u0438\u0432\u043E\u0439
    \u0443\u0447\u0435\u043D\u0438\u0446\u044B, \u043E\u043D \u0437\u0430\u0434\u0430\u043B
    \u0435\u0439 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447. \u041A\u043E\u0433\u0434\u0430 \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430 \u0438\u0445 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F, \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441
    \u0431\u044B\u043B \u043F\u043E\u0440\u0430\u0436\u0435\u043D \u0438 \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u043B\u0441\u044F
    \u0434\u0430\u0432\u0430\u0442\u044C \u0435\u0439 \u0447\u0430\u0441\u0442\u043D\u044B\u0435
    \u0443\u0440\u043E\u043A\u0438. \u042D\u0442\u0438 \u0437\u0430\u043D\u044F\u0442\u0438\u044F
    \u0434\u043B\u0438\u043B\u0438\u0441\u044C **\u0447\u0435\u0442\u044B\u0440\u0435
    \u0433\u043E\u0434\u0430 (1870\u20131874)**. \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u0448\u0443\u0442\u0438\u043B\u0438, \u0447\u0442\u043E \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \"\u0432\u044B\u0432\u0435\u043B\u0430 \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u0430
    \u0438\u0437 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044F \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0441\u0442\u0438\".
    \u041E\u043D \u0432\u044B\u0441\u043E\u043A\u043E \u0446\u0435\u043D\u0438\u043B
    \u0435\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0433\u043E\u0432\u043E\u0440\u0438\u043B, \u0447\u0442\u043E \u0438\u043C\u0435\u043B
    \u043E\u0447\u0435\u043D\u044C \u043C\u0430\u043B\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u043E\u0433\u043B\u0438 \u0431\u044B
    \u0441\u0440\u0430\u0432\u043D\u0438\u0442\u044C\u0441\u044F \u0441 \u043D\u0435\u0439
    \u0432 \u043F\u0440\u0438\u043B\u0435\u0436\u0430\u043D\u0438\u0438 \u0438 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u043D\u0430\u0443\u043A\u043E\u0439.  \u0412 1874 \u0433\u043E\u0434\u0443 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0437\u0430\u043E\u0447\u043D\u043E
    \u043F\u0440\u0438\u0441\u0443\u0434\u0438\u043B \u0421\u043E\u0444\u044C\u0435
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0434\u043E\u043A\u0442\u043E\u0440\u0430 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u0437\u0430 \u0442\u0440\u0438 \u0440\u0430\u0431\u043E\u0442\u044B, \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0435
    \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u043E\u043C. 
    ### \u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0432
    \u0420\u043E\u0441\u0441\u0438\u044E \u0438 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F 
    \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C \u0432 \u0420\u043E\u0441\u0441\u0438\u044E,
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0430\u0441\u044C
    \u0441 \u043D\u0435\u043F\u0440\u0435\u043E\u0434\u043E\u043B\u0438\u043C\u043E\u0439
    \u0441\u0442\u0435\u043D\u043E\u0439. \u041E\u043D\u0430 \u043D\u0435 \u0441\u043C\u043E\u0433\u043B\u0430
    \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043C\u0435\u0441\u0442\u043E
    \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. \u0411\u043E\u043B\u0435\u0435
    \u0442\u043E\u0433\u043E, \u0435\u0439 \u0434\u0430\u0436\u0435 \u043D\u0435
    \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043B\u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C
    \u043D\u0430 \u0412\u044B\u0441\u0448\u0438\u0445 \u0436\u0435\u043D\u0441\u043A\u0438\u0445
    \u043A\u0443\u0440\u0441\u0430\u0445. \u041F\u043E\u0447\u0442\u0438 \u043D\u0430
    \u0448\u0435\u0441\u0442\u044C \u043B\u0435\u0442 \u043E\u043D\u0430 \u043E\u0442\u043E\u0448\u043B\u0430
    \u043E\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0437\u0430\u043D\u044F\u0432\u0448\u0438\u0441\u044C
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u043E-\u043F\u0443\u0431\u043B\u0438\u0446\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E. 
    \u041E\u043D\u0430 \u043E\u0431\u0449\u0430\u043B\u0430\u0441\u044C \u0441\u043E
    \u043C\u043D\u043E\u0433\u0438\u043C\u0438 \u0432\u0438\u0434\u043D\u044B\u043C\u0438
    \u0434\u0435\u044F\u0442\u0435\u043B\u044F\u043C\u0438 \u043D\u0430\u0443\u043A\u0438
    \u0438 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u044B, \u0442\u0430\u043A\u0438\u043C\u0438
    \u043A\u0430\u043A \u0414\u043C\u0438\u0442\u0440\u0438\u0439 \u041C\u0435\u043D\u0434\u0435\u043B\u0435\u0435\u0432,
    \u0418\u0432\u0430\u043D \u0421\u0435\u0447\u0435\u043D\u043E\u0432, \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440
    \u0411\u0443\u0442\u043B\u0435\u0440\u043E\u0432, \u041F\u0430\u0444\u043D\u0443\u0442\u0438\u0439
    \u0427\u0435\u0431\u044B\u0448\u0435\u0432, \u0418\u0432\u0430\u043D \u0422\u0443\u0440\u0433\u0435\u043D\u0435\u0432
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0435. \u0415\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u043C\u0443\u0436\u0435\u043C \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C
    \u0441\u0442\u0430\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C\u0438.
    \u0412 1878 \u0433\u043E\u0434\u0443 \u0443 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C
    \u0434\u043E\u0447\u044C, \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0442\u043E\u0436\u0435
    \u043D\u0430\u0437\u0432\u0430\u043B\u0438 \u0421\u043E\u0444\u044C\u0435\u0439,
    \u0430 \u0434\u043E\u043C\u0430 \u0437\u0432\u0430\u043B\u0438 \"\u0424\u0443\u0444\u0430\".
    \u041E\u0434\u043D\u0430\u043A\u043E \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0435
    \u0434\u0435\u043B\u0430 \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440\u0430
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u0440\u0430\u0437\u043B\u0430\u0434\u0438\u043B\u0438\u0441\u044C.
    \u0412 1883 \u0433\u043E\u0434\u0443, \u043F\u043E\u0433\u0440\u044F\u0437\u043D\u0443\u0432
    \u0432 \u0434\u043E\u043B\u0433\u0430\u0445, \u043E\u043D \u043F\u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0436\u0438\u0437\u043D\u044C \u0441\u0430\u043C\u043E\u0443\u0431\u0438\u0439\u0441\u0442\u0432\u043E\u043C.
    \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0434\u043B\u044F \u0421\u043E\u0444\u044C\u0438
    \u0442\u044F\u0436\u0435\u043B\u0435\u0439\u0448\u0435\u0439 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439. 
    ### \u0422\u0440\u0438\u0443\u043C\u0444 \u0432 \u0428\u0432\u0435\u0446\u0438\u0438
    \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435  \u041E\u0441\u0442\u0430\u0432\u0448\u0438\u0441\u044C
    \u0431\u0435\u0437 \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u0441 \u043F\u044F\u0442\u0438\u043B\u0435\u0442\u043D\u0435\u0439
    \u0434\u043E\u0447\u0435\u0440\u044C\u044E, \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u0432\u0435\u0440\u043D\u0443\u043B\u0430\u0441\u044C \u0432 \u0411\u0435\u0440\u043B\u0438\u043D
    \u043A \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u0443.
    \u0415\u0435 \u0443\u0447\u0438\u0442\u0435\u043B\u044C \u0438 \u0448\u0432\u0435\u0434\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0413\u0435\u0441\u0442\u0430
    \u041C\u0438\u0442\u0442\u0430\u0433-\u041B\u0435\u0444\u0444\u043B\u0435\u0440
    \u043F\u0440\u0438\u043B\u043E\u0436\u0438\u043B\u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435
    \u0443\u0441\u0438\u043B\u0438\u044F, \u0447\u0442\u043E\u0431\u044B \u043D\u0430\u0439\u0442\u0438
    \u0435\u0439 \u043C\u0435\u0441\u0442\u043E. \u0412 1884 \u0433\u043E\u0434\u0443
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u0431\u044B\u043B\u0430
    \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0430 \u0432 \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u0433\u0434\u0435
    \u0441\u0442\u0430\u043B\u0430 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C.
    \u041F\u0435\u0440\u0432\u044B\u0439 \u0433\u043E\u0434 \u043E\u043D\u0430 \u0447\u0438\u0442\u0430\u043B\u0430
    \u043B\u0435\u043A\u0446\u0438\u0438 \u043D\u0430 \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435, \u0430 \u0437\u0430\u0442\u0435\u043C \u043F\u0435\u0440\u0435\u0448\u043B\u0430
    \u043D\u0430 \u0448\u0432\u0435\u0434\u0441\u043A\u0438\u0439.  \u0412 \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C\u0435
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u0441\u0431\u043B\u0438\u0437\u0438\u043B\u0430\u0441\u044C
    \u0441 \u0431\u0440\u0430\u0442\u043E\u043C \u043F\u043E\u043A\u043E\u0439\u043D\u043E\u0433\u043E
    \u043C\u0443\u0436\u0430, \u0441\u043E\u0446\u0438\u043E\u043B\u043E\u0433\u043E\u043C
    **\u041C\u0430\u043A\u0441\u0438\u043C\u043E\u043C \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0438\u043C**.
    \u041E\u043D \u0431\u044B\u043B \u0432 \u0438\u0437\u0433\u043D\u0430\u043D\u0438\u0438,
    \u0438 \u0421\u043E\u0444\u044C\u044F \u043F\u043E\u043C\u043E\u0433\u043B\u0430
    \u0435\u043C\u0443 \u0443\u0441\u0442\u0440\u043E\u0438\u0442\u044C\u0441\u044F
    \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442.
    \u0418\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u043F\u0435\u0440\u0435\u0440\u043E\u0441\u043B\u0438
    \u0432 \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u044C.
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0438\u0439 \u0441\u0434\u0435\u043B\u0430\u043B
    \u0435\u0439 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435,
    \u043D\u043E \u0421\u043E\u0444\u044C\u044F \u043E\u0442\u0432\u0435\u0442\u0438\u043B\u0430
    \u043E\u0442\u043A\u0430\u0437\u043E\u043C. \u041E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u043D\u0438 \u0440\u0430\u0441\u0441\u0442\u0430\u043B\u0438\u0441\u044C
    \u0432 1890 \u0433\u043E\u0434\u0443 \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F
    \u043F\u043E \u0420\u0438\u0432\u044C\u0435\u0440\u0435.  \u0412 1888 \u0433\u043E\u0434\u0443
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u0434\u043E\u0431\u0438\u043B\u0430\u0441\u044C
    **\u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u0442\u0440\u0438\u0443\u043C\u0444\u0430**: \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u0443
    \"\u0417\u0430\u0434\u0430\u0447\u0430 \u043E \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
    \u0442\u0432\u0435\u0440\u0434\u043E\u0433\u043E \u0442\u0435\u043B\u0430 \u0432\u043E\u043A\u0440\u0443\u0433
    \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u0438\"
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0430\u044F \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044F
    \u043D\u0430\u0443\u043A \u043F\u0440\u0438\u0441\u0443\u0434\u0438\u043B\u0430
    \u0435\u0439 **\u043F\u0440\u0435\u043C\u0438\u044E \u0411\u043E\u0440\u0434\u0435\u043D\u0430**,
    \u0443\u0432\u0435\u043B\u0438\u0447\u0438\u0432 \u043F\u0440\u0438\u0437\u043E\u0432\u0443\u044E
    \u0441\u0443\u043C\u043C\u0443 \u0432\u0434\u0432\u043E\u0435 \u0432\u0432\u0438\u0434\u0443
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F.
    \u0412 1889 \u0433\u043E\u0434\u0443 \u0437\u0430 \u0432\u0442\u043E\u0440\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0430 \u0442\u0443 \u0436\u0435 \u0442\u0435\u043C\u0443
    \u043E\u043D\u0430 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 \u043F\u0440\u0435\u043C\u0438\u044E
    \u0428\u0432\u0435\u0434\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A. \u0412 \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443,
    \u043F\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044E
    \u041F\u0430\u0444\u043D\u0443\u0442\u0438\u044F \u0427\u0435\u0431\u044B\u0448\u0435\u0432\u0430
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0445 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u0432,
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u0431\u044B\u043B\u0430
    \u0438\u0437\u0431\u0440\u0430\u043D\u0430 \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A, \u0441\u0442\u0430\u0432
    **\u043F\u0435\u0440\u0432\u043E\u0439 \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439
    \u0432 \u0420\u043E\u0441\u0441\u0438\u0438**, \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D\u043D\u043E\u0439
    \u044D\u0442\u043E\u0433\u043E \u0437\u0432\u0430\u043D\u0438\u044F.  ### \u0421\u043C\u0435\u0440\u0442\u044C 
    \u0421\u043E\u0444\u044C\u044F \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u0443\u043C\u0435\u0440\u043B\u0430 \u0432 \u0440\u0430\u0441\u0446\u0432\u0435\u0442\u0435
    \u0441\u0438\u043B \u0438 \u0441\u043B\u0430\u0432\u044B. \u0412 \u043D\u0430\u0447\u0430\u043B\u0435
    1891 \u0433\u043E\u0434\u0430 \u043E\u043D\u0430 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u043B\u0430\u0441\u044C
    \u0438\u0437 \u041D\u0438\u0446\u0446\u044B, \u0433\u0434\u0435 \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B\u0430
    \u0440\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u0435\u043D\u0441\u043A\u0438\u0435
    \u043A\u0430\u043D\u0438\u043A\u0443\u043B\u044B \u0432\u043C\u0435\u0441\u0442\u0435
    \u0441 \u041C\u0430\u043A\u0441\u0438\u043C\u043E\u043C \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0438\u043C.
    \u041F\u043E \u0434\u043E\u0440\u043E\u0433\u0435 \u043E\u043D\u0430 \u0441\u0438\u043B\u044C\u043D\u043E
    \u043F\u0440\u043E\u0441\u0442\u0443\u0434\u0438\u043B\u0430\u0441\u044C. **10
    \u0444\u0435\u0432\u0440\u0430\u043B\u044F 1891 \u0433\u043E\u0434\u0430 \u0432
    \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C\u0435 \u043E\u043D\u0430
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C \u043E\u0442 \u0432\u043E\u0441\u043F\u0430\u043B\u0435\u043D\u0438\u044F
    \u043B\u0435\u0433\u043A\u0438\u0445 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    41 \u0433\u043E\u0434\u0430**. \u041F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D\u0430
    \u043E\u043D\u0430 \u0432 \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C\u0435."
  personalLifeEn: 
  shortBioRu: "\u0421\u043E\u0444\u044C\u044F \u0412\u0430\u0441\u0438\u043B\u044C\u0435\u0432\u043D\u0430
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F (\u0443\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u0430\u044F
    \u041A\u043E\u0440\u0432\u0438\u043D-\u041A\u0440\u0443\u043A\u043E\u0432\u0441\u043A\u0430\u044F)
    \u2014 \u0444\u0438\u0433\u0443\u0440\u0430, \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C
    \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u0430 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0437\u043C\u0430
    \u0438 \u0431\u043E\u0440\u044C\u0431\u044B \u0437\u0430 \u043F\u0440\u0430\u0432\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F \u043D\u0430\u0443\u043A\u043E\u0439.
    \u041E\u043D\u0430 \u0432\u043E\u0448\u043B\u0430 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E
    \u043A\u0430\u043A \u043F\u0435\u0440\u0432\u0430\u044F \u0432 \u043C\u0438\u0440\u0435
    \u0436\u0435\u043D\u0449\u0438\u043D\u0430-\u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u043F\u0435\u0440\u0432\u0430\u044F
    \u0436\u0435\u043D\u0449\u0438\u043D\u0430 \u2014 \u0447\u043B\u0435\u043D-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A.  \u0412\u043E\u0442
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044F
    \u0435\u0451 \u0436\u0438\u0437\u043D\u0438:  ### **\u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    (1850\u20131866)**  *   **\u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438
    \u0441\u0435\u043C\u044C\u044F:** \u0421\u043E\u0444\u044C\u044F \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C
    15 \u044F\u043D\u0432\u0430\u0440\u044F 1850 \u0433\u043E\u0434\u0430 \u0432
    \u041C\u043E\u0441\u043A\u0432\u0435, \u0432 \u0441\u0435\u043C\u044C\u0435 \u0433\u0435\u043D\u0435\u0440\u0430\u043B-\u043B\u0435\u0439\u0442\u0435\u043D\u0430\u043D\u0442\u0430
    \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u0438 \u0412\u0430\u0441\u0438\u043B\u0438\u044F
    \u0412\u0430\u0441\u0438\u043B\u044C\u0435\u0432\u0438\u0447\u0430 \u041A\u043E\u0440\u0432\u0438\u043D-\u041A\u0440\u0443\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0438 \u0415\u043B\u0438\u0437\u0430\u0432\u0435\u0442\u044B \u0424\u0451\u0434\u043E\u0440\u043E\u0432\u043D\u044B,
    \u0443\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u043E\u0439 \u0428\u0443\u0431\u0435\u0440\u0442.
    \u0420\u043E\u0434\u0438\u0442\u0435\u043B\u0438 \u043D\u0435 \u0431\u044B\u043B\u0438
    \u0440\u0430\u0434\u044B \u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u044E
    \u0434\u043E\u0447\u0435\u0440\u0438, \u043E\u0436\u0438\u0434\u0430\u044F \u0441\u044B\u043D\u0430,
    \u0438 \u0421\u043E\u0444\u044C\u044F \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430 \u0441\u0435\u0431\u044F
    \u043D\u0435\u043B\u044E\u0431\u0438\u043C\u044B\u043C \u0440\u0435\u0431\u0435\u043D\u043A\u043E\u043C,
    \u0437\u0430 \u0447\u0442\u043E \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430
    \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435 \"\u0434\u0438\u043A\u0430\u0440\u043A\u0430\".
    *   **\u041F\u0440\u0435\u0434\u043A\u0438:** \u0421\u044B\u0433\u0440\u0430\u043B\u0438
    \u0432\u0430\u0436\u043D\u0443\u044E \u0440\u043E\u043B\u044C \u0432 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438
    \u0435\u0451 \u0442\u0430\u043B\u0430\u043D\u0442\u0430. \u041F\u043E \u043E\u0442\u0446\u0443
    \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043F\u043E\u0442\u043E\u043C\u043A\u043E\u043C
    \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u044F
    \u041C\u0430\u0442\u0432\u0435\u044F \u041A\u043E\u0440\u0432\u0438\u043D\u0430,
    \u0430 \u043F\u043E \u043C\u0430\u0442\u0435\u0440\u0438 \u2014 \u0432\u043D\u0443\u0447\u043A\u043E\u0439
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0438 \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0441\u0442\u0430 \u0424\u0451\u0434\u043E\u0440\u0430
    \u0424\u0451\u0434\u043E\u0440\u043E\u0432\u0438\u0447\u0430 \u0428\u0443\u0431\u0435\u0440\u0442\u0430
    \u0438 \u043F\u0440\u0430\u0432\u043D\u0443\u0447\u043A\u043E\u0439 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430
    \u0424\u0451\u0434\u043E\u0440\u0430 \u0418\u0432\u0430\u043D\u043E\u0432\u0438\u0447\u0430
    \u0428\u0443\u0431\u0435\u0440\u0442\u0430. *   **\u041F\u0435\u0440\u0435\u0435\u0437\u0434
    \u0432 \u0438\u043C\u0435\u043D\u0438\u0435:** \u0412 1858 \u0433\u043E\u0434\u0443,
    \u043F\u043E\u0441\u043B\u0435 \u0432\u044B\u0445\u043E\u0434\u0430 \u043E\u0442\u0446\u0430
    \u0432 \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0443, \u0441\u0435\u043C\u044C\u044F
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430 \u0432 \u0440\u043E\u0434\u043E\u0432\u043E\u0435
    \u043F\u043E\u043C\u0435\u0441\u0442\u044C\u0435 \u041F\u043E\u043B\u0438\u0431\u0438\u043D\u043E
    \u0432 \u0412\u0438\u0442\u0435\u0431\u0441\u043A\u043E\u0439 \u0433\u0443\u0431\u0435\u0440\u043D\u0438\u0438
    (\u043D\u044B\u043D\u0435 \u041F\u0441\u043A\u043E\u0432\u0441\u043A\u0430\u044F
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C). \u0417\u0434\u0435\u0441\u044C \u043F\u0440\u043E\u0448\u043B\u0438
    \u0434\u0435\u0442\u0441\u043A\u0438\u0435 \u0433\u043E\u0434\u044B \u0421\u043E\u0444\u044C\u0438.
    *   **\u0414\u043E\u043C\u0430\u0448\u043D\u0435\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:**
    \u0412\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0435\u043C \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0430\u0441\u044C
    \u0441\u0442\u0440\u043E\u0433\u0430\u044F \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0430\u044F
    \u0433\u0443\u0432\u0435\u0440\u043D\u0430\u043D\u0442\u043A\u0430, \u0430 \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435\u043C
    \u2014 \u0434\u043E\u043C\u0430\u0448\u043D\u0438\u0439 \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u0418\u043E\u0441\u0438\u0444 \u0418\u0433\u043D\u0430\u0442\u044C\u0435\u0432\u0438\u0447
    \u041C\u0430\u043B\u0435\u0432\u0438\u0447. \u0417\u0430 \u0432\u043E\u0441\u0435\u043C\u044C
    \u043B\u0435\u0442 \u043E\u043D\u0430 \u043E\u0441\u0432\u043E\u0438\u043B\u0430
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443 \u043C\u0443\u0436\u0441\u043A\u0438\u0445
    \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0439. *   **\"\u0422\u0430\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F\"
    \u0441\u0442\u0435\u043D\u0430:** \u041E\u0434\u0438\u043D \u0438\u0437 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0430.
    \u0412 \u0435\u0451 \u043A\u043E\u043C\u043D\u0430\u0442\u0435 \u043D\u0435 \u0445\u0432\u0430\u0442\u0438\u043B\u043E
    \u043E\u0431\u043E\u0435\u0432, \u0438 \u0441\u0442\u0435\u043D\u0443 \u043E\u043A\u043B\u0435\u0438\u043B\u0438
    \u043B\u0438\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u043C\u0438
    \u043B\u0435\u043A\u0446\u0438\u044F\u043C\u0438 \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u0430
    \u041E\u0441\u0442\u0440\u043E\u0433\u0440\u0430\u0434\u0441\u043A\u043E\u0433\u043E.
    \u0421\u043E\u0444\u044C\u044F \u0447\u0430\u0441\u0430\u043C\u0438 \u0440\u0430\u0437\u0433\u043B\u044F\u0434\u044B\u0432\u0430\u043B\u0430
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \"\u0432\u0440\u0435\u0437\u0430\u043B\u0438\u0441\u044C\" \u0435\u0439 \u0432
    \u043F\u0430\u043C\u044F\u0442\u044C \u0438 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u0431\u043B\u0435\u0433\u0447\u0438\u043B\u0438 \u0431\u0443\u0434\u0443\u0449\u0435\u0435
    \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435. *   **\u041F\u0435\u0440\u0432\u044B\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438:** \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u041D\u0438\u043A\u043E\u043B\u0430\u0439 \u0422\u044B\u0440\u0442\u043E\u0432,
    \u0434\u0440\u0443\u0433 \u043E\u0442\u0446\u0430, \u0437\u0430\u043C\u0435\u0442\u0438\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0434\u0430\u0440 \u0434\u0435\u0432\u043E\u0447\u043A\u0438, \u043A\u043E\u0433\u0434\u0430
    \u0442\u0430 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0438\u0437\u0443\u0447\u0430\u044F \u0435\u0433\u043E \u0443\u0447\u0435\u0431\u043D\u0438\u043A
    \u0444\u0438\u0437\u0438\u043A\u0438, \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u043B\u0430\u0441\u044C
    \u0432 \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F\u0445. \u041E\u043D \u043D\u0430\u0437\u0432\u0430\u043B
    \u0435\u0451 \"\u043D\u043E\u0432\u044B\u043C \u041F\u0430\u0441\u043A\u0430\u043B\u0435\u043C\"
    \u0438 \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u043E\u0432\u0430\u043B
    \u043E\u0442\u0446\u0443 \u0434\u0430\u0442\u044C \u0435\u0439 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435, \u043D\u043E
    \u0433\u0435\u043D\u0435\u0440\u0430\u043B \u0441\u0447\u0435\u043B \u044D\u0442\u043E
    \u043D\u0435\u0443\u043C\u0435\u0441\u0442\u043D\u044B\u043C \u0434\u043B\u044F
    \u0436\u0435\u043D\u0449\u0438\u043D\u044B.  ### **\u042E\u043D\u043E\u0441\u0442\u044C,
    \u0444\u0438\u043A\u0442\u0438\u0432\u043D\u044B\u0439 \u0431\u0440\u0430\u043A
    \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0432
    \u0415\u0432\u0440\u043E\u043F\u0435 (1866\u20131874)**  *   **\u041F\u0443\u0442\u044C
    \u043A \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044E:**
    \u0412 1866 \u0433\u043E\u0434\u0443 \u0421\u043E\u0444\u044C\u044F \u043D\u0430\u0447\u0430\u043B\u0430
    \u0431\u0440\u0430\u0442\u044C \u0447\u0430\u0441\u0442\u043D\u044B\u0435 \u0443\u0440\u043E\u043A\u0438
    \u043F\u043E \u0432\u044B\u0441\u0448\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0443 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0430
    \u0410.\u041D. \u0421\u0442\u0440\u0430\u043D\u043D\u043E\u043B\u044E\u0431\u0441\u043A\u043E\u0433\u043E
    \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0435. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0434\u043B\u044F \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F \u0432\u044B\u0441\u0448\u0435\u0433\u043E
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F \u043F\u0443\u0442\u044C
    \u0432 \u0440\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u0438\u0435 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u044B
    \u0434\u043B\u044F \u0436\u0435\u043D\u0449\u0438\u043D \u0431\u044B\u043B \u0437\u0430\u043A\u0440\u044B\u0442.
    \u041C\u043E\u0436\u043D\u043E \u0431\u044B\u043B\u043E \u0443\u0435\u0445\u0430\u0442\u044C
    \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0443, \u043D\u043E \u0434\u043B\u044F
    \u044D\u0442\u043E\u0433\u043E \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u043E\u0441\u044C
    \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043E\u0442\u0446\u0430
    \u0438\u043B\u0438 \u043C\u0443\u0436\u0430. *   **\u0424\u0438\u043A\u0442\u0438\u0432\u043D\u044B\u0439
    \u0431\u0440\u0430\u043A:** \u0412\u043C\u0435\u0441\u0442\u0435 \u0441 \u0441\u0435\u0441\u0442\u0440\u043E\u0439
    \u0410\u043D\u043D\u043E\u0439, \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u043D\u043E\u0439
    \u0438\u0434\u0435\u044F\u043C\u0438 \u044D\u043C\u0430\u043D\u0441\u0438\u043F\u0430\u0446\u0438\u0438,
    \u0421\u043E\u0444\u044C\u044F \u0440\u0435\u0448\u0438\u043B\u0430 \u0437\u0430\u043A\u043B\u044E\u0447\u0438\u0442\u044C
    \u0444\u0438\u043A\u0442\u0438\u0432\u043D\u044B\u0439 \u0431\u0440\u0430\u043A.
    \u0412\u044B\u0431\u043E\u0440 \u043F\u0430\u043B \u043D\u0430 \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440\u0430
    \u041E\u043D\u0443\u0444\u0440\u0438\u0435\u0432\u0438\u0447\u0430 \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E.
    \u041E\u043D \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u043B\u0441\u044F, \u043D\u043E
    \u0432\u043B\u044E\u0431\u0438\u043B\u0441\u044F \u0432 \u0421\u043E\u0444\u044C\u044E
    \u0441 \u043F\u0435\u0440\u0432\u043E\u0433\u043E \u0432\u0437\u0433\u043B\u044F\u0434\u0430
    \u0438 \u043D\u0430\u0441\u0442\u043E\u044F\u043B \u043D\u0430 \u0431\u0440\u0430\u043A\u0435
    \u0438\u043C\u0435\u043D\u043D\u043E \u0441 \u043D\u0435\u0439. \u0421\u0432\u0430\u0434\u044C\u0431\u0430
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0430\u0441\u044C \u0432 1868 \u0433\u043E\u0434\u0443.
    *   **\u0413\u043E\u0434\u044B \u0443\u0447\u0435\u0431\u044B:**     *   **\u0413\u0435\u0439\u0434\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    (1869\u20131870):** \u041F\u043E\u0441\u043B\u0435 \u043F\u0435\u0440\u0435\u0435\u0437\u0434\u0430
    \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0443 \u0421\u043E\u0444\u044C\u044F
    \u0434\u043E\u0431\u0438\u043B\u0430\u0441\u044C \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0441\u043B\u0443\u0448\u0430\u0442\u044C \u043B\u0435\u043A\u0446\u0438\u0438
    \u0432 \u0413\u0435\u0439\u0434\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u0443
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.    
    *   **\u0411\u0435\u0440\u043B\u0438\u043D (1870\u20131874):** \u0416\u0435\u043D\u0449\u0438\u043D\u0430\u043C
    \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u0432\u0445\u043E\u0434 \u0431\u044B\u043B \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D.
    \u0422\u043E\u0433\u0434\u0430 \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u043E\u0431\u0440\u0430\u0442\u0438\u043B\u0430\u0441\u044C \u043A \u0432\u0435\u043B\u0438\u043A\u043E\u043C\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u041A\u0430\u0440\u043B\u0443
    \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u0443. \u0427\u0442\u043E\u0431\u044B
    \u0438\u0437\u0431\u0430\u0432\u0438\u0442\u044C\u0441\u044F \u043E\u0442 \u043D\u0430\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0439
    \u0443\u0447\u0435\u043D\u0438\u0446\u044B, \u043E\u043D \u0434\u0430\u043B \u0435\u0439
    \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0435 \u0437\u0430\u0434\u0430\u0447\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043D\u0430 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435
    \u0440\u0435\u0448\u0438\u043B\u0430. \u0412\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u043D\u044B\u0439
    \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441 \u0441\u0442\u0430\u043B
    \u0434\u0430\u0432\u0430\u0442\u044C \u0435\u0439 \u0447\u0430\u0441\u0442\u043D\u044B\u0435
    \u0443\u0440\u043E\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B\u0438\u0441\u044C
    \u0447\u0435\u0442\u044B\u0440\u0435 \u0433\u043E\u0434\u0430. *   **\u0414\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0430\u044F
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C:** \u0412 1874 \u0433\u043E\u0434\u0443,
    \u043C\u0438\u043D\u0443\u044F \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438,
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u043F\u0440\u0438\u0441\u0443\u0434\u0438\u043B
    \u0421\u043E\u0444\u044C\u0435 \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0434\u043E\u043A\u0442\u043E\u0440\u0430
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u0437\u0430 \u0442\u0440\u0438
    \u0440\u0430\u0431\u043E\u0442\u044B, \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435
    \u043F\u043E \"\u041A \u0442\u0435\u043E\u0440\u0438\u0438 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0432 \u0447\u0430\u0441\u0442\u043D\u044B\u0445
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0445\" \u0438 \"\u041E
    \u0444\u043E\u0440\u043C\u0435 \u043A\u043E\u043B\u044C\u0446\u0430 \u0421\u0430\u0442\u0443\u0440\u043D\u0430\". 
    ### **\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0432
    \u0420\u043E\u0441\u0441\u0438\u044E, \u043B\u0438\u0447\u043D\u044B\u0435 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438
    \u0438 \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    (1874\u20131891)**  *   **\u041D\u0435\u0443\u0434\u0430\u0447\u0438 \u043D\u0430
    \u0440\u043E\u0434\u0438\u043D\u0435:** \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C
    \u0432 \u0420\u043E\u0441\u0441\u0438\u044E \u0432 1874 \u0433\u043E\u0434\u0443,
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0430\u0441\u044C
    \u0441 \u043D\u0435\u043F\u0440\u0438\u044F\u0442\u0438\u0435\u043C. \u0415\u0439
    \u043D\u0435 \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438
    \u043C\u0435\u0441\u0442\u0430 \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u0438 \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u0430
    \u043F\u043E\u0447\u0442\u0438 \u043D\u0430 6 \u043B\u0435\u0442 \u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0430\u043A\u0442\u0438\u0432\u043D\u0443\u044E \u043D\u0430\u0443\u0447\u043D\u0443\u044E
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C. *  
    **\u0421\u0435\u043C\u0435\u0439\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C:**
    \u0424\u0438\u043A\u0442\u0438\u0432\u043D\u044B\u0439 \u0431\u0440\u0430\u043A
    \u043F\u0435\u0440\u0435\u0440\u043E\u0441 \u0432 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439.
    \u0412 1878 \u0433\u043E\u0434\u0443 \u0443 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C
    \u0434\u043E\u0447\u044C \u0421\u043E\u0444\u044C\u044F (\"\u0424\u0443\u0444\u0430\").
    \u041E\u0434\u043D\u0430\u043A\u043E \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0435
    \u0434\u0435\u043B\u0430 \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440\u0430
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u0440\u0430\u0437\u043B\u0430\u0434\u0438\u043B\u0438\u0441\u044C.
    \u0412 1883 \u0433\u043E\u0434\u0443, \u043F\u043E\u0433\u0440\u044F\u0437\u043D\u0443\u0432
    \u0432 \u0434\u043E\u043B\u0433\u0430\u0445, \u043E\u043D \u043F\u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0436\u0438\u0437\u043D\u044C \u0441\u0430\u043C\u043E\u0443\u0431\u0438\u0439\u0441\u0442\u0432\u043E\u043C,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0442\u044F\u0436\u0435\u043B\u044B\u043C
    \u0443\u0434\u0430\u0440\u043E\u043C \u0434\u043B\u044F \u0421\u043E\u0444\u044C\u0438.
    *   **\u0422\u0440\u0438\u0443\u043C\u0444 \u0432 \u0428\u0432\u0435\u0446\u0438\u0438:**
    \u0412 1884 \u0433\u043E\u0434\u0443, \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0443\u0441\u0438\u043B\u0438\u044F\u043C \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u0430
    \u0438 \u0448\u0432\u0435\u0434\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u041C\u0438\u0442\u0442\u0430\u0433-\u041B\u0435\u0444\u0444\u043B\u0435\u0440\u0430,
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430
    \u043C\u0435\u0441\u0442\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0432 \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. \u041E\u043D\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u043E\u0439 \u0432 \u043C\u0438\u0440\u0435
    \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439, \u0437\u0430\u043D\u044F\u0432\u0448\u0435\u0439
    \u044D\u0442\u0443 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C. \u041F\u0435\u0440\u0432\u044B\u0439
    \u0433\u043E\u0434 \u043E\u043D\u0430 \u0447\u0438\u0442\u0430\u043B\u0430 \u043B\u0435\u043A\u0446\u0438\u0438
    \u043F\u043E-\u043D\u0435\u043C\u0435\u0446\u043A\u0438, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E \u043F\u0435\u0440\u0435\u0448\u043B\u0430
    \u043D\u0430 \u0448\u0432\u0435\u0434\u0441\u043A\u0438\u0439 \u044F\u0437\u044B\u043A.
    *   **\u0412\u0435\u0440\u0448\u0438\u043D\u0430 \u0441\u043B\u0430\u0432\u044B
    (1888\u20131889):** \u0412 1888 \u0433\u043E\u0434\u0443 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0430\u044F
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044F \u043D\u0430\u0443\u043A \u043F\u0440\u0438\u0441\u0443\u0434\u0438\u043B\u0430
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u044E
    \u0411\u043E\u0440\u0434\u0435\u043D\u0430 \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u0443,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D\u0430 \u0440\u0435\u0448\u0438\u043B\u0430
    \"\u0437\u0430\u0434\u0430\u0447\u0443 \u043E \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
    \u0442\u0432\u0435\u0440\u0434\u043E\u0433\u043E \u0442\u0435\u043B\u0430 \u0432\u043E\u043A\u0440\u0443\u0433
    \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u0438\",
    \u043E\u0442\u043A\u0440\u044B\u0432 \u0442\u0440\u0435\u0442\u0438\u0439 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u043B\u0443\u0447\u0430\u0439 \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u044D\u0442\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0438. \u0412 1889 \u0433\u043E\u0434\u0443
    \u043E\u043D\u0430 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 \u043F\u0440\u0435\u043C\u0438\u044E
    \u0428\u0432\u0435\u0434\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u0438, \u043D\u0430\u043A\u043E\u043D\u0435\u0446,
    \u0431\u044B\u043B\u0430 \u0438\u0437\u0431\u0440\u0430\u043D\u0430 \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A, \u0441\u0442\u0430\u0432
    \u043F\u0435\u0440\u0432\u043E\u0439 \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439,
    \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D\u043D\u043E\u0439 \u044D\u0442\u043E\u0439
    \u0447\u0435\u0441\u0442\u0438 \u0432 \u0420\u043E\u0441\u0441\u0438\u0438. 
    ### **\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u0438
    \u0441\u043C\u0435\u0440\u0442\u044C**  *   **\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B:** \u0412 \u043A\u043E\u043D\u0446\u0435 1880-\u0445
    \u0431\u043B\u0438\u0437\u043A\u0438\u043C \u0434\u0440\u0443\u0433\u043E\u043C
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u0441\u0442\u0430\u043B
    \u0441\u043E\u0446\u0438\u043E\u043B\u043E\u0433 \u041C\u0430\u043A\u0441\u0438\u043C
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0438\u0439 (\u043E\u0434\u043D\u043E\u0444\u0430\u043C\u0438\u043B\u0435\u0446
    \u043F\u043E\u043A\u043E\u0439\u043D\u043E\u0433\u043E \u043C\u0443\u0436\u0430).
    \u041E\u043D\u0438 \u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u043F\u043E\u0436\u0435\u043D\u0438\u0442\u044C\u0441\u044F, \u043D\u043E \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0442\u0430\u043A \u0438
    \u043D\u0435 \u043E\u0444\u043E\u0440\u043C\u0438\u043B\u0438. *   **\u0421\u043C\u0435\u0440\u0442\u044C:**
    \u0421\u043E\u0444\u044C\u044F \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C 10 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    (29 \u044F\u043D\u0432\u0430\u0440\u044F \u043F\u043E \u0441\u0442\u0430\u0440\u043E\u043C\u0443
    \u0441\u0442\u0438\u043B\u044E) 1891 \u0433\u043E\u0434\u0430 \u0432 \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C\u0435
    \u043E\u0442 \u0432\u043E\u0441\u043F\u0430\u043B\u0435\u043D\u0438\u044F \u043B\u0435\u0433\u043A\u0438\u0445,
    \u0432\u0441\u0435\u0433\u043E \u0432 41 \u0433\u043E\u0434. \u041E\u043D\u0430
    \u043F\u0440\u043E\u0441\u0442\u0443\u0434\u0438\u043B\u0430\u0441\u044C \u0432\u043E
    \u0432\u0440\u0435\u043C\u044F \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u0438\u0437 \u043F\u043E\u0435\u0437\u0434\u043A\u0438 \u043F\u043E \u0420\u0438\u0432\u044C\u0435\u0440\u0435. 
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u0431\u044B\u043B\u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u043D\u043E \u0438 \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u043C
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u043E\u0440\u043E\u043C. \u041E\u043D\u0430
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430 \u043F\u043E\u0441\u043B\u0435
    \u0441\u0435\u0431\u044F \u0430\u0432\u0442\u043E\u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043F\u043E\u0432\u0435\u0441\u0442\u044C **\"\u0412\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F
    \u0434\u0435\u0442\u0441\u0442\u0432\u0430\"** \u0438 \u0440\u043E\u043C\u0430\u043D
    **\"\u041D\u0438\u0433\u0438\u043B\u0438\u0441\u0442\u043A\u0430\"**. \u0415\u0451
    \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439 \u0441\u0438\u043B\u044B
    \u0432\u043E\u043B\u0438, \u0441\u0442\u043E\u043B\u043A\u043D\u043E\u0432\u0435\u043D\u0438\u044F
    \u0433\u0435\u043D\u0438\u044F \u0441 \u043F\u0440\u0435\u0434\u0440\u0430\u0441\u0441\u0443\u0434\u043A\u0430\u043C\u0438
    \u044D\u043F\u043E\u0445\u0438 \u0438 \u043F\u043E\u0438\u0441\u043A\u0430 \u043B\u0438\u0447\u043D\u043E\u0433\u043E
    \u0441\u0447\u0430\u0441\u0442\u044C\u044F."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0421\u043E\u0444\u044C\u0438
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u043F\u043E\u043B\u043D\u0430
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u0441\u043E\u0432\u043F\u0430\u0434\u0435\u043D\u0438\u0439,
    \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043E\u0432 \u0438 \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445
    \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u0435\u043B\u0430\u044E\u0442 \u0435\u0451 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E
    \u043F\u043E\u0445\u043E\u0436\u0435\u0439 \u043D\u0430 \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0440\u043E\u043C\u0430\u043D. \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435 \u0438\u0437 \u043D\u0438\u0445. 
    ### \U0001F9F1 \"\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0431\u043E\u0438\" \u0438 \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u043E  \u041F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u0443\u0440\u044C\u0451\u0437 \u0438\u0437 \u0435\u0451 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
    \u2014 \u044D\u0442\u043E \u0441\u043B\u0443\u0447\u0430\u0439 \u0441 \u043E\u0431\u043E\u044F\u043C\u0438.
    \u041A\u043E\u0433\u0434\u0430 \u0441\u0435\u043C\u044C\u044F \u0436\u0438\u043B\u0430
    \u0432 \u0438\u043C\u0435\u043D\u0438\u0438 \u041F\u0430\u043B\u0438\u0431\u0438\u043D\u043E,
    \u043D\u0430 \u043E\u0434\u043D\u0443 \u0438\u0437 \u0441\u0442\u0435\u043D \u0432
    \u0434\u0435\u0442\u0441\u043A\u043E\u0439 \u043A\u043E\u043C\u043D\u0430\u0442\u0435
    \u043D\u0435 \u0445\u0432\u0430\u0442\u0438\u043B\u043E \u043E\u0431\u044B\u0447\u043D\u044B\u0445
    \u043E\u0431\u043E\u0435\u0432, \u0438 \u0435\u0451 \u043E\u043A\u043B\u0435\u0438\u043B\u0438
    \u043B\u0438\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u043C\u0438
    \u043B\u0438\u0441\u0442\u0430\u043C\u0438 \u043B\u0435\u043A\u0446\u0438\u0439
    \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u0430
    \u041E\u0441\u0442\u0440\u043E\u0433\u0440\u0430\u0434\u0441\u043A\u043E\u0433\u043E.
    \u041C\u0430\u043B\u0435\u043D\u044C\u043A\u0430\u044F \u0421\u043E\u043D\u044F
    \u0447\u0430\u0441\u0430\u043C\u0438 \u0440\u0430\u0437\u0433\u043B\u044F\u0434\u044B\u0432\u0430\u043B\u0430
    \u043D\u0435\u043F\u043E\u043D\u044F\u0442\u043D\u044B\u0435 \u0444\u043E\u0440\u043C\u0443\u043B\u044B,
    \u0438 \u043E\u043D\u0438 \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E
    \u0432\u0440\u0435\u0437\u0430\u043B\u0438\u0441\u044C \u0435\u0439 \u0432 \u043F\u0430\u043C\u044F\u0442\u044C.
    \u0413\u043E\u0434\u044B \u0441\u043F\u0443\u0441\u0442\u044F, \u043A\u043E\u0433\u0434\u0430
    \u043E\u043D\u0430 \u043D\u0430\u0447\u0430\u043B\u0430 \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u043E
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0443 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0430
    \u0421\u0442\u0440\u0430\u043D\u043D\u043E\u043B\u044E\u0431\u0441\u043A\u043E\u0433\u043E,
    \u0435\u0439 \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C, \u0447\u0442\u043E
    \u043E\u043D\u0430 \u0443\u0436\u0435 \u0432\u0441\u0451 \u044D\u0442\u043E \u0437\u043D\u0430\u0435\u0442
    \u2014 \u0444\u043E\u0440\u043C\u0443\u043B\u044B \u0432\u0441\u043F\u043B\u044B\u0432\u0430\u043B\u0438
    \u0432 \u043F\u0430\u043C\u044F\u0442\u0438 \u0438\u0437 \u0434\u0435\u0442\u0441\u0442\u0432\u0430. 
    \u041A \u044D\u0442\u043E\u043C\u0443 \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0438 \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0444\u0430\u043A\u0442:
    \u0435\u0451 \u043C\u0430\u0442\u0435\u0440\u0438 \u043F\u0440\u0438\u0441\u043D\u0438\u043B\u0441\u044F
    \u0441\u043E\u043D, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0441\u043A\u0430\u0437\u0430\u043B: \xAB\u0422\u0432\u043E\u044F \u0434\u043E\u0447\u044C
    \u0431\u0443\u0434\u0435\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C\xBB.
    \u042D\u0442\u043E\u0442 \u0441\u043E\u043D \u0421\u043E\u0444\u044C\u044F \u043F\u043E\u0437\u0436\u0435
    \u043E\u043F\u0438\u0441\u0430\u043B\u0430 \u0432 \u0441\u0432\u043E\u0438\u0445
    \u043C\u0435\u043C\u0443\u0430\u0440\u0430\u0445.  ### \u2764\uFE0F \u041B\u044E\u0431\u043E\u0432\u044C,
    \u0444\u0438\u043A\u0442\u0438\u0432\u043D\u044B\u0439 \u0431\u0440\u0430\u043A
    \u0438 \"\u043A\u043E\u043D\u0441\u0435\u0440\u0432\u044B\"  \u0412 1860-\u0435
    \u0433\u043E\u0434\u044B \u0432\u044B\u0441\u0448\u0435\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0434\u043B\u044F \u0436\u0435\u043D\u0449\u0438\u043D \u0432 \u0420\u043E\u0441\u0441\u0438\u0438
    \u0431\u044B\u043B\u043E \u0437\u0430\u043A\u0440\u044B\u0442\u043E. \u0427\u0442\u043E\u0431\u044B
    \u0443\u0447\u0438\u0442\u044C\u0441\u044F \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0435\u0439,
    \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u043E\u0441\u044C \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u043E\u0442\u0446\u0430 \u0438\u043B\u0438 \u043C\u0443\u0436\u0430. \u0421\u043E\u0444\u044C\u044F
    \u0438 \u0435\u0451 \u0441\u0435\u0441\u0442\u0440\u0430 \u0410\u043D\u043D\u0430
    \u043D\u0430\u0448\u043B\u0438 \u0432\u044B\u0445\u043E\u0434 \u0432 \"\u0444\u0438\u043A\u0442\u0438\u0432\u043D\u043E\u043C
    \u0431\u0440\u0430\u043A\u0435\" \u2014 \u043C\u043E\u043B\u043E\u0434\u044B\u0435
    \u043B\u044E\u0434\u0438 \u0438\u0437 \u043A\u0440\u0443\u0433\u0430 \u044D\u043C\u0430\u043D\u0441\u0438\u043F\u0435
    \u0441\u043E\u0433\u043B\u0430\u0448\u0430\u043B\u0438\u0441\u044C \u0436\u0435\u043D\u0438\u0442\u044C\u0441\u044F
    \u0438 \u0443\u0432\u043E\u0437\u0438\u0442\u044C \u0434\u0435\u0432\u0443\u0448\u0435\u043A
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0443.  \u0412 \u043A\u0440\u0443\u0436\u043A\u0435
    \u0441\u0435\u0441\u0442\u0451\u0440 \u0442\u0430\u043A\u0438\u0445 \u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u0443\u0436\u0435\u0439 \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    **\"\u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u043C\u0438\"**, \u0430
    \u0441\u0430\u043C \u043F\u043B\u0430\u043D \u043F\u043E\u0431\u0435\u0433\u0430
    \u0438\u043C\u0435\u043D\u043E\u0432\u0430\u043B\u0441\u044F **\"\u043A\u0443\u0445\u043D\u0435\u0439\"**.
    \u041A\u043E\u0433\u0434\u0430 \u0432 \u0433\u043E\u0441\u0442\u0438\u043D\u043E\u0439
    \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u043C\u043E\u043B\u043E\u0434\u043E\u0439
    \u0443\u0447\u0451\u043D\u044B\u0439 \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0438\u0439, \u043E\u043D,
    \u043D\u0435\u0434\u043E\u043B\u0433\u043E \u0434\u0443\u043C\u0430\u044F, \u0432\u044B\u0431\u0440\u0430\u043B
    \u0421\u043E\u0444\u044C\u044E \u0438 \u0441\u043A\u0430\u0437\u0430\u043B: **\"\u0413\u043E\u0442\u043E\u0432
    \u0436\u0435\u043D\u0438\u0442\u044C\u0441\u044F \u0445\u043E\u0442\u044C \u0437\u0430\u0432\u0442\u0440\u0430!\"**. 
    \u0418\u0440\u043E\u043D\u0438\u044F \u0441\u0443\u0434\u044C\u0431\u044B \u0432
    \u0442\u043E\u043C, \u0447\u0442\u043E \u0444\u0438\u043A\u0442\u0438\u0432\u043D\u044B\u0439
    \u0431\u0440\u0430\u043A, \u0437\u0430\u043A\u043B\u044E\u0447\u0451\u043D\u043D\u044B\u0439
    \u0440\u0430\u0434\u0438 \u043D\u0430\u0443\u043A\u0438, \u0447\u0435\u0440\u0435\u0437
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043B\u0435\u0442 \u0441\u0442\u0430\u043B
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C, \u0438 \u0443 \u043D\u0438\u0445
    \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u0434\u043E\u0447\u044C.  ###
    \U0001F3AD \"\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0440\u0443\u0441\u0430\u043B\u043A\u0430\" \u0438 \u0434\u0432\u043E\u0439\u043D\u043E\u0439
    \u043F\u0440\u0438\u0437  \u0417\u0430\u0434\u0430\u0447\u0430 \u043E \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
    \u0442\u0432\u0451\u0440\u0434\u043E\u0433\u043E \u0442\u0435\u043B\u0430, \u0437\u0430
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430
    \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0441\u043B\u0430\u0432\u0443, \u0431\u044B\u043B\u0430
    \u0442\u0430\u043A \u0441\u043B\u043E\u0436\u043D\u0430, \u0447\u0442\u043E \u0441\u0440\u0435\u0434\u0438
    \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u043E\u043D\u0430 \u043D\u043E\u0441\u0438\u043B\u0430 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435
    **\"Die mathematische Nixe\"** (\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0440\u0443\u0441\u0430\u043B\u043A\u0430). \u042D\u0442\u043E \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435
    \u043E\u0442\u0440\u0430\u0436\u0430\u043B\u043E \u0435\u0451 \"\u043D\u0435\u0443\u043B\u043E\u0432\u0438\u043C\u043E\u0441\u0442\u044C\"
    \u2014 \u043D\u0430\u0434 \u0440\u0435\u0448\u0435\u043D\u0438\u0435\u043C \u0431\u0438\u043B\u0438\u0441\u044C
    \u043B\u0443\u0447\u0448\u0438\u0435 \u0443\u043C\u044B, \u043D\u043E \u043E\u043D\u0430
    \u0443\u0441\u043A\u043E\u043B\u044C\u0437\u0430\u043B\u0430 \u043E\u0442 \u043D\u0438\u0445. 
    \u041A\u043E\u0433\u0434\u0430 \u0432 1888 \u0433\u043E\u0434\u0443 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0430\u044F
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044F \u043D\u0430\u0443\u043A \u043F\u0440\u0438\u0441\u0443\u0434\u0438\u043B\u0430
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u044E
    \u0411\u043E\u0440\u0434\u0435\u043D\u0430 \u0437\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u044D\u0442\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0438, \u0441\u0443\u043C\u043C\u0430
    \u043F\u0440\u0435\u043C\u0438\u0438 \u0431\u044B\u043B\u0430 **\u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u0430
    \u0432\u0434\u0432\u043E\u0435** (\u0441 3000 \u0434\u043E 5000 \u0444\u0440\u0430\u043D\u043A\u043E\u0432)
    \u2014 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u0438
    \u0431\u044B\u043B\u0438 \u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u044B
    \u0435\u0451 \u0440\u0430\u0431\u043E\u0442\u043E\u0439. \u0415\u0451 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0434\u0430\u043D\u0430 \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u043E,
    \u043F\u043E\u0434 \u0434\u0435\u0432\u0438\u0437\u043E\u043C: **\xAB\u0413\u043E\u0432\u043E\u0440\u0438,
    \u0447\u0442\u043E \u0437\u043D\u0430\u0435\u0448\u044C, \u0434\u0435\u043B\u0430\u0439,
    \u0447\u0442\u043E \u0434\u043E\u043B\u0436\u0435\u043D, \u0438 \u043F\u0443\u0441\u0442\u044C
    \u0431\u0443\u0434\u0435\u0442, \u0447\u0442\u043E \u0431\u0443\u0434\u0435\u0442\xBB**. 
    ### \U0001F48E \"\u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u0430\u044F\"
    \u043A\u0440\u043E\u0432\u044C \u0438 \u0443\u043F\u0440\u044F\u043C\u044B\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440  \u0421\u043E\u0444\u044C\u044F
    \u0412\u0430\u0441\u0438\u043B\u044C\u0435\u0432\u043D\u0430 \u043B\u044E\u0431\u0438\u043B\u0430
    \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u0442\u044C, \u0447\u0442\u043E \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430
    \u0441\u0432\u043E\u0438 \u0442\u0430\u043B\u0430\u043D\u0442\u044B \u0438 \u0447\u0435\u0440\u0442\u044B
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0430 \u0432 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E
    \u043E\u0442 \u0440\u0430\u0437\u043D\u044B\u0445 \u043F\u0440\u0435\u0434\u043A\u043E\u0432.
    \u041E\u043D\u0430 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0430:  > **\xAB\u042F
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 \u0432 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E
    \u0441\u0442\u0440\u0430\u0441\u0442\u044C \u043A \u043D\u0430\u0443\u043A\u0435
    \u043E\u0442 \u043F\u0440\u0435\u0434\u043A\u0430, \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u044F \u041C\u0430\u0442\u0432\u0435\u044F \u041A\u043E\u0440\u0432\u0438\u043D\u0430;
    \u043B\u044E\u0431\u043E\u0432\u044C \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u043C\u0443\u0437\u044B\u043A\u0435, \u043F\u043E\u044D\u0437\u0438\u0438 \u2014
    \u043E\u0442 \u0434\u0435\u0434\u0430 \u043F\u043E \u043C\u0430\u0442\u0435\u0440\u0438,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430 \u0428\u0443\u0431\u0435\u0440\u0442\u0430;
    \u043B\u0438\u0447\u043D\u0443\u044E \u0441\u0432\u043E\u0431\u043E\u0434\u0443
    \u2014 \u043E\u0442 \u041F\u043E\u043B\u044C\u0448\u0438; \u043E\u0442 \u0446\u044B\u0433\u0430\u043D\u043A\u0438-\u043F\u0440\u0430\u0431\u0430\u0431\u043A\u0438
    \u2014 \u043B\u044E\u0431\u043E\u0432\u044C \u043A \u0431\u0440\u043E\u0434\u044F\u0436\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0443
    \u0438 \u043D\u0435\u0443\u043C\u0435\u043D\u0438\u0435 \u043F\u043E\u0434\u0447\u0438\u043D\u044F\u0442\u044C\u0441\u044F
    \u043F\u0440\u0438\u043D\u044F\u0442\u044B\u043C \u043E\u0431\u044B\u0447\u0430\u044F\u043C;
    \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0435 \u2014 \u043E\u0442 \u0420\u043E\u0441\u0441\u0438\u0438\xBB**. 
    \u042D\u0442\u043E \"\u043D\u0435\u0443\u043C\u0435\u043D\u0438\u0435 \u043F\u043E\u0434\u0447\u0438\u043D\u044F\u0442\u044C\u0441\u044F\"
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u043E\u0441\u044C \u0438 \u0432 \u043F\u043E\u043F\u044B\u0442\u043A\u0430\u0445
    \u043D\u0430\u0439\u0442\u0438 \u0441\u0432\u043E\u0451 \u043C\u0435\u0441\u0442\u043E
    \u043D\u0430 \u0440\u043E\u0434\u0438\u043D\u0435. \u0412 1890 \u0433\u043E\u0434\u0443,
    \u0443\u0436\u0435 \u0431\u0443\u0434\u0443\u0447\u0438 \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A, \u043E\u043D\u0430
    \u043F\u0440\u0438\u0435\u0445\u0430\u043B\u0430 \u0432 \u0420\u043E\u0441\u0441\u0438\u044E
    \u0441 \u043D\u0430\u0434\u0435\u0436\u0434\u043E\u0439 \u0437\u0430\u043D\u044F\u0442\u044C
    \u043C\u0435\u0441\u0442\u043E \u0443\u043C\u0435\u0440\u0448\u0435\u0433\u043E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u0430. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0439 \u0443\u043A\u0430\u0437\u0430\u043B\u0438 \u043D\u0430 \u0434\u0432\u0435\u0440\u044C
    \u0441\u043E \u0441\u043B\u043E\u0432\u0430\u043C\u0438: **\xAB\u041F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435
    \u0436\u0435\u043D\u0449\u0438\u043D \u043D\u0430 \u0437\u0430\u0441\u0435\u0434\u0430\u043D\u0438\u044F\u0445
    \u043D\u0435 \u0432 \u043E\u0431\u044B\u0447\u0430\u044F\u0445 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438\xBB**. 
    ### \U0001F58B\uFE0F \u041F\u0438\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0430,
    \u043F\u043E\u044D\u0442\u0435\u0441\u0441\u0430 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0432 \u043E\u0434\u043D\u043E\u043C \u043B\u0438\u0446\u0435  \u0421\u043E\u0444\u044C\u044F
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u0431\u044B\u043B\u0430
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u043D\u043E
    \u0438 \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u043E\u0439 \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0435\u0439.
    \u041E\u043D\u0430 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u0432\u044B\u0443\u0447\u0438\u043B\u0430
    \u0448\u0432\u0435\u0434\u0441\u043A\u0438\u0439 \u044F\u0437\u044B\u043A \u0437\u0430
    \u0433\u043E\u0434, \u0447\u0442\u043E\u0431\u044B \u0447\u0438\u0442\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0432 \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C\u0435,
    \u0438 \u0434\u0430\u0436\u0435 \u043D\u0430\u043F\u0438\u0441\u0430\u043B\u0430
    \u043D\u0430 \u043D\u0451\u043C \u0440\u043E\u043C\u0430\u043D **\xAB\u0411\u043E\u0440\u044C\u0431\u0430
    \u0437\u0430 \u0441\u0447\u0430\u0441\u0442\u044C\u0435. \u0414\u0432\u0435 \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u0435
    \u0434\u0440\u0430\u043C\u044B\xBB**.  \u0412 \u043E\u0441\u043D\u043E\u0432\u0443
    \u044D\u0442\u043E\u0433\u043E \u0440\u043E\u043C\u0430\u043D\u0430 \u043E\u043D\u0430
    \u043F\u043E\u043B\u043E\u0436\u0438\u043B\u0430 \u0441\u0432\u043E\u044E \u043D\u0430\u0443\u0447\u043D\u0443\u044E
    \u0438\u0434\u0435\u044E \u043E \u0442\u043E\u0447\u043A\u0430\u0445 \u0431\u0438\u0444\u0443\u0440\u043A\u0430\u0446\u0438\u0438
    \u0432 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u0445, \u0433\u0434\u0435
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0443\u0435\u043C\u043E\u0435
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0441\u043E\u0431\u044B\u0442\u0438\u0439
    \u0432\u043D\u0435\u0437\u0430\u043F\u043D\u043E \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
    \u0432 \"\u043E\u0441\u043E\u0431\u043E\u0439 \u0442\u043E\u0447\u043A\u0435\".
    \u041E\u043D\u0430 \u0441\u0447\u0438\u0442\u0430\u043B\u0430, \u0447\u0442\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0443\u0441\u0442\u0440\u043E\u0435\u043D\u0430 \u043F\u043E\u0445\u043E\u0436\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C."
