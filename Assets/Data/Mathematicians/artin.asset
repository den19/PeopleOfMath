  achievementsRu: "\u042D\u043C\u0438\u043B\u044C \u0410\u0440\u0442\u0438\u043D
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0441\u043B\u0435\u0434 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u0438 \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u0432\u044B\u0445\u043E\u0434\u0438\u0442
    \u0434\u0430\u043B\u0435\u043A\u043E \u0437\u0430 \u0440\u0430\u043C\u043A\u0438
    \u043E\u0434\u043D\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. \u041E\u043D
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0435\u0448\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438
    \u2014 \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B \u043D\u043E\u0432\u044B\u0435
    \u044F\u0437\u044B\u043A\u0438 \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432 \u0438 \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0438\u0432\u0430\u043B
    \u0446\u0435\u043B\u044B\u0435 \u0442\u0435\u043E\u0440\u0438\u0438. \u0415\u0433\u043E
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043E\u043D \u0432\u044B\u0441\u0442\u0443\u043F\u0438\u043B
    \u043A\u0430\u043A \u043D\u043E\u0432\u0430\u0442\u043E\u0440, \u043C\u043E\u0436\u043D\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439.  ### \U0001F4DC
    \u0417\u0430\u043A\u043E\u043D \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438
    \u0410\u0440\u0442\u0438\u043D\u0430: \u0432\u0435\u043D\u0435\u0446 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043F\u043E\u043B\u0435\u0439 \u043A\u043B\u0430\u0441\u0441\u043E\u0432  \u042D\u0442\u043E,
    \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E, \u0435\u0433\u043E
    \u0441\u0430\u043C\u043E\u0435 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B \"\u0432\u0435\u0440\u0448\u0438\u043D\u043E\u0439\"
    \u0441\u0432\u043E\u0435\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u044B. \u0412
    1927 \u0433\u043E\u0434\u0443 \u0410\u0440\u0442\u0438\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    **\u043E\u0431\u0449\u0438\u0439 \u0437\u0430\u043A\u043E\u043D \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0430\u043B \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u043C
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C \u0430\u0431\u0435\u043B\u0435\u0432\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u043E\u043B\u0435\u0439 \u043A\u043B\u0430\u0441\u0441\u043E\u0432. 
    **\u0412 \u0447\u0435\u043C \u0435\u0433\u043E \u0441\u0443\u0442\u044C \u0438
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435?**  *   **\u041E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u0435**:
    \u042D\u0442\u043E\u0442 \u0437\u0430\u043A\u043E\u043D \u0441\u0442\u0430\u043B
    \u043A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u0435\u0439 \u0431\u043E\u043B\u0435\u0435
    \u0447\u0435\u043C \u043F\u043E\u043B\u0443\u0442\u043E\u0440\u0430\u0432\u0435\u043A\u043E\u0432\u044B\u0445
    \u043F\u043E\u0438\u0441\u043A\u043E\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.
    \u041E\u043D \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u043B \u0438 \u043E\u0431\u043E\u0431\u0449\u0438\u043B
    \u0432\u0441\u0435 \u0440\u0430\u043D\u0435\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435
    \u0437\u0430\u043A\u043E\u043D\u044B \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438:
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0439 \u0437\u0430\u043A\u043E\u043D
    \u0413\u0430\u0443\u0441\u0441\u0430, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0437\u0430\u043A\u043E\u043D\u044B
    \u0434\u043B\u044F \u0441\u0442\u0435\u043F\u0435\u043D\u0435\u0439 \u0431\u043E\u043B\u0435\u0435
    \u0432\u044B\u0441\u043E\u043A\u0438\u0445 \u043F\u043E\u0440\u044F\u0434\u043A\u043E\u0432,
    \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u0435 \u042D\u0439\u0437\u0435\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C
    \u0438 \u041A\u0443\u043C\u043C\u0435\u0440\u043E\u043C. *   **\u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F**: \u0417\u0430\u043A\u043E\u043D
    \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438 \u0410\u0440\u0442\u0438\u043D\u0430
    \u0443\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442
    \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0438 \u0438\u0437\u044F\u0449\u043D\u0443\u044E
    \u0441\u0432\u044F\u0437\u044C \u043C\u0435\u0436\u0434\u0443 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u043E\u0439
    \u043F\u043E\u043B\u044F (\u0435\u0433\u043E \u0438\u0434\u0435\u0430\u043B\u0430\u043C\u0438)
    \u0438 \u0435\u0433\u043E \u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u044F\u043C\u0438
    (\u0433\u0440\u0443\u043F\u043F\u043E\u0439 \u0413\u0430\u043B\u0443\u0430).
    \u0413\u0440\u0443\u0431\u043E \u0433\u043E\u0432\u043E\u0440\u044F, \u043E\u043D
    \u0434\u0430\u0435\u0442 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u0439
    \u0440\u0435\u0446\u0435\u043F\u0442, \u043A\u0430\u043A \u043F\u043E \u043F\u0440\u043E\u0441\u0442\u043E\u043C\u0443
    \u0447\u0438\u0441\u043B\u0443 \u0432 \u043F\u043E\u043B\u0435 \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442 \u0432 \u0433\u0440\u0443\u043F\u043F\u0435
    \u0413\u0430\u043B\u0443\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \"\u043F\u0435\u0440\u0435\u043C\u0435\u0448\u0438\u0432\u0430\u0435\u0442\"
    \u044D\u0442\u043E \u043F\u043E\u043B\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C.  \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u0441\u0442\u0430\u043B\u043E \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u043A\u0430\u043C\u043D\u0435\u0439 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B.  ### \U0001F9E9
    \u0420\u0435\u0448\u0435\u043D\u0438\u0435 17-\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430: \u0440\u0430\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u043D\u0430 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u044B  \u0410\u0440\u0442\u0438\u043D
    \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u043A\u043E\u043C\u0443
    \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u0440\u0435\u0448\u0438\u0442\u044C
    \u0434\u0432\u0435 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0414\u0430\u0432\u0438\u0434\u0430
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430, \u043F\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0435
    \u0432 1900 \u0433\u043E\u0434\u0443. \u0412 1927 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0440\u0435\u0448\u0438\u043B **17-\u044E \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443**. 
    *   **\u0421\u0443\u0442\u044C \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B**:
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u043B:
    \u043C\u043E\u0436\u043D\u043E \u043B\u0438 \u043B\u044E\u0431\u0443\u044E \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0443\u044E
    \u0444\u0443\u043D\u043A\u0446\u0438\u044E \u043E\u0442 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0435\u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F, \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0432 \u0432\u0438\u0434\u0435 \u0441\u0443\u043C\u043C\u044B \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439?
    *   **\u0420\u0435\u0448\u0435\u043D\u0438\u0435**: \u0410\u0440\u0442\u0438\u043D
    \u0434\u0430\u043B \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u043E\u0442\u0432\u0435\u0442 \u043D\u0430 \u044D\u0442\u043E\u0442 \u0432\u043E\u043F\u0440\u043E\u0441.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u0437\u0434\u0435\u0441\u044C \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0441\u0430\u043C \u0444\u0430\u043A\u0442 \u0440\u0435\u0448\u0435\u043D\u0438\u044F,
    \u0430 \u043F\u0443\u0442\u044C \u043A \u043D\u0435\u043C\u0443.  ### \U0001F333
    \u0422\u0435\u043E\u0440\u0438\u044F \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u043F\u043E\u043B\u0435\u0439: \u043D\u043E\u0432\u044B\u0439 \u0432\u0437\u0433\u043B\u044F\u0434
    \u043D\u0430 \u0447\u0438\u0441\u043B\u0430  \u0414\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    17-\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u0410\u0440\u0442\u0438\u043D\u0443 \u043D\u0443\u0436\u043D\u043E \u0431\u044B\u043B\u043E
    \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u043D\u043E\u0432\u0443\u044E \u0442\u0435\u043E\u0440\u0438\u044E.
    \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u041E\u0442\u0442\u043E
    \u0428\u0440\u0430\u0439\u0435\u0440\u043E\u043C \u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    **\u0442\u0435\u043E\u0440\u0438\u044E \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u043F\u043E\u043B\u0435\u0439**.  *   **\u041D\u043E\u0432\u044B\u0439 \u043F\u043E\u0434\u0445\u043E\u0434**:
    \u041E\u043D\u0438 \u0441\u043E\u0437\u0434\u0430\u043B\u0438 \u0441\u0442\u0440\u043E\u0439\u043D\u0443\u044E
    \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E, \u0432 \u0440\u0430\u043C\u043A\u0430\u0445
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0441\u0442\u0430\u043B\u043E \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u043C
    \u0447\u0435\u0442\u043A\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C
    \u0438 \u0438\u0437\u0443\u0447\u0438\u0442\u044C \u043F\u043E\u043B\u044F, \u0433\u0434\u0435
    \u043C\u043E\u0436\u043D\u043E \u0432\u0432\u0435\u0441\u0442\u0438 \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \"\u043F\u043E\u0440\u044F\u0434\u043A\u0430\" (\u0431\u043E\u043B\u044C\u0448\u0435/\u043C\u0435\u043D\u044C\u0448\u0435),
    \u0438 \u043F\u043E\u043B\u044F, \u0433\u0434\u0435 \u044D\u0442\u043E \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430). \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E
    \u0410\u0440\u0442\u0438\u043D\u0443 \u0434\u0430\u0442\u044C \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u043E\u0435
    \u0438 \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    17-\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430. 
    ### \U0001F300 \u0422\u0435\u043E\u0440\u0438\u044F \u043A\u043E\u0441: \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u043D\u043E\u0432\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438  \u0412
    1925 \u0433\u043E\u0434\u0443 \u0410\u0440\u0442\u0438\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u043D\u043E\u0432\u0443\u044E
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u2014 **\u0442\u0435\u043E\u0440\u0438\u044E \u043A\u043E\u0441**.  *   **\u0424\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u044F**:
    \u041E\u043D \u0434\u0430\u043B \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0433\u0440\u0443\u043F\u043F\u044B \u043A\u043E\u0441, \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u043A\u0430\u043A \u0435\u0435 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u044B
    \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0442\u044C
    \u0432 \u0432\u0438\u0434\u0435 \u0434\u0438\u0430\u0433\u0440\u0430\u043C\u043C
    (\u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u043D\u0438\u0442\u0435\u0439), \u0438 \u043D\u0430\u0448\u0435\u043B \u0435\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E\u0435 \u0438 \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u043E\u0435
    \u0437\u0430\u0434\u0430\u043D\u0438\u0435 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043E\u0431\u0440\u0430\u0437\u0443\u044E\u0449\u0438\u0445 \u0438 \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0439.
    *   **\u0412\u043B\u0438\u044F\u043D\u0438\u0435**: \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0433\u0440\u0443\u043F\u043F, \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044E
    (\u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435 \u0443\u0437\u043B\u043E\u0432
    \u0438 \u0437\u0430\u0446\u0435\u043F\u043B\u0435\u043D\u0438\u0439) \u0438 \u0434\u0430\u0436\u0435
    \u043D\u0430 \u0444\u0438\u0437\u0438\u043A\u0443. \u0413\u0440\u0443\u043F\u043F\u044B
    \u043A\u043E\u0441 \u0442\u0435\u0441\u043D\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u044B
    \u0441 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u043E\u0431\u044A\u0435\u043A\u0442\u0430\u043C\u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0444\u0438\u0437\u0438\u043A\u0438,
    \u0442\u0430\u043A\u0438\u043C\u0438 \u043A\u0430\u043A \u0433\u0440\u0443\u043F\u043F\u044B
    \u043A\u043E\u0441 \u0410\u0440\u0442\u0438\u043D\u0430 (\u0438\u0445 \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u0435)
    \u0438 \u0442\u0435\u043E\u0440\u0438\u044F \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439. 
    ### \U0001F517 \u0410\u0440\u0442\u0438\u043D\u043E\u0432\u044B \u043A\u043E\u043B\u044C\u0446\u0430
    \u0438 \u043E\u0431\u0449\u0430\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u0430 
    \u0412 1944 \u0433\u043E\u0434\u0443 \u0410\u0440\u0442\u0438\u043D \u0432\u0432\u0435\u043B
    \u0432\u0430\u0436\u043D\u044B\u0439 \u043A\u043B\u0430\u0441\u0441 \u043A\u043E\u043B\u0435\u0446,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0442\u0435\u043F\u0435\u0440\u044C
    \u043D\u043E\u0441\u044F\u0442 \u0435\u0433\u043E \u0438\u043C\u044F \u2014 **\u0430\u0440\u0442\u0438\u043D\u043E\u0432\u044B
    \u043A\u043E\u043B\u044C\u0446\u0430**.  *   **\u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u043E\u0431\u044A\u0435\u043A\u0442**: \u042D\u0442\u043E \u043A\u043E\u043B\u044C\u0446\u0430,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043B\u044E\u0431\u0430\u044F
    \u0443\u0431\u044B\u0432\u0430\u044E\u0449\u0430\u044F \u0446\u0435\u043F\u043E\u0447\u043A\u0430
    \u0438\u0434\u0435\u0430\u043B\u043E\u0432 \u043E\u0431\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    (\u0443\u0441\u043B\u043E\u0432\u0438\u0435 \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438).
    \u041D\u0430 \u043F\u0435\u0440\u0432\u044B\u0439 \u0432\u0437\u0433\u043B\u044F\u0434
    \u044D\u0442\u043E \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0435
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E, \u043D\u043E \u043E\u043D\u043E
    \u043E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C. *  
    **\u0420\u043E\u043B\u044C \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0435**:
    \u0410\u0440\u0442\u0438\u043D\u043E\u0432\u044B \u043A\u043E\u043B\u044C\u0446\u0430
    \u0441\u0442\u0430\u043B\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u043C \u0432 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0435 \u0438 \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0435, \u043E\u0431\u043E\u0431\u0449\u0430\u044F
    \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C\u0435\u0440\u043D\u044B\u0435
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0438 \u043F\u043E\u043B\u044F. \u042D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430, \u0432\u043C\u0435\u0441\u0442\u0435 \u0441
    \u0435\u0433\u043E \u043F\u043E\u0434\u0445\u043E\u0434\u0430\u043C\u0438 \u043A
    \u0434\u0440\u0443\u0433\u0438\u043C \u0440\u0430\u0437\u0434\u0435\u043B\u0430\u043C,
    \u0441\u0434\u0435\u043B\u0430\u043B\u0430 \u0435\u0433\u043E, \u043D\u0430\u0440\u044F\u0434\u0443
    \u0441 \u042D\u043C\u043C\u0438 \u041D\u0451\u0442\u0435\u0440, \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u0439 **\u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043E\u0431\u0449\u0435\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u044B**. 
    ### \U0001F4DA \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0443\u0447\u0438\u0442\u0435\u043B\u044F
    \u0438 \u044D\u043A\u0441\u043F\u043E\u0437\u0438\u0442\u043E\u0440\u0430  \u041F\u043E\u043C\u0438\u043C\u043E
    \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439,
    \u0410\u0440\u0442\u0438\u043D \u0431\u044B\u043B \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C \u0438 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0415\u0433\u043E
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0438 \u043A\u043D\u0438\u0433\u0438, \u0442\u0430\u043A\u0438\u0435
    \u043A\u0430\u043A \"\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\", \"\u0422\u0435\u043E\u0440\u0438\u044F
    \u0413\u0430\u043B\u0443\u0430\", \"\u0422\u0435\u043E\u0440\u0438\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B\", \u0446\u0435\u043D\u0438\u043B\u0438\u0441\u044C
    \u0437\u0430 \u043D\u0435\u043E\u0431\u044B\u0447\u0430\u0439\u043D\u0443\u044E
    \u044F\u0441\u043D\u043E\u0441\u0442\u044C, \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C
    \u0438 \u043A\u0440\u0430\u0441\u043E\u0442\u0443 \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u044F. 
    *   **\u0428\u043A\u043E\u043B\u0430 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432**:
    \u041E\u043D \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u043B 34
    \u0434\u043E\u043A\u0442\u043E\u0440\u0430 \u043D\u0430\u0443\u043A, \u0441\u0440\u0435\u0434\u0438
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0442\u0430\u043A\u0438\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043A\u0430\u043A
    \u0421\u0435\u0440\u0436 \u041B\u0435\u043D\u0433 \u0438 \u0414\u0436\u043E\u043D
    \u0422\u0435\u0439\u0442. *   **\u0412\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435**: \u0415\u0433\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434\u044B \u043A \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u044E
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0443\u0447\u0435\u0431\u043D\u0438\u043A
    \u0432\u0430\u043D \u0434\u0435\u0440 \u0412\u0430\u0440\u0434\u0435\u043D\u0430
    \"\u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u0430\". 
    \u0412\u043A\u043B\u0430\u0434 \u042D\u043C\u0438\u043B\u044F \u0410\u0440\u0442\u0438\u043D\u0430
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0430\u0431\u043E\u0440
    \u0442\u0435\u043E\u0440\u0435\u043C, \u0430 \u0446\u0435\u043B\u0430\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435: \u0441\u0442\u0440\u0435\u043C\u043B\u0435\u043D\u0438\u0435
    \u043A \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u0438, \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u044E
    \u0438 \u043F\u043E\u0438\u0441\u043A\u0443 \u0441\u0430\u043C\u044B\u0445 \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u044B\u0445
    \u0438 \u044F\u0441\u043D\u044B\u0445 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u042D\u043C\u0438\u043B\u044F \u0410\u0440\u0442\u0438\u043D\u0430, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0435\u0433\u043E \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044E
    \u0441\u0442\u0440\u043E\u0433\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E,
    \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C\u0438 \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u044F\u043C\u0438
    \u0438 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u0430\u043C\u0438, \u0442\u0435\u0441\u043D\u043E
    \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u043D\u044B\u043C\u0438
    \u0441 \u0431\u0443\u0440\u043D\u043E\u0439 \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439
    XX \u0432\u0435\u043A\u0430.  ### \U0001F494 \u0422\u044F\u0436\u0435\u043B\u043E\u0435
    \u0434\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u0440\u0430\u043D\u043D\u0438\u0435
    \u0443\u0442\u0440\u0430\u0442\u044B  \u0415\u0433\u043E \u0434\u0435\u0442\u0441\u0442\u0432\u043E
    \u0431\u044B\u043B\u043E \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u043E \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439.
    \u041E\u0442\u0435\u0446, \u042D\u043C\u0438\u043B\u044C \u0410\u0440\u0442\u0438\u043D-\u0441\u0442\u0430\u0440\u0448\u0438\u0439,
    \u0437\u0430\u0440\u0430\u0437\u0438\u043B\u0441\u044F \u0441\u0438\u0444\u0438\u043B\u0438\u0441\u043E\u043C,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E\u043C\u0443
    \u043F\u0441\u0438\u0445\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443 \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0443.
    \u0412 1904 \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B \u043F\u043E\u043C\u0435\u0449\u0435\u043D
    \u0432 \u043F\u0441\u0438\u0445\u0438\u0430\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043B\u0435\u0447\u0435\u0431\u043D\u0438\u0446\u0443, \u0433\u0434\u0435 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 1906 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u0431\u0443\u0434\u0443\u0449\u0435\u043C\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0431\u044B\u043B\u043E
    \u0432\u0441\u0435\u0433\u043E \u0432\u043E\u0441\u0435\u043C\u044C \u043B\u0435\u0442.
    \u041C\u0430\u0442\u044C, \u042D\u043C\u043C\u0430, \u0431\u044B\u0432\u0448\u0430\u044F
    \u043F\u0435\u0432\u0438\u0446\u0430 \u043E\u043F\u0435\u0440\u0435\u0442\u0442\u044B,
    \u0432\u0441\u043A\u043E\u0440\u0435 \u0432\u044B\u0448\u043B\u0430 \u0437\u0430\u043C\u0443\u0436
    \u043F\u043E\u0432\u0442\u043E\u0440\u043D\u043E \u2014 \u0437\u0430 \u043F\u0440\u0435\u0443\u0441\u043F\u0435\u0432\u0430\u044E\u0449\u0435\u0433\u043E
    \u0444\u0430\u0431\u0440\u0438\u043A\u0430\u043D\u0442\u0430 \u0420\u0443\u0434\u043E\u043B\u044C\u0444\u0430
    \u0425\u044E\u0431\u043D\u0435\u0440\u0430, \u0438 \u0441\u0435\u043C\u044C\u044F
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430 \u0432 \u0420\u0430\u0439\u0445\u0435\u043D\u0431\u0435\u0440\u0433
    (\u043D\u044B\u043D\u0435 \u041B\u0438\u0431\u0435\u0440\u0435\u0446 \u0432 \u0427\u0435\u0445\u0438\u0438). 
    ### \U0001F49E \u0411\u0440\u0430\u043A \u0441 \u041D\u0430\u0442\u0430\u0448\u0435\u0439
    \u042F\u0441\u043D\u043E\u0439: \u043B\u044E\u0431\u043E\u0432\u044C \u0438 \u043E\u0431\u0449\u0435\u0435
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435  \u0412 1929 \u0433\u043E\u0434\u0443
    \u0410\u0440\u0442\u0438\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430
    \u041D\u0430\u0442\u0430\u043B\u0438 (\u041D\u0430\u0442\u0430\u0448\u0435) \u041D\u0430\u0443\u043C\u043E\u0432\u043D\u0435
    \u042F\u0441\u043D\u043E\u0439, \u043C\u043E\u043B\u043E\u0434\u043E\u0439 \u044D\u043C\u0438\u0433\u0440\u0430\u043D\u0442\u043A\u0435
    \u0438\u0437 \u0420\u043E\u0441\u0441\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043A\u043E\u0439.
    \u0423 \u043D\u0438\u0445 \u0431\u044B\u043B\u043E \u043C\u043D\u043E\u0433\u043E
    \u043E\u0431\u0449\u0438\u0445 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432,
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0441\u0438\u043B\u044C\u043D\u044B\u0445
    \u0431\u044B\u043B\u0430 \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u044F.
    \u0410\u0440\u0442\u0438\u043D \u043A\u0443\u043F\u0438\u043B \u043E\u0434\u043D\u0443
    \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u043A\u0430\u043C\u0435\u0440
    Leica, \u0438 \u043E\u043D\u0438 \u0432\u043C\u0435\u0441\u0442\u0435 \u0441\u043E\u0437\u0434\u0430\u043B\u0438
    \u0446\u0435\u043B\u0443\u044E \u0441\u0435\u0440\u0438\u044E \u0437\u0430\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442\u043E\u0432 \u0434\u0440\u0443\u0433
    \u0434\u0440\u0443\u0433\u0430 \u0438 \u043E\u043A\u0440\u0443\u0436\u0430\u044E\u0449\u0435\u0439
    \u0436\u0438\u0437\u043D\u0438. \u0418\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u044B\u0435
    \u0444\u043E\u0442\u043E\u0440\u0430\u0431\u043E\u0442\u044B \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0431\u044B\u043B\u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u044B \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u044F\u043C\u0438
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430 \u0438 \u0434\u0430\u0436\u0435
    \u0432\u044B\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0438\u0441\u044C \u0432
    \u043C\u0443\u0437\u0435\u0435 \u0432 \u0413\u0430\u043C\u0431\u0443\u0440\u0433\u0435. 
    ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466 \u0421\u0435\u043C\u044C\u044F
    \u0438 \u0434\u0435\u0442\u0438  \u0423 \u042D\u043C\u0438\u043B\u044F \u0438
    \u041D\u0430\u0442\u0430\u0448\u0438 \u0431\u044B\u043B\u043E \u0442\u0440\u043E\u0435
    \u0434\u0435\u0442\u0435\u0439: *   **\u041A\u0430\u0440\u0438\u043D** (\u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C
    \u0432 \u044F\u043D\u0432\u0430\u0440\u0435 1933 \u0433\u043E\u0434\u0430). *  
    **\u041C\u0430\u0439\u043A\u043B** (\u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u043B\u0435\u0442\u043E\u043C 1934 \u0433\u043E\u0434\u0430). \u041E\u043D \u043F\u043E\u0448\u0435\u043B
    \u043F\u043E \u0441\u0442\u043E\u043F\u0430\u043C \u043E\u0442\u0446\u0430 \u0438
    \u0441\u0442\u0430\u043B \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u0443\u044E\u0449\u0438\u043C\u0441\u044F
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. *   **\u0422\u043E\u043C\u0430\u0441**
    (\u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0432 1938 \u0433\u043E\u0434\u0443,
    \u0443\u0436\u0435 \u0432 \u0421\u0428\u0410).  \u0414\u043E\u0447\u044C \u041A\u0430\u0440\u0438\u043D
    \u0432\u044B\u0448\u043B\u0430 \u0437\u0430\u043C\u0443\u0436 \u0437\u0430 \u0414\u0436\u043E\u043D\u0430
    \u0422\u0435\u0439\u0442\u0430, \u0443\u0447\u0435\u043D\u0438\u043A\u0430 \u042D\u043C\u0438\u043B\u044F
    \u0410\u0440\u0442\u0438\u043D\u0430 \u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0433\u043E\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B.  ### \U0001F6A9
    \u0416\u0438\u0437\u043D\u044C \u043F\u043E\u0434 \u043F\u0440\u0438\u0446\u0435\u043B\u043E\u043C
    \u043D\u0430\u0446\u0438\u0441\u0442\u0441\u043A\u043E\u0433\u043E \u0440\u0435\u0436\u0438\u043C\u0430 
    \u0411\u0440\u0430\u043A \u0441 \u041D\u0430\u0442\u0430\u0448\u0435\u0439, \u0438\u043C\u0435\u0432\u0448\u0435\u0439
    \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0435 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435,
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0443\u044E
    \u0441\u0443\u0434\u044C\u0431\u0443 \u0410\u0440\u0442\u0438\u043D\u0430 \u0432
    \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438. \u0421 \u043F\u0440\u0438\u0445\u043E\u0434\u043E\u043C
    \u043D\u0430\u0446\u0438\u0441\u0442\u043E\u0432 \u043A \u0432\u043B\u0430\u0441\u0442\u0438
    \u0438\u0445 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u043E\u0441\u044C
    \u0432\u0441\u0435 \u0431\u043E\u043B\u0435\u0435 \u0448\u0430\u0442\u043A\u0438\u043C.
    \u0421\u0430\u043C \u0410\u0440\u0442\u0438\u043D \u043D\u0435 \u0441\u043A\u0440\u044B\u0432\u0430\u043B
    \u0441\u0432\u043E\u0435\u0433\u043E \u043D\u0435\u0433\u0430\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u043A \u0440\u0435\u0436\u0438\u043C\u0443,
    \u0437\u0430 \u0447\u0442\u043E \u0435\u0433\u043E \u0434\u0430\u0436\u0435 \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0436\u0434\u0430\u043B\u0438
    \u043E \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438
    \u0431\u044B\u0442\u044C \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u0435\u0435
    \u0432 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u044B\u0445 \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043D\u0438\u044F\u0445.
    \u041F\u043E \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F\u043C
    \u041D\u0430\u0442\u0430\u0448\u0438, \u0437\u0430 \u0438\u0445 \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u043E\u0439
    \u0432\u0435\u043B\u043E\u0441\u044C \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u0435,
    \u0438 \u0438\u043C \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C \u0436\u0438\u0442\u044C
    \u0441 \u043E\u0449\u0443\u0449\u0435\u043D\u0438\u0435\u043C \u0441\u043B\u0435\u0436\u043A\u0438.
    \u0422\u0435\u043C \u043D\u0435 \u043C\u0435\u043D\u0435\u0435, \u043E\u043D\u0438
    \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u043B\u0438 \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435
    \u0434\u0443\u0445\u0430 \u0438 \u0434\u0430\u0436\u0435 \"\u0438\u0433\u0440\u0430\u043B\u0438\"
    \u0441\u043E \u0441\u0432\u043E\u0438\u043C \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u0435\u043B\u0435\u043C,
    \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u044F\u0441\u044C \u043D\u0430
    \u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435 \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0438,
    \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u044F \u0435\u0433\u043E \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u044C
    \u0437\u0430 \u043D\u0438\u043C\u0438.  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043F\u043E\u043F\u044B\u0442\u043A\u0438 \u043A\u043E\u043B\u043B\u0435\u0433,
    \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 \u0413\u0435\u043B\u044C\u043C\u0443\u0442\u0430
    \u0425\u0430\u0441\u0441\u0435, \u043F\u043E\u0432\u043B\u0438\u044F\u0442\u044C
    \u043D\u0430 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044E, \u0432 1937 \u0433\u043E\u0434\u0443
    \u0410\u0440\u0442\u0438\u043D \u0431\u044B\u043B \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u0435\u043D
    \u0432 \u043F\u0440\u0438\u043D\u0443\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0443 \u0432 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0438
    \u0441 \u043D\u0430\u0446\u0438\u0441\u0442\u0441\u043A\u0438\u043C\u0438 \u0440\u0430\u0441\u043E\u0432\u044B\u043C\u0438
    \u0437\u0430\u043A\u043E\u043D\u0430\u043C\u0438. \u0412 \u043E\u043A\u0442\u044F\u0431\u0440\u0435
    1937 \u0433\u043E\u0434\u0430 \u0441\u0435\u043C\u044C\u044F \u0410\u0440\u0442\u0438\u043D\u043E\u0432
    \u0431\u044B\u043B\u0430 \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u0430
    \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C \u0432
    \u0421\u0428\u0410.  ### \U0001F1FA\U0001F1F8 \u0416\u0438\u0437\u043D\u044C
    \u0432 \u0410\u043C\u0435\u0440\u0438\u043A\u0435, \u0440\u0430\u0437\u0432\u043E\u0434
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B 
    \u0412 \u0421\u0428\u0410 \u0410\u0440\u0442\u0438\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0418\u043D\u0434\u0438\u0430\u043D\u044B, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435. \u0412 1958 \u0433\u043E\u0434\u0443
    \u0438\u0445 \u0431\u0440\u0430\u043A \u0441 \u041D\u0430\u0442\u0430\u0448\u0435\u0439
    \u0440\u0430\u0441\u043F\u0430\u043B\u0441\u044F, \u0438 \u043E\u043D\u0438 \u0440\u0430\u0437\u0432\u0435\u043B\u0438\u0441\u044C.
    \u041D\u0430\u0442\u0430\u0448\u0430 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0432\u044B\u0448\u043B\u0430 \u0437\u0430\u043C\u0443\u0436 \u0437\u0430 \u043A\u043E\u043C\u043F\u043E\u0437\u0438\u0442\u043E\u0440\u0430
    \u041C\u0430\u0440\u043A\u0430 \u0411\u0440\u0430\u043D\u0441\u0443\u0438\u043A\u0430. 
    \u0421\u0430\u043C \u0410\u0440\u0442\u0438\u043D \u0432\u0441\u043A\u043E\u0440\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0440\u0430\u0437\u0432\u043E\u0434\u0430 \u043D\u0430\u0447\u0430\u043B
    \u0431\u043B\u0438\u0437\u043A\u0438\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0425\u0435\u043B\u044C \u0411\u0440\u0430\u0443\u043D, \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0438 \u043E\u043D\u0438 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0438\u0441\u044C
    \u043F\u0430\u0440\u0442\u043D\u0435\u0440\u0430\u043C\u0438 \u0434\u043E \u0441\u0430\u043C\u043E\u0439
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u0432 1962 \u0433\u043E\u0434\u0443."
  personalLifeEn: 
  shortBioRu: "\u042D\u043C\u0438\u043B\u044C \u0410\u0440\u0442\u0438\u043D (1898\u20131962)
    \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 XX \u0432\u0435\u043A\u0430,
    \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u044B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B. \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C
    \u2013 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0433\u043E
    \u0443\u043C\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0440\u0430\u0441\u0446\u0432\u0435\u043B
    \u0432 \u0431\u0443\u0440\u043D\u044B\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u0430
    \u0432\u043E\u0439\u043D \u0438 \u0438\u0434\u0435\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u0442\u0440\u044F\u0441\u0435\u043D\u0438\u0439, \u0430 \u0435\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0432\u0445\u043E\u0434\u0438\u0442 \u0432 \u0437\u043E\u043B\u043E\u0442\u043E\u0439
    \u0444\u043E\u043D\u0434 \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u043E\u0435 \u0434\u0435\u0442\u0441\u0442\u0432\u043E 
    \u042D\u043C\u0438\u043B\u044C \u0410\u0440\u0442\u0438\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    3 \u043C\u0430\u0440\u0442\u0430 1898 \u0433\u043E\u0434\u0430 \u0432 \u0412\u0435\u043D\u0435,
    \u0432 \u0441\u0435\u043C\u044C\u0435, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0439
    \u0441 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E\u043C. \u0415\u0433\u043E
    \u043E\u0442\u0435\u0446 \u0431\u044B\u043B \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0435\u043C
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430\u043C\u0438 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430
    \u0438, \u043F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0434\u0430\u043D\u043D\u044B\u043C,
    \u043F\u0435\u0432\u0446\u043E\u043C, \u0430 \u043C\u0430\u0442\u044C \u2014
    \u043F\u0435\u0432\u0438\u0446\u0435\u0439 \u043E\u043F\u0435\u0440\u0435\u0442\u0442\u044B.
    \u0412 1906 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u042D\u043C\u0438\u043B\u044E
    \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E \u0432\u043E\u0441\u0435\u043C\u044C
    \u043B\u0435\u0442, \u0435\u0433\u043E \u043E\u0442\u0435\u0446 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F.
    \u0412\u0441\u043A\u043E\u0440\u0435 \u043C\u0430\u0442\u044C \u0432\u044B\u0448\u043B\u0430
    \u0437\u0430\u043C\u0443\u0436 \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439
    \u0440\u0430\u0437, \u0438 \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u0420\u0430\u0439\u0445\u0435\u043D\u0431\u0435\u0440\u0433 \u0432 \u0411\u043E\u0433\u0435\u043C\u0438\u0438
    (\u043D\u044B\u043D\u0435 \u041B\u0438\u0431\u0435\u0440\u0435\u0446 \u0432 \u0427\u0435\u0445\u0438\u0438),
    \u0433\u0434\u0435 \u043E\u0442\u0447\u0438\u043C \u0432\u043B\u0430\u0434\u0435\u043B
    \u0442\u0435\u043A\u0441\u0442\u0438\u043B\u044C\u043D\u044B\u043C \u0431\u0438\u0437\u043D\u0435\u0441\u043E\u043C. 
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u043F\u043E
    \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0410\u0440\u0442\u0438\u043D \u0431\u044B\u043B \u0430\u0432\u0441\u0442\u0440\u0438\u0439\u0446\u0435\u043C
    \u0441 \u0430\u0440\u043C\u044F\u043D\u0441\u043A\u0438\u043C\u0438 \u043A\u043E\u0440\u043D\u044F\u043C\u0438.
    \u0421\u0432\u043E\u044E \u0444\u0430\u043C\u0438\u043B\u0438\u044E \u043E\u043D
    \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u043E\u0442
    \u0434\u0435\u0434\u0430, \u0430\u0440\u043C\u044F\u043D\u0441\u043A\u043E\u0433\u043E
    \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0430 \u043A\u043E\u0432\u0440\u0430\u043C\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0435\u0440\u0435\u0431\u0440\u0430\u043B\u0441\u044F
    \u0432 \u0412\u0435\u043D\u0443. \u041F\u043E \u0441\u043B\u043E\u0432\u0430\u043C
    \u0435\u0433\u043E \u0441\u044B\u043D\u0430, \u041C\u0430\u0439\u043A\u043B\u0430,
    \u043F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u0430\u044F
    \u0444\u0430\u043C\u0438\u043B\u0438\u044F \u0431\u044B\u043B\u0430 \xAB\u0410\u0440\u0442\u0438\u043D\u044F\u043D\xBB,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043F\u043E\u0437\u0436\u0435 \u0441\u043E\u043A\u0440\u0430\u0442\u0438\u043B\u0438. 
    \u0412 \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0435 \u0433\u043E\u0434\u044B
    \u0410\u0440\u0442\u0438\u043D \u043D\u0435 \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0435\u0439
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u0415\u0433\u043E
    \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0439 \u0441\u0442\u0440\u0430\u0441\u0442\u044C\u044E
    \u0431\u044B\u043B\u0430 \u0445\u0438\u043C\u0438\u044F, \u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0441\u0442\u0430\u043B\u0430 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u0442\u044C
    \u0435\u0433\u043E \u0442\u043E\u043B\u044C\u043A\u043E \u0441 16 \u043B\u0435\u0442.
    \u0412\u043F\u0440\u043E\u0447\u0435\u043C, \u044D\u0442\u043E \u043D\u0435 \u043F\u043E\u043C\u0435\u0448\u0430\u043B\u043E
    \u0435\u043C\u0443 \u0432 1916 \u0433\u043E\u0434\u0443 \u0441 \u043E\u0442\u043B\u0438\u0447\u0438\u0435\u043C
    \u043E\u043A\u043E\u043D\u0447\u0438\u0442\u044C \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0435
    \u0443\u0447\u0438\u043B\u0438\u0449\u0435.  ### \U0001F393 \u041F\u0443\u0442\u044C
    \u043A \u043D\u0430\u0443\u043A\u0435: \u0412\u0435\u043D\u0430, \u0432\u043E\u0439\u043D\u0430
    \u0438 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D  \u0412 1916 \u0433\u043E\u0434\u0443
    \u0410\u0440\u0442\u0438\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0412\u0435\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u043E\u0434\u043D\u0430\u043A\u043E \u043F\u0440\u043E\u0443\u0447\u0438\u043B\u0441\u044F
    \u0442\u0430\u043C \u0432\u0441\u0435\u0433\u043E \u043E\u0434\u0438\u043D \u0441\u0435\u043C\u0435\u0441\u0442\u0440.
    \u0412 \u0440\u0430\u0437\u0433\u0430\u0440 \u041F\u0435\u0440\u0432\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B \u0435\u0433\u043E
    \u043F\u0440\u0438\u0437\u0432\u0430\u043B\u0438 \u0432 \u0430\u0432\u0441\u0442\u0440\u0438\u0439\u0441\u043A\u0443\u044E
    \u0430\u0440\u043C\u0438\u044E, \u0438 \u0434\u043E 1918 \u0433\u043E\u0434\u0430
    \u043E\u043D \u0441\u043B\u0443\u0436\u0438\u043B \u043D\u0430 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u043E\u043C
    \u0444\u0440\u043E\u043D\u0442\u0435.  \u041F\u043E\u0441\u043B\u0435 \u0434\u0435\u043C\u043E\u0431\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u0438
    \u0432 1919 \u0433\u043E\u0434\u0443 \u0410\u0440\u0442\u0438\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0432 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u0433\u0434\u0435
    \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0441\u0442\u0430\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0413\u0443\u0441\u0442\u0430\u0432
    \u0425\u0435\u0440\u0433\u043B\u043E\u0446. \u0412 1921 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441 \u0431\u043B\u0435\u0441\u043A\u043E\u043C \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E,
    \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0443\u044E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0435
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0445 \u043F\u043E\u043B\u0435\u0439.
    \u0417\u0430\u0442\u0435\u043C \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u043A\u0440\u0430\u0439\u043D\u0435 \u0432\u0430\u0436\u043D\u044B\u0439 \u0434\u043B\u044F
    \u0435\u0433\u043E \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0433\u043E\u0434 \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u2014
    \u043C\u0438\u0440\u043E\u0432\u043E\u043C \u0446\u0435\u043D\u0442\u0440\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0442\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u0422\u0430\u043C \u043E\u043D \u0441\u043B\u0443\u0448\u0430\u043B
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0414\u0430\u0432\u0438\u0434\u0430 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u0438 \u0420\u0438\u0447\u0430\u0440\u0434\u0430 \u041A\u0443\u0440\u0430\u043D\u0442\u0430,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u043D\u0430\u0447\u0430\u043B \u0442\u0435\u0441\u043D\u043E\u0435
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u042D\u043C\u043C\u0438 \u041D\u0451\u0442\u0435\u0440, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430 \u043D\u0430 \u043D\u0435\u0433\u043E
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435. 
    ### \U0001F3EB \u0413\u0430\u043C\u0431\u0443\u0440\u0433\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 \u0438 \u0440\u0430\u0441\u0446\u0432\u0435\u0442
    \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430  \u0412 1922 \u0433\u043E\u0434\u0443
    \u0410\u0440\u0442\u0438\u043D \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u043C, \u0430 \u0432\u0441\u043A\u043E\u0440\u0435
    \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0432
    \u0413\u0430\u043C\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0431\u0443\u0434\u0435\u0442
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0431\u043E\u043B\u044C\u0448\u0430\u044F
    \u0447\u0430\u0441\u0442\u044C \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.
    \u0412 1925 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B \u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C,
    \u0430 \u0432 1926 \u2014 \u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C.  \u042D\u0442\u043E
    \u0432\u0440\u0435\u043C\u044F \u0441\u0442\u0430\u043B\u043E \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C \u0434\u043B\u044F
    \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u044B.
    \u0414\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u0435 \u0441 1921
    \u043F\u043E 1931 \u0433\u043E\u0434, \u043A\u0430\u043A \u043E\u0442\u043C\u0435\u0447\u0430\u043B\u0438
    \u043A\u043E\u043B\u043B\u0435\u0433\u0438, \u0441\u0442\u0430\u043B\u043E \u043F\u0435\u0440\u0438\u043E\u0434\u043E\u043C
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438, \u0440\u0435\u0434\u043A\u043E
    \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u0432 \u0436\u0438\u0437\u043D\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430.
    \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0410\u0440\u0442\u0438\u043D\u0430 \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F
    \u0438\u043C\u0435\u043D\u043D\u043E \u043A \u044D\u0442\u043E\u043C\u0443 \u043F\u0435\u0440\u0438\u043E\u0434\u0443: 
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u043F\u043E\u043B\u0435\u0439:**
    \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u041E\u0442\u0442\u043E
    \u0428\u0440\u0430\u0439\u0435\u0440\u043E\u043C \u0410\u0440\u0442\u0438\u043D
    \u0441\u043E\u0437\u0434\u0430\u043B \u0442\u0435\u043E\u0440\u0438\u044E \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u043F\u043E\u043B\u0435\u0439 \u0438 \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E-\u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u043F\u043E\u043B\u0435\u0439. \u041D\u0430 \u0435\u0435 \u043E\u0441\u043D\u043E\u0432\u0435
    \u0432 1927 \u0433\u043E\u0434\u0443 \u043E\u043D \u0440\u0435\u0448\u0438\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **17-\u044E \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u043B\u0430, \u043C\u043E\u0436\u043D\u043E
    \u043B\u0438 \u043B\u044E\u0431\u0443\u044E \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u0443\u044E \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0443\u044E
    \u0444\u0443\u043D\u043A\u0446\u0438\u044E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u043A\u0430\u043A \u0441\u0443\u043C\u043C\u0443 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u043A\u043E\u0441:** \u0412 1925
    \u0433\u043E\u0434\u0443 \u0410\u0440\u0442\u0438\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u043D\u043E\u0432\u0443\u044E
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u2014 \u0442\u0435\u043E\u0440\u0438\u044E \u043A\u043E\u0441, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043D\u0430\u0448\u043B\u0430 \u0448\u0438\u0440\u043E\u043A\u043E\u0435 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0432 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0433\u0440\u0443\u043F\u043F. *   **\u0422\u0435\u043E\u0440\u0438\u044F \u043F\u043E\u043B\u0435\u0439
    \u043A\u043B\u0430\u0441\u0441\u043E\u0432 \u0438 \u0437\u0430\u043A\u043E\u043D
    \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438:** \u0412\u0435\u0440\u0448\u0438\u043D\u043E\u0439
    \u0435\u0433\u043E \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430
    \u0441\u0442\u0430\u043B\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043E\u0431\u0449\u0435\u0433\u043E \u0437\u0430\u043A\u043E\u043D\u0430 \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438
    (\u043D\u044B\u043D\u0435 **\u0437\u0430\u043A\u043E\u043D \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438
    \u0410\u0440\u0442\u0438\u043D\u0430**), \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u0431\u043E\u0431\u0449\u0438\u043B \u0432\u0441\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435
    \u0440\u0430\u043D\u0435\u0435 \u0437\u0430\u043A\u043E\u043D\u044B \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438,
    \u043D\u0430\u0447\u0438\u043D\u0430\u044F \u0441 \u0440\u0430\u0431\u043E\u0442
    \u0413\u0430\u0443\u0441\u0441\u0430. \u042D\u0442\u043E\u0442 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u0441\u0442\u0430\u043B \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u043C
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u043E\u043B\u0435\u0439 \u043A\u043B\u0430\u0441\u0441\u043E\u0432.
    *   **\u0410\u0440\u0442\u0438\u043D\u043E\u0432\u044B \u043A\u043E\u043B\u044C\u0446\u0430:**
    \u0412 1944 \u0433\u043E\u0434\u0443 \u043E\u043D \u0432\u0432\u0435\u043B \u0432\u0430\u0436\u043D\u044B\u0439
    \u043A\u043B\u0430\u0441\u0441 \u043A\u043E\u043B\u0435\u0446, \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u044B\u0445
    \u0432 \u0435\u0433\u043E \u0447\u0435\u0441\u0442\u044C \u0430\u0440\u0442\u0438\u043D\u043E\u0432\u044B\u043C\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u0442\u0430\u043B\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u043C \u0432 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0435.  ### \U0001F30A \u042D\u043C\u0438\u0433\u0440\u0430\u0446\u0438\u044F
    \u0432 \u0421\u0428\u0410 \u0438 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0443  \u041F\u0440\u0438\u0445\u043E\u0434
    \u043A \u0432\u043B\u0430\u0441\u0442\u0438 \u043D\u0430\u0446\u0438\u0441\u0442\u043E\u0432
    \u0432 1933 \u0433\u043E\u0434\u0443 \u043A\u0440\u0443\u0442\u043E \u0438\u0437\u043C\u0435\u043D\u0438\u043B
    \u0436\u0438\u0437\u043D\u044C \u0410\u0440\u0442\u0438\u043D\u0430. \u0425\u043E\u0442\u044F
    \u0441\u0430\u043C \u043E\u043D \u043D\u0435 \u0431\u044B\u043B \u0435\u0432\u0440\u0435\u0435\u043C,
    \u0435\u0433\u043E \u0436\u0435\u043D\u0430 \u041D\u0430\u0442\u0430\u0448\u0430
    (\u041D\u0430\u0442\u0430\u043B\u0438) \u042F\u0441\u043D\u0430\u044F, \u0434\u043E\u0447\u044C
    \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0441\u0442\u0430 \u0438\u0437 \u0420\u043E\u0441\u0441\u0438\u0438,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u0432 1929 \u0433\u043E\u0434\u0443, \u0438\u043C\u0435\u043B\u0430 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0435
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435.
    \u0412 1937 \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435 \u0443\u0436\u0435\u0441\u0442\u043E\u0447\u0435\u043D\u0438\u044F
    \u0430\u043D\u0442\u0438\u0441\u0435\u043C\u0438\u0442\u0441\u043A\u0438\u0445
    \u0437\u0430\u043A\u043E\u043D\u043E\u0432, \u043E\u043D \u0431\u044B\u043B \u0443\u0432\u043E\u043B\u0435\u043D
    \u0438\u0437 \u0413\u0430\u043C\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0438
    \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0432 \u0421\u0428\u0410.  \u0412 \u0410\u043C\u0435\u0440\u0438\u043A\u0435
    \u0410\u0440\u0442\u0438\u043D \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B
    \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0418\u043D\u0434\u0438\u0430\u043D\u044B (1938\u20131946), \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 (1946\u20131958).
    \u0415\u0433\u043E \u043B\u0435\u043A\u0446\u0438\u0438 \u0438 \u0441\u0435\u043C\u0438\u043D\u0430\u0440\u044B
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443. \u0421\u0440\u0435\u0434\u0438 \u0435\u0433\u043E
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432 \u2014 \u0442\u0430\u043A\u0438\u0435
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u043A\u0430\u043A \u0421\u0435\u0440\u0436 \u041B\u0435\u043D\u0433, \u0414\u0436\u043E\u043D
    \u0422\u0435\u0439\u0442 \u0438 \u0425\u0430\u043D\u0441 \u0426\u0430\u0441\u0441\u0435\u043D\u0445\u0430\u0443\u0441. 
    \u0412 1958 \u0433\u043E\u0434\u0443 \u0410\u0440\u0442\u0438\u043D \u043F\u0440\u0438\u043D\u044F\u043B
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
    \u0432 \u0413\u0430\u043C\u0431\u0443\u0440\u0433, \u0433\u0434\u0435 \u0438
    \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0434\u043E \u0441\u0430\u043C\u043E\u0439
    \u0441\u043C\u0435\u0440\u0442\u0438 20 \u0434\u0435\u043A\u0430\u0431\u0440\u044F
    1962 \u0433\u043E\u0434\u0430.  ### \U0001F9EC \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435  \u042D\u043C\u0438\u043B\u044C
    \u0410\u0440\u0442\u0438\u043D, \u043D\u0430\u0440\u044F\u0434\u0443 \u0441 \u042D\u043C\u043C\u0438
    \u041D\u0451\u0442\u0435\u0440, \u043F\u043E \u043F\u0440\u0430\u0432\u0443 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B. \u0415\u0433\u043E \u0438\u0434\u0435\u0438
    \u0438 \u043C\u0435\u0442\u043E\u0434\u044B \u043B\u0435\u0436\u0430\u0442 \u0432
    \u043E\u0441\u043D\u043E\u0432\u0435 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432 \u044D\u0442\u043E\u0439 \u043D\u0430\u0443\u043A\u0438.
    \u0415\u0433\u043E \u0442\u0440\u0443\u0434\u044B \u0432\u043E\u0448\u043B\u0438
    \u0432 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A \xAB\u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\xBB \u0411\u0430\u0440\u0442\u0430
    \u0432\u0430\u043D \u0434\u0435\u0440 \u0412\u0430\u0440\u0434\u0435\u043D\u0430.
    \u041E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u043F\u043E\u0447\u0435\u0442\u043D\u044B\u043C
    \u0447\u043B\u0435\u043D\u043E\u043C \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430.  \u041D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0434\u0438\u043D\u0430\u0441\u0442\u0438\u044F \u0410\u0440\u0442\u0438\u043D\u043E\u0432
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B\u0430\u0441\u044C \u0438
    \u0432 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0438:
    \u0435\u0433\u043E \u0441\u044B\u043D, \u041C\u0430\u0439\u043A\u043B \u0410\u0440\u0442\u0438\u043D,
    \u0442\u0430\u043A\u0436\u0435 \u0441\u0442\u0430\u043B \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u043E\u043C \u0432
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0438 \u0440\u0430\u0431\u043E\u0442\u0430
    \u042D\u043C\u0438\u043B\u044F \u0410\u0440\u0442\u0438\u043D\u0430 \u043F\u043E\u043B\u043D\u044B
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u043E\u0432
    \u0438 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0445 \u0434\u0435\u0442\u0430\u043B\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u0435\u043B\u0430\u044E\u0442
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u0435\u0449\u0435
    \u0431\u043E\u043B\u0435\u0435 \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439.
    \u0412\u043E\u0442 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0445
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u043E \u043D\u0435\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432\u044B\u0445\u043E\u0434\u044F\u0442 \u0437\u0430 \u0440\u0430\u043C\u043A\u0438
    \u0441\u0442\u0440\u043E\u0433\u0438\u0445 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u0430\u043D\u043D\u044B\u0445.  ### \U0001F468\u200D\U0001F52C \u0425\u0438\u043C\u0438\u044F
    \u0432\u043C\u0435\u0441\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438:
    \u044E\u043D\u043E\u0448\u0435\u0441\u043A\u043E\u0435 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435
    \u041C\u0430\u043B\u043E \u043A\u0442\u043E \u0437\u043D\u0430\u0435\u0442, \u0447\u0442\u043E
    \u0432 \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0435 \u0433\u043E\u0434\u044B
    \u0410\u0440\u0442\u0438\u043D \u0431\u044B\u043B \u043A\u0443\u0434\u0430 \u0431\u043E\u043B\u044C\u0448\u0435
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D \u0445\u0438\u043C\u0438\u0435\u0439,
    \u0447\u0435\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439.
    \u041E\u043D \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B \u0445\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u043F\u044B\u0442\u044B \u0438 \u0434\u0430\u0436\u0435 \u0443\u0441\u0442\u0440\u043E\u0438\u043B
    \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u0432\u0437\u0440\u044B\u0432
    \u0432 \u0445\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u0438
    \u0441\u0432\u043E\u0435\u0439 \u0448\u043A\u043E\u043B\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u0433\u0440\u043E\u043C\u043A\u0438\u043C \u0441\u043E\u0431\u044B\u0442\u0438\u0435\u043C!
    \u041B\u0438\u0448\u044C \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    16 \u043B\u0435\u0442, \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0432\u043B\u0438\u044F\u043D\u0438\u044E \u0448\u043A\u043E\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F, \u043E\u043D \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439 \u0432\u0441\u0435\u0440\u044C\u0435\u0437. 
    ### \U0001F4F8 \u0412\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444-\u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044C
    \u0410\u0440\u0442\u0438\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0435\u0439
    \u2014 \u043E\u043D \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C
    \u043C\u0430\u0441\u0442\u0435\u0440\u043E\u043C, \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u044B \u0446\u0435\u043D\u043D\u044B\u043C\u0438
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u043C\u0438 \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    \u0412 1930 \u0433\u043E\u0434\u0443 \u043E\u043D \u043A\u0443\u043F\u0438\u043B
    \u043E\u0434\u043D\u0443 \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u043A\u0430\u043C\u0435\u0440
    Leica \u0438 \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u0436\u0435\u043D\u043E\u0439
    \u041D\u0430\u0442\u0430\u0448\u0435\u0439 \u0441\u043E\u0437\u0434\u0430\u043B
    \u043A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u044E \u0444\u043E\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0435\u0433\u043E\u0434\u043D\u044F
    \u0432\u044B\u0441\u043E\u043A\u043E \u0446\u0435\u043D\u0438\u0442\u0441\u044F.
    \u0421\u0440\u0435\u0434\u0438 \u0435\u0433\u043E \u0441\u043D\u0438\u043C\u043A\u043E\u0432
    \u0435\u0441\u0442\u044C \u043F\u043E\u0440\u0442\u0440\u0435\u0442\u044B \u0442\u0430\u043A\u0438\u0445
    \u043A\u043E\u0440\u0438\u0444\u0435\u0435\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u043A\u0430\u043A \u0410\u043B\u044C\u0431\u0435\u0440\u0442 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D,
    \u0414\u0430\u0432\u0438\u0434 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0438 \u042D\u043C\u043C\u0438 \u041D\u0451\u0442\u0435\u0440. \u042D\u0442\u0438
    \u0441\u043D\u0438\u043C\u043A\u0438 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0444\u0438\u043A\u0441\u0438\u0440\u0443\u044E\u0442 \u0438\u0441\u0442\u043E\u0440\u0438\u044E,
    \u043D\u043E \u0438 \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u0443\u044E\u0442
    \u0435\u0433\u043E \u0445\u0443\u0434\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0432\u0437\u0433\u043B\u044F\u0434.  ### \u265F \u0428\u0430\u0445\u043C\u0430\u0442\u043D\u044B\u0439
    \u0433\u0440\u043E\u0441\u0441\u043C\u0435\u0439\u0441\u0442\u0435\u0440 \u0432
    \u0443\u0437\u043A\u043E\u043C \u043A\u0440\u0443\u0433\u0443 \u0410\u0440\u0442\u0438\u043D
    \u0431\u044B\u043B \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u044B\u043C \u0438
    \u0441\u0438\u043B\u044C\u043D\u044B\u043C \u0448\u0430\u0445\u043C\u0430\u0442\u0438\u0441\u0442\u043E\u043C.
    \u0412 \u0413\u0430\u043C\u0431\u0443\u0440\u0433\u0435 \u043E\u043D \u0447\u0430\u0441\u0442\u043E
    \u0438\u0433\u0440\u0430\u043B \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438
    \u0438 \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u0430\u043C\u0438
    \u043F\u0440\u044F\u043C\u043E \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u043F\u0440\u0438\u0447\u0435\u043C \u0434\u0435\u043B\u0430\u043B \u044D\u0442\u043E
    \u0441 \u0442\u0430\u043A\u0438\u043C \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u043E\u043C,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0438\u0433\u0440\u0443 \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u043B\u0438
    \u0441 \u0438\u0433\u0440\u043E\u0439 \u0433\u0440\u043E\u0441\u0441\u043C\u0435\u0439\u0441\u0442\u0435\u0440\u0430.
    \u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B
    \u0435\u0433\u043E \u043F\u0430\u0440\u0442\u0438\u0438 \u0441 \u041E\u0442\u0442\u043E
    \u0428\u0440\u0430\u0439\u0435\u0440\u043E\u043C, \u0438\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0430\u044F
    \u0438\u0433\u0440\u0430 \u0431\u044B\u043B\u0430 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0434\u043E\u0441\u0443\u0433\u043E\u043C, \u0430 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439
    \u0434\u0443\u044D\u043B\u044C\u044E.  ### \U0001F575\uFE0F \u0418\u0433\u0440\u044B
    \u0441 \u0433\u0435\u0441\u0442\u0430\u043F\u043E \u0412 \u043D\u0430\u0446\u0438\u0441\u0442\u0441\u043A\u043E\u0439
    \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438 \u0438\u0445 \u0441\u0435\u043C\u044C\u044F
    \u0436\u0438\u043B\u0430 \u043F\u043E\u0434 \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E\u0439
    \u0443\u0433\u0440\u043E\u0437\u043E\u0439 \u0438\u0437-\u0437\u0430 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0436\u0435\u043D\u044B \u041D\u0430\u0442\u0430\u0448\u0438. \u041F\u043E \u0435\u0435
    \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F\u043C,
    \u043E\u043D\u0438 \u0437\u043D\u0430\u043B\u0438, \u0447\u0442\u043E \u0437\u0430
    \u0438\u0445 \u0434\u043E\u043C\u043E\u043C \u0432\u0435\u0434\u0435\u0442\u0441\u044F
    \u0441\u043B\u0435\u0436\u043A\u0430. \u0412\u043C\u0435\u0441\u0442\u043E \u0442\u043E\u0433\u043E
    \u0447\u0442\u043E\u0431\u044B \u0432\u043F\u0430\u0434\u0430\u0442\u044C \u0432
    \u043F\u0430\u043D\u0438\u043A\u0443, \u043E\u043D\u0438 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u0438
    \u044D\u0442\u043E \u0432 \u0441\u0432\u043E\u0435\u043E\u0431\u0440\u0430\u0437\u043D\u0443\u044E
    \u0438\u0433\u0440\u0443: \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u043B\u0438\u0441\u044C
    \u043D\u0430 \u0434\u043E\u043B\u0433\u0438\u0435 \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0438,
    \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u044F \u0441\u0432\u043E\u0435\u0433\u043E
    \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044F,
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443 \u0431\u044B\u043B\u043E \u0442\u044F\u0436\u0435\u043B\u043E
    \u0438\u0434\u0442\u0438, \u0442\u0430\u0449\u0438\u0442\u044C\u0441\u044F \u0437\u0430
    \u043D\u0438\u043C\u0438 \u043C\u043D\u043E\u0433\u043E \u043A\u0438\u043B\u043E\u043C\u0435\u0442\u0440\u043E\u0432. 
    ### \U0001F4AC \u0410\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0447\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C \u0410\u0440\u0442\u0438\u043D
    \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0435\u0439
    \u043D\u0435\u043F\u043E\u0434\u043A\u0443\u043F\u043D\u043E\u0439 \u0447\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C\u044E
    \u0432 \u043D\u0430\u0443\u043A\u0435. \u041E\u043D \u043C\u043E\u0433 \u043F\u0440\u0435\u0440\u0432\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u044E \u0438 \u0441\u043A\u0430\u0437\u0430\u0442\u044C
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430\u043C: \"\u0412\u044B \u043D\u0435
    \u0434\u043E\u043B\u0436\u043D\u044B \u0432\u0435\u0440\u0438\u0442\u044C \u043D\u0438
    \u043E\u0434\u043D\u043E\u043C\u0443 \u043C\u043E\u0435\u043C\u0443 \u0441\u043B\u043E\u0432\u0443,
    \u043F\u043E\u043A\u0430 \u044F \u043D\u0435 \u0434\u043E\u043A\u0430\u0436\u0443
    \u044D\u0442\u043E\". \u041E\u043D \u043F\u0440\u0438\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0441\u044F
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430, \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u2014 \u044D\u0442\u043E \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u0430\u044F
    \u0438\u0441\u0442\u0438\u043D\u0430, \u0438 \u043D\u0435 \u0442\u0435\u0440\u043F\u0435\u043B
    \u043D\u0438 \u043C\u0430\u043B\u0435\u0439\u0448\u0435\u0433\u043E \u043D\u0430\u043C\u0435\u043A\u0430
    \u043D\u0430 \u043C\u043E\u0448\u0435\u043D\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0438\u043B\u0438 \u043D\u0435\u0434\u043E\u043C\u043E\u043B\u0432\u043A\u0443. 
    ### \U0001F4DA \"\u041F\u0438\u043E\u043D\u0435\u0440\" \u041B\u0435\u043A\u0446\u0438\u0439
    \u0415\u0433\u043E \u043B\u0435\u043A\u0446\u0438\u0438 \u0431\u044B\u043B\u0438
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B. \u041E\u043D \u043C\u043E\u0433
    \u043F\u0440\u0438\u0439\u0442\u0438 \u043D\u0430 \u0437\u0430\u043D\u044F\u0442\u0438\u044F
    \u0431\u0435\u0437 \u0435\u0434\u0438\u043D\u043E\u0433\u043E \u043B\u0438\u0441\u0442\u0430
    \u0431\u0443\u043C\u0430\u0433\u0438 \u0438, \u0437\u0430\u0434\u0430\u0432 \u043B\u0438\u0448\u044C
    \u043E\u0434\u0438\u043D \u0432\u043E\u043F\u0440\u043E\u0441 \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u0438,
    \u043F\u0440\u043E\u0432\u0435\u0441\u0442\u0438 \u0447\u0430\u0441\u043E\u0432\u0443\u044E
    \u043B\u0435\u043A\u0446\u0438\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0438 \u044F\u0441\u043D\u043E\u0439, \u0447\u0442\u043E \u0441\u043B\u0443\u0448\u0430\u0442\u0435\u043B\u0438
    \u043D\u0435 \u0437\u0430\u043C\u0435\u0447\u0430\u043B\u0438, \u043A\u0430\u043A
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0435
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0438\u0441\u044C
    \u0434\u043B\u044F \u043D\u0438\u0445 \u043F\u043E\u043D\u044F\u0442\u043D\u044B\u043C\u0438.
    \u0417\u0430 \u044D\u0442\u043E \u0435\u0433\u043E \u043F\u0440\u043E\u0437\u0432\u0430\u043B\u0438
    \"\u043F\u0435\u0432\u0446\u043E\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\",
    \u0442\u0430\u043A \u043A\u0430\u043A \u0435\u0433\u043E \u0433\u043E\u043B\u043E\u0441
    \u0438 \u043C\u0430\u043D\u0435\u0440\u0430 \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u0431\u044B\u043B\u0438 \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u044B
    \u0438 \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B. 
    ### \U0001F30D \"\u0411\u043B\u0443\u0434\u043D\u044B\u0439 \u0441\u044B\u043D\"
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u041F\u043E\u0441\u043B\u0435
    \u0442\u043E\u0433\u043E \u043A\u0430\u043A \u043E\u043D \u043F\u043E\u043A\u0438\u043D\u0443\u043B
    \u0413\u0430\u043C\u0431\u0443\u0440\u0433 \u0432 1937 \u0433\u043E\u0434\u0443,
    \u043E\u043D \u043E\u0447\u0435\u043D\u044C \u0442\u043E\u0441\u043A\u043E\u0432\u0430\u043B
    \u043F\u043E \u0415\u0432\u0440\u043E\u043F\u0435. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0443\u044E \u043A\u0430\u0440\u044C\u0435\u0440\u0443
    \u0432 \u0421\u0428\u0410 (\u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435),
    \u0432 1958 \u0433\u043E\u0434\u0443 \u043E\u043D \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E
    \u0434\u043B\u044F \u0432\u0441\u0435\u0445 \u043F\u0440\u0438\u043D\u044F\u043B
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
    \u0432 \u0413\u0430\u043C\u0431\u0443\u0440\u0433 \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C
    \u0442\u0430\u043C \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0436\u0438\u0437\u043D\u0438.
    \u0413\u043E\u0432\u043E\u0440\u044F\u0442, \u0435\u0433\u043E \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u0430\u043B\u0430
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0440\u0430\u0431\u043E\u0442\u0430,
    \u043D\u043E \u0438 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u0430\u044F \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0430
    \u0441\u0442\u0430\u0440\u043E\u0433\u043E \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430.  ###
    \U0001F9EC \u0414\u0438\u043D\u0430\u0441\u0442\u0438\u044F \u0433\u0435\u043D\u0438\u0435\u0432
    \u0423\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E, \u043D\u043E
    \u0442\u0430\u043B\u0430\u043D\u0442 \u0410\u0440\u0442\u0438\u043D\u0430 \u043F\u0435\u0440\u0435\u0434\u0430\u043B\u0441\u044F
    \u043F\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0443. \u0415\u0433\u043E
    \u0441\u044B\u043D, \u041C\u0430\u0439\u043A\u043B \u0410\u0440\u0442\u0438\u043D,
    \u0441\u0442\u0430\u043B \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u043E\u0432
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u041C\u0430\u0442\u044C
    \u041C\u0430\u0439\u043A\u043B\u0430 \u2014 \u041D\u0430\u0442\u0430\u0448\u0430
    \u2014 \u0448\u0443\u0442\u0438\u043B\u0430, \u0447\u0442\u043E \u0432 \u0434\u043E\u043C\u0435
    \u0431\u044B\u043B\u043E \u0434\u0432\u0430 \"\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u043E\u043D\u0441\u0442\u0440\u0430\": \u043E\u0442\u0435\u0446 \u0438
    \u0441\u044B\u043D.  \u042D\u0442\u0438 \u0444\u0430\u043A\u0442\u044B \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442,
    \u0447\u0442\u043E \u042D\u043C\u0438\u043B\u044C \u0410\u0440\u0442\u0438\u043D
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \"\u0441\u0443\u0445\u0438\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C\", \u0430 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0441 \u0436\u0438\u0432\u044B\u043C, \u044F\u0440\u043A\u0438\u043C \u0438
    \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u044B\u043C \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C."
