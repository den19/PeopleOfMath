  shortBioRu: "\u042D\u043C\u0438\u043B\u044C \u0410\u0440\u0442\u0438\u043D (1898\u20131962)
    \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 XX \u0432\u0435\u043A\u0430,
    \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u044B.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C, \u043E\u0442\u043C\u0435\u0447\u0435\u043D\u043D\u0430\u044F
    \u043A\u0430\u043A \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u043C\u0438
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u043C\u0438,
    \u0442\u0430\u043A \u0438 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u0430\u043C\u0438 \u0441\u0443\u0434\u044C\u0431\u044B,
    \u0442\u0435\u0441\u043D\u043E \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u0430
    \u0441 \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439 \u0415\u0432\u0440\u043E\u043F\u044B
    \u0438 \u0410\u043C\u0435\u0440\u0438\u043A\u0438 \u043F\u0435\u0440\u0432\u043E\u0439
    \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u044B XX \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F. 
    ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435  \u042D\u043C\u0438\u043B\u044C
    \u0410\u0440\u0442\u0438\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F 3 \u043C\u0430\u0440\u0442\u0430
    1898 \u0433\u043E\u0434\u0430 \u0432 \u0412\u0435\u043D\u0435, \u0432 \u0441\u0435\u043C\u044C\u0435
    \u0441 \u0431\u043E\u0433\u0435\u043C\u043D\u044B\u043C\u0438 \u0438 \u0438\u043D\u0442\u0435\u0440\u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u043A\u043E\u0440\u043D\u044F\u043C\u0438 . \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u0442\u043E\u0436\u0435 \u042D\u043C\u0438\u043B\u044C \u0410\u0440\u0442\u0438\u043D,
    \u0431\u044B\u043B \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0435\u043C \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430\u043C\u0438
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430, \u0430 \u043C\u0430\u0442\u044C,
    \u042D\u043C\u043C\u0430 \u041B\u0430\u0443\u0440\u0430, \u0434\u043E \u0437\u0430\u043C\u0443\u0436\u0435\u0441\u0442\u0432\u0430
    \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B\u0430 \u043A\u0430\u043A \u043F\u0435\u0432\u0438\u0446\u0430
    \u0432 \u043E\u043F\u0435\u0440\u0435\u0442\u0442\u0435 . \u0424\u0430\u043C\u0438\u043B\u0438\u044E
    \u0410\u0440\u0442\u0438\u043D \u043E\u043D \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u043E\u0442 \u0434\u0435\u0434\u0430-\u0430\u0440\u043C\u044F\u043D\u0438\u043D\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0435\u0440\u0435\u0431\u0440\u0430\u043B\u0441\u044F
    \u0432 \u0412\u0435\u043D\u0443 \u0432 XIX \u0432\u0435\u043A\u0435 . \u041F\u043E
    \u0441\u043B\u043E\u0432\u0430\u043C \u0441\u044B\u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430,
    \u041C\u0430\u0439\u043A\u043B\u0430 \u0410\u0440\u0442\u0438\u043D\u0430, \u043F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u0430\u044F
    \u0444\u0430\u043C\u0438\u043B\u0438\u044F \u0431\u044B\u043B\u0430 \"\u0410\u0440\u0442\u0438\u043D\u044F\u043D\"
    (Artinian) .  \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u042D\u043C\u0438\u043B\u044F
    \u043D\u0435\u043B\u044C\u0437\u044F \u043D\u0430\u0437\u0432\u0430\u0442\u044C
    \u0431\u0435\u0437\u043E\u0431\u043B\u0430\u0447\u043D\u044B\u043C. \u0415\u0433\u043E
    \u043E\u0442\u0435\u0446 \u0443\u043C\u0435\u0440 \u0432 1906 \u0433\u043E\u0434\u0443,
    \u043A\u043E\u0433\u0434\u0430 \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0443
    \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E \u0432\u043E\u0441\u0435\u043C\u044C
    \u043B\u0435\u0442, \u0430 \u0432\u0441\u043A\u043E\u0440\u0435 \u043C\u0430\u0442\u044C
    \u043F\u043E\u0432\u0442\u043E\u0440\u043D\u043E \u0432\u044B\u0448\u043B\u0430
    \u0437\u0430\u043C\u0443\u0436 \u0437\u0430 \u043F\u0440\u0435\u0443\u0441\u043F\u0435\u0432\u0430\u044E\u0449\u0435\u0433\u043E
    \u043F\u0440\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u0438\u043A\u0430,
    \u0438 \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u0420\u0430\u0439\u0445\u0435\u043D\u0431\u0435\u0440\u0433 (\u043D\u044B\u043D\u0435
    \u041B\u0438\u0431\u0435\u0440\u0435\u0446 \u0432 \u0427\u0435\u0445\u0438\u0438)
    . \u0412 \u0448\u043A\u043E\u043B\u0435 \u0410\u0440\u0442\u0438\u043D \u043F\u043E\u043D\u0430\u0447\u0430\u043B\u0443
    \u043D\u0435 \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0435\u0439 \u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u041E\u043D \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F
    \u0445\u0438\u043C\u0438\u0435\u0439 \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0435\u0439,
    \u0438 \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u043F\u0440\u043E\u0441\u043D\u0443\u043B\u0441\u044F \u0442\u043E\u043B\u044C\u043A\u043E
    \u043A \u0448\u0435\u0441\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u0438 \u0433\u043E\u0434\u0430\u043C
    . \u041F\u043E\u0437\u0436\u0435 \u043E\u043D \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B\u0441\u044F,
    \u0447\u0442\u043E \u0434\u043E \u044D\u0442\u043E\u0433\u043E \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0430
    \u043E \u043A\u0430\u043A\u043E\u043C-\u043B\u0438\u0431\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u043C
    \u0442\u0430\u043B\u0430\u043D\u0442\u0435 \u043A \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0443
    \u043D\u0435 \u043C\u043E\u0433\u043B\u043E \u0431\u044B\u0442\u044C \u0438 \u0440\u0435\u0447\u0438
    .  \u0412 1916 \u0433\u043E\u0434\u0443 \u0410\u0440\u0442\u0438\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0412\u0435\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u043D\u043E \u043F\u0440\u043E\u0443\u0447\u0438\u043B\u0441\u044F \u0442\u0430\u043C
    \u0432\u0441\u0435\u0433\u043E \u043E\u0434\u0438\u043D \u0441\u0435\u043C\u0435\u0441\u0442\u0440
    . \u0412 \u0440\u0430\u0437\u0433\u0430\u0440 \u041F\u0435\u0440\u0432\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B \u043E\u043D
    \u0431\u044B\u043B \u043F\u0440\u0438\u0437\u0432\u0430\u043D \u0432 \u0430\u0432\u0441\u0442\u0440\u0438\u0439\u0441\u043A\u0443\u044E
    \u0430\u0440\u043C\u0438\u044E \u0438 \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u0435\u043D
    \u043D\u0430 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u0439
    \u0444\u0440\u043E\u043D\u0442 . \u041A \u0441\u0447\u0430\u0441\u0442\u044C\u044E,
    \u0435\u043C\u0443 \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u0438\u0437\u0431\u0435\u0436\u0430\u0442\u044C
    \u0430\u043A\u0442\u0438\u0432\u043D\u044B\u0445 \u0431\u043E\u0435\u0432\u044B\u0445
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439, \u0441\u043B\u0443\u0436\u0430
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0447\u0438\u043A\u043E\u043C . \u041F\u043E\u0441\u043B\u0435
    \u0432\u043E\u0439\u043D\u044B, \u0432 1919 \u0433\u043E\u0434\u0443, \u0410\u0440\u0442\u0438\u043D
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0432 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u0433\u0434\u0435 \u0432 1921 \u0433\u043E\u0434\u0443 \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0413\u0443\u0441\u0442\u0430\u0432\u0430 \u0425\u0435\u0440\u0433\u043B\u043E\u0442\u0446\u0430
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    . /n/n ### \U0001F680 \u0420\u0430\u0441\u0446\u0432\u0435\u0442 \u043A\u0430\u0440\u044C\u0435\u0440\u044B
    \u0438 \u0433\u0430\u043C\u0431\u0443\u0440\u0433\u0441\u043A\u0438\u0439 \u043F\u0435\u0440\u0438\u043E\u0434 
    \u0417\u0430\u0449\u0438\u0442\u0438\u0432 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E,
    \u0410\u0440\u0442\u0438\u043D \u0433\u043E\u0434 \u043F\u0440\u043E\u0432\u0435\u043B
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435 \u2014 \u043C\u0438\u0440\u043E\u0432\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u0433\u0434\u0435
    \u043E\u0431\u0449\u0430\u043B\u0441\u044F \u0441 \u0442\u0430\u043A\u0438\u043C\u0438
    \u043A\u043E\u0440\u0438\u0444\u0435\u044F\u043C\u0438, \u043A\u0430\u043A \u0414\u0430\u0432\u0438\u0434
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442, \u0420\u0438\u0445\u0430\u0440\u0434
    \u041A\u0443\u0440\u0430\u043D\u0442 \u0438, \u0447\u0442\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0432\u0430\u0436\u043D\u043E, \u042D\u043C\u043C\u0438 \u041D\u0451\u0442\u0435\u0440
    . \u0412 1922 \u0433\u043E\u0434\u0443 \u043E\u043D \u043D\u0430\u0447\u0430\u043B
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u043C
    \u0432 \u0413\u0430\u043C\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u0430 \u0432 1923 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0437\u0432\u0430\u043D\u0438\u0435 \u043F\u0440\u0438\u0432\u0430\u0442-\u0434\u043E\u0446\u0435\u043D\u0442\u0430
    . \u041A\u0430\u0440\u044C\u0435\u0440\u0430 \u0410\u0440\u0442\u0438\u043D\u0430
    \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B\u0430\u0441\u044C:
    \u0432 1925 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B \u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C,
    \u0430 \u0432 1926-\u043C \u2014 \u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0413\u0430\u043C\u0431\u0443\u0440\u0433\u0430
    .  \u041F\u0435\u0440\u0438\u043E\u0434 \u0441 1921 \u043F\u043E 1931 \u0433\u043E\u0434
    \u0441\u0442\u0430\u043B \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438
    \u0410\u0440\u0442\u0438\u043D\u0430 . \u0418\u043C\u0435\u043D\u043D\u043E \u0432
    \u044D\u0442\u0438 \u0433\u043E\u0434\u044B \u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0441\u0430\u043C\u044B\u0435 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F:  *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u043F\u043E\u043B\u0435\u0439 \u0438 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430:**
    \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u041E\u0442\u0442\u043E
    \u0428\u0440\u0430\u0439\u0435\u0440\u043E\u043C \u0410\u0440\u0442\u0438\u043D
    \u0441\u043E\u0437\u0434\u0430\u043B \u0442\u0435\u043E\u0440\u0438\u044E \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u043F\u043E\u043B\u0435\u0439 . \u0412 1927 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u044D\u0442\u0443 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    **17-\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430**
    \u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0438
    \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0445
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u0432 \u0432\u0438\u0434\u0435 \u0441\u0443\u043C\u043C\u044B \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432
    . \u042D\u0442\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u043E \u0435\u043C\u0443 \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u0443\u044E
    \u0441\u043B\u0430\u0432\u0443. *   **\u0417\u0430\u043A\u043E\u043D \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438:**
    \u0412 \u0442\u043E\u043C \u0436\u0435 1927 \u0433\u043E\u0434\u0443 \u0410\u0440\u0442\u0438\u043D
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u044E
    \u0433\u043B\u0430\u0432\u043D\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u043E\u043B\u0435\u0439
    \u043A\u043B\u0430\u0441\u0441\u043E\u0432, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B **\u043E\u0431\u0449\u0438\u0439 \u0437\u0430\u043A\u043E\u043D
    \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438**, \u043D\u044B\u043D\u0435
    \u043D\u043E\u0441\u044F\u0449\u0438\u0439 \u0435\u0433\u043E \u0438\u043C\u044F.
    \u042D\u0442\u043E\u0442 \u0437\u0430\u043A\u043E\u043D \u043E\u0431\u043E\u0431\u0449\u0438\u043B
    \u0432\u0441\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435 \u0440\u0430\u043D\u0435\u0435
    \u0437\u0430\u043A\u043E\u043D\u044B \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0441\u0442\u0430\u043B \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u043C
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C \u0432\u0441\u0435\u0439
    \u0430\u0431\u0435\u043B\u0435\u0432\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043F\u043E\u043B\u0435\u0439 \u043A\u043B\u0430\u0441\u0441\u043E\u0432 . *  
    **\u0422\u0435\u043E\u0440\u0438\u044F \u043A\u043E\u0441:** \u0412 1925 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u043D\u043E\u0432\u0443\u044E
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u2014 \u0442\u0435\u043E\u0440\u0438\u044E \u043A\u043E\u0441, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043D\u0430\u0448\u043B\u0430 \u0432\u0430\u0436\u043D\u044B\u0435 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u0432 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0433\u0440\u0443\u043F\u043F . *   **\u0422\u0435\u043E\u0440\u0438\u044F \u043A\u043E\u043B\u0435\u0446:**
    \u0410\u0440\u0442\u0438\u043D \u0432\u0432\u0435\u043B \u0432\u0430\u0436\u043D\u043E\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u043A\u043E\u043B\u0435\u0446 \u0441
    \u0443\u0441\u043B\u043E\u0432\u0438\u0435\u043C \u043E\u0431\u0440\u044B\u0432\u0430
    \u0443\u0431\u044B\u0432\u0430\u044E\u0449\u0438\u0445 \u0446\u0435\u043F\u043E\u0447\u0435\u043A
    \u0438\u0434\u0435\u0430\u043B\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0442\u0435\u043F\u0435\u0440\u044C \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B
    \u043A\u0430\u043A **\u0430\u0440\u0442\u0438\u043D\u043E\u0432\u044B \u043A\u043E\u043B\u044C\u0446\u0430**
    .  \u0412\u043C\u0435\u0441\u0442\u0435 \u0441 \u042D\u043C\u043C\u0438 \u041D\u0451\u0442\u0435\u0440
    \u0410\u0440\u0442\u0438\u043D \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u0439 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u044B.
    \u0415\u0433\u043E \u0438\u0434\u0435\u0438 \u043B\u0435\u0433\u043B\u0438 \u0432
    \u043E\u0441\u043D\u043E\u0432\u0443 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0430 \u0432\u0430\u043D \u0434\u0435\u0440
    \u0412\u0430\u0440\u0434\u0435\u043D\u0430 \"\u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\" .  ### \U0001F30A \u042D\u043C\u0438\u0433\u0440\u0430\u0446\u0438\u044F
    \u0438 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435  \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0410\u0440\u0442\u0438\u043D\u0430 \u0431\u044B\u043B\u0430
    \u0442\u0435\u0441\u043D\u043E \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u0430
    \u0441 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043A\u0430\u0442\u0430\u043A\u043B\u0438\u0437\u043C\u0430\u043C\u0438 \u044D\u043F\u043E\u0445\u0438.
    \u0412 1929 \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0441\u0432\u043E\u0435\u0439 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043A\u0435
    \u041D\u0430\u0442\u0430\u043B\u0438 (\u041D\u0430\u0442\u0430\u0448\u0435) \u042F\u0441\u043D\u043E\u0439,
    \u0434\u043E\u0447\u0435\u0440\u0438 \u0440\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0441\u0442\u0430, \u0432\u044B\u0432\u0435\u0437\u0435\u043D\u043D\u043E\u0439
    \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u044F\u043C\u0438 \u0438\u0437 \u0420\u043E\u0441\u0441\u0438\u0438
    \u043F\u043E\u0441\u043B\u0435 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438
    . \u041F\u043E\u0441\u043B\u0435 \u043F\u0440\u0438\u0445\u043E\u0434\u0430 \u043D\u0430\u0446\u0438\u0441\u0442\u043E\u0432
    \u043A \u0432\u043B\u0430\u0441\u0442\u0438 \u0432 1933 \u0433\u043E\u0434\u0443
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0441\u0435\u043C\u044C\u0438
    \u0441\u0442\u0430\u043B\u043E \u043E\u043F\u0430\u0441\u043D\u044B\u043C, \u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443
    \u041D\u0430\u0442\u0430\u0448\u0430 \u0431\u044B\u043B\u0430 \u0435\u0432\u0440\u0435\u0439\u043A\u043E\u0439
    \u043F\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044E
    . \u0425\u043E\u0442\u044F \u0441\u0430\u043C \u0410\u0440\u0442\u0438\u043D
    \u043D\u0435 \u0431\u044B\u043B \u0435\u0432\u0440\u0435\u0435\u043C, \u0432
    1937 \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435 \u0443\u0436\u0435\u0441\u0442\u043E\u0447\u0435\u043D\u0438\u044F
    \u0440\u0430\u0441\u043E\u0432\u044B\u0445 \u0437\u0430\u043A\u043E\u043D\u043E\u0432,
    \u043E\u043D \u0431\u044B\u043B \u0443\u0432\u043E\u043B\u0435\u043D \u0438\u0437
    \u0413\u0430\u043C\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u043A\u0430\u043A \u043C\u0443\u0436 \u0435\u0432\u0440\u0435\u0439\u043A\u0438
    .  \u041E\u0441\u0435\u043D\u044C\u044E 1937 \u0433\u043E\u0434\u0430 \u0410\u0440\u0442\u0438\u043D
    \u0441 \u0441\u0435\u043C\u044C\u0435\u0439 \u0431\u044B\u043B \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u043F\u043E\u043A\u0438\u043D\u0443\u0442\u044C \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044E
    \u0438 \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0432 \u0421\u0428\u0410 . \u0412 \u0410\u043C\u0435\u0440\u0438\u043A\u0435
    \u043E\u043D \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B \u0432
    \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u041D\u043E\u0442\u0440-\u0414\u0430\u043C
    (1937\u20131938), \u0437\u0430\u0442\u0435\u043C \u0432 \u0418\u043D\u0434\u0438\u0430\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u0432
    \u0411\u043B\u0443\u043C\u0438\u043D\u0433\u0442\u043E\u043D\u0435 (1938\u20131946)
    \u0438, \u043D\u0430\u043A\u043E\u043D\u0435\u0446, \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 (1946\u20131958)
    .  \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445
    \u0434\u0440\u0443\u0433\u0438\u0445 \u044D\u043C\u0438\u0433\u0440\u0430\u043D\u0442\u043E\u0432,
    \u0410\u0440\u0442\u0438\u043D \u0440\u0435\u0448\u0438\u043B \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
    \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044E. \u0412 1958 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u0440\u0438\u043D\u044F\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435
    \u0413\u0430\u043C\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u0438 \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u043B \u043A\u0430\u0444\u0435\u0434\u0440\u0443,
    \u0441 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0431\u044B\u043B \u0438\u0437\u0433\u043D\u0430\u043D
    \u0434\u0432\u0443\u043C\u044F \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F\u043C\u0438
    \u0440\u0430\u043D\u0435\u0435 . \u041E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u0413\u0430\u043C\u0431\u0443\u0440\u0433\u0435 \u0434\u043E \u0441\u0430\u043C\u043E\u0439
    \u0441\u043C\u0435\u0440\u0442\u0438 20 \u0434\u0435\u043A\u0430\u0431\u0440\u044F
    1962 \u0433\u043E\u0434\u0430 .  ### \U0001F33F \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0438 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C  \u042D\u043C\u0438\u043B\u044C
    \u0410\u0440\u0442\u0438\u043D \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F \u0443\u0447\u0435\u043D\u044B\u043C,
    \u043D\u043E \u0438 \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C. \u041E\u043D \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u043E
    \u043B\u044E\u0431\u0438\u043B \u043C\u0443\u0437\u044B\u043A\u0443, \u0438\u0433\u0440\u0430\u043B
    \u043D\u0430 \u0444\u043E\u0440\u0442\u0435\u043F\u0438\u0430\u043D\u043E \u0438
    \u0444\u043B\u0435\u0439\u0442\u0435, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0435\u0439 . \u0421\u0440\u0435\u0434\u0438
    \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432 \u2014 \u0442\u0430\u043A\u0438\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u043A\u0430\u043A \u0421\u0435\u0440\u0436 \u041B\u0435\u043D\u0433, \u0414\u0436\u043E\u043D
