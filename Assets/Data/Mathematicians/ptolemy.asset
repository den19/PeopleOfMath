  achievementsRu: "\u041A\u043B\u0430\u0432\u0434\u0438\u0439 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043D\u0430 \u043F\u043E\u043B\u0442\u043E\u0440\u044B \u0442\u044B\u0441\u044F\u0447\u0438
    \u043B\u0435\u0442 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u043E
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438,
    \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u0438 \u043E\u043F\u0442\u0438\u043A\u0438.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u043C\u0435\u0442\u043E\u0434
    \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0441\u044F \u0432 \u0442\u043E\u043C,
    \u0447\u0442\u043E\u0431\u044B \u0441\u043E\u0431\u0440\u0430\u0442\u044C, \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0438 \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u044C \u0442\u0440\u0443\u0434\u044B
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u0441\u043E\u0437\u0434\u0430\u0432 \u043D\u0430 \u0438\u0445 \u043E\u0441\u043D\u043E\u0432\u0435
    \u0441\u0442\u0440\u043E\u0439\u043D\u044B\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438, \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435
    \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0432\u0448\u0438\u0435 \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0435\u043C\u044B\u0435
    \u044F\u0432\u043B\u0435\u043D\u0438\u044F. \u0412\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0435
    \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u044B \u0432 \u0434\u0435\u0442\u0430\u043B\u044F\u0445
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u044B \u043D\u0438\u0436\u0435. 
    ### \U0001F4DA \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\xBB:
    \u0412\u0435\u043D\u0435\u0446 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0439
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438  \u042D\u0442\u043E
    \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0438 \u0441\u0430\u043C\u044B\u0439
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u0442\u0440\u0443\u0434
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F, \u043F\u043E\u043B\u043D\u043E\u0435
    \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u2014 \xAB\u0412\u0435\u043B\u0438\u043A\u043E\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u0432 13 \u043A\u043D\u0438\u0433\u0430\u0445\xBB. \u0410\u0440\u0430\u0431\u044B,
    \u0447\u0435\u0439 \u043F\u0435\u0440\u0435\u0432\u043E\u0434 \u043F\u043E\u043F\u0430\u043B
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0443, \u043D\u0430\u0437\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \xAB\u0410\u043B\u044C-\u041C\u0430\u0434\u0436\u0438\u0441\u0442\u0438\xBB
    (\xAB\u0412\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0439\xBB), \u0447\u0442\u043E
    \u043F\u043E\u0437\u0436\u0435 \u0442\u0440\u0430\u043D\u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u043E\u0441\u044C
    \u0432 \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\xBB. \u042D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0441\u0442\u0430\u043B\u0430 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0440\u043E\u0434\u0430 \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0435\u0439
    \u0438 \u0432\u0435\u0440\u0448\u0438\u043D\u043E\u0439 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430. \u0415\u0451 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435
    \u043F\u043E \u043A\u043D\u0438\u0433\u0430\u043C:  *   **\u041A\u043D\u0438\u0433\u0430
    I**: \u0417\u0430\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0441\u043D\u043E\u0432\u044B \u0433\u0435\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043C\u0438\u0440\u0430. \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u0441\u0444\u0435\u0440\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u043D\u0435\u0431\u0430 \u0438 \u0417\u0435\u043C\u043B\u0438, \u0435\u0451
    \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0435 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0432\u043E \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439. \u0417\u0434\u0435\u0441\u044C
    \u0436\u0435 \u0434\u0430\u0435\u0442\u0441\u044F \u0442\u0430\u0431\u043B\u0438\u0446\u0430
    \u0445\u043E\u0440\u0434 \u2014 \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043E\u0441\u043D\u043E\u0432\u0430 \u0434\u043B\u044F \u0432\u0441\u0435\u0445
    \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u0445 \u0440\u0430\u0441\u0447\u0435\u0442\u043E\u0432.
    *   **\u041A\u043D\u0438\u0433\u0430 II**: \u041F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438.
    \u0420\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u044E\u0442\u0441\u044F
    \u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u0417\u0435\u043C\u043B\u0438 \u043D\u0430
    \u043A\u043B\u0438\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u043E\u044F\u0441\u0430, \u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0434\u043D\u044F \u0438 \u043D\u043E\u0447\u0438 \u0432 \u0440\u0430\u0437\u043D\u044B\u0445
    \u0448\u0438\u0440\u043E\u0442\u0430\u0445, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u044F\u0432\u043B\u0435\u043D\u0438\u044F \u0432\u043E\u0441\u0445\u043E\u0434\u0430
    \u0438 \u0437\u0430\u0445\u043E\u0434\u0430 \u0441\u0432\u0435\u0442\u0438\u043B.
    *   **\u041A\u043D\u0438\u0433\u0430 III**: \u0421\u043E\u0434\u0435\u0440\u0436\u0438\u0442
    \u0442\u0435\u043E\u0440\u0438\u044E \u0432\u0438\u0434\u0438\u043C\u043E\u0433\u043E
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0421\u043E\u043B\u043D\u0446\u0430,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u0443\u044E \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    \u0413\u0438\u043F\u043F\u0430\u0440\u0445\u0430. \u0412 \u043D\u0435\u0439 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u0442 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0433\u043E\u0434\u0430 \u0438 \u0441\u0442\u0440\u043E\u0438\u0442 \u043C\u043E\u0434\u0435\u043B\u044C
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0421\u043E\u043B\u043D\u0446\u0430
    \u043F\u043E \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u0438. *   **\u041A\u043D\u0438\u0433\u0430
    IV \u0438 V**: \u041F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u044B \u0441\u0430\u043C\u043E\u043C\u0443
    \u0441\u043B\u043E\u0436\u043D\u043E\u043C\u0443 \u0434\u043B\u044F \u043C\u043E\u0434\u0435\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043E\u0431\u044A\u0435\u043A\u0442\u0443
    \u2014 \u041B\u0443\u043D\u0435. \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E \u0443\u0441\u043B\u043E\u0436\u043D\u044F\u0435\u0442
    \u043C\u043E\u0434\u0435\u043B\u044C \u0413\u0438\u043F\u043F\u0430\u0440\u0445\u0430,
    \u0432\u0432\u043E\u0434\u044F \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u044D\u043F\u0438\u0446\u0438\u043A\u043B \u0438 \xAB\u043F\u0440\u043E\u0441\u043D\u0435\u0432\u0437\u0438\u0441\xBB
    (\u043A\u043E\u043B\u0435\u0431\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u043B\u0443\u043D\u043D\u043E\u0433\u043E
    \u044D\u043F\u0438\u0446\u0438\u043A\u043B\u0430). \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E
    \u043F\u0440\u0435\u0434\u0432\u044B\u0447\u0438\u0441\u043B\u044F\u0442\u044C
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u041B\u0443\u043D\u044B
    \u0441 \u043D\u0435\u0432\u0438\u0434\u0430\u043D\u043D\u043E\u0439 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u2014 \u0434\u043E 10 \u0443\u0433\u043B\u043E\u0432\u044B\u0445 \u043C\u0438\u043D\u0443\u0442.
    \u0412 V \u043A\u043D\u0438\u0433\u0435 \u0442\u0430\u043A\u0436\u0435 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E \u0430\u0441\u0442\u0440\u043E\u043B\u044F\u0431\u0438\u0438
    \u0438 \u043F\u0440\u0438\u0432\u043E\u0434\u044F\u0442\u0441\u044F \u043C\u0435\u0442\u043E\u0434\u044B
    \u0440\u0430\u0441\u0447\u0435\u0442\u0430 \u043F\u0430\u0440\u0430\u043B\u043B\u0430\u043A\u0441\u0430
    \u0438 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F \u0434\u043E
    \u041B\u0443\u043D\u044B \u0438 \u0421\u043E\u043B\u043D\u0446\u0430. *   **\u041A\u043D\u0438\u0433\u0430
    VI**: \u0418\u0437\u043B\u0430\u0433\u0430\u0435\u0442 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u0439 \u2014 \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0445
    \u0438 \u043B\u0443\u043D\u043D\u044B\u0445, \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u044F
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F \u0438\u0445 \u043D\u0430\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
    \u0438 \u043C\u0435\u0442\u043E\u0434\u044B \u0440\u0430\u0441\u0447\u0435\u0442\u0430.
    *   **\u041A\u043D\u0438\u0433\u0438 VII \u0438 VIII**: \u0421\u043E\u0434\u0435\u0440\u0436\u0430\u0442
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0437\u0432\u0435\u0437\u0434\u043D\u044B\u0439
    \u043A\u0430\u0442\u0430\u043B\u043E\u0433. \u041E\u043D \u0432\u043A\u043B\u044E\u0447\u0430\u0435\u0442
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435 48 \u0441\u043E\u0437\u0432\u0435\u0437\u0434\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0431\u044B\u043B\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B
    \u0433\u0440\u0435\u043A\u0430\u043C, \u0438 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B
    1022 \u0437\u0432\u0435\u0437\u0434 (\u043F\u043E \u0434\u0440\u0443\u0433\u0438\u043C
    \u0434\u0430\u043D\u043D\u044B\u043C \u2014 \u0431\u043E\u043B\u0435\u0435 1000).
    \u0425\u043E\u0442\u044F \u043A\u0430\u0442\u0430\u043B\u043E\u0433 \u043E\u0441\u043D\u043E\u0432\u0430\u043D
    \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    \u0413\u0438\u043F\u043F\u0430\u0440\u0445\u0430, \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u043B \u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0438\u0437\u043B\u043E\u0436\u0438\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u043F\u0440\u0435\u0446\u0435\u0441\u0441\u0438\u0438
    (\u043F\u0440\u0435\u0434\u0432\u0430\u0440\u0435\u043D\u0438\u044F \u0440\u0430\u0432\u043D\u043E\u0434\u0435\u043D\u0441\u0442\u0432\u0438\u0439).
    *   **\u041A\u043D\u0438\u0433\u0438 IX\u2014XIII**: \u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u043D\u0430\u0443\u0447\u043D\u044B\u0439 \u0432\u044B\u0432\u043E\u0434 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F
    \u2014 \u043F\u0435\u0440\u0432\u0430\u044F \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043F\u043E\u043B\u043D\u0430\u044F \u0442\u0435\u043E\u0440\u0438\u044F \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043F\u044F\u0442\u0438 \u043F\u043B\u0430\u043D\u0435\u0442 (\u041C\u0435\u0440\u043A\u0443\u0440\u0438\u0439,
    \u0412\u0435\u043D\u0435\u0440\u0430, \u041C\u0430\u0440\u0441, \u042E\u043F\u0438\u0442\u0435\u0440,
    \u0421\u0430\u0442\u0443\u0440\u043D). \u0427\u0442\u043E\u0431\u044B \u0441\u043E\u0433\u043B\u0430\u0441\u043E\u0432\u0430\u0442\u044C
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u043F\u0435\u0442\u043B\u0435\u043E\u0431\u0440\u0430\u0437\u043D\u044B\u0435
    \u0432\u0438\u0434\u0438\u043C\u044B\u0435 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442 \u0441 \u0438\u0434\u0435\u0435\u0439 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u044B\u0445
    \u043A\u0440\u0443\u0433\u043E\u0432\u044B\u0445 \u043E\u0440\u0431\u0438\u0442,
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u0432\u0432\u043E\u0434\u0438\u0442
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438 **\u044D\u043F\u0438\u0446\u0438\u043A\u043B\u043E\u0432,
    \u0434\u0435\u0444\u0435\u0440\u0435\u043D\u0442\u043E\u0432** \u0438, \u0441\u0430\u043C\u043E\u0435
    \u0433\u043B\u0430\u0432\u043D\u043E\u0435, **\u044D\u043A\u0432\u0430\u043D\u0442\u0430**.
    \u042D\u043A\u0432\u0430\u043D\u0442 \u2014 \u044D\u0442\u043E \u0442\u043E\u0447\u043A\u0430,
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435
    \u0446\u0435\u043D\u0442\u0440\u0430 \u044D\u043F\u0438\u0446\u0438\u043A\u043B\u0430
    \u043F\u043E \u0434\u0435\u0444\u0435\u0440\u0435\u043D\u0442\u0443 \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442
    \u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u044B\u043C. \u042D\u0442\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \"\u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435\",
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043E\u0442\u0445\u043E\u0434
    \u043E\u0442 \u0430\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u0435\u0432\u0441\u043A\u0438\u0445
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u043E\u0432, \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E
    \u0441 \u0432\u044B\u0441\u043E\u043A\u043E\u0439 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u043F\u043B\u0430\u043D\u0435\u0442,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \xAB\u0441\u0442\u0440\u043E\u043F\u0442\u0438\u0432\u043E\u0433\u043E\xBB
    \u041C\u0430\u0440\u0441\u0430.  ### \U0001F30D \xAB\u0413\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u044F\xBB:
    \u0421\u0432\u043E\u0434 \u0437\u043D\u0430\u043D\u0438\u0439 \u043E \u0417\u0435\u043C\u043B\u0435 
    \u041F\u043E\u043B\u043D\u043E\u0435 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435
    \u2014 \xAB\u0413\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\xBB \u0432
    8 \u043A\u043D\u0438\u0433\u0430\u0445. \u042D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434
    \u0441\u0442\u0430\u043B \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u043C
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u043C \u043F\u043E \u043A\u0430\u0440\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u0432\u043F\u043B\u043E\u0442\u044C \u0434\u043E \u044D\u043F\u043E\u0445\u0438
    \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F. \u041D\u0430
    \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435, \u0434\u043E\u0448\u0435\u0434\u0448\u0438\u0439
    \u0434\u043E \u043D\u0430\u0441 \u0442\u0435\u043A\u0441\u0442 \u0432\u044B\u0437\u044B\u0432\u0430\u0435\u0442
    \u0441\u043F\u043E\u0440\u044B \u0443 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432,
    \u0438 \u043C\u043D\u043E\u0433\u0438\u0435 \u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0442,
    \u0447\u0442\u043E \u043C\u044B \u0438\u043C\u0435\u0435\u043C \u0434\u0435\u043B\u043E
    \u0441 \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0435\u0439
    \u043A\u043E\u043C\u043F\u0438\u043B\u044F\u0446\u0438\u0435\u0439, \u043E\u0434\u043D\u0430\u043A\u043E
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0441\u043D\u043E\u0432\u044B \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E
    \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u0442 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044E. 
    *   **\u041A\u043D\u0438\u0433\u0430 I**: \u0421\u043E\u0434\u0435\u0440\u0436\u0438\u0442
    \u043A\u0440\u0438\u0442\u0438\u043A\u0443 \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    (\u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u041C\u0430\u0440\u0438\u043D\u0430
    \u0422\u0438\u0440\u0441\u043A\u043E\u0433\u043E) \u0438 \u0438\u0437\u043B\u0430\u0433\u0430\u0435\u0442
    **\u043F\u0440\u0438\u043D\u0446\u0438\u043F\u044B \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F
    \u043A\u0430\u0440\u0442**. \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u0435\u0442 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
    \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B (\u0448\u0438\u0440\u043E\u0442\u0443
    \u0438 \u0434\u043E\u043B\u0433\u043E\u0442\u0443) \u0438 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442
    \u0434\u0432\u0435 \u043A\u0430\u0440\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u043E\u0435\u043A\u0446\u0438\u0438: \u043F\u0440\u043E\u0441\u0442\u0443\u044E
    \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0438 \u0431\u043E\u043B\u0435\u0435
    \u0441\u043B\u043E\u0436\u043D\u0443\u044E \u043F\u0441\u0435\u0432\u0434\u043E\u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E.
    *   **\u041A\u043D\u0438\u0433\u0438 II\u2014VII**: \u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0442
    \u0441\u043E\u0431\u043E\u0439 \u0433\u0438\u0433\u0430\u043D\u0442\u0441\u043A\u0438\u0439
    \u0441\u043F\u0438\u0441\u043E\u043A \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442.
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u0442
    \u0448\u0438\u0440\u043E\u0442\u0443 \u0438 \u0434\u043E\u043B\u0433\u043E\u0442\u0443
    \u0434\u043B\u044F **\u043E\u043A\u043E\u043B\u043E 8000 \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0443\u043D\u043A\u0442\u043E\u0432** \u2014 \u043E\u0442 \u0421\u043A\u0430\u043D\u0434\u0438\u043D\u0430\u0432\u0438\u0438
    \u0434\u043E \u0432\u0435\u0440\u0445\u043E\u0432\u044C\u0435\u0432 \u041D\u0438\u043B\u0430
    \u0438 \u043E\u0442 \u0410\u0442\u043B\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u043A\u0435\u0430\u043D\u0430 \u0434\u043E \u0418\u043D\u0434\u043E\u043A\u0438\u0442\u0430\u044F.
    \u0417\u0430 \u043D\u0443\u043B\u0435\u0432\u043E\u0439 \u043C\u0435\u0440\u0438\u0434\u0438\u0430\u043D
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B\u0438\u0441\u044C \u0442\u0430\u043A
    \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u044B\u0435 \u041E\u0441\u0442\u0440\u043E\u0432\u0430
    \u0411\u043B\u0430\u0436\u0435\u043D\u043D\u044B\u0445 (\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u041A\u0430\u043D\u0430\u0440\u0441\u043A\u0438\u0435). *   **\u041A\u043D\u0438\u0433\u0430
    VIII**: \u0421\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u0438\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438
    \u043F\u043E \u0438\u0437\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u0438\u044E
    \u043A\u0430\u0440\u0442 \u0438, \u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0440\u0435\u0434\u0430\u043A\u0446\u0438\u044F\u0445, 26 \u0440\u0435\u0433\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u043A\u0430\u0440\u0442.  **\u0412\u0430\u0436\u043D\u044B\u0439 \u043D\u044E\u0430\u043D\u0441**:
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u043E\u0448\u0438\u0431\u0441\u044F
    \u0432 \u043E\u0446\u0435\u043D\u043A\u0435 \u0440\u0430\u0437\u043C\u0435\u0440\u043E\u0432
    \u0417\u0435\u043C\u043B\u0438, \u043F\u0440\u0435\u0443\u043C\u0435\u043D\u044C\u0448\u0438\u0432
    \u0435\u0451 \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E
    \u0432 1,4 \u0440\u0430\u0437\u0430, \u0438 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u0440\u0435\u0443\u0432\u0435\u043B\u0438\u0447\u0438\u043B \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0410\u0437\u0438\u0438 \u0441 \u0437\u0430\u043F\u0430\u0434\u0430 \u043D\u0430
    \u0432\u043E\u0441\u0442\u043E\u043A. \u0418\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u0430
    \u043E\u0448\u0438\u0431\u043A\u0430, \u043F\u043E \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u0432\u0435\u0440\u0441\u0438\u0439, \u043F\u043E\u0434\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0430
    \u0425\u0440\u0438\u0441\u0442\u043E\u0444\u043E\u0440\u0430 \u041A\u043E\u043B\u0443\u043C\u0431\u0430
    \u043A \u043C\u044B\u0441\u043B\u0438, \u0447\u0442\u043E \u0434\u043E \u0418\u043D\u0434\u0438\u0438
    \u043C\u043E\u0436\u043D\u043E \u0434\u043E\u043F\u043B\u044B\u0442\u044C, \u043F\u043B\u044B\u0432\u044F
    \u043D\u0430 \u0437\u0430\u043F\u0430\u0434.  ### \U0001F52C \xAB\u041E\u043F\u0442\u0438\u043A\u0430\xBB:
    \u0423\u0447\u0435\u043D\u0438\u0435 \u043E \u0441\u0432\u0435\u0442\u0435 \u0438
    \u0437\u0440\u0435\u043D\u0438\u0438  \u0422\u0440\u0430\u043A\u0442\u0430\u0442
    \u0432 \u043F\u044F\u0442\u0438 \u043A\u043D\u0438\u0433\u0430\u0445, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F \u0441\u0447\u0438\u0442\u0430\u043B\u0441\u044F
    \u0443\u0442\u0435\u0440\u044F\u043D\u043D\u044B\u043C, \u043D\u043E \u0431\u044B\u043B
    \u043D\u0430\u0439\u0434\u0435\u043D \u0432 \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u043E\u043C
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0435 \u0432 XIX \u0432\u0435\u043A\u0435. 
    *   **\u0421\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435**: \u0412
    \u044D\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430
    \u0441\u0432\u0435\u0442\u0430. \u041E\u043D \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0435\u0442
    \u0442\u0435\u043E\u0440\u0438\u044E \u0437\u0440\u0435\u043D\u0438\u044F, \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u044F
    \u043B\u0443\u0447\u0438 \u0441\u0432\u0435\u0442\u0430, \u0438\u0434\u0443\u0449\u0438\u043C\u0438
    \u043E\u0442 \u0433\u043B\u0430\u0437\u0430 \u043A \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0443,
    \u0445\u043E\u0442\u044F \u0438 \u043D\u0435 \u043F\u0440\u0438\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u0441\u0442\u0440\u043E\u0433\u043E \u044D\u0442\u043E\u0439 \u0438\u0434\u0435\u0438.
    *   **\u0417\u0430\u043A\u043E\u043D\u044B \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044F**:
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442
    \u0438 \u0443\u0442\u043E\u0447\u043D\u044F\u0435\u0442 \u0437\u0430\u043A\u043E\u043D\u044B
    \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044F \u0441\u0432\u0435\u0442\u0430
    \u043E\u0442 \u043F\u043B\u043E\u0441\u043A\u0438\u0445 \u0438 \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0435\u0440\u043A\u0430\u043B, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435
    \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D \u0415\u0432\u043A\u043B\u0438\u0434\u0430.
    *   **\u041F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u0435 \u0441\u0432\u0435\u0442\u0430**:
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u2014 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u044F
    \u0441\u0432\u0435\u0442\u0430. \u041E\u043D \u043F\u0440\u043E\u0432\u0435\u043B
    \u043E\u043F\u044B\u0442\u044B \u0441 \u0434\u0438\u0441\u043A\u043E\u043C, \u043F\u043E\u0433\u0440\u0443\u0436\u0430\u0435\u043C\u044B\u043C
    \u0432 \u0432\u043E\u0434\u0443, \u0438 \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0442\u0430\u0431\u043B\u0438\u0446\u0443 \u0443\u0433\u043B\u043E\u0432 \u043F\u0430\u0434\u0435\u043D\u0438\u044F
    \u0438 \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u044F \u0434\u043B\u044F
    \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0430 \u0441\u0432\u0435\u0442\u0430
    \u0438\u0437 \u0432\u043E\u0437\u0434\u0443\u0445\u0430 \u0432 \u0432\u043E\u0434\u0443
    \u0438 \u0441\u0442\u0435\u043A\u043B\u043E. \u0425\u043E\u0442\u044F \u0435\u043C\u0443
    \u043D\u0435 \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u0432\u044B\u0432\u0435\u0441\u0442\u0438
    \u0442\u043E\u0447\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0437\u0430\u043A\u043E\u043D (\u044D\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u044E\u0442
    \u0421\u043D\u0435\u043B\u043B\u0438\u0443\u0441 \u0438 \u0414\u0435\u043A\u0430\u0440\u0442
    \u0432 XVII \u0432\u0435\u043A\u0435), \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430
    \u0441\u0442\u0430\u043B\u0430 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u043C
    \u044D\u0442\u0430\u043F\u043E\u043C \u0432 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0438
    \u043E\u043F\u0442\u0438\u043A\u0438.  ### \U0001F4AB \xAB\u0422\u0435\u0442\u0440\u0430\u0431\u0438\u0431\u043B\u043E\u0441\xBB:
    \u041E\u0441\u043D\u043E\u0432\u044B \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u0438 
    \u042D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u0430\u043A \xAB\u0427\u0435\u0442\u0432\u0435\u0440\u043E\u043A\u043D\u0438\u0436\u0438\u0435\xBB,
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0434\u0440\u0435\u0432\u043D\u0435\u0439\u0448\u0438\u043C
    \u0438\u0437 \u0434\u043E\u0448\u0435\u0434\u0448\u0438\u0445 \u0434\u043E \u043D\u0430\u0441
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432 \u043F\u043E \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u0438.
    \u0412 \u043D\u0435\u043C \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439, \u043E\u043F\u0438\u0440\u0430\u044F\u0441\u044C
    \u043D\u0430 \u0430\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E
    \u0444\u0438\u0437\u0438\u043A\u0443, \u0438\u0437\u043B\u0430\u0433\u0430\u0435\u0442
    \u043E\u0441\u043D\u043E\u0432\u044B \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u0438,
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u0443\u044F
    \u0437\u043D\u0430\u043D\u0438\u044F \u043E \u0432\u043B\u0438\u044F\u043D\u0438\u0438
    \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u0445 \u0442\u0435\u043B \u043D\u0430
    \u0437\u0435\u043C\u043D\u044B\u0435 \u0441\u043E\u0431\u044B\u0442\u0438\u044F
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430.  \u042D\u0442\u043E\u0442
    \u0441\u043F\u0438\u0441\u043E\u043A \u0442\u0440\u0443\u0434\u043E\u0432 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442,
    \u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043C
    \u0431\u044B\u043B \u0433\u0435\u043D\u0438\u0439 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F.
    \u041E\u043D \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u0435\u043B\u0435\u043C, \u0430
    \u0432\u0435\u043B\u0438\u043A\u0438\u043C \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C,
    \u0441\u043E\u0437\u0434\u0430\u0432\u0448\u0438\u043C \u0438\u0437 \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0445
    \u0437\u043D\u0430\u043D\u0438\u0439 \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    \u0435\u0434\u0438\u043D\u044B\u0435, \u043B\u043E\u0433\u0438\u0447\u043D\u044B\u0435
    \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0449\u0438\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0442\u0430\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F \u043D\u0430\u0443\u043A\u0438
    \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0435 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F."
  achievementsEn: 
  personalLifeRu: "\u042D\u0442\u043E \u0441\u0430\u043C\u044B\u0439 \u0441\u043B\u043E\u0436\u043D\u044B\u0439
    \u0440\u0430\u0437\u0434\u0435\u043B \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0435\u0433\u043E \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435, \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0441\u0430\u043C\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E
    \u0441\u043A\u0440\u044B\u0442\u0430 \u0437\u0430\u0432\u0435\u0441\u043E\u0439
    \u0442\u0430\u0439\u043D\u044B \u2013 \u043C\u044B \u0437\u043D\u0430\u0435\u043C
    \u043E \u043D\u0435\u043C \u043F\u043E\u0447\u0442\u0438 \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0438\u0437 \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u043A\u043D\u0438\u0433.  ### \U0001F464 \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435,
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u0438\u043C\u044F  \u0422\u043E\u0447\u043D\u0430\u044F
    \u0434\u0430\u0442\u0430 \u0438 \u043C\u0435\u0441\u0442\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u041A\u043B\u0430\u0432\u0434\u0438\u044F \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B. \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u043E\u043A\u043E\u043B\u043E
    **100 \u0433\u043E\u0434\u0430 \u043D. \u044D.** (\u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438 \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    90-\u0439 \u0433\u043E\u0434).  \u0415\u0433\u043E \u043F\u043E\u043B\u043D\u043E\u0435
    \u0438\u043C\u044F \u2014 **\u041A\u043B\u0430\u0432\u0434\u0438\u0439 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439**
    \u2014 \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043E \u0441\u043B\u043E\u0436\u043D\u043E\u043C
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0438:
    *   \u0418\u043C\u044F **\u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439** \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u043D\u0430 \u0435\u0433\u043E \u0433\u0440\u0435\u043A\u043E-\u0435\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0438\u0435
    \u043A\u043E\u0440\u043D\u0438, \u0442\u0430\u043A \u043A\u0430\u043A \u043E\u043D\u043E
    \u0431\u044B\u043B\u043E \u043E\u0447\u0435\u043D\u044C \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u043E
    \u0432 \u0415\u0433\u0438\u043F\u0442\u0435. *   \u0420\u0438\u043C\u0441\u043A\u0438\u0439
    \u0440\u043E\u0434\u043E\u0432\u043E\u0439 \u043D\u043E\u043C\u0435\u043D **\u041A\u043B\u0430\u0432\u0434\u0438\u0439**
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443\u0435\u0442
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u043E\u043D \u0438\u043B\u0438
    \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u043A\u0438 \u0431\u044B\u043B\u0438
    \u0440\u0438\u043C\u0441\u043A\u0438\u043C\u0438 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0430\u043C\u0438.
    \u0412\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u043E
    \u0431\u044B\u043B\u043E \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043E \u043E\u0442
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430 \u041A\u043B\u0430\u0432\u0434\u0438\u044F. 
    \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u043F\u043E\u0437\u0434\u043D\u0435\u0435
    (XIV \u0432\u0435\u043A) \u0438 \u043D\u0435 \u0432\u043F\u043E\u043B\u043D\u0435
    \u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E\u0435 \u0441\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u0435,
    \u0447\u0442\u043E \u043E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0432
    \u0433\u043E\u0440\u043E\u0434\u0435 **\u041F\u0442\u043E\u043B\u0435\u043C\u0430\u0438\u0434\u0430
    \u0413\u0435\u0440\u043C\u0438\u0435\u0432\u0430** \u0432 \u0412\u0435\u0440\u0445\u043D\u0435\u043C
    \u0415\u0433\u0438\u043F\u0442\u0435. \u041D\u0430\u0434\u0435\u0436\u043D\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043B\u0438\u0448\u044C \u0442\u043E,
    \u0447\u0442\u043E **\u0432\u0441\u044F \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0441\u0432\u044F\u0437\u0430\u043D\u0430
    \u0441 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0435\u0439
    \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0439**, \u0433\u0434\u0435
    \u043E\u043D \u0436\u0438\u043B \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B. 
    ### \U0001F3DB\uFE0F \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u043D\u0430\u0447\u0430\u043B\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u043F\u0443\u0442\u0438  \u041E \u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044F\u0445
    \u0438 \u044E\u043D\u044B\u0445 \u0433\u043E\u0434\u0430\u0445 \u043F\u043E\u0447\u0442\u0438
    \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E.
    \u0415\u0441\u0442\u044C \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430, \u0447\u0442\u043E
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F
    \u043C\u043E\u0433 \u0431\u044B\u0442\u044C **\u0422\u0435\u043E\u043D \u0421\u043C\u0438\u0440\u043D\u0441\u043A\u0438\u0439**,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444-\u043F\u043B\u0430\u0442\u043E\u043D\u0438\u043A,
    \u0436\u0438\u0432\u0448\u0438\u0439 \u0432 \u043F\u0435\u0440\u0432\u043E\u0439
    \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0435 II \u0432\u0435\u043A\u0430
    \u043D. \u044D..  \u041A\u043E\u0441\u0432\u0435\u043D\u043D\u044B\u043C \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0438\u0445 \u0441\u0432\u044F\u0437\u0438 \u0441\u043B\u0443\u0436\u0438\u0442
    \u0442\u043E, \u0447\u0442\u043E: *   \u0412 \u0441\u0432\u043E\u0435\u043C \u0433\u043B\u0430\u0432\u043D\u043E\u043C
    \u0442\u0440\u0443\u0434\u0435 \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0435\xBB
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u0441\u0441\u044B\u043B\u0430\u0435\u0442\u0441\u044F
    \u043D\u0430 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F, \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u043D\u044B\u0435
    \xAB\u0422\u0435\u043E\u043D\u043E\u043C-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C\xBB
    \u0432 127\u2013132 \u0433\u043E\u0434\u0430\u0445 \u043D. \u044D.. *   \u0422\u0435\u043E\u043D
    \u0431\u044B\u043B \u0430\u0432\u0442\u043E\u0440\u043E\u043C \u0440\u0430\u0431\u043E\u0442\u044B
    \xAB\u0418\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u0432, \u043F\u043E\u043B\u0435\u0437\u043D\u044B\u0445
    \u043F\u0440\u0438 \u0447\u0442\u0435\u043D\u0438\u0438 \u041F\u043B\u0430\u0442\u043E\u043D\u0430\xBB
    \u2014 \u0441\u0432\u043E\u0435\u0433\u043E \u0440\u043E\u0434\u0430 \u0432\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u0432 \u043D\u0430\u0443\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0442 \u043E\u0441\u043D\u043E\u0432\u0443
    \u0437\u043D\u0430\u043D\u0438\u0439 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F. 
    \u0421\u0430\u043C \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u0432 \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0435\xBB
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442 \u043D\u0435\u043A\u043E\u0435\u0433\u043E
    **\u0421\u0438\u0440\u0430**, \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u043E\u043D \u043F\u043E\u0441\u0432\u044F\u0449\u0430\u0435\u0442 \u0441\u0432\u043E\u0439
    \u0442\u0440\u0443\u0434, \u043D\u043E \u043A\u0442\u043E \u044D\u0442\u043E
    \u0431\u044B\u043B \u2014 \u0434\u0440\u0443\u0433, \u043A\u043E\u043B\u043B\u0435\u0433\u0430
    \u0438\u043B\u0438 \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A \u2014 \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F
    \u0437\u0430\u0433\u0430\u0434\u043A\u043E\u0439.  ### \U0001F3D9\uFE0F \u0420\u0430\u0431\u043E\u0442\u0430
    \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438  \u0426\u0435\u043D\u0442\u0440\u043E\u043C
    \u0436\u0438\u0437\u043D\u0438 \u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F
    \u0431\u044B\u043B\u0430 **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u044F
    \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0430\u044F** \u2014 \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u0439
    \u0446\u0435\u043D\u0442\u0440 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430. \u041F\u0435\u0440\u0438\u043E\u0434 \u0435\u0433\u043E
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438 \u0442\u043E\u0447\u043D\u043E
    \u0437\u0430\u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D
    \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F\u043C\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u043D \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B \u0441 **127 \u043F\u043E
    151 \u0433\u043E\u0434 \u043D. \u044D.**.  \u0414\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u043D, \u043D\u0435\u0441\u043E\u043C\u043D\u0435\u043D\u043D\u043E, \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u0444\u043E\u043D\u0434\u0430\u043C\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0438** (\u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u0447\u0430\u0441\u0442\u044C\u044E \u041C\u0443\u0441\u0435\u0439\u043E\u043D\u0430
    \u2014 \u0445\u0440\u0430\u043C\u0430 \u043C\u0443\u0437), \u0433\u0434\u0435,
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0443 \u043D\u0435\u0433\u043E
    \u0441\u043B\u043E\u0436\u0438\u043B\u0438\u0441\u044C \u0440\u0430\u0431\u043E\u0447\u0438\u0435
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u0430\u043C\u0438,
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u0432\u0448\u0438\u043C\u0438
    \u0435\u043C\u0443 \u0434\u043E\u0441\u0442\u0443\u043F \u043A \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0435.
    \u0411\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0430 \u0432 \u0442\u043E
    \u0432\u0440\u0435\u043C\u044F \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u043C
    \u0441\u0435\u0440\u0434\u0446\u0435\u043C \u0438\u043C\u043F\u0435\u0440\u0438\u0438,
    \u0438 \u043E\u043D \u043C\u043E\u0433 \u0431\u0435\u0441\u043F\u0440\u0435\u043F\u044F\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u0442\u0440\u0443\u0434\u044B \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432:
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430, \u0413\u0438\u043F\u043F\u0430\u0440\u0445\u0430,
    \u0410\u043F\u043E\u043B\u043B\u043E\u043D\u0438\u044F \u041F\u0435\u0440\u0433\u0441\u043A\u043E\u0433\u043E. 
    ### \U0001F9D1\u200D\U0001F91D\u200D\U0001F9D1 \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438 
    **\u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438.**
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u0431\u044B\u043B \u043D\u0435
    \u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043F\u0435\u0440\u0432\u043E\u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0442\u0435\u043B\u0435\u043C,
    \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0432\u0435\u043B\u0438\u043A\u0438\u043C
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    (\xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\xBB, \xAB\u0413\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u044F\xBB)
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u044B \u043D\u0430 \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u043A\u0435
    \u0437\u043D\u0430\u043D\u0438\u0439 \u043F\u0440\u043E\u0448\u043B\u043E\u0433\u043E.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0437\u0432\u0435\u0437\u0434\u043D\u044B\u0439 \u043A\u0430\u0442\u0430\u043B\u043E\u0433
    \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C \u043E\u0441\u043D\u043E\u0432\u0430\u043D
    \u043D\u0430 \u0442\u0440\u0443\u0434\u0430\u0445 **\u0413\u0438\u043F\u043F\u0430\u0440\u0445\u0430
    \u041D\u0438\u043A\u0435\u0439\u0441\u043A\u043E\u0433\u043E** (II \u0432\u0435\u043A
    \u0434\u043E \u043D. \u044D.), \u0430 \u0442\u0435\u043E\u0440\u0438\u044F \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442 \u2014 \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    **\u0410\u043F\u043E\u043B\u043B\u043E\u043D\u0438\u044F \u041F\u0435\u0440\u0433\u0441\u043A\u043E\u0433\u043E**.
    \u041E\u043D \u043D\u0435 \u0432\u0441\u0435\u0433\u0434\u0430 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u043B
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438, \u0447\u0442\u043E \u0432
    \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u0430
    \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u043E \u0441\u043F\u043E\u0440\u044B
    \u043E \u043F\u043B\u0430\u0433\u0438\u0430\u0442\u0435.  **\u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438.**
    \u0412 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442\u0430\u0445 \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u043D\u0435\u0442 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0438\u043A\u0430\u043A\u0438\u0445 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0439
    \u043E \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0435. \u042D\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u0435\u0442
    \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u0438\u0435, \u0447\u0442\u043E
    \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438, \u043D\u0435 \u0443\u0447\u0430\u0441\u0442\u0432\u0443\u044F
    \u0432 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u044B\u0445 \u0434\u0438\u0441\u043F\u0443\u0442\u0430\u0445,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0431\u044B\u043B\u0438 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u044B
    \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438. \u041C\u044B
    \u0437\u043D\u0430\u0435\u043C \u043E \u043D\u0435\u043C \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E \u0435\u0433\u043E \u043A\u043D\u0438\u0433\u0430\u043C, \u0430
    \u043D\u0435 \u043F\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C
    \u043E\u0447\u0435\u0432\u0438\u0434\u0446\u0435\u0432.  ### \u26B0\uFE0F \u0421\u043C\u0435\u0440\u0442\u044C 
    \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E \u041A\u043B\u0430\u0432\u0434\u0438\u0439
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u0443\u043C\u0435\u0440 \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E
    \u0432 **170 \u0433\u043E\u0434\u0443 \u043D. \u044D.** (\u043F\u043E \u0434\u0440\u0443\u0433\u0438\u043C
    \u043E\u0446\u0435\u043D\u043A\u0430\u043C, \u0432 165-\u043C), \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u043E\u043A\u043E\u043B\u043E 70 \u043B\u0435\u0442.  \u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u043E \u043F\u0440\u0438\u0447\u0438\u043D\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u043D\u0430 **\u044D\u043F\u0438\u0434\u0435\u043C\u0438\u044E
    \u0447\u0443\u043C\u044B**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0432
    \u0442\u0435 \u0433\u043E\u0434\u044B \u043E\u0445\u0432\u0430\u0442\u0438\u043B\u0430
    \u0415\u0433\u0438\u043F\u0435\u0442, \u0410\u0437\u0438\u044E \u0438 \u0415\u0432\u0440\u043E\u043F\u0443.
    \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0438\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u0430 \u0431\u043E\u043B\u0435\u0437\u043D\u044C \u043E\u0431\u043E\u0440\u0432\u0430\u043B\u0430
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C, \u0445\u043E\u0442\u044F \u0442\u043E\u0447\u043D\u044B\u0445
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0439
    \u044D\u0442\u043E\u043C\u0443 \u043D\u0435\u0442.  \u0412 \u0438\u0442\u043E\u0433\u0435,
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0433\u0435\u043D\u0438\u044F,
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C \u0432 \u0442\u0435\u043D\u0438
    \u0435\u0433\u043E \u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432. \u041C\u044B \u043C\u043E\u0436\u0435\u043C
    \u043B\u0438\u0448\u044C \u0441\u0442\u0440\u043E\u0438\u0442\u044C \u0434\u043E\u0433\u0430\u0434\u043A\u0438
    \u043E \u0435\u0433\u043E \u0447\u0430\u0441\u0442\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438,
    \u043D\u043E \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u0441\u0430\u043C\u043E \u0437\u0430
    \u0441\u0435\u0431\u044F."
  personalLifeEn: 
  shortBioRu: "\u041A\u043B\u0430\u0432\u0434\u0438\u0439 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u2014 \u043E\u0434\u043D\u0430 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445,
    \u043D\u043E \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u0441\u0430\u043C\u044B\u0445
    \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u044B\u0445 \u0444\u0438\u0433\u0443\u0440
    \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0439 \u043D\u0430\u0443\u043A\u0438.
    \u041E \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E
    \u0434\u043E \u043E\u0431\u0438\u0434\u043D\u043E\u0433\u043E \u043C\u0430\u043B\u043E,
    \u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u043E\u043C
    \u0434\u043B\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u0447\u044C\u0438
    \u0442\u0440\u0443\u0434\u044B \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u043B\u0438
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u0438 \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u043D\u0430 \u0446\u0435\u043B\u044B\u0445
    \u043F\u043E\u043B\u0442\u043E\u0440\u044B \u0442\u044B\u0441\u044F\u0447\u0438
    \u043B\u0435\u0442.  ### \u23F3 \u0416\u0438\u0437\u043D\u044C, \u043E\u043A\u0443\u0442\u0430\u043D\u043D\u0430\u044F
    \u0442\u0430\u0439\u043D\u043E\u0439: \u0444\u0430\u043A\u0442\u044B \u0438 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B 
    \u0413\u043B\u0430\u0432\u043D\u0430\u044F \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u043D\u0430\u0448\u0438 \u0437\u043D\u0430\u043D\u0438\u044F
    \u043E \u043D\u0435\u043C \u043F\u043E\u0447\u0442\u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0447\u0435\u0440\u043F\u043D\u0443\u0442\u044B \u0438\u0437 \u0435\u0433\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445 \u0440\u0430\u0431\u043E\u0442.
    \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043B\u0438 \u0435\u0433\u043E
    \u0432 \u0441\u0432\u043E\u0438\u0445 \u0442\u0440\u0443\u0434\u0430\u0445, \u0438
    \u043D\u0438\u043A\u0430\u043A\u0438\u0445 \u0434\u0440\u0443\u0433\u0438\u0445
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u044B\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u0432
    \u043E \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438 \u043D\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C. 
    *   **\u0418\u043C\u044F \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435**.
    \u0415\u0433\u043E \u043F\u043E\u043B\u043D\u043E\u0435 \u0438\u043C\u044F \u2014
    **\u041A\u043B\u0430\u0432\u0434\u0438\u0439 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439**
    \u2014 \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043E \u0441\u043B\u043E\u0436\u043D\u043E\u043C
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0438.
    \u0418\u043C\u044F **\u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439** \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u043D\u0430 \u0435\u0433\u043E \u0433\u0440\u0435\u043A\u043E-\u0435\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0438\u0435
    \u043A\u043E\u0440\u043D\u0438, \u0442\u0430\u043A \u043A\u0430\u043A \u043E\u043D\u043E
    \u0431\u044B\u043B\u043E \u043E\u0447\u0435\u043D\u044C \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E
    \u0432 \u0415\u0433\u0438\u043F\u0442\u0435. \u0420\u0438\u043C\u0441\u043A\u0438\u0439
    \u0440\u043E\u0434\u043E\u0432\u043E\u0439 \u043D\u043E\u043C\u0435\u043D **\u041A\u043B\u0430\u0432\u0434\u0438\u0439**
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443\u0435\u0442
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u043E\u043D \u0438\u043B\u0438
    \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u043A\u0438 \u0431\u044B\u043B\u0438
    \u0440\u0438\u043C\u0441\u043A\u0438\u043C\u0438 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0430\u043C\u0438.
    \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u043E
    \u043C\u043E\u0433 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u043A\u043E\u0432 \u043E\u0442
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430 \u041A\u043B\u0430\u0432\u0434\u0438\u044F.
    *   **\u0413\u043E\u0434\u044B \u0436\u0438\u0437\u043D\u0438**. \u041F\u0440\u0438\u043D\u044F\u0442\u043E
    \u0441\u0447\u0438\u0442\u0430\u0442\u044C, \u0447\u0442\u043E \u043E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u043E\u043A\u043E\u043B\u043E **100 \u0433\u043E\u0434\u0430 \u043D.\u044D.**,
    \u0430 \u0443\u043C\u0435\u0440 \u043E\u043A\u043E\u043B\u043E **170 \u0433\u043E\u0434\u0430
    \u043D.\u044D.**. \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438
    \u0440\u0430\u0441\u0448\u0438\u0440\u044F\u044E\u0442 \u044D\u0442\u0438 \u0440\u0430\u043C\u043A\u0438
    \u0434\u043E 90\u2013168 \u0433\u0433. \u043D.\u044D.. \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0434\u0430\u0442\u044B \u0435\u0433\u043E \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u044B \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0437\u0430\u043F\u0438\u0441\u044F\u043C: \u043E\u043D \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
