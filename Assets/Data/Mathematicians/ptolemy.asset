  shortBioRu: "\u041A\u043B\u0430\u0301\u0432\u0434\u0438\u0439 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0301\u0439\_\u2014
    \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u0439 \u0443\u0447\u0451\u043D\u044B\u0439
    \u0433\u0440\u0435\u043A\u043E-\u0435\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F;
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0433\u0435\u043E\u0433\u0440\u0430\u0444, \u043C\u0435\u0445\u0430\u043D\u0438\u043A,
    \u043E\u043F\u0442\u0438\u043A \u0438 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A
    \u043C\u0443\u0437\u044B\u043A\u0438. \u0416\u0438\u043B \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438 \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0439,
    \u0433\u0434\u0435 \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F."
