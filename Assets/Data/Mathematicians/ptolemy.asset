    \u0441 127 \u043F\u043E 151 \u0433\u043E\u0434 \u043D.\u044D.**. *   **\u041C\u0435\u0441\u0442\u043E
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F**. \u0422\u043E\u0447\u043D\u043E\u0435
    \u043C\u0435\u0441\u0442\u043E \u0435\u0433\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E. \u0412\u0438\u0437\u0430\u043D\u0442\u0438\u0439\u0441\u043A\u0438\u0439
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C XIV \u0432\u0435\u043A\u0430
    \u0424\u0435\u043E\u0434\u043E\u0440 \u041C\u0435\u043B\u0438\u0442\u0435\u043D\u0438\u043E\u0442
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0432 \u0433\u043E\u0440\u043E\u0434\u0435
    **\u041F\u0442\u043E\u043B\u0435\u043C\u0430\u0438\u0434\u0430 \u0413\u0435\u0440\u043C\u0438\u0435\u0432\u0430**
    \u0432 \u0412\u0435\u0440\u0445\u043D\u0435\u043C \u0415\u0433\u0438\u043F\u0442\u0435,
    \u043D\u043E \u044D\u0442\u0430 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F
