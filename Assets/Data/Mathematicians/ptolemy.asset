    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043D\u0435\u043A\u0438\u0439 \u0421\u0438\u0440, \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u0432\u043E\u0438
    \u0440\u0430\u043D\u043D\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u044B.  ###
    \U0001F4DA \u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435:
    \u0442\u0440\u0443\u0434\u044B, \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0438\u0435
    \u043C\u0438\u0440  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430
    \u0441\u043A\u0443\u0434\u043E\u0441\u0442\u044C \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u0430\u043D\u043D\u044B\u0445, \u0434\u043E \u043D\u0430\u0441 \u0434\u043E\u0448\u043B\u043E
    \u0431\u043E\u043B\u044C\u0448\u043E\u0435 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u043E\u0432, \u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439 \u0443\u0434\u0430\u0447\u0435\u0439.
    \u0412 \u043D\u0438\u0445 \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0435\u0442
    \u043A\u0430\u043A \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0430\u0442\u043E\u0440
    \u0438 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0441\u0443\u043C\u0435\u0432\u0448\u0438\u0439 \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C
    \u0438 \u0440\u0430\u0437\u0432\u0438\u0442\u044C \u0437\u043D\u0430\u043D\u0438\u044F
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432. 
    *   **\xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\xBB** \u2014
    \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434 \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u0438. \u041F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0435
    \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \u2014 \xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0435 \u0432 13 \u043A\u043D\u0438\u0433\u0430\u0445\xBB.
    \u041F\u043E\u0437\u0436\u0435 \u0435\u0433\u043E \u0441\u0442\u0430\u043B\u0438
    \u043D\u0430\u0437\u044B\u0432\u0430\u0442\u044C \xAB\u0412\u0435\u043B\u0438\u043A\u0438\u043C\xBB
    (\xAB\u041C\u0435\u0433\u0438\u0441\u0442\u0435\xBB), \u0430 \u0430\u0440\u0430\u0431\u044B,
    \u0447\u0435\u0439 \u043F\u0435\u0440\u0435\u0432\u043E\u0434 \u043F\u043E\u043F\u0430\u043B
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0443, \u0442\u0440\u0430\u043D\u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u044D\u0442\u043E \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \u0432 **\xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\xBB**.    
    *   **\u0421\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435**: \u042D\u0442\u043E
    \u0432\u0441\u0435\u043E\u0431\u044A\u0435\u043C\u043B\u044E\u0449\u0430\u044F
    \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u043D\u0430\u043D\u0438\u0439 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430. \u0412 \u043D\u0435\u0439 \u0438\u0437\u043B\u0430\u0433\u0430\u0435\u0442\u0441\u044F
    **\u0433\u0435\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u043C\u0438\u0440\u0430**, \u0433\u0434\u0435
    \u0432 \u0446\u0435\u043D\u0442\u0440\u0435 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u0430\u044F \u0417\u0435\u043C\u043B\u044F,
    \u0430 \u0432\u0441\u0435 \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u0435 \u0442\u0435\u043B\u0430
    \u0432\u0440\u0430\u0449\u0430\u044E\u0442\u0441\u044F \u0432\u043E\u043A\u0440\u0443\u0433
    \u043D\u0435\u0435 \u043F\u043E \u0441\u043B\u043E\u0436\u043D\u044B\u043C \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0446\u0438\u044F\u043C
    \u043A\u0440\u0443\u0433\u043E\u0432\u044B\u0445 \u043E\u0440\u0431\u0438\u0442
    (\u044D\u043F\u0438\u0446\u0438\u043A\u043B\u044B \u0438 \u0434\u0435\u0444\u0435\u0440\u0435\u043D\u0442\u044B).
    \u042D\u0442\u0430 \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u0431\u044B\u043B\u0430
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0442\u043E\u0447\u043D\u0430
    \u0434\u043B\u044F \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438,
    \u0447\u0442\u043E \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u0432\u043F\u043B\u043E\u0442\u044C \u0434\u043E XVI \u0432\u0435\u043A\u0430,
    \u043F\u043E\u043A\u0430 \u043D\u0435 \u0431\u044B\u043B\u0430 \u0437\u0430\u043C\u0435\u043D\u0435\u043D\u0430
    \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439 \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430.    
    *   **\u0417\u0432\u0451\u0437\u0434\u043D\u044B\u0439 \u043A\u0430\u0442\u0430\u043B\u043E\u0433**:
    \u0412\u043A\u043B\u044E\u0447\u0430\u0435\u0442 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    **48 \u0441\u043E\u0437\u0432\u0435\u0437\u0434\u0438\u0439** \u0438 \u0431\u043E\u043B\u0435\u0435
    1000 \u0437\u0432\u0435\u0437\u0434, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u043D \u043C\u043E\u0433 \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u044C
    \u0438\u0437 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438.
    \u042D\u0442\u043E\u0442 \u043A\u0430\u0442\u0430\u043B\u043E\u0433 \u0441\u0442\u0430\u043B
    \u0434\u0440\u0435\u0432\u043D\u0435\u0439\u0448\u0438\u043C \u0438\u0437 \u0434\u043E\u0448\u0435\u0434\u0448\u0438\u0445
    \u0434\u043E \u043D\u0430\u0441 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0445
    \u0437\u0432\u0435\u0437\u0434\u043D\u044B\u0445 \u043A\u0430\u0442\u0430\u043B\u043E\u0433\u043E\u0432.
    *   **\xAB\u0413\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u044F\xBB** \u2014
    \u0435\u0449\u0435 \u043E\u0434\u0438\u043D \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u0432 8 \u043A\u043D\u0438\u0433\u0430\u0445. \u042D\u0442\u043E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u0437\u0435\u043C\u0435\u043B\u044C, \u0430 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u043E **\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u0430\u0440\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438**.     *  
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u043C\u0435\u0442\u043E\u0434\u044B \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F
    \u043A\u0430\u0440\u0442 \u0441 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442 (\u0448\u0438\u0440\u043E\u0442\u044B
    \u0438 \u0434\u043E\u043B\u0433\u043E\u0442\u044B) \u0438 \u043F\u0440\u0438\u0432\u0435\u043B
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B \u0434\u043B\u044F
    \u0442\u044B\u0441\u044F\u0447 \u043C\u0435\u0441\u0442 \u043E\u0442 \u0411\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u0438\u0445
    \u043E\u0441\u0442\u0440\u043E\u0432\u043E\u0432 \u0434\u043E \u0418\u043D\u0434\u043E\u043A\u0438\u0442\u0430\u044F.    
    *   **\u0418\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u0440\u043E\u043D\u0438\u044F**: \u0415\u0433\u043E \u043A\u0430\u0440\u0442\u0430
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0430 \u043E\u0448\u0438\u0431\u043A\u0443
    \u2014 \u043E\u043D \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u0440\u0435\u0443\u0432\u0435\u043B\u0438\u0447\u0438\u043B \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0410\u0437\u0438\u0438 \u0441 \u0437\u0430\u043F\u0430\u0434\u0430 \u043D\u0430
    \u0432\u043E\u0441\u0442\u043E\u043A. \u0418\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u0430
    \u043E\u0448\u0438\u0431\u043A\u0430, \u043F\u043E \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u0432\u0435\u0440\u0441\u0438\u0439, \u043F\u043E\u0434\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0430
    \u0425\u0440\u0438\u0441\u0442\u043E\u0444\u043E\u0440\u0430 \u041A\u043E\u043B\u0443\u043C\u0431\u0430
    \u043A \u043C\u044B\u0441\u043B\u0438, \u0447\u0442\u043E \u0434\u043E \u0418\u043D\u0434\u0438\u0438
    \u043C\u043E\u0436\u043D\u043E \u0434\u043E\u043F\u043B\u044B\u0442\u044C, \u043F\u043B\u044B\u0432\u044F
    \u043D\u0430 \u0437\u0430\u043F\u0430\u0434, \u0447\u0442\u043E \u0432 \u0438\u0442\u043E\u0433\u0435
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044E
    \u0410\u043C\u0435\u0440\u0438\u043A\u0438. *   **\u0414\u0440\u0443\u0433\u0438\u0435
    \u0432\u0430\u0436\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B**:     *  
    **\xAB\u041E\u043F\u0442\u0438\u043A\u0430\xBB** \u2014 \u043E\u0434\u043D\u043E
    \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439,
    \u0433\u0434\u0435 \u0431\u044B\u043B\u0438 \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u044B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043F\u0442\u0438\u043A\u0438, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0437\u0430\u043A\u043E\u043D\u044B \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u044F
    \u0441\u0432\u0435\u0442\u0430.     *   **\xAB\u0422\u0435\u0442\u0440\u0430\u0431\u0438\u0431\u043B\u043E\u0441\xBB
    (\xAB\u0427\u0435\u0442\u0432\u0435\u0440\u043E\u043A\u043D\u0438\u0436\u0438\u0435\xBB)**
    \u2014 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A \u043F\u043E \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u044C\u044E
    \u0432 \u0421\u0440\u0435\u0434\u043D\u0438\u0435 \u0432\u0435\u043A\u0430.    
    *   **\xAB\u0413\u0430\u0440\u043C\u043E\u043D\u0438\u043A\u0430\xBB** \u2014
    \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0435 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u0443\u0437\u044B\u043A\u0438, \u0433\u0434\u0435 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043F\u0440\u0438\u043C\u0438\u0440\u0438\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0438
    \u0441 \u0434\u0430\u043D\u043D\u044B\u043C\u0438 \u0447\u0443\u0432\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u044F.  ### \u2696\uFE0F
    \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0438 \u0441\u043F\u043E\u0440\u044B 
    \u041A\u043B\u0430\u0432\u0434\u0438\u0439 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F
    \u0444\u0438\u0433\u0443\u0440\u043E\u0439, \u0432\u044B\u0437\u044B\u0432\u0430\u044E\u0449\u0435\u0439
    \u0433\u043E\u0440\u044F\u0447\u0438\u0435 \u0441\u043F\u043E\u0440\u044B. \u0421
    \u043E\u0434\u043D\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B, \u0435\u0433\u043E
    \u0433\u0435\u043D\u0438\u0439 \u043A\u0430\u043A \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0430\u0442\u043E\u0440\u0430
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u043D\u0435\u043E\u0441\u043F\u043E\u0440\u0438\u043C.
    \u0421 \u0434\u0440\u0443\u0433\u043E\u0439, \u0435\u0433\u043E \u043E\u0431\u0432\u0438\u043D\u044F\u044E\u0442
    \u0432 \u043F\u043B\u0430\u0433\u0438\u0430\u0442\u0435 \u0438 \u0434\u0430\u0436\u0435
    \u0444\u0430\u043B\u044C\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0438
    \u0434\u0430\u043D\u043D\u044B\u0445, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u0437\u0430 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0431\u0435\u0437 \u0441\u0441\u044B\u043B\u043E\u043A \u043A\u0430\u0442\u0430\u043B\u043E\u0433\u0430
    \u0413\u0438\u043F\u043F\u0430\u0440\u0445\u0430 \u0438 \u043F\u043E\u0434\u0433\u043E\u043D\u043A\u0443
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u0439 \u043F\u043E\u0434
    \u0441\u0432\u043E\u0438 \u0442\u0435\u043E\u0440\u0438\u0438. \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0438,
    \u043E\u0434\u043D\u0430\u043A\u043E, \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F
    \u043A \u044D\u0442\u043E\u043C\u0443 \u0431\u043E\u043B\u0435\u0435 \u0441\u0431\u0430\u043B\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E,
    \u0432\u0438\u0434\u044F \u0432 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    \u043F\u0440\u0435\u0436\u0434\u0435 \u0432\u0441\u0435\u0433\u043E \u0432\u0435\u043B\u0438\u043A\u0438\u0439
    \u0441\u0432\u043E\u0434 \u0437\u043D\u0430\u043D\u0438\u0439, \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u0432\u0448\u0438\u0439
    \u044D\u043F\u043E\u0445\u0443 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430\u0443\u043A\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u041A\u043B\u0430\u0432\u0434\u0438\u044F
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F, \u0445\u043E\u0442\u044C \u0438
    \u043E\u043A\u0443\u0442\u0430\u043D\u0430 \u0442\u0430\u0439\u043D\u043E\u0439,
    \u043F\u043E\u043B\u043D\u0430 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0434\u0435\u0442\u0430\u043B\u0435\u0439, \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u0432
    \u0438 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u0435\u043B\u0430\u044E\u0442 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E
    \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435 \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0435\u0439.
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0438\u0437 \u043D\u0438\u0445.  ### \U0001F575\uFE0F\u200D\u2642\uFE0F \u0427\u0435\u043B\u043E\u0432\u0435\u043A-\u0437\u0430\u0433\u0430\u0434\u043A\u0430:
    \u0438\u043C\u044F \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435 
    \u0421\u0430\u043C\u0430 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F
    \u2014 \u044D\u0442\u043E \u0433\u043E\u043B\u043E\u0432\u043E\u043B\u043E\u043C\u043A\u0430.
    \u0415\u0433\u043E \u043F\u043E\u043B\u043D\u043E\u0435 \u0438\u043C\u044F, **\u041A\u043B\u0430\u0432\u0434\u0438\u0439
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439**, \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    \u0441\u043E\u0431\u043E\u0439 \u043F\u0440\u0438\u0447\u0443\u0434\u043B\u0438\u0432\u0443\u044E
    \u0441\u043C\u0435\u0441\u044C \u043A\u0443\u043B\u044C\u0442\u0443\u0440.  *  
    **\u0413\u0440\u0435\u043A\u043E-\u0435\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0438\u0435
    \u043A\u043E\u0440\u043D\u0438**: \u0418\u043C\u044F **\u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439**
    \u0431\u044B\u043B\u043E \u043E\u0447\u0435\u043D\u044C \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u043E
    \u0432 \u0415\u0433\u0438\u043F\u0442\u0435, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0441\u0440\u0435\u0434\u0438 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0439
    \u0437\u043D\u0430\u0442\u0438, \u0438 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u043D\u0430 \u0435\u0433\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438\u0437 \u044D\u0442\u043E\u0439 \u0441\u0440\u0435\u0434\u044B. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u0432 \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u0445
    \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445
    \u0435\u0433\u043E \u0438\u043D\u043E\u0433\u0434\u0430 \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    \"\u0412\u0435\u0440\u0445\u043D\u0435\u0435\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0438\u043C\",
    \u0447\u0442\u043E \u043D\u0430\u0432\u043E\u0434\u0438\u0442 \u043D\u0430 \u043C\u044B\u0441\u043B\u044C
    \u043E \u0435\u0433\u043E \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u043C
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0438
    \u0441 \u044E\u0433\u0430 \u0441\u0442\u0440\u0430\u043D\u044B. *   **\u0420\u0438\u043C\u0441\u043A\u043E\u0435
    \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u043E**: \u0418\u043C\u044F
    **\u041A\u043B\u0430\u0432\u0434\u0438\u0439** \u2014 \u0440\u0438\u043C\u0441\u043A\u0438\u0439
    \u0440\u043E\u0434\u043E\u0432\u043E\u0439 \u043D\u043E\u043C\u0435\u043D (nomen).
    \u042D\u0442\u043E \u0437\u043D\u0430\u0447\u0438\u0442, \u0447\u0442\u043E \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u0438\u043B\u0438 \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u043A\u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438
    \u0440\u0438\u043C\u0441\u043A\u043E\u0435 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u043E,
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043E\u0442 \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430
    \u041A\u043B\u0430\u0432\u0434\u0438\u044F. \u042D\u0442\u043E \u0431\u044B\u043B
    \u0437\u043D\u0430\u043A \u0432\u044B\u0441\u043E\u043A\u043E\u0433\u043E \u0441\u0442\u0430\u0442\u0443\u0441\u0430,
    \u043D\u043E \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u0438 \u0442\u0440\u0443\u0434\u044B
    \u043D\u0430 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u043C \u0438 \u0432\u0441\u044E
    \u0436\u0438\u0437\u043D\u044C \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u0415\u0433\u0438\u043F\u0442\u0435.  **\u041A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442**: \u0414\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u043F\u0443\u0442\u0430\u043B\u0438 \u0435\u0433\u043E \u0441 \u0446\u0430\u0440\u0441\u043A\u043E\u0439
    \u0434\u0438\u043D\u0430\u0441\u0442\u0438\u0435\u0439 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0435\u0432,
    \u043F\u0440\u0430\u0432\u0438\u0432\u0448\u0435\u0439 \u0415\u0433\u0438\u043F\u0442\u043E\u043C.
    \u042D\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E \u0438\u0437-\u0437\u0430
    \u0441\u043E\u0432\u043F\u0430\u0434\u0435\u043D\u0438\u044F \u0438\u043C\u0435\u043D\u0438,
    \u043D\u043E \u041A\u043B\u0430\u0432\u0434\u0438\u0439 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    \u043D\u0435 \u0438\u043C\u0435\u043B \u043A \u0444\u0430\u0440\u0430\u043E\u043D\u0430\u043C
    \u043D\u0438\u043A\u0430\u043A\u043E\u0433\u043E \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F. 
    ### \U0001F4D6 \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\xBB:
    \u0432\u0435\u043B\u0438\u0447\u0438\u0435, \u043F\u043B\u0430\u0433\u0438\u0430\u0442
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0434\u0435\u0442\u0435\u043A\u0442\u0438\u0432  \u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F, \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\xBB,
    \u0441\u0430\u043C \u043F\u043E \u0441\u0435\u0431\u0435 \u043F\u043E\u043B\u043E\u043D
    \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0438\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439.  *   **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u044F**: \u041D\u0430\u0437\u0432\u0430\u043D\u0438\u0435
    \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\xBB \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E
    \u043E\u0442 \u0430\u0440\u0430\u0431\u0441\u043A\u043E\u0433\u043E \"\u0430\u043B\u044C-\u041C\u0430\u0434\u0436\u0438\u0441\u0442\u0438\",
    \u0447\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442 \"\u0412\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0439\".
    \u0410\u0440\u0430\u0431\u044B \u0442\u0430\u043A \u043D\u0430\u0437\u0432\u0430\u043B\u0438
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0439 \u0442\u0440\u0443\u0434
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F \xAB\u041C\u0435\u0433\u0438\u0441\u0442\u0435
    \u0421\u0438\u043D\u0442\u0430\u043A\u0441\u0438\u0441\xBB (\xAB\u0412\u0435\u043B\u0438\u043A\u043E\u0435
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435\xBB). \u041F\u043E\u0434
    \u044D\u0442\u0438\u043C \u0438\u043C\u0435\u043D\u0435\u043C \u043E\u043D \u0438
    \u0432\u043E\u0448\u0435\u043B \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E.
    *   **\u041E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u0435 \u0432 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0435\u043C
    \u043D\u0430\u0443\u0447\u043D\u043E\u043C \u043C\u043E\u0448\u0435\u043D\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0435**:
    \u0412 1977 \u0433\u043E\u0434\u0443 \u0432\u044B\u0448\u043B\u0430 \u043D\u0430\u0448\u0443\u043C\u0435\u0432\u0448\u0430\u044F
    \u043A\u043D\u0438\u0433\u0430 \u0444\u0438\u0437\u0438\u043A\u0430 \u0420\u043E\u0431\u0435\u0440\u0442\u0430
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 **\xAB\u041F\u0440\u0435\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0435
    \u041A\u043B\u0430\u0432\u0434\u0438\u044F \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F\xBB**.
    \u0412 \u043D\u0435\u0439 \u041D\u044C\u044E\u0442\u043E\u043D \u0437\u0430\u044F\u0432\u0438\u043B,
    \u0447\u0442\u043E \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u043D\u0435
    \u0431\u044B\u043B \u0432\u0435\u043B\u0438\u043A\u0438\u043C \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C-\u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u0435\u043B\u0435\u043C,
    \u0430 \u0431\u044B\u043B, \u043F\u043E \u0441\u0443\u0442\u0438, **\u0444\u0430\u043B\u044C\u0441\u0438\u0444\u0438\u043A\u0430\u0442\u043E\u0440\u043E\u043C**.
    \u041E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u043D\u0435 \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445 \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u0439,
    \u0430 \u043F\u043E\u0434\u0433\u043E\u043D\u044F\u043B \u0434\u0430\u043D\u043D\u044B\u0435
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    (\u0432 \u043F\u0435\u0440\u0432\u0443\u044E \u043E\u0447\u0435\u0440\u0435\u0434\u044C,
    \u0413\u0438\u043F\u043F\u0430\u0440\u0445\u0430) \u043F\u043E\u0434 \u0441\u0432\u043E\u0438
    \u0442\u0435\u043E\u0440\u0438\u0438. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u041D\u044C\u044E\u0442\u043E\u043D \u0443\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u0435 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0435\u043C
    \u043E\u0441\u0435\u043D\u043D\u0435\u0433\u043E \u0440\u0430\u0432\u043D\u043E\u0434\u0435\u043D\u0441\u0442\u0432\u0438\u044F
    \u0432 132 \u0433\u043E\u0434\u0443 \u043D.\u044D., \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043E\u043D \u043F\u0440\u043E\u0432\u0435\u043B \u0441 \xAB\u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0435\u0439
    \u0442\u0449\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E\xBB,
    \u0431\u044B\u043B\u043E \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u044B\u043C
    \u0431\u043E\u043B\u0435\u0435 \u0447\u0435\u043C \u043D\u0430 \u0434\u0435\u043D\u044C.
    *   **\u0417\u0430\u0449\u0438\u0442\u0430 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F**:
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0433\u0440\u043E\u043C\u043A\u0438\u0435
    \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u044F, \u043C\u043D\u043E\u0433\u0438\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043D\u0430\u0443\u043A\u0438
    \u0432\u0441\u0442\u0430\u043B\u0438 \u043D\u0430 \u0437\u0430\u0449\u0438\u0442\u0443
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F. \u041E\u043D\u0438 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E:     1.  \u0415\u0433\u043E \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\xBB
    \u0431\u044B\u043B **\u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0435\u0439**,
    \u0441\u0431\u043E\u0440\u043D\u0438\u043A\u043E\u043C \u0432\u0441\u0435\u0445
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u0437\u043D\u0430\u043D\u0438\u0439,
    \u0438 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u043D\u0435 \u043E\u0431\u044F\u0437\u0430\u043D
    \u0431\u044B\u043B \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C \u043A\u0430\u0436\u0434\u043E\u0433\u043E
    \u0430\u0432\u0442\u043E\u0440\u0430 \u2014 \u044D\u0442\u043E \u0431\u044B\u043B\u043E
    \u043E\u0431\u044B\u0447\u043D\u043E\u0439 \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u043E\u0439
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.     2. 
    \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435 \u0440\u0430\u0441\u0447\u0435\u0442\u044B
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0438, \u0447\u0442\u043E \u043A\u0430\u0442\u0430\u043B\u043E\u0433
    \u0437\u0432\u0435\u0437\u0434 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0431\u044B\u043B \u043E\u0441\u043D\u043E\u0432\u0430\u043D \u043D\u0430 \u0434\u0430\u043D\u043D\u044B\u0445
    \u0413\u0438\u043F\u043F\u0430\u0440\u0445\u0430, \u043D\u043E \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    **\u043F\u0435\u0440\u0435\u0441\u0447\u0438\u0442\u0430\u043B** \u0438\u0445
    \u0441 \u0443\u0447\u0435\u0442\u043E\u043C \u043F\u0440\u0435\u0446\u0435\u0441\u0441\u0438\u0438
    (\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E\u0433\u043E \u0441\u043C\u0435\u0449\u0435\u043D\u0438\u044F
    \u0437\u0435\u043C\u043D\u043E\u0439 \u043E\u0441\u0438). \u041E\u0448\u0438\u0431\u043A\u0430
    \u0432\u043E\u0437\u043D\u0438\u043A\u043B\u0430 \u0438\u0437-\u0437\u0430 \u0442\u043E\u0433\u043E,
    \u0447\u0442\u043E \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043D\u0435\u0432\u0435\u0440\u043D\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u043F\u0440\u0435\u0446\u0435\u0441\u0441\u0438\u0438. \u0422\u043E \u0435\u0441\u0442\u044C
    \u044D\u0442\u043E \u0431\u044B\u043B\u0430 \u043D\u0435 \u0444\u0430\u043B\u044C\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044F,
    \u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043D\u0435\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C.  **\u0418\u0442\u043E\u0433**:
    \u0412\u043E\u043F\u0440\u043E\u0441 \u043E \xAB\u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0438\xBB
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F \u0442\u0430\u043A \u0438 \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u043C. \u0415\u0433\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u0442\u043E \xAB\u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C \u0434\u0440\u0435\u0432\u043D\u043E\u0441\u0442\u0438\xBB,
    \u0442\u043E \xAB\u0441\u0430\u043C\u044B\u043C \u0443\u0441\u043F\u0435\u0448\u043D\u044B\u043C
    \u043C\u043E\u0448\u0435\u043D\u043D\u0438\u043A\u043E\u043C \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430\u0443\u043A\u0438\xBB.  ### \U0001F30D \u041A\u0430\u0440\u0442\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u0438\u0432\u0435\u043B\u0430
    \u043A \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044E \u0410\u043C\u0435\u0440\u0438\u043A\u0438 
    \u0421\u0430\u043C\u044B\u0439 \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0439
    \u0438 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u043A\u0443\u0440\u044C\u0435\u0437
    \u0441\u0432\u044F\u0437\u0430\u043D \u0441 \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u043E\u043C
    \xAB\u0413\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u044F\xBB.  *   **\u041E\u0448\u0438\u0431\u043A\u0430,
    \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0430\u044F \u043C\u0438\u0440**:
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439, \u043A\u0430\u043A \u0438 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u0435 \u0443\u0447\u0435\u043D\u044B\u0435,
    \u0441\u0438\u043B\u044C\u043D\u043E **\u043F\u0440\u0435\u0443\u043C\u0435\u043D\u044C\u0448\u0438\u043B
    \u0440\u0430\u0437\u043C\u0435\u0440\u044B \u0417\u0435\u043C\u043B\u0438** (\u043F\u043E\u0447\u0442\u0438
    \u043D\u0430 30%) \u0438 **\u043F\u0440\u0435\u0443\u0432\u0435\u043B\u0438\u0447\u0438\u043B
    \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0410\u0437\u0438\u0438 \u0441 \u0437\u0430\u043F\u0430\u0434\u0430 \u043D\u0430
    \u0432\u043E\u0441\u0442\u043E\u043A**. *   \u0412 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435,
    \u043A\u043E\u0433\u0434\u0430 \u0425\u0440\u0438\u0441\u0442\u043E\u0444\u043E\u0440
    \u041A\u043E\u043B\u0443\u043C\u0431 \u0432 1492 \u0433\u043E\u0434\u0443 \u0437\u0430\u0434\u0443\u043C\u0430\u043B
    \u043F\u043B\u044B\u0442\u044C \u0432 \u0418\u043D\u0434\u0438\u044E \u0437\u0430\u043F\u0430\u0434\u043D\u044B\u043C
    \u043F\u0443\u0442\u0435\u043C, \u043E\u043D \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0441\u044F
    \u0438\u043C\u0435\u043D\u043D\u043E \u043A\u0430\u0440\u0442\u043E\u0439 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F.
    \u0415\u0441\u043B\u0438 \u0431\u044B \u043A\u0430\u0440\u0442\u0430 \u0431\u044B\u043B\u0430
    \u0442\u043E\u0447\u043D\u043E\u0439, \u041A\u043E\u043B\u0443\u043C\u0431 \u043F\u043E\u043D\u044F\u043B
    \u0431\u044B, \u0447\u0442\u043E \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u0434\u043E \u0410\u0437\u0438\u0438 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0432\u0435\u043B\u0438\u043A\u043E, \u0438, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u043D\u0435 \u0440\u0438\u0441\u043A\u043D\u0443\u043B \u0431\u044B \u043F\u0443\u0441\u0442\u0438\u0442\u044C\u0441\u044F
    \u0432 \u043F\u043B\u0430\u0432\u0430\u043D\u0438\u0435. \u041C\u043E\u0436\u043D\u043E
    \u0441\u043A\u0430\u0437\u0430\u0442\u044C, \u0447\u0442\u043E \u043E\u0448\u0438\u0431\u043A\u0430
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F \u0441\u0442\u0430\u043B\u0430
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u043F\u0440\u0438\u0447\u0438\u043D
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u041D\u043E\u0432\u043E\u0433\u043E
    \u0421\u0432\u0435\u0442\u0430!.  ### \U0001F4A1 \u0423\u0447\u0435\u043D\u044B\u0439-\u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B
    \u0438 \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C \u043F\u0440\u0438\u0431\u043E\u0440\u043E\u0432 
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u0431\u044B\u043B \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \xAB\u043A\u0430\u0431\u0438\u043D\u0435\u0442\u043D\u044B\u043C\xBB
    \u0443\u0447\u0435\u043D\u044B\u043C. \u041E\u043D \u0431\u044B\u043B \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u0435\u043C
    \u0438 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u0442\u043E\u0440\u043E\u043C: 
    *   \u041E\u043D \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0430\u0432\u0442\u043E\u0440\u043E\u043C
    \u0434\u0432\u0443\u0445 \u0432\u0430\u0436\u043D\u044B\u0445 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432: **\u0430\u0440\u043C\u0438\u043B\u043B\u044F\u0440\u043D\u043E\u0439
    \u0441\u0444\u0435\u0440\u044B** \u0438 **\u0442\u0440\u0438\u043A\u0432\u0435\u0442\u0440\u0430**
    (\u0442\u0440\u043E\u0439\u043D\u043E\u0439 \u0440\u0435\u0439\u043A\u0438),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u0438
    \u0441 \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u0438\u0437\u043C\u0435\u0440\u044F\u0442\u044C \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0437\u0432\u0435\u0437\u0434 \u0438 \u043F\u043B\u0430\u043D\u0435\u0442. *  
    \u0412 \u0441\u0432\u043E\u0435\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 \u043F\u043E
    \u043E\u043F\u0442\u0438\u043A\u0435 \u043E\u043D \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B
    \u043E\u043F\u044B\u0442\u044B \u043F\u043E \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u044E
    \u0441\u0432\u0435\u0442\u0430, \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u0432
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B \u0443\u0433\u043B\u043E\u0432 \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u044F
    \u0434\u043B\u044F \u0432\u043E\u0434\u044B \u0438 \u0441\u0442\u0435\u043A\u043B\u0430,
    \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E
    \u0434\u043B\u044F \u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. 
    ### \u2753 \u0417\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u0430\u044F \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E
    \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E, \u043C\u044B
    \u043D\u0435 \u0437\u043D\u0430\u0435\u043C \u043E \u043D\u0435\u043C \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0438\u0447\u0435\u0433\u043E. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430 \u0434\u0430\u0436\u0435
    \u0442\u043E\u0447\u043D\u0430\u044F \u0434\u0430\u0442\u0430 \u0435\u0433\u043E
    \u0441\u043C\u0435\u0440\u0442\u0438 \u2014 \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u043F\u0435\u0440\u0438\u043E\u0434 \u043C\u0435\u0436\u0434\u0443 161 \u0438
    180 \u0433\u043E\u0434\u0430\u043C\u0438 \u043D.\u044D.. \u0421\u043E\u0437\u0434\u0430\u0435\u0442\u0441\u044F
    \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u0438\u0435, \u0447\u0442\u043E
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0440\u0430\u0441\u0442\u0432\u043E\u0440\u0438\u043B\u0441\u044F \u0432 \u0441\u0432\u043E\u0438\u0445
