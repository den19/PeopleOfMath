    \u0441\u043F\u0443\u0441\u0442\u044F \u0431\u043E\u043B\u0435\u0435 \u0442\u044B\u0441\u044F\u0447\u0438
    \u043B\u0435\u0442 \u0438 \u043D\u0435 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E\u0439. \u041E\u0434\u043D\u0430\u043A\u043E,
    \u0443\u0447\u0438\u0442\u044B\u0432\u0430\u044F \u0435\u0433\u043E \u0438\u043C\u044F,
    \u0432\u043F\u043E\u043B\u043D\u0435 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u0447\u0442\u043E \u043E\u043D \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B
    \u0438\u0437 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0439 \u0441\u0435\u043C\u044C\u0438,
    \u0436\u0438\u0432\u0448\u0435\u0439 \u0432 \u0415\u0433\u0438\u043F\u0442\u0435.
    *   **\u041C\u0435\u0441\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u044B**.
    \u0412\u0441\u044F \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0431\u044B\u043B\u0430
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441 **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0435\u0439
    \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0439** \u2014 \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u043C
    \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430. \u041F\u0440\u0435\u0434\u043F\u043E\u043B\u0430\u0433\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u0444\u043E\u043D\u0434\u0430\u043C\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0438, \u0447\u0442\u043E
    \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0435\u0442 \u0435\u0433\u043E \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u0443\u044E
    \u044D\u0440\u0443\u0434\u0438\u0446\u0438\u044E. \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0443\u043C\u0435\u0440 \u0438 \u0431\u044B\u043B
    \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438.
    *   **\u0423\u0447\u0438\u0442\u0435\u043B\u044F**. \u0425\u043E\u0442\u044F
    \u043E \u043D\u0438\u0445 \u043F\u043E\u0447\u0442\u0438 \u043D\u0438\u0447\u0435\u0433\u043E
