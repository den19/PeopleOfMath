  achievementsRu: "\u0424\u0435\u043B\u0438\u043A\u0441 \u041A\u043B\u0435\u0439\u043D
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0441\u043B\u0435\u0434 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u043D\u0435 \u043E\u0434\u043D\u0438\u043C, \u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u043C\u0438
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u043C\u0438. \u0415\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u0430\u044F \u0437\u0430\u0441\u043B\u0443\u0433\u0430
    \u2014 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0435\u0434\u0438\u043D\u043E\u0439
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438, \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0432\u0448\u0435\u0439
    \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438, \u0430 \u0442\u0430\u043A\u0436\u0435 \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439, \u0430\u043B\u0433\u0435\u0431\u0440\u0435
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0443\u043F\u043F. 
    \u0415\u0433\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0438 \u0438\u0434\u0435\u0438 \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0442\u0430\u043A:  ### \U0001F4DC \xAB\u042D\u0440\u043B\u0430\u043D\u0433\u0435\u043D\u0441\u043A\u0430\u044F
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430\xBB (1872): \u041E\u0431\u044A\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u0435
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0439  \u042D\u0442\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u041A\u043B\u0435\u0439\u043D\u0430. \u0421\u0443\u0442\u044C
    \u0435\u0433\u043E \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u043E\u0439
    \u0438\u0434\u0435\u0438, \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u043D\u043E\u0439
    \u0432 \u0438\u043D\u0430\u0443\u0433\u0443\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u043B\u0435\u043A\u0446\u0438\u0438, \u043F\u0440\u043E\u0441\u0442\u0430 \u0438
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u0430: **\u043B\u044E\u0431\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u2014 \u044D\u0442\u043E,
    \u043F\u043E \u0441\u0443\u0442\u0438, \u0442\u0435\u043E\u0440\u0438\u044F \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432
    (\u0441\u0432\u043E\u0439\u0441\u0442\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0435 \u043C\u0435\u043D\u044F\u044E\u0442\u0441\u044F) \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u044B \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0439.**  
    \u0414\u043E \u041A\u043B\u0435\u0439\u043D\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0431\u043E\u0440\u043E\u043C \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0445
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D. \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E:  *   **\u0415\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F** \u0438\u0437\u0443\u0447\u0430\u0435\u0442
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430, \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043D\u044B\u0435
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0433\u0440\u0443\u043F\u043F\u044B
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0439 (\u043F\u043E\u0432\u043E\u0440\u043E\u0442\u044B,
    \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u044B).  *   **\u0410\u0444\u0444\u0438\u043D\u043D\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F** \u2014 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u044B
    \u0430\u0444\u0444\u0438\u043D\u043D\u044B\u0445 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0439. 
    *   **\u041F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u0430\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F**
    \u2014 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u044B \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0439.  
    \u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432\u0430\u0436\u043D\u043E,
    \u0447\u0442\u043E \u043E\u043D \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B
    \u044D\u0442\u043E\u0442 \u043F\u043E\u0434\u0445\u043E\u0434 \u043A **\u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E**.
    \u041A\u043B\u0435\u0439\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \u043E\u043D\u0430 \u044D\u043A\u0432\u0438\u0432\u0430\u043B\u0435\u043D\u0442\u043D\u0430
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432
    \u0433\u0440\u0443\u043F\u043F\u044B \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0439,
    \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0449\u0438\u0445 \u043D\u0430
    \u043C\u0435\u0441\u0442\u0435 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u0441\u0435\u0447\u0435\u043D\u0438\u0435
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043A\u0440\u0443\u0433).
    \u042D\u0442\u043E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u0440\u043E\u044F\u0441\u043D\u0438\u043B\u043E
    \u0435\u0451 \u043C\u0435\u0441\u0442\u043E \u0441\u0440\u0435\u0434\u0438 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0439, \u043D\u043E \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B\u043E
    \u0435\u0451 \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0441\u0442\u044C.
    \u0421\u0430\u043C\u0430 \u0438\u0434\u0435\u044F \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0438
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0439 \u0447\u0435\u0440\u0435\u0437
    \u0438\u0445 \u0433\u0440\u0443\u043F\u043F\u044B \u043B\u0435\u0433\u043B\u0430
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434\u0430 \u0438 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u043E\u0439 \u0434\u043B\u044F
    \u0444\u0438\u0437\u0438\u043A\u0438, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0434\u043B\u044F \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043F\u043E\u043B\u044F.  ### \U0001F9E9 \u0423\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u043F\u044F\u0442\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u0438
    \u0438\u043A\u043E\u0441\u0430\u044D\u0434\u0440  \u042D\u0442\u043E \u043E\u0434\u043D\u0430
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442 \u041A\u043B\u0435\u0439\u043D\u0430, \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0449\u0430\u044F
    \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u0443\u044E \u0441\u0432\u044F\u0437\u044C
    \u043C\u0435\u0436\u0434\u0443 \u0430\u043B\u0433\u0435\u0431\u0440\u043E\u0439,
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439 \u0438 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u0433\u0440\u0443\u043F\u043F. \u0412 \u0441\u0432\u043E\u0435\u0439 \u043A\u043D\u0438\u0433\u0435
    **\xAB\u041B\u0435\u043A\u0446\u0438\u0438 \u043E\u0431 \u0438\u043A\u043E\u0441\u0430\u044D\u0434\u0440\u0435
    \u0438 \u0440\u0435\u0448\u0435\u043D\u0438\u0438 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u043F\u044F\u0442\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438\xBB**
    (1884)  \u043E\u043D \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0437\u0430\u0434\u0430\u0447\u0443, \u043D\u0430\u0434 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0431\u0438\u043B\u0438\u0441\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F\u043C\u0438: \u043C\u043E\u0436\u043D\u043E
    \u043B\u0438 \u0440\u0435\u0448\u0438\u0442\u044C \u043E\u0431\u0449\u0435\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 5-\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0432 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0430\u0445? (\u041E\u0442\u0432\u0435\u0442:
    \u043D\u0435\u0442, \u044D\u0442\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0410\u0431\u0435\u043B\u044C).  \u041A\u043B\u0435\u0439\u043D \u043F\u043E\u0448\u0451\u043B
    \u0434\u0440\u0443\u0433\u0438\u043C \u043F\u0443\u0442\u0451\u043C. \u041E\u043D
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0433\u0440\u0443\u043F\u043F\u0430
    \u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u0439 \u0438\u043A\u043E\u0441\u0430\u044D\u0434\u0440\u0430
    (\u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E\u0433\u043E \u0434\u0432\u0430\u0434\u0446\u0430\u0442\u0438\u0433\u0440\u0430\u043D\u043D\u0438\u043A\u0430)
    \u0442\u0435\u0441\u043D\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441
    \u043C\u043E\u043D\u043E\u0434\u0440\u043E\u043C\u0438\u0435\u0439 (\u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u044F\u043C\u0438
    \u043A\u043E\u0440\u043D\u0435\u0439) \u043E\u0431\u0449\u0435\u0433\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u043F\u044F\u0442\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438. \u041E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u044D\u0442\u043E\u0433\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u043C\u043E\u0436\u043D\u043E
    \u0432\u044B\u0440\u0430\u0437\u0438\u0442\u044C \u043D\u0435 \u0447\u0435\u0440\u0435\u0437
    \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044B, \u0430 \u0447\u0435\u0440\u0435\u0437
    **\u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438** \u2014 \u0433\u043E\u0440\u0430\u0437\u0434\u043E
    \u0431\u043E\u043B\u0435\u0435 \u0441\u043B\u043E\u0436\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442. \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u2014 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0439 \u043F\u0440\u0438\u043C\u0435\u0440
    \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u043D\u0430\u0433\u043B\u044F\u0434\u043D\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u044F (\u0443\u0432\u0438\u0434\u0435\u043D\u043D\u0430\u044F
    \u0432 \u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u044F\u0445 \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u0430)
    \u043F\u0440\u0438\u0432\u0435\u043B\u0430 \u043A \u0440\u0435\u0448\u0435\u043D\u0438\u044E
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B.  ### \U0001F4D0 \u0422\u0435\u043E\u0440\u0438\u044F
    \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439 
    \u042D\u0442\u043E \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0441\u0442\u0430\u043B\u043E, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0441\u0430\u043C\u044B\u043C \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u043D\u044B\u043C
    \u043F\u0440\u043E\u0435\u043A\u0442\u043E\u043C \u0432 \u0436\u0438\u0437\u043D\u0438
    \u041A\u043B\u0435\u0439\u043D\u0430. \u041E\u043D\u043E \u0441\u0442\u0430\u043B\u043E
    \u043B\u043E\u0433\u0438\u0447\u043D\u044B\u043C \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435\u043C
    \u0438\u0434\u0435\u0439 \xAB\u042D\u0440\u043B\u0430\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u0439
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B\xBB \u0438 \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u043D\u0430\u0434 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435\u043C
    \u043F\u044F\u0442\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438.  *  
    **\u0412\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E:**
    \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u0410\u043D\u0440\u0438
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435, \u041A\u043B\u0435\u0439\u043D
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0442\u0435\u043E\u0440\u0438\u0438 **\u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439** \u2014 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E\u0433\u043E \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0435 \u043C\u0435\u043D\u044F\u044E\u0442\u0441\u044F
    (\u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043D\u044B) \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445 \u0433\u0440\u0443\u043F\u043F
    \u0434\u0440\u043E\u0431\u043D\u043E-\u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0445
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0439.
    *   **\u041C\u0430\u0441\u0448\u0442\u0430\u0431\u043D\u044B\u0439 \u0442\u0440\u0443\u0434:**
    \u0412\u043C\u0435\u0441\u0442\u0435 \u0441\u043E \u0441\u0432\u043E\u0438\u043C
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C \u0420\u043E\u0431\u0435\u0440\u0442\u043E\u043C
    \u0424\u0440\u0438\u043A\u0435 \u043E\u043D \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    4-\u0442\u043E\u043C\u043D\u044B\u0439 \u0442\u0440\u0443\u0434 \xAB\u041B\u0435\u043A\u0446\u0438\u0438
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439\xBB, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u0438\u0442\u043E\u0433\u043E\u043C \u044D\u0442\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B \u0438 \u043E\u043A\u0430\u0437\u0430\u043B
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0433\u0440\u0443\u043F\u043F \u041B\u0438, \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B.  ### \U0001F522 \u0414\u0440\u0443\u0433\u0438\u0435
    \u0432\u0430\u0436\u043D\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u044B \u0438
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B  *   **\u041C\u043E\u0434\u0435\u043B\u044C
    \u041A\u043B\u0435\u0439\u043D\u0430:** \u0412 \u0435\u0433\u043E \u0447\u0435\u0441\u0442\u044C
    \u043D\u0430\u0437\u0432\u0430\u043D\u0430 \u043E\u0434\u043D\u0430 \u0438\u0437
    \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0445 \u043C\u043E\u0434\u0435\u043B\u0435\u0439
    \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438 (\u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u0430\u044F
    \u043C\u043E\u0434\u0435\u043B\u044C), \u0433\u0434\u0435 \xAB\u043F\u0440\u044F\u043C\u044B\u043C\u0438\xBB
    \u0441\u043B\u0443\u0436\u0430\u0442 \u0445\u043E\u0440\u0434\u044B \u043A\u0440\u0443\u0433\u0430.
    *   **\u041A\u0432\u0430\u0440\u0442\u0438\u043A\u0430 \u041A\u043B\u0435\u0439\u043D\u0430:**
    \u0412 1878 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0438\u0441\u0430\u043B
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u0443\u044E \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u0443
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C \u0440\u043E\u0434\u0430
    3, \u043E\u0431\u043B\u0430\u0434\u0430\u044E\u0449\u0443\u044E \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0439 \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E
    \u0440\u043E\u0434\u0430 \u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u0435\u0439
    (168 \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u0438\u0437\u043C\u043E\u0432).
    \u042D\u0442\u0430 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C,
    \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u0430\u044F \u0435\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C,
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0432\u0430\u0436\u043D\u044B\u043C \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u043C
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    *   **\u0420\u0435\u0444\u043E\u0440\u043C\u0430 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F:**
    \u041E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \xAB\u0447\u0438\u0441\u0442\u043E\u0439\xBB \u043D\u0430\u0443\u043A\u043E\u0439.
    \u041A\u043B\u0435\u0439\u043D \u0441\u044B\u0433\u0440\u0430\u043B \u043A\u043B\u044E\u0447\u0435\u0432\u0443\u044E
    \u0440\u043E\u043B\u044C \u0432 \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0432
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0446\u0435\u043D\u0442\u0440 \u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u0432 \u0440\u0435\u0444\u043E\u0440\u043C\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F, \u043D\u0430\u043F\u0438\u0441\u0430\u0432
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435 \u0442\u0440\u0443\u0434\u044B
    \u043F\u043E \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \xAB\u0441 \u0432\u044B\u0441\u0448\u0435\u0439
    \u0442\u043E\u0447\u043A\u0438 \u0437\u0440\u0435\u043D\u0438\u044F\xBB.  \u0424\u0435\u043B\u0438\u043A\u0441
    \u041A\u043B\u0435\u0439\u043D \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0433\u0435\u043D\u0435\u0440\u0430\u0442\u043E\u0440\u043E\u043C \u0438\u0434\u0435\u0439,
    \u043D\u043E \u0438 \xAB\u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u043E\u0440\u043E\u043C\xBB
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0443\u043C\u0435\u043B \u0441\u0432\u044F\u0437\u0430\u0442\u044C \u0432\u043E\u0435\u0434\u0438\u043D\u043E
    \u0435\u0451 \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0435
    \u0447\u0430\u0441\u0442\u0438 \u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u043A\u0440\u0430\u0441\u043E\u0442\u0443 \u0438 \u0441\u0438\u043B\u0443 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A\u043E-\u0433\u0440\u0443\u043F\u043F\u043E\u0432\u043E\u0433\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434\u0430. \u0415\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u043B\u0435\u0436\u0438\u0442 \u0432 \u043E\u0441\u043D\u043E\u0432\u0435 \u043C\u043D\u043E\u0433\u0438\u0445
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0442\u0435\u043E\u0440\u0438\u0439."
  achievementsEn: 
  personalLifeRu: "\u0411\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u0424\u0435\u043B\u0438\u043A\u0441\u0430
    \u041A\u043B\u0435\u0439\u043D\u0430 \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430, \u043D\u043E \u0438
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0432\u043B\u0438\u044F\u043B \u043D\u0430
    \u043D\u0430\u0443\u043A\u0443 \u0441\u0432\u043E\u0438\u043C\u0438 \u043B\u0438\u0447\u043D\u044B\u043C\u0438
    \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0430\u043C\u0438, \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u043C\u0438
    \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438 \u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u0440\u0435\u043E\u0434\u043E\u043B\u0435\u0432\u0430\u0442\u044C \u043A\u0440\u0438\u0437\u0438\u0441\u044B. 
    \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u044B
    \u0434\u0435\u0442\u0430\u043B\u0438 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u0443\u0442\u0438.  ### \U0001F4DC \u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435 
    \u0424\u0435\u043B\u0438\u043A\u0441 \u0425\u0440\u0438\u0441\u0442\u0438\u0430\u043D
    \u041A\u043B\u0435\u0439\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F 25
    \u0430\u043F\u0440\u0435\u043B\u044F 1849 \u0433\u043E\u0434\u0430 \u0432 \u0414\u044E\u0441\u0441\u0435\u043B\u044C\u0434\u043E\u0440\u0444\u0435,
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u043F\u0440\u0443\u0441\u0441\u043A\u0438\u0445
    \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u043E\u0432. \u0415\u0433\u043E
    \u043E\u0442\u0435\u0446, \u041A\u0430\u0441\u043F\u0430\u0440 \u041A\u043B\u0435\u0439\u043D,
    \u0431\u044B\u043B \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u0435\u043C
    \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u0430 \u0432 \u0420\u0435\u0439\u043D\u0441\u043A\u043E\u0439
    \u043F\u0440\u043E\u0432\u0438\u043D\u0446\u0438\u0438, \u0430 \u043C\u0430\u0442\u044C
    \u2014 \u0421\u043E\u0444\u0438 \u042D\u043B\u0438\u0437, \u0443\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u0430\u044F
    \u041A\u0430\u0439\u0441\u0435\u0440. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u044F\u0440\u043A\u043E\u0435 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u0435\u0433\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F: \u043E\u043D\u043E
    \u0441\u043E\u0432\u043F\u0430\u043B\u043E \u0441 \u0443\u043B\u0438\u0447\u043D\u044B\u043C\u0438
    \u0431\u043E\u044F\u043C\u0438 \u0420\u0435\u0439\u043D\u0441\u043A\u043E\u0439
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438 \u043F\u0440\u043E\u0442\u0438\u0432
    \u043F\u0440\u0443\u0441\u0441\u043A\u0438\u0445 \u0432\u043B\u0430\u0441\u0442\u0435\u0439,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0434\u0430\u043B\u043E \u0435\u0433\u043E
    \u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u044E \u043D\u0430 \u0441\u0432\u0435\u0442
    \u043F\u043E\u0447\u0442\u0438 \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440.  ### \U0001F393 \u0423\u0447\u0451\u0431\u0430
    \u0438 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435 
    *   **\u0413\u0438\u043C\u043D\u0430\u0437\u0438\u044F \u0438 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442:**
    \u041A\u043B\u0435\u0439\u043D \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u044E
    \u0432 \u0414\u044E\u0441\u0441\u0435\u043B\u044C\u0434\u043E\u0440\u0444\u0435
    \u0438 \u0432 1865 \u0433\u043E\u0434\u0443 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0411\u043E\u043D\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u0433\u0434\u0435 \u043F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u043D\u0430\u043C\u0435\u0440\u0435\u0432\u0430\u043B\u0441\u044F \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u0444\u0438\u0437\u0438\u043A\u0443. *   **\u0412\u0441\u0442\u0440\u0435\u0447\u0430
    \u0441 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C:**
    \u0421\u0443\u0434\u044C\u0431\u043E\u043D\u043E\u0441\u043D\u044B\u043C \u0441\u0442\u0430\u043B\u043E
    \u0435\u0433\u043E \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E
    \u0441 **\u042E\u043B\u0438\u0443\u0441\u043E\u043C \u041F\u043B\u044E\u043A\u043A\u0435\u0440\u043E\u043C**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438. \u041A\u043B\u0435\u0439\u043D \u0441\u0442\u0430\u043B
    \u0435\u0433\u043E \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u043C
    \u0432 1866 \u0433\u043E\u0434\u0443. \u041F\u043E\u0434 \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C
    \u041F\u043B\u044E\u043A\u043A\u0435\u0440\u0430, \u0447\u0435\u0439 \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441 \u043B\u0435\u0436\u0430\u043B \u0432
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B \u041A\u043B\u0435\u0439\u043D\u0430
    \u0441\u043C\u0435\u0441\u0442\u0438\u043B\u0438\u0441\u044C \u0432 \u044D\u0442\u0443
    \u0441\u0442\u043E\u0440\u043E\u043D\u0443. *   **\u0414\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0430\u044F
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C:** \u0412 1868 \u0433\u043E\u0434\u0443,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 19 \u043B\u0435\u0442,
    \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u041F\u043B\u044E\u043A\u043A\u0435\u0440\u0430 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0437\u0430 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u043F\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u043B\u0438\u043D\u0438\u0439
    \u0438 \u0435\u0451 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F\u043C
    \u043A \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435. \u041F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u041F\u043B\u044E\u043A\u043A\u0435\u0440\u0430
    \u0432 \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u0438\u043C\u0435\u043D\u043D\u043E
    \u041A\u043B\u0435\u0439\u043D\u0443 \u0431\u044B\u043B\u043E \u043F\u043E\u0440\u0443\u0447\u0435\u043D\u043E
    \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u044C \u0438 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C
    \u043A \u043F\u0435\u0447\u0430\u0442\u0438 \u0432\u0442\u043E\u0440\u043E\u0439
    \u0442\u043E\u043C \u0435\u0433\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430.  ### \U0001F30D \u041F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F
    \u0438 \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435 
    \u041F\u043E\u0441\u043B\u0435 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u041A\u043B\u0435\u0439\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u043E\u0435\u0437\u0434\u043A\u0443 \u043F\u043E \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438,
    \u043F\u043E\u0441\u0435\u0442\u0438\u0432 \u0411\u0435\u0440\u043B\u0438\u043D,
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D \u0438 \u041F\u0430\u0440\u0438\u0436.
    \u0412 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u043D\u0430
    \u043D\u0435\u0433\u043E \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u0431\u043E\u043B\u044C\u0448\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u0432\u0441\u0442\u0440\u0435\u0447\u0438
    \u0441 \u043A\u0440\u0443\u043F\u043D\u044B\u043C\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438,
    \u0442\u0430\u043A\u0438\u043C\u0438 \u043A\u0430\u043A **\u0410\u043B\u044C\u0444\u0440\u0435\u0434
    \u041A\u043B\u0435\u0431\u0448** (\u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u0438\u0434\u0435\u043B \u0432 \u043D\u0451\u043C \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E
    \u043B\u0438\u0434\u0435\u0440\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438)
    \u0438, \u0432 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0438,
    \u0441 \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    **\u0421\u043E\u0444\u0443\u0441\u043E\u043C \u041B\u0438**. \u0418\u043C\u0435\u043D\u043D\u043E
    \u041B\u0438 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B \u041A\u043B\u0435\u0439\u043D\u0430
    \u0441 \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0435\u0439 \u0433\u0440\u0443\u043F\u043F,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u044B\u0433\u0440\u0430\u043B\u0430
    \u043A\u043B\u044E\u0447\u0435\u0432\u0443\u044E \u0440\u043E\u043B\u044C \u0432
    \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435.  \u0412 1870 \u0433\u043E\u0434\u0443,
    \u043F\u0435\u0440\u0435\u0434 \u0441\u0430\u043C\u044B\u043C \u043D\u0430\u0447\u0430\u043B\u043E\u043C
    \u0424\u0440\u0430\u043D\u043A\u043E-\u043F\u0440\u0443\u0441\u0441\u043A\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B, \u041A\u043B\u0435\u0439\u043D \u0432\u043C\u0435\u0441\u0442\u0435
    \u0441 \u041B\u0438 \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0441\u044F \u0432
    \u041F\u0430\u0440\u0438\u0436\u0435, \u0433\u0434\u0435 \u043E\u0431\u0449\u0430\u043B\u0441\u044F
    \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438
    \u0416\u0430\u043D\u043E\u043C \u0413\u0430\u0441\u0442\u043E\u043D\u043E\u043C
    \u0414\u0430\u0440\u0431\u0443 \u0438 \u041A\u0430\u043C\u0438\u043B\u0435\u043C
    \u0416\u043E\u0440\u0434\u0430\u043D\u043E\u043C. \u0421 \u043D\u0430\u0447\u0430\u043B\u043E\u043C
    \u0432\u043E\u0439\u043D\u044B \u043E\u043D \u0431\u044B\u043B \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u0441\u0440\u043E\u0447\u043D\u043E \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
    \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044E \u0438 \u0447\u0443\u0442\u044C
    \u043D\u0435 \u0441\u0442\u0430\u043B \u0436\u0435\u0440\u0442\u0432\u043E\u0439
    \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u0438 \u0442\u0438\u0444\u0430.  ###
    \U0001F3DB\uFE0F \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430  *   **\u042D\u0440\u043B\u0430\u043D\u0433\u0435\u043D
    (1872\u20131875):** \u041F\u043E \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u0438
    \u041A\u043B\u0435\u0431\u0448\u0430, 23-\u043B\u0435\u0442\u043D\u0438\u0439
    \u041A\u043B\u0435\u0439\u043D \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u042D\u0440\u043B\u0430\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430. \u0417\u0434\u0435\u0441\u044C
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **\xAB\u042D\u0440\u043B\u0430\u043D\u0433\u0435\u043D\u0441\u043A\u0443\u044E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443\xBB**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430 \u0435\u043C\u0443 \u043E\u0431\u0449\u0435\u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0443\u044E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C. *   **\u041C\u044E\u043D\u0445\u0435\u043D
    (1875\u20131880):** \u0412 1875 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0435\u0440\u0435\u0448\u0451\u043B
    \u043D\u0430 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0432 \u0412\u044B\u0441\u0448\u0443\u044E \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u0432 \u041C\u044E\u043D\u0445\u0435\u043D\u0435.
    \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u0431\u044B\u043B
    \u043E\u0442\u043C\u0435\u0447\u0435\u043D \u043D\u0430\u0447\u0430\u043B\u043E\u043C
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438:
    \u0432 \u044D\u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u0410\u043D\u043D\u0435
    \u0413\u0435\u0433\u0435\u043B\u044C**, \u0432\u043D\u0443\u0447\u043A\u0435
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430
    \u0413\u0435\u043E\u0440\u0433\u0430 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u0430
    \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430 \u0413\u0435\u0433\u0435\u043B\u044F.
    \u0412 \u041C\u044E\u043D\u0445\u0435\u043D\u0435 \u041A\u043B\u0435\u0439\u043D
    \u0438 \u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0430 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440
    \u0444\u043E\u043D \u0411\u0440\u0438\u043B\u043B\u044C \u0447\u0438\u0442\u0430\u043B\u0438
    \u043F\u0440\u043E\u0434\u0432\u0438\u043D\u0443\u0442\u044B\u0435 \u043A\u0443\u0440\u0441\u044B
    \u0434\u043B\u044F \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432, \u0441\u0440\u0435\u0434\u0438
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0431\u044B\u043B\u0438 \u0410\u0434\u043E\u043B\u044C\u0444
    \u0413\u0443\u0440\u0432\u0438\u0446, \u0412\u0430\u043B\u044C\u0442\u0435\u0440
    \u0444\u043E\u043D \u0414\u0438\u043A, \u041A\u0430\u0440\u043B \u0420\u0443\u043D\u0433\u0435
    \u0438 \u041C\u0430\u043A\u0441 \u041F\u043B\u0430\u043D\u043A. \u0412 1876 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441\u0442\u0430\u043B \u0440\u0435\u0434\u0430\u043A\u0442\u043E\u0440\u043E\u043C
    \u0432\u0435\u0434\u0443\u0449\u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0436\u0443\u0440\u043D\u0430\u043B\u0430 \xABMathematische Annalen\xBB. *  
    **\u041B\u0435\u0439\u043F\u0446\u0438\u0433 (1880\u20131886):** \u0417\u0430\u0442\u0435\u043C
    \u041A\u043B\u0435\u0439\u043D \u0431\u044B\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0451\u043D
    \u043D\u0430 \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0432 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442.
    \u042D\u0442\u043E \u0432\u0440\u0435\u043C\u044F \u0441\u0442\u0430\u043B\u043E
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0441\u0430\u043C\u044B\u043C \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u043C
    \u0432 \u043D\u0430\u0443\u0447\u043D\u043E\u043C \u043F\u043B\u0430\u043D\u0435,
    \u043D\u043E \u0438 \u0441\u0430\u043C\u044B\u043C \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u044B\u043C.
    \u041E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0432 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0435
    \u0438 \u043D\u0430\u043F\u0440\u044F\u0436\u0451\u043D\u043D\u043E\u043C \u0441\u043E\u043F\u0435\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0435
    \u0441 \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435.
    \u0412 1882\u20131884 \u0433\u043E\u0434\u0430\u0445 \u0435\u0433\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435,
    \u043F\u043E\u0434\u043E\u0440\u0432\u0430\u043D\u043D\u043E\u0435 \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u044B\u043C
    \u043F\u0435\u0440\u0435\u0443\u0442\u043E\u043C\u043B\u0435\u043D\u0438\u0435\u043C,
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0440\u0443\u0445\u043D\u0443\u043B\u043E:
    \u043E\u043D \u043F\u0435\u0440\u0435\u0436\u0438\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E
    \u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u044E. \u042D\u0442\u0430 \u0431\u043E\u043B\u0435\u0437\u043D\u044C
    \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u043E\u043B\u043E\u0436\u0438\u043B\u0430
    \u043A\u043E\u043D\u0435\u0446 \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0435
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044F
    \u0438 \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u043B\u0430 \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u0442\u044C\u0441\u044F
    \u043D\u0430 \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0438 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443. *   **\u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D
    (1886\u20131913) \u0438 \u043A\u043E\u043D\u0447\u0438\u043D\u0430:** \u0412
    1886 \u0433\u043E\u0434\u0443 \u041A\u043B\u0435\u0439\u043D \u043F\u0440\u0438\u043D\u044F\u043B
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0443\u0440\u0443 \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. \u0417\u0434\u0435\u0441\u044C
    \u043E\u043D \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0438\u043B\u0441\u044F
    \u043D\u0430 \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0432
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0446\u0435\u043D\u0442\u0440 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. \u041E\u043D
    \u0432\u0432\u0451\u043B \u0435\u0436\u0435\u043D\u0435\u0434\u0435\u043B\u044C\u043D\u044B\u0435
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440\u044B, \u0441\u043E\u0437\u0434\u0430\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0443 \u0438 \u043F\u0440\u0438\u0432\u043B\u0451\u043A
    \u043A \u0440\u0430\u0431\u043E\u0442\u0435 \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435
    **\u0414\u0430\u0432\u0438\u0434\u0430 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430**.
    \u041E\u043D \u0447\u0438\u0442\u0430\u043B \u044F\u0440\u043A\u0438\u0435 \u043A\u0443\u0440\u0441\u044B
    \u043F\u043E \u0441\u0430\u043C\u044B\u043C \u0440\u0430\u0437\u043D\u044B\u043C
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430\u043C, \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u0430\u044F
    \u0441\u043B\u0443\u0448\u0430\u0442\u0435\u043B\u0435\u0439 \u0441\u043E \u0432\u0441\u0435\u0433\u043E
    \u043C\u0438\u0440\u0430. \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u0432 \u0440\u0435\u0444\u043E\u0440\u043C\u0435
    \u0448\u043A\u043E\u043B\u044C\u043D\u043E\u0433\u043E \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u043D\u0430\u0443\u0447\u043D\u043E-\u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0445
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u043E\u0432. \u0412 1913 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0432\u044B\u0448\u0435\u043B \u0432 \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0443
    \u043F\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F,
    \u043D\u043E \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C.
    \u0421 \u043D\u0430\u0447\u0430\u043B\u043E\u043C \u041F\u0435\u0440\u0432\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B \u041A\u043B\u0435\u0439\u043D,
    \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445
    \u043A\u043E\u043B\u043B\u0435\u0433, \u043D\u0435 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0448\u043E\u0432\u0438\u043D\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0430\u043A\u0446\u0438\u044F\u0445.  \u0412 1924 \u0433\u043E\u0434\u0443 \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0448\u0438\u0440\u043E\u043A\u043E \u043E\u0442\u043C\u0435\u0442\u0438\u043B\u0430
    \u0435\u0433\u043E 75-\u043B\u0435\u0442\u0438\u0435. \u0424\u0435\u043B\u0438\u043A\u0441
    \u041A\u043B\u0435\u0439\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435 22 \u0438\u044E\u043D\u044F
    1925 \u0433\u043E\u0434\u0430 \u0438 \u0431\u044B\u043B \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u043D\u0430 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u043C \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435.
    \u0412 1933 \u0433\u043E\u0434\u0443, \u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438, \u043D\u0430\u0446\u0438\u0441\u0442\u0441\u043A\u0438\u0435
    \u0438\u0434\u0435\u043E\u043B\u043E\u0433\u0438, \u0432 \u0440\u0430\u043C\u043A\u0430\u0445
    \u0431\u043E\u0440\u044C\u0431\u044B \u0441 \xAB\u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u043E\u0439\xBB, \u043F\u044B\u0442\u0430\u043B\u0438\u0441\u044C
    \u043E\u0441\u043F\u043E\u0440\u0438\u0442\u044C \u0435\u0433\u043E \xAB\u0430\u0440\u0438\u0439\u0441\u043A\u043E\u0435\xBB
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u043E\u0431\u0432\u0438\u043D\u0438\u0442\u044C \u0432 \u043F\u043E\u0442\u0432\u043E\u0440\u0441\u0442\u0432\u0435
    \u0435\u0432\u0440\u0435\u044F\u043C, \u043D\u043E \u0440\u0430\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u043D\u0435 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u043B\u043E
    \u044D\u0442\u0438\u0445 \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u043D\u0438\u0439. 
    ### \U0001F9D1\u200D\U0001F91D\u200D\U0001F9D1 \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0443\u0447\u0435\u043D\u044B\u043C\u0438  *   **\u0421\u043E\u0444\u0443\u0441
    \u041B\u0438:** \u0421\u0430\u043C\u043E\u0435 \u0442\u0435\u0441\u043D\u043E\u0435
    \u0438 \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u043E\u0435
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E.
    \u0418\u0445 \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u0432 1869 \u0433\u043E\u0434\u0443
    \u0438 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u044B \u0442\u0435\u043E\u0440\u0438\u0438 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0445
    \u0433\u0440\u0443\u043F\u043F. *   **\u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435:**
    \u0421\u043E\u043F\u0435\u0440\u043D\u0438\u043A \u0438 \u0434\u0440\u0443\u0433.
    \u0418\u0445 \u043A\u043E\u043D\u043A\u0443\u0440\u0435\u043D\u0446\u0438\u044F
    \u0432 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u0431\u044B\u043B\u0430 \u0438\u043D\u0442\u0435\u043D\u0441\u0438\u0432\u043D\u043E\u0439,
    \u043D\u043E \u0443\u0432\u0430\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439.
    \u041E\u043D\u0438 \u043E\u0431\u043C\u0435\u043D\u0438\u0432\u0430\u043B\u0438\u0441\u044C
    \u043F\u0438\u0441\u044C\u043C\u0430\u043C\u0438 \u0438 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0438\u0441\u044C \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u0432\u0435\u043B\u0438\u043A\u0443\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u0443\u043D\u0438\u0444\u043E\u0440\u043C\u0438\u0437\u0430\u0446\u0438\u0438.
    *   **\u0414\u0430\u0432\u0438\u0434 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442:**
    \u041A\u043B\u0435\u0439\u043D \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D
    \u0432 1895 \u0433\u043E\u0434\u0443, \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u043D\u0430\u0447\u0430\u043B\u043E\u043C \u0438\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0432
    \u0432\u0435\u0434\u0443\u0449\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0446\u0435\u043D\u0442\u0440 \u043C\u0438\u0440\u0430. *   **\u0410\u043B\u044C\u0444\u0440\u0435\u0434
    \u041A\u043B\u0435\u0431\u0448:** \u0412\u0430\u0436\u043D\u044B\u0439 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u043E\u0432\u0430\u043B
    \u041A\u043B\u0435\u0439\u043D\u0430 \u043D\u0430 \u043F\u0435\u0440\u0432\u0443\u044E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0432 \u042D\u0440\u043B\u0430\u043D\u0433\u0435\u043D\u0435.
    *   **\u042D\u043C\u043C\u0438 \u041D\u0451\u0442\u0435\u0440:** \u041A\u043B\u0435\u0439\u043D
    \u0442\u0435\u0441\u043D\u043E \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0430\u043B
    \u0441 \u043D\u0435\u0439 \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0436\u0438\u0437\u043D\u0438, \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u044F
    \u0435\u0451 \u0440\u0430\u0431\u043E\u0442\u0443 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432 \u0438 \u043E\u0431\u0449\u0435\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u041E\u043D \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0435\u0451
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    \u043A \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438 \u0432 1918
    \u0433\u043E\u0434\u0443. *   **\u0413\u0440\u0435\u0439\u0441 \u0427\u0438\u0441\u0445\u043E\u043B\u043C
    \u042F\u043D\u0433:** \u041A\u043B\u0435\u0439\u043D \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u043B
    \u0435\u0451 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u043E\u0439 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0435\u0439 \u043F\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0437\u0430\u0449\u0438\u0449\u0451\u043D\u043D\u043E\u0439
    \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439 \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435.
    \u0412 \u0446\u0435\u043B\u043E\u043C, \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0443\u0441\u0438\u043B\u0438\u044F\u043C \u041A\u043B\u0435\u0439\u043D\u0430,
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u043D\u0430\u0447\u0430\u043B
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0442\u044C \u0436\u0435\u043D\u0449\u0438\u043D
    \u0432 1893 \u0433\u043E\u0434\u0443."
  personalLifeEn: 
  shortBioRu: "\u0424\u0435\u043B\u0438\u043A\u0441 \u0425\u0440\u0438\u0441\u0442\u0438\u0430\u043D
    \u041A\u043B\u0435\u0439\u043D (1849\u20131925) \u2014 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0447\u044C\u0451 \u0438\u043C\u044F
    \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u0432\u043F\u0438\u0441\u0430\u043D\u043E
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u043D\u0430\u0443\u043A\u0438.
    \u041E\u043D \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C \u0443\u0447\u0451\u043D\u044B\u043C,
    \u043D\u043E \u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C,
    \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u043E\u043C \u0438 \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u0442\u043E\u0440\u043E\u043C,
    \u0441\u0443\u043C\u0435\u0432\u0448\u0438\u043C \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C
    \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432 \u0441\u0442\u0440\u043E\u0439\u043D\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0438 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0442\u044C
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0432 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0446\u0435\u043D\u0442\u0440 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438.  ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    (1849\u20131872)  \u041A\u043B\u0435\u0439\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0414\u044E\u0441\u0441\u0435\u043B\u044C\u0434\u043E\u0440\u0444\u0435
    25 \u0430\u043F\u0440\u0435\u043B\u044F 1849 \u0433\u043E\u0434\u0430 \u0432
    \u0441\u0435\u043C\u044C\u0435 \u043F\u0440\u0443\u0441\u0441\u043A\u043E\u0433\u043E
    \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u0430. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043F\u0440\u0435\u0434\u0430\u043D\u0438\u0435, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0441\u043E\u0432\u043F\u0430\u043B\u043E
    \u0441 \u0443\u043B\u0438\u0447\u043D\u044B\u043C\u0438 \u0431\u043E\u044F\u043C\u0438
    \u0420\u0435\u0439\u043D\u0441\u043A\u043E\u0439 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0434\u0430\u0451\u0442 \u0435\u0433\u043E
    \u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u044E \u043D\u0430 \u0441\u0432\u0435\u0442
    \u043F\u043E\u0447\u0442\u0438 \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440.  *   **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u0411\u043E\u043D\u043D\u0430 \u0438 \u0432\u0441\u0442\u0440\u0435\u0447\u0430
    \u0441 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C:**
    \u0412 1865 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    16 \u043B\u0435\u0442, \u041A\u043B\u0435\u0439\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0411\u043E\u043D\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u0433\u0434\u0435 \u043F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u043B \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u0444\u0438\u0437\u0438\u043A\u0443. \u0421\u0443\u0434\u044C\u0431\u043E\u043D\u043E\u0441\u043D\u044B\u043C
    \u0441\u0442\u0430\u043B\u043E \u0435\u0433\u043E \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E
    \u0441 \u042E\u043B\u0438\u0443\u0441\u043E\u043C \u041F\u043B\u044E\u043A\u043A\u0435\u0440\u043E\u043C,
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438. \u041A\u043B\u0435\u0439\u043D \u0441\u0442\u0430\u043B
    \u0435\u0433\u043E \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u043C,
    \u0438 \u043F\u043E\u0434 \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C \u041F\u043B\u044E\u043A\u043A\u0435\u0440\u0430
    \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B \u0441\u043C\u0435\u0441\u0442\u0438\u043B\u0438\u0441\u044C
    \u0432 \u0441\u0442\u043E\u0440\u043E\u043D\u0443 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.
    *   **\u0420\u0430\u043D\u043D\u0438\u0439 \u0434\u043E\u043A\u0442\u043E\u0440\u0430\u0442
    \u0438 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0435 \u0442\u0440\u0443\u0434\u043E\u0432
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F:** \u0412 1868 \u0433\u043E\u0434\u0443,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 19 \u043B\u0435\u0442,
    \u041A\u043B\u0435\u0439\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0437\u0430 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u043F\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u043B\u0438\u043D\u0438\u0439
    \u0438 \u0435\u0451 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F\u043C
    \u043A \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435. \u041A\u043E\u0433\u0434\u0430
    \u0432 \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u041F\u043B\u044E\u043A\u043A\u0435\u0440
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F, \u0438\u043C\u0435\u043D\u043D\u043E
    \u043C\u043E\u043B\u043E\u0434\u043E\u0439 \u041A\u043B\u0435\u0439\u043D \u0431\u044B\u043B
    \u043F\u0440\u0438\u0437\u0432\u0430\u043D \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u044C
    \u0438 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C \u043A
    \u043F\u0435\u0447\u0430\u0442\u0438 \u0432\u0442\u043E\u0440\u043E\u0439 \u0442\u043E\u043C
    \u0435\u0433\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430 \xAB\u041D\u043E\u0432\u0430\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430\xBB.
    *   **\u0413\u043E\u0434\u044B \u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0438\u0439
    \u0438 \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u0430:** \u041F\u043E\u0441\u043B\u0435
    \u0411\u043E\u043D\u043D\u0430 \u041A\u043B\u0435\u0439\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u043F\u043E\u0435\u0437\u0434\u043A\u0443 \u043F\u043E \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438,
    \u043F\u043E\u0441\u0435\u0442\u0438\u0432 \u0411\u0435\u0440\u043B\u0438\u043D,
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D \u0438 \u041F\u0430\u0440\u0438\u0436.
    \u041E\u0441\u043E\u0431\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u043D\u0435\u0433\u043E \u043E\u043A\u0430\u0437\u0430\u043B\u0430
    \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u0441 \u0410\u043B\u044C\u0444\u0440\u0435\u0434\u043E\u043C
    \u041A\u043B\u0435\u0431\u0448\u0435\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0440\u0430\u0437\u0433\u043B\u044F\u0434\u0435\u043B \u0432 \u043D\u0451\u043C
    \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E \u043B\u0438\u0434\u0435\u0440\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0412 1870 \u0433\u043E\u0434\u0443
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u041A\u043B\u0435\u0439\u043D \u043D\u0430\u0447\u0430\u043B
    \u0441\u0432\u043E\u0451 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0421\u043E\u0444\u0443\u0441\u043E\u043C \u041B\u0438, \u0432\u043C\u0435\u0441\u0442\u0435
    \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u043E\u043D\u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u044B \u0442\u0435\u043E\u0440\u0438\u0438 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0445
    \u0433\u0440\u0443\u043F\u043F. \u0418\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0431\u044B\u043B\u0430 \u043F\u0440\u0435\u0440\u0432\u0430\u043D\u0430
    \u043D\u0430\u0447\u0430\u043B\u043E\u043C \u0424\u0440\u0430\u043D\u043A\u043E-\u043F\u0440\u0443\u0441\u0441\u043A\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B, \u0432\u044B\u043D\u0443\u0434\u0438\u0432\u0448\u0435\u0439
    \u041A\u043B\u0435\u0439\u043D\u0430 \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
    \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044E.  ### \U0001F9E0 \u0420\u0430\u0441\u0446\u0432\u0435\u0442
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0438 \xAB\u042D\u0440\u043B\u0430\u043D\u0433\u0435\u043D\u0441\u043A\u0430\u044F
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430\xBB (1872\u20131886) 
    \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u0441\u0442\u0430\u043B
    \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C \u0441\u0430\u043C\u044B\u0445
    \u044F\u0440\u043A\u0438\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439
    \u041A\u043B\u0435\u0439\u043D\u0430.  *   **\u042D\u0440\u043B\u0430\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 \u0438 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u043D\u044B\u0439
    \u043C\u0430\u043D\u0438\u0444\u0435\u0441\u0442:** \u0412 1872 \u0433\u043E\u0434\u0443,
    \u043F\u043E \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u0438
    \u041A\u043B\u0435\u0431\u0448\u0430, 23-\u043B\u0435\u0442\u043D\u0438\u0439
    \u041A\u043B\u0435\u0439\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u0443\u044E
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u042D\u0440\u043B\u0430\u043D\u0433\u0435\u043D\u0430. \u0412 \u0441\u0432\u043E\u0435\u0439
    \u0438\u043D\u0430\u0443\u0433\u0443\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u043B\u0435\u043A\u0446\u0438\u0438 (\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u043A\u0430\u043A \xAB\u0421\u0440\u0430\u0432\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0440\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0435\u043D\u0438\u0435 \u043D\u043E\u0432\u044B\u0445
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439\xBB)
    \u043E\u043D \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u0438\u0434\u0435\u0438,
    \u0432\u043E\u0448\u0435\u0434\u0448\u0438\u0435 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E
    \u043A\u0430\u043A **\xAB\u042D\u0440\u043B\u0430\u043D\u0433\u0435\u043D\u0441\u043A\u0430\u044F
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430\xBB**. \u041E\u0441\u043D\u043E\u0432\u043D\u0430\u044F
    \u043C\u044B\u0441\u043B\u044C \u0431\u044B\u043B\u0430 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0439:
    **\u043A\u0430\u0436\u0434\u0430\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    (\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0430, \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0430,
    \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u0430\u044F \u0438 \u0442.\u0434.)
    \u0435\u0441\u0442\u044C \u043D\u0435 \u0447\u0442\u043E \u0438\u043D\u043E\u0435,
    \u043A\u0430\u043A \u0442\u0435\u043E\u0440\u0438\u044F \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u043E\u0439 \u0433\u0440\u0443\u043F\u043F\u044B
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0439**.
    \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C
    \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B, \u043D\u043E \u0438 \u0441\u0442\u0440\u043E\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0441\u0442\u044C
    \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.
    *   **\u041C\u044E\u043D\u0445\u0435\u043D \u0438 \u041B\u0435\u0439\u043F\u0446\u0438\u0433:**
    \u0412 1875 \u0433\u043E\u0434\u0443 \u041A\u043B\u0435\u0439\u043D \u043F\u0435\u0440\u0435\u0448\u0451\u043B
    \u0432 \u041C\u044E\u043D\u0445\u0435\u043D\u0441\u043A\u0438\u0439 \u043F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u043A\u0443\u043C,
    \u0430 \u0432 1880 \u0433\u043E\u0434\u0443 \u2014 \u0432 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442. \u0412 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0435
    \u043E\u043D \u043F\u0435\u0440\u0435\u0436\u0438\u043B \u0441\u0432\u043E\u044E
    \u0441\u0430\u043C\u0443\u044E \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u0443\u044E,
    \u043D\u043E \u0438 \u0441\u0430\u043C\u0443\u044E \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u0443\u044E
    \u043F\u043E\u0440\u0443. \u0417\u0434\u0435\u0441\u044C \u043E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445 \u0438 \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439, \u0432\u0441\u0442\u0443\u043F\u0438\u0432
    \u0432 \u0434\u0440\u0443\u0436\u0435\u0441\u043A\u043E\u0435, \u043D\u043E \u043D\u0430\u043F\u0440\u044F\u0436\u0451\u043D\u043D\u043E\u0435
    \u0441\u043E\u043F\u0435\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0437\u0430 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0432\u0435\u043B\u0438\u043A\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u0443\u043D\u0438\u0444\u043E\u0440\u043C\u0438\u0437\u0430\u0446\u0438\u0438.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u043D\u0430\u0447\u0430\u043B\u0438\u0441\u044C \u0435\u0433\u043E \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
    \u0441\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435\u043C. *   **\u041A\u0440\u0438\u0437\u0438\u0441
    \u0438 \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u0438\u0435:**
    \u041E\u043A\u043E\u043B\u043E 1882\u20131884 \u0433\u043E\u0434\u043E\u0432
    \u0438\u0437-\u0437\u0430 \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0435\u0443\u0442\u043E\u043C\u043B\u0435\u043D\u0438\u044F
    \u0438 \u043D\u0435\u0440\u0432\u043D\u043E\u0433\u043E \u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u0438\u044F
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435 \u041A\u043B\u0435\u0439\u043D\u0430
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0440\u0443\u0445\u043D\u0443\u043B\u043E,
    \u043E\u043D \u0432\u043F\u0430\u043B \u0432 \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E
    \u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u044E. \u042D\u0442\u0430 \u0431\u043E\u043B\u0435\u0437\u043D\u044C
    \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u043E\u043B\u043E\u0436\u0438\u043B\u0430
    \u043A\u043E\u043D\u0435\u0446 \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0435
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044F-\u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0430
    \u0438 \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u043B\u0430 \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u0442\u044C
    \u0441\u0432\u043E\u044E \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0443\u044E
    \u044D\u043D\u0435\u0440\u0433\u0438\u044E \u043D\u0430 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u044E
    \u043D\u0430\u0443\u043A\u0438 \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435. 
    ### \U0001F3DB\uFE0F \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434: \u041E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440
    \u0438 \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u0442\u043E\u0440 (1886\u20131925) 
    \u041F\u0435\u0440\u0435\u0435\u0437\u0434 \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D
    \u0432 1886 \u0433\u043E\u0434\u0443 \u0441\u0442\u0430\u043B \u043D\u0430\u0447\u0430\u043B\u043E\u043C
    \u043D\u043E\u0432\u043E\u0433\u043E, \u043D\u0435 \u043C\u0435\u043D\u0435\u0435
    \u0432\u0430\u0436\u043D\u043E\u0433\u043E \u044D\u0442\u0430\u043F\u0430 \u0432
    \u0436\u0438\u0437\u043D\u0438 \u041A\u043B\u0435\u0439\u043D\u0430.  *   **\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043C\u0438\u0440\u043E\u0432\u043E\u0433\u043E \u0446\u0435\u043D\u0442\u0440\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438:** \u041A\u043B\u0435\u0439\u043D
    \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0446\u0435\u043B\u044C \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0442\u044C
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D \u0432 \u0432\u0435\u0434\u0443\u0449\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0446\u0435\u043D\u0442\u0440 \u043C\u0438\u0440\u0430. \u041E\u043D \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B
    \u0442\u0443\u0434\u0430 \u0414\u0430\u0432\u0438\u0434\u0430 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430,
    \u0441\u043E\u0437\u0434\u0430\u043B \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0443\u044E
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0443 \u0438 \u0432\u0432\u0451\u043B
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0443 \u0435\u0436\u0435\u043D\u0435\u0434\u0435\u043B\u044C\u043D\u044B\u0445
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440\u043E\u0432 \u0438 \u043A\u043E\u043B\u043B\u043E\u043A\u0432\u0438\u0443\u043C\u043E\u0432.
    \u041C\u043E\u0434\u0435\u043B\u044C \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430,
    \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u0430\u044F \u041A\u043B\u0435\u0439\u043D\u043E\u043C,
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0431\u0440\u0430\u0437\u0446\u043E\u043C
    \u0434\u043B\u044F \u043F\u043E\u0434\u0440\u0430\u0436\u0430\u043D\u0438\u044F
    \u0432\u043E \u0432\u0441\u0451\u043C \u043C\u0438\u0440\u0435. *   **\u0420\u0435\u0434\u0430\u043A\u0442\u043E\u0440\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C:** \u0421
    1876 \u0433\u043E\u0434\u0430 \u0438 \u043F\u043E\u0447\u0442\u0438 40 \u043B\u0435\u0442
    \u041A\u043B\u0435\u0439\u043D \u0431\u044B\u043B \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u0440\u0435\u0434\u0430\u043A\u0442\u043E\u0440\u043E\u043C \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438\u0437 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0436\u0443\u0440\u043D\u0430\u043B\u043E\u0432 \u043C\u0438\u0440\u0430 \u2014
    **\xABMathematische Annalen\xBB**. \u0415\u0433\u043E \u0443\u043C\u0435\u043B\u043E\u0435
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E \u0432\u044B\u0432\u0435\u043B\u043E
    \u0436\u0443\u0440\u043D\u0430\u043B \u043D\u0430 \u043B\u0438\u0434\u0438\u0440\u0443\u044E\u0449\u0438\u0435
    \u043F\u043E\u0437\u0438\u0446\u0438\u0438. \u041A\u0440\u043E\u043C\u0435 \u0442\u043E\u0433\u043E,
    \u043E\u043D \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u043B \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435\u043C
    \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \xAB\u042D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A\xBB. *   **\u041F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u043A\u0430
    \u0438 \u0440\u0435\u0444\u043E\u0440\u043C\u0430 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F:**
    \u041A\u043B\u0435\u0439\u043D \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0441\u044F
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0415\u0433\u043E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0442\u0440\u0443\u0434
    \xAB\u042D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0441 \u0442\u043E\u0447\u043A\u0438
    \u0437\u0440\u0435\u043D\u0438\u044F \u0432\u044B\u0441\u0448\u0435\u0439\xBB
    \u0431\u044B\u043B \u043D\u0430\u043F\u0438\u0441\u0430\u043D \u0434\u043B\u044F
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439 \u0438 \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440 \u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u044C\u044E.
    \u0412 1908 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u0435\u0440\u0432\u044B\u043C
    \u043F\u0440\u0435\u0434\u0441\u0435\u0434\u0430\u0442\u0435\u043B\u0435\u043C
    \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0439
    \u043A\u043E\u043C\u0438\u0441\u0441\u0438\u0438 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044E. \u041F\u0440\u0438
    \u0435\u0433\u043E \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0439 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0435
    \u0432 1893 \u0433\u043E\u0434\u0443 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u043D\u0430\u0447\u0430\u043B
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0442\u044C \u0436\u0435\u043D\u0449\u0438\u043D
    \u0434\u043B\u044F \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    *   **\u041F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0435 \u0430\u0441\u043F\u0435\u043A\u0442\u044B:**
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445
    \xAB\u0447\u0438\u0441\u0442\u044B\u0445\xBB \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u041A\u043B\u0435\u0439\u043D \u0443\u0434\u0435\u043B\u044F\u043B \u0431\u043E\u043B\u044C\u0448\u043E\u0435
    \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F\u043C.
    \u041E\u043D \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u043F\u0440\u0438 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u043E\u0432 \u0434\u043B\u044F
    \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439,
    \u0430 \u0432 \u043F\u0440\u0435\u043A\u043B\u043E\u043D\u043D\u043E\u043C \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0441\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430\u043C\u0438 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430 \u0438 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E.
    \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441\u043E \u0441\u0432\u043E\u0438\u043C
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u043E\u043C
    \u0417\u043E\u043C\u043C\u0435\u0440\u0444\u0435\u043B\u044C\u0434\u043E\u043C
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0447\u0435\u0442\u044B\u0440\u0451\u0445\u0442\u043E\u043C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0438\u0440\u043E\u0441\u043A\u043E\u043F\u0430.
    *   **\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B:**
    \u041A\u043B\u0435\u0439\u043D \u0432\u044B\u0448\u0435\u043B \u0432 \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0443
    \u0432 1913 \u0433\u043E\u0434\u0443, \u043D\u043E \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B
    \u0447\u0438\u0442\u0430\u0442\u044C \u043B\u0435\u043A\u0446\u0438\u0438. \u0412
    \u0433\u043E\u0434\u044B \u041F\u0435\u0440\u0432\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u043E\u043D, \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445 \u043A\u043E\u043B\u043B\u0435\u0433,
    \u043D\u0435 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u0432
    \u0448\u043E\u0432\u0438\u043D\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0430\u043A\u0446\u0438\u044F\u0445. \u0412 1924 \u0433\u043E\u0434\u0443 \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E \u0448\u0438\u0440\u043E\u043A\u043E
    \u043E\u0442\u043C\u0435\u0442\u0438\u043B\u043E \u0435\u0433\u043E 75-\u043B\u0435\u0442\u0438\u0435,
    \u0430 22 \u0438\u044E\u043D\u044F 1925 \u0433\u043E\u0434\u0430 \u043E\u043D
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435. 
    ### \U0001F52C \u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u0412\u043A\u043B\u0430\u0434 \u0424\u0435\u043B\u0438\u043A\u0441\u0430 \u041A\u043B\u0435\u0439\u043D\u0430
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u043E\u0433\u0440\u043E\u043C\u0435\u043D.
    \u041F\u043E\u043C\u0438\u043C\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \xAB\u042D\u0440\u043B\u0430\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u0439
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B\xBB, \u043A \u0435\u0433\u043E
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u043C \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u043C
    \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F:  *   **\u041D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:** \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043C\u043E\u0434\u0435\u043B\u044C \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 (\u043C\u043E\u0434\u0435\u043B\u044C
    \u041A\u043B\u0435\u0439\u043D\u0430), \u0434\u043E\u043A\u0430\u0437\u0430\u0432
    \u0435\u0451 \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0441\u0442\u044C
    \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435 \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u0439:**
    \u041E\u043D \u0432\u043D\u0451\u0441 \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0449\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u044B\u0445 \u0438 \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439, \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0432\u0448\u0438\u0439\u0441\u044F
    \u043C\u043D\u043E\u0433\u043E\u0442\u043E\u043C\u043D\u043E\u0439 \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u0435\u0439
    \u0441 \u0420\u043E\u0431\u0435\u0440\u0442\u043E\u043C \u0424\u0440\u0438\u043A\u0435.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0433\u0440\u0443\u043F\u043F:**
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u043E \u0441\u0432\u044F\u0437\u0438
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0443\u043F\u043F \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0441\u0442\u0430\u043B\u0430 \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C
    \u043A\u0430\u043C\u043D\u0435\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0435\u0439
    \u0440\u0430\u0431\u043E\u0442\u043E\u0439 \u043F\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u044E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u043F\u044F\u0442\u043E\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043A\u043E\u0441\u0430\u044D\u0434\u0440\u0430.
    *   **\u0422\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F:** \u041E\u043D
    \u043E\u043F\u0438\u0441\u0430\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    **\xAB\u0431\u0443\u0442\u044B\u043B\u043A\u0443 \u041A\u043B\u0435\u0439\u043D\u0430\xBB**
    \u2014 \u043E\u0434\u043D\u043E\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u044E\u044E
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C \u0431\u0435\u0437
    \u043A\u0440\u0430\u044F, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u043B\u0430
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u043C
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438.  \u0424\u0435\u043B\u0438\u043A\u0441
    \u041A\u043B\u0435\u0439\u043D \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0443\u0447\u0451\u043D\u044B\u043C; \u043E\u043D \u0431\u044B\u043B \u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438, \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u043C
    \u0435\u0451 \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u043E\u0432, \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u0439
    \u0438 \u0441\u0432\u044F\u0437\u0435\u0439 \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C\u0438 \u0437\u043D\u0430\u043D\u0438\u044F.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u0438 \u0440\u0430\u0431\u043E\u0442\u0430
    \u2014 \u044D\u0442\u043E \u043F\u0440\u0438\u043C\u0435\u0440 \u0442\u043E\u0433\u043E,
    \u043A\u0430\u043A \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u0443\u043C \u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u043C\u043E\u0433\u0443\u0442
    \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C \u043B\u0438\u0446\u043E \u0446\u0435\u043B\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0424\u0435\u043B\u0438\u043A\u0441 \u041A\u043B\u0435\u0439\u043D
    \u0431\u044B\u043B \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0439\u0441\u044F
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C\u044E, \u0438 \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C \u043F\u043E\u043B\u043D\u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u0435\u043B\u0438\u043A\u0438\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0441\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0439, \u043D\u043E \u0438 \u044F\u0440\u043A\u0438\u0445,
    \u0430 \u043F\u043E\u0440\u043E\u0439 \u0438 \u043A\u0443\u0440\u044C\u0451\u0437\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439. \u0412\u043E\u0442 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0437 \u043D\u0438\u0445, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0437\u0430\u043F\u043E\u043C\u043D\u0438\u043B\u0438\u0441\u044C.  ### \U0001F604
    \xAB\u0412\u0435\u043B\u0438\u043A\u0438\u0439 \u0424\u0435\u043B\u0438\u043A\u0441\xBB
    \u0438 \u0435\u0433\u043E \u0436\u0435\u043B\u0435\u0437\u043D\u0430\u044F \u0432\u043E\u043B\u044F 
    \u0412 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435, \u0433\u0434\u0435
    \u041A\u043B\u0435\u0439\u043D \u0431\u044B\u043B \u043D\u0435\u043F\u0440\u0435\u0440\u0435\u043A\u0430\u0435\u043C\u044B\u043C
    \u0430\u0432\u0442\u043E\u0440\u0438\u0442\u0435\u0442\u043E\u043C, \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B
    \u0441 \u043F\u043E\u0447\u0442\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0438\u0440\u043E\u043D\u0438\u0435\u0439 \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E **\xAB\u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u0424\u0435\u043B\u0438\u043A\u0441\xBB**.
    \u041E\u043D \u043E\u0431\u043B\u0430\u0434\u0430\u043B \u0445\u0430\u0440\u0438\u0437\u043C\u043E\u0439
    \u0438 \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u0435\u0439 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u0434\u043D\u0438\u043C \u0441\u043B\u043E\u0432\u043E\u043C
    \u043C\u043E\u0433 \u043A\u0430\u043A \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u043A\u0430\u0440\u044C\u0435\u0440\u0443 \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430, \u0442\u0430\u043A
    \u0438 \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0442\u044C \u0435\u0451. \u042D\u0442\u0430
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E\u0447\u0435\u043D\u044C \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u0430. 
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u0431\u0443\u0434\u0443\u0449\u0438\u0439
    \u043D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0438\u0439 \u043B\u0430\u0443\u0440\u0435\u0430\u0442
    **\u041C\u0430\u043A\u0441 \u0411\u043E\u0440\u043D** \u043E\u0441\u043C\u0435\u043B\u0438\u043B\u0441\u044F
    \u043F\u043E\u0439\u0442\u0438 \u043F\u0440\u043E\u0442\u0438\u0432 \u0432\u043E\u043B\u0438
    \u041A\u043B\u0435\u0439\u043D\u0430 \u0438 \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u043C
    \u043A\u043E\u043D\u043A\u0443\u0440\u0441\u0435. \u0414\u0440\u0443\u0437\u044C\u044F,
    \u043F\u0435\u0440\u0435\u043F\u0443\u0433\u0430\u0432\u0448\u0438\u0441\u044C
    \u0437\u0430 \u0435\u0433\u043E \u0431\u0443\u0434\u0443\u0449\u0435\u0435, \u0443\u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438
    \u0411\u043E\u0440\u043D\u0430 \u043F\u0435\u0440\u0435\u0434\u0443\u043C\u0430\u0442\u044C.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u043A\u043E\u0433\u0434\u0430 \u043E\u043D
    \u0441\u043E\u043E\u0431\u0449\u0438\u043B \u043E \u0441\u0432\u043E\u0451\u043C
    \u0440\u0435\u0448\u0435\u043D\u0438\u0438 \xAB\u0432\u0435\u043B\u0438\u043A\u043E\u043C\u0443
    \u0424\u0435\u043B\u0438\u043A\u0441\u0443\xBB, \u043C\u0435\u0436\u0434\u0443
    \u043D\u0438\u043C\u0438 \u0432\u043E\u0446\u0430\u0440\u0438\u043B\u0430\u0441\u044C
    \u043B\u0435\u0434\u044F\u043D\u0430\u044F \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0430. 
    \u0410\u043F\u043E\u0433\u0435\u0435\u043C \u0438\u0445 \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u044B\u0445
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0439 \u0441\u0442\u0430\u043B,
    \u043F\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C\u0443
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044E \u0411\u043E\u0440\u043D\u0430,
    \u0435\u0433\u043E \u0434\u043E\u043A\u043B\u0430\u0434 \u043F\u0435\u0440\u0435\u0434
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E\u043C. \u0412\u043E\u043B\u043D\u0443\u044F\u0441\u044C
    \u043E\u0442 \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0432\u0437\u0433\u043B\u044F\u0434\u043E\u0432 \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u0438,
    \u043E\u043D \u043F\u0440\u043E\u0432\u0430\u043B\u0438\u043B \u0432\u044B\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0435.
    \u041A\u043B\u0435\u0439\u043D \u0431\u044B\u043B \u0431\u0435\u0441\u043F\u043E\u0449\u0430\u0434\u0435\u043D:
    **\xAB\u0422\u0430\u043A\u043E\u0433\u043E \u043F\u043B\u043E\u0445\u043E\u0433\u043E
    \u0434\u043E\u043A\u043B\u0430\u0434\u0430 \u044F \u0435\u0449\u0451 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0441\u043B\u044B\u0448\u0430\u043B\xBB**. \u0411\u043E\u0440\u043D\u0430
    \u0441\u043F\u0430\u0441\u043B\u043E \u0437\u0430\u0441\u0442\u0443\u043F\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043A\u043E\u043B\u043B\u0435\u0433, \u0438 \u0435\u043C\u0443 \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043B\u0438
    \u043F\u043E\u0432\u0442\u043E\u0440\u0438\u0442\u044C \u0434\u043E\u043A\u043B\u0430\u0434.
    \u041D\u0430 \u044D\u0442\u043E\u0442 \u0440\u0430\u0437 \u0432\u044B\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0448\u043B\u043E \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435
    \u0438 \u043F\u043E\u043B\u043E\u0436\u0438\u043B\u043E \u043D\u0430\u0447\u0430\u043B\u043E
    \u0435\u0433\u043E \u0433\u043E\u043B\u043E\u0432\u043E\u043A\u0440\u0443\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u0435.  ### \U0001F9E0 \u0421\u043E\u043F\u0435\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0438 \xAB\u043A\u0440\u0430\u0436\u0430\xBB
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439  \u041E\u0434\u043D\u0438\u043C \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u044B\u0445
    \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432 \u0432 \u0436\u0438\u0437\u043D\u0438
    \u041A\u043B\u0435\u0439\u043D\u0430 \u0431\u044B\u043B\u043E \u0435\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u0441\u043E\u043F\u0435\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435. \u0412
    1882 \u0433\u043E\u0434\u0443 \u043E\u043D\u0438 \u043E\u0431\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438
    \u043D\u0430\u0434 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439, \u043F\u043E \u0441\u0443\u0442\u0438,
    \u0443\u0447\u0430\u0441\u0442\u0432\u0443\u044F \u0432 \u043D\u0430\u043F\u0440\u044F\u0436\u0451\u043D\u043D\u043E\u0439
    \u0433\u043E\u043D\u043A\u0435 \u0437\u0430 \u043F\u0435\u0440\u0432\u0435\u043D\u0441\u0442\u0432\u043E. 
    \u041A\u043B\u0435\u0439\u043D \u0441\u0443\u043C\u0435\u043B \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0442\u044C
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043D\u0435\u0434\u0435\u043B\u044C, \u0447\u0442\u043E \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u044B
    \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u044E\u0442 \u043A\u0430\u043A
    \xAB\u0442\u044F\u0436\u0435\u043B\u043E \u0437\u0430\u0432\u043E\u0451\u0432\u0430\u043D\u043D\u0443\u044E
    \u043F\u043E\u0431\u0435\u0434\u0443\xBB. \u0411\u043E\u043B\u0435\u0435 \u0442\u043E\u0433\u043E,
    \u0445\u043E\u0434\u0438\u043B\u0438 \u0441\u043B\u0443\u0445\u0438, \u0447\u0442\u043E
    \u041A\u043B\u0435\u0439\u043D \u043F\u0440\u0438\u0431\u0435\u0433\u043D\u0443\u043B
    \u043A \xAB\u043F\u0440\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u043E\u043C\u0443
    \u0448\u043F\u0438\u043E\u043D\u0430\u0436\u0443\xBB \u0438 \xAB\u0443\u043A\u0440\u0430\u043B\xBB
    \u0438\u0434\u0435\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435, \u0447\u0442\u043E\u0431\u044B
    \u043F\u0435\u0440\u0432\u044B\u043C \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u0439 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0446\u0435\u043D\u0430 \u044D\u0442\u043E\u0439
    \u043F\u043E\u0431\u0435\u0434\u044B \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C
    \u043D\u0435\u043F\u043E\u043C\u0435\u0440\u043D\u043E \u0432\u044B\u0441\u043E\u043A\u0430.
    \u0413\u043E\u043D\u043A\u0430 \u0438\u0441\u0442\u043E\u0449\u0438\u043B\u0430
    \u0435\u0433\u043E \u0434\u043E \u043F\u0440\u0435\u0434\u0435\u043B\u0430, \u0438
    \u0432 \u0442\u043E\u043C \u0436\u0435 1882 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043F\u0435\u0440\u0435\u0436\u0438\u043B **\u0442\u044F\u0436\u0451\u043B\u044B\u0439
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0438 \u043D\u0435\u0440\u0432\u043D\u044B\u0439
    \u0441\u0440\u044B\u0432**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0435\u0433\u043E\u0434\u043D\u044F
    \u043C\u044B \u043D\u0430\u0437\u0432\u0430\u043B\u0438 \u0431\u044B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u043C
    \u0432\u044B\u0433\u043E\u0440\u0430\u043D\u0438\u0435\u043C. \u041F\u043E\u0441\u043B\u0435
    \u044D\u0442\u043E\u0433\u043E \u041A\u043B\u0435\u0439\u043D \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0442\u043E\u0448\u0451\u043B \u043E\u0442 \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B, \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u0432\u0448\u0438\u0441\u044C
    \u043D\u0430 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u044E
    \u043D\u0430\u0443\u043A\u0438.  ### \U0001F5FF \xAB\u041A\u043B\u0435\u0439\u043D\xBB
    \u0437\u043D\u0430\u0447\u0438\u0442 \xAB\u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439\xBB:
    \u0448\u0443\u0442\u043A\u0438 \u043F\u0440\u043E \u0440\u043E\u0441\u0442  \u0424\u0430\u043C\u0438\u043B\u0438\u044F
    \u041A\u043B\u0435\u0439\u043D\u0430 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442
    \u043E\u0442 \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0433\u043E \u0441\u043B\u043E\u0432\u0430
    *klein*, \u0447\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442
    \xAB\u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439\xBB. \u042D\u0442\u0443
    \u0438\u0433\u0440\u0443 \u0441\u043B\u043E\u0432 \u043E\u0431\u043E\u0436\u0430\u043B\u0438
    \u0435\u0433\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438.
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043D\u0435\u0433\u043E,
    \u0435\u0433\u043E \u0434\u0440\u0443\u0433 \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0430,
    \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0421\u043E\u0444\u0443\u0441 \u041B\u0438, \u0431\u044B\u043B \u043E\u0447\u0435\u043D\u044C
    \u0432\u044B\u0441\u043E\u043A\u043E\u0433\u043E \u0440\u043E\u0441\u0442\u0430,
    \u0437\u0430 \u0447\u0442\u043E \u0435\u0433\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    \xAB\u0433\u0435\u0440\u043C\u0430\u043D\u0441\u043A\u0438\u043C \u0432\u0435\u043B\u0438\u043A\u0430\u043D\u043E\u043C\xBB.
    \u041C\u0435\u0436\u0434\u0443 \u043D\u0438\u043C\u0438 \u0447\u0430\u0441\u0442\u043E
    \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u043B\u0438 \u0434\u0440\u0443\u0436\u0435\u0441\u043A\u0438\u0435
    \u043F\u043E\u0434\u0442\u0440\u0443\u043D\u0438\u0432\u0430\u043D\u0438\u044F,
    \u0438 \u041A\u043B\u0435\u0439\u043D \u0441 \u044E\u043C\u043E\u0440\u043E\u043C
    \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0441\u044F \u043A \u0441\u0432\u043E\u0435\u043C\u0443
    \u043D\u0435\u0432\u044B\u0441\u043E\u043A\u043E\u043C\u0443 \u0440\u043E\u0441\u0442\u0443
    \u043D\u0430 \u0444\u043E\u043D\u0435 \u0434\u0440\u0443\u0433\u0430.  ### \U0001F3DB\uFE0F
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D vs \u0411\u0435\u0440\u043B\u0438\u043D:
    \u0438\u0433\u0440\u0430 \u043F\u0440\u0435\u0441\u0442\u043E\u043B\u043E\u0432 
    \u041A\u043B\u0435\u0439\u043D \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0443\u0447\u0451\u043D\u044B\u043C, \u043D\u043E \u0438 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u043C
    \xAB\u0438\u0433\u0440\u043E\u043A\u043E\u043C \u043F\u0440\u0435\u0441\u0442\u043E\u043B\u043E\u0432\xBB
    \u0432 \u043C\u0438\u0440\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0412 \u043A\u043E\u043D\u0446\u0435 XIX \u0432\u0435\u043A\u0430 \u043E\u0441\u0442\u0440\u043E
    \u0441\u043E\u043F\u0435\u0440\u043D\u0438\u0447\u0430\u043B\u0438 \u0434\u0432\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0448\u043A\u043E\u043B\u044B \u2014 \u0431\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0430\u044F
    \u0438 \u0433\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0430\u044F.
    \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0441\u0432\u044B\u0441\u043E\u043A\u0430 \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0438\u0441\u044C
    \u043A \u041A\u043B\u0435\u0439\u043D\u0443, \u0441\u0447\u0438\u0442\u0430\u044F
    \u0435\u0433\u043E \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u043D\u044B\u043C
    \xAB\u0444\u0430iseur\xBB (\u0444\u0440. \xAB\u043F\u043E\u0437\u0451\u0440,
    \u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044C \u0434\u0435\u043B\u0430\u0442\u044C
    \u0432\u0438\u0434\xBB). \u041A\u043B\u0435\u0439\u043D, \u0432 \u0441\u0432\u043E\u044E
    \u043E\u0447\u0435\u0440\u0435\u0434\u044C, \u0441\u0442\u0440\u043E\u0438\u043B
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435 \xAB\u0438\u043C\u043F\u0435\u0440\u0438\u044E\xBB,
    \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u0430\u044F \u043B\u0443\u0447\u0448\u0438\u0435
    \u0443\u043C\u044B \u0441\u043E \u0432\u0441\u0435\u0433\u043E \u043C\u0438\u0440\u0430,
    \u0438 \u0432 \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C \u0441\u0447\u0451\u0442\u0435
    \u0438\u043C\u0435\u043D\u043D\u043E \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D
    \u0441\u0442\u0430\u043B \u043C\u0438\u0440\u043E\u0432\u044B\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0446\u0435\u043D\u0442\u0440\u043E\u043C. \u042D\u0442\u0443 \u043F\u043E\u0431\u0435\u0434\u0443
    \u043E\u043D \u043E\u0434\u0435\u0440\u0436\u0430\u043B \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0441\u0432\u043E\u0435\u043C\u0443
    \u0442\u0430\u043B\u0430\u043D\u0442\u0443 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440\u0430
    \u0438 \u0441\u0435\u0442\u0435\u0432\u0438\u043A\u0430.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466
    \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C: \u0422\u0440\u0443\u0434\u043E\u0433\u043E\u043B\u0438\u043A
    \u0438 \u0441\u0435\u043C\u044C\u044F  \u041A\u043B\u0435\u0439\u043D \u0431\u044B\u043B
    \u043E\u0434\u0435\u0440\u0436\u0438\u043C \u0440\u0430\u0431\u043E\u0442\u043E\u0439.
    \u0412 \u0441\u0432\u043E\u0438 \xAB\u0437\u043E\u043B\u043E\u0442\u044B\u0435
    \u0433\u043E\u0434\u044B\xBB \u043E\u043D \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B, \u0447\u0442\u043E
    \u0435\u043C\u0443 \u043D\u0443\u0436\u043D\u043E \u0434\u0435\u043B\u0430\u0442\u044C
    \u0431\u043E\u043B\u044C\u0448\u0435 \u0438 \u043D\u0435 \u0434\u0430\u0432\u0430\u0442\u044C
    \u0441\u0435\u0431\u0435 \u043E\u0442\u0434\u044B\u0445\u0430. \u041E\u043D \u0431\u044B\u043B
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C **\u0442\u0440\u0443\u0434\u043E\u0433\u043E\u043B\u0438\u043A\u043E\u043C**,
    \u0438 \u044D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u043F\u0440\u0438\u0447\u0438\u043D \u0435\u0433\u043E \u0438\u0441\u0442\u043E\u0449\u0435\u043D\u0438\u044F.
    \u041E \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043D\u0435\u043C\u043D\u043E\u0433\u043E,
    \u0438\u0431\u043E, \u043A\u0430\u043A \u043E\u0442\u043C\u0435\u0447\u0430\u044E\u0442
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u044B, \u043E\u043D\u0430 \u0447\u0430\u0441\u0442\u043E
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C \u0432\u043D\u0435
    \u043F\u043E\u043B\u044F \u0437\u0440\u0435\u043D\u0438\u044F \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439,
    \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0435\u043D\u043D\u044B\u0445
    \u043D\u0430 \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. 
    \u0422\u0435\u043C \u043D\u0435 \u043C\u0435\u043D\u0435\u0435, \u0432 1875 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u0410\u043D\u043D\u0435
    \u0413\u0435\u0433\u0435\u043B\u044C**, \u0432\u043D\u0443\u0447\u043A\u0435
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430
    \u0413\u0435\u043E\u0440\u0433\u0430 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u0430
    \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430 \u0413\u0435\u0433\u0435\u043B\u044F.
    \u0423 \u043D\u0438\u0445 \u0431\u044B\u043B\u043E \u0447\u0435\u0442\u0432\u0435\u0440\u043E
    \u0434\u0435\u0442\u0435\u0439: \u041E\u0442\u0442\u043E, \u041B\u0443\u0438\u0437\u0430,
    \u0421\u043E\u0444\u0438 (\u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u0432
    \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0435) \u0438 \u042D\u043B\u0438\u0437\u0430\u0431\u0435\u0442.
    \u042D\u0442\u043E \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442,
    \u0447\u0442\u043E, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430
    \u0441\u0432\u043E\u044E \u043F\u043E\u0433\u043B\u043E\u0449\u0451\u043D\u043D\u043E\u0441\u0442\u044C
    \u043D\u0430\u0443\u043A\u043E\u0439, \u0443 \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u0430
    \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u0430\u044F \u0441\u0435\u043C\u0435\u0439\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C.  ### \U0001F4DC \u041F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438: \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u044F
    \u043D\u0430\u0446\u0438\u0441\u0442\u043E\u0432  \u0421\u0430\u043C\u044B\u0439
    \u043C\u0440\u0430\u0447\u043D\u044B\u0439 \u043A\u0443\u0440\u044C\u0451\u0437
    \u0441\u043B\u0443\u0447\u0438\u043B\u0441\u044F \u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u041A\u043B\u0435\u0439\u043D\u0430. \u0412
    1933 \u0433\u043E\u0434\u0443, \u0447\u0435\u0440\u0435\u0437 \u0432\u043E\u0441\u0435\u043C\u044C
    \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u043A\u043E\u043D\u0447\u0438\u043D\u044B,
    \u043D\u0430\u0446\u0438\u0441\u0442\u0441\u043A\u0438\u0439 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    **\u0425\u0443\u0433\u043E \u0414\u0438\u043D\u0433\u043B\u0435\u0440** \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0434\u043E\u043D\u043E\u0441, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043E\u0431\u0432\u0438\u043D\u0438\u043B \u041A\u043B\u0435\u0439\u043D\u0430
    \u0432 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u0438 **\xAB\u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0433\u043E
    \u0437\u0430\u0433\u043E\u0432\u043E\u0440\u0430\xBB** \u0441 \u0446\u0435\u043B\u044C\u044E
    \u0437\u0430\u0445\u0432\u0430\u0442\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0414\u0438\u043D\u0433\u043B\u0435\u0440 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u041A\u043B\u0435\u0439\u043D \u0443\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u043E
    \u0441\u043E\u0437\u0434\u0430\u043B \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435
    \u0446\u0435\u043D\u0442\u0440 \u0434\u043B\u044F \u043F\u0440\u0438\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F
    \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u0438\u0445 \u0438 \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0445
    \u0443\u0447\u0451\u043D\u044B\u0445, \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0432
    \xAB\u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0435 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435\xBB
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u0432 \u043F\u043E
    \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438, \u0438 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B
    \u0434\u0438\u043A\u0442\u0430\u0442\u0443\u0440\u0443 \u043D\u0430\u0434 \u0432\u0441\u0435\u043C\u0438
    \u0432\u0430\u0436\u043D\u044B\u043C\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438
    \u0436\u0443\u0440\u043D\u0430\u043B\u0430\u043C\u0438 \u0438 \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F\u043C\u0438.
    \u0411\u043E\u043B\u0435\u0435 \u0442\u043E\u0433\u043E, \u043E\u043D \u043E\u0431\u0432\u0438\u043D\u0438\u043B
    \u041A\u043B\u0435\u0439\u043D\u0430 \u0432 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u043C
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0438.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0430\u0431\u0441\u0443\u0440\u0434\u043D\u043E\u0441\u0442\u044C
    \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u0439 (\u041A\u043B\u0435\u0439\u043D
    \u0441\u043F\u0430\u0441 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0438 \u043F\u0440\u0438\u0432\u043B\u0451\u043A
    \u0432 \u043D\u0435\u0451 \u0432\u0435\u0441\u044C \u0446\u0432\u0435\u0442 \u043D\u0430\u0443\u043A\u0438,
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E \u043E\u0442 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F),
    \u044D\u0442\u043E\u0442 \u0444\u0430\u043A\u0442 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442,
    \u043A\u0430\u043A\u0443\u044E \u043E\u0433\u0440\u043E\u043C\u043D\u0443\u044E
    \u0440\u043E\u043B\u044C \u043E\u043D \u0438\u0433\u0440\u0430\u043B \u0432 \u043D\u0430\u0443\u043A\u0435,
    \u0435\u0441\u043B\u0438 \u0434\u0430\u0436\u0435 \u043D\u0430\u0446\u0438\u0441\u0442\u044B
    \u0441\u043F\u0443\u0441\u0442\u044F \u0433\u043E\u0434\u044B \u043F\u044B\u0442\u0430\u043B\u0438\u0441\u044C
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u0430\u0442\u044C \u0438\u0441\u0442\u043E\u0440\u0438\u044E,
    \u043F\u0440\u0438\u043F\u0438\u0441\u0430\u0432 \u0435\u043C\u0443 \u0441\u0432\u043E\u0438
    \u0438\u0434\u0435\u0438 \u043E \xAB\u043C\u0438\u0440\u043E\u0432\u043E\u043C
    \u0437\u0430\u0433\u043E\u0432\u043E\u0440\u0435\xBB. \u041F\u043E\u0441\u043B\u0435
    \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438 \u0432\u043B\u0430\u0441\u0442\u0438
    \u043D\u0435 \u043D\u0430\u0448\u043B\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u044F\u043C, \u0438 \u043F\u043E\u0440\u0442\u0440\u0435\u0442
    \u041A\u043B\u0435\u0439\u043D\u0430 \u043D\u0435 \u0431\u044B\u043B \u0441\u043D\u044F\u0442,
    \u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043D\u0435\u043C\u044B\u043C
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0435\u0433\u043E \u0432\u0435\u043B\u0438\u0447\u0438\u044F.  ### \U0001F3C6
    \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438 \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u044F 
    \u0414\u0430\u0432\u0438\u0434 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u041A\u043B\u0435\u0439\u043D
    \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D,
    \u0441\u043A\u0430\u0437\u0430\u043B \u043E \u043D\u0451\u043C \u043D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
    \u0434\u0435\u043D\u044C \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438:
    **\xAB\u0412\u0441\u0451, \u0447\u0442\u043E \u0432\u044B \u0437\u0434\u0435\u0441\u044C
    \u0432\u0438\u0434\u0438\u0442\u0435 \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435,
    \u2014 \u0434\u0435\u043B\u043E \u0440\u0443\u043A \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438
    [...] \u0421\u0435\u043A\u0440\u0435\u0442 \u0443\u0441\u043F\u0435\u0445\u0430
    \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0441\u044F \u0432 \u0435\u0433\u043E
    \u043D\u0435\u043F\u043E\u0434\u043A\u0443\u043F\u043D\u043E\u0439 \u043E\u0431\u044A\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438.
    \u0412\u0435\u043B\u0438\u043A\u0438\u0435 \u0446\u0435\u043B\u0438, \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u2014 \u043C\u0435\u043B\u044C\u0447\u0430\u0439\u0448\u0438\u0435 \u043B\u0438\u0447\u043D\u044B\u0435
    \u043F\u043E\u0431\u0443\u0436\u0434\u0435\u043D\u0438\u044F [...]\xBB**.  \u042D\u0442\u043E
    \u0441\u0430\u043C\u043E\u0435 \u0442\u043E\u0447\u043D\u043E\u0435 \u0438 \u043B\u0430\u043A\u043E\u043D\u0438\u0447\u043D\u043E\u0435
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435 \u0442\u043E\u0433\u043E, \u043A\u0435\u043C
    \u0431\u044B\u043B \u0424\u0435\u043B\u0438\u043A\u0441 \u041A\u043B\u0435\u0439\u043D
    \u0434\u043B\u044F \u043D\u0430\u0443\u043A\u0438. \u041D\u0430 \u0435\u0433\u043E
    \u043C\u043E\u0433\u0438\u043B\u0435 \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u0438 \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438
    \u043F\u0440\u043E\u0441\u0442\u0443\u044E, \u043D\u043E \u043E\u0447\u0435\u043D\u044C
    \u0451\u043C\u043A\u0443\u044E \u043D\u0430\u0434\u043F\u0438\u0441\u044C: **\xAB\u0424\u0435\u043B\u0438\u043A\u0441
    \u041A\u043B\u0435\u0439\u043D. \u0414\u0440\u0443\u0433. \u0418\u0441\u043A\u0440\u0435\u043D\u043D\u0438\u0439
    \u0438 \u043D\u0435\u0438\u0437\u043C\u0435\u043D\u043D\u044B\u0439\xBB**."
