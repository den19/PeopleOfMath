  achievementsRu: "\u041B\u0430\u0441\u043B\u043E \u041B\u043E\u0432\u0430\u0441
    \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u0447\u044C\u0438
    \u0440\u0430\u0431\u043E\u0442\u044B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0440\u0435\u0448\u0438\u043B\u0438 \u0434\u0430\u0432\u043D\u0438\u0435 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B,
    \u043D\u043E \u0438 \u0441\u043E\u0437\u0434\u0430\u043B\u0438 \u0446\u0435\u043B\u044B\u0435
    \u043D\u043E\u0432\u044B\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043D\u0430
    \u0441\u0442\u044B\u043A\u0435 \u0434\u0438\u0441\u043A\u0440\u0435\u0442\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u0447\u0430\u0441\u0442\u043E
    \u0434\u0435\u043B\u044F\u0442 \u043D\u0430 \u0442\u0440\u0438 \u0432\u0437\u0430\u0438\u043C\u043E\u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0435
    \u0441\u0444\u0435\u0440\u044B: \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F, \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043F\u0440\u043E\u0440\u044B\u0432\u043D\u044B\u0445 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432
    \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0443 \u043C\u043E\u0449\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u0435\u0442\u043E\u0434\u043E\u0432.  ### \U0001F52D \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0430\u0444\u043E\u0432:
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447  \u0412 \u043D\u0430\u0447\u0430\u043B\u0435 1970-\u0445
    \u0433\u043E\u0434\u043E\u0432, \u043A\u043E\u0433\u0434\u0430 \u0442\u0435\u043E\u0440\u0438\u044F
    \u0433\u0440\u0430\u0444\u043E\u0432 \u0435\u0449\u0435 \u0441\u0447\u0438\u0442\u0430\u043B\u0430\u0441\u044C
    \u043F\u0435\u0440\u0438\u0444\u0435\u0440\u0438\u0439\u043D\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u044C\u044E,
    \u041B\u043E\u0432\u0430\u0441 \u0440\u0435\u0448\u0438\u043B \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0437\u0430\u0434\u0430\u0447, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0438
    \u0435\u043C\u0443 \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438
    \u044D\u0442\u0443 \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0443. 
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u044B\u0445
    \u0433\u0440\u0430\u0444\u0430\u0445 (1972 \u0433\u043E\u0434)**: \u0415\u0433\u043E
    \u043F\u0435\u0440\u0432\u043E\u0435 \u043A\u0440\u0443\u043F\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435. \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443, \u0434\u043E\u043B\u0433\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u043E\u0441\u0442\u0430\u0432\u0430\u0432\u0448\u0443\u044E\u0441\u044F
    \u043D\u0435\u0440\u0435\u0448\u0435\u043D\u043D\u043E\u0439, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442 \u0433\u0440\u0430\u0444\u044B
    \u0441 \u043E\u0441\u043E\u0431\u044B\u043C \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C
    \u2014 \u0432 \u043D\u0438\u0445 \u0445\u0440\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E \u043B\u044E\u0431\u043E\u0433\u043E \u043F\u043E\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u043E\u0434\u0433\u0440\u0430\u0444\u0430 \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u0435\u0442
    \u0441 \u0440\u0430\u0437\u043C\u0435\u0440\u043E\u043C \u0435\u0433\u043E \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u043A\u043B\u0438\u043A\u0438. \u042D\u0442\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0441\u0440\u0430\u0437\u0443 \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B\u043E
    \u0435\u0433\u043E \u0432 \u043F\u0435\u0440\u0432\u044B\u0439 \u0440\u044F\u0434
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u043C\u0438\u0440\u0430.
    *   **\u0401\u043C\u043A\u043E\u0441\u0442\u044C \u0428\u0435\u043D\u043D\u043E\u043D\u0430
    \u043F\u044F\u0442\u0438\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430
    (1979 \u0433\u043E\u0434)**: \u041B\u043E\u0432\u0430\u0441 \u0440\u0435\u0448\u0438\u043B
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0437\u0430\u0434\u0430\u0447\u0443
    \u0438\u0437 \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438,
    \u043D\u0430\u0439\u0434\u044F \u0442\u043E\u0447\u043D\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0451\u043C\u043A\u043E\u0441\u0442\u0438 \u0428\u0435\u043D\u043D\u043E\u043D\u0430
    \u0434\u043B\u044F \u0433\u0440\u0430\u0444\u0430-\u043F\u044F\u0442\u0438\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430.
    \u0412 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0435 \u043E\u043D \u0432\u0432\u0435\u043B
    \u043D\u043E\u0432\u0443\u044E \u043C\u0435\u0440\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0442\u0435\u043F\u0435\u0440\u044C \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u043A\u0430\u043A **\u0447\u0438\u0441\u043B\u043E \u041B\u043E\u0432\u0430\u0441\u0430
    (\u0438\u043B\u0438 \u0442\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u044F
    \u041B\u043E\u0432\u0430\u0441\u0430)** \u2014 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0439
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442 \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0433\u0440\u0430\u0444\u043E\u0432 \u0438 \u043E\u043F\u0442\u0438\u043C\u0438\u0437\u0430\u0446\u0438\u0438.
    *   **\u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430 \u041A\u043D\u0435\u0437\u0435\u0440\u0430**:
    \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u044D\u0442\u0443 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u0438\u0437 \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0430\u0444\u043E\u0432,
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u0432 \u043C\u0435\u0442\u043E\u0434\u044B
    \u0438\u0437 **\u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438** \u2014 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u0434\u0440\u0443\u0433\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u042D\u0442\u043E\u0442
    \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0439 \u0438 \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u044B\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434 \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0449\u0438\u0445
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432 \u0432 \u0437\u0430\u0440\u043E\u0436\u0434\u0430\u044E\u0449\u0435\u0439\u0441\u044F
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0435. 
    ### \U0001F9EE \u0410\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u044B: \u043C\u043E\u0441\u0442
    \u043C\u0435\u0436\u0434\u0443 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u0438
    \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u043C \u043C\u0438\u0440\u043E\u043C 
    \u0413\u043B\u0430\u0432\u043D\u0430\u044F \u0437\u0430\u0441\u043B\u0443\u0433\u0430
    \u041B\u043E\u0432\u0430\u0441\u0430 \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E
    \u043E\u043D \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u0432 \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0435 \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B, \u043F\u043E\u043A\u0430\u0437\u0430\u0432,
    \u043A\u0430\u043A \u0434\u0438\u0441\u043A\u0440\u0435\u0442\u043D\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u043C\u043E\u0436\u0435\u0442
    \u0440\u0435\u0448\u0430\u0442\u044C \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438.  *   **LLL-\u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    (\u0410\u043B\u0433\u043E\u0440\u0438\u0442\u043C \u041B\u0435\u043D\u0441\u0442\u0440\u044B
    \u2014 \u041B\u0435\u043D\u0441\u0442\u0440\u044B \u2014 \u041B\u043E\u0432\u0430\u0441\u0430)**:
    \u0421\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C \u0435\u0433\u043E \u0438\u043C\u0435\u043D\u0438,
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u043D\u044B\u0439
    \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u0431\u0440\u0430\u0442\u044C\u044F\u043C\u0438
    \u041B\u0435\u043D\u0441\u0442\u0440\u0430. \u042D\u0442\u043E \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    \u0440\u0435\u0434\u0443\u043A\u0446\u0438\u0438 \u0431\u0430\u0437\u0438\u0441\u0430
    \u0432 \u0446\u0435\u043B\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445
    \u0440\u0435\u0448\u0435\u0442\u043A\u0430\u0445.     *   **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435**:
    \u041E\u043D \u0441\u0442\u0430\u043B \"\u0448\u0432\u0435\u0439\u0446\u0430\u0440\u0441\u043A\u0438\u043C
    \u043D\u043E\u0436\u043E\u043C\" \u0434\u043B\u044F \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438.
    \u0421 \u043E\u0434\u043D\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B,
    \u0435\u0433\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442
    \u043A\u0440\u0438\u043F\u0442\u043E\u0430\u043D\u0430\u043B\u0438\u0442\u0438\u043A\u0438
    \u0434\u043B\u044F \u0432\u0437\u043B\u043E\u043C\u0430 \u0441\u0442\u0430\u0440\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C. \u0421 \u0434\u0440\u0443\u0433\u043E\u0439
    \u2014 \u043D\u0430 \u043D\u0435\u043C \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u044B
    **\u043F\u043E\u0441\u0442\u043A\u0432\u0430\u043D\u0442\u043E\u0432\u044B\u0435
    \u043A\u0440\u0438\u043F\u0442\u043E\u0441\u0438\u0441\u0442\u0435\u043C\u044B**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u0447\u0438\u0442\u0430\u044E\u0442\u0441\u044F
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B\u043C\u0438 \u0432\u044B\u0434\u0435\u0440\u0436\u0430\u0442\u044C
    \u0430\u0442\u0430\u043A\u0438 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u044B\u0445
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u0432. \u0415\u0433\u043E
    \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u044E\u0442
    \u0434\u043B\u044F \u0444\u0430\u043A\u0442\u043E\u0440\u0438\u0437\u0430\u0446\u0438\u0438
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432 \u0438 \u0432
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B. *   **\u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u0432 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0430\u0445 \u043E\u043F\u0442\u0438\u043C\u0438\u0437\u0430\u0446\u0438\u0438**:
    \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u041C\u0430\u0440\u0442\u0438\u043D\u043E\u043C
    \u0413\u0440\u0451\u0442\u0448\u0435\u043B\u0435\u043C \u0438 \u041B\u0435\u043A\u0441\u043E\u043C
    \u0428\u0440\u0435\u0439\u0432\u0435\u0440\u043E\u043C \u043E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u043A\u0430\u043A \u0437\u0430\u0434\u0430\u0447\u0438 \u043F\u043E\u043B\u0443\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u043C\u043E\u0436\u043D\u043E \u0440\u0435\u0448\u0430\u0442\u044C \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E,
    \u0447\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u043E \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u0434\u0438\u0437\u0430\u0439\u043D\u0435 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432. 
    ### \U0001F3B2 \u0412\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u043D\u044B\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u0438 \u0442\u0435\u043E\u0440\u0438\u044F
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438  \u041B\u043E\u0432\u0430\u0441
    \u0432\u043D\u0435\u0441 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u043E, \u043A\u0430\u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442 \u0441\u043E \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0441\u0442\u044C\u044E
    \u0438 \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C\u044E.  *   **\u041B\u043E\u043A\u0430\u043B\u044C\u043D\u0430\u044F
    \u043B\u0435\u043C\u043C\u0430 \u041B\u043E\u0432\u0430\u0441\u0430 (\u041B\u041B\u041B)**:
    \u042D\u0442\u043E \u043C\u043E\u0449\u043D\u0435\u0439\u0448\u0438\u0439 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442
    \u0432 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u043D\u043E\u0439
    \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0435.
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u043E\u0433\u043E
    \u043C\u0435\u0442\u043E\u0434\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442, \u043A\u043E\u0433\u0434\u0430
    \u043D\u0443\u0436\u043D\u044B\u0439 \u043E\u0431\u044A\u0435\u043A\u0442 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0435\u0442\u0441\u044F
    \u0447\u0430\u0441\u0442\u043E, \u043B\u0435\u043C\u043C\u0430 \u041B\u043E\u0432\u0430\u0441\u0430
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u043E\u0447\u0435\u043D\u044C \u0440\u0435\u0434\u043A\u0438\u0445 \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432,
    \u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0433\u043E\u0440\u0430\u0437\u0434\u043E
    \u0431\u043E\u043B\u0435\u0435 \u0441\u043B\u043E\u0436\u043D\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0435\u0439.
    *   **\u0412\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E
    PCP**: \u0412\u043C\u0435\u0441\u0442\u0435 \u0441 \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u0430\u043C\u0438
    \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u0430\u0434 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u043D\u043E \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0435\u043C\u044B\u0445
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    (PCP). \u042D\u0442\u043E\u0442 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442,
    \u043B\u0435\u0436\u0430\u0449\u0438\u0439 \u0432 \u043E\u0441\u043D\u043E\u0432\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438, \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442,
    \u0447\u0442\u043E \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
    \u0441 \u0432\u044B\u0441\u043E\u043A\u043E\u0439 \u043D\u0430\u0434\u0435\u0436\u043D\u043E\u0441\u0442\u044C\u044E,
    \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u0432 \u043B\u0438\u0448\u044C \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0435\u0433\u043E \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u0432.  ### \U0001F30C
    \u041D\u043E\u0432\u0430\u044F \u0433\u043B\u0430\u0432\u0430: \u0442\u0435\u043E\u0440\u0438\u044F
    \u043F\u0440\u0435\u0434\u0435\u043B\u043E\u0432 \u0433\u0440\u0430\u0444\u043E\u0432 
    \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u041B\u043E\u0432\u0430\u0441 (\u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u041A\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u043E\u043C
    \u0411\u043E\u0440\u0433\u0441\u043E\u043C, \u0414\u0436\u0435\u043D\u043D\u0438\u0444\u0435\u0440
    \u0427\u0435\u0439\u0435\u0441, \u0412\u0435\u0440\u043E\u0439 \u0428\u043E\u0448,
    \u0411\u0430\u043B\u0430\u0436\u0435\u043C \u0421\u0435\u0433\u0435\u0434\u0438
    \u0438 \u0441\u0432\u043E\u0435\u0439 \u0436\u0435\u043D\u043E\u0439 \u041A\u0430\u0442\u0430\u043B\u0438\u043D
    \u0412\u0435\u0441\u0442\u0435\u0440\u0433\u043E\u043C\u0431\u0438) \u0440\u0430\u0437\u0432\u0438\u043B
    **\u0442\u0435\u043E\u0440\u0438\u044E \u043F\u0440\u0435\u0434\u0435\u043B\u043E\u0432
    \u0433\u0440\u0430\u0444\u043E\u0432**. \u042D\u0442\u043E \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u043D\u043E\u0432\u043E\u0435 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0443\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442
    \u0441\u0432\u044F\u0437\u0438 \u043C\u0435\u0436\u0434\u0443 \u044D\u043A\u0441\u0442\u0440\u0435\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u0433\u0440\u0430\u0444\u043E\u0432,
    \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439
    \u0438 \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u043E\u0439, \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044F
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0435
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B, \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u044E\u0449\u0438\u0435
    \u043A\u0430\u043A \u043F\u0440\u0435\u0434\u0435\u043B\u044B \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0435\u0439
    \u0431\u043E\u043B\u044C\u0448\u0438\u0445 \u0433\u0440\u0430\u0444\u043E\u0432. 
    ### \U0001F4DA \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B 
    \u041B\u0430\u0441\u043B\u043E \u041B\u043E\u0432\u0430\u0441 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0430\u0432\u0442\u043E\u0440\u043E\u043C \u0438 \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u043E\u043C
    \u0431\u043E\u043B\u0435\u0435 300 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0441\u0442\u0430\u0442\u0435\u0439 \u0438 11 \u043A\u043D\u0438\u0433, \u043C\u043D\u043E\u0433\u0438\u0435
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u0442\u0430\u043B\u0438
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0430\u043C\u0438. \u0421\u0440\u0435\u0434\u0438
    \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445: 
    *   **\"Combinatorial Problems and Exercises\"** \u2014 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0437\u0430\u0434\u0430\u0447\u043D\u0438\u043A \u043F\u043E \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0435,
    \u0432\u044B\u0434\u0435\u0440\u0436\u0430\u0432\u0448\u0438\u0439 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043F\u0435\u0440\u0435\u0438\u0437\u0434\u0430\u043D\u0438\u0439. *   **\"Matching
    Theory\"** (\u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u041C.\u0414.
    \u041F\u043B\u0430\u043C\u043C\u0435\u0440\u043E\u043C) \u2014 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0440\u0443\u0434 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u0430\u0440\u043E\u0441\u043E\u0447\u0435\u0442\u0430\u043D\u0438\u0439,
    \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043D\u043D\u044B\u0439 \u043D\u0430
    \u0440\u0443\u0441\u0441\u043A\u0438\u0439 \u044F\u0437\u044B\u043A \u043A\u0430\u043A
    **\"\u041F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0430\u0444\u043E\u0432. \u0422\u0435\u043E\u0440\u0438\u044F
    \u043F\u0430\u0440\u043E\u0441\u043E\u0447\u0435\u0442\u0430\u043D\u0438\u0439
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0444\u0438\u0437\u0438\u043A\u0435,
    \u0445\u0438\u043C\u0438\u0438\"**. *   **\"Discrete Mathematics: Elementary
    and Beyond\"** \u2014 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0435
    \u0432\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0432 \u0434\u0438\u0441\u043A\u0440\u0435\u0442\u043D\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443."
  achievementsEn: 
  personalLifeRu: "\u041B\u0430\u0441\u043B\u043E \u041B\u043E\u0432\u0430\u0441
    \u0436\u0438\u0432 \u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    \u043F\u043E \u0441\u0435\u0439 \u0434\u0435\u043D\u044C (\u0435\u043C\u0443
    78 \u043B\u0435\u0442, \u043E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    9 \u043C\u0430\u0440\u0442\u0430 1948 \u0433\u043E\u0434\u0430). \u041E\u043D
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u043D\u0430\u0443\u043A\u043E\u0439, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0432 2025 \u0433\u043E\u0434\u0443 \u043C\u0435\u0434\u0430\u043B\u044C \u042D\u0440\u0430\u0437\u043C\u0430
    \u2014 \u043E\u0434\u043D\u0443 \u0438\u0437 \u0432\u044B\u0441\u0448\u0438\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434 \u0415\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438.  \u041D\u0438\u0436\u0435 \u2014
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u0438, \u0443\u0447\u0451\u0431\u044B \u0438 \u0432\u0437\u0430\u0438\u043C\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0439
    \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438.  ### \U0001F476
    \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435, \u0434\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u0448\u0430\u0433\u0438 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 
    \u041B\u0430\u0441\u043B\u043E \u041B\u043E\u0432\u0430\u0441 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0411\u0443\u0434\u0430\u043F\u0435\u0448\u0442\u0435, \u0412\u0435\u043D\u0433\u0440\u0438\u044F.
    \u0415\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0430\u043B\u0430\u043D\u0442 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u043E\u0447\u0435\u043D\u044C \u0440\u0430\u043D\u043E:  *   **\u0421\u0440\u0435\u0434\u043D\u044F\u044F
    \u0448\u043A\u043E\u043B\u0430**: \u0423\u0447\u0438\u043B\u0441\u044F \u0432
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043A\u043B\u0430\u0441\u0441\u0435 **Fazekas Mih\xE1ly Gimn\xE1zium**, \u043A\u0443\u0434\u0430
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u043F\u043E \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u0438
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F. \u042D\u0442\u0430 \u0448\u043A\u043E\u043B\u0430
    \u0441\u0442\u0430\u043B\u0430 \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0438
    \u0435\u0433\u043E \u0441\u0432\u0435\u0440\u0441\u0442\u043D\u0438\u043A\u043E\u0432
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u0440\u0435\u0434\u043E\u0439:
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u0438\u0437 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u0438 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 \u0447\u0438\u0442\u0430\u043B\u0438
    \u0438\u043C \u043B\u0435\u043A\u0446\u0438\u0438, \u0438 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0443\u0447\u0435\u043D\u0438\u043A\u0438, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u041B\u043E\u0432\u0430\u0441\u0430, \u0443\u0436\u0435 \u0432 \u0448\u043A\u043E\u043B\u0435
    \u043D\u0430\u0447\u0430\u043B\u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u043E\u0439. *   **\u0418\u0441\u0442\u043E\u0447\u043D\u0438\u043A
    \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0435\u043D\u0438\u044F**: \u0412
    14 \u043B\u0435\u0442 \u043E\u043D \u043D\u0430\u0442\u043A\u043D\u0443\u043B\u0441\u044F
    \u043D\u0430 \u0441\u0442\u0430\u0442\u044C\u044E **\u041F\u0430\u043B\u0430
    \u042D\u0440\u0434\u0451\u0448\u0430** \u0432 \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0436\u0443\u0440\u043D\u0430\u043B\u0435 \u0434\u043B\u044F \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432.
    \u042D\u0442\u0430 \u0441\u0442\u0430\u0442\u044C\u044F \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0430
    \u043D\u0430 \u043D\u0435\u0433\u043E \u0442\u0430\u043A\u043E\u0435 \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u0438\u0435,
    \u0447\u0442\u043E \u043E\u043D \u043F\u0435\u0440\u0435\u0447\u0438\u0442\u0430\u043B
    \u0435\u0451 \xAB\u043A\u0430\u043A \u043C\u0438\u043D\u0438\u043C\u0443\u043C
    \u0434\u0432\u0430\u0434\u0446\u0430\u0442\u044C \u0440\u0430\u0437\xBB. \u0412
    1963 \u0433\u043E\u0434\u0443, \u0431\u0443\u0434\u0443\u0447\u0438 \u0441\u0442\u0430\u0440\u0448\u0435\u043A\u043B\u0430\u0441\u0441\u043D\u0438\u043A\u043E\u043C,
    \u043E\u043D \u043B\u0438\u0447\u043D\u043E \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B
    \u042D\u0440\u0434\u0451\u0448\u0430, \u0438 \u044D\u0442\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430
    \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0430
    \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u0439
    \u043F\u0443\u0442\u044C. *   **\u041E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u044B**:
    \u0421 1964 \u043F\u043E 1966 \u0433\u043E\u0434 \u041B\u043E\u0432\u0430\u0441
    \u0442\u0440\u0438\u0436\u0434\u044B \u043F\u043E\u0434\u0440\u044F\u0434 \u0432\u044B\u0438\u0433\u0440\u044B\u0432\u0430\u043B
    **\u0437\u043E\u043B\u043E\u0442\u044B\u0435 \u043C\u0435\u0434\u0430\u043B\u0438**
    \u043D\u0430 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u0435 (\u0432 1965 \u0438 1966
    \u0433\u043E\u0434\u0430\u0445 \u2014 \u0441 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u044B\u043C
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C). \u0414\u043E
    \u044D\u0442\u043E\u0433\u043E, \u0432 1963 \u0433\u043E\u0434\u0443, \u043E\u043D
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0435\u0440\u0435\u0431\u0440\u043E.
    *   **\u0422\u0435\u043B\u0435\u0432\u0438\u0437\u0438\u043E\u043D\u043D\u0430\u044F
    \u0438\u0433\u0440\u0430**: \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0438 \u043F\u043E\u0431\u0435\u0434\u0438\u043B \u0432 \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u043C
    \u0442\u0435\u043B\u0435\u0432\u0438\u0437\u0438\u043E\u043D\u043D\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0448\u043E\u0443, \u0433\u0434\u0435 \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u043E\u0432
    \u043F\u043E\u043C\u0435\u0449\u0430\u043B\u0438 \u0432 \u0441\u0442\u0435\u043A\u043B\u044F\u043D\u043D\u044B\u0435
    \u043A\u0430\u0431\u0438\u043D\u044B \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0437\u0430\u0434\u0430\u0447. \u0412 \u0444\u0438\u043D\u0430\u043B\u0435 \u043E\u043D
    \u0441\u043E\u0440\u0435\u0432\u043D\u043E\u0432\u0430\u043B\u0441\u044F \u0441\u043E
    \u0441\u0432\u043E\u0438\u043C \u0434\u0440\u0443\u0433\u043E\u043C \u041B\u0430\u0439\u043E\u0448\u0435\u043C
    \u041F\u043E\u0448\u0435\u0439. \u042D\u043F\u0438\u0437\u043E\u0434, \u043A\u043E\u0433\u0434\u0430
    \u043E\u043D \u043F\u0440\u0438\u043F\u0438\u0441\u0430\u043B \u043F\u043E\u0431\u0435\u0434\u0443
    \u0438\u0434\u0435\u0435, \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u043D\u043E\u0439
    \u0434\u0440\u0443\u0433\u043E\u043C, \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u0435\u0433\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440.  ### \U0001F393
    \u0423\u0447\u0451\u0431\u0430 \u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F  *   **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442**:
    \u041F\u043E\u0441\u043B\u0435 \u0448\u043A\u043E\u043B\u044B \u041B\u043E\u0432\u0430\u0441
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0411\u0443\u0434\u0430\u043F\u0435\u0448\u0442\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0438\u043C\u0435\u043D\u0438
    \u042D\u0442\u0432\u0451\u0448\u0430 \u041B\u043E\u0440\u0430\u043D\u0434\u0430.
    *   **\u0423\u0447\u0451\u043D\u0430\u044F \u0441\u0442\u0435\u043F\u0435\u043D\u044C**:
    \u0412 1970 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    22 \u043B\u0435\u0442, \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0430
    \u043D\u0430\u0443\u043A (C.Sc.) \u0432 \u0412\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A. \u042D\u0442\u043E
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E, \u0442\u0430\u043A
    \u043A\u0430\u043A \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0435 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u0430\u0433\u0430\u043B\u0438,
    \u0447\u0442\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442 \u0441\u043C\u043E\u0436\u0435\u0442
    \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u0442\u044C \u0440\u0430\u0431\u043E\u0442\u0443
    \u0442\u0430\u043A\u043E\u0433\u043E \u0443\u0440\u043E\u0432\u043D\u044F. \u041A
    \u0442\u043E\u043C\u0443 \u043C\u043E\u043C\u0435\u043D\u0442\u0443 \u0443 \u043D\u0435\u0433\u043E
    \u0431\u044B\u043B\u043E \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043E
    **15 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0441\u0442\u0430\u0442\u0435\u0439**.
    \u0412 1971 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    (Dr.Rer.Nat.) \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435.
    *   **\u041D\u0430\u0443\u0447\u043D\u044B\u0439 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C**:
    \u0415\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    **\u0422\u0438\u0431\u043E\u0440 \u0413\u0430\u043B\u043B\u0430\u0438**.  ###
    \U0001F9D1\u200D\U0001F3EB \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0438 \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u0435
    \u0441\u0432\u044F\u0437\u0438  \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u041B\u043E\u0432\u0430\u0441\u0430
    \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0441\u0442\u0440\u0430\u043D \u0438 \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0446\u0438\u0439: 
    *   **\u0412\u0435\u043D\u0433\u0440\u0438\u044F**: \u041F\u043E\u0441\u043B\u0435
    \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u0443\u0440\u044B \u043E\u043D
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 \u0411\u0443\u0434\u0430\u043F\u0435\u0448\u0442\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 (1971\u20131975),
    \u0437\u0430\u0442\u0435\u043C \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0421\u0435\u0433\u0435\u0434\u0430 (1975\u20131983), \u0433\u0434\u0435 \u0441\u0442\u0430\u043B
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0438 \u0437\u0430\u0432\u0435\u0434\u0443\u044E\u0449\u0438\u043C
    \u043A\u0430\u0444\u0435\u0434\u0440\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u0430 \u0432 1983 \u0433\u043E\u0434\u0443 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u0411\u0443\u0434\u0430\u043F\u0435\u0448\u0442 \u0443\u0436\u0435 \u043D\u0430
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0437\u0430\u0432\u0435\u0434\u0443\u044E\u0449\u0435\u0433\u043E
    \u043A\u0430\u0444\u0435\u0434\u0440\u043E\u0439 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0412 1979 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    31 \u0433\u043E\u0434\u0430, \u043E\u043D \u0441\u0442\u0430\u043B \u0441\u0430\u043C\u044B\u043C
    \u043C\u043E\u043B\u043E\u0434\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u0412\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u0437\u0430 \u0432\u0441\u044E \u0435\u0451 \u0438\u0441\u0442\u043E\u0440\u0438\u044E.
    *   **\u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u0439
    \u043E\u043F\u044B\u0442**: \u041E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u0421\u0428\u0410 \u2014 \u0431\u044B\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0432 **\u0419\u0435\u043B\u044C\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435**
    (1993\u20131999), \u0437\u0430\u0442\u0435\u043C \u0441\u0442\u0430\u0440\u0448\u0438\u043C
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0432 **Microsoft Research** (1999\u20132006). \u0412 1972\u20131973 \u0433\u043E\u0434\u0430\u0445
    \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B \u0441\u0442\u0430\u0436\u0438\u0440\u043E\u0432\u043A\u0443
    \u0432 **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0412\u0430\u043D\u0434\u0435\u0440\u0431\u0438\u043B\u044C\u0442\u0430**. *  
    **\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0438 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E**:
    \u0412 2006 \u0433\u043E\u0434\u0443 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u0412\u0435\u043D\u0433\u0440\u0438\u044E, \u0441\u0442\u0430\u0432 \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 \u0432 \u0411\u0443\u0434\u0430\u043F\u0435\u0448\u0442\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. \u0421
    2014 \u043F\u043E 2020 \u0433\u043E\u0434 \u0431\u044B\u043B \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u0412\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A.  ### \U0001F91D \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u041F\u0430\u043B\u043E\u043C \u042D\u0440\u0434\u0451\u0448\u0435\u043C
    \u0438 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0451\u043D\u044B\u043C\u0438 
    *   **\u0421 \u042D\u0440\u0434\u0451\u0448\u0435\u043C**: \u0418\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0431\u044B\u043B\u0438 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u044B\u043C\u0438.
    \u042D\u0440\u0434\u0451\u0448 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u043B \u041B\u043E\u0432\u0430\u0441\u0430,
    \u043D\u043E \u0438 \u0441\u0442\u0430\u043B \u0435\u0433\u043E \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u043E\u043C
    \u043F\u043E \u0448\u0435\u0441\u0442\u0438 \u0441\u0442\u0430\u0442\u044C\u044F\u043C.
    \u042D\u0442\u043E \u0434\u0430\u0451\u0442 \u041B\u043E\u0432\u0430\u0441\u0443
    **\u0447\u0438\u0441\u043B\u043E \u042D\u0440\u0434\u0451\u0448\u0430, \u0440\u0430\u0432\u043D\u043E\u0435
    1**. \u0421\u0430\u043C \u041B\u043E\u0432\u0430\u0441 \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B,
    \u0447\u0442\u043E \u042D\u0440\u0434\u0451\u0448 \u043D\u0430\u0443\u0447\u0438\u043B
    \u0435\u0433\u043E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u043D\u043E \u0438 \xAB\u043F\u043E\u043B\u043D\u043E\u0439 \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0441\u0442\u0438
    \u0432 \u0437\u0430\u0434\u0430\u0447\u0430\u0445 \u0438 \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u044B\u0445
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430\u0445\xBB, \u0447\u0442\u043E
    \u043D\u0435\u0438\u0437\u0431\u0435\u0436\u043D\u043E \u0432\u0435\u0434\u0451\u0442
    \u043A \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0443.
    *   **\u0421 \u0436\u0435\u043D\u043E\u0439**: \u0415\u0433\u043E \u0436\u0435\u043D\u0430,
    **\u041A\u0430\u0442\u0430\u043B\u0438\u043D \u0412\u0435\u0441\u0442\u0435\u0440\u0433\u043E\u043C\u0431\u0438**
    (Katalin Vesztergombi), \u0442\u043E\u0436\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A.
    \u041E\u043D\u0438 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0438\u0441\u044C
    \u0435\u0449\u0451 \u0432 \u0448\u043A\u043E\u043B\u0435, \u0433\u0434\u0435
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u0432 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0435 \u0434\u043B\u044F
    \u043E\u0434\u0430\u0440\u0451\u043D\u043D\u044B\u0445 \u0434\u0435\u0442\u0435\u0439.
    \u041E\u043D\u0438 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0443\u043F\u0440\u0443\u0433\u0438,
    \u043D\u043E \u0438 \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0438\u0435
    \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u044B. *   **\u0412 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0440\u0435\u0434\u0435**: \u041A\u043E\u043B\u043B\u0435\u0433\u0438
    \u0438 \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u044B \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442
    \u041B\u043E\u0432\u0430\u0441\u0430 \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \xAB\u043D\u0430\u0432\u043E\u0434\u0438\u0442
    \u043C\u043E\u0441\u0442\u044B\xBB \u043C\u0435\u0436\u0434\u0443 \u0440\u0430\u0437\u043D\u044B\u043C\u0438
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0410\u0432\u0438 \u0412\u0438\u0433\u0434\u0435\u0440\u0441\u043E\u043D, \u0435\u0433\u043E
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430 \u0438 \u0431\u0443\u0434\u0443\u0449\u0438\u0439
    \u0441\u043E-\u043B\u0430\u0443\u0440\u0435\u0430\u0442 \u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438, \u043E\u0442\u043C\u0435\u0447\u0430\u043B
    \u0435\u0433\u043E \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0443\u044E
    \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0449\u0435\u0434\u0440\u043E\u0441\u0442\u044C, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0442\u043E, \u0447\u0442\u043E \u043E\u043D \xAB\u0444\u0430\u043D\u0442\u0430\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A \u0438 \u0443\u0447\u0438\u0442\u0435\u043B\u044C\xBB.
    \u0415\u0433\u043E \u0441\u0442\u0438\u043B\u044C \u2014 \u0438\u043C\u043F\u043E\u0440\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043C\u0435\u0442\u043E\u0434\u044B \u0438\u0437 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438,
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0432 \u0434\u0438\u0441\u043A\u0440\u0435\u0442\u043D\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443. 
    ### \u23F3 \u0421\u043C\u0435\u0440\u0442\u044C  **\u041B\u0430\u0441\u043B\u043E
    \u041B\u043E\u0432\u0430\u0441 \u0436\u0438\u0432.** \u041F\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044E
    \u043D\u0430 2025 \u0433\u043E\u0434 \u043E\u043D \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C-\u044D\u043C\u0435\u0440\u0438\u0442\u043E\u043C
    \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u042D\u0442\u0432\u0451\u0448\u0430
    \u041B\u043E\u0440\u0430\u043D\u0434\u0430 \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u043C
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u043C \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0410\u043B\u044C\u0444\u0440\u0435\u0434\u0430
    \u0420\u0435\u043D\u044C\u0438 \u0432 \u0411\u0443\u0434\u0430\u043F\u0435\u0448\u0442\u0435. 
    ### \U0001F4DA \u0414\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u043E:
    \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u041F\u043E\u043C\u0438\u043C\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439, \u041B\u043E\u0432\u0430\u0441
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0438\u043C
    \u0432\u043A\u043B\u0430\u0434\u043E\u043C \u0432 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435.
    \u0415\u0433\u043E \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0437\u0430\u0434\u0430\u0447\u043D\u0438\u043A **\xABCombinatorial Problems
    and Exercises\xBB**, \u0438\u0437\u0434\u0430\u043D\u043D\u044B\u0439, \u043A\u043E\u0433\u0434\u0430
    \u0435\u043C\u0443 \u0435\u0449\u0451 \u043D\u0435 \u0431\u044B\u043B\u043E 30
    \u043B\u0435\u0442, \u043E\u043A\u0430\u0437\u0430\u043B \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0441\u0432\u043E\u0435\u0439 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0435:
    \u0437\u0430\u0434\u0430\u0447\u0438, \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0438
    \u0438 \u043F\u043E\u043B\u043D\u044B\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u044F. 
    \u041E\u043D \u0438 \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F
    \u0430\u043A\u0442\u0438\u0432\u043D\u044B\u043C \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u043E\u043C
    \u043C\u0438\u0440\u043E\u0432\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430, \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044F
    \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C \u0440\u0430\u0431\u043E\u0442\u044B
    \u0438 \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C \u043D\u0430\u0433\u0440\u0430\u0434\u044B."
  personalLifeEn: 
  shortBioRu: "\u041B\u0430\u0441\u043B\u043E \u041B\u043E\u0432\u0430\u0441 (\u0432\u0435\u043D\u0433.
    Lov\xE1sz L\xE1szl\xF3) \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0441\u0442\u0438,
    \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0441\u043E\u0435\u0434\u0438\u043D\u0438\u043B\u0438
    \u0447\u0438\u0441\u0442\u0443\u044E \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0443
    \u0441 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u043E\u0439 \u0438
    \u043D\u0430\u0448\u043B\u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0432 \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u0438 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0430\u0445. \u041E\u043D
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 9 \u043C\u0430\u0440\u0442\u0430 1948
    \u0433\u043E\u0434\u0430 \u0432 \u0411\u0443\u0434\u0430\u043F\u0435\u0448\u0442\u0435
    \u0438 \u0441\u0442\u0430\u043B \u0447\u0430\u0441\u0442\u044C\u044E \u0442\u043E\u0433\u043E
    \u0441\u0430\u043C\u043E\u0433\u043E \xAB\u0437\u043E\u043B\u043E\u0442\u043E\u0433\u043E
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F\xBB \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u043E\u0441\u044C
    \u043F\u043E\u0434 \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B \u0441\u0442\u0440\u0430\u043D\u044B.  ### \U0001F9D1\u200D\U0001F393
    \u0414\u0435\u0442\u0441\u0442\u0432\u043E, \u044E\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043D\u0430\u0447\u0430\u043B\u043E \u043F\u0443\u0442\u0438  \u0411\u0443\u0434\u0443\u0449\u0438\u0439
    \u0433\u0435\u043D\u0438\u0439 \u043F\u0440\u043E\u044F\u0432\u0438\u043B \u0441\u0435\u0431\u044F
    \u0435\u0449\u0435 \u0432 \u0448\u043A\u043E\u043B\u0435. \u0412 1960-\u0445
    \u0433\u043E\u0434\u0430\u0445 \u043E\u043D \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u0430\u0445, \u0433\u0434\u0435
    \u0435\u0433\u043E \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
    \u0431\u044B\u043B\u0438 \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u044B\u043C\u0438:
    *   **1964, 1965, 1966** \u2014 \u0442\u0440\u0438\u0436\u0434\u044B \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u043B
    \u0437\u043E\u043B\u043E\u0442\u044B\u0435 \u043C\u0435\u0434\u0430\u043B\u0438,
    \u043F\u0440\u0438\u0447\u0435\u043C \u0432 1965 \u0438 1966 \u0433\u043E\u0434\u0430\u0445
    \u0441 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u044B\u043C \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C
    (\u0434\u043E \u044D\u0442\u043E\u0433\u043E, \u0432 1963 \u0433\u043E\u0434\u0443,
    \u0432\u0437\u044F\u043B \u0441\u0435\u0440\u0435\u0431\u0440\u043E). *   \u042D\u0442\u043E
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0441\u0442\u0430\u043B\u043E
    \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u043C: \u0435\u0433\u043E \u0441\u044B\u043D
    \u0442\u0430\u043A\u0436\u0435 \u0432\u044B\u0438\u0433\u0440\u0430\u043B \u043C\u0435\u0434\u0430\u043B\u044C
    \u043D\u0430 \u043E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u0435 \u0432 2008
    \u0433\u043E\u0434\u0443.  \u041E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u044E\u043D\u043E\u0433\u043E \u041B\u043E\u0432\u0430\u0441\u0430
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430
    \u0441\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    **\u041F\u0430\u043B\u043E\u043C \u042D\u0440\u0434\u0451\u0448\u0435\u043C**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u043B
    \u0435\u0433\u043E \u043D\u0430 \u0437\u0430\u043D\u044F\u0442\u0438\u044F \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u043E\u0439
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u0433\u0440\u0430\u0444\u043E\u0432.
    \u0412\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u041B\u043E\u0432\u0430\u0441
    \u0441\u0442\u0430\u043B \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u043E\u043C
    \u0448\u0435\u0441\u0442\u0438 \u0441\u0442\u0430\u0442\u0435\u0439 \u0441 \u042D\u0440\u0434\u0451\u0448\u0435\u043C,
    \u0447\u0442\u043E \u0434\u0430\u043B\u043E \u0435\u043C\u0443 **\u0447\u0438\u0441\u043B\u043E
    \u042D\u0440\u0434\u0451\u0448\u0430, \u0440\u0430\u0432\u043D\u043E\u0435 1**
    (\u043D\u0430\u0438\u0432\u044B\u0441\u0448\u0438\u0439 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C
    \u0431\u043B\u0438\u0437\u043E\u0441\u0442\u0438 \u043A \xAB\u043F\u0430\u0442\u0440\u0438\u0430\u0440\u0445\u0443\xBB
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438).  \u041F\u043E\u0441\u043B\u0435
    \u0448\u043A\u043E\u043B\u044B \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0411\u0443\u0434\u0430\u043F\u0435\u0448\u0442\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0438\u043C\u0435\u043D\u0438
    \u042D\u0442\u0432\u0451\u0448\u0430 \u041B\u043E\u0440\u0430\u043D\u0434\u0430.
    \u0412 22 \u0433\u043E\u0434\u0430, \u0432 **1970 \u0433\u043E\u0434\u0443**,
    \u043E\u043D \u0443\u0436\u0435 \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0430 \u043D\u0430\u0443\u043A
    \u0432 \u0412\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0422\u0438\u0431\u043E\u0440\u0430 \u0413\u0430\u043B\u043B\u0430\u0438, \u0430
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0433\u043E\u0434 \u0441\u043F\u0443\u0441\u0442\u044F, \u0432 1971-\u043C.
    \u041A \u044D\u0442\u043E\u043C\u0443 \u043C\u043E\u043C\u0435\u043D\u0442\u0443
    \u043E\u043D \u0431\u044B\u043B \u0430\u0432\u0442\u043E\u0440\u043E\u043C 15
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0441\u0442\u0430\u0442\u0435\u0439. 
    ### \U0001F468\u200D\U0001F52C \u041A\u0430\u0440\u044C\u0435\u0440\u0430 \u0438
    \u043C\u0438\u0440\u043E\u0432\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u0415\u0433\u043E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0431\u044B\u043B\u0430 \u043D\u0430\u0441\u044B\u0449\u0435\u043D\u0430
    \u0440\u0430\u0431\u043E\u0442\u043E\u0439 \u0432 \u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\u0445
    \u043C\u0438\u0440\u0430: *   **\u0412\u0435\u043D\u0433\u0440\u0438\u044F (\u0440\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B):** \u041F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B
    \u0432 \u0411\u0443\u0434\u0430\u043F\u0435\u0448\u0442\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 (\u0434\u043E
    1975), \u0437\u0430\u0442\u0435\u043C \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0421\u0435\u0433\u0435\u0434\u0430, \u0433\u0434\u0435 \u0432 1978 \u0433\u043E\u0434\u0443
    \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u043B \u043A\u0430\u0444\u0435\u0434\u0440\u0443
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u0412 1983 \u0433\u043E\u0434\u0443
    \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u0432 \u0411\u0443\u0434\u0430\u043F\u0435\u0448\u0442,
    \u0447\u0442\u043E\u0431\u044B \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u0442\u0430\u043C
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u044B\u0445
    \u043D\u0430\u0443\u043A. *   **\u0421\u0428\u0410 (1993\u20132006):** \u0411\u044B\u043B
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0432 \u0419\u0435\u043B\u044C\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 (1993-1999),
    \u0430 \u0437\u0430\u0442\u0435\u043C \u043F\u0435\u0440\u0435\u0448\u0435\u043B
    \u043D\u0430 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0441\u0442\u0430\u0440\u0448\u0435\u0433\u043E
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044F
    \u0432 **Microsoft Research** (\u0434\u043E 2006 \u0433\u043E\u0434\u0430). *  
    **\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0432 \u0412\u0435\u043D\u0433\u0440\u0438\u044E
    (\u0441 2006):** \u0412\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u043D\u0430
    \u0440\u043E\u0434\u0438\u043D\u0443, \u0441\u0442\u0430\u0432 \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432 \u0411\u0443\u0434\u0430\u043F\u0435\u0448\u0442\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 (2006-2011).
    \u0412 2014\u20132020 \u0433\u043E\u0434\u0430\u0445 \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u043F\u043E\u0441\u0442 \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u0430
    \u0412\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A.  \u0412 2007\u20132010 \u0433\u043E\u0434\u0430\u0445
    \u041B\u043E\u0432\u0430\u0441 \u0431\u044B\u043B **\u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u044E\u0437\u0430 (IMU)**.  ### \U0001F4A1 \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F 
    \u041B\u043E\u0432\u0430\u0441 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432\u044B \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445 \u0434\u0438\u0441\u043A\u0440\u0435\u0442\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0438: 
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0433\u0440\u0430\u0444\u043E\u0432:**    
    *   \u0412 1972 \u0433\u043E\u0434\u0443 \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    **\u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u043E \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u044B\u0445
    \u0433\u0440\u0430\u0444\u0430\u0445**, \u0434\u043E\u043B\u0433\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u043E\u0441\u0442\u0430\u0432\u0430\u0432\u0448\u0443\u044E\u0441\u044F
    \u043D\u0435\u0440\u0435\u0448\u0435\u043D\u043D\u043E\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u043E\u0439.    
    *   \u0414\u043E\u043A\u0430\u0437\u0430\u043B \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u041A\u043D\u0435\u0437\u0435\u0440\u0430, \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u0432
    \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438.     *   \u041D\u0430\u0448\u0435\u043B
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u0443 **\u0451\u043C\u043A\u043E\u0441\u0442\u0438
    \u0428\u0435\u043D\u043D\u043E\u043D\u0430** \u0434\u043B\u044F \u043F\u044F\u0442\u0438\u0443\u0433\u043E\u043B\u044C\u043D\u043E\u0433\u043E
    \u0433\u0440\u0430\u0444\u0430, \u0440\u0435\u0448\u0438\u0432 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0437\u0430\u0434\u0430\u0447\u0443 \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438. 
    *   **\u0410\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u044B \u0438 \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C:**     *   \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0431\u0440\u0430\u0442\u044C\u044F\u043C\u0438 \u041B\u0435\u043D\u0441\u0442\u0440\u0430
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B **LLL-\u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C**
    (\u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C \u041B\u0435\u043D\u0441\u0442\u0440\u044B
    \u2014 \u041B\u0435\u043D\u0441\u0442\u0440\u044B \u2014 \u041B\u043E\u0432\u0430\u0441\u0430)
    \u2014 \u043E\u0441\u043D\u043E\u0432\u0443 \u0434\u043B\u044F \u043A\u0440\u0438\u043F\u0442\u043E\u0441\u0438\u0441\u0442\u0435\u043C,
    \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u044B\u0445 \u043A \u0430\u0442\u0430\u043A\u0430\u043C
    \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u044B\u0445 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u0432.    
    *   \u0421\u043E\u0437\u0434\u0430\u043B **\u043B\u043E\u043A\u0430\u043B\u044C\u043D\u0443\u044E
    \u043B\u0435\u043C\u043C\u0443 \u041B\u043E\u0432\u0430\u0441\u0430** \u2014
    \u043C\u043E\u0449\u043D\u044B\u0439 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442
    \u0432 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u043D\u043E\u0439
    \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0435.    
    *   \u0412\u043D\u0435\u0441 \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E
    **\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u043D\u043E \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0435\u043C\u044B\u0445
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    (PCP)**, \u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0435\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u044C\u044E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438. 
    ### \U0001F3C6 \u0413\u043B\u0430\u0432\u043D\u044B\u0435 \u043D\u0430\u0433\u0440\u0430\u0434\u044B 
    \u0417\u0430 \u0441\u0432\u043E\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u041B\u0430\u0441\u043B\u043E
    \u041B\u043E\u0432\u0430\u0441 \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u0441\u0435\u0445
    \u043C\u044B\u0441\u043B\u0438\u043C\u044B\u0445 \u043F\u0440\u0435\u043C\u0438\u0439
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435: *   **\u041F\u0440\u0435\u043C\u0438\u044F
    \u0412\u043E\u043B\u044C\u0444\u0430 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435**
    (1999). *   **\u041F\u0440\u0435\u043C\u0438\u044F \u041A\u043D\u0443\u0442\u0430**
    (1999). *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0413\u0451\u0434\u0435\u043B\u044F**
    (2001). *   **\u041F\u0440\u0435\u043C\u0438\u044F \u041A\u0438\u043E\u0442\u043E**
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043D\u0430\u0443\u043A (2010). *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0410\u0431\u0435\u043B\u044F**
    (2021) \u2014 \u043E\u0434\u043D\u0430 \u0438\u0437 \u0432\u044B\u0441\u043E\u0447\u0430\u0439\u0448\u0438\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    *   \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    **\u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A** (\u0441 2006) \u0438 \u0447\u043B\u0435\u043D\u043E\u043C
    \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u0421\u0428\u0410.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466
    \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C  \u041B\u0430\u0441\u043B\u043E
    \u041B\u043E\u0432\u0430\u0441 \u0436\u0435\u043D\u0430\u0442 \u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    **\u041A\u0430\u0442\u0430\u043B\u0438\u043D \u0412\u0435\u0441\u0442\u0435\u0440\u0433\u043E\u043C\u0431\u0438**,
    \u0441 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D\u0438 \u0432\u043C\u0435\u0441\u0442\u0435
    \u0443\u0447\u0438\u043B\u0438\u0441\u044C \u0432 \u0441\u043F\u0435\u0446\u0448\u043A\u043E\u043B\u0435.
    \u0423 \u043D\u0438\u0445 \u0447\u0435\u0442\u0432\u0435\u0440\u043E \u0434\u0435\u0442\u0435\u0439
    \u0438 \u0441\u0435\u043C\u0435\u0440\u043E \u0432\u043D\u0443\u043A\u043E\u0432.
    \u0418\u0445 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u0441\u0435\u043C\u044C\u0435\u0439 \u2014 \u043E\u043D\u0438 \u0432\u043C\u0435\u0441\u0442\u0435
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438 \u043D\u0430\u0434 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0430\u043C\u0438
    \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\u043C\u0438."
  shortBioEn: 
  interestingFactsRu: "\u041F\u043E\u043C\u0438\u043C\u043E \u0432\u0435\u043B\u0438\u043A\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439, \u0432 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u041B\u0430\u0441\u043B\u043E \u041B\u043E\u0432\u0430\u0441\u0430 \u0435\u0441\u0442\u044C
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u044F\u0440\u043A\u0438\u0445
    \u0438 \u043A\u0443\u0440\u044C\u0451\u0437\u043D\u044B\u0445 \u0434\u0435\u0442\u0430\u043B\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0440\u0438\u0441\u0443\u044E\u0442
    \u0435\u0433\u043E \u043A\u0430\u043A \u043D\u0435\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u0443\u044E
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C.  ### \U0001F3C6 \u0412\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434
    \u0438 \xAB\u0437\u043E\u043B\u043E\u0442\u043E\u0435 \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0435\xBB 
    *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u041E\u043B\u0438\u043C\u043F**: \u041B\u0430\u0441\u043B\u043E \u041B\u043E\u0432\u0430\u0441
    \u0431\u044B\u043B \u0447\u0430\u0441\u0442\u044C\u044E \u0442\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u043E\u0433\u043E
    \xAB\u0437\u043E\u043B\u043E\u0442\u043E\u0433\u043E \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F\xBB
    \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.
    \u041E\u043D \u0442\u0440\u0438\u0436\u0434\u044B \u043F\u043E\u0434\u0440\u044F\u0434
    \u0432\u044B\u0438\u0433\u0440\u044B\u0432\u0430\u043B \u0437\u043E\u043B\u043E\u0442\u044B\u0435
    \u043C\u0435\u0434\u0430\u043B\u0438 \u043D\u0430 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u0435 (\u0432 1964, 1965 \u0438
    1966 \u0433\u043E\u0434\u0430\u0445), \u043F\u0440\u0438\u0447\u0451\u043C \u0432
    \u0434\u0432\u0443\u0445 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0445
    \u0441\u043B\u0443\u0447\u0430\u044F\u0445 \u2014 \u0441 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u044B\u043C
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C. \u042D\u0442\u043E
    \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0435\u0441\u044F \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0439
    \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u0435\u0439: \u0435\u0433\u043E \u0441\u044B\u043D
    \u0442\u0430\u043A\u0436\u0435 \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u043B
    \u043C\u0435\u0434\u0430\u043B\u044C \u043D\u0430 \u044D\u0442\u043E\u0439 \u043E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u0435
    \u0432 2008 \u0433\u043E\u0434\u0443. *   **\u0422\u0435\u043B\u0435\u0432\u0438\u0437\u0438\u043E\u043D\u043D\u0430\u044F
    \u0434\u0443\u044D\u043B\u044C**: \u0412 \u044E\u043D\u043E\u0441\u0442\u0438
    \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u043E\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u0435\u043C
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0433\u043E \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0433\u043E
    \u0442\u0435\u043B\u0435\u0432\u0438\u0437\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0448\u043E\u0443, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u043E\u0432
    \u043F\u043E\u043C\u0435\u0449\u0430\u043B\u0438 \u0432 \u0441\u0442\u0435\u043A\u043B\u044F\u043D\u043D\u044B\u0435
    \u043A\u0430\u0431\u0438\u043D\u044B \u0438 \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u043B\u0438
    \u0440\u0435\u0448\u0430\u0442\u044C \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u043D\u0430 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C.
    \u042D\u0442\u043E\u0442 \u0444\u043E\u0440\u043C\u0430\u0442 \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u043B
    \u0437\u0440\u0435\u043B\u0438\u0449\u043D\u043E\u0441\u0442\u0438 \u0438 \u0434\u0435\u043B\u0430\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0437\u0440\u0435\u043B\u0438\u0449\u0435\u043C \u0434\u043B\u044F \u0448\u0438\u0440\u043E\u043A\u043E\u0439
    \u043F\u0443\u0431\u043B\u0438\u043A\u0438.  ### \U0001F91D \u0414\u0440\u0443\u0436\u0431\u0430
    \u0441 \xAB\u043A\u043E\u0447\u0443\u044E\u0449\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C\xBB 
    *   **\u041A\u0443\u043C\u0438\u0440 \u0438 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A**:
    \u041E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u041B\u043E\u0432\u0430\u0441\u0430 \u043E\u043A\u0430\u0437\u0430\u043B\u0430
    \u0441\u0442\u0430\u0442\u044C\u044F \u0438 \u043B\u0438\u0447\u043D\u0430\u044F
    \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u0441 \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u043C
    \u041F\u0430\u043B\u043E\u043C \u042D\u0440\u0434\u0451\u0448\u0435\u043C \u2014
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u0441\u0432\u043E\u0438\u043C \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u043C
    \u0441\u0442\u0438\u043B\u0435\u043C \u0436\u0438\u0437\u043D\u0438 \xAB\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\xBB. \u0418\u043C\u0435\u043D\u043D\u043E
    \u042D\u0440\u0434\u0451\u0448 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u043B
    \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E \u041B\u043E\u0432\u0430\u0441\u0430
    \u043D\u0430 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435 \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0438.
    *   **\u0421\u0442\u0435\u043F\u0435\u043D\u044C \u0440\u043E\u0434\u0441\u0442\u0432\u0430
    \u0432 \u043C\u0438\u0440\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438**:
    \u041B\u043E\u0432\u0430\u0441 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u043E\u043C \u0448\u0435\u0441\u0442\u0438
    \u0441\u0442\u0430\u0442\u0435\u0439 \u0441 \u042D\u0440\u0434\u0451\u0448\u0435\u043C,
    \u0447\u0442\u043E \u0432 \u043C\u0438\u0440\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0434\u0430\u0451\u0442 \u0435\u043C\u0443 **\u0447\u0438\u0441\u043B\u043E
    \u042D\u0440\u0434\u0451\u0448\u0430, \u0440\u0430\u0432\u043D\u043E\u0435 1**.
    \u042D\u0442\u043E \u0447\u0438\u0441\u043B\u043E \u2014 \u0441\u0432\u043E\u0435\u043E\u0431\u0440\u0430\u0437\u043D\u044B\u0439
    \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C \xAB\u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0431\u043B\u0438\u0437\u043E\u0441\u0442\u0438\xBB \u043A \u042D\u0440\u0434\u0451\u0448\u0443,
    \u0438 \u0438\u043C\u0435\u0442\u044C \u0435\u0434\u0438\u043D\u0438\u0446\u0443
    \u2014 \u0437\u043D\u0430\u0447\u0438\u0442 \u0431\u044B\u0442\u044C \u0435\u0433\u043E
    \u043F\u0440\u044F\u043C\u044B\u043C \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u043E\u043C,
    \u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0432\u044B\u0441\u0448\u0438\u043C
    \u0437\u043D\u0430\u043A\u043E\u043C \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u0430.
    *   **\u041E\u0442\u043A\u0440\u044B\u0442\u044B\u0439 \u0441\u0442\u0438\u043B\u044C**:
    \u041E\u0431\u0449\u0435\u043D\u0438\u0435 \u0441 \u042D\u0440\u0434\u0451\u0448\u0435\u043C
    \u043F\u0440\u0438\u0432\u0438\u043B\u043E \u041B\u043E\u0432\u0430\u0441\u0443
    \u0441\u0442\u0438\u043B\u044C \xAB\u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0439\xBB
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0433\u0434\u0435
    \u0438\u0434\u0435\u0438 \u0438 \u043D\u0435\u043F\u043E\u043B\u043D\u044B\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E
    \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u044E\u0442\u0441\u044F \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438.
    \u0421\u0430\u043C \u041B\u043E\u0432\u0430\u0441 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B,
    \u0447\u0442\u043E \u042D\u0440\u0434\u0451\u0448 \u043D\u0430\u0443\u0447\u0438\u043B
    \u0435\u0433\u043E \xAB\u043F\u043E\u043B\u043D\u043E\u0439 \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0441\u0442\u0438
    \u0432 \u0437\u0430\u0434\u0430\u0447\u0430\u0445 \u0438 \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u044B\u0445
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430\u0445\xBB, \u0447\u0442\u043E
    \u043D\u0435\u0438\u0437\u0431\u0435\u0436\u043D\u043E \u0432\u0435\u0434\u0451\u0442
    \u043A \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0443. 
    ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466 \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0438 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0435
    \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u0438  *   **\u0428\u043A\u043E\u043B\u044C\u043D\u0430\u044F
    \u043B\u044E\u0431\u043E\u0432\u044C**: \u041B\u043E\u0432\u0430\u0441 \u0436\u0435\u043D\u0430\u0442
    \u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u041A\u0430\u0442\u0430\u043B\u0438\u043D
    \u0412\u0435\u0441\u0442\u0435\u0440\u0433\u043E\u043C\u0431\u0438, \u0441 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043E\u043D\u0438 \u0432\u043C\u0435\u0441\u0442\u0435 \u0443\u0447\u0438\u043B\u0438\u0441\u044C
    \u0432 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 \u0434\u043B\u044F \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u0445
    \u0434\u0435\u0442\u0435\u0439. \u0418\u0445 \u0441\u043E\u044E\u0437 \u2014
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u0439,
    \u043D\u043E \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439:
    \u043E\u043D\u0438 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0438\u043C\u0438
    \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u0430\u043C\u0438. *   **\u041A\u0443\u0440\u044C\u0451\u0437
    \u0441 \u0444\u0430\u043C\u0438\u043B\u0438\u0435\u0439**: \u0412\u0430\u0436\u043D\u043E
    \u043E\u0442\u043C\u0435\u0442\u0438\u0442\u044C, \u0447\u0442\u043E \u0432 \u0440\u0443\u0441\u0441\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435 \u0444\u0430\u043C\u0438\u043B\u0438\u044F **\u041B\u043E\u0432\u0430\u0441**
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0442\u043E\u0447\u043D\u043E\u0439
    \u0442\u0440\u0430\u043D\u0441\u043A\u0440\u0438\u043F\u0446\u0438\u0435\u0439
    \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0439 \u0444\u0430\u043C\u0438\u043B\u0438\u0438
    Lov\xE1sz, \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u0430\u043A
    \u0438\u043C\u044F **\u041B\u043E\u0432\u0435\u043B\u0430\u0441** (\u043E\u0442
    \u0430\u043D\u0433\u043B. Lovelace) \u2014 \u044D\u0442\u043E \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u044B\u0439
    \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436-\u0440\u0430\u0441\u043F\u0443\u0442\u043D\u0438\u043A
    \u0438\u0437 \u0440\u043E\u043C\u0430\u043D\u0430 \u0421\u044D\u043C\u044E\u044D\u043B\u0430
    \u0420\u0438\u0447\u0430\u0440\u0434\u0441\u043E\u043D\u0430 \xAB\u041A\u043B\u0430\u0440\u0438\u0441\u0441\u0430\xBB,
    \u0447\u044C\u0451 \u0438\u043C\u044F \u0441\u0442\u0430\u043B\u043E \u043D\u0430\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C.
    \u042D\u0442\u043E \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u0440\u0430\u0437\u043D\u044B\u0435 \u043B\u044E\u0434\u0438, \u0438 \u0438\u0445
    \u043F\u0443\u0442\u0430\u043D\u0438\u0446\u0430 \u0431\u044B\u043B\u0430 \u0431\u044B
    \u0437\u0430\u0431\u0430\u0432\u043D\u043E\u0439 \u043E\u0448\u0438\u0431\u043A\u043E\u0439. 
    \u041A\u0430\u043A \u0432\u0438\u0434\u0438\u0442\u0435, \u041B\u0430\u0441\u043B\u043E
    \u041B\u043E\u0432\u0430\u0441 \u2014 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043D\u043E \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0441 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439, \u0442\u0435\u0441\u043D\u043E
    \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0439 \u0441 \u0437\u043E\u043B\u043E\u0442\u044B\u043C
    \u0432\u0435\u043A\u043E\u043C \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438."
