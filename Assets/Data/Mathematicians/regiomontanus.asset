  achievementsRu: "\u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439
    \u043F\u0440\u043E\u0440\u044B\u0432 \u0432 \u043D\u0430\u0443\u043A\u0435, \u0437\u0430\u043B\u043E\u0436\u0438\u0432
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0434\u043B\u044F \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u043D\u0430 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F \u0432\u043F\u0435\u0440\u0435\u0434.
    \u0415\u0433\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u0442\u0440\u0443\u0434\u044B
    \u0438 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u043C\u043E\u0436\u043D\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439. 
    ### \U0001F4D0 \xAB\u041E \u0432\u0441\u0435\u0445 \u0432\u0438\u0434\u0430\u0445
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432\xBB
    (De triangulis omnimodis, 1464)  \u042D\u0442\u043E\u0442 \u0442\u0440\u0430\u043A\u0442\u0430\u0442
    \u2014 \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0440\u0443\u0434 \u0438, \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E,
    \u0441\u0430\u043C\u044B\u0439 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043D\u0430\u0443\u043A\u0443. \u041A\u043D\u0438\u0433\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0442\u043F\u0440\u0430\u0432\u043D\u043E\u0439
    \u0442\u043E\u0447\u043A\u043E\u0439 \u0434\u043B\u044F \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u043A\u0430\u043A \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u044B \u0432 \u0415\u0432\u0440\u043E\u043F\u0435. 
    *   **\u0421\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430 \u0442\u0440\u0443\u0434\u0430**:
    \u041A\u043D\u0438\u0433\u0430 \u0441\u043E\u0441\u0442\u043E\u0438\u0442 \u0438\u0437
    \u043F\u044F\u0442\u0438 \u0447\u0430\u0441\u0442\u0435\u0439. \u041F\u0435\u0440\u0432\u044B\u0435
    \u0434\u0432\u0435 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u044B \u043F\u043B\u043E\u0441\u043A\u043E\u0439
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u0430 \u0442\u0440\u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u2014 \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u0430 \u0434\u043B\u044F
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0441\u0447\u0435\u0442\u043E\u0432. *   **\u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0438\u043D\u043D\u043E\u0432\u0430\u0446\u0438\u0438**: \u0412 \u044D\u0442\u043E\u043C
    \u0442\u0440\u0443\u0434\u0435 \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0432 \u0415\u0432\u0440\u043E\u043F\u0435
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0438\u0437\u043B\u043E\u0436\u0438\u043B **\u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u0441\u0438\u043D\u0443\u0441\u043E\u0432** \u0434\u043B\u044F \u043F\u043B\u043E\u0441\u043A\u0438\u0445
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432
    \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439 \u043A\u043D\u0438\u0433\u0435
    , \u0430 \u0432 \u0447\u0435\u0442\u0432\u0435\u0440\u0442\u043E\u0439 \u043A\u043D\u0438\u0433\u0435
    \u2014 **\u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u0441\u0438\u043D\u0443\u0441\u043E\u0432
    \u0434\u043B\u044F \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432**.
    \u0411\u043E\u043B\u0435\u0435 \u0442\u043E\u0433\u043E, \u0432 \u043F\u044F\u0442\u043E\u0439
    \u043A\u043D\u0438\u0433\u0435 \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    **\u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u043A\u043E\u0441\u0438\u043D\u0443\u0441\u043E\u0432
    \u0434\u043B\u044F \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432**.
    \u042D\u0442\u043E \u0431\u044B\u043B \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u0448\u0430\u0433 \u0432\u043F\u0435\u0440\u0435\u0434 \u043F\u043E \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044E
    \u0441 \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u043C\u0438 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u043C\u0438.
    *   **\u0420\u043E\u043B\u044C \u0430\u043B\u0433\u0435\u0431\u0440\u044B**:
    \u0412 \u0441\u0432\u043E\u0438\u0445 \u0440\u0435\u0448\u0435\u043D\u0438\u044F\u0445
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u043B \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B, \u043D\u0430\u0437\u044B\u0432\u0430\u044F
    \u044D\u0442\u043E \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E `ars
    rei et census` (\u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E \u0432\u0435\u0449\u0438
    \u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430). \u041E\u043D \u0440\u0435\u0448\u0430\u043B
    \u0437\u0430\u0434\u0430\u0447\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0440\u0430\u043D\u0435\u0435 \u043D\u0435 \u0431\u044B\u043B\u0438 \u043E\u043F\u0438\u0441\u0430\u043D\u044B
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438,
    \u0441\u0432\u043E\u0434\u044F \u0438\u0445 \u043A \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u043C
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C, \u0445\u043E\u0442\u044F
    \u0438 \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u043B \u0432\u0441\u0435
    \u044D\u0442\u043E \u0441\u043B\u043E\u0432\u0435\u0441\u043D\u043E, \u0431\u0435\u0437
    \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u0432.  ### \U0001F30C \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F
    \u0438 \u043D\u0430\u0432\u0438\u0433\u0430\u0446\u0438\u044F  \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A,
    \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B, \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0438\u0435
    \u043C\u043E\u0440\u0435\u043F\u043B\u0430\u0432\u0430\u043D\u0438\u0435.  *  
    **\xAB\u042D\u0444\u0435\u043C\u0435\u0440\u0438\u0434\u044B\xBB (Ephemerides,
    1474)**: \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u0439
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043F\u0435\u0447\u0430\u0442\u043D\u044B\u0439
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u043F\u0440\u0430\u0432\u043E\u0447\u043D\u0438\u043A, \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0432\u0448\u0438\u0439
    \u0435\u0436\u0435\u0434\u043D\u0435\u0432\u043D\u044B\u0435 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442, \u0421\u043E\u043B\u043D\u0446\u0430 \u0438
    \u041B\u0443\u043D\u044B \u043D\u0430 1475-1506 \u0433\u043E\u0434\u044B. \u042D\u0442\u0430
    \u043A\u043D\u0438\u0433\u0430 \u0441\u0442\u0430\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043D\u043E\u0439
    \u0434\u043B\u044F \u043C\u043E\u0440\u0435\u043F\u043B\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u0439.
    **\u0425\u0440\u0438\u0441\u0442\u043E\u0444\u043E\u0440 \u041A\u043E\u043B\u0443\u043C\u0431**
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u044D\u0444\u0435\u043C\u0435\u0440\u0438\u0434\u044B
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0441\u0432\u043E\u0438\u0445 \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u0439.
    \u0411\u043E\u043B\u0435\u0435 \u0442\u043E\u0433\u043E, \u0438\u043C\u0435\u043D\u043D\u043E
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u043D\u043E\u0433\u043E
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D\u043E\u043C
    \u043B\u0443\u043D\u043D\u043E\u0433\u043E \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u044F
    \u043D\u0430 29 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 1504 \u0433\u043E\u0434\u0430
    \u041A\u043E\u043B\u0443\u043C\u0431 \u0441\u043C\u043E\u0433 \u0437\u0430\u043F\u0443\u0433\u0430\u0442\u044C
    \u0432\u0440\u0430\u0436\u0434\u0435\u0431\u043D\u043E \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u044B\u0445
    \u0436\u0438\u0442\u0435\u043B\u0435\u0439 \u042F\u043C\u0430\u0439\u043A\u0438
    \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043F\u0440\u043E\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u0435.
    *   **\xAB\u0422\u0430\u0431\u043B\u0438\u0446\u044B \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439\xBB
    (Tabulae directionum, 1467)**: \u042D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B \u043D\u043E\u0432\u044B\u0435
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B \u0441 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439
    \u0434\u043B\u044F \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E. \u041E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0441\u0438\u043D\u0443\u0441\u044B \u0441 \u0440\u0430\u0434\u0438\u0443\u0441\u0430\u043C\u0438
    \u0434\u043E 10 000 000 \u0438 \u0432\u0432\u0435\u043B \u0442\u0430\u0431\u043B\u0438\u0446\u044B
    \u0442\u0430\u043D\u0433\u0435\u043D\u0441\u043E\u0432, \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u043E
    \u0441 \u0432\u044B\u0441\u043E\u043A\u043E\u0439 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442\u044C \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u0445 \u0442\u0435\u043B. *   **\u041D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F**:
    \u0412 \u041D\u044E\u0440\u043D\u0431\u0435\u0440\u0433\u0435 \u043E\u043D \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    \u043E\u0434\u043D\u0443 \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0439
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u0438 \u0432\u043C\u0435\u0441\u0442\u0435
    \u0441 \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434\u043E\u043C \u0412\u0430\u043B\u044C\u0442\u0435\u0440\u043E\u043C
    \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F, \u0432 \u0442\u043E\u043C
    \u0447\u0438\u0441\u043B\u0435 \u0437\u0430 \u043A\u043E\u043C\u0435\u0442\u043E\u0439
    1472 \u0433\u043E\u0434\u0430, \u0438 \u0432\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u043F\u043E\u043B\u0435\u043C\u0438\u043A\u0443 \u0441 \u0430\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u0435\u0432\u0441\u043A\u0438\u043C
    \u0432\u0437\u0433\u043B\u044F\u0434\u043E\u043C \u043D\u0430 \u043A\u043E\u043C\u0435\u0442\u044B
    \u043A\u0430\u043A \u043D\u0430 \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u043D\u044B\u0435
    \u044F\u0432\u043B\u0435\u043D\u0438\u044F.  ### \U0001F4D6 \xAB\u042D\u043F\u0438\u0442\u043E\u043C\u0430
    \u201E\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0430\u201C\xBB
    (Epytoma in almagesti Ptolemei, 1462)  \u042D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434
    \u0441\u0442\u0430\u043B \u0438\u0442\u043E\u0433\u043E\u043C \u0440\u0430\u0431\u043E\u0442\u044B,
    \u043D\u0430\u0447\u0430\u0442\u043E\u0439 \u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C
    \u0413\u0435\u043E\u0440\u0433\u043E\u043C \u041F\u0443\u0440\u0431\u0430\u0445\u043E\u043C,
    \u0438 \u0431\u044B\u043B \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D \u043F\u043E
    \u0437\u0430\u0434\u0430\u043D\u0438\u044E \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u0430
    \u0412\u0438\u0441\u0441\u0430\u0440\u0438\u043E\u043D\u0430.  *   **\u0418\u0441\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043E\u0448\u0438\u0431\u043E\u043A**: \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0435\u0440\u0435\u0441\u043A\u0430\u0437\u0430\u043B
    \u0442\u0440\u0443\u0434 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F, \u043E\u043D
    \u0441\u043E\u0437\u0434\u0430\u043B \u0435\u0433\u043E \u0441\u0436\u0430\u0442\u043E\u0435
    \u0438 \u0438\u0441\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u0435
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435. *   **\u041F\u0435\u0440\u0432\u0430\u044F
    \u043A\u0440\u0438\u0442\u0438\u043A\u0430**: \u0412 \u044D\u0442\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F
    \u043E\u0434\u043D\u0430 \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u0432
    \u0415\u0432\u0440\u043E\u043F\u0435 \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0446\u0435\u043D\u043E\u043A \u043C\u043E\u0434\u0435\u043B\u0438 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442, \u0447\u0442\u043E \u0442\u0435\u043E\u0440\u0438\u044F
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u0434\u0438\u0430\u043C\u0435\u0442\u0440 \u041B\u0443\u043D\u044B \u0432 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0447\u0435\u0442\u0432\u0435\u0440\u0442\u0438 \u0432\u0434\u0432\u043E\u0435
    \u0431\u043E\u043B\u044C\u0448\u0438\u0439, \u0447\u0435\u043C \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0435\u043C\u044B\u0439.
    \u041F\u043E\u0437\u0436\u0435 \u044D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434
    \u043E\u043A\u0430\u0437\u0430\u043B \u0441\u0438\u043B\u044C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 **\u041D\u0438\u043A\u043E\u043B\u0430\u044F
    \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430**.  ### \U0001F5A8\uFE0F
    \u041F\u0438\u043E\u043D\u0435\u0440 \u043A\u043D\u0438\u0433\u043E\u043F\u0435\u0447\u0430\u0442\u0430\u043D\u0438\u044F 
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u043E\u0441\u043E\u0437\u043D\u0430\u043B
    \u0441\u0438\u043B\u0443 \u043F\u0435\u0447\u0430\u0442\u043D\u043E\u0433\u043E
    \u0441\u0442\u0430\u043D\u043A\u0430 \u0434\u043B\u044F \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u0437\u043D\u0430\u043D\u0438\u044F. 
    *   \u0412 \u041D\u044E\u0440\u043D\u0431\u0435\u0440\u0433\u0435 \u043E\u043D
    \u043E\u0441\u043D\u043E\u0432\u0430\u043B \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0442\u0438\u043F\u043E\u0433\u0440\u0430\u0444\u0438\u044E \u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0430\u043C\u0431\u0438\u0446\u0438\u043E\u0437\u043D\u044B\u0439 \u0441\u043F\u0438\u0441\u043E\u043A
    \u043A\u043D\u0438\u0433 (`Haec opera`), \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u043B \u0438\u0437\u0434\u0430\u0442\u044C:
    \u043E\u0442 \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u0438 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430
    \u0434\u043E \u0441\u0432\u043E\u0438\u0445 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432. *   \u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u0435\u0433\u043E \u0440\u0430\u043D\u043D\u044F\u044F \u0441\u043C\u0435\u0440\u0442\u044C
    \u043F\u043E\u043C\u0435\u0448\u0430\u043B\u0430 \u043E\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0438\u0442\u044C
    \u0432\u0441\u0435 \u043F\u043B\u0430\u043D\u044B. \u041C\u043D\u043E\u0433\u0438\u0435
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u0442\u0440\u0443\u0434 \u043F\u043E
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u0431\u044B\u043B\u0438 \u0438\u0437\u0434\u0430\u043D\u044B \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E,
    \u0443\u0436\u0435 \u0432 XVI \u0432\u0435\u043A\u0435."
  achievementsEn: 
  personalLifeRu: "\u0416\u0438\u0437\u043D\u044C \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439,
    \u043A\u0430\u043A \u043A\u043E\u043C\u0435\u0442\u0430, \u0438 \u043D\u0435
    \u043C\u0435\u043D\u0435\u0435 \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u043E\u0439.
    \u0420\u043E\u0434\u0438\u0432\u0448\u0438\u0441\u044C \u0441\u044B\u043D\u043E\u043C
    \u043C\u0435\u043B\u044C\u043D\u0438\u043A\u0430, \u043E\u043D \u0441\u0442\u0430\u043B
    \xAB\u043A\u043E\u0440\u043E\u043B\u0435\u043C \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u0432\xBB
    XV \u0432\u0435\u043A\u0430, \u043D\u043E \u0435\u0433\u043E \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0439
    \u043F\u0443\u0442\u044C \u043E\u0431\u043E\u0440\u0432\u0430\u043B\u0441\u044F
    \u0442\u0430\u043A \u0436\u0435 \u0432\u043D\u0435\u0437\u0430\u043F\u043D\u043E,
    \u043A\u0430\u043A \u0438 \u043D\u0430\u0447\u0430\u043B\u0441\u044F .  ### \U0001F4DC
    \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u0441\u0435\u043C\u044C\u044F 
    *   **\u0418\u043C\u044F \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435**:
    \u041E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F **6 \u0438\u044E\u043D\u044F
    1436 \u0433\u043E\u0434\u0430** \u0432 \u0431\u0430\u0432\u0430\u0440\u0441\u043A\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u0435 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433
    (K\xF6nigsberg in Bayern), \u0447\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442
    \xAB\u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u0433\u043E\u0440\u0430\xBB
    . \u041D\u0435 \u043F\u0443\u0442\u0430\u0442\u044C \u0441 \u043E\u0434\u043D\u043E\u0438\u043C\u0435\u043D\u043D\u044B\u043C
    \u0433\u043E\u0440\u043E\u0434\u043E\u043C \u0432 \u041F\u0440\u0443\u0441\u0441\u0438\u0438
    (\u043D\u044B\u043D\u0435 \u041A\u0430\u043B\u0438\u043D\u0438\u043D\u0433\u0440\u0430\u0434).
    \u0415\u0433\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C \u0438\u043C\u0435\u043D\u0435\u043C
    \u0431\u044B\u043B\u043E **\u0418\u043E\u0433\u0430\u043D\u043D \u041C\u044E\u043B\u043B\u0435\u0440**
    (Johannes M\xFCller). \u0418\u043C\u044F \xAB\u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D\xBB
    \u2014 \u044D\u0442\u043E \u043B\u0430\u0442\u0438\u043D\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043F\u0441\u0435\u0432\u0434\u043E\u043D\u0438\u043C (\u043E\u0442 *Regiomontanus*
    \u2014 \xAB\u0441 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0433\u043E\u0440\u044B\xBB), \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u043A\u0430\u043A
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u043E\u043D \u0441\u0430\u043C
    \u043D\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438; \u043E\u043D \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u043F\u043E\u0437\u0436\u0435, \u0432 1531 \u0433\u043E\u0434\u0443, \u0432
    \u0442\u0440\u0443\u0434\u0430\u0445 \u0424\u0438\u043B\u0438\u043F\u043F\u0430
    \u041C\u0435\u043B\u0430\u043D\u0445\u0442\u043E\u043D\u0430 . *   **\u0421\u0435\u043C\u044C\u044F**:
    \u041E\u043D \u0431\u044B\u043B \u0441\u044B\u043D\u043E\u043C **\u043C\u0435\u043B\u044C\u043D\u0438\u043A\u0430**
    (M\xFCller \u2014 \u043F\u043E-\u043D\u0435\u043C\u0435\u0446\u043A\u0438 \xAB\u043C\u0435\u043B\u044C\u043D\u0438\u043A\xBB)
    . \u0421\u0435\u043C\u044C\u044F, \u0441\u0443\u0434\u044F \u043F\u043E \u0432\u0441\u0435\u043C\u0443,
    \u0431\u044B\u043B\u0430 **\u0437\u0430\u0436\u0438\u0442\u043E\u0447\u043D\u043E\u0439**:
    \u0435\u0433\u043E \u043E\u0442\u0435\u0446, \u0418\u043E\u0433\u0430\u043D\u043D
    \u041C\u044E\u043B\u043B\u0435\u0440-\u0441\u0442\u0430\u0440\u0448\u0438\u0439,
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442\u0441\u044F \u043A\u0430\u043A
    \u0447\u043B\u0435\u043D \u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u0432\u0435\u0442\u0430 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0430,
    \u0430 \u0435\u0433\u043E \u0441\u0435\u0441\u0442\u0440\u0430 \u041A\u0430\u0442\u0430\u0440\u0438\u043D\u0430
    \u0432\u044B\u0448\u043B\u0430 \u0437\u0430\u043C\u0443\u0436 \u0437\u0430 \u0431\u0443\u0440\u0433\u043E\u043C\u0438\u0441\u0442\u0440\u0430
    \u044D\u0442\u043E\u0433\u043E \u0436\u0435 \u0433\u043E\u0440\u043E\u0434\u0430
    .  ### \U0001F393 \u041E\u0431\u0443\u0447\u0435\u043D\u0438\u0435 \u0438 \u0440\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B  *   **\u0412\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434**:
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u043D\u0435\u043E\u0431\u044B\u0447\u0430\u0439\u043D\u044B\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u043E\u0447\u0435\u043D\u044C \u0440\u0430\u043D\u043E. \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    **11 \u043B\u0435\u0442** \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 **\u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442**
    . \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u043B\u0435\u0433\u0435\u043D\u0434\u0430,
    \u0447\u0442\u043E \u0432 12 \u043B\u0435\u0442 \u043E\u043D \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0440\u0443\u0447\u043D\u043E
    \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0431\u043E\u043B\u0435\u0435
    \u0442\u043E\u0447\u043D\u044B\u0439 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043B\u044C\u043C\u0430\u043D\u0430\u0445, \u0447\u0435\u043C \u0442\u043E\u0442,
    \u0447\u0442\u043E \u043D\u0435\u0434\u0430\u0432\u043D\u043E \u043D\u0430\u043F\u0435\u0447\u0430\u0442\u0430\u043B
    \u0413\u0443\u0442\u0435\u043D\u0431\u0435\u0440\u0433 . *   **\u0412\u0435\u043D\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434**: \u0412 1450 \u0433\u043E\u0434\u0443,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 14 \u043B\u0435\u0442,
    \u043E\u043D \u043F\u0435\u0440\u0435\u0448\u0435\u043B \u0432 **\u0412\u0435\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B\u043B \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438 . \u0412 1452 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430, \u043D\u043E \u0438\u0437-\u0437\u0430
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0445
    \u043F\u0440\u0430\u0432\u0438\u043B \u0431\u044B\u043B \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u0436\u0434\u0430\u0442\u044C \u0434\u043E 21 \u0433\u043E\u0434\u0430, \u0447\u0442\u043E\u0431\u044B
    \u0432 1457 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432 \u0438 \u043D\u0430\u0447\u0430\u0442\u044C
    \u0447\u0438\u0442\u0430\u0442\u044C \u043B\u0435\u043A\u0446\u0438\u0438 . 
    ### \U0001F468\u200D\U0001F3EB \u0420\u0430\u0431\u043E\u0442\u0430 \u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438 
    *   **\u041D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u041F\u0443\u0440\u0431\u0430\u0445\u0430**: \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C
    \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u043E \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430
    \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u0441 **\u0413\u0435\u043E\u0440\u0433\u043E\u043C
    \u041F\u0443\u0440\u0431\u0430\u0445\u043E\u043C** (Georg von Peuerbach), \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C
    \u0438 \u0434\u0440\u0443\u0433\u043E\u043C . \u041E\u043D\u0438 \u0432\u043C\u0435\u0441\u0442\u0435
    \u0432\u0435\u043B\u0438 \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F,
    \u0434\u0435\u043B\u0430\u043B\u0438 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B
    \u0438 \u043C\u0435\u0447\u0442\u0430\u043B\u0438 \u0438\u0441\u043F\u0440\u0430\u0432\u0438\u0442\u044C
    \u043D\u0435\u0442\u043E\u0447\u043D\u044B\u0435 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u044B
    \u0434\u0440\u0435\u0432\u043D\u0438\u0445 \u0442\u0435\u043A\u0441\u0442\u043E\u0432
    . *   **\u041A\u0430\u0440\u0434\u0438\u043D\u0430\u043B \u0412\u0438\u0441\u0441\u0430\u0440\u0438\u043E\u043D
    \u0438 \u043F\u043E\u0435\u0437\u0434\u043A\u0430 \u0432 \u0418\u0442\u0430\u043B\u0438\u044E**:
    \u0412 1460 \u0433\u043E\u0434\u0443 \u0432 \u0412\u0435\u043D\u0443 \u043F\u0440\u0438\u0431\u044B\u043B
    \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B **\u0412\u0438\u0441\u0441\u0430\u0440\u0438\u043E\u043D**
    (Basilios Bessarion), \u0433\u0440\u0435\u043A \u043F\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044E
    \u0438 \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u044B\u0439 \u043A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u043E\u043D\u0435\u0440
    \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u0445 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0435\u0439
    . \u041E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u041F\u0443\u0440\u0431\u0430\u0445\u0443
    \u043F\u043E\u0435\u0445\u0430\u0442\u044C \u0441 \u043D\u0438\u043C \u0432 \u0418\u0442\u0430\u043B\u0438\u044E,
    \u0447\u0442\u043E\u0431\u044B \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u043D\u043E\u0432\u044B\u0439,
    \u0442\u043E\u0447\u043D\u044B\u0439 \u043F\u0435\u0440\u0435\u0432\u043E\u0434
    \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0430\xBB \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F.
    \u041F\u0443\u0440\u0431\u0430\u0445 \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u043B\u0441\u044F
    \u043F\u0440\u0438 \u0443\u0441\u043B\u043E\u0432\u0438\u0438, \u0447\u0442\u043E
    \u0432\u043E\u0437\u044C\u043C\u0435\u0442 \u0441 \u0441\u043E\u0431\u043E\u0439
    \u0443\u0447\u0435\u043D\u0438\u043A\u0430. \u041E\u0434\u043D\u0430\u043A\u043E
    \u041F\u0443\u0440\u0431\u0430\u0445 \u0443\u043C\u0435\u0440 \u0432 1461 \u0433\u043E\u0434\u0443,
    \u0438 \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u0418\u0442\u0430\u043B\u0438\u044E \u043E\u0434\u0438\u043D, \u0432\u043E\u0439\u0434\u044F
    \u0432 \u0441\u0432\u0438\u0442\u0443 \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u0430
    . *   **\u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438
    \u0443\u0447\u0435\u043D\u044B\u043C\u0438 \u0438 \u043F\u043E\u043B\u0435\u043C\u0438\u043A\u0430**:
    \u0412 \u0418\u0442\u0430\u043B\u0438\u0438 \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0432 \u0446\u0435\u043D\u0442\u0440\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0431\u0430\u0442\u0430\u043B\u0438\u0439.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u043E\u043C
    \u0441\u0442\u0430\u043B **\u0413\u0435\u043E\u0440\u0433\u0438\u0439 \u0422\u0440\u0430\u043F\u0435\u0437\u0443\u043D\u0434\u0441\u043A\u0438\u0439**
    (George of Trebizond), \u0447\u0435\u0439 \u043F\u0435\u0440\u0435\u0432\u043E\u0434
    \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0430\xBB \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    \u0436\u0435\u0441\u0442\u043A\u043E \u0440\u0430\u0441\u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B
    . \u042D\u0442\u0430 \u0432\u0440\u0430\u0436\u0434\u0430, \u043A\u0430\u043A
    \u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0442, \u043F\u043E\u0437\u0436\u0435
    \u0441\u0442\u043E\u0438\u043B\u0430 \u0435\u043C\u0443 \u0436\u0438\u0437\u043D\u0438.
    \u0412 \u0442\u043E \u0436\u0435 \u0432\u0440\u0435\u043C\u044F \u043E\u043D
    \u0437\u0430\u0432\u044F\u0437\u0430\u043B \u043F\u0440\u043E\u0447\u043D\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0441\u0432\u044F\u0437\u0438 \u0441
    \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u043C\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438,
    \u0442\u0430\u043A\u0438\u043C\u0438 \u043A\u0430\u043A **\u0414\u0436\u043E\u0432\u0430\u043D\u043D\u0438
    \u0411\u044C\u044F\u043D\u043A\u0438\u043D\u0438** (Giovanni Bianchini) . *  
    **\u0412\u0435\u043D\u0433\u0440\u0438\u044F**: \u0421 1467 \u043F\u043E 1471
    \u0433\u043E\u0434 \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043F\u0440\u0438 \u0434\u0432\u043E\u0440\u0435
    \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u044F
    **\u041C\u0430\u0442\u0432\u0435\u044F \u041A\u043E\u0440\u0432\u0438\u043D\u0430**,
    \u0433\u0434\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0435\u0439
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u0435\u0439 . *  
    **\u041D\u044E\u0440\u043D\u0431\u0435\u0440\u0433 \u0438 \u0434\u0440\u0443\u0436\u0431\u0430
    \u0441 \u0412\u0430\u043B\u044C\u0442\u0435\u0440\u043E\u043C**: \u0412 1471
    \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u041D\u044E\u0440\u043D\u0431\u0435\u0440\u0433, \u0433\u0434\u0435 \u0435\u0433\u043E
    \u0431\u043B\u0438\u0437\u043A\u0438\u043C \u0434\u0440\u0443\u0433\u043E\u043C
    \u0438 \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u0435\u043C
    \u0441\u0442\u0430\u043B \u0431\u043E\u0433\u0430\u0442\u044B\u0439 \u043A\u0443\u043F\u0435\u0446
    **\u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434 \u0412\u0430\u043B\u044C\u0442\u0435\u0440**
    (Bernhard Walther). \u0412\u043C\u0435\u0441\u0442\u0435 \u043E\u043D\u0438 \u0441\u043E\u0437\u0434\u0430\u043B\u0438
    \u043E\u0434\u043D\u0443 \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u0432
    \u0415\u0432\u0440\u043E\u043F\u0435 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0439 \u0438
    \u043E\u0441\u043D\u043E\u0432\u0430\u043B\u0438 \u043D\u0430\u0443\u0447\u043D\u0443\u044E
    \u0442\u0438\u043F\u043E\u0433\u0440\u0430\u0444\u0438\u044E .  ### \u2620\uFE0F
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0441\u043C\u0435\u0440\u0442\u044C  *   **\u0412\u044B\u0437\u043E\u0432
    \u0432 \u0420\u0438\u043C**: \u0412 1475 \u0433\u043E\u0434\u0443 \u043F\u0430\u043F\u0430
    **\u0421\u0438\u043A\u0441\u0442 IV** \u043F\u0440\u0438\u0437\u0432\u0430\u043B
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D\u0430 \u0432
    \u0420\u0438\u043C \u0434\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B \u043D\u0430\u0434
    \u0440\u0435\u0444\u043E\u0440\u043C\u043E\u0439 \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044F,
    \u043F\u043E\u043E\u0431\u0435\u0449\u0430\u0432 \u0435\u043C\u0443 \u0441\u0430\u043D
    \u0435\u043F\u0438\u0441\u043A\u043E\u043F\u0430 \u0420\u0435\u0433\u0435\u043D\u0441\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0433\u043E
    . *   **\u0422\u0430\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u043A\u043E\u043D\u0447\u0438\u043D\u0430**: \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    \u043F\u0440\u0438\u0431\u044B\u043B \u0432 \u0420\u0438\u043C, \u043D\u043E
    \u0443\u0436\u0435 \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043C\u0435\u0441\u044F\u0446\u0435\u0432, **6 \u0438\u044E\u043B\u044F 1476
    \u0433\u043E\u0434\u0430**, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    40 \u043B\u0435\u0442 \u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    . \u041E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u0438
    \u0434\u0432\u0435 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0432\u0435\u0440\u0441\u0438\u0438:    
    1.  **\u0427\u0443\u043C\u0430**: \u041D\u0430\u0438\u0431\u043E\u043B\u0435\u0435
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0430\u044F \u043F\u0440\u0438\u0447\u0438\u043D\u0430.
    \u0412 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u0432 \u0420\u0438\u043C\u0435
    \u0441\u0432\u0438\u0440\u0435\u043F\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u044F \u0447\u0443\u043C\u044B, \u0443\u0441\u0443\u0433\u0443\u0431\u043B\u0435\u043D\u043D\u0430\u044F
    \u0440\u0430\u0437\u043B\u0438\u0432\u043E\u043C \u0422\u0438\u0431\u0440\u0430
    .     2.  **\u041E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435**: \u0423\u043F\u043E\u0440\u043D\u0430\u044F
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430, \u0447\u0442\u043E \u0435\u0433\u043E
    \u043E\u0442\u0440\u0430\u0432\u0438\u043B\u0438 \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0438
    \u0413\u0435\u043E\u0440\u0433\u0438\u044F \u0422\u0440\u0430\u043F\u0435\u0437\u0443\u043D\u0434\u0441\u043A\u043E\u0433\u043E
    \u0438\u0437 \u043C\u0435\u0441\u0442\u0438 \u0437\u0430 \u0435\u0433\u043E \u043A\u0440\u0438\u0442\u0438\u043A\u0443
    . \u042D\u0442\u0430 \u0432\u0435\u0440\u0441\u0438\u044F, \u0445\u043E\u0442\u044F
    \u0438 \u0436\u0438\u0432\u043E\u043F\u0438\u0441\u043D\u0430, \u043D\u0435 \u0438\u043C\u0435\u0435\u0442
    \u043F\u0440\u044F\u043C\u044B\u0445 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u0438 \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u043F\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C
    \u043B\u0438\u0448\u044C \u0441\u043F\u0443\u0441\u0442\u044F \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    .  \u0415\u0441\u043B\u0438 \u0432\u0430\u0441 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0443\u044E\u0442
    \u043A\u0430\u043A\u0438\u0435-\u0442\u043E \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0435
    \u0434\u0435\u0442\u0430\u043B\u0438 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438
    \u0438\u043B\u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441
    \u0442\u0435\u043C \u0438\u043B\u0438 \u0438\u043D\u044B\u043C \u0443\u0447\u0435\u043D\u044B\u043C,
    \u044F \u0433\u043E\u0442\u043E\u0432 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u0442\u044C
    \u043E\u0431 \u044D\u0442\u043E\u043C \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0435."
  personalLifeEn: 
  shortBioRu: "\u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    (\u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0435 \u0438\u043C\u044F **\u0418\u043E\u0433\u0430\u043D\u043D
    \u041C\u044E\u043B\u043B\u0435\u0440**) \u2014 \u043E\u0434\u0438\u043D \u0438\u0437
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u0443\u043C\u043E\u0432
    XV \u0432\u0435\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043F\u043E \u043F\u0440\u0430\u0432\u0443 \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \xAB\u043E\u0442\u0446\u043E\u043C \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0439
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C, \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u0432\u0448\u0438\u043C
    \u043F\u043E\u0447\u0432\u0443 \u0434\u043B\u044F \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430, \u043F\u043E\u043B\u043D\u0430\u044F
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0439, \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439 \u0438 \u0438\u043D\u0442\u0440\u0438\u0433. 
    ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435 (1436\u20131461) 
    *   **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435:**
    \u041E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F 6 \u0438\u044E\u043D\u044F
    1436 \u0433\u043E\u0434\u0430 \u0432 \u0431\u0430\u0432\u0430\u0440\u0441\u043A\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u0435 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433
    (\u0447\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442 \xAB\u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u0433\u043E\u0440\u0430\xBB, \u043E\u0442\u0441\u044E\u0434\u0430 \u0435\u0433\u043E
    \u043B\u0430\u0442\u0438\u043D\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0435
    \u0438\u043C\u044F Regiomontanus) \u0432 \u0441\u0435\u043C\u044C\u0435 \u043C\u0435\u043B\u044C\u043D\u0438\u043A\u0430.
    \u0412\u043E\u043F\u0440\u0435\u043A\u0438 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u043D\u043E\u043C\u0443
    \u0437\u0430\u0431\u043B\u0443\u0436\u0434\u0435\u043D\u0438\u044E, \u043E\u043D
    \u043D\u0435 \u0438\u043C\u0435\u0435\u0442 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u043A \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0443 \u0432
    \u041F\u0440\u0443\u0441\u0441\u0438\u0438 (\u043D\u044B\u043D\u0435 \u041A\u0430\u043B\u0438\u043D\u0438\u043D\u0433\u0440\u0430\u0434).
    *   **\u0412\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434:** \u041F\u0440\u043E\u044F\u0432\u0438\u043B
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u0443\u0436\u0435 \u0432 11 \u043B\u0435\u0442, \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u0432
    \u0432 \u041B\u0435\u0439\u043F\u0446\u0438\u0433\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    (1447\u20131450). \u0412 1450 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0432 \u0412\u0435\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0442\u043E\u0433\u0434\u0430 \u0431\u044B\u043B \u0446\u0435\u043D\u0442\u0440\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438. *   **\u0412\u0441\u0442\u0440\u0435\u0447\u0430
    \u0441 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C:**
    \u0412 \u0412\u0435\u043D\u0435 \u043E\u043D \u0441\u0442\u0430\u043B \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C
    \u0438 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0438\u043C \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u043E\u043C
    \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0433\u043E\u0441\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430
    **\u0413\u0435\u043E\u0440\u0433\u0430 \u041F\u0443\u0440\u0431\u0430\u0445\u0430**.
    \u042D\u0442\u0430 \u0434\u0440\u0443\u0436\u0431\u0430 \u0438 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0438 \u0432\u0441\u044E
    \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C. \u0412\u043C\u0435\u0441\u0442\u0435 \u043E\u043D\u0438
    \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u043B\u0438 \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u0435
    \u0442\u0435\u043B\u0430, \u0438\u0437\u0433\u043E\u0442\u0430\u0432\u043B\u0438\u0432\u0430\u043B\u0438
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B \u0438 \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B\u0438
    \u043D\u0435\u0442\u043E\u0447\u043D\u044B\u0435 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u044B
    \u0434\u0440\u0435\u0432\u043D\u0438\u0445 \u0442\u0435\u043A\u0441\u0442\u043E\u0432.
    *   **\u041F\u0435\u0440\u0432\u044B\u0435 \u0443\u0441\u043F\u0435\u0445\u0438:**
    \u0412 1452 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430,
    \u0430 \u0432 1457 \u0433\u043E\u0434\u0443, \u043F\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0438
    21 \u0433\u043E\u0434\u0430, \u2014 \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432
    \u0438 \u0431\u044B\u043B \u0437\u0430\u0447\u0438\u0441\u043B\u0435\u043D \u0432
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0439
    \u0441\u043E\u0441\u0442\u0430\u0432 \u0412\u0435\u043D\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430.  ###
    \U0001F1EE\U0001F1F9 \u0418\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 \u0438 \u0442\u0440\u0438\u0443\u043C\u0444
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    (1461\u20131467)  \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0441\u0442\u0430\u043B \u043F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u043C
    \u0432 \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0435.  *   **\u041C\u0438\u0441\u0441\u0438\u044F
    \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u0430:** \u0412 1460 \u0433\u043E\u0434\u0443
    \u0432 \u0412\u0435\u043D\u0443 \u043F\u0440\u0438\u0431\u044B\u043B \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B
    **\u0412\u0438\u0441\u0441\u0430\u0440\u0438\u043E\u043D**, \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C
    \u043D\u0430\u0443\u043A. \u041E\u043D \u043F\u043E\u0440\u0443\u0447\u0438\u043B
    \u041F\u0443\u0440\u0431\u0430\u0445\u0443 \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u043D\u043E\u0432\u044B\u0439, \u0431\u043E\u043B\u0435\u0435 \u0442\u043E\u0447\u043D\u044B\u0439
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434 \u0438 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0439
    \u043A \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0443\xBB \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F.
    \u041F\u0443\u0440\u0431\u0430\u0445 \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u043B\u0441\u044F,
    \u043D\u043E \u043F\u0440\u0438 \u0443\u0441\u043B\u043E\u0432\u0438\u0438, \u0447\u0442\u043E
    \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    \u043F\u043E\u0435\u0434\u0435\u0442 \u0441 \u043D\u0438\u043C \u0432 \u0418\u0442\u0430\u043B\u0438\u044E.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0432 1461 \u0433\u043E\u0434\u0443 \u041F\u0443\u0440\u0431\u0430\u0445
    \u0443\u043C\u0435\u0440, \u0443\u0441\u043F\u0435\u0432 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u0442\u044C
    \u043B\u0438\u0448\u044C \u0447\u0430\u0441\u0442\u044C \u0440\u0430\u0431\u043E\u0442\u044B.
    \u0423\u043C\u0438\u0440\u0430\u044F, \u043E\u043D \u0437\u0430\u0432\u0435\u0449\u0430\u043B
    \u0441\u0432\u043E\u0435\u043C\u0443 \u0443\u0447\u0435\u043D\u0438\u043A\u0443
    \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u044C \u044D\u0442\u043E\u0442
    \u0442\u0440\u0443\u0434. *   **\u0416\u0438\u0437\u043D\u044C \u0432 \u0418\u0442\u0430\u043B\u0438\u0438:**
    \u0421\u0434\u0435\u0440\u0436\u0430\u0432 \u0441\u043B\u043E\u0432\u043E, \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432 \u0418\u0442\u0430\u043B\u0438\u044E,
    \u0432\u043E\u0439\u0434\u044F \u0432 \u0441\u0432\u0438\u0442\u0443 \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u0430
    \u0412\u0438\u0441\u0441\u0430\u0440\u0438\u043E\u043D\u0430. \u041E\u043D \u0436\u0438\u043B
    \u0432 \u0420\u0438\u043C\u0435, \u0412\u0438\u0442\u0435\u0440\u0431\u043E,
    \u0412\u0435\u043D\u0435\u0446\u0438\u0438, \u041F\u0430\u0434\u0443\u0435 \u0438
    \u0424\u0435\u0440\u0440\u0430\u0440\u0435. \u0417\u0434\u0435\u0441\u044C \u043E\u043D
    \u0432 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u0435
    \u043E\u0432\u043B\u0430\u0434\u0435\u043B \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u043C
    \u044F\u0437\u044B\u043A\u043E\u043C \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0424\u0435\u043E\u0434\u043E\u0440\u0430
    \u0413\u0430\u0437\u0441\u043A\u043E\u0433\u043E, \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u0441\u0442\u0443\u043F \u043A \u043B\u0443\u0447\u0448\u0438\u043C
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0430\u043C \u0415\u0432\u0440\u043E\u043F\u044B
    \u0438 \u0441\u043A\u043E\u043F\u0438\u0440\u043E\u0432\u0430\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0435\u0439. *   **\u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434:** \u0412 1462\u20131464 \u0433\u043E\u0434\u0430\u0445
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u0439
    magnum opus \u2014 \u0442\u0440\u0430\u043A\u0442\u0430\u0442 **\xAB\u041E \u0432\u0441\u0435\u0445
    \u0432\u0438\u0434\u0430\u0445 \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432\xBB**
    (De triangulis omnimodis). \u042D\u0442\u043E\u0442 \u043F\u044F\u0442\u0438\u0442\u043E\u043C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u0441\u0442\u0430\u043B \u043F\u0435\u0440\u0432\u044B\u043C
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    (\u043F\u043B\u043E\u0441\u043A\u043E\u0439 \u0438 \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439)
    \u043A\u0430\u043A \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u044B, \u0430 \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u0432\u0441\u043F\u043E\u043C\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430 \u0434\u043B\u044F
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438. \u041E\u043D \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0442\u043E\u0447\u043D\u044B\u0435 \u0442\u0430\u0431\u043B\u0438\u0446\u044B
    \u0441\u0438\u043D\u0443\u0441\u043E\u0432 \u0438 \u0442\u0430\u043D\u0433\u0435\u043D\u0441\u043E\u0432.
    *   **\u0417\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0435 \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0430\xBB:**
    \u041A 1463 \u0433\u043E\u0434\u0443 \u043E\u043D \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0430\u0434 \xAB\u042D\u043F\u0438\u0442\u043E\u043C\u043E\u0439
    \u201E\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0430\u201C\xBB
    (Epytoma in almagesti Ptolemei), \u0438\u0441\u043F\u0440\u0430\u0432\u0438\u0432
    \u043E\u0448\u0438\u0431\u043A\u0438 \u043F\u0440\u0435\u0434\u044B\u0434\u0443\u0449\u0438\u0445
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u043E\u0432. \u041F\u043E\u0437\u0436\u0435
    \u044D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434 \u0441\u0442\u0430\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043D\u043E\u0439
    \u043A\u043D\u0438\u0433\u043E\u0439 \u0434\u043B\u044F \u041D\u0438\u043A\u043E\u043B\u0430\u044F
    \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430.  ### \U0001F451 \u041F\u0440\u0438
    \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u043C \u0434\u0432\u043E\u0440\u0435
    \u0438 \u0440\u0430\u0441\u0446\u0432\u0435\u0442 \u0432 \u041D\u044E\u0440\u043D\u0431\u0435\u0440\u0433\u0435
    (1467\u20131475)  *   **\u0412\u0435\u043D\u0433\u0440\u0438\u044F (1467\u20131471):**
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D \u043F\u0440\u0438\u043D\u044F\u043B
    \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435 \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u044F **\u041C\u0430\u0442\u0432\u0435\u044F \u041A\u043E\u0440\u0432\u0438\u043D\u0430**
    \u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0411\u0443\u0434\u0443,
    \u0433\u0434\u0435 \u0437\u0430\u0432\u0435\u0434\u043E\u0432\u0430\u043B \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u043E\u0439 \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043A\u0430\u043A \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A.
    \u0422\u0430\u043C \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B Tabulae directionum \u0434\u043B\u044F
    \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0441\u0447\u0435\u0442\u043E\u0432. *   **\u041D\u044E\u0440\u043D\u0431\u0435\u0440\u0433
    (1471\u20131475):** \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0438\u043A
    \u0435\u0433\u043E \u0441\u043B\u0430\u0432\u044B. \u0412 1471 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u041D\u044E\u0440\u043D\u0431\u0435\u0440\u0433
    \u2014 \u0446\u0435\u043D\u0442\u0440 \u0440\u0435\u043C\u0435\u0441\u0435\u043B
    \u0438 \u0442\u043E\u0440\u0433\u043E\u0432\u043B\u0438. \u0417\u0434\u0435\u0441\u044C
    \u0435\u0433\u043E \u0431\u043E\u0433\u0430\u0442\u044B\u0439 \u0434\u0440\u0443\u0433
    \u0438 \u0443\u0447\u0435\u043D\u0438\u043A, \u043A\u0443\u043F\u0435\u0446 **\u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434
    \u0412\u0430\u043B\u044C\u0442\u0435\u0440**, \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E **\u043F\u0435\u0440\u0432\u0443\u044E
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u044E** \u0438
    \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043B \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u0443\u044E
    \u0434\u043B\u044F \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0442\u043E\u0447\u043D\u0435\u0439\u0448\u0438\u0445
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432. *  
    **\u041F\u0435\u0447\u0430\u0442\u043D\u0438\u043A \u0438 \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u044C:**
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E \u043D\u0430\u0443\u0447\u043D\u0443\u044E
    \u0442\u0438\u043F\u043E\u0433\u0440\u0430\u0444\u0438\u044E, \u0441\u0442\u0430\u0432
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0438\u043E\u043D\u0435\u0440\u043E\u0432
    \u043A\u043D\u0438\u0433\u043E\u043F\u0435\u0447\u0430\u0442\u0430\u043D\u0438\u044F.
    \u041E\u043D \u0438\u0437\u0434\u0430\u0432\u0430\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0432\u043E\u0438 \u0440\u0430\u0431\u043E\u0442\u044B, \u043D\u043E \u0438
    \u0442\u0440\u0443\u0434\u044B \u0434\u0440\u0435\u0432\u043D\u0438\u0445 \u0443\u0447\u0435\u043D\u044B\u0445,
    \u043D\u0430\u043F\u0435\u0447\u0430\u0442\u0430\u043B \xAB\u0422\u0435\u043E\u0440\u0438\u0438
    \u043F\u043B\u0430\u043D\u0435\u0442\xBB \u0441\u0432\u043E\u0435\u0433\u043E
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F \u041F\u0443\u0440\u0431\u0430\u0445\u0430
    \u0438 \u0441\u0432\u043E\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    **\u044D\u0444\u0435\u043C\u0435\u0440\u0438\u0434\u044B** (\u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B \u043D\u0430 1475\u20131506 \u0433\u043E\u0434\u044B),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u0442\u0430\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043D\u043E\u0439
    \u043A\u043D\u0438\u0433\u043E\u0439 \u043C\u043E\u0440\u0435\u043F\u043B\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    (\u0438\u0445 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0434\u0430\u0436\u0435 \u0425\u0440\u0438\u0441\u0442\u043E\u0444\u043E\u0440
    \u041A\u043E\u043B\u0443\u043C\u0431!).  ### \U0001F56F\uFE0F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u0430\u044F
    \u0441\u043C\u0435\u0440\u0442\u044C (1475\u20131476)  *   **\u0412\u044B\u0437\u043E\u0432
    \u0432 \u0420\u0438\u043C:** \u0412 1475 \u0433\u043E\u0434\u0443 \u043F\u0430\u043F\u0430
    \u0421\u0438\u043A\u0441\u0442 IV \u043F\u0440\u0438\u0437\u0432\u0430\u043B
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D\u0430 \u0432
    \u0420\u0438\u043C \u0434\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B \u043D\u0430\u0434
    \u0440\u0435\u0444\u043E\u0440\u043C\u043E\u0439 \u044E\u043B\u0438\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044F, \u043F\u043E\u043E\u0431\u0435\u0449\u0430\u0432
    \u0435\u043C\u0443 \u0441\u0430\u043D \u0435\u043F\u0438\u0441\u043A\u043E\u043F\u0430
    \u0420\u0435\u0433\u0435\u043D\u0441\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0433\u043E.
    *   **\u0422\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u043A\u043E\u043D\u0435\u0446:**
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D \u043F\u0440\u0438\u0431\u044B\u043B
    \u0432 \u0420\u0438\u043C, \u043D\u043E \u0443\u0436\u0435 \u0447\u0435\u0440\u0435\u0437
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0435\u0441\u044F\u0446\u0435\u0432,
    6 \u0438\u044E\u043B\u044F 1476 \u0433\u043E\u0434\u0430, \u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F.
    \u0415\u043C\u0443 \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E 40
    \u043B\u0435\u0442. \u041E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u0438
    \u0441\u043B\u0443\u0445\u0438.     *   **\u041E\u0441\u043D\u043E\u0432\u043D\u0430\u044F
    \u0432\u0435\u0440\u0441\u0438\u044F:** **\u0427\u0443\u043C\u0430** (\u0432
    \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u0432 \u0420\u0438\u043C\u0435 \u0431\u044B\u043B\u0430
    \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u044F).     *   **\u041B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u0430\u044F
    \u0432\u0435\u0440\u0441\u0438\u044F:** **\u041E\u0442\u0440\u0430\u0432\u0430**.
    \u0425\u043E\u0434\u0438\u043B\u0438 \u0443\u043F\u043E\u0440\u043D\u044B\u0435
    \u0441\u043B\u0443\u0445\u0438, \u0447\u0442\u043E \u0435\u0433\u043E \u043E\u0442\u0440\u0430\u0432\u0438\u043B\u0438
    \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0438 \u0413\u0435\u043E\u0440\u0433\u0430
    \u0422\u0440\u0430\u043F\u0435\u0437\u0443\u043D\u0434\u0441\u043A\u043E\u0433\u043E
    \u2014 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430, \u0447\u0435\u0439 \u043D\u0435\u0442\u043E\u0447\u043D\u044B\u0439
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434 \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0430\xBB
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D \u0436\u0435\u0441\u0442\u043A\u043E
    \u0440\u0430\u0441\u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B
    \u0432 \u0441\u0432\u043E\u0438\u0445 \u0442\u0440\u0443\u0434\u0430\u0445. 
    ### \U0001F31F \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0438 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u043D\u0430\u0443\u043A\u0443  *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:**
    \u041F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u0432 \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u0443\u044E \u043D\u0430\u0443\u043A\u0443.
    \u0412\u0432\u0435\u043B \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u0442\u0430\u0431\u043B\u0438\u0446\u044B
    \u0442\u0430\u043D\u0433\u0435\u043D\u0441\u043E\u0432 \u0438 \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u044B\u0435
    \u0434\u0440\u043E\u0431\u0438. *   **\u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F:**
    \u0417\u0430\u0432\u0435\u0440\u0448\u0438\u0432 \u043F\u0435\u0440\u0435\u0432\u043E\u0434
