    \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0435 \u0437\u043D\u0430\u043D\u0438\u0435
    \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u043C. \u0415\u0433\u043E \u043C\u0435\u0442\u043E\u0434
    \xAB\u043B\u0443\u043D\u043D\u044B\u0445 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0439\xBB
    \u0434\u043B\u044F \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u0434\u043E\u043B\u0433\u043E\u0442\u044B \u043D\u0430 \u043C\u043E\u0440\u0435
    \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u043C \u0432
    \u043D\u0430\u0432\u0438\u0433\u0430\u0446\u0438\u0438. *   **\u0410\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u044F:**
    \u0425\u043E\u0442\u044F \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u044D\u0442\u043E
    \u043A\u0430\u0436\u0435\u0442\u0441\u044F \u0441\u043F\u043E\u0440\u043D\u044B\u043C,
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D \u0431\u044B\u043B
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u043E\u0432 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u043D\u043E\u0432\u0443\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u043E\u043C\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440. *   **\u0412\u043B\u0438\u044F\u043D\u0438\u0435:**
    \u0415\u0433\u043E \u0438\u0434\u0435\u0438 \u0438 \u0442\u0440\u0443\u0434\u044B
    \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0438
    \u043D\u0430 \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043D\u0430 \u0442\u0430\u043A\u0438\u0445 \u0433\u0438\u0433\u0430\u043D\u0442\u043E\u0432
