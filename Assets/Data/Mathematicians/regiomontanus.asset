    \u041B\u0443\u043D\u0435."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D\u0430
    \u043F\u043E\u043B\u043D\u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u0435\u043B\u0438\u043A\u0438\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439, \u043D\u043E \u0438
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445, \u0430
    \u043F\u043E\u0440\u043E\u0439 \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0445
    \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u0435\u043B\u0430\u044E\u0442 \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u044F\u0440\u043A\u043E\u0439. 
    ### \U0001F632 \u041B\u0443\u043D\u043D\u044B\u0439 \u0447\u0435\u043B\u043E\u0432\u0435\u043A:
    \u0430\u0432\u0442\u043E\u043F\u043E\u0440\u0442\u0440\u0435\u0442 \u043D\u0430
    \u043D\u0435\u0431\u0435?  \u041E\u0434\u0438\u043D \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u0442\u0440\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u0438
    \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0445 \u0444\u0430\u043A\u0442\u043E\u0432
    \u0441\u0432\u044F\u0437\u0430\u043D \u0441 \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u043C
    \u0438\u0437\u0434\u0430\u043D\u0438\u0435\u043C \u0435\u0433\u043E \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044F, \u043D\u0430\u043F\u0435\u0447\u0430\u0442\u0430\u043D\u043D\u043E\u0433\u043E
    \u0432 1482 \u0433\u043E\u0434\u0443 \u0432 \u0412\u0435\u043D\u0435\u0446\u0438\u0438
    \u0435\u0433\u043E \u043F\u043E\u0447\u0438\u0442\u0430\u0442\u0435\u043B\u0435\u043C
    \u042D\u0440\u0445\u0430\u0440\u0434\u043E\u043C \u0420\u0430\u0442\u0434\u043E\u043B\u044C\u0442\u043E\u043C.
    \u0412 \u0446\u0435\u043D\u0442\u0440\u0435 \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044F
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0434\u0432\u0438\u0436\u043D\u0430\u044F
    \u043A\u0430\u0440\u0442\u0430 \u041B\u0443\u043D\u044B (\u043B\u0443\u043D\u043D\u0430\u044F
    \u0432\u043E\u043B\u0432\u0435\u043B\u043B\u0430). \u0412 \u043D\u0435\u0435
    \u0431\u044B\u043B\u043E \u0432\u043C\u043E\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043E
    **\u0440\u0435\u0430\u043B\u0438\u0441\u0442\u0438\u0447\u043D\u043E\u0435 \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0444\u0438\u043B\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    \u0441 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043D\u044B\u043C \u043D\u043E\u0441\u043E\u043C**
    \u0432 \u0432\u0438\u0434\u0435 \u043F\u043E\u043B\u0443\u043C\u0435\u0441\u044F\u0446\u0430. 
    \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E \u044D\u0442\u043E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0439
    \xAB\u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0432 \u041B\u0443\u043D\u0435\xBB,
    \u0430 **\u043F\u043E\u0434\u043B\u0438\u043D\u043D\u044B\u0439 \u043F\u043E\u0440\u0442\u0440\u0435\u0442
    \u0441\u0430\u043C\u043E\u0433\u043E \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D\u0430**,
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u044B\u0439
    \u043F\u043E \u043F\u0430\u043C\u044F\u0442\u0438 \u0435\u0433\u043E \u0434\u0440\u0443\u0433\u043E\u043C
    \u0438 \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u043C. \u041E\u043D \u0443\u043C\u0435\u0440
    \u0437\u0430 \u0448\u0435\u0441\u0442\u044C \u043B\u0435\u0442 \u0434\u043E \u044D\u0442\u043E\u0433\u043E,
    \u0438 \u0420\u0430\u0442\u0434\u043E\u043B\u044C\u0442 \u0442\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0441\u043E\u0437\u0434\u0430\u043B
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439 \u0438 \u043F\u043E\u044D\u0442\u0438\u0447\u043D\u044B\u0439
    \u043F\u0430\u043C\u044F\u0442\u043D\u0438\u043A \u0441\u0432\u043E\u0435\u043C\u0443
    \u0443\u0447\u0438\u0442\u0435\u043B\u044E, \u043D\u0430\u0432\u0435\u0447\u043D\u043E
    \u043F\u043E\u043C\u0435\u0441\u0442\u0438\u0432 \u0435\u0433\u043E \u043D\u0430
    \u043D\u0435\u0431\u0435\u0441\u0430.  ### \U0001F311 \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F,
    \u0441\u043F\u0430\u0441\u0448\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u041A\u043E\u043B\u0443\u043C\u0431\u0443 
    \u0421\u0430\u043C\u0430\u044F \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u0430\u044F
    \u0441 \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435\u043C
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D\u0430, \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430
    \u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438.
    \u0412 1504 \u0433\u043E\u0434\u0443, \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0441\u0432\u043E\u0435\u0439 \u0447\u0435\u0442\u0432\u0435\u0440\u0442\u043E\u0439
    \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u0438, \u0425\u0440\u0438\u0441\u0442\u043E\u0444\u043E\u0440
    \u041A\u043E\u043B\u0443\u043C\u0431 \u0438 \u0435\u0433\u043E \u043A\u043E\u043C\u0430\u043D\u0434\u0430
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C \u0432 \u0431\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0438 \u043D\u0430 \u042F\u043C\u0430\u0439\u043A\u0435.
    \u041C\u0435\u0441\u0442\u043D\u044B\u0435 \u0436\u0438\u0442\u0435\u043B\u0438,
    \u0443\u0441\u0442\u0430\u0432\u0448\u0438\u0435 \u043E\u0442 \u0430\u043B\u0447\u043D\u043E\u0441\u0442\u0438
    \u0438\u0441\u043F\u0430\u043D\u0446\u0435\u0432, \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0438\u0441\u044C
    \u0441\u043D\u0430\u0431\u0436\u0430\u0442\u044C \u0438\u0445 \u043F\u0440\u043E\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u0435\u043C. 
    \u0418 \u0442\u043E\u0433\u0434\u0430 \u041A\u043E\u043B\u0443\u043C\u0431\u0443
    \u043F\u0440\u0438\u0433\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u043A\u043D\u0438\u0433\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D \u0432\u0437\u044F\u043B
    \u0441 \u0441\u043E\u0431\u043E\u0439 \u0432 \u043F\u043B\u0430\u0432\u0430\u043D\u0438\u0435,
    \u2014 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435 \xAB\u042D\u0444\u0435\u043C\u0435\u0440\u0438\u0434\u044B\xBB
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D\u0430. \u0412
    \u043D\u0438\u0445 \u0431\u044B\u043B\u043E \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u043E
    \u043F\u043E\u043B\u043D\u043E\u0435 \u043B\u0443\u043D\u043D\u043E\u0435 \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u0435
    \u043D\u0430 29 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 1504 \u0433\u043E\u0434\u0430.
    \u041D\u0430\u043A\u0430\u043D\u0443\u043D\u0435 \u041A\u043E\u043B\u0443\u043C\u0431
    \u043F\u0440\u0438\u0433\u0440\u043E\u0437\u0438\u043B \u0432\u043E\u0436\u0434\u044F\u043C,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0431\u043E\u0433 \u0440\u0430\u0437\u0433\u043D\u0435\u0432\u0430\u0435\u0442\u0441\u044F
    \u0438 \u043B\u0438\u0448\u0438\u0442 \u0438\u0445 \u043B\u0443\u043D\u044B.
    \u041A\u043E\u0433\u0434\u0430 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u0435
    \u0441\u0431\u044B\u043B\u043E\u0441\u044C \u0432 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438,
    \u043F\u0435\u0440\u0435\u043F\u0443\u0433\u0430\u043D\u043D\u044B\u0435 \u0442\u0443\u0437\u0435\u043C\u0446\u044B
    \u0443\u043C\u043E\u043B\u044F\u043B\u0438 \u0435\u0433\u043E \u0432\u0435\u0440\u043D\u0443\u0442\u044C
    \u0441\u0432\u0435\u0442\u0438\u043B\u043E. \u041A\u043E\u043B\u0443\u043C\u0431,
    \u0442\u043E\u0447\u043D\u043E \u0437\u043D\u0430\u044F \u043F\u043E \u0442\u0430\u0431\u043B\u0438\u0446\u0430\u043C
    \u0432\u0440\u0435\u043C\u044F \u043E\u043A\u043E\u043D\u0447\u0430\u043D\u0438\u044F
    \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u044F, \xAB\u043F\u043E\u0448\u0435\u043B
    \u043D\u0430 \u0441\u0434\u0435\u043B\u043A\u0443\xBB \u0441 \u0431\u043E\u0436\u0435\u0441\u0442\u0432\u043E\u043C,
    \u0438 \u043B\u0443\u043D\u0430, \u043A\u0430\u043A \u043F\u043E \u0440\u0430\u0441\u043F\u0438\u0441\u0430\u043D\u0438\u044E,
    \u0432\u0435\u0440\u043D\u0443\u043B\u0430\u0441\u044C \u043D\u0430 \u043D\u0435\u0431\u043E.
    \u0422\u0430\u043A \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F
    \u0441\u043F\u0430\u0441\u043B\u0430 \u0436\u0438\u0437\u043D\u044C \u0432\u0435\u043B\u0438\u043A\u043E\u043C\u0443
    \u043C\u043E\u0440\u0435\u043F\u043B\u0430\u0432\u0430\u0442\u0435\u043B\u044E. 
    ### \u2712\uFE0F \u041F\u043E\u043B\u0438\u0433\u043B\u043E\u0442 \u0438 \u043A\u043D\u0438\u0436\u043D\u044B\u0439
    \u043E\u0445\u043E\u0442\u043D\u0438\u043A  \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D
    \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u043D\u043E \u0438 \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u044B\u043C \u0431\u0438\u0431\u043B\u0438\u043E\u0444\u0438\u043B\u043E\u043C.
    \u041F\u0435\u0440\u0435\u0435\u0445\u0430\u0432 \u0432 \u0418\u0442\u0430\u043B\u0438\u044E
    \u0432 \u0441\u0432\u0438\u0442\u0435 \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u0430
    \u0412\u0438\u0441\u0441\u0430\u0440\u0438\u043E\u043D\u0430, \u043E\u043D \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u043C\u043D\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043F\u043E\u0438\u0441\u043A\u0443
    \u0434\u0440\u0435\u0432\u043D\u0438\u0445 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0435\u0439.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0435\u043C\u0443, \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u043C
    \u0433\u0443\u043C\u0430\u043D\u0438\u0441\u0442\u0430\u043C, \u0443\u0434\u0430\u043B\u043E\u0441\u044C
    \u043F\u0435\u0440\u0432\u044B\u043C \u0432 \u0415\u0432\u0440\u043E\u043F\u0435
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u0442\u044C \u0442\u0435\u043A\u0441\u0442
    \u0443\u0446\u0435\u043B\u0435\u0432\u0448\u0438\u0445 \u0448\u0435\u0441\u0442\u0438
    \u043A\u043D\u0438\u0433 \xAB\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\xBB
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430 \u2014 \u0442\u0440\u0443\u0434\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0437\u0436\u0435 \u043E\u043A\u0430\u0436\u0435\u0442
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0430\u043B\u0433\u0435\u0431\u0440\u044B. 
    \u0427\u0442\u043E\u0431\u044B \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u044C
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434 \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0430\xBB
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F, \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u043D\u044B\u0439
    \u0443\u043C\u0438\u0440\u0430\u044E\u0449\u0438\u043C \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C,
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D **\u0432 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u0435
    \u043E\u0432\u043B\u0430\u0434\u0435\u043B \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u043C
    \u044F\u0437\u044B\u043A\u043E\u043C** \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0424\u0435\u043E\u0434\u043E\u0440\u0430
    \u0413\u0430\u0437\u0441\u043A\u043E\u0433\u043E. \u0412\u043B\u0430\u0434\u0435\u043D\u0438\u0435
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u043C \u0431\u044B\u043B\u043E
    \u0440\u0435\u0434\u043A\u043E\u0441\u0442\u044C\u044E \u0434\u043B\u044F \u0443\u0447\u0435\u043D\u043E\u0433\u043E
    \u0421\u0435\u0432\u0435\u0440\u043D\u043E\u0439 \u0415\u0432\u0440\u043E\u043F\u044B
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.  ### \U0001F4D6
    \u041D\u043E\u0432\u0430\u0442\u043E\u0440 \u043A\u043D\u0438\u0433\u043E\u043F\u0435\u0447\u0430\u0442\u0430\u043D\u0438\u044F 
    \u041F\u0435\u0440\u0435\u0435\u0445\u0430\u0432 \u0432 \u041D\u044E\u0440\u043D\u0431\u0435\u0440\u0433,
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0438\u043F\u043E\u0433\u0440\u0430\u0444\u0438\u044E,
    \u0430 **\u043D\u0430\u0443\u0447\u043D\u0443\u044E \u0442\u0438\u043F\u043E\u0433\u0440\u0430\u0444\u0438\u044E**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0432 \u0441\u0432\u043E\u0435\u043C \u0440\u043E\u0434\u0435. \u0415\u0433\u043E
    \u0446\u0435\u043B\u044C\u044E \u0431\u044B\u043B\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u0435\u0447\u0430\u0442\u0430\u0442\u044C \u043A\u043D\u0438\u0433\u0438,
    \u0430 \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u043D\u0430\u043D\u0438\u044F \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u043C\u0438
    \u0434\u043B\u044F \u0448\u0438\u0440\u043E\u043A\u043E\u0433\u043E \u043A\u0440\u0443\u0433\u0430
    \u0447\u0438\u0442\u0430\u0442\u0435\u043B\u0435\u0439 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043D\u043E\u0432\u043E\u0433\u043E \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F
    \u2014 \u043F\u0435\u0447\u0430\u0442\u043D\u043E\u0433\u043E \u0441\u0442\u0430\u043D\u043A\u0430. 
    \u0415\u0433\u043E \u043A\u043D\u0438\u0433\u0438 \u0431\u044B\u043B\u0438 \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0435\u043A\u0441\u0442\u043E\u043C.
    \u041E\u043D \u0432\u0432\u0435\u043B \u0432 \u043D\u0438\u0445 \u0438\u043D\u043D\u043E\u0432\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u0434\u043B\u044F \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    **\u043F\u0435\u0447\u0430\u0442\u043D\u044B\u0435 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u0438\u0430\u0433\u0440\u0430\u043C\u043C\u044B \u0438 \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B**, \u0430 \u0432 \u043A\u043E\u043D\u0446\u0435
    \u0435\u0433\u043E \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044F \u0431\u044B\u043B\u0438
    \u0434\u0430\u0436\u0435 \u0432\u043A\u043B\u0430\u0434\u043A\u0438 \u0441 \u0431\u0443\u043C\u0430\u0436\u043D\u044B\u043C\u0438
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430\u043C\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u043E\u0436\u043D\u043E \u0431\u044B\u043B\u043E
    \u0432\u044B\u0440\u0435\u0437\u0430\u0442\u044C \u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C! 
    ### \U0001F92B \u0422\u0430\u0439\u043D\u0430, \u043E\u043A\u0443\u0442\u0430\u043D\u043D\u0430\u044F
    \u043B\u0435\u0433\u0435\u043D\u0434\u043E\u0439  \u0421\u043C\u0435\u0440\u0442\u044C
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D\u0430 \u0432
    \u0420\u0438\u043C\u0435 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    40 \u043B\u0435\u0442, \u043A\u0443\u0434\u0430 \u043E\u043D \u0431\u044B\u043B
    \u043F\u0440\u0438\u0437\u0432\u0430\u043D \u0434\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B
    \u043D\u0430\u0434 \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u043D\u043E\u0439
    \u0440\u0435\u0444\u043E\u0440\u043C\u043E\u0439, \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u0430
    \u043E\u0434\u043D\u0443 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0436\u0438\u0432\u0443\u0447\u0438\u0445
    \u043B\u0435\u0433\u0435\u043D\u0434. \u041F\u043E\u043C\u0438\u043C\u043E \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0432\u0435\u0440\u0441\u0438\u0438 \u043E \u0441\u043C\u0435\u0440\u0442\u0438
    \u043E\u0442 \u0447\u0443\u043C\u044B (\u0432 \u0433\u043E\u0440\u043E\u0434\u0435
    \u043A\u0430\u043A \u0440\u0430\u0437 \u0431\u044B\u043B\u0430 \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u044F),
    \u0445\u043E\u0434\u0438\u043B\u0438 \u0443\u043F\u043E\u0440\u043D\u044B\u0435
    \u0441\u043B\u0443\u0445\u0438 \u043E\u0431 **\u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0438**.
    \u041C\u043E\u043B\u0432\u0430 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0430
    \u043D\u0430 \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    \u0435\u0433\u043E \u0434\u0430\u0432\u043D\u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u043E\u043F\u043F\u043E\u043D\u0435\u043D\u0442\u0430, \u0413\u0435\u043E\u0440\u0433\u0438\u044F
    \u0422\u0440\u0430\u043F\u0435\u0437\u0443\u043D\u0434\u0441\u043A\u043E\u0433\u043E,
    \u0447\u0435\u0439 \u043F\u0435\u0440\u0435\u0432\u043E\u0434 \xAB\u0410\u043B\u044C\u043C\u0430\u0433\u0435\u0441\u0442\u0430\xBB
    \u0420\u0435\u0433\u0438\u043E\u043C\u043E\u043D\u0442\u0430\u043D \u0436\u0435\u0441\u0442\u043A\u043E
    \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B. \u0425\u043E\u0442\u044F
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u044D\u0442\u043E\u0439 \u0432\u0435\u0440\u0441\u0438\u0438 \u043D\u0435\u0442,
    \u043E\u043D\u0430 \u0434\u0435\u043B\u0430\u0435\u0442 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E
    \u043F\u043E\u0445\u043E\u0436\u0435\u0439 \u043D\u0430 \u0434\u0435\u0442\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0439
    \u0440\u043E\u043C\u0430\u043D.  \u0415\u0441\u043B\u0438 \u043A\u0430\u043A\u043E\u0439-\u0442\u043E
    \u0438\u0437 \u044D\u0442\u0438\u0445 \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432
    \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B
    \u0432\u0430\u0441 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E, \u044F \u043C\u043E\u0433\u0443
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u0442\u044C \u043E \u043D\u0435\u043C
    \u0435\u0449\u0435 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0435."
