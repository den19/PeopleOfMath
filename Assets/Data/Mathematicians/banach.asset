  achievementsRu: "\u0421\u0442\u0435\u0301\u0444\u0430\u043D \u0411\u0430\u0301\u043D\u0430\u0445
    (\u043F\u043E\u043B. Stefan Banach; \u0440\u043E\u0434. 30 \u043C\u0430\u0440\u0442\u0430
    1892, \u041A\u0440\u0430\u043A\u043E\u0432, \u0410\u0432\u0441\u0442\u0440\u043E-\u0412\u0435\u043D\u0433\u0440\u0438\u044F
    \u2014 31 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1945, \u041B\u044C\u0432\u043E\u0432,
    \u0423\u0421\u0421\u0420, \u0421\u0421\u0421\u0420) \u2014 \u043F\u043E\u043B\u044C\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u042F\u043D\u0430
    \u041A\u0430\u0437\u0438\u043C\u0438\u0440\u0430 (1924), \u0434\u0435\u043A\u0430\u043D
    \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0430 \u041B\u044C\u0432\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 (1939).
    \u0427\u043B\u0435\u043D \u041F\u043E\u043B\u044C\u0441\u043A\u043E\u0439 \u0410\u041D.
    \u041E\u0434\u0438\u043D \u0438\u0437 \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u0438 \u043B\u044C\u0432\u043E\u0432\u0441\u043A\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B.\n\n== \u0411\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    == \u0420\u043E\u0434\u0438\u043B\u0441\u044F \u0432 \u0441\u0435\u043C\u044C\u0435
    \u0421\u0442\u0435\u0444\u0430\u043D\u0430 \u0413\u0440\u0435\u0447\u0435\u043A\u0430
    \u0438 \u041A\u0430\u0442\u0430\u0436\u0438\u043D\u044B \u0411\u0430\u043D\u0430\u0445,
    \u0443\u0440\u043E\u0436\u0435\u043D\u0446\u0435\u0432 \u044E\u0436\u043D\u043E-\u043F\u043E\u043B\u044C\u0441\u043A\u043E\u0439
    \u043F\u0440\u043E\u0432\u0438\u043D\u0446\u0438\u0438 \u041F\u043E\u0434\u0433\u0430\u043B\u044C\u0435.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446 \u0431\u044B\u043B \u0440\u044F\u0434\u043E\u0432\u044B\u043C
    \u0438 \u043D\u0435 \u0438\u043C\u0435\u043B \u043F\u0440\u0430\u0432\u0430 \u0436\u0435\u043D\u0438\u0442\u044C\u0441\u044F,
    \u0430 \u043C\u0430\u0442\u044C \u0431\u044B\u043B\u0430 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0431\u0435\u0434\u043D\u043E\u0439, u0\u2026"
  achievementsEn: 
  personalLifeRu: "\u0412 \u0433\u043E\u0434\u044B \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0439
    \u043E\u043A\u043A\u0443\u043F\u0430\u0446\u0438\u0438 \u041B\u044C\u0432\u043E\u0432\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0431\u044B\u043B
    \u0437\u0430\u043A\u0440\u044B\u0442, \u0411\u0430\u043D\u0430\u0445 \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0432 \u0442\u044E\u0440\u044C\u043C\u0435, \u043D\u043E \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E
    \u0431\u044B\u0441\u0442\u0440\u043E \u0431\u044B\u043B \u0432\u044B\u043F\u0443\u0449\u0435\u043D
    \u0438 \u0441\u0443\u043C\u0435\u043B \u0443\u0441\u0442\u0440\u043E\u0438\u0442\u044C\u0441\u044F
    \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0443 \xAB\u043A\u043E\u0440\u043C\u0438\u0442\u0435\u043B\u044F
    \u0432\u0448\u0435\u0439\xBB \u043D\u0430 \u0437\u0430\u0432\u043E\u0434 \u043F\u043E
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u0443 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0442\u0438\u0444\u043E\u0437\u043D\u043E\u0439
    \u0432\u0430\u043A\u0446\u0438\u043D\u044B \u043F\u0440\u0438 \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435
    \u043F\u043E \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044E
    \u0442\u0438\u0444\u0430 \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u0420\u0443\u0434\u043E\u043B\u044C\u0444\u0430
    \u0412\u0430\u0439\u0433\u043B\u044F. \u042D\u0442\u043E \u0431\u044B\u043B\u0430
    \u043E\u0434\u043D\u0430 \u0438\u0437 \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0445
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0435\u0439 \u0434\u043B\u044F
    \u0411\u0430\u043D\u0430\u0445\u0430 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 \u043E\u043A\u043A\u0443\u043F\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u043C
    \u041B\u044C\u0432\u043E\u0432\u0435, \u0434\u0430\u044E\u0449\u0430\u044F \u0442\u0430\u043A\u0436\u0435
    \u0437\u0430\u0449\u0438\u0442\u0443 \u043E\u0442 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0445
    \u0440\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u0439 \u0441\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u044B
    \u043E\u043A\u043A\u0443\u043F\u0430\u043D\u0442\u043E\u0432. \u0412\u043C\u0435\u0441\u0442\u0435
    \u0441 \u0411\u0430\u043D\u0430\u0445\u043E\u043C \xAB\u043A\u043E\u0440\u043C\u0438\u0442\u0435\u043B\u044F\u043C\u0438
    \u0432\u0448\u0435\u0439\xBB \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438
    \u043C\u043D\u043E\u0433\u0438u0\u2026"
  personalLifeEn: 
  shortBioRu: "\u0421\u0442\u0435\u0301\u0444\u0430\u043D \u0411\u0430\u0301\u043D\u0430\u0445_\u2014
    \u043F\u043E\u043B\u044C\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u042F\u043D\u0430 \u041A\u0430\u0437\u0438\u043C\u0438\u0440\u0430 (1924), \u0434\u0435\u043A\u0430\u043D
    \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0430 \u041B\u044C\u0432\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 (1939)."
