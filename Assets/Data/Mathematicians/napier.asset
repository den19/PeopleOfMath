  achievementsRu: "\u0414\u0436\u043E\u043D \u041D\u0435\u043F\u0435\u0440 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0437\u0430\u043C\u0435\u0442\u043D\u044B\u0439 \u0441\u043B\u0435\u0434 \u0432
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043D\u0430\u0443\u043A\u0438, \u0438
    \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C, \u043F\u0443\u0441\u0442\u044C \u0438 \u0432\u0435\u043B\u0438\u043A\u0438\u043C,
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\u043C. \u0415\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u043D\u0430 \u0442\u0440\u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0441\u0444\u0435\u0440\u044B,
    \u043A\u0430\u0436\u0434\u0430\u044F \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043F\u043E-\u0441\u0432\u043E\u0435\u043C\u0443 \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430
    \u043C\u0438\u0440 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439. 
    ### \u2728 \u0418\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432: \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u0432 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F\u0445  \u042D\u0442\u043E
    \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u0438 \u0441\u0430\u043C\u043E\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u041D\u0435\u043F\u0435\u0440\u0430, \u043D\u0430\u0434 \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043E\u043A\u043E\u043B\u043E
    20 \u043B\u0435\u0442, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043D\u0430\u0447\u0438\u043D\u0430\u044F
    \u0441 1594 \u0433\u043E\u0434\u0430. \u0415\u0433\u043E \u0446\u0435\u043B\u044C\u044E
    \u0431\u044B\u043B\u043E \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u0438\u0435
    \u0442\u0440\u0443\u0434\u043E\u0435\u043C\u043A\u0438\u0445 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0441\u0447\u0435\u0442\u043E\u0432. \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C
    \u0441\u0442\u0430\u043B\u0438 \u0434\u0432\u0430 \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0442\u0440\u0443\u0434\u0430:  *   **\xAB\u041E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439 \u0442\u0430\u0431\u043B\u0438\u0446\u044B
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432\xBB (Mirifici Logarithmorum
    Canonis Descriptio, 1614)**: \u0412 \u044D\u0442\u043E\u0439 \u043A\u043D\u0438\u0433\u0435,
    \u0441\u043E\u0441\u0442\u043E\u044F\u0449\u0435\u0439 \u0438\u0437 57 \u0441\u0442\u0440\u0430\u043D\u0438\u0446
    \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u0439 \u0438 90 \u0441\u0442\u0440\u0430\u043D\u0438\u0446
    \u0442\u0430\u0431\u043B\u0438\u0446, \u041D\u0435\u043F\u0435\u0440 \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0441\u0432\u043E\u0435
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435 \u043C\u0438\u0440\u0443.
    \u041E\u043D \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B \u043F\u0440\u0438\u0440\u043E\u0434\u0443
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432 \u0438, \u0447\u0442\u043E
    \u0441\u0430\u043C\u043E\u0435 \u0432\u0430\u0436\u043D\u043E\u0435, \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u043A\u0430\u043A \u0438\u0445 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C,
    \u0447\u0442\u043E\u0431\u044B \u0437\u0430\u043C\u0435\u043D\u0438\u0442\u044C
    \u0441\u043B\u043E\u0436\u043D\u043E\u0435 \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435
    \u0438 \u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u043E\u0435
    \u0441\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0438 \u0432\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u0435.
    \u041A\u043D\u0438\u0433\u0430 \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u0431\u0443\u0434\u0443\u0449\u0435\u043C\u0443 \u043A\u043E\u0440\u043E\u043B\u044E
    \u041A\u0430\u0440\u043B\u0443 I. *   **\xAB\u041F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439 \u0442\u0430\u0431\u043B\u0438\u0446\u044B
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432\xBB (Mirifici Logarithmorum
    Canonis Constructio, 1619)**: \u042D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434
    \u0431\u044B\u043B \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D
    \u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E. \u0412 \u043D\u0435\u043C \u041D\u0435\u043F\u0435\u0440
    \u0440\u0430\u0441\u043A\u0440\u044B\u043B \u043C\u0435\u0442\u043E\u0434\u043E\u043B\u043E\u0433\u0438\u044E,
    \u043B\u0435\u0436\u0430\u0449\u0443\u044E \u0432 \u043E\u0441\u043D\u043E\u0432\u0435
    \u0435\u0433\u043E \u0440\u0430\u0441\u0447\u0435\u0442\u043E\u0432, \u0438 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E
    \u043E\u043F\u0438\u0441\u0430\u043B, \u043A\u0430\u043A \u043E\u043D \u0441\u0442\u0440\u043E\u0438\u043B
    \u0441\u0432\u043E\u0438 \u0442\u0430\u0431\u043B\u0438\u0446\u044B. \u0412 \u044D\u0442\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 \u0442\u0430\u043A\u0436\u0435 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u0430\u044F
    \u0442\u043E\u0447\u043A\u0430 \u0434\u043B\u044F \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u0434\u0440\u043E\u0431\u043D\u043E\u0439 \u0447\u0430\u0441\u0442\u0438 \u0447\u0438\u0441\u043B\u0430,
    \u0447\u0442\u043E \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0430\u0446\u0438\u0438
    \u044D\u0442\u043E\u0439 \u043D\u043E\u0442\u0430\u0446\u0438\u0438.  **\u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0434\u0435\u0442\u0430\u043B\u0438:** *   **\u0412\u043B\u0438\u044F\u043D\u0438\u0435**:
    \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0431\u044B\u043B\u043E \u043F\u0440\u0438\u043D\u044F\u0442\u043E
    \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E \u0438 \u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C
    \u044D\u043D\u0442\u0443\u0437\u0438\u0430\u0437\u043C\u043E\u043C. \u0410\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A **\u0413\u0435\u043D\u0440\u0438
    \u0411\u0440\u0438\u0433\u0433\u0441** \u043F\u043E\u0441\u0435\u0442\u0438\u043B
    \u041D\u0435\u043F\u0435\u0440\u0430 \u0432 1615 \u0433\u043E\u0434\u0443, \u0438
    \u043E\u043D\u0438 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0440\u0435\u0448\u0438\u043B\u0438
    \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443, \u0441\u043E\u0437\u0434\u0430\u0432
    \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u044B\u0435 (\u0431\u0440\u0438\u0433\u0433\u043E\u0432\u044B)
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u044B, \u0433\u0434\u0435 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C
    \u0435\u0434\u0438\u043D\u0438\u0446\u044B \u0440\u0430\u0432\u0435\u043D \u043D\u0443\u043B\u044E.
    *   **\u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435**: \u041A\u0430\u043A
    \u043F\u043E\u0437\u0436\u0435 \u0441\u043A\u0430\u0437\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u041F\u044C\u0435\u0440-\u0421\u0438\u043C\u043E\u043D \u041B\u0430\u043F\u043B\u0430\u0441,
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u044B, **\xAB\u043F\u0440\u043E\u0434\u043B\u0438\u043B\u0438
    \u0436\u0438\u0437\u043D\u044C \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430\u043C\xBB**,
    \u0438\u0437\u0431\u0430\u0432\u0438\u0432 \u0438\u0445 \u043E\u0442 \u0443\u0442\u043E\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438 \u0434\u043E\u043B\u0433\u0438\u0445 \u0440\u0430\u0441\u0447\u0451\u0442\u043E\u0432.
    \u0425\u043E\u0442\u044F \u0438\u0437\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u043E\u043D\u0438 \u0431\u044B\u043B\u0438 \u0441\u043E\u0437\u0434\u0430\u043D\u044B
    \u0434\u043B\u044F \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438, \u0438\u0445
    \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u044C \u0434\u043B\u044F \u043D\u0430\u0432\u0438\u0433\u0430\u0446\u0438\u0438
    \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B\u0430 \u043D\u0435\u043E\u0446\u0435\u043D\u0438\u043C\u0430. 
    ### \U0001F9B4 \u041C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430  \u041F\u043E\u043C\u0438\u043C\u043E
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432, \u041D\u0435\u043F\u0435\u0440
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432 \u0434\u043B\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u0438 \u0441\u0447\u0435\u0442\u0430,
    \u043E\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0445 \u0432 \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0435 **\xAB\u0420\u0430\u0431\u0434\u043E\u043B\u043E\u0433\u0438\u044F\xBB
    (Rabdologiae, 1617)**. \u042D\u0442\u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F
    \u0441\u0442\u0430\u043B\u0438 \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438
    \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u0445 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0430\u043B\u044C\u043A\u0443\u043B\u044F\u0442\u043E\u0440\u043E\u0432
    \u0438 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u0438\u043D\u0435\u0439\u043A\u0438.  *   **\xAB\u041F\u0430\u043B\u043E\u0447\u043A\u0438
    \u041D\u0435\u043F\u0435\u0440\u0430\xBB (Napier's Bones)**: \u042D\u0442\u043E
    \u043D\u0430\u0431\u043E\u0440 \u043F\u0440\u044F\u043C\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u043F\u0430\u043B\u043E\u0447\u0435\u043A (\u0438\u0437 \u043A\u043E\u0441\u0442\u0438
    \u0438\u043B\u0438 \u0434\u0435\u0440\u0435\u0432\u0430), \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0430\u043D\u0435\u0441\u0435\u043D\u044B \u0442\u0430\u0431\u043B\u0438\u0446\u044B
    \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u044F \u0432 \u0432\u0438\u0434\u0435
    \u0440\u0435\u0448\u0435\u0442\u043A\u0438. \u0421 \u0438\u0445 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435 \u0438 \u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043C\u043D\u043E\u0433\u043E\u0437\u043D\u0430\u0447\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B
    \u0441\u0432\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u043A \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u044B\u043C
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u044F\u043C \u0441\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u0438 \u0432\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u044F. \u042D\u0442\u043E
    \u0431\u044B\u043B \u0441\u0432\u043E\u0435\u0433\u043E \u0440\u043E\u0434\u0430
    \xAB\u043A\u0430\u0440\u043C\u0430\u043D\u043D\u044B\u0439 \u043A\u0430\u043B\u044C\u043A\u0443\u043B\u044F\u0442\u043E\u0440\xBB
    XVII \u0432\u0435\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u044C.
    *   **\u041F\u0440\u043E\u043C\u043F\u0442\u0443\u0430\u0440\u0438\u0439 (Promptuary)**:
    \u0411\u043E\u043B\u0435\u0435 \u0441\u043B\u043E\u0436\u043D\u043E\u0435 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E,
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0449\u0435\u0435
    \u0441\u043E\u0431\u043E\u0439 \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u043D\u0443\u044E
    \u0432\u0435\u0440\u0441\u0438\u044E \u043F\u0430\u043B\u043E\u0447\u0435\u043A
    \u0434\u043B\u044F \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u044F. \u041E\u043D\u043E
    \u0434\u043E\u043B\u0436\u043D\u043E \u0431\u044B\u043B\u043E \u0438\u0437\u0431\u0430\u0432\u0438\u0442\u044C
    \u043E\u0442 \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u0447\u043D\u044B\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B, \u043D\u043E, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u0438\u0437-\u0437\u0430 \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u0438\u0437\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u0438\u044F \u043D\u0435
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u043E \u0448\u0438\u0440\u043E\u043A\u043E\u0433\u043E
    \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044F.
    *   **\xAB\u0428\u0430\u0445\u043C\u0430\u0442\u043D\u044B\u0439 \u043A\u0430\u043B\u044C\u043A\u0443\u043B\u044F\u0442\u043E\u0440\xBB
    (Chessboard Calculator)**: \u0422\u0440\u0435\u0442\u044C\u0435 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E,
    \u043E\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0435 \u0432 \xAB\u0420\u0430\u0431\u0434\u043E\u043B\u043E\u0433\u0438\u0438\xBB,
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u0441\u043E\u0431\u043E\u0439
    \u0441\u0430\u043C\u0443\u044E \u0440\u0430\u043D\u043D\u044E\u044E \u0438\u0437
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043C\u0430\u0448\u0438\u043D, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0449\u0438\u0445
    **\u0434\u0432\u043E\u0438\u0447\u043D\u0443\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F**. \u041D\u0435\u043F\u0435\u0440
    \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u043B \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0442\u044C
    \u0447\u0438\u0441\u043B\u0430 \u043D\u0430 \u0448\u0430\u0445\u043C\u0430\u0442\u043D\u043E\u0439
    \u0434\u043E\u0441\u043A\u0435 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0444\u0438\u0448\u0435\u043A, \u0433\u0434\u0435 \u043A\u0430\u0436\u0434\u0430\u044F
    \u043A\u043B\u0435\u0442\u043A\u0430 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u0435\u0442
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0434\u0432\u043E\u0439\u043A\u0438. \u042D\u0442\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u0434\u043B\u044F \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u043E \u0434\u0432\u043E\u0438\u0447\u043D\u043E\u0439 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0435
    \u043F\u043E\u0447\u0442\u0438 \u043D\u0430 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0435. 
    ### \U0001F4D0 \u0412\u043A\u043B\u0430\u0434 \u0432 \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u044E 
    \u041D\u0435\u043F\u0435\u0440 \u0432\u043D\u0435\u0441 \u0432\u0430\u0436\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u2014 \u0440\u0430\u0437\u0434\u0435\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u0430\u0436\u043D\u044B\u0439
    \u0434\u043B\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u0438 \u043D\u0430\u0432\u0438\u0433\u0430\u0446\u0438\u0438.  *   \u041E\u043D
    \u0441\u0432\u0435\u043B \u0434\u0435\u0441\u044F\u0442\u044C \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C\u044B\u0445
    \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432,
    \u043A \u0434\u0432\u0443\u043C \u043E\u0431\u0449\u0438\u043C \u043F\u0440\u0430\u0432\u0438\u043B\u0430\u043C,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C \u043A\u0430\u043A **\xAB\u041F\u0440\u0430\u0432\u0438\u043B\u0430
    \u043A\u0440\u0443\u0433\u043E\u0432\u044B\u0445 \u0447\u0430\u0441\u0442\u0435\u0439
    \u041D\u0435\u043F\u0435\u0440\u0430\xBB** (Napier's Rules of Circular Parts).
    *   \u0415\u043C\u0443 \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0435 \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0432 \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u044B\u0435 **\xAB\u0430\u043D\u0430\u043B\u043E\u0433\u0438\u044F\u043C\u0438
    \u041D\u0435\u043F\u0435\u0440\u0430\xBB**, \u0445\u043E\u0442\u044F \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438 \u0441\u0447\u0438\u0442\u0430\u044E\u0442,
    \u0447\u0442\u043E \u0432 \u0438\u0445 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438
    \u043C\u043E\u0433 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u0438 \u0413\u0435\u043D\u0440\u0438 \u0411\u0440\u0438\u0433\u0433\u0441. 
    \u041F\u043E\u043C\u0438\u043C\u043E \u044D\u0442\u0438\u0445 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439, \u041D\u0435\u043F\u0435\u0440
    \u0442\u0430\u043A\u0436\u0435 \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u0443\u044E \u043D\u043E\u0442\u0430\u0446\u0438\u044E
    \u0421\u0442\u0435\u0432\u0438\u043D\u0430, \u0432\u0432\u0435\u0434\u044F \u0442\u043E\u0447\u043A\u0443
    \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u0435\u043B\u044F,
    \u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0434\u043B\u044F \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u0438\u043D\u0435\u0439\u043A\u0438. \u041A\u0430\u043A \u0432\u0438\u0434\u0438\u0442\u0435,
    \u0435\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u043E
    \u0438 \u0432\u043A\u043B\u044E\u0447\u0430\u0435\u0442 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u043E\u0440\u044B\u0432\u044B, \u043D\u043E \u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432\u0435\u043A\u0430\u043C\u0438 \u0441\u043B\u0443\u0436\u0438\u043B\u0438
    \u043B\u044E\u0434\u044F\u043C \u043D\u0430\u0443\u043A\u0438."
  achievementsEn: 
  personalLifeRu: "### \U0001F3F0 \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435  \u0414\u0436\u043E\u043D
    \u041D\u0435\u043F\u0435\u0440 \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0432
    **1550 \u0433\u043E\u0434\u0443** \u0432 \u0440\u043E\u0434\u043E\u0432\u043E\u043C
    \u0437\u0430\u043C\u043A\u0435 **\u041C\u0435\u0440\u0447\u0438\u0441\u0442\u043E\u043D**
    \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E \u043E\u0442 \u042D\u0434\u0438\u043D\u0431\u0443\u0440\u0433\u0430.
    \u0415\u0433\u043E \u043E\u0442\u0446\u043E\u043C \u0431\u044B\u043B \u0441\u044D\u0440
    **\u0410\u0440\u0447\u0438\u0431\u0430\u043B\u044C\u0434 \u041D\u0435\u043F\u0435\u0440**,
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443 \u043D\u0430 \u043C\u043E\u043C\u0435\u043D\u0442
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0441\u044B\u043D\u0430 \u0431\u044B\u043B\u043E
    \u0432\u0441\u0435\u0433\u043E 16 \u043B\u0435\u0442, \u0430 \u043C\u0430\u0442\u0435\u0440\u044C\u044E
    \u2014 **\u0414\u0436\u0435\u043D\u0435\u0442 \u0411\u043E\u0441\u0443\u044D\u043B\u043B**,
    \u0434\u043E\u0447\u044C \u0447\u043B\u0435\u043D\u0430 \u043F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442\u0430
    \u0438 \u0441\u0435\u0441\u0442\u0440\u0430 \u0435\u043F\u0438\u0441\u043A\u043E\u043F\u0430
    \u041E\u0440\u043A\u043D\u0435\u0439\u0441\u043A\u043E\u0433\u043E. \u0421\u0435\u043C\u044C\u044F
    \u0432\u043B\u0430\u0434\u0435\u043B\u0430 \u043F\u043E\u043C\u0435\u0441\u0442\u044C\u0435\u043C
    \u041C\u0435\u0440\u0447\u0438\u0441\u0442\u043E\u043D \u0441 1430-\u0445 \u0433\u043E\u0434\u043E\u0432,
    \u0438 \u0414\u0436\u043E\u043D \u0441\u0442\u0430\u043B 8-\u043C \u043B\u044D\u0440\u0434\u043E\u043C
    \u041C\u0435\u0440\u0447\u0438\u0441\u0442\u043E\u043D\u0430 \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u0442\u0446\u0430 \u0432 1608 \u0433\u043E\u0434\u0443. 
    ### \U0001F4DA \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F  \u041E
    \u0440\u0430\u043D\u043D\u0438\u0445 \u0433\u043E\u0434\u0430\u0445 \u041D\u0435\u043F\u0435\u0440\u0430
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043D\u0435\u043C\u043D\u043E\u0433\u043E.
    \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E \u0434\u043E
    13 \u043B\u0435\u0442 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0430\u043B
    \u0434\u043E\u043C\u0430\u0448\u043D\u0435\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435.
    \u0412 1563 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 **\u0421\u0435\u043D\u0442-\u042D\u043D\u0434\u0440\u044E\u0441\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442**, \u0432
    \u043A\u043E\u043B\u043B\u0435\u0434\u0436 **St Salvator's**, \u0433\u0434\u0435
    \u0435\u0433\u043E \u043C\u0430\u0442\u044C \u0434\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0430\u0441\u044C,
    \u0447\u0442\u043E\u0431\u044B \u043E \u043D\u0451\u043C \u043B\u0438\u0447\u043D\u043E
    \u0437\u0430\u0431\u043E\u0442\u0438\u043B\u0441\u044F \u0440\u0435\u043A\u0442\u043E\u0440
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0414\u0436\u043E\u043D
    \u0420\u0435\u0437\u0435\u0440\u0444\u043E\u0440\u0434. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0432 \u0421\u0435\u043D\u0442-\u042D\u043D\u0434\u0440\u044E\u0441\u0435 \u0443
    \u041D\u0435\u043F\u0435\u0440\u0430 \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B\u0441\u044F \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441 \u043A \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u0438. 
    \u041E\u0434\u043D\u0430\u043A\u043E \u041D\u0435\u043F\u0435\u0440 \u043D\u0435
    \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u2014 \u0435\u0433\u043E \u0438\u043C\u044F \u043D\u0435 \u0444\u0438\u0433\u0443\u0440\u0438\u0440\u0443\u0435\u0442
    \u0432 \u0441\u043F\u0438\u0441\u043A\u0430\u0445 \u0432\u044B\u043F\u0443\u0441\u043A\u043D\u0438\u043A\u043E\u0432.
    \u042D\u0442\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u043E \u0441 \u043F\u0438\u0441\u044C\u043C\u043E\u043C
    \u0435\u0433\u043E \u0434\u044F\u0434\u0438 \u0410\u0434\u0430\u043C\u0430 \u0411\u043E\u0441\u0443\u044D\u043B\u043B\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432 1560 \u0433\u043E\u0434\u0443
    \u043D\u0430\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E \u0441\u043E\u0432\u0435\u0442\u043E\u0432\u0430\u043B
    \u043E\u0442\u0446\u0443 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C
    \u0414\u0436\u043E\u043D\u0430 \u0443\u0447\u0438\u0442\u044C\u0441\u044F \u0437\u0430
    \u0433\u0440\u0430\u043D\u0438\u0446\u0443, \u0442\u0430\u043A \u043A\u0430\u043A
    \u0432 \u0428\u043E\u0442\u043B\u0430\u043D\u0434\u0438\u0438 \"\u043E\u043D
    \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u043D\u0430\u0443\u0447\u0438\u0442\u044C\u0441\u044F
    \u043D\u0438\u0447\u0435\u043C\u0443 \u0445\u043E\u0440\u043E\u0448\u0435\u043C\u0443\". 
    \u041F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0432 \u044D\u0442\u043E\u043C\u0443
    \u0441\u043E\u0432\u0435\u0442\u0443, \u041D\u0435\u043F\u0435\u0440 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0443. \u0422\u043E\u0447\u043D\u044B\u0445
    \u0434\u0430\u043D\u043D\u044B\u0445 \u043E \u0442\u043E\u043C, \u0433\u0434\u0435
    \u043E\u043D \u0443\u0447\u0438\u043B\u0441\u044F, \u043D\u0435\u0442, \u043D\u043E
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0438
    \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0442, \u0447\u0442\u043E
    \u043E\u043D \u043C\u043E\u0433 \u043F\u043E\u0441\u0435\u0449\u0430\u0442\u044C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u044B \u0432\u043E
    **\u0424\u0440\u0430\u043D\u0446\u0438\u0438** (\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435), **\u0424\u043B\u0430\u043D\u0434\u0440\u0438\u0438**,
    **\u0418\u0442\u0430\u043B\u0438\u0438** \u0438 **\u041D\u0438\u0434\u0435\u0440\u043B\u0430\u043D\u0434\u0430\u0445**.
    \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C \u0432 \u0428\u043E\u0442\u043B\u0430\u043D\u0434\u0438\u044E
    \u0432 1571 \u0433\u043E\u0434\u0443, \u043E\u043D \u0432\u043B\u0430\u0434\u0435\u043B
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u043C \u044F\u0437\u044B\u043A\u043E\u043C,
    \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u0440\u0435\u0434\u043A\u043E\u0441\u0442\u044C\u044E
    \u0434\u043B\u044F \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. 
    ### \U0001F468\u200D\U0001F469\u200D\U0001F466 \u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435,
    \u0431\u0440\u0430\u043A \u0438 \u0436\u0438\u0437\u043D\u044C \u0432 \u043F\u043E\u043C\u0435\u0441\u0442\u044C\u0435 
    \u0412 1571 \u0433\u043E\u0434\u0443 \u041D\u0435\u043F\u0435\u0440 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u043D\u0430 \u0440\u043E\u0434\u0438\u043D\u0443. \u0412\u0441\u043A\u043E\u0440\u0435,
    \u0432 1572 \u0433\u043E\u0434\u0443, \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 16-\u043B\u0435\u0442\u043D\u0435\u0439 **\u042D\u043B\u0438\u0437\u0430\u0431\u0435\u0442
    \u0421\u0442\u0438\u0440\u043B\u0438\u043D\u0433**, \u0434\u043E\u0447\u0435\u0440\u0438
    \u0414\u0436\u0435\u0439\u043C\u0441\u0430 \u0421\u0442\u0438\u0440\u043B\u0438\u043D\u0433\u0430,
    4-\u0433\u043E \u043B\u044D\u0440\u0434\u0430 \u041A\u0438\u0440\u0430. \u0412
    1574 \u0433\u043E\u0434\u0443 \u043E\u043D \u043A\u0443\u043F\u0438\u043B \u0437\u0430\u043C\u043E\u043A
    \u0432 \u0413\u0430\u0440\u0442\u043D\u0435\u0441\u0441\u0435, \u043A\u0443\u0434\u0430
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0441 \u0441\u0435\u043C\u044C\u0451\u0439.
    \u0423 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0434\u0432\u043E\u0435
    \u0434\u0435\u0442\u0435\u0439, \u043D\u043E \u0432 1579 \u0433\u043E\u0434\u0443
    \u042D\u043B\u0438\u0437\u0430\u0431\u0435\u0442 \u0443\u043C\u0435\u0440\u043B\u0430. 
    \u041F\u043E\u0437\u0434\u043D\u0435\u0435 \u041D\u0435\u043F\u0435\u0440 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439 \u0440\u0430\u0437 \u043D\u0430
    **\u0410\u0433\u043D\u0435\u0441 \u0427\u0438\u0441\u0445\u043E\u043B\u043C**,
    \u043E\u0442 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0443 \u043D\u0435\u0433\u043E
    \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0435\u0449\u0451 \u0434\u0435\u0441\u044F\u0442\u044C
    \u0434\u0435\u0442\u0435\u0439. \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u043E\u0442\u0446\u0430 \u0432 1608 \u0433\u043E\u0434\u0443 \u041D\u0435\u043F\u0435\u0440
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0440\u043E\u0434\u043E\u0432\u043E\u0439
    \u0437\u0430\u043C\u043E\u043A \u041C\u0435\u0440\u0447\u0438\u0441\u0442\u043E\u043D,
    \u0433\u0434\u0435 \u0438 \u043F\u0440\u043E\u0436\u0438\u043B \u0434\u043E \u043A\u043E\u043D\u0446\u0430
    \u0436\u0438\u0437\u043D\u0438.  \u041E\u043D \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0441\u0435\u043B\u044C\u0441\u043A\u0438\u043C
    \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u043E\u043C, \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u044F
    \u043D\u0430\u0443\u0447\u043D\u044B\u0439 \u043F\u043E\u0434\u0445\u043E\u0434
    \u043A \u0443\u0434\u043E\u0431\u0440\u0435\u043D\u0438\u044E \u0437\u0435\u043C\u0435\u043B\u044C.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u041D\u0435\u043F\u0435\u0440
    \u0436\u0438\u043B \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E \u0443\u0435\u0434\u0438\u043D\u0451\u043D\u043D\u043E
    \u0438 \u0440\u0435\u0434\u043A\u043E \u043F\u043E\u043A\u0438\u0434\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0432\u043B\u0430\u0434\u0435\u043D\u0438\u044F.  ###
    \U0001F91D \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438
    \u0443\u0447\u0435\u043D\u044B\u043C\u0438  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0438\u0437\u043E\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043E\u0431\u0440\u0430\u0437 \u0436\u0438\u0437\u043D\u0438, \u041D\u0435\u043F\u0435\u0440
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u044B
    \u0441 \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E\u043C.
    \u041E\u043D \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0441\u044F
    \u0441 \u0432\u0435\u043B\u0438\u043A\u0438\u043C \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C
    **\u0422\u0438\u0445\u043E \u0411\u0440\u0430\u0433\u0435** \u0447\u0435\u0440\u0435\u0437
    \u043E\u0431\u0449\u0435\u0433\u043E \u0434\u0440\u0443\u0433\u0430 \u0414\u0436\u043E\u043D\u0430
    \u041A\u0440\u0435\u0439\u0433\u0430.  \u0421\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u2014 \u044D\u0442\u043E \u0432\u0441\u0442\u0440\u0435\u0447\u0430
    \u0441 **\u0413\u0435\u043D\u0440\u0438 \u0411\u0440\u0438\u0433\u0433\u0441\u043E\u043C**,
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0438\u0437 \u041E\u043A\u0441\u0444\u043E\u0440\u0434\u0430. \u0412 1615 \u0433\u043E\u0434\u0443
    \u0411\u0440\u0438\u0433\u0433\u0441 \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u044F\u043B
    \u0434\u043E\u043B\u0433\u043E\u0435 \u0438 \u0442\u0440\u0443\u0434\u043D\u043E\u0435
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0438\u0437
    \u041B\u043E\u043D\u0434\u043E\u043D\u0430 \u0432 \u042D\u0434\u0438\u043D\u0431\u0443\u0440\u0433,
    \u0447\u0442\u043E\u0431\u044B \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u0442\u044C\u0441\u044F
    \u0441 \u041D\u0435\u043F\u0435\u0440\u043E\u043C. \u0418\u0445 \u0432\u0441\u0442\u0440\u0435\u0447\u0430,
    \u043F\u0435\u0440\u0435\u0434\u0430\u043D\u043D\u0430\u044F \u043E\u0447\u0435\u0432\u0438\u0434\u0446\u0435\u043C,
    \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C \u0441 \u0442\u043E\u0433\u043E,
    \u0447\u0442\u043E \u043E\u043D\u0438 \u043F\u043E\u0447\u0442\u0438 \u0447\u0435\u0442\u0432\u0435\u0440\u0442\u044C
    \u0447\u0430\u0441\u0430 \u043C\u043E\u043B\u0447\u0430 \u0441\u043C\u043E\u0442\u0440\u0435\u043B\u0438
    \u0434\u0440\u0443\u0433 \u043D\u0430 \u0434\u0440\u0443\u0433\u0430, \u043F\u0440\u0435\u0436\u0434\u0435
    \u0447\u0435\u043C \u0437\u0430\u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C.
    \u0411\u0440\u0438\u0433\u0433\u0441 \u043D\u0430\u0447\u0430\u043B \u0441 \u0432\u043E\u0441\u0445\u0438\u0449\u0451\u043D\u043D\u044B\u0445
    \u0441\u043B\u043E\u0432: \"\u041C\u0438\u043B\u043E\u0440\u0434, \u044F \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u044F\u043B
    \u044D\u0442\u043E \u0434\u043E\u043B\u0433\u043E\u0435 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435
    \u043D\u0430\u0440\u043E\u0447\u043D\u043E, \u0447\u0442\u043E\u0431\u044B \u0443\u0432\u0438\u0434\u0435\u0442\u044C
    \u0432\u0430\u0441 \u043B\u0438\u0447\u043D\u043E...\". \u041E\u043D\u0438 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438 \u043D\u0430\u0434 \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432, \u0438 \u0411\u0440\u0438\u0433\u0433\u0441
    \u0432\u0437\u044F\u043B \u043D\u0430 \u0441\u0435\u0431\u044F \u0442\u0440\u0443\u0434
    \u043F\u043E \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E \u0442\u0430\u0431\u043B\u0438\u0446
    \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u044B\u0445 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432.
    \u0411\u0440\u0438\u0433\u0433\u0441 \u043F\u043E\u0441\u0435\u0449\u0430\u043B
    \u041D\u0435\u043F\u0435\u0440\u0430 \u0438 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u043C
    \u043B\u0435\u0442\u043E\u043C.  ### \U0001F480 \u0421\u043C\u0435\u0440\u0442\u044C 
    \u0414\u0436\u043E\u043D \u041D\u0435\u043F\u0435\u0440 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    4 \u0430\u043F\u0440\u0435\u043B\u044F 1617 \u0433\u043E\u0434\u0430 \u0432 \u0437\u0430\u043C\u043A\u0435
    \u041C\u0435\u0440\u0447\u0438\u0441\u0442\u043E\u043D. \u0418\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438
    \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442, \u0447\u0442\u043E \u043E\u043D
    \u0441\u0442\u0440\u0430\u0434\u0430\u043B \u043E\u0442 **\u043F\u043E\u0434\u0430\u0433\u0440\u044B**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u0438 \u0441\u0442\u0430\u043B\u0430 \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439
    \u0441\u043C\u0435\u0440\u0442\u0438. \u0412 \u0441\u0432\u043E\u0438\u0445 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    \u043E\u043D \u043D\u0435\u043E\u0434\u043D\u043E\u043A\u0440\u0430\u0442\u043D\u043E
    \u0436\u0430\u043B\u043E\u0432\u0430\u043B\u0441\u044F \u043D\u0430 \u043F\u043B\u043E\u0445\u043E\u0435
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435 \u0438 \u043D\u0435\u043C\u043E\u0449\u044C.
    \u0415\u0433\u043E \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0435 \u0431\u044B\u043B\u043E
    \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u043D\u043E \u0437\u0430 \u0447\u0435\u0442\u044B\u0440\u0435
    \u0434\u043D\u044F \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438. \u041C\u0435\u0441\u0442\u043E
    \u0435\u0433\u043E \u0437\u0430\u0445\u043E\u0440\u043E\u043D\u0435\u043D\u0438\u044F
    \u0442\u043E\u0447\u043D\u043E \u043D\u0435 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043E:
    \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u043E \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0431\u044B\u043B \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u0432 \u0446\u0435\u0440\u043A\u0432\u0438 \u0421\u0432. \u042D\u0433\u0438\u0434\u0438\u044F
    \u0432 \u042D\u0434\u0438\u043D\u0431\u0443\u0440\u0433\u0435, \u043D\u043E \u0435\u0441\u0442\u044C
    \u0432\u0435\u0441\u043A\u0438\u0435 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u043F\u043E\u043B\u0430\u0433\u0430\u0442\u044C, \u0447\u0442\u043E \u0435\u0433\u043E
    \u043E\u0441\u0442\u0430\u043D\u043A\u0438 \u043F\u043E\u043A\u043E\u044F\u0442\u0441\u044F
    \u0432 \u0441\u0442\u0430\u0440\u043E\u0439 \u0446\u0435\u0440\u043A\u0432\u0438
    \u0421\u0432. \u041A\u0430\u0442\u0431\u0435\u0440\u0442\u0430, \u0432 \u043F\u0440\u0438\u0445\u043E\u0434\u0435
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0441\u044F
    \u0437\u0430\u043C\u043E\u043A \u041C\u0435\u0440\u0447\u0438\u0441\u0442\u043E\u043D."
  personalLifeEn: 
  shortBioRu: "\u0414\u0436\u043E\u043D \u041D\u0435\u043F\u0435\u0440 (1550\u20131617)
    \u0431\u044B\u043B \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u043C
    \u0431\u0430\u0440\u043E\u043D\u043E\u043C, \u0447\u044C\u0451 \u0438\u043C\u044F
    \u043D\u0435\u0440\u0430\u0437\u0440\u044B\u0432\u043D\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u043E
    \u0441 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u0438\u0435\u043C
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430\u0443\u043A\u0438 \u2014 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435\u043C
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u0430
    \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u043E\u0432: \u043D\u0430\u0431\u043E\u0436\u043D\u044B\u0439
    \u043F\u0443\u0440\u0438\u0442\u0430\u043D\u0438\u043D, \u043E\u043D \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F
    \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u0435\u0439 \u0438 \u0430\u043B\u0445\u0438\u043C\u0438\u0435\u0439;
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043E\u043D \u0441\u0447\u0438\u0442\u0430\u043B \u0441\u0432\u043E\u0435\u0439
    \u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u043E\u0439
    \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0441\u043A\u0438\u0439 \u0442\u0440\u0430\u043A\u0442\u0430\u0442. 
    \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F,
    \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u0430\u044F \u0438\u0437
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u0434\u0435\u0442\u0430\u043B\u0435\u0439
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.  ### \U0001F3F0 \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B  \u0414\u0436\u043E\u043D
    \u041D\u0435\u043F\u0435\u0440 \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0432
    1550 \u0433\u043E\u0434\u0443 \u0432 \u0440\u043E\u0434\u043E\u0432\u043E\u043C
    \u0437\u0430\u043C\u043A\u0435 \u041C\u0435\u0440\u0447\u0438\u0441\u0442\u043E\u043D,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u043B \u0444\u0430\u043C\u0438\u043B\u044C\u043D\u043E\u0439
    \u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0446\u0438\u0435\u0439 \u0435\u0433\u043E
    \u0441\u0435\u043C\u044C\u0438 \u0441 XV \u0432\u0435\u043A\u0430 \u0438 \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0441\u044F
    \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E \u043E\u0442 \u042D\u0434\u0438\u043D\u0431\u0443\u0440\u0433\u0430.
    \u041E\u043D \u0431\u044B\u043B \u0441\u044B\u043D\u043E\u043C \u0441\u044D\u0440\u0430
    \u0410\u0440\u0447\u0438\u0431\u0430\u043B\u044C\u0434\u0430 \u041D\u0435\u043F\u0435\u0440\u0430,
    7-\u0433\u043E \u043B\u044D\u0440\u0434\u0430 \u041C\u0435\u0440\u0447\u0438\u0441\u0442\u043E\u043D\u0430,
    \u0438 \u0414\u0436\u0435\u043D\u0435\u0442 \u0411\u043E\u0441\u0443\u044D\u043B\u043B.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0438 \u0437\u043D\u0430\u0442\u043E\u043A
    \u043B\u0430\u0442\u044B\u043D\u0438, \u043F\u043E\u0437\u0436\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u043F\u043E\u0441\u0442 \u0433\u043B\u0430\u0432\u044B \u041C\u043E\u043D\u0435\u0442\u043D\u043E\u0433\u043E
    \u0434\u0432\u043E\u0440\u0430 \u0428\u043E\u0442\u043B\u0430\u043D\u0434\u0438\u0438.
    \u0421\u0430\u043C \u0414\u0436\u043E\u043D \u041D\u0435\u043F\u0435\u0440 \u0441\u0442\u0430\u043B
    8-\u043C \u043B\u044D\u0440\u0434\u043E\u043C \u041C\u0435\u0440\u0447\u0438\u0441\u0442\u043E\u043D\u0430
    \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u0442\u0446\u0430
    \u0432 1608 \u0433\u043E\u0434\u0443.  \u0412 13 \u043B\u0435\u0442, \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u043C\u0430\u0442\u0435\u0440\u0438 \u0432
    1563 \u0433\u043E\u0434\u0443, \u041D\u0435\u043F\u0435\u0440 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0421\u0435\u043D\u0442-\u042D\u043D\u0434\u0440\u044E\u0441\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043E\u043D \u043D\u0435 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B \u0435\u0433\u043E,
    \u0438, \u043A\u0430\u043A \u0431\u044B\u043B\u043E \u043F\u0440\u0438\u043D\u044F\u0442\u043E
    \u0441\u0440\u0435\u0434\u0438 \u0441\u044B\u043D\u043E\u0432\u0435\u0439 \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u043E\u0433\u043E
    \u0434\u0432\u043E\u0440\u044F\u043D\u0441\u0442\u0432\u0430, \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u043F\u043E
    \u0415\u0432\u0440\u043E\u043F\u0435. \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u043F\u043E\u0441\u0435\u0442\u0438\u043B \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044E,
    \u0424\u0440\u0430\u043D\u0446\u0438\u044E \u0438, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u0418\u0442\u0430\u043B\u0438\u044E, \u0433\u0434\u0435 \u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u043F\u0435\u0440\u0435\u0434\u043E\u0432\u044B\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u0442\u0430\u043A\u0438\u043C\u0438
    \u043A\u0430\u043A \u0421\u0438\u043C\u043E\u043D \u0421\u0442\u0435\u0432\u0438\u043D,
    \u0424\u0440\u0430\u043D\u0441\u0443\u0430 \u0412\u0438\u0435\u0442 \u0438 \u041C\u0438\u0445\u0430\u044D\u043B\u044C
    \u0428\u0442\u0438\u0444\u0435\u043B\u044C.  ### \U0001F468\u200D\U0001F469\u200D\U0001F466
    \u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0432 \u0428\u043E\u0442\u043B\u0430\u043D\u0434\u0438\u044E,
    \u0431\u0440\u0430\u043A \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F 
    \u0412 1571 \u0433\u043E\u0434\u0443 \u041D\u0435\u043F\u0435\u0440 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u043D\u0430 \u0440\u043E\u0434\u0438\u043D\u0443 \u0438 \u043F\u043E\u0441\u0435\u043B\u0438\u043B\u0441\u044F
    \u0432 \u0440\u043E\u0434\u043E\u0432\u043E\u043C \u0437\u0430\u043C\u043A\u0435,
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0431\u043E\u043B\u044C\u0448\u0435
    \u043D\u0435 \u0432\u044B\u0435\u0437\u0436\u0430\u043B \u043D\u0430\u0434\u043E\u043B\u0433\u043E.
    \u0421 \u044D\u0442\u043E\u0433\u043E \u043C\u043E\u043C\u0435\u043D\u0442\u0430
    \u0438 \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0441\u0432\u043E\u0438\u0445
    \u0434\u043D\u0435\u0439 \u043E\u043D \u0436\u0438\u043B \u0432 \u0428\u043E\u0442\u043B\u0430\u043D\u0434\u0438\u0438.
    \u0412 1572 \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u042D\u043B\u0438\u0437\u0430\u0431\u0435\u0442 \u0421\u0442\u0438\u0440\u043B\u0438\u043D\u0433,
    \u043E\u0442 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0443 \u043D\u0435\u0433\u043E
    \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C \u0441\u044B\u043D \u0438 \u0434\u043E\u0447\u044C.
    \u041F\u043E\u0441\u043B\u0435 \u0435\u0451 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0432 1579 \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043F\u043E\u0432\u0442\u043E\u0440\u043D\u043E \u2014 \u043D\u0430 \u0410\u0433\u043D\u0435\u0441
    \u0427\u0438\u0437\u0445\u043E\u043B\u043C, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0440\u043E\u0434\u0438\u043B\u0430 \u0435\u043C\u0443 \u0435\u0449\u0451 \u0434\u0435\u0441\u044F\u0442\u044C
    \u0434\u0435\u0442\u0435\u0439.  \u041D\u0435\u043F\u0435\u0440 \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0441\u0432\u043E\u0438\u043C\u0438
    \u043F\u043E\u043C\u0435\u0441\u0442\u044C\u044F\u043C\u0438 \u0438 \u0441\u0435\u043B\u044C\u0441\u043A\u0438\u043C
    \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u043E\u043C , \u043D\u043E \u0435\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u044B\u043C\u0438 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0430\u043C\u0438
    \u0431\u044B\u043B\u0438 **\u0440\u0435\u043B\u0438\u0433\u0438\u044F \u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430**. \u041F\u0440\u0438
    \u044D\u0442\u043E\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043E\u043D \u0441\u0447\u0438\u0442\u0430\u043B \u043B\u0438\u0448\u044C \u043E\u0442\u0434\u044B\u0445\u043E\u043C
    \u043E\u0442 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0433\u043E \u0434\u0435\u043B\u0430
    \u2014 \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u0438.  \u041E\u043D \u0431\u044B\u043B
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u043A\u0430\u043A \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u044C
    \u0438 \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u0439
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A. \u0421\u0440\u0435\u0434\u0438 \u0435\u0433\u043E
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0439 \u0431\u044B\u043B\u0438
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430 \u0434\u043B\u044F
    \u0432\u0435\u0434\u0435\u043D\u0438\u044F \u0441\u0435\u043B\u044C\u0441\u043A\u043E\u0433\u043E
    \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u0430 \u0438 \u0434\u0430\u0436\u0435
    \u0441\u0435\u043A\u0440\u0435\u0442\u043D\u044B\u0435 \u0432\u043E\u0435\u043D\u043D\u044B\u0435
    \u043C\u0430\u0448\u0438\u043D\u044B \u0434\u043B\u044F \u0437\u0430\u0449\u0438\u0442\u044B
    \u0441\u0442\u0440\u0430\u043D\u044B \u043E\u0442 \u0438\u0441\u043F\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u0432\u0442\u043E\u0440\u0436\u0435\u043D\u0438\u044F, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \"\u0433\u043E\u0440\u044F\u0449\u0438\u0435 \u0437\u0435\u0440\u043A\u0430\u043B\u0430\"
    \u0438 \"\u043C\u0435\u0442\u0430\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u043E\u043B\u0435\u0441\u043D\u0438\u0446\u0443\". \u0422\u0430\u043A\u0436\u0435
    \u0441 \u0435\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C \u0441\u0432\u044F\u0437\u0430\u043D\u044B
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0437\u0430\u043D\u044F\u0442\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439, \u0443\u043A\u0440\u0435\u043F\u0438\u0432\u0448\u0438\u0445
    \u0435\u0433\u043E \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044E \u043C\u0430\u0433\u0430
    \u0438 \u0447\u0430\u0440\u043E\u0434\u0435\u044F : *   \u0427\u0442\u043E\u0431\u044B
    \u043F\u043E\u0439\u043C\u0430\u0442\u044C \u0432\u043E\u0440\u0430 \u0441\u0440\u0435\u0434\u0438
    \u0441\u043B\u0443\u0433, \u043E\u043D \u044F\u043A\u043E\u0431\u044B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043F\u0435\u0442\u0443\u0445\u0430, \u0432\u044B\u043C\u0430\u0437\u0430\u043D\u043D\u043E\u0433\u043E
    \u0441\u0430\u0436\u0435\u0439: \u0432\u043E\u0440, \u0431\u043E\u044F\u0441\u044C
    \u043F\u0440\u0438\u043A\u043E\u0441\u043D\u0443\u0442\u044C\u0441\u044F \u043A
    \u043F\u0442\u0438\u0446\u0435, \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0441
    \u0447\u0438\u0441\u0442\u044B\u043C\u0438 \u0440\u0443\u043A\u0430\u043C\u0438,
    \u0447\u0435\u043C \u0438 \u0432\u044B\u0434\u0430\u043B \u0441\u0435\u0431\u044F.
    *   \u0427\u0442\u043E\u0431\u044B \u0438\u0437\u0431\u0430\u0432\u0438\u0442\u044C\u0441\u044F
    \u043E\u0442 \u0433\u043E\u043B\u0443\u0431\u0435\u0439 \u0441\u043E\u0441\u0435\u0434\u0430,
    \u043F\u043E\u0435\u0434\u0430\u0432\u0448\u0438\u0445 \u0435\u0433\u043E \u0437\u0435\u0440\u043D\u043E,
    \u043E\u043D \u043D\u0430\u043C\u043E\u0447\u0438\u043B \u0433\u043E\u0440\u043E\u0445
    \u0432 \u0431\u0440\u0435\u043D\u0434\u0438 \u0438 \u0440\u0430\u0437\u0431\u0440\u043E\u0441\u0430\u043B
    \u043F\u043E \u043F\u043E\u043B\u044E. \u041F\u0442\u0438\u0446\u044B, \u043F\u043E\u043A\u043B\u0435\u0432\u0430\u0432
    \u0435\u0433\u043E, \u043D\u0435 \u043C\u043E\u0433\u043B\u0438 \u0432\u0437\u043B\u0435\u0442\u0435\u0442\u044C. 
    ### \U0001F4D6 \u0411\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0438\u0435 \u0438
    \"\u041E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u0438\u0435\"  \u041A\u0430\u043A
    \u0438\u0441\u0442\u043E\u0432\u044B\u0439 \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442-\u043F\u0443\u0440\u0438\u0442\u0430\u043D\u0438\u043D,
    \u041D\u0435\u043F\u0435\u0440 \u0431\u044B\u043B \u0441\u0438\u043B\u044C\u043D\u043E
    \u0432\u043E\u0432\u043B\u0435\u0447\u0451\u043D \u0432 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u0428\u043E\u0442\u043B\u0430\u043D\u0434\u0438\u0438
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u043E\u0440\u043E\u043B\u0430\u0441\u044C \u0441 \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0440\u0435\u0441\u0442\u0430\u0432\u0440\u0430\u0446\u0438\u0435\u0439 \u0438
    \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C \u0430\u043D\u0433\u043B\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0439
    \u0446\u0435\u0440\u043A\u0432\u0438.  \u0412 1588 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0434\u0435\u043B\u0435\u0433\u0430\u0442\u043E\u043C
    \u0432 \u0413\u0435\u043D\u0435\u0440\u0430\u043B\u044C\u043D\u0443\u044E \u0430\u0441\u0441\u0430\u043C\u0431\u043B\u0435\u044E
    \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u043E\u0439 \u0446\u0435\u0440\u043A\u0432\u0438.
    \u0412 1593 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u0433\u043B\u0430\u0432\u043D\u044B\u0439, \u043A\u0430\u043A
    \u043E\u043D \u0441\u0430\u043C \u0441\u0447\u0438\u0442\u0430\u043B, \u0442\u0440\u0443\u0434
    \u2014 \"\u041F\u043E\u043D\u044F\u0442\u043D\u043E\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u0432\u0441\u0435\u0433\u043E \u041E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u0438\u044F
    \u0441\u0432\u044F\u0442\u043E\u0433\u043E \u0418\u043E\u0430\u043D\u043D\u0430\"
    (A Plaine Discovery of the Whole Revelation of Saint John). \u0412 \u044D\u0442\u043E\u043C
    \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0441\u043A\u043E\u043C \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0438
    \u043E\u043D \u0430\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0431\u0438\u0431\u043B\u0435\u0439\u0441\u043A\u0438\u0435 \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u0430,
    \u044F\u0440\u043E\u0441\u0442\u043D\u043E \u043E\u0431\u043B\u0438\u0447\u0430\u043B
    \u043F\u0430\u043F\u0441\u0442\u0432\u043E \u0438 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B
    \u043A\u043E\u043D\u0435\u0446 \u0441\u0432\u0435\u0442\u0430 \u043D\u0430 1688
    \u0438\u043B\u0438 1700 \u0433\u043E\u0434. \u041A\u043D\u0438\u0433\u0430 \u0438\u043C\u0435\u043B\u0430
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u0443\u0441\u043F\u0435\u0445
    \u0438 \u0431\u044B\u043B\u0430 \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043D\u0430
    \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u044F\u0437\u044B\u043A\u043E\u0432. 
    ### \u2728 \u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435: \u041B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u044B 
    \u041F\u043E\u0442\u0440\u0435\u0431\u043D\u043E\u0441\u0442\u044C \u0432 \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u0438\u0438
    \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439 \u043F\u0440\u0438\u0432\u0435\u043B\u0430
    \u041D\u0435\u043F\u0435\u0440\u0430 \u043A \u0433\u043B\u0430\u0432\u043D\u043E\u043C\u0443
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044E \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.
    \u041E\u0441\u043D\u043E\u0432\u043D\u0430\u044F \u0438\u0434\u0435\u044F, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u0440\u0438\u0448\u043B\u0430 \u0435\u043C\u0443 \u0432 \u0433\u043E\u043B\u043E\u0432\u0443,
    \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0430\u0441\u044C \u0432 \u0437\u0430\u043C\u0435\u043D\u0435
    \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u044F \u0438 \u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043D\u0430 \u0431\u043E\u043B\u0435\u0435 \u043F\u0440\u043E\u0441\u0442\u044B\u0435
    \u0441\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0438 \u0432\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u0435
    \u0447\u0435\u0440\u0435\u0437 \u0441\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441\u0438\u0439.  \u0412 1614 \u0433\u043E\u0434\u0443
    \u041D\u0435\u043F\u0435\u0440 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 magnum opus \u2014 \u043A\u043D\u0438\u0433\u0443 **\"\u041E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439 \u0442\u0430\u0431\u043B\u0438\u0446\u044B
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432\"** (Mirifici Logarithmorum
    Canonis Descriptio). \u0412 \u044D\u0442\u043E\u043C \u0442\u0440\u0443\u0434\u0435
    \u043E\u0431\u044A\u0451\u043C\u043E\u043C 56 \u0441\u0442\u0440\u0430\u043D\u0438\u0446
    \u0442\u0435\u043A\u0441\u0442\u0430 \u0438 90 \u0441\u0442\u0440\u0430\u043D\u0438\u0446
    \u0442\u0430\u0431\u043B\u0438\u0446 \u043E\u043D : *   \u0434\u0430\u043B \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0430; *   \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B
    \u0435\u0433\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430; *   \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043F\u0435\u0440\u0432\u044B\u0435 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432
    \u0434\u043B\u044F \u0441\u0438\u043D\u0443\u0441\u043E\u0432, \u043A\u043E\u0441\u0438\u043D\u0443\u0441\u043E\u0432
    \u0438 \u0442\u0430\u043D\u0433\u0435\u043D\u0441\u043E\u0432 (\u0441 \u0448\u0430\u0433\u043E\u043C
    1 \u043C\u0438\u043D\u0443\u0442\u0430).  \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u0444\u0443\u043D\u043A\u0446\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u043E\u043F\u0438\u0441\u0430\u043B, \u043D\u0435 \u0431\u044B\u043B\u0430
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u044B\u043C
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u043C. \u041D\u0435\u043F\u0435\u0440
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C
    \u043A\u0438\u043D\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438,
    \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u044F \u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0435
    \u0438 \u0437\u0430\u043C\u0435\u0434\u043B\u044F\u044E\u0449\u0435\u0435\u0441\u044F
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435. \u0415\u0433\u043E \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C
    \u0447\u0438\u0441\u043B\u0430 10 000 000 \u0431\u044B\u043B \u0440\u0430\u0432\u0435\u043D
    \u043D\u0443\u043B\u044E, \u0430 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C
    \u043D\u0443\u043B\u044F \u2014 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E \u0438\u0434\u0435\u044F
    \u0431\u044B\u043B\u0430 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0439. 
    \u0412 1615 \u0433\u043E\u0434\u0443 \u041D\u0435\u043F\u0435\u0440\u0430 \u043F\u043E\u0441\u0435\u0442\u0438\u043B
    \u0413\u0435\u043D\u0440\u0438 \u0411\u0440\u0438\u0433\u0433\u0441 \u2014 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438\u0437 \u041E\u043A\u0441\u0444\u043E\u0440\u0434\u0430.
    \u041E\u043D\u0438 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0440\u0435\u0448\u0438\u043B\u0438,
    \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u0431\u044B \u0443\u0434\u043E\u0431\u043D\u0435\u0435,
    \u0435\u0441\u043B\u0438 \u0431\u044B \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C
    \u0435\u0434\u0438\u043D\u0438\u0446\u044B \u0431\u044B\u043B \u0440\u0430\u0432\u0435\u043D
    \u043D\u0443\u043B\u044E, \u0430 \u043D\u0435 10 000 000. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0411\u0440\u0438\u0433\u0433\u0441 \u043F\u043E\u0437\u0436\u0435 \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B
    \u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0442\u0430\u0431\u043B\u0438\u0446\u044B
    \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u044B\u0445 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432
    (\u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432 \u0411\u0440\u0438\u0433\u0433\u0441\u0430). 
    \u0412 1617 \u0433\u043E\u0434\u0443, \u043D\u0435\u0437\u0430\u0434\u043E\u043B\u0433\u043E
    \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438, \u041D\u0435\u043F\u0435\u0440
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0435\u0449\u0451
    \u043E\u0434\u043D\u043E \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435
    \u2014 **\"\u041F\u0430\u043B\u043E\u0447\u043A\u0438 \u041D\u0435\u043F\u0435\u0440\u0430\"**
    (Rabdologiae), \u043F\u0440\u0438\u0431\u043E\u0440 \u0434\u043B\u044F \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u044F \u0438 \u0434\u0435\u043B\u0435\u043D\u0438\u044F.
    \u041D\u0430\u0431\u043E\u0440 \u043F\u0430\u043B\u043E\u0447\u0435\u043A \u0441
    \u043D\u0430\u043D\u0435\u0441\u0451\u043D\u043D\u044B\u043C\u0438 \u0446\u0438\u0444\u0440\u0430\u043C\u0438
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B \u0431\u044B\u0441\u0442\u0440\u043E
    \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0442\u044C \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0432\u043D\u0451\u0441 \u0432\u0430\u0436\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u044E,
    \u0432\u044B\u0432\u0435\u0434\u044F \"\u043F\u0440\u0430\u0432\u0438\u043B\u0430
    \u043A\u0440\u0443\u0433\u043E\u0432\u044B\u0445 \u0447\u0430\u0441\u0442\u0435\u0439\"
    \u0434\u043B\u044F \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432. 
    ### \U0001F56F\uFE0F \u0421\u043C\u0435\u0440\u0442\u044C \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u0412 \u043D\u0430\u0447\u0430\u043B\u0435 1617 \u0433\u043E\u0434\u0430 \u0414\u0436\u043E\u043D
    \u041D\u0435\u043F\u0435\u0440 \u0442\u044F\u0436\u0435\u043B\u043E \u0437\u0430\u0431\u043E\u043B\u0435\u043B
    \u0438 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 4 \u0430\u043F\u0440\u0435\u043B\u044F
    \u0432 \u0441\u0432\u043E\u0451\u043C \u0437\u0430\u043C\u043A\u0435 \u041C\u0435\u0440\u0447\u0438\u0441\u0442\u043E\u043D.
    \u041F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    \u0441\u044B\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0432\u0442\u043E\u0440\u043E\u0439 \u0442\u0440\u0443\u0434 \u2014 **\"\u041F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439 \u0442\u0430\u0431\u043B\u0438\u0446\u044B
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432\"** (1619), \u0432
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u041D\u0435\u043F\u0435\u0440 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E
    \u043E\u043F\u0438\u0441\u0430\u043B \u043C\u0435\u0442\u043E\u0434\u0438\u043A\u0443
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0441\u0432\u043E\u0438\u0445
    \u0442\u0430\u0431\u043B\u0438\u0446.  \u0418\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435
    \u041D\u0435\u043F\u0435\u0440\u0430 \u0438\u043C\u0435\u043B\u043E \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435. \u041A\u0430\u043A \u043F\u043E\u0437\u0436\u0435
    \u0441\u043A\u0430\u0437\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u041F\u044C\u0435\u0440-\u0421\u0438\u043C\u043E\u043D \u041B\u0430\u043F\u043B\u0430\u0441,
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u044B **\"\u043F\u0440\u043E\u0434\u043B\u0438\u043B\u0438
    \u0436\u0438\u0437\u043D\u044C \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430\u043C\"**,
    \u0438\u0437\u0431\u0430\u0432\u0438\u0432 \u0438\u0445 \u043E\u0442 \u0443\u0442\u043E\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438 \u0434\u043E\u043B\u0433\u0438\u0445 \u0440\u0430\u0441\u0447\u0451\u0442\u043E\u0432.
    \u0412 \u0447\u0435\u0441\u0442\u044C \u0414\u0436\u043E\u043D\u0430 \u041D\u0435\u043F\u0435\u0440\u0430
    \u043D\u0430\u0437\u0432\u0430\u043D\u044B: *   \u043A\u0440\u0430\u0442\u0435\u0440
    \u043D\u0430 \u041B\u0443\u043D\u0435 \u0438 \u0430\u0441\u0442\u0435\u0440\u043E\u0438\u0434
    ; *   \u0435\u0434\u0438\u043D\u0438\u0446\u0430 \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0432\u0435\u043B\u0438\u0447\u0438\u043D
    \u2014 \u043D\u0435\u043F\u0435\u0440 (Neper) ; *   \u042D\u0434\u0438\u043D\u0431\u0443\u0440\u0433\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u041D\u0435\u043F\u0435\u0440\u0430
    (Edinburgh Napier University), \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0439
    \u043D\u0430 \u043C\u0435\u0441\u0442\u0435 \u0435\u0433\u043E \u0440\u043E\u0434\u043E\u0432\u043E\u0433\u043E
    \u0437\u0430\u043C\u043A\u0430."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0414\u0436\u043E\u043D\u0430
    \u041D\u0435\u043F\u0435\u0440\u0430 \u043F\u043E\u043B\u043D\u0430 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u043E\u0432: \u043E\u043D \u0431\u044B\u043B
    \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0432\u0435\u0440\u0443\u044E\u0449\u0438\u043C
    \u043F\u0443\u0440\u0438\u0442\u0430\u043D\u0438\u043D\u043E\u043C \u0438...
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438 \u0432\u0441\u0435\u0440\u044C\u0435\u0437
    \u0441\u0447\u0438\u0442\u0430\u043B\u0438 \u043C\u0430\u0433\u043E\u043C \u0438
    \u043A\u043E\u043B\u0434\u0443\u043D\u043E\u043C. \u0421\u043B\u0430\u0432\u0430
    \u043E \u0435\u0433\u043E \"\u0447\u0443\u0434\u0435\u0441\u0430\u0445\" \u0431\u044B\u043B\u0430
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0438\u043B\u044C\u043D\u0430,
    \u0447\u0442\u043E \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435
    **\"\u0423\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u041C\u0435\u0440\u0447\u0438\u0441\u0442\u043E\u043D\" (Marvellous Merchiston)**.
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u044B\u0435
    \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0435 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0438\u0437 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u044E\u0442 \u044D\u0442\u0443 \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044E. 
    ### \U0001F413 \"\u0413\u0430\u0434\u0430\u044E\u0449\u0438\u0439\" \u043F\u0435\u0442\u0443\u0445
    \u0438 \u043B\u043E\u0432\u043B\u044F \u0432\u043E\u0440\u0430  \u0421\u0430\u043C\u0430\u044F
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043E \u041D\u0435\u043F\u0435\u0440\u0435-\u043C\u0430\u0433\u0435 \u0441\u0432\u044F\u0437\u0430\u043D\u0430
    \u0441 \u0435\u0433\u043E \u043B\u044E\u0431\u0438\u043C\u0446\u0435\u043C \u2014
    \u0447\u0435\u0440\u043D\u044B\u043C \u043F\u0435\u0442\u0443\u0445\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0441\u0443\u0435\u0432\u0435\u0440\u043D\u044B\u0435
    \u0441\u043E\u0441\u0435\u0434\u0438 \u0441\u0447\u0438\u0442\u0430\u043B\u0438
    \u0435\u0433\u043E \"\u0444\u0430\u043C\u0438\u043B\u044C\u044F\u0440\u043E\u043C\",
    \u0442\u043E \u0435\u0441\u0442\u044C \u0434\u0443\u0445\u043E\u043C-\u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u043E\u043C
    \u0432 \u043A\u043E\u043B\u0434\u043E\u0432\u0441\u0442\u0432\u0435.  \u041A\u043E\u0433\u0434\u0430
    \u0432 \u0437\u0430\u043C\u043A\u0435 \u043D\u0430\u0447\u0430\u043B\u0438\u0441\u044C
    \u043A\u0440\u0430\u0436\u0438, \u041D\u0435\u043F\u0435\u0440 \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B
    \u0445\u0438\u0442\u0440\u043E\u0443\u043C\u043D\u044B\u0439 \u043F\u043B\u0430\u043D.
    \u041E\u043D \u0437\u0430\u044F\u0432\u0438\u043B \u0441\u043B\u0443\u0433\u0430\u043C,
    \u0447\u0442\u043E \u0435\u0433\u043E \u043F\u0435\u0442\u0443\u0445 \u043C\u043E\u0436\u0435\u0442
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C \u0432\u043E\u0440\u0430,
    \u0438 \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E \u043D\u0443\u0436\u043D\u043E
    \u043F\u0440\u043E\u0432\u0435\u0441\u0442\u0438 \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u0435.
    \u041D\u0435\u043F\u0435\u0440 \u0442\u0430\u0439\u043D\u043E \u0432\u044B\u043C\u0430\u0437\u0430\u043B
    \u043F\u0442\u0438\u0446\u0443 \u0441\u0430\u0436\u0435\u0439, \u0437\u0430\u043F\u0435\u0440
    \u0435\u0435 \u0432 \u0442\u0435\u043C\u043D\u043E\u0439 \u043A\u043E\u043C\u043D\u0430\u0442\u0435
    \u0438 \u0432\u0435\u043B\u0435\u043B \u043A\u0430\u0436\u0434\u043E\u043C\u0443
    \u0438\u0437 \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u0432\u0430\u0435\u043C\u044B\u0445
    \u043F\u043E \u043E\u0447\u0435\u0440\u0435\u0434\u0438 \u0437\u0430\u0439\u0442\u0438
    \u0438 \u043F\u043E\u0433\u043B\u0430\u0434\u0438\u0442\u044C \u043F\u0435\u0442\u0443\u0445\u0430.
    \u041F\u043E \u0435\u0433\u043E \u0441\u043B\u043E\u0432\u0430\u043C, \u043F\u0442\u0438\u0446\u0430
    \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u043B\u0430 \u0437\u0430\u043A\u0440\u0438\u0447\u0430\u0442\u044C,
    \u043A\u043E\u0433\u0434\u0430 \u0434\u043E \u043D\u0435\u0435 \u0434\u043E\u0442\u0440\u043E\u043D\u0435\u0442\u0441\u044F
    \u0432\u0438\u043D\u043E\u0432\u043D\u044B\u0439.  \u0420\u0430\u0437\u0443\u043C\u0435\u0435\u0442\u0441\u044F,
    \u043F\u0435\u0442\u0443\u0445 \u043C\u043E\u043B\u0447\u0430\u043B, \u043D\u043E
    \u0432\u043E\u0440, \u0438\u0441\u043F\u0443\u0433\u0430\u0432\u0448\u0438\u0441\u044C
    \u0440\u0430\u0437\u043E\u0431\u043B\u0430\u0447\u0435\u043D\u0438\u044F, \u043F\u043E\u0431\u043E\u044F\u043B\u0441\u044F
    \u043A \u043D\u0435\u043C\u0443 \u043F\u0440\u0438\u043A\u0430\u0441\u0430\u0442\u044C\u0441\u044F
    \u0438 \u043B\u0438\u0448\u044C \u0441\u0434\u0435\u043B\u0430\u043B \u0432\u0438\u0434,
    \u0447\u0442\u043E \u0433\u043B\u0430\u0434\u0438\u0442. \u0412\u044B\u0439\u0434\u044F
    \u0438\u0437 \u043A\u043E\u043C\u043D\u0430\u0442\u044B, \u0432\u0441\u0435 \u0441\u043B\u0443\u0433\u0438
    \u043F\u0435\u0440\u0435\u043F\u0430\u0447\u043A\u0430\u043B\u0438 \u0440\u0443\u043A\u0438
    \u0441\u0430\u0436\u0435\u0439... \u043A\u0440\u043E\u043C\u0435 \u043E\u0434\u043D\u043E\u0433\u043E.
    \u0418\u043C\u0435\u043D\u043D\u043E \u043E\u043D \u0438 \u0431\u044B\u043B \u0443\u043B\u0438\u0447\u0435\u043D
    \u0432 \u0432\u043E\u0440\u043E\u0432\u0441\u0442\u0432\u0435.  ### \U0001F377
    \u041F\u044C\u044F\u043D\u044B\u0435 \u0433\u043E\u043B\u0443\u0431\u0438 \u0438
    \u0441\u043F\u043E\u0440 \u0441 \u0441\u043E\u0441\u0435\u0434\u043E\u043C  \u0415\u0449\u0435
    \u043E\u0434\u0438\u043D \u0441\u043B\u0443\u0447\u0430\u0439 \u043B\u0438\u0448\u044C
    \u0443\u043A\u0440\u0435\u043F\u0438\u043B \u0435\u0433\u043E \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044E
    \u0447\u0430\u0440\u043E\u0434\u0435\u044F. \u0421\u043E\u0441\u0435\u0434\u0441\u043A\u0438\u0435
    \u0433\u043E\u043B\u0443\u0431\u0438 \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E
    \u043F\u043E\u0435\u0434\u0430\u043B\u0438 \u0437\u0435\u0440\u043D\u043E \u043D\u0430
    \u043F\u043E\u043B\u044F\u0445 \u041D\u0435\u043F\u0435\u0440\u0430. \u041D\u0430
    \u0432\u0441\u0435 \u0436\u0430\u043B\u043E\u0431\u044B \u0441\u043E\u0441\u0435\u0434
    \u043E\u0442\u0432\u0435\u0447\u0430\u043B, \u0447\u0442\u043E \u043D\u0438\u0447\u0435\u0433\u043E
    \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u043F\u043E\u0434\u0435\u043B\u0430\u0442\u044C
    \u0441 \u043F\u0442\u0438\u0446\u0430\u043C\u0438, \u0438 \u0432 \u043D\u0430\u0441\u043C\u0435\u0448\u043A\u0443
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u041D\u0435\u043F\u0435\u0440\u0443
    \u0441\u0430\u043C\u043E\u043C\u0443 \u0438\u0445 \u043E\u0442\u043B\u043E\u0432\u0438\u0442\u044C,
    \u0435\u0441\u043B\u0438 \u0442\u043E\u0442 \u0441\u043C\u043E\u0436\u0435\u0442. 
    \u041D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439 \u0434\u0435\u043D\u044C
    \u0441\u043E\u0441\u0435\u0434 \u0441 \u0438\u0437\u0443\u043C\u043B\u0435\u043D\u0438\u0435\u043C
    \u0443\u0432\u0438\u0434\u0435\u043B, \u043A\u0430\u043A \u041D\u0435\u043F\u0435\u0440
    \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E \u0445\u043E\u0434\u0438\u0442
    \u043F\u043E \u043F\u043E\u043B\u044E, \u043F\u043E\u0434\u0431\u0438\u0440\u0430\u0435\u0442
    \u0431\u0435\u0441\u043F\u043E\u043C\u043E\u0449\u043D\u044B\u0445 \u0433\u043E\u043B\u0443\u0431\u0435\u0439
    \u0438 \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442 \u0438\u0445
    \u0432 \u043C\u0435\u0448\u043E\u043A. \u041E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u043D\u043E\u0447\u044C\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0437\u0430\u043C\u043E\u0447\u0438\u043B \u0433\u043E\u0440\u043E\u0445 \u0432
    \u0431\u0440\u0435\u043D\u0434\u0438 \u0438 \u0440\u0430\u0437\u0431\u0440\u043E\u0441\u0430\u043B
    \u0435\u0433\u043E \u043F\u043E \u043F\u043E\u043B\u044E. \u0421\u043A\u043B\u0435\u0432\u0430\u0432\u0448\u0438\u0435
    \u0443\u0433\u043E\u0449\u0435\u043D\u0438\u0435 \u043F\u0442\u0438\u0446\u044B
    \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0435 \u043C\u043E\u0433\u043B\u0438
    \u0432\u0437\u043B\u0435\u0442\u0435\u0442\u044C.  ### \U0001F52E \u041F\u0440\u043E\u0440\u043E\u043A,
    \u043D\u0435\u043A\u0440\u043E\u043C\u0430\u043D\u0442 \u0438 \u0430\u043B\u0445\u0438\u043C\u0438\u043A 
    \u041F\u0440\u043E\u0437\u0432\u0438\u0449\u0435 \"\u0432\u043E\u043B\u0448\u0435\u0431\u043D\u0438\u043A\"
    \u043D\u0435 \u0431\u044B\u043B\u043E \u043F\u0443\u0441\u0442\u044B\u043C \u0437\u0432\u0443\u043A\u043E\u043C.
    \u041E\u043D\u043E \u043F\u043E\u0434\u043A\u0440\u0435\u043F\u043B\u044F\u043B\u043E\u0441\u044C
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u043B\u0443\u0445\u0430\u043C\u0438,
    \u043D\u043E \u0438 \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u043C\u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u043A\u0430\u043C\u0438
    \u041D\u0435\u043F\u0435\u0440\u0430: *   **\u041F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u0435
    \u043A\u043E\u043D\u0446\u0430 \u0441\u0432\u0435\u0442\u0430**: \u041D\u0435\u043F\u0435\u0440
    \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u0435\u043D
    \u0438 \u0432\u0441\u0435\u0440\u044C\u0435\u0437 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0442\u043E\u043B\u043A\u043E\u0432\u0430\u043D\u0438\u0435\u043C \u041E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u0438\u044F
    \u0418\u043E\u0430\u043D\u043D\u0430 \u0411\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0430.
    \u0412 \u0441\u0432\u043E\u0435\u043C \u0442\u0440\u0443\u0434\u0435 1594 \u0433\u043E\u0434\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043D \u0441\u0447\u0438\u0442\u0430\u043B
    \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u0434\u0435\u043B\u043E\u043C \u0441\u0432\u043E\u0435\u0439
    \u0436\u0438\u0437\u043D\u0438, \u043E\u043D \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0432\u044B\u043A\u043B\u0430\u0434\u043E\u043A \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043A\u043E\u043D\u0435\u0446 \u0441\u0432\u0435\u0442\u0430
    \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u0442 \u043C\u0435\u0436\u0434\u0443
    1688 \u0438 1700 \u0433\u043E\u0434\u0430\u043C\u0438. \u041A \u0441\u0447\u0430\u0441\u0442\u044C\u044E,
    \u0435\u0433\u043E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430
    \u0432 \u044D\u0442\u043E\u0442 \u0440\u0430\u0437 \u043F\u043E\u0434\u0432\u0435\u043B\u0430.
    *   **\u041F\u043E\u0438\u0441\u043A \u043A\u043B\u0430\u0434\u0430**: \u0412
    1594 \u0433\u043E\u0434\u0443 \u041D\u0435\u043F\u0435\u0440 \u0437\u0430\u043A\u043B\u044E\u0447\u0438\u043B
    \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u043A\u043E\u043D\u0442\u0440\u0430\u043A\u0442
    \u0441 \u043D\u0435\u043A\u0438\u043C \u0420\u043E\u0431\u0435\u0440\u0442\u043E\u043C
    \u041B\u043E\u0433\u0430\u043D\u043E\u043C \u0434\u043B\u044F \u043F\u043E\u0438\u0441\u043A\u0430
    \u0441\u043F\u0440\u044F\u0442\u0430\u043D\u043D\u043E\u0433\u043E \u0441\u043E\u043A\u0440\u043E\u0432\u0438\u0449\u0430
    \u0432 \u0437\u0430\u043C\u043A\u0435 \u0424\u0430\u0441\u0442\u043A\u0430\u0441\u043B.
    \u0412 \u0434\u043E\u0433\u043E\u0432\u043E\u0440\u0435 \u0431\u044B\u043B\u043E
    \u0441\u043A\u0430\u0437\u0430\u043D\u043E, \u0447\u0442\u043E \u041D\u0435\u043F\u0435\u0440
    \u0434\u043E\u043B\u0436\u0435\u043D \u043F\u0440\u0438\u043B\u043E\u0436\u0438\u0442\u044C
    \"\u0432\u0441\u0435 \u0443\u0441\u0438\u043B\u0438\u044F, \u0447\u0442\u043E\u0431\u044B
    \u0438\u0441\u043A\u0430\u0442\u044C \u0438 \u043D\u0430\u0439\u0442\u0438\"
    \u043A\u043B\u0430\u0434, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \"\u0432\u0441\u0435 \u0443\u0445\u0438\u0449\u0440\u0435\u043D\u0438\u044F \u0438
    \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u043E\". *   **\u0418\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u0430\u043B\u0445\u0438\u043C\u0438\u0438**: \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442
    \u0437\u0430\u043F\u0438\u0441\u0438 \u043E \u0435\u0433\u043E \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0430\u0446\u0438\u044F\u0445
    \u0441 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u043C \u0430\u043B\u0445\u0438\u043C\u0438\u043A\u043E\u043C,
    \u0430 \u0435\u0433\u043E \u0441\u044B\u043D \u0420\u043E\u0431\u0435\u0440\u0442,
    \u0441\u0442\u0430\u0432\u0448\u0438\u0439 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u044B\u043C
    \u0434\u0443\u0448\u0435\u043F\u0440\u0438\u043A\u0430\u0437\u0447\u0438\u043A\u043E\u043C,
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F
    \u0442\u0440\u0443\u0434\u044B \u043D\u0430 \u044D\u0442\u0443 \u0442\u0435\u043C\u0443. 
    ### \u2694\uFE0F \u0424\u0443\u0442\u0443\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \"\u0441\u0435\u043A\u0440\u0435\u0442\u043D\u044B\u0435 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F\" 
    \u0412\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043F\u0440\u043E\u0442\u043E\u0442\u0438\u043F\u044B
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 \u0432\u0438\u0434\u043E\u0432
    \u043E\u0440\u0443\u0436\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u041D\u0435\u043F\u0435\u0440 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B
    \u0432 \u0441\u0432\u043E\u0438\u0445 \u0437\u0430\u043F\u0438\u0441\u044F\u0445,
    \u0442\u0430\u043A\u0436\u0435 \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043B\u0435\u0433\u0435\u043D\u0434.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0432 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0435
    1596 \u0433\u043E\u0434\u0430, \u043A\u043E\u0433\u0434\u0430 \u0443\u0433\u0440\u043E\u0437\u0430
    \u0438\u0441\u043F\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u0432\u0442\u043E\u0440\u0436\u0435\u043D\u0438\u044F
    \u0431\u044B\u043B\u0430 \u0440\u0435\u0430\u043B\u044C\u043D\u0430, \u043E\u043D
    \u043E\u043F\u0438\u0441\u0430\u043B \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0432\u043E\u0435\u043D\u043D\u044B\u0445 \u043C\u0430\u0448\u0438\u043D: *  
    **\"\u041A\u0440\u0443\u0433\u043B\u0430\u044F \u043C\u0435\u0442\u0430\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u043E\u043B\u0435\u0441\u043D\u0438\u0446\u0430\"**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u043B\u0430 \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F
    \u0438\u0437\u043D\u0443\u0442\u0440\u0438 \u0438 \u043F\u0440\u043E\u0431\u0438\u0432\u0430\u0442\u044C
    \u0440\u044F\u0434\u044B \u0432\u0440\u0430\u0433\u0430, \u0441\u0442\u0440\u0435\u043B\u044F\u044F
    \u0447\u0435\u0440\u0435\u0437 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u043E\u0442\u0432\u0435\u0440\u0441\u0442\u0438\u044F. \u042D\u0442\u043E \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439 \u0442\u0430\u043D\u043A.
    *   \u041E\u0440\u0443\u0434\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0441\u0442\u0440\u0435\u043B\u044F\u043B\u043E \u0431\u044B \u043D\u0435 \u043F\u043E
    \u043F\u0440\u044F\u043C\u043E\u0439 \u043B\u0438\u043D\u0438\u0438, \u0430 \"\u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u043D\u043E,
    \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u044F \u0432 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u0445
    \u0432\u0441\u0435\u0433\u043E \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u043E\u0433\u043E
    \u043C\u0435\u0441\u0442\u0430\", \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0430\u044F
    \u0432\u0441\u0435\u0445 \u0432\u0440\u0430\u0433\u043E\u0432 \u043D\u0430 \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u0439
    \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u0438. \u041E\u0434\u0438\u043D
    \u0438\u0437 \u0435\u0433\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E \u041D\u0435\u043F\u0435\u0440
    \u0434\u0430\u0436\u0435 \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435, \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u0432
    \u0441\u0442\u0430\u0434\u0430 \u0441\u043A\u043E\u0442\u0430 \u0438 \u043E\u0432\u0435\u0446
    \u043D\u0430 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u043C
    \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0438.  \u0412 \u0438\u0442\u043E\u0433\u0435,
    \u043E\u043D \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u0430 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u044D\u043F\u043E\u0445\u0438 \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F,
    \u0441\u043E\u0447\u0435\u0442\u0430\u0432\u0448\u0438\u043C \u0432 \u0441\u0435\u0431\u0435
    \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0441\u0442\u044C,
    \u043F\u0435\u0440\u0435\u0434\u043E\u0432\u0443\u044E \u043D\u0430\u0443\u0447\u043D\u0443\u044E
    \u043C\u044B\u0441\u043B\u044C \u0438 \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u044D\u0437\u043E\u0442\u0435\u0440\u0438\u043A\u0435. \u042D\u0442\u043E
    \u043F\u0440\u0438\u0447\u0443\u0434\u043B\u0438\u0432\u043E\u0435 \u0441\u043C\u0435\u0448\u0435\u043D\u0438\u0435
