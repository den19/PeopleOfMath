  achievementsRu: "\u041F\u043E\u0434\u0440\u043E\u0431\u043D\u043E \u0440\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0438\u043C
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u0438 \u0442\u0440\u0443\u0434\u044B
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430. \u041A\u043B\u044E\u0447\u0435\u0432\u0430\u044F
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0432 \u0442\u043E\u043C,
    \u0447\u0442\u043E \u043E\u043D, \u043A\u0430\u043A \u0438 \u0421\u043E\u043A\u0440\u0430\u0442,
    \u043D\u0435 \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043F\u043E\u0441\u043B\u0435
    \u0441\u0435\u0431\u044F \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u044B\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432. \u0412\u0441\u0435, \u0447\u0442\u043E
    \u043C\u044B \u0437\u043D\u0430\u0435\u043C, \u0434\u043E\u0448\u043B\u043E \u0434\u043E
    \u043D\u0430\u0441 \u0432 \u043F\u0435\u0440\u0435\u0441\u043A\u0430\u0437\u0430\u0445
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432 (\u043F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u0435\u0432)
    \u0438 \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u0445
    \u0430\u0432\u0442\u043E\u0440\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0447\u0430\u0441\u0442\u043E \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438
    \u0443\u0447\u0438\u0442\u0435\u043B\u044E \u0432\u0441\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0441\u0432\u043E\u0435\u0439 \u0448\u043A\u043E\u043B\u044B. \u041F\u043E\u044D\u0442\u043E\u043C\u0443
    \u043C\u044B \u0433\u043E\u0432\u043E\u0440\u0438\u043C \u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u0445
    **\u043F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B** \u0432 \u0446\u0435\u043B\u043E\u043C, \u043D\u043E\u0441\u044F\u0449\u0435\u0439
    \u0435\u0433\u043E \u0438\u043C\u044F.  ### \U0001F4D0 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0435\u043E\u0440\u0435\u043C\u0430 
    \u0412 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0437\u0430\u0441\u043B\u0443\u0433\u0438
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430 \u0438 \u0435\u0433\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B.
    \u0418\u043C \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442
    \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438\u0437 \u043D\u0430\u0431\u043E\u0440\u0430 \u044D\u043C\u043F\u0438\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0430\u0432\u0438\u043B \u0432 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443.  *   **\u0412\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432:**
    \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E \u041F\u0438\u0444\u0430\u0433\u043E\u0440
    \u043F\u0435\u0440\u0432\u044B\u043C \u043D\u0430\u0447\u0430\u043B \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u0432\u043E\u0434\u0438\u0442\u044C **\u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430**
    \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E, \u043F\u0440\u0438\u0434\u0430\u0432\u0430\u044F
    \u0435\u0439 \u0441\u0442\u0440\u043E\u0433\u0438\u0439 \u0438 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440. \u0414\u043E \u043D\u0435\u0433\u043E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0444\u0430\u043A\u0442\u044B \u043F\u0440\u043E\u0441\u0442\u043E \u043A\u043E\u043D\u0441\u0442\u0430\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u0438\u0441\u044C,
    \u0430 \u0442\u0435\u043F\u0435\u0440\u044C \u0438\u0445 \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u043E\u0441\u044C
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u044B\u0432\u0430\u0442\u044C. *  
    **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430:**
    \u042D\u0442\u043E, \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E,
    \u0441\u0430\u043C\u043E\u0435 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435. \u0425\u043E\u0442\u044F
    \u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u0438 \u043C\u0435\u0436\u0434\u0443
    \u0441\u0442\u043E\u0440\u043E\u043D\u0430\u043C\u0438 \u043F\u0440\u044F\u043C\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430 \u0431\u044B\u043B\u0438
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B \u0432 \u0415\u0433\u0438\u043F\u0442\u0435
    \u0438 \u0412\u0430\u0432\u0438\u043B\u043E\u043D\u0435, \u0438\u043C\u0435\u043D\u043D\u043E
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0443, \u043F\u043E \u043F\u0440\u0435\u0434\u0430\u043D\u0438\u044E,
    \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442 \u0435\u0451
    \u043F\u0435\u0440\u0432\u043E\u0435 \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E.
    \u0424\u043E\u0440\u043C\u0443\u043B\u0430 `a\xB2 + b\xB2 = c\xB2` \u0441\u0442\u0430\u043B\u0430
    \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C \u043A\u0430\u043C\u043D\u0435\u043C
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B:** \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u044B
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u044B
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438. \u041E\u043D\u0438:    
    *   \u0420\u0430\u0437\u0434\u0435\u043B\u0438\u043B\u0438 \u0447\u0438\u0441\u043B\u0430
    \u043D\u0430 **\u0447\u0435\u0442\u043D\u044B\u0435 \u0438 \u043D\u0435\u0447\u0435\u0442\u043D\u044B\u0435**,
    **\u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u0438 \u0441\u043E\u0441\u0442\u0430\u0432\u043D\u044B\u0435**.    
    *   \u0418\u0437\u0443\u0447\u0430\u043B\u0438 **\xAB\u0444\u0438\u0433\u0443\u0440\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430\xBB** (\u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0435,
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0435, \u043F\u044F\u0442\u0438\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0435),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0438
    \u0432 \u0432\u0438\u0434\u0435 \u0442\u043E\u0447\u0435\u043A, \u0432\u044B\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u044F
    \u0438\u0445 \u043D\u0430 \u043F\u0435\u0441\u043A\u0435. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0447\u0438\u0441\u043B\u043E 10 \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0430\u043B\u043E\u0441\u044C
    \u043A\u0430\u043A \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u044B\u0439 \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A
    \u2014 **\u0442\u0435\u0442\u0440\u0430\u043A\u0442\u0438\u0441**.     *   \u041E\u0442\u043A\u0440\u044B\u043B\u0438
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    **\u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B** (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u221A2), \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0448\u043E\u043A\u043E\u043C
    \u0434\u043B\u044F \u0438\u0445 \u043A\u0430\u0440\u0442\u0438\u043D\u044B \u043C\u0438\u0440\u0430,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u043E\u0439 \u043D\u0430 \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0438
    \u0446\u0435\u043B\u044B\u0445 \u0447\u0438\u0441\u0435\u043B. *   **\u041F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u0438:**
    \u0418\u043C \u0431\u044B\u043B\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B
    \u0442\u0440\u0438 \u0432\u0438\u0434\u0430 \u0441\u0440\u0435\u0434\u043D\u0438\u0445:
    **\u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F,
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438 \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F**. 
    ### \U0001F30C \u041A\u043E\u0441\u043C\u043E\u043B\u043E\u0433\u0438\u044F \u0438
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F: \u0413\u0430\u0440\u043C\u043E\u043D\u0438\u044F
    \u0441\u0444\u0435\u0440  \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u044B
    \u043E\u0434\u043D\u0438\u043C\u0438 \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0438\u0441\u044C \u043E\u043F\u0438\u0441\u0430\u0442\u044C
    \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u0443\u044E \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u043A\u043E\u043D\u043E\u0432.  *   **\u0417\u0435\u043C\u043B\u044F
    \u2014 \u0448\u0430\u0440:** \u041E\u043D\u0438 \u043F\u0435\u0440\u0432\u044B\u043C\u0438
    \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B\u0438 \u0438\u0434\u0435\u044E
    \u043E **\u0448\u0430\u0440\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u043E\u0441\u0442\u0438
    \u0417\u0435\u043C\u043B\u0438**, \u043E\u0441\u043D\u043E\u0432\u044B\u0432\u0430\u044F\u0441\u044C
    \u043D\u0435 \u043D\u0430 \u044D\u043C\u043F\u0438\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u0430\u043D\u043D\u044B\u0445, \u0430 \u043D\u0430 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0438
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u0441\u0444\u0435\u0440\u0430
    \u2014 \u0441\u0430\u043C\u0430\u044F \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u043E\u0440\u043C\u0430. *   **\xAB\u041A\u043E\u0441\u043C\u043E\u0441\xBB:**
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0443 \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442
    \u0432\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0441\u0430\u043C\u043E\u0433\u043E
    \u0442\u0435\u0440\u043C\u0438\u043D\u0430 **\xAB\u043A\u043E\u0441\u043C\u043E\u0441\xBB**
    \u0434\u043B\u044F \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    \u0443\u043F\u043E\u0440\u044F\u0434\u043E\u0447\u0435\u043D\u043D\u043E\u0433\u043E
    \u0438 \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0447\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430, \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442
    \u0445\u0430\u043E\u0441\u0430. *   **\xAB\u041C\u0443\u0437\u044B\u043A\u0430
    \u0441\u0444\u0435\u0440\xBB:** \u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u0430\u044F
    \u0438\u0434\u0435\u044F, \u0447\u0442\u043E \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u043F\u043B\u0430\u043D\u0435\u0442 \u043F\u043E\u0440\u043E\u0436\u0434\u0430\u0435\u0442
    \u0437\u0432\u0443\u043A, \u0447\u0430\u0441\u0442\u043E\u0442\u0443 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043C\u043E\u0436\u043D\u043E \u0432\u044B\u0440\u0430\u0437\u0438\u0442\u044C
    \u0447\u0438\u0441\u043B\u0430\u043C\u0438. \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u0431\u044B\u043B\u043E \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u0435\u043D\u043E
    \u0441\u0432\u044F\u0437\u044C\u044E \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u043E\u0439
    \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0438 \u0438 \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u0445
    \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u0439.  ### \U0001F3B5 \u041C\u0443\u0437\u044B\u043A\u0430
    \u0438 \u0430\u043A\u0443\u0441\u0442\u0438\u043A\u0430: \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0437\u0432\u0443\u043A\u0430  \u041E\u0434\u043D\u043E \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439 \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430
    \u043B\u0435\u0436\u0438\u0442 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043C\u0443\u0437\u044B\u043A\u0438.  *   **\u0427\u0438\u0441\u043B\u043E\u0432\u0430\u044F
    \u043F\u0440\u0438\u0440\u043E\u0434\u0430 \u0437\u0432\u0443\u043A\u0430:**
    \u041E\u043D \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B, \u0447\u0442\u043E
    \u0432\u044B\u0441\u043E\u0442\u0430 \u0442\u043E\u043D\u0430 \u0437\u0430\u0432\u0438\u0441\u0438\u0442
    \u043E\u0442 \u0434\u043B\u0438\u043D\u044B \u0441\u0442\u0440\u0443\u043D\u044B.
    \u041F\u0440\u0438\u044F\u0442\u043D\u044B\u0435 \u0441\u043B\u0443\u0445\u0443
    \u0441\u043E\u0437\u0432\u0443\u0447\u0438\u044F (\u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u044B)
    \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u044E\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u043E\u0433\u0434\u0430, \u043A\u043E\u0433\u0434\u0430 \u0434\u043B\u0438\u043D\u044B
    \u0441\u0442\u0440\u0443\u043D \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F
    \u043A\u0430\u043A \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u0446\u0435\u043B\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430.     *   **\u041E\u043A\u0442\u0430\u0432\u0430**
    \u2014 \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435 2:1.    
    *   **\u041A\u0432\u0438\u043D\u0442\u0430** \u2014 \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435
    3:2.     *   **\u041A\u0432\u0430\u0440\u0442\u0430** \u2014 \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435
    4:3. *   \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u0441\u0442\u0430\u043B\u043E \u043C\u043E\u0449\u043D\u0435\u0439\u0448\u0438\u043C
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E \u0442\u0435\u0437\u0438\u0441\u0430:
    **\xAB\u0412\u0441\u0451 \u0435\u0441\u0442\u044C \u0447\u0438\u0441\u043B\u043E\xBB**.
    \u0422\u0430\u043A \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C **\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u043A\u0430**.  ### \U0001F9D8 \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F
    \u0438 \u044D\u0442\u0438\u043A\u0430: \u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E
    \u0436\u0438\u0442\u044C  \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0441\u043A\u0430\u044F
    \u0448\u043A\u043E\u043B\u0430 \u0431\u044B\u043B\u0430 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C, \u043D\u043E \u0438 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E-\u044D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E\u043C.  *   **\u0422\u0435\u0440\u043C\u0438\u043D
    \xAB\u0424\u0438\u043B\u043E\u0441\u043E\u0444\xBB:** \u0418\u043C\u0435\u043D\u043D\u043E
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0443\u043F\u043E\u0442\u0440\u0435\u0431\u0438\u043B \u044D\u0442\u043E \u0441\u043B\u043E\u0432\u043E,
    \u043D\u0430\u0437\u0432\u0430\u0432 \u0441\u0435\u0431\u044F \u043D\u0435 \xAB\u043C\u0443\u0434\u0440\u0435\u0446\u043E\u043C\xBB
    (\u0442\u0435\u043C, \u043A\u0442\u043E \u0437\u043D\u0430\u0435\u0442), \u0430
    \xAB\u043B\u044E\u0431\u0438\u0442\u0435\u043B\u0435\u043C \u043C\u0443\u0434\u0440\u043E\u0441\u0442\u0438\xBB
    (\u0442\u0435\u043C, \u043A\u0442\u043E \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0441\u044F
    \u043A \u0437\u043D\u0430\u043D\u0438\u044E). *   **\u041C\u0435\u0442\u0435\u043C\u043F\u0441\u0438\u0445\u043E\u0437:**
    \u0423\u0447\u0435\u043D\u0438\u0435 \u043E **\u043F\u0435\u0440\u0435\u0441\u0435\u043B\u0435\u043D\u0438\u0438
    \u0434\u0443\u0448**, \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0432\u043E
    \u043C\u043D\u043E\u0433\u043E\u043C \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u043B\u043E
    \u0438\u0445 \u0430\u0441\u043A\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043E\u0431\u0440\u0430\u0437 \u0436\u0438\u0437\u043D\u0438, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0441\u0442\u0432\u043E.
    *   **\u0426\u0435\u043B\u0435\u0431\u043D\u0430\u044F \u0441\u0438\u043B\u0430
    \u043C\u0443\u0437\u044B\u043A\u0438:** \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u044B
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438 \u043C\u0443\u0437\u044B\u043A\u0443
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043B\u044F \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0433\u043E,
    \u043D\u043E \u0438 \u0434\u043B\u044F \u0442\u0435\u0440\u0430\u043F\u0435\u0432\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u044D\u0444\u0444\u0435\u043A\u0442\u0430, \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0443\u044F
    \u0445\u043E\u0440\u043E\u0432\u043E\u0435 \u043F\u0435\u043D\u0438\u0435 \u0434\u043B\u044F
    \u043B\u0435\u0447\u0435\u043D\u0438\u044F \u0434\u0443\u0448\u0435\u0432\u043D\u044B\u0445
    \u043D\u0435\u0434\u0443\u0433\u043E\u0432.  \u0421\u043B\u043E\u0436\u043D\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C, \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E
    \u0431\u044B\u043B\u043E \u043B\u0438\u0447\u043D\u044B\u043C \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\u043C
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430, \u0430 \u0447\u0442\u043E \u2014
    \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432. \u041D\u043E
    \u044F\u0441\u043D\u043E \u043E\u0434\u043D\u043E: \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u0448\u043A\u043E\u043B\u0443, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043D\u0430\u0443\u043A\u0430, \u043C\u0438\u0441\u0442\u0438\u043A\u0430 \u0438
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E \u0431\u044B\u043B\u0438
    \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0435\u043D\u044B \u0435\u0434\u0438\u043D\u043E\u0439
    \u0432\u0435\u0440\u043E\u0439 \u0432 \u043C\u043E\u0433\u0443\u0449\u0435\u0441\u0442\u0432\u043E
    \u0447\u0438\u0441\u043B\u0430 \u0438 \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0438."
  achievementsEn: 
  personalLifeRu: "\u041A\u043E\u043D\u0435\u0447\u043D\u043E, \u0434\u0430\u0432\u0430\u0439\u0442\u0435
    \u0440\u0430\u0437\u0431\u0435\u0440\u0435\u043C \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430 \u0432 \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043F\u043E\u0440\u044F\u0434\u043A\u0435, \u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u044D\u0442\u043E \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u0434\u043B\u044F
    \u0444\u0438\u0433\u0443\u0440\u044B, \u043E\u043A\u0443\u0442\u0430\u043D\u043D\u043E\u0439
    \u043C\u0438\u0444\u0430\u043C\u0438. \u0412\u0441\u0435, \u0447\u0442\u043E
    \u043C\u044B \u0437\u043D\u0430\u0435\u043C \u043E \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438, \u0443\u0447\u0451\u0431\u0435 \u0438 \u0441\u043C\u0435\u0440\u0442\u0438,
    \u0434\u043E\u0448\u043B\u043E \u0434\u043E \u043D\u0430\u0441 \u0432 \u043F\u0435\u0440\u0435\u0441\u043A\u0430\u0437\u0430\u0445
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0447\u0430\u0441\u0442\u043E \u043E\u0431\u043E\u0436\u0435\u0441\u0442\u0432\u043B\u044F\u043B\u0438
    \u0441\u0432\u043E\u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044F,
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0444\u0430\u043A\u0442\u044B \u0437\u0434\u0435\u0441\u044C \u0442\u0435\u0441\u043D\u043E
    \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u044B \u0441 \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u043C\u0438. 
    ### \U0001F476 \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435, \u0441\u0435\u043C\u044C\u044F
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B  *   **\u0414\u0430\u0442\u0430
    \u0438 \u043C\u0435\u0441\u0442\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F:**
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u043E\u043A\u043E\u043B\u043E **570 \u0433\u043E\u0434\u0430 \u0434\u043E \u043D.
    \u044D.** \u043D\u0430 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u043C
    \u043E\u0441\u0442\u0440\u043E\u0432\u0435 **\u0421\u0430\u043C\u043E\u0441**
    \u0432 \u042D\u0433\u0435\u0439\u0441\u043A\u043E\u043C \u043C\u043E\u0440\u0435.
    *   **\u0420\u043E\u0434\u0438\u0442\u0435\u043B\u0438:** \u0415\u0433\u043E
    \u043E\u0442\u0446\u043E\u043C \u0431\u044B\u043B **\u041C\u043D\u0435\u0441\u0430\u0440\u0445**.
    \u0421\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u043E \u043D\u0435\u043C \u0440\u0430\u0437\u043D\u044F\u0442\u0441\u044F:
    \u043E\u0434\u043D\u0438 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u0435\u0433\u043E \u0437\u0430\u0436\u0438\u0442\u043E\u0447\u043D\u044B\u043C
    \u043A\u0443\u043F\u0446\u043E\u043C \u0438\u043B\u0438 \u043A\u0430\u043C\u043D\u0435\u0440\u0435\u0437\u043E\u043C
    (\u044E\u0432\u0435\u043B\u0438\u0440\u043E\u043C) , \u0434\u0440\u0443\u0433\u0438\u0435
    \u2014 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043E\u0431\u043B\u0430\u0434\u0430\u0432\u0448\u0438\u043C
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C \u0438 \u043A\u0430\u043F\u0438\u0442\u0430\u043B\u043E\u043C,
    \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u044B\u043C \u0434\u043B\u044F
    \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u0430.
    \u0418\u043C\u044F \u043C\u0430\u0442\u0435\u0440\u0438 \u2014 **\u041F\u0430\u0440\u0442\u0435\u043D\u0438\u044F**
    (\u0438\u043B\u0438 \u041F\u0430\u0440\u0442\u0435\u043D\u0438\u0434\u0430),
    \u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u044F\u0445
    \u043E\u043D\u0430 \u0442\u0430\u043A\u0436\u0435 \u0444\u0438\u0433\u0443\u0440\u0438\u0440\u0443\u0435\u0442
    \u043A\u0430\u043A \u041F\u0438\u0444\u0438\u0430\u0434\u0430. *   **\u041F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u043E
    \u0438 \u0438\u043C\u044F:** \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u043B\u0435\u0433\u0435\u043D\u0434\u0435, \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u044F\u043C
    \u0431\u044B\u043B\u043E \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u043E
    \u0434\u0435\u043B\u044C\u0444\u0438\u0439\u0441\u043A\u043E\u0439 \u041F\u0438\u0444\u0438\u0435\u0439
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0441\u044B\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043D\u0435\u0442 \u0432\u0435\u043B\u0438\u043A\u0438\u043C
    \u043C\u0443\u0434\u0440\u0435\u0446\u043E\u043C. \u0418\u043C\u0435\u043D\u043D\u043E
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430
    \u043D\u0430\u0437\u0432\u0430\u043B\u0438 \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u043E\u043C,
    \u0447\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442 *\xAB\u0442\u043E\u0442,
    \u043E \u043A\u043E\u043C \u043E\u0431\u044A\u044F\u0432\u0438\u043B\u0430 \u041F\u0438\u0444\u0438\u044F\xBB*.
    \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0438 \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0432\u0435\u0440\u0441\u0438\u044F \u043E \u0435\u0433\u043E \u0431\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0438
    \u043E\u0442 \u0410\u043F\u043E\u043B\u043B\u043E\u043D\u0430. *   **\u0411\u0440\u0430\u0442\u044C\u044F:**
    \u0412 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u044E\u0442\u0441\u044F \u0434\u0432\u0430
    \u0435\u0433\u043E \u0441\u0442\u0430\u0440\u0448\u0438\u0445 \u0431\u0440\u0430\u0442\u0430
    \u2014 \u042D\u0432\u043D\u043E\u0441\u0442 \u0438 \u0422\u0438\u0440\u0440\u0435\u043D. 
    ### \U0001F9E0 \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F  \u042E\u043D\u044B\u0439
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u0440\u0430\u043D\u043E \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u0431\u043E\u043B\u044C\u0448\u0438\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u043A \u043D\u0430\u0443\u043A\u0430\u043C.  *   **\u041F\u0435\u0440\u0432\u044B\u0435
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F:** \u0415\u0433\u043E \u043F\u0435\u0440\u0432\u044B\u043C
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C \u0431\u044B\u043B
    **\u0413\u0435\u0440\u043C\u043E\u0434\u0430\u043C\u0430\u043D\u0442**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u0431\u0443\u0447\u0438\u043B \u0435\u0433\u043E \u043E\u0441\u043D\u043E\u0432\u0430\u043C
    \u043C\u0443\u0437\u044B\u043A\u0438, \u0436\u0438\u0432\u043E\u043F\u0438\u0441\u0438,
    \u0433\u0440\u0430\u043C\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u043B
    \u0437\u0430\u0443\u0447\u0438\u0432\u0430\u0442\u044C \u043D\u0430\u0438\u0437\u0443\u0441\u0442\u044C
    \u043F\u043E\u044D\u043C\u044B \u0413\u043E\u043C\u0435\u0440\u0430 \u0434\u043B\u044F
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F \u043F\u0430\u043C\u044F\u0442\u0438.
    *   **\u041E\u0431\u0443\u0447\u0435\u043D\u0438\u0435 \u0443 \u0424\u0435\u0440\u0435\u043A\u0438\u0434\u0430:**
    \u041E\u043A\u043E\u043B\u043E 18 \u043B\u0435\u0442 \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u043D\u0430 \u043E\u0441\u0442\u0440\u043E\u0432 \u041B\u0435\u0441\u0431\u043E\u0441,
    \u0433\u0434\u0435 \u0438\u0437\u0443\u0447\u0430\u043B \u0444\u0438\u0437\u0438\u043A\u0443,
    \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0443, \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u044E
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E \u0443 **\u0424\u0435\u0440\u0435\u043A\u0438\u0434\u0430
    \u0421\u0438\u0440\u043E\u0441\u0441\u043A\u043E\u0433\u043E**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u0432.
    *   **\u041C\u0438\u043B\u0435\u0442\u0441\u043A\u0430\u044F \u0448\u043A\u043E\u043B\u0430:**
    \u0417\u0430\u0442\u0435\u043C \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u041C\u0438\u043B\u0435\u0442, \u0433\u0434\u0435 \u0441\u043B\u0443\u0448\u0430\u043B
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E
    **\u0424\u0430\u043B\u0435\u0441\u0430** \u0438 \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0430
    **\u0410\u043D\u0430\u043A\u0441\u0438\u043C\u0430\u043D\u0434\u0440\u0430**,
    \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0439 \u0448\u043A\u043E\u043B\u044B
    \u0432 \u0413\u0440\u0435\u0446\u0438\u0438. \u041E\u0442 \u043D\u0438\u0445
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0437\u043D\u0430\u043D\u0438\u044F
    \u043F\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u043E\u0441\u043D\u043E\u0432\u044B
    \u0438\u043E\u043D\u0438\u0439\u0441\u043A\u043E\u0439 \u043D\u0430\u0443\u043A\u0438.
    *   **\u041F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0432
    \u0415\u0433\u0438\u043F\u0435\u0442:** \u041F\u043E \u0441\u043E\u0432\u0435\u0442\u0443
    \u0424\u0430\u043B\u0435\u0441\u0430, \u041F\u0438\u0444\u0430\u0433\u043E\u0440
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432 \u0415\u0433\u0438\u043F\u0435\u0442,
    \u0447\u0442\u043E\u0431\u044B \u0443\u0447\u0438\u0442\u044C\u0441\u044F \u0443
    \u0436\u0440\u0435\u0446\u043E\u0432. \u041F\u043E \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u0432\u0435\u0440\u0441\u0438\u0439, \u043E\u043D \u043F\u0440\u043E\u0432\u0435\u043B
    \u0442\u0430\u043C **22 \u0433\u043E\u0434\u0430**, \u0438\u0437\u0443\u0447\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443, \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0443
    \u0438 \u0431\u044B\u043B \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D \u0432
    \u0445\u0440\u0430\u043C\u043E\u0432\u044B\u0435 \u0442\u0430\u0438\u043D\u0441\u0442\u0432\u0430.
    *   **\u0412\u0430\u0432\u0438\u043B\u043E\u043D\u0441\u043A\u0438\u0439 \u043F\u043B\u0435\u043D:**
    \u0412 525 \u0433\u043E\u0434\u0443 \u0434\u043E \u043D. \u044D. \u0415\u0433\u0438\u043F\u0435\u0442
    \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u043B \u043F\u0435\u0440\u0441\u0438\u0434\u0441\u043A\u0438\u0439
    \u0446\u0430\u0440\u044C \u041A\u0430\u043C\u0431\u0438\u0437, \u0438 \u041F\u0438\u0444\u0430\u0433\u043E\u0440
    \u0431\u044B\u043B \u0443\u0432\u0435\u0434\u0435\u043D \u0432 **\u0412\u0430\u0432\u0438\u043B\u043E\u043D**
    \u043A\u0430\u043A \u043F\u043B\u0435\u043D\u043D\u0438\u043A. \u0422\u0430\u043C
    \u043E\u043D \u043F\u0440\u043E\u0432\u0435\u043B **12 \u043B\u0435\u0442**,
    \u043E\u0431\u0449\u0430\u044F\u0441\u044C \u0441 \u043C\u0430\u0433\u0430\u043C\u0438
    \u0438 \u0445\u0430\u043B\u0434\u0435\u0439\u0441\u043A\u0438\u043C\u0438 \u0436\u0440\u0435\u0446\u0430\u043C\u0438,
    \u0438 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u043E\u0439 \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u0438\u0435\u0439
    \u0438 \u043C\u0438\u0441\u0442\u0438\u043A\u043E\u0439, \u0447\u0442\u043E \u043F\u043E\u0437\u0436\u0435
    \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u043E \u043D\u0430 \u0435\u0433\u043E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E. \u041F\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435,
    \u0435\u0433\u043E \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u043B \u0446\u0430\u0440\u044C
    \u0414\u0430\u0440\u0438\u0439 \u0413\u0438\u0441\u0442\u0430\u0441\u043F.  ###
    \U0001F3DB\uFE0F \u0420\u0430\u0431\u043E\u0442\u0430 \u0438 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u0448\u043A\u043E\u043B\u044B  *   **\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0438 \u043F\u0435\u0440\u0435\u0435\u0437\u0434:** \u041E\u043A\u043E\u043B\u043E
    **532 \u0433\u043E\u0434\u0430 \u0434\u043E \u043D. \u044D.**, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u043E\u043A\u043E\u043B\u043E 60 \u043B\u0435\u0442, \u041F\u0438\u0444\u0430\u0433\u043E\u0440
    \u043F\u043E\u043A\u0438\u043D\u0443\u043B \u0421\u0430\u043C\u043E\u0441 (\u0438\u0437-\u0437\u0430
    \u043D\u0435\u0436\u0435\u043B\u0430\u043D\u0438\u044F \u043C\u0438\u0440\u0438\u0442\u044C\u0441\u044F
    \u0441 \u0442\u0438\u0440\u0430\u043D\u0438\u0435\u0439 \u041F\u043E\u043B\u0438\u043A\u0440\u0430\u0442\u0430)
    \u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u043E\u043B\u043E\u043D\u0438\u044E **\u041A\u0440\u043E\u0442\u043E\u043D**
    \u0432 \u042E\u0436\u043D\u043E\u0439 \u0418\u0442\u0430\u043B\u0438\u0438. *  
    **\u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0441\u043A\u0438\u0439
    \u0441\u043E\u044E\u0437:** \u0412 \u041A\u0440\u043E\u0442\u043E\u043D\u0435
    \u043E\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0448\u043A\u043E\u043B\u0443.
    \u042D\u0442\u043E \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0443\u0447\u0435\u0431\u043D\u044B\u0439 \u0446\u0435\u043D\u0442\u0440, \u0430
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E-\u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0435
    \u0431\u0440\u0430\u0442\u0441\u0442\u0432\u043E, \u0442\u0430\u0439\u043D\u044B\u0439
    \u043E\u0440\u0434\u0435\u043D \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043A\u043B\u0443\u0431. \u0415\u0433\u043E \u043F\u0440\u043E\u043F\u043E\u0432\u0435\u0434\u0438
    \u043E \u043D\u0440\u0430\u0432\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0438
    \u0438\u043C\u0435\u043B\u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u0443\u0441\u043F\u0435\u0445, \u0438 \u043E\u043D \u043E\u0431\u0440\u0435\u043B
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439,
    \u043A\u0430\u043A \u0441\u0440\u0435\u0434\u0438 \u043C\u0443\u0436\u0447\u0438\u043D,
    \u0442\u0430\u043A \u0438 \u0441\u0440\u0435\u0434\u0438 \u0436\u0435\u043D\u0449\u0438\u043D. 
    ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466 \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C: \u0436\u0435\u043D\u0430 \u0438 \u0434\u0435\u0442\u0438 
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u0432 \u0442\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u0436\u0438\u0437\u043D\u044C \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430
    \u0431\u044B\u043B\u0430 \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0439, \u0438
    \u044D\u0442\u043E \u043D\u0430\u0448\u043B\u043E \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445.  *   **\u0421\u0443\u043F\u0440\u0443\u0433\u0430:**
    \u0415\u0433\u043E \u0436\u0435\u043D\u043E\u0439 \u0441\u0442\u0430\u043B\u0430
    \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u0430\u044F \u0434\u0435\u0432\u0443\u0448\u043A\u0430
    \u043F\u043E \u0438\u043C\u0435\u043D\u0438 **\u0424\u0435\u0430\u043D\u0430**
    (\u0422\u0435\u0430\u043D\u043E). \u041E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u0446,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F, \u0432\u043E\u043F\u0440\u0435\u043A\u0438
    \u0437\u0430\u043A\u043E\u043D\u0430\u043C, \u043F\u0440\u0438\u0448\u043B\u0430
    \u043F\u043E\u0441\u043B\u0443\u0448\u0430\u0442\u044C \u0435\u0433\u043E \u0440\u0435\u0447\u0438.
    *   **\u0414\u0435\u0442\u0438:** \u0412 \u0431\u0440\u0430\u043A\u0435 \u0443
    \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C \u0434\u0435\u0442\u0438.
    \u0418\u043C\u0435\u043D\u0430 \u0434\u0435\u0442\u0435\u0439 \u0432 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445
    \u0440\u0430\u0437\u043D\u044F\u0442\u0441\u044F: \u0443 \u0414\u0438\u043E\u0433\u0435\u043D\u0430
    \u041B\u0430\u044D\u0440\u0442\u0441\u043A\u043E\u0433\u043E \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u044E\u0442\u0441\u044F
    \u0441\u044B\u043D \u0422\u0435\u043B\u0430\u0432\u0433 \u0438 \u0434\u043E\u0447\u044C
    \u0410\u0440\u0438\u0433\u043D\u043E\u0442\u0430 , \u0432 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445 \u2014 \u0441\u044B\u043D
    \u0410\u0440\u0438\u043C\u043D\u0435\u0441\u0442 \u0438 \u0434\u043E\u0447\u044C
    \u041C\u043D\u044F. \u0421\u044B\u043D \u0422\u0435\u043B\u0430\u0432\u0433 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0441\u0442\u0430\u043B \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0414\u0435\u043C\u043E\u043A\u0440\u0438\u0442\u0430.  ### \U0001F940 \u0421\u043C\u0435\u0440\u0442\u044C
    \u0438 \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043A\u043E\u043D\u0447\u0438\u043D\u044B  \u0416\u0438\u0437\u043D\u044C \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430
    \u0438 \u0435\u0433\u043E \u0441\u043E\u044E\u0437\u0430 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0431\u043E\u0440\u0432\u0430\u043B\u0430\u0441\u044C \u0438\u0437-\u0437\u0430
    \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0431\u043E\u0440\u044C\u0431\u044B
    \u0432 \u041A\u0440\u043E\u0442\u043E\u043D\u0435.  *   **\u041F\u0440\u0438\u0447\u0438\u043D\u0430:**
    \u0412 \u043A\u043E\u043D\u0446\u0435 VI \u0432\u0435\u043A\u0430 \u0434\u043E
    \u043D. \u044D. \u0432 \u041A\u0440\u043E\u0442\u043E\u043D\u0435 \u0432\u0441\u043F\u044B\u0445\u043D\u0443\u043B
    \u043C\u044F\u0442\u0435\u0436 \u043F\u0440\u043E\u0442\u0438\u0432 \u043F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u0435\u0432
    (\u0442\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u0430\u044F
    \xAB\u041A\u0438\u043B\u043E\u043D\u043E\u0432\u0430 \u0441\u043C\u0443\u0442\u0430\xBB),
    \u0438 \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0443 \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C
    \u0431\u0435\u0436\u0430\u0442\u044C \u0432 \u0441\u043E\u0441\u0435\u0434\u043D\u0438\u0439
    \u0433\u043E\u0440\u043E\u0434 **\u041C\u0435\u0442\u0430\u043F\u043E\u043D\u0442**.
    *   **\u041E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0441\u043C\u0435\u0440\u0442\u0438:** \u0422\u043E\u0447\u043D\u044B\u0435
    \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0435\u0433\u043E \u043A\u043E\u043D\u0447\u0438\u043D\u044B \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B,
    \u0438 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0432\u0435\u0440\u0441\u0438\u0439 :     1.  **\u041C\u0438\u0440\u043D\u0430\u044F
    \u043A\u043E\u043D\u0447\u0438\u043D\u0430:** \u041F\u043E \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u0432\u0435\u0440\u0441\u0438\u0439, \u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 \u041C\u0435\u0442\u0430\u043F\u043E\u043D\u0442\u0435 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    80 \u043B\u0435\u0442 (\u0438\u043B\u0438 90 \u043B\u0435\u0442, \u043F\u043E
    \u0434\u0440\u0443\u0433\u0438\u043C \u0434\u0430\u043D\u043D\u044B\u043C).    
    2.  **\u0413\u0438\u0431\u0435\u043B\u044C \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u043F\u043E\u0436\u0430\u0440\u0430 \u0438\u043B\u0438 \u043D\u0430\u043F\u0430\u0434\u0435\u043D\u0438\u044F:**
    \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435
    \u043F\u043E\u044D\u0442\u0438\u0447\u043D\u043E\u0439 \u0438 \u0442\u0440\u0430\u0433\u0438\u0447\u043D\u043E\u0439
    \u043B\u0435\u0433\u0435\u043D\u0434\u0435, \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0438,
    \u043F\u044B\u0442\u0430\u044F\u0441\u044C \u0441\u043F\u0430\u0441\u0442\u0438
    \u0435\u0433\u043E \u0438\u0437 \u0433\u043E\u0440\u044F\u0449\u0435\u0433\u043E
    \u0434\u043E\u043C\u0430, \u0441\u043B\u043E\u0436\u0438\u043B\u0438 \u043C\u043E\u0441\u0442
    \u0438\u0437 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0442\u0435\u043B. \u041E\u0441\u0442\u0430\u0432\u0448\u0438\u0441\u044C \u0432
    \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u0435, \u041F\u0438\u0444\u0430\u0433\u043E\u0440
    \u043F\u043E\u0433\u0438\u0431 \u0432 \u043E\u0433\u043D\u0435 \u0438\u043B\u0438
    \u043B\u0438\u0448\u0438\u043B \u0441\u0435\u0431\u044F \u0436\u0438\u0437\u043D\u0438.    
    3.  **\u0412\u043E\u043E\u0440\u0443\u0436\u0435\u043D\u043D\u044B\u0439 \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442:**
    \u0415\u0449\u0435 \u043E\u0434\u043D\u0430 \u0432\u0435\u0440\u0441\u0438\u044F
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043E \u0435\u0433\u043E \u0433\u0438\u0431\u0435\u043B\u0438
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0432\u043E\u043E\u0440\u0443\u0436\u0435\u043D\u043D\u043E\u0433\u043E
    \u0441\u0442\u043E\u043B\u043A\u043D\u043E\u0432\u0435\u043D\u0438\u044F \u0432
    \u041C\u0435\u0442\u0430\u043F\u043E\u043D\u0442\u0435.  \u0418\u0442\u0430\u043A,
    \u0436\u0438\u0437\u043D\u044C \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430
    \u2014 \u044D\u0442\u043E \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u043E\u0442
    \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u0430 \u043E \u0435\u0433\u043E
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0438 \u0434\u043E \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0438\u0431\u0435\u043B\u0438 \u0432 \u043F\u043E\u043F\u044B\u0442\u043A\u0435
    \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E, \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u043C\u043E\u0435
    \u0437\u043D\u0430\u043D\u0438\u0435\u043C \u0438 \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0435\u0439."
  personalLifeEn: 
  shortBioRu: "\u0416\u0438\u0437\u043D\u044C \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430
    \u0421\u0430\u043C\u043E\u0441\u0441\u043A\u043E\u0433\u043E \u2014 \u044D\u0442\u043E
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0435 \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u0438\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0444\u0430\u043A\u0442\u043E\u0432
    \u0438 \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0445 \u043B\u0435\u0433\u0435\u043D\u0434,
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u043F\u043E\u0447\u0442\u0438 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E.
    \u041E\u043D \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u0430 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u043C
    \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u0442\u043E\u0440\u043E\u043C \u0438
    \u043C\u0438\u0441\u0442\u0438\u043A\u043E\u043C, \u043E\u0441\u043D\u043E\u0432\u0430\u0432\u0448\u0438\u043C
    \u0442\u0430\u0439\u043D\u043E\u0435 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043D\u0430 \u0434\u0432\u0430 \u0442\u044B\u0441\u044F\u0447\u0435\u043B\u0435\u0442\u0438\u044F
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u043E \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u0437\u0430\u043F\u0430\u0434\u043D\u043E\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u0438 \u043D\u0430\u0443\u043A\u0438. \u0414\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u044B\u0445
    \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u0432,
    \u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0445 \u0438\u043C
    \u0441\u0430\u043C\u0438\u043C, \u043D\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442,
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430 \u043D\u0430\u043C \u043F\u043E
    \u0442\u0440\u0443\u0434\u0430\u043C \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u0445
    \u0430\u0432\u0442\u043E\u0440\u043E\u0432, \u043F\u043E\u043B\u043D\u044B\u0445
    \u043C\u0438\u0444\u043E\u0432.  ### \U0001F4DC \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B (\u043E\u043A.
    570 \u0433. \u0434\u043E \u043D.\u044D.)  \u0411\u0443\u0434\u0443\u0449\u0438\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u043E\u043A\u043E\u043B\u043E 570 \u0433\u043E\u0434\u0430 \u0434\u043E \u043D.
    \u044D. \u043D\u0430 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u043C \u043E\u0441\u0442\u0440\u043E\u0432\u0435
    \u0421\u0430\u043C\u043E\u0441 \u0432 \u042D\u0433\u0435\u0439\u0441\u043A\u043E\u043C
    \u043C\u043E\u0440\u0435. \u0415\u0433\u043E \u0438\u043C\u044F, \u043F\u043E
    \u043B\u0435\u0433\u0435\u043D\u0434\u0435, \u0431\u044B\u043B\u043E \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u043E
    \u0434\u0435\u043B\u044C\u0444\u0438\u0439\u0441\u043A\u043E\u0439 \u041F\u0438\u0444\u0438\u0435\u0439,
    \u0447\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442 *\xAB\u0442\u043E\u0442,
    \u043E \u043A\u043E\u043C \u043E\u0431\u044A\u044F\u0432\u0438\u043B\u0430 \u041F\u0438\u0444\u0438\u044F\xBB*. 
    *   **\u0421\u0435\u043C\u044C\u044F:** \u041E\u0442\u0446\u0430 \u0437\u0432\u0430\u043B\u0438
    \u041C\u043D\u0435\u0441\u0430\u0440\u0445. \u0418\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438
    \u0440\u0430\u0441\u0445\u043E\u0434\u044F\u0442\u0441\u044F \u0432 \u0435\u0433\u043E
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0438:
    \u043F\u043E \u043E\u0434\u043D\u043E\u0439 \u0432\u0435\u0440\u0441\u0438\u0438,
    \u043E\u043D \u0431\u044B\u043B \u0431\u043E\u0433\u0430\u0442\u044B\u043C \u043A\u0443\u043F\u0446\u043E\u043C
    \u0438\u0437 \u0422\u0438\u0440\u0430, \u043F\u043E\u043B\u0443\u0447\u0438\u0432\u0448\u0438\u043C
    \u0441\u0430\u043C\u043E\u0441\u0441\u043A\u043E\u0435 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u043E
    \u0437\u0430 \u043F\u043E\u043C\u043E\u0449\u044C \u0433\u043E\u0440\u043E\u0434\u0443,
    \u043F\u043E \u0434\u0440\u0443\u0433\u043E\u0439 \u2014 \u0440\u0435\u043C\u0435\u0441\u043B\u0435\u043D\u043D\u0438\u043A\u043E\u043C
    (\u043A\u0430\u043C\u043D\u0435\u0440\u0435\u0437\u043E\u043C \u0438\u043B\u0438
    \u0440\u0435\u0437\u0447\u0438\u043A\u043E\u043C \u0433\u0435\u043C\u043C). \u041C\u0430\u0442\u044C,
    \u041F\u0430\u0440\u0442\u0435\u043D\u0438\u0434\u0430 (\u043F\u043E\u0437\u0436\u0435
    \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u0430\u044F \u041F\u0438\u0444\u0430\u0438\u0434\u043E\u0439),
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0430 \u0438\u0437
    \u0437\u043D\u0430\u0442\u043D\u043E\u0433\u043E \u0440\u043E\u0434\u0430.  ###
    \U0001F30D \u041F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F
    \u0438 \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435 (\u043E\u043A. 548\u2013532
    \u0433\u0433. \u0434\u043E \u043D.\u044D.)  \u041D\u0435\u0443\u0433\u043E\u043C\u043E\u043D\u043D\u044B\u0439
    \u0443\u043C \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430 \u0438 \u0436\u0430\u0436\u0434\u0430
    \u0437\u043D\u0430\u043D\u0438\u0439 \u043F\u0440\u0438\u0432\u0435\u043B\u0438
    \u0435\u0433\u043E \u0432 \u0434\u043E\u043B\u0433\u0438\u0435 \u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0438\u044F.
    \u041E\u043D \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u043D\u044B\u0445 \u043B\u044E\u0434\u0435\u0439
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438,
    \u0432\u043E\u0431\u0440\u0430\u0432\u0448\u0438\u043C \u0432 \u0441\u0435\u0431\u044F
    \u043C\u0443\u0434\u0440\u043E\u0441\u0442\u044C \u0440\u0430\u0437\u043D\u044B\u0445
    \u043A\u0443\u043B\u044C\u0442\u0443\u0440.  *   **\u041D\u0430\u0447\u0430\u043B\u043E
    \u043F\u0443\u0442\u0438:** \u0415\u0433\u043E \u043F\u0435\u0440\u0432\u044B\u043C
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C \u0431\u044B\u043B
    \u0413\u0435\u0440\u043C\u043E\u0434\u0430\u043C\u0430\u043D\u0442, \u043E\u0431\u0443\u0447\u0438\u0432\u0448\u0438\u0439
    \u0435\u0433\u043E \u043C\u0443\u0437\u044B\u043A\u0435 \u0438 \u0436\u0438\u0432\u043E\u043F\u0438\u0441\u0438.
    \u0417\u0430\u0442\u0435\u043C \u043E\u043D \u0441\u043B\u0443\u0448\u0430\u043B
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0424\u0430\u043B\u0435\u0441\u0430 \u0438
    \u0410\u043D\u0430\u043A\u0441\u0438\u043C\u0430\u043D\u0434\u0440\u0430 \u0432
    \u041C\u0438\u043B\u0435\u0442\u0435 \u2014 \u043A\u043E\u043B\u044B\u0431\u0435\u043B\u0438
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438.
    *   **\u0415\u0433\u0438\u043F\u0435\u0442:** \u041F\u043E \u0441\u043E\u0432\u0435\u0442\u0443
    \u0424\u0430\u043B\u0435\u0441\u0430 \u0438 \u043F\u0440\u0438 \u0441\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0438
    \u0441\u0430\u043C\u043E\u0441\u0441\u043A\u043E\u0433\u043E \u0442\u0438\u0440\u0430\u043D\u0430
    \u041F\u043E\u043B\u0438\u043A\u0440\u0430\u0442\u0430, \u041F\u0438\u0444\u0430\u0433\u043E\u0440
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432 \u0415\u0433\u0438\u043F\u0435\u0442,
    \u0433\u0434\u0435 \u043F\u0440\u043E\u0431\u044B\u043B **22 \u0433\u043E\u0434\u0430**.
    \u0422\u0430\u043C \u043E\u043D \u0438\u0437\u0443\u0447\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044E, \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0443
    \u0438, \u0447\u0442\u043E \u0441\u0430\u043C\u043E\u0435 \u0432\u0430\u0436\u043D\u043E\u0435,
    \u0431\u044B\u043B \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D \u0432 \u0437\u0430\u043A\u0440\u044B\u0442\u044B\u0435
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435 \u0442\u0430\u0438\u043D\u0441\u0442\u0432\u0430
    \u0436\u0440\u0435\u0446\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0430 \u043D\u0435\u0433\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0438
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u0438\u0435.
    *   **\u0412\u0430\u0432\u0438\u043B\u043E\u043D:** \u0412 525 \u0433\u043E\u0434\u0443
    \u0434\u043E \u043D. \u044D. \u0415\u0433\u0438\u043F\u0435\u0442 \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u043B
    \u043F\u0435\u0440\u0441\u0438\u0434\u0441\u043A\u0438\u0439 \u0446\u0430\u0440\u044C
    \u041A\u0430\u043C\u0431\u0438\u0437, \u0438 \u041F\u0438\u0444\u0430\u0433\u043E\u0440
    \u0431\u044B\u043B \u0443\u0432\u0435\u0434\u0435\u043D \u0432 \u0412\u0430\u0432\u0438\u043B\u043E\u043D
    \u043A\u0430\u043A \u043F\u043B\u0435\u043D\u043D\u0438\u043A. \u041F\u0440\u043E\u0431\u044B\u0432
    \u0442\u0430\u043C **12 \u043B\u0435\u0442**, \u043E\u043D \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0435\u0439 \u0438
    \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u0438\u044F\u043C\u0438
    \u043C\u0435\u0441\u0442\u043D\u044B\u0445 \u043C\u0430\u0433\u043E\u0432 \u0438
    \u0445\u0430\u043B\u0434\u0435\u0435\u0432.  ### \U0001F3DB \u041E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435
    \u0448\u043A\u043E\u043B\u044B \u0438 \u0436\u0438\u0437\u043D\u044C \u0432 \u041A\u0440\u043E\u0442\u043E\u043D\u0435
    (\u043E\u043A. 532\u2013510 \u0433\u0433. \u0434\u043E \u043D.\u044D.)  \u0412
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u043E\u043A\u043E\u043B\u043E
    56 \u043B\u0435\u0442 \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u043D\u0430 \u0421\u0430\u043C\u043E\u0441, \u043D\u043E, \u043D\u0435 \u0436\u0435\u043B\u0430\u044F
    \u043C\u0438\u0440\u0438\u0442\u044C\u0441\u044F \u0441 \u0442\u0438\u0440\u0430\u043D\u0438\u0435\u0439
    \u041F\u043E\u043B\u0438\u043A\u0440\u0430\u0442\u0430, \u043E\u043A\u043E\u043B\u043E
    532 \u0433\u043E\u0434\u0430 \u0434\u043E \u043D. \u044D. \u043F\u043E\u043A\u0438\u043D\u0443\u043B
    \u0440\u043E\u0434\u0438\u043D\u0443 \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0438 \u043F\u0435\u0440\u0435\u0441\u0435\u043B\u0438\u043B\u0441\u044F \u0432
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0439 \u0433\u043E\u0440\u043E\u0434
    \u041A\u0440\u043E\u0442\u043E\u043D \u0432 \u042E\u0436\u043D\u043E\u0439 \u0418\u0442\u0430\u043B\u0438\u0438.
    \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u0441\u0442\u0430\u043B
    \u0441\u0430\u043C\u044B\u043C \u044F\u0440\u043A\u0438\u043C \u0432 \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u0438.  *   **\u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0441\u043A\u0438\u0439
    \u0441\u043E\u044E\u0437:** \u0412 \u041A\u0440\u043E\u0442\u043E\u043D\u0435
    \u043E\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u044B\u043B\u0430
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0439
    \u043E\u0431\u0449\u0438\u043D\u043E\u0439, \u043D\u0430\u0443\u0447\u043D\u044B\u043C
    \u0431\u0440\u0430\u0442\u0441\u0442\u0432\u043E\u043C \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043A\u043B\u0443\u0431\u043E\u043C. \u042D\u0442\u043E \u0431\u044B\u043B \u0441\u0432\u043E\u0435\u0433\u043E
    \u0440\u043E\u0434\u0430 \u0442\u0430\u0439\u043D\u044B\u0439 \u043E\u0440\u0434\u0435\u043D
    \u0434\u043B\u044F \u0438\u0437\u0431\u0440\u0430\u043D\u043D\u044B\u0445.    
    *   **\u0421\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430:** \u0423\u0447\u0435\u043D\u0438\u043A\u0438
    \u0434\u0435\u043B\u0438\u043B\u0438\u0441\u044C \u043D\u0430 \u0434\u0432\u0435
    \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0438: **\u0430\u043A\u0443\u0441\u043C\u0430\u0442\u0438\u043A\u0438**
    (\xAB\u0441\u043B\u0443\u0448\u0430\u0442\u0435\u043B\u0438\xBB) \u2014 \u043D\u043E\u0432\u0438\u0447\u043A\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0440\u0430\u0437\u0440\u0435\u0448\u0430\u043B\u043E\u0441\u044C
    \u043B\u0438\u0448\u044C \u0432\u043D\u0438\u043C\u0430\u0442\u044C \u0433\u043E\u043B\u043E\u0441\u0443
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F \u0438\u0437-\u0437\u0430 \u0437\u0430\u043D\u0430\u0432\u0435\u0441\u0430,
    \u0438 **\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438** (\xAB\u043F\u043E\u0437\u043D\u0430\u044E\u0449\u0438\u0435\xBB)
    \u2014 \u0442\u0435, \u043A\u0442\u043E \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0435 \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435
    \u0438 \u043C\u043E\u0433 \u0432\u0438\u0434\u0435\u0442\u044C \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430.    
    *   **\u041E\u0431\u0440\u0430\u0437 \u0436\u0438\u0437\u043D\u0438:** \u0427\u043B\u0435\u043D\u044B
    \u0441\u043E\u044E\u0437\u0430 \u0432\u0435\u043B\u0438 \u0441\u0442\u0440\u043E\u0433\u0438\u0439
    \u0430\u0441\u043A\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u043E\u0431\u0440\u0430\u0437
    \u0436\u0438\u0437\u043D\u0438: \u0431\u044B\u043B\u0438 \u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0446\u0430\u043C\u0438,
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u043E\u0432\u0430\u043B\u0438 \u0440\u0438\u0442\u0443\u0430\u043B\u044B
    \u043E\u0447\u0438\u0449\u0435\u043D\u0438\u044F, \u0443\u0434\u0435\u043B\u044F\u043B\u0438
    \u043C\u043D\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043C\u0443\u0437\u044B\u043A\u0435
    \u0438 \u0433\u0438\u043C\u043D\u0430\u0441\u0442\u0438\u043A\u0435. \u0418\u0445
    \u0434\u0435\u0432\u0438\u0437\u043E\u043C \u0431\u044B\u043B\u0438 \u0441\u043B\u043E\u0432\u0430:
    *\xAB\u041E\u0442\u0441\u0435\u043A\u0430\u0439 \u043E\u0433\u043D\u0435\u043C,
    \u0436\u0435\u043B\u0435\u0437\u043E\u043C \u0438 \u043B\u044E\u0431\u044B\u043C
    \u043E\u0440\u0443\u0436\u0438\u0435\u043C \u043E\u0442 \u0442\u0435\u043B\u0430
    \u2014 \u0431\u043E\u043B\u0435\u0437\u043D\u044C, \u043E\u0442 \u0434\u0443\u0448\u0438
    \u2014 \u043D\u0435\u0432\u0435\u0436\u0435\u0441\u0442\u0432\u043E, \u043E\u0442
    \u0443\u0442\u0440\u043E\u0431\u044B \u2014 \u0440\u043E\u0441\u043A\u043E\u0448\u044C\xBB*.    
    *   **\u0421\u0438\u043C\u0432\u043E\u043B:** \u041E\u043F\u043E\u0437\u043D\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0437\u043D\u0430\u043A\u043E\u043C \u043F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u0435\u0432
    \u0431\u044B\u043B\u0430 **\u043F\u0435\u043D\u0442\u0430\u0433\u0440\u0430\u043C\u043C\u0430**
    \u2014 \u043F\u044F\u0442\u0438\u043A\u043E\u043D\u0435\u0447\u043D\u0430\u044F
    \u0437\u0432\u0435\u0437\u0434\u0430.  ### \U0001F4A1 \u0423\u0447\u0435\u043D\u0438\u0435
    \u0438 \u0432\u043A\u043B\u0430\u0434 \u0432 \u043D\u0430\u0443\u043A\u0443 
    \u0421\u0435\u0440\u0434\u0446\u0435\u043C \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430 \u0431\u044B\u043B\u0430 \u043C\u044B\u0441\u043B\u044C:
    **\xAB\u0412\u0441\u0451 \u0435\u0441\u0442\u044C \u0447\u0438\u0441\u043B\u043E\xBB**.
    \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u0441\u0443\u0449\u043D\u043E\u0441\u0442\u044C
    \u043C\u0438\u0440\u0430 \u043C\u043E\u0436\u043D\u043E \u043F\u043E\u0437\u043D\u0430\u0442\u044C
    \u0447\u0435\u0440\u0435\u0437 \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u0435
    \u0437\u0430\u043A\u043E\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438,
    \u0438 \u0447\u0438\u0441\u043B\u0430 \u044D\u0442\u0438 \u2014 \u043D\u0435
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u044F, \u0430 \u0436\u0438\u0432\u044B\u0435
    \u0441\u0443\u0449\u043D\u043E\u0441\u0442\u0438.  *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0438 \u043C\u0443\u0437\u044B\u043A\u0430:** \u0415\u043C\u0443 \u0438 \u0435\u0433\u043E
    \u0448\u043A\u043E\u043B\u0435 \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0432\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 (\u0445\u043E\u0442\u044F, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u0438 \u0434\u043E \u043D\u0435\u0433\u043E). \u0422\u0430\u043A\u0436\u0435
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u043E\u0442\u043A\u0440\u044B\u043B,
    \u0447\u0442\u043E \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0447\u043D\u044B\u0435
    \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B\u044B
    (\u043E\u043A\u0442\u0430\u0432\u0430, \u043A\u0432\u0438\u043D\u0442\u0430,
    \u043A\u0432\u0430\u0440\u0442\u0430) \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E\u0442
    \u0441\u0442\u0440\u043E\u0433\u0438\u043C \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u043C
    \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u043C (2:1,
    3:2, 4:3). \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u0438 \u043B\u0435\u0433\u043B\u043E \u0432 \u043E\u0441\u043D\u043E\u0432\u0443
    \u0438\u0434\u0435\u0438 **\xAB\u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0438
    \u0441\u0444\u0435\u0440\xBB** \u2014 \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0437\u0432\u0443\u0447\u0430\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0438\u0437\u0434\u0430\u044E\u0442 \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u0435
    \u0442\u0435\u043B\u0430, \u0432\u0440\u0430\u0449\u0430\u044F\u0441\u044C \u0432\u043E
    \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439. *   **\u041C\u0438\u0441\u0442\u0438\u043A\u0430
    \u0438 \u044D\u0442\u0438\u043A\u0430:** \u041F\u0438\u0444\u0430\u0433\u043E\u0440
    \u0432\u0435\u0440\u0438\u043B \u0432 **\u043C\u0435\u0442\u0435\u043C\u043F\u0441\u0438\u0445\u043E\u0437**
    (\u043F\u0435\u0440\u0435\u0441\u0435\u043B\u0435\u043D\u0438\u0435 \u0434\u0443\u0448)
    \u0438 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E
    \u043F\u043E\u043C\u043D\u0438\u0442 \u0447\u0435\u0442\u044B\u0440\u0435 \u0441\u0432\u043E\u0438
    \u043F\u0440\u043E\u0448\u043B\u044B\u0435 \u0436\u0438\u0437\u043D\u0438. \u0418\u0437-\u0437\u0430
    \u044D\u0442\u043E\u0439 \u0432\u0435\u0440\u044B \u043E\u043D \u043F\u0440\u043E\u043F\u043E\u0432\u0435\u0434\u043E\u0432\u0430\u043B
    \u0441\u0432\u044F\u0442\u043E\u0441\u0442\u044C \u0436\u0438\u0437\u043D\u0438
    \u0432\u0441\u0435\u0445 \u0441\u0443\u0449\u0435\u0441\u0442\u0432 \u0438 \u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0441\u0442\u0432\u043E. 
    ### \U0001F4D6 \u0421\u043C\u0435\u0440\u0442\u044C \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u041C\u043E\u0433\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0441\u043A\u0438\u0439
    \u0441\u043E\u044E\u0437 \u0432\u044B\u0437\u044B\u0432\u0430\u043B \u043D\u0435\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u043E
    \u0434\u0435\u043C\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0443\u0433\u043E\u0432 \u041A\u0440\u043E\u0442\u043E\u043D\u0430.
    \u041E\u043A\u043E\u043B\u043E 500 \u0433\u043E\u0434\u0430 \u0434\u043E \u043D.
    \u044D. \u0432\u0441\u043F\u044B\u0445\u043D\u0443\u043B \u043C\u044F\u0442\u0435\u0436
    \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u043D\u0435\u043A\u043E\u0435\u0433\u043E \u041A\u0438\u043B\u043E\u043D\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043D\u0430\u043F\u0430\u043B \u043D\u0430
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435 \u043F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u0435\u0432.
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u0431\u0435\u0436\u0430\u043B \u0432
    \u0441\u043E\u0441\u0435\u0434\u043D\u0438\u0439 \u0433\u043E\u0440\u043E\u0434
    \u041C\u0435\u0442\u0430\u043F\u043E\u043D\u0442.  \u041E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u043F\u043E\u043A\u0440\u044B\u0442\u044B
    \u043C\u0440\u0430\u043A\u043E\u043C. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0432\u0435\u0440\u0441\u0438\u0439:
    1.  **\u041C\u0438\u0440\u043D\u0430\u044F \u043A\u043E\u043D\u0447\u0438\u043D\u0430:**
    \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u0414\u0438\u043E\u0433\u0435\u043D\u0443
    \u041B\u0430\u044D\u0440\u0442\u0441\u043A\u043E\u043C\u0443, \u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 90 \u043B\u0435\u0442
    \u0432 \u041C\u0435\u0442\u0430\u043F\u043E\u043D\u0442\u0435. 2.  **\u0413\u0438\u0431\u0435\u043B\u044C
    \u0432 \u043F\u043E\u0436\u0430\u0440\u0435:** \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u0434\u0440\u0443\u0433\u043E\u0439 \u043B\u0435\u0433\u0435\u043D\u0434\u0435,
    \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0438, \u043F\u044B\u0442\u0430\u044F\u0441\u044C
    \u0441\u043F\u0430\u0441\u0442\u0438 \u0435\u0433\u043E \u0438\u0437 \u0433\u043E\u0440\u044F\u0449\u0435\u0433\u043E
    \u0434\u043E\u043C\u0430, \u0441\u043B\u043E\u0436\u0438\u043B\u0438 \u043C\u043E\u0441\u0442
    \u0438\u0437 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0442\u0435\u043B. \u041E\u0441\u0442\u0430\u0432\u0448\u0438\u0441\u044C \u043E\u0434\u0438\u043D,
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u043F\u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0441 \u0441\u043E\u0431\u043E\u0439.  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0433\u0438\u0431\u0435\u043B\u044C \u0443\u0447\u0438\u0442\u0435\u043B\u044F
    \u0438 \u0440\u0430\u0437\u0433\u0440\u043E\u043C \u0448\u043A\u043E\u043B\u044B
    \u0432 \u041A\u0440\u043E\u0442\u043E\u043D\u0435, \u043F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u044B
    \u0440\u0430\u0441\u0441\u0435\u044F\u043B\u0438\u0441\u044C \u043F\u043E \u0433\u043E\u0440\u043E\u0434\u0430\u043C
    \u0413\u0440\u0435\u0446\u0438\u0438 \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B\u0438
    \u0441\u0432\u043E\u044E \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C,
    \u043E\u043A\u0430\u0437\u0430\u0432 \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E
    \u041F\u043B\u0430\u0442\u043E\u043D\u0430 \u0438 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u0432\u0441\u0435\u0439 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0431\u0440\u043E\u0441\u043B\u0430
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u043C\u0438, \u0447\u0442\u043E \u043E\u0442\u0434\u0435\u043B\u0438\u0442\u044C
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u043F\u0440\u0430\u0432\u0434\u0443
    \u043E\u0442 \u0432\u044B\u043C\u044B\u0441\u043B\u0430 \u043F\u043E\u0440\u043E\u0439
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0432 \u044D\u0442\u043E\u0439 \xAB\u0441\u0435\u0440\u043E\u0439 \u0437\u043E\u043D\u0435\xBB
    \u043A\u0440\u043E\u044E\u0442\u0441\u044F \u0441\u0430\u043C\u044B\u0435 \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0435 \u0444\u0430\u043A\u0442\u044B.
    \u0412\u043E\u0442 \u043F\u043E\u0434\u0431\u043E\u0440\u043A\u0430 \u0441\u0430\u043C\u044B\u0445
    \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0445 \u0438 \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445
    \u0434\u0435\u0442\u0430\u043B\u0435\u0439 \u0438\u0437 \u0436\u0438\u0437\u043D\u0438
    \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430
    \u0438 \u0435\u0433\u043E \u0448\u043A\u043E\u043B\u044B.  ### 1. \U0001F947
    \xAB\u0424\u0438\u043B\u043E\u0441\u043E\u0444\xBB \u2014 \u044D\u0442\u043E
    \u0441\u043B\u043E\u0432\u043E \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B
    \u043E\u043D  \u0414\u043E \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430 \u043C\u0443\u0434\u0440\u0435\u0446\u043E\u0432
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438 **\xAB\u0441\u043E\u0444\u043E\u0441\u0430\u043C\u0438\xBB**
    (\u043C\u0443\u0434\u0440\u0435\u0446\u0430\u043C\u0438). \u042D\u0442\u043E
    \u0437\u0432\u0443\u0447\u0430\u043B\u043E \u0433\u043E\u0440\u0434\u0435\u043B\u0438\u0432\u043E
    \u0438 \u0441\u0430\u043C\u043E\u0443\u0432\u0435\u0440\u0435\u043D\u043D\u043E.
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u0436\u0435 \u0432\u0432\u0435\u043B
    \u0442\u0435\u0440\u043C\u0438\u043D **\xAB\u0444\u0438\u043B\u043E\u0441\u043E\u0444\xBB**
    (\u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E \u2014 \xAB\u043B\u044E\u0431\u044F\u0449\u0438\u0439
    \u043C\u0443\u0434\u0440\u043E\u0441\u0442\u044C\xBB). \u041D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441,
    \u043A\u0442\u043E \u043E\u043D \u0442\u0430\u043A\u043E\u0439, \u043E\u043D
    \u0441\u043A\u0440\u043E\u043C\u043D\u043E \u043E\u0442\u0432\u0435\u0447\u0430\u043B:
    \xAB\u042F \u043D\u0435 \u043C\u0443\u0434\u0440\u0435\u0446, \u044F \u043B\u0438\u0448\u044C
    \u0441\u0442\u0440\u0435\u043C\u043B\u044E\u0441\u044C \u043A \u043C\u0443\u0434\u0440\u043E\u0441\u0442\u0438\xBB.
    \u041E\u043D \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u043B \u0436\u0438\u0437\u043D\u044C
    \u0441 \u041E\u043B\u0438\u043C\u043F\u0438\u0439\u0441\u043A\u0438\u043C\u0438
    \u0438\u0433\u0440\u0430\u043C\u0438: \u043E\u0434\u043D\u0438 \u043F\u0440\u0438\u0445\u043E\u0434\u044F\u0442
    \u0441\u043E\u0440\u0435\u0432\u043D\u043E\u0432\u0430\u0442\u044C\u0441\u044F,
    \u0434\u0440\u0443\u0433\u0438\u0435 \u2014 \u0442\u043E\u0440\u0433\u043E\u0432\u0430\u0442\u044C,
    \u0430 \u0442\u0440\u0435\u0442\u044C\u0438 (\u0441\u0430\u043C\u044B\u0435 \u043B\u0443\u0447\u0448\u0438\u0435)
    \u2014 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
    \u0438 \u043F\u043E\u043D\u0438\u043C\u0430\u0442\u044C, \u043A\u0430\u043A \u0432\u0441\u0451
    \u0443\u0441\u0442\u0440\u043E\u0435\u043D\u043E.  ### 2. \U0001F507 \u041E\u0431\u0435\u0442
    \u043C\u043E\u043B\u0447\u0430\u043D\u0438\u044F \u0438 \xAB\u0421\u0430\u043C
    \u0441\u043A\u0430\u0437\u0430\u043B\xBB  \u0412 \u0448\u043A\u043E\u043B\u0435
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E
    \u0441\u0442\u0440\u043E\u0436\u0430\u0439\u0448\u0435\u0435 \u043F\u0440\u0430\u0432\u0438\u043B\u043E:
    **\u043F\u0435\u0440\u0432\u044B\u0435 \u043F\u044F\u0442\u044C \u043B\u0435\u0442
    \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u044F \u0443\u0447\u0435\u043D\u0438\u043A\u0438
    \u0434\u043E\u043B\u0436\u043D\u044B \u0431\u044B\u043B\u0438 \u0445\u0440\u0430\u043D\u0438\u0442\u044C
    \u043C\u043E\u043B\u0447\u0430\u043D\u0438\u0435**. \u041E\u043D\u0438 \u043C\u043E\u0433\u043B\u0438
    \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u043B\u0443\u0448\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0443\u0447\u0438\u0442\u0435\u043B\u044F
    \u0438\u0437-\u0437\u0430 \u0437\u0430\u043D\u0430\u0432\u0435\u0441\u043A\u0438,
    \u043D\u0435 \u0432\u0438\u0434\u044F \u0435\u0433\u043E \u043B\u0438\u0446\u0430,
    \u0438 \u043D\u0438 \u0432 \u043A\u043E\u0435\u043C \u0441\u043B\u0443\u0447\u0430\u0435
    \u043D\u0435 \u0437\u0430\u0434\u0430\u0432\u0430\u0442\u044C \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u0432
    \u0438 \u043D\u0435 \u0441\u043F\u043E\u0440\u0438\u0442\u044C. \u042D\u0442\u043E
    \u0434\u0435\u043B\u0430\u043B\u043E\u0441\u044C \u0434\u043B\u044F \u0442\u043E\u0433\u043E,
    \u0447\u0442\u043E\u0431\u044B \u043E\u0447\u0438\u0441\u0442\u0438\u0442\u044C
    \u0440\u0430\u0437\u0443\u043C \u043E\u0442 \u0441\u0442\u0430\u0440\u044B\u0445
    \u043F\u0440\u0435\u0434\u0440\u0430\u0441\u0441\u0443\u0434\u043A\u043E\u0432. 
    \u041F\u043E\u0437\u0436\u0435, \u043A\u043E\u0433\u0434\u0430 \u0443\u0447\u0435\u043D\u0438\u043A
    \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0438\u043B \u0432 \u0440\u0430\u0437\u0440\u044F\u0434
    \xAB\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432\xBB (\u043F\u043E\u0437\u043D\u0430\u044E\u0449\u0438\u0445),
    \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u043A\u043B\u044F\u0442\u0432\u043E\u0439
    \u043F\u0435\u0440\u0435\u0434 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0438\u0435\u043C
    \u0432 \u0442\u0430\u0439\u043D\u044B \u0443\u0447\u0435\u043D\u0438\u044F \u0431\u044B\u043B\u0430
    \u0444\u0440\u0430\u0437\u0430: **\xAB\u0410\u0432\u0442\u0301\u043E\u0441 \u044D\u0301\u0444\u0430\xBB**
    \u2014 **\xAB\u0421\u0430\u043C \u0441\u043A\u0430\u0437\u0430\u043B\xBB** (\u0438\u043C\u0435\u044F
    \u0432 \u0432\u0438\u0434\u0443 \u0423\u0447\u0438\u0442\u0435\u043B\u044F).
    \u042D\u0442\u043E\u0442 \u0430\u0432\u0442\u043E\u0440\u0438\u0442\u0435\u0442
    \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0435\u043F\u0440\u0435\u0440\u0435\u043A\u0430\u0435\u043C,
    \u0447\u0442\u043E \u0444\u0440\u0430\u0437\u0430 \u0441\u0442\u0430\u043B\u0430
    \u043A\u0440\u044B\u043B\u0430\u0442\u043E\u0439. \u0415\u0441\u043B\u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u0438
    \u0441\u043B\u044B\u0448\u0430\u043B\u0438 \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u043B
    \u0441\u043B\u043E\u0432\u0430\u043C \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430,
    \u043E\u043D\u0438 \u043F\u0440\u043E\u0441\u0442\u043E \u0437\u0430\u043A\u0440\u044B\u0432\u0430\u043B\u0438
    \u0433\u043B\u0430\u0437\u0430 \u0438 \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u043B\u0438:
    \xAB\u0421\u0430\u043C \u0441\u043A\u0430\u0437\u0430\u043B\xBB, \u043F\u0440\u0435\u043A\u0440\u0430\u0449\u0430\u044F
    \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u044E.  ### 3. \U0001F300 \u0424\u0430\u0441\u043E\u043B\u044C
    \u2014 \u0441\u0430\u043C\u043E\u0435 \u0441\u0442\u0440\u0430\u0448\u043D\u043E\u0435
    \u0442\u0430\u0431\u0443  \u0421\u0430\u043C\u044B\u043C \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u0438 \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u043C \u0437\u0430\u043F\u0440\u0435\u0442\u043E\u043C
    \u043F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u0435\u0432 \u0431\u044B\u043B\u043E
    \u0442\u0430\u0431\u0443 \u043D\u0430 **\u0431\u043E\u0431\u044B (\u0444\u0430\u0441\u043E\u043B\u044C)**.
    \u0417\u0430\u043F\u0440\u0435\u0442 \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0442\u0440\u043E\u0433\u0438\u043C, \u0447\u0442\u043E \u043D\u0430\u0440\u0443\u0448\u0435\u043D\u0438\u0435
    \u043A\u0430\u0440\u0430\u043B\u043E\u0441\u044C \u0441\u043C\u0435\u0440\u0442\u044C\u044E.
    \u041F\u0440\u0438\u0447\u0438\u043D (\u043F\u043E \u0432\u0435\u0440\u0441\u0438\u044F\u043C
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432) \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E,
    \u0438 \u0432\u0441\u0435 \u043E\u043D\u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B:
    *   **\u041C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F:** \u041F\u0438\u0444\u0430\u0433\u043E\u0440
    \u0432\u0435\u0440\u0438\u043B \u0432 \u043F\u0435\u0440\u0435\u0441\u0435\u043B\u0435\u043D\u0438\u0435
    \u0434\u0443\u0448 \u0438 \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E
    \u0432 \u0431\u043E\u0431\u0430\u0445 \u043C\u043E\u0433\u0443\u0442 \u043E\u0431\u0438\u0442\u0430\u0442\u044C
    \u0434\u0443\u0448\u0438 \u0443\u043C\u0435\u0440\u0448\u0438\u0445 (\u0438\u0437-\u0437\u0430
    \u043F\u043E\u043B\u043E\u0439 \u0442\u0440\u0443\u0431\u043A\u0438 \u0432\u043D\u0443\u0442\u0440\u0438
    \u0441\u0442\u0435\u0431\u043B\u044F, \u0447\u0435\u0440\u0435\u0437 \u043A\u043E\u0442\u043E\u0440\u0443\u044E,
    \u044F\u043A\u043E\u0431\u044B, \u0434\u0443\u0448\u0438 \u043F\u043E\u043F\u0430\u0434\u0430\u044E\u0442
    \u0432 \u0437\u0435\u043C\u043B\u044E). *   **\u041F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F:**
    \u0411\u043E\u0431\u044B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u0434\u043B\u044F \u0433\u043E\u043B\u043E\u0441\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432 \u0434\u0435\u043C\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u044F\u0445 (\u0431\u0435\u043B\u044B\u0435
    \u0438 \u0447\u0435\u0440\u043D\u044B\u0435 \u043A\u0430\u043C\u0435\u0448\u043A\u0438).
    \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u041F\u0438\u0444\u0430\u0433\u043E\u0440,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u043B \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u043E\u043C,
    \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B \u0434\u0435\u043C\u043E\u043A\u0440\u0430\u0442\u0438\u044E
    \u0438 \u0437\u0430\u043F\u0440\u0435\u0449\u0430\u043B \u0431\u043E\u0431\u044B
    \u043A\u0430\u043A \u0441\u0438\u043C\u0432\u043E\u043B \xAB\u0432\u043B\u0430\u0441\u0442\u0438
    \u0442\u043E\u043B\u043F\u044B\xBB. *   **\u0414\u0438\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F:**
    \u0421\u044B\u0440\u044B\u0435 \u0431\u043E\u0431\u044B \u0432\u044B\u0437\u044B\u0432\u0430\u044E\u0442
    \u043C\u0435\u0442\u0435\u043E\u0440\u0438\u0437\u043C \u0438 \u0432\u0437\u0434\u0443\u0442\u0438\u0435,
    \u0447\u0442\u043E \u043D\u0430\u0440\u0443\u0448\u0430\u043B\u043E \xAB\u0433\u0430\u0440\u043C\u043E\u043D\u0438\u044E\xBB
    \u0442\u0435\u043B\u0430 \u0438 \u0441\u0431\u0438\u0432\u0430\u043B\u043E \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u0441\u0442\u0440\u043E\u0439 \u0434\u0443\u0448\u0438. *   **\u0410\u043B\u043B\u0435\u0440\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F:**
    \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430,
    \u0447\u0442\u043E \u0443 \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430 \u0431\u044B\u043B\u0430
    \u0433\u0435\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0431\u043E\u043B\u0435\u0437\u043D\u044C
    (\u0444\u0430\u0432\u0438\u0437\u043C), \u043F\u0440\u0438 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0443\u043F\u043E\u0442\u0440\u0435\u0431\u043B\u0435\u043D\u0438\u0435 \u0431\u043E\u0431\u043E\u0432
    \u0432\u044B\u0437\u044B\u0432\u0430\u043B\u043E \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u0438\u0435
    \u044D\u0440\u0438\u0442\u0440\u043E\u0446\u0438\u0442\u043E\u0432 \u0438 \u043C\u043E\u0433\u043B\u043E
    \u0431\u044B\u0442\u044C \u0441\u043C\u0435\u0440\u0442\u0435\u043B\u044C\u043D\u044B\u043C. 
    \u041F\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435, \u0438\u043C\u0435\u043D\u043D\u043E
    \u0431\u043E\u0431\u044B \u0441\u0442\u0430\u043B\u0438 \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439
    \u0435\u0433\u043E \u0433\u0438\u0431\u0435\u043B\u0438: \u0441\u043F\u0430\u0441\u0430\u044F\u0441\u044C
    \u043E\u0442 \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439,
    \u043E\u043D \u0431\u0435\u0436\u0430\u043B \u0447\u0435\u0440\u0435\u0437 \u043F\u043E\u043B\u0435
    \u0441 \u0431\u043E\u0431\u0430\u043C\u0438, \u043D\u043E, \u0443\u0432\u0438\u0434\u0435\u0432
    \u0438\u0445, \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0441\u044F
    \u0438 \u0441\u043A\u0430\u0437\u0430\u043B: \xAB\u041B\u0443\u0447\u0448\u0435
    \u0443\u043C\u0435\u0440\u0435\u0442\u044C, \u0447\u0435\u043C \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u0442\u044C
    \u043D\u0430 \u0431\u043E\u0431\u044B\xBB, \u043F\u043E\u0441\u043B\u0435 \u0447\u0435\u0433\u043E
    \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0438\u0433\u043B\u0438 \u0432\u0440\u0430\u0433\u0438. 
    ### 4. \U0001F4D0 \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B (\u0438 \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u043E
    \u0437\u0430 \u043D\u0435\u0433\u043E)  \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u044B
    \u0431\u043E\u0433\u043E\u0442\u0432\u043E\u0440\u0438\u043B\u0438 \u0447\u0438\u0441\u043B\u0430
    \u0438 \u0432\u0435\u0440\u0438\u043B\u0438, \u0447\u0442\u043E \u0432\u0441\u0451
    \u0432 \u043C\u0438\u0440\u0435 \u043C\u043E\u0436\u043D\u043E \u0432\u044B\u0440\u0430\u0437\u0438\u0442\u044C
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435\u043C \u0446\u0435\u043B\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B (\u0434\u0440\u043E\u0431\u044F\u043C\u0438).
    \u041E\u043D\u0438 \u0431\u044B\u043B\u0438 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u044B
    \u0432 \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0438 \u0438 \xAB\u0438\u0437\u043C\u0435\u0440\u0438\u043C\u043E\u0441\u0442\u0438\xBB
    \u043C\u0438\u0440\u0430.  \u041E\u0434\u043D\u0430\u043A\u043E \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432, **\u0413\u0438\u043F\u043F\u0430\u0441
    \u041C\u0435\u0442\u0430\u043F\u043E\u043D\u0442\u0441\u043A\u0438\u0439**, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u044C
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430 \u043D\u0435\u0441\u043E\u0438\u0437\u043C\u0435\u0440\u0438\u043C\u0430
    \u0441 \u0435\u0433\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u043E\u0439 (\u0442\u043E
    \u0435\u0441\u0442\u044C \u221A2 \u2014 \u044D\u0442\u043E \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u0430\u044F
    \u043D\u0435\u043F\u0435\u0440\u0438\u043E\u0434\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0434\u0440\u043E\u0431\u044C). \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u0440\u0430\u0437\u0440\u0443\u0448\u0430\u043B\u043E \u0432\u0441\u044E \u0438\u0445
    \u043A\u0430\u0440\u0442\u0438\u043D\u0443 \u043C\u0438\u0440\u0430. \u0412\u043C\u0435\u0441\u0442\u043E
    \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B \u0440\u0430\u0434\u043E\u0432\u0430\u0442\u044C\u0441\u044F
    \u043D\u0430\u0443\u0447\u043D\u043E\u043C\u0443 \u043F\u0440\u043E\u0440\u044B\u0432\u0443,
    \u043F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u044B \u043F\u0440\u0438\u0448\u043B\u0438
    \u0432 \u0443\u0436\u0430\u0441. \u041F\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435,
    \u043E\u043D\u0438 \u0441\u0445\u0432\u0430\u0442\u0438\u043B\u0438 \u0413\u0438\u043F\u043F\u0430\u0441\u0430
    \u0438 \u0443\u0442\u043E\u043F\u0438\u043B\u0438 \u0435\u0433\u043E \u0432 \u043C\u043E\u0440\u0435,
    \u043E\u0431\u044A\u044F\u0432\u0438\u0432, \u0447\u0442\u043E \u043E\u043D \xAB\u0432\u043D\u0435\u0441
    \u0432 \u043C\u0438\u0440 \u044D\u043B\u0435\u043C\u0435\u043D\u0442 \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E,
    \u043E\u0442\u0440\u0438\u0446\u0430\u044E\u0449\u0435\u0433\u043E \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u044E\xBB,
    \u0438\u043B\u0438, \u043F\u043E \u0434\u0440\u0443\u0433\u043E\u0439 \u0432\u0435\u0440\u0441\u0438\u0438,
    \u043F\u0440\u043E\u0441\u0442\u043E \u0438\u0437\u0433\u043D\u0430\u043B\u0438
    \u0435\u0433\u043E \u0441 \u043F\u043E\u0437\u043E\u0440\u043E\u043C. \u0412\u043E\u0442
    \u0442\u0430\u043A\u0430\u044F \xAB\u043B\u044E\u0431\u043E\u0432\u044C \u043A
    \u0438\u0441\u0442\u0438\u043D\u0435\xBB.  ### 5. \U0001F9E6 \u041D\u0435\u043E\u0431\u044B\u0447\u043D\u0430\u044F
    \u0432\u043D\u0435\u0448\u043D\u043E\u0441\u0442\u044C \u0438 \xAB\u0417\u043E\u043B\u043E\u0442\u043E\u0435
    \u0431\u0435\u0434\u0440\u043E\xBB  \u0418\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044E\u0442, \u0447\u0442\u043E
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u0431\u044B\u043B \u043E\u0447\u0435\u043D\u044C
    \u044D\u0444\u0444\u0435\u043A\u0442\u043D\u044B\u043C \u043C\u0443\u0436\u0447\u0438\u043D\u043E\u0439.
    \u041E\u043D \u043D\u043E\u0441\u0438\u043B \u0434\u043B\u0438\u043D\u043D\u044B\u0435,
    \u043D\u0438\u0441\u043F\u0430\u0434\u0430\u044E\u0449\u0438\u0435 \u043E\u0434\u0435\u0436\u0434\u044B
    \u0431\u0435\u043B\u043E\u0433\u043E \u0446\u0432\u0435\u0442\u0430 (\u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0433\u0440\u0435\u043A\u043E\u0432
    \u0432 \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0445 \u0445\u0438\u0442\u043E\u043D\u0430\u0445),
    \u0447\u0442\u043E \u043F\u0440\u0438\u0434\u0430\u0432\u0430\u043B\u043E \u0435\u043C\u0443
    \u0431\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439 \u0432\u0438\u0434. 
    \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430 \u043B\u0435\u0433\u0435\u043D\u0434\u0430,
    \u0447\u0442\u043E \u0443 \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430 \u0431\u044B\u043B\u043E
    **\xAB\u0437\u043E\u043B\u043E\u0442\u043E\u0435 \u0431\u0435\u0434\u0440\u043E\xBB**.
    \u041A\u043E\u0433\u0434\u0430 \u043E\u043D \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B
    \u043D\u0430 \u041E\u043B\u0438\u043C\u043F\u0438\u0439\u0441\u043A\u0438\u0445
    \u0438\u0433\u0440\u0430\u0445 \u043F\u0435\u0440\u0435\u0434 \u0442\u043E\u043B\u043F\u043E\u0439,
    \u043E\u043D \u044F\u043A\u043E\u0431\u044B \u043F\u0440\u0438\u043F\u043E\u0434\u043D\u044F\u043B
    \u043E\u0434\u0435\u0436\u0434\u044B \u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u043B
    \u0441\u043E\u0431\u0440\u0430\u0432\u0448\u0438\u043C\u0441\u044F, \u0447\u0442\u043E
    \u0443 \u043D\u0435\u0433\u043E \u043E\u0434\u043D\u0430 \u043D\u043E\u0433\u0430
    \u043E\u0442 \u0431\u0435\u0434\u0440\u0430 \u0441\u0434\u0435\u043B\u0430\u043D\u0430
    \u0438\u0437 \u0447\u0438\u0441\u0442\u043E\u0433\u043E \u0437\u043E\u043B\u043E\u0442\u0430.
    \u042D\u0442\u043E \u0434\u043E\u043B\u0436\u043D\u043E \u0431\u044B\u043B\u043E
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u0442\u044C \u0435\u0433\u043E
    \u0431\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    (\u0441\u0432\u044F\u0437\u044C \u0441 \u0410\u043F\u043E\u043B\u043B\u043E\u043D\u043E\u043C).
    \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u0441\u0447\u0438\u0442\u0430\u044E\u0442, \u0447\u0442\u043E \u044D\u0442\u043E
    \u0431\u044B\u043B\u0430 \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0435\u0430\u0442\u0440\u0430\u043B\u044C\u043D\u0430\u044F
    \u0443\u043B\u043E\u0432\u043A\u0430 \u0441 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043F\u043E\u0437\u043E\u043B\u043E\u0447\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0442\u0435\u0437\u0430 \u0438\u043B\u0438 \u043C\u0435\u0442\u0430\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043B\u0430\u0441\u0442\u0438\u043D\u044B, \u0432\u0448\u0438\u0442\u043E\u0439
    \u043F\u043E\u0434 \u043A\u043E\u0436\u0443.  ### 6. \U0001F9E0 \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u0430\u044F
    \u043F\u0430\u043C\u044F\u0442\u044C \u0438 \u043F\u0440\u043E\u0448\u043B\u044B\u0435
    \u0436\u0438\u0437\u043D\u0438  \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u0432\u0435\u0440\u0438\u043B
    \u0432 \u043F\u0435\u0440\u0435\u0441\u0435\u043B\u0435\u043D\u0438\u0435 \u0434\u0443\u0448
    (\u043C\u0435\u0442\u0435\u043C\u043F\u0441\u0438\u0445\u043E\u0437) \u0438 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E **\u043F\u043E\u043C\u043D\u0438\u0442 \u0432\u0441\u0435
    \u0441\u0432\u043E\u0438 \u043F\u0440\u0435\u0434\u044B\u0434\u0443\u0449\u0438\u0435
    \u0436\u0438\u0437\u043D\u0438**. \u041E\u043D \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B
    \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C, \u0447\u0442\u043E \u0431\u044B\u043B:
    1.  \u0421\u044B\u043D\u043E\u043C \u0413\u0435\u0440\u043C\u0435\u0441\u0430
    \u043F\u043E \u0438\u043C\u0435\u043D\u0438 \u042D\u0444\u0430\u043B\u0438\u0434,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043C\u043E\u0433 \u0437\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u0442\u044C
    \u0432\u0441\u0451 \u043D\u0430 \u0441\u0432\u0435\u0442\u0435. 2.  \u0422\u0440\u043E\u044F\u043D\u0441\u043A\u0438\u043C
    \u0433\u0435\u0440\u043E\u0435\u043C \u0415\u0432\u0444\u043E\u0440\u0431\u043E\u043C
    (\u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0443\u0431\u0438\u043B\u0438
    \u043F\u043E\u0434 \u0441\u0442\u0435\u043D\u0430\u043C\u0438 \u0422\u0440\u043E\u0438).
    3.  \u0420\u044B\u0431\u0430\u043A\u043E\u043C \u043F\u043E \u0438\u043C\u0435\u043D\u0438
    \u041F\u0438\u0440\u0440. 4.  \u041A\u0440\u0430\u0441\u0430\u0432\u0438\u0446\u0435\u0439
    \u043F\u043E \u0438\u043C\u0435\u043D\u0438 \u0410\u043B\u0435\u0442\u0430. \u0427\u0442\u043E\u0431\u044B
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435,
    \u043E\u043D \u044F\u043A\u043E\u0431\u044B \u0437\u0430\u0448\u0435\u043B \u0432
    \u0445\u0440\u0430\u043C \u0413\u0435\u0440\u044B \u0432 \u0410\u0440\u0433\u043E\u0441\u0435
    \u0438 \u0443\u0437\u043D\u0430\u043B \u0441\u0432\u043E\u0439 \u0441\u0442\u0430\u0440\u044B\u0439
    \u0449\u0438\u0442, \u0432\u0438\u0441\u0435\u0432\u0448\u0438\u0439 \u0442\u0430\u043C
    \u0435\u0449\u0435 \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D \u0422\u0440\u043E\u044F\u043D\u0441\u043A\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u2014 \u043D\u0430 \u043D\u0435\u043C \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C
    \u043D\u0430\u0434\u043F\u0438\u0441\u044C \u0441 \u0438\u043C\u0435\u043D\u0435\u043C
    \u0415\u0432\u0444\u043E\u0440\u0431\u0430.  ### 7. \U0001F4A7 \u0417\u043E\u043B\u043E\u0442\u0430\u044F
    \u0447\u0430\u0448\u0430 \u0438 \u0433\u0438\u0433\u0438\u0435\u043D\u0430  \u041E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u0432 \u043F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u0435\u0432
    \u0431\u044B\u043B\u0430 **\xAB\u0417\u043E\u043B\u043E\u0442\u0430\u044F \u0447\u0430\u0448\u0430\xBB**.
    \u041D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435 \u044D\u0442\u043E
    \u0431\u044B\u043B\u0430 \u043D\u0435 \u0447\u0430\u0448\u0430, \u0430 \u0431\u0440\u043E\u043D\u0437\u043E\u0432\u044B\u0439
    \u0441\u043E\u0441\u0443\u0434, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0430\u0432\u0438\u043B\u0438
    \u043D\u0430 \u043F\u0435\u0440\u0435\u043A\u0440\u0435\u0441\u0442\u043A\u0430\u0445.
    \u0421\u0443\u0442\u044C \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C
    \u0432 \u043D\u0435\u043C \u0432\u043E\u0434\u0443 \u043C\u043E\u0433\u043B\u0438
    \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0435, \u043A\u0442\u043E \u0442\u043E\u0447\u043D\u043E
    \u0437\u043D\u0430\u043B \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u043E\u0431\u044A\u0435\u043C\u0430.  \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0441\u043F\u043E\u0441\u043E\u0431 \u0431\u043E\u0440\u043E\u0442\u044C\u0441\u044F
    \u0441 \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u044F\u043C\u0438 (\u0434\u043E\u0433\u0430\u0434\u0430\u0432\u0448\u0438\u0441\u044C
    \u043E\u0431 \u0438\u0445 \u0437\u0430\u0440\u0430\u0437\u043D\u043E\u0439 \u043F\u0440\u0438\u0440\u043E\u0434\u0435).
    \u041E\u043D \u043F\u0440\u0438\u043A\u0430\u0437\u044B\u0432\u0430\u043B \u0436\u0438\u0442\u0435\u043B\u044F\u043C
    \u0433\u043E\u0440\u043E\u0434\u0430 \u0432\u044B\u0445\u043E\u0434\u0438\u0442\u044C
    \u043D\u0430 \u0443\u043B\u0438\u0446\u044B \u0441 \u0432\u0435\u0442\u043A\u0430\u043C\u0438
    \u043B\u0430\u0432\u0440\u0430 \u0438 \xAB\u043E\u0447\u0438\u0449\u0430\u0442\u044C
    \u0432\u043E\u0437\u0434\u0443\u0445\xBB \u043F\u043E\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u043E\u043C
    \u0445\u043E\u0440\u043E\u0432\u043E\u0433\u043E \u043F\u0435\u043D\u0438\u044F
    \u0438 \u043C\u0443\u0437\u044B\u043A\u0438, \u0447\u0442\u043E \u043D\u0430
    \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435 \u043F\u043E\u043C\u043E\u0433\u0430\u043B\u043E
    \u0440\u0430\u0441\u043F\u044B\u043B\u044F\u0442\u044C \u0444\u0438\u0442\u043E\u043D\u0446\u0438\u0434\u044B
    \u0438 \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u0442\u044C \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043A\u043E\u043C\u0444\u043E\u0440\u0442.  ### 8. \U0001F6AB \u041F\u0435\u0440\u0432\u044B\u0439
    \u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0435\u0446 \u0438
    \u0432\u0435\u0433\u0430\u043D\u0441\u043A\u0438\u0435 \xAB\u043D\u043E\u0443-\u0445\u0430\u0443\xBB 
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0446\u0435\u043C.
    \u041D\u043E \u0435\u0433\u043E \u043F\u043E\u0434\u0445\u043E\u0434 \u0431\u044B\u043B
    \u0438\u0437\u0431\u0438\u0440\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C:
    \u043E\u043D \u0437\u0430\u043F\u0440\u0435\u0449\u0430\u043B \u0435\u0441\u0442\u044C
    \u043C\u044F\u0441\u043E \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445, \u0442\u0430\u043A
    \u043A\u0430\u043A \u0432 \u043D\u0438\u0445 \u043C\u043E\u0433\u0443\u0442 \u0436\u0438\u0442\u044C
    \u0434\u0443\u0448\u0438 \u043B\u044E\u0434\u0435\u0439, \u043D\u043E \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C \u043E\u043D \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B
    \u0443\u043F\u043E\u0442\u0440\u0435\u0431\u043B\u044F\u0442\u044C \u0432 \u043F\u0438\u0449\u0443
    \u0440\u044B\u0431\u0443 \u0438 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043F\u0442\u0438\u0446 (\u0438\u0441\u043A\u043B\u044E\u0447\u0430\u044F \u043E\u0440\u043B\u043E\u0432,
    \u043F\u0447\u0435\u043B \u0438 \u0434\u0435\u043B\u044C\u0444\u0438\u043D\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435, \u043F\u043E \u0435\u0433\u043E \u043C\u043D\u0435\u043D\u0438\u044E,
    \u0442\u043E\u0436\u0435 \u0431\u044B\u043B\u0438 \u043B\u044E\u0434\u044C\u043C\u0438
    \u0432 \u043F\u0440\u043E\u0448\u043B\u043E\u0439 \u0436\u0438\u0437\u043D\u0438). 
    \u041A\u0441\u0442\u0430\u0442\u0438, \u0438\u043C\u0435\u043D\u043D\u043E \u043F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0446\u044B
    \u043F\u0435\u0440\u0432\u044B\u043C\u0438 \u043D\u0430\u0447\u0430\u043B\u0438
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0438\u0442\u044C **\xAB\u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \u043C\u044F\u0441\u043E\xBB** \u0438\u0437 \u043F\u0448\u0435\u043D\u0438\u0446\u044B
    \u0438 \u0431\u043E\u0431\u043E\u0432, \u043F\u043E\u0434\u0436\u0430\u0440\u0438\u0432\u0430\u044F
    \u0438\u0445 \u0434\u043E \u0445\u0440\u0443\u0441\u0442\u044F\u0449\u0435\u0439
    \u043A\u043E\u0440\u043E\u0447\u043A\u0438, \u0447\u0442\u043E\u0431\u044B \u0437\u0430\u043C\u0435\u043D\u0438\u0442\u044C
    \u0436\u0435\u0440\u0442\u0432\u0435\u043D\u043D\u044B\u0445 \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445,
    \u0442\u0430\u043A \u043A\u0430\u043A \u043F\u0440\u0438\u043D\u043E\u0441\u0438\u0442\u044C
    \u043A\u0440\u043E\u0432\u0430\u0432\u044B\u0435 \u0436\u0435\u0440\u0442\u0432\u044B
    \u0431\u043E\u0433\u0430\u043C \u043E\u043D\u0438 \u0441\u0447\u0438\u0442\u0430\u043B\u0438
    \u0432\u0430\u0440\u0432\u0430\u0440\u0441\u0442\u0432\u043E\u043C.  ### 9. \U0001F3B5
    \u041B\u0435\u0447\u0435\u043D\u0438\u0435 \u043C\u0443\u0437\u044B\u043A\u043E\u0439
    (\xAB\u041C\u0443\u0437\u044B\u043A\u043E\u0442\u0435\u0440\u0430\u043F\u0438\u044F\xBB) 
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u043B\u0435\u0447\u0438\u043B \u0431\u043E\u043B\u0435\u0437\u043D\u0438
    \u0434\u0443\u0448\u0438 \u0438 \u0442\u0435\u043B\u0430 \u043C\u0443\u0437\u044B\u043A\u043E\u0439.
    \u041E\u043D \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u0441\u043E\u0447\u0438\u043D\u044F\u043B
    \u043C\u0435\u043B\u043E\u0434\u0438\u0438 \u043F\u0440\u043E\u0442\u0438\u0432
    \u044F\u0440\u043E\u0441\u0442\u0438 \u0438 \u0433\u043D\u0435\u0432\u0430, \u0430
    \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u043E\u0442\u0438\u0432 \u0441\u0442\u0440\u0430\u0441\u0442\u0435\u0439.
    \u0423\u0442\u0440\u043E\u043C \u043E\u043D \u043F\u0440\u0438\u043A\u0430\u0437\u044B\u0432\u0430\u043B
    \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C \u043F\u0435\u0442\u044C \u0431\u043E\u0434\u0440\u044B\u0435,
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u043C\u0435\u043B\u043E\u0434\u0438\u0438,
    \u0447\u0442\u043E\u0431\u044B \u0441\u0442\u0438\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0443\u043C, \u0430 \u0432\u0435\u0447\u0435\u0440\u043E\u043C \u2014 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u044B\u0435,
    \u0443\u0431\u0430\u044E\u043A\u0438\u0432\u0430\u044E\u0449\u0438\u0435, \u0447\u0442\u043E\u0431\u044B
    \u043E\u0447\u0438\u0441\u0442\u0438\u0442\u044C \u0441\u043E\u0437\u043D\u0430\u043D\u0438\u0435
    \u043E\u0442 \u0434\u043D\u0435\u0432\u043D\u044B\u0445 \u0432\u043E\u043B\u043D\u0435\u043D\u0438\u0439.
    \u0413\u043E\u0432\u043E\u0440\u044F\u0442, \u0447\u0442\u043E \u043E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043E\u043D \u043B\u0438\u0447\u043D\u043E \u0443\u0441\u043C\u0438\u0440\u0438\u043B
    \u043F\u044C\u044F\u043D\u043E\u0433\u043E \u0431\u0443\u044F\u043D\u0430, \u043F\u0440\u043E\u0441\u0442\u043E
    \u0441\u043C\u0435\u043D\u0438\u0432 \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u043B\u0430\u0434 (\u0444\u043B\u0435\u0439\u0442\u0443) \u0432 \u0434\u043E\u043C\u0435,
    \u0433\u0434\u0435 \u0442\u043E\u0442 \u043F\u0438\u0440\u043E\u0432\u0430\u043B. 
    ### 10. \U0001F480 \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F \u0448\u0443\u0442\u043A\u0430
    \u0438\u043B\u0438 \u043F\u0440\u043E\u043A\u043B\u044F\u0442\u0438\u0435  \u0414\u0438\u043E\u0433\u0435\u043D
    \u041B\u0430\u044D\u0440\u0442\u0441\u043A\u0438\u0439 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0437\u0430\u043F\u0438\u0441\u044C \u043E \u0442\u043E\u043C, \u043A\u0430\u043A
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440 \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0441\u044F
    \u043A \u0441\u043C\u0435\u0440\u0442\u0438. \u041A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E
    \u0441\u043F\u0440\u043E\u0441\u0438\u043B\u0438, \u0447\u0442\u043E \u043B\u0443\u0447\u0448\u0435
    \u0434\u043B\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u043F\u043E\u0441\u043B\u0435
    \u0436\u0438\u0437\u043D\u0438, \u043E\u043D \u043E\u0442\u0432\u0435\u0442\u0438\u043B:
    **\xAB\u041D\u0435 \u0437\u0430\u0434\u0430\u0432\u0430\u0439 \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u0432
    \u043E \u0442\u043E\u043C, \u043E \u0447\u0435\u043C \u0443 \u0442\u0435\u0431\u044F
    \u043D\u0435\u0442 \u0434\u0430\u0436\u0435 \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u0432\xBB**. 
    \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0439
    \u043A\u0443\u0440\u044C\u0435\u0437, \u0447\u0442\u043E \u043F\u0435\u0440\u0435\u0434
    \u0441\u043C\u0435\u0440\u0442\u044C\u044E (\u043F\u043E \u0432\u0435\u0440\u0441\u0438\u0438
    \u043C\u0438\u0440\u043D\u043E\u0439 \u043A\u043E\u043D\u0447\u0438\u043D\u044B)
    \u043E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0435
    \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C, \u0433\u0434\u0435 \u043F\u0440\u043E\u0441\u0438\u043B
    \u0438\u0445 \u043A\u043E\u0440\u043C\u0438\u0442\u044C \u0435\u0433\u043E \u043A\u043E\u0442\u0430
    \u0438 \u043A\u0443\u043F\u0438\u0442\u044C \u043D\u043E\u0432\u044B\u0439 \u0445\u0438\u0442\u043E\u043D,
    \u0442\u0430\u043A \u043A\u0430\u043A \u0441\u0442\u0430\u0440\u044B\u0439 \xAB\u0438\u0437\u043D\u043E\u0441\u0438\u043B\u0441\u044F\xBB.
    \u042D\u0442\u043E \u0441\u0442\u0440\u0430\u043D\u043D\u0430\u044F \u043C\u0435\u043B\u043E\u0447\u044C
    \u043D\u0430 \u0444\u043E\u043D\u0435 \u0435\u0433\u043E \u0432\u0435\u043B\u0438\u0447\u0438\u044F
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442, \u0447\u0442\u043E
    \u0434\u0430\u0436\u0435 \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0441 \u0431\u044B\u0442\u043E\u0432\u044B\u043C\u0438 \u0437\u0430\u0431\u043E\u0442\u0430\u043C\u0438."
