  achievementsRu: "\u0412\u043A\u043B\u0430\u0434 \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \u0432 \u043D\u0430\u0443\u043A\u0443 \u043E\u0433\u0440\u043E\u043C\u0435\u043D
    \u0438 \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u0444\u0438\u0437\u0438\u043A\u0438. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F, \u0430 \u0446\u0435\u043B\u044B\u0435
    \u0437\u0434\u0430\u043D\u0438\u044F \u0437\u043D\u0430\u043D\u0438\u0439, \u043D\u0430
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u0442\u0440\u043E\u0438\u043B\u0438
    \u0441\u0432\u043E\u0438 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0435 \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F
    \u0443\u0447\u0451\u043D\u044B\u0445.  \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u044B
    \u0435\u0433\u043E \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F,
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u043F\u043E \u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F\u043C.  ###
    \U0001F522 \u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B 
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043F\u0440\u043E\u0434\u0432\u0438\u043D\u0443\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u0447\u0438\u0441\u0435\u043B, \u0441\u0434\u0435\u043B\u0430\u0432
    \u0435\u0451 \u0431\u043E\u043B\u0435\u0435 \u0441\u0442\u0440\u043E\u0433\u043E\u0439
    \u0438 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u0439 \u0434\u043B\u044F
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F.  *   **\u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434**: \u0415\u0433\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 **\xAB\u041E\u043F\u044B\u0442 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B\xBB (Essai sur la th\xE9orie des nombres**, 1798),
    \u043F\u043E\u0437\u0436\u0435 \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u043D\u0430\u044F
    \u0432 \u0434\u0432\u0443\u0445\u0442\u043E\u043C\u043D\u0438\u043A **\xAB\u0422\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B\xBB (Th\xE9orie des nombres**, 1830), \u0441\u0442\u0430\u043B\u0430
    \u043F\u0435\u0440\u0432\u043E\u0439 \u0432\u0441\u0435\u043E\u0431\u044A\u0435\u043C\u043B\u044E\u0449\u0435\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u0435\u0439
    \u0437\u043D\u0430\u043D\u0438\u0439 \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438.
    *   **\u041A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0439
    \u0437\u0430\u043A\u043E\u043D \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438**:
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E\u0442 \u043A\u043B\u044E\u0447\u0435\u0432\u043E\u0439 \u0437\u0430\u043A\u043E\u043D
    \u0438 \u0432\u0432\u0451\u043B \u0434\u043B\u044F \u0435\u0433\u043E \u0443\u0434\u043E\u0431\u043D\u043E\u0433\u043E
    \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F **\u0441\u0438\u043C\u0432\u043E\u043B
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430**. \u0425\u043E\u0442\u044F
    \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u0434\u0430\u043B
    \u0413\u0430\u0443\u0441\u0441, \u0440\u0430\u0431\u043E\u0442\u0430 \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. *  
    **\u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430 \u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B**:
    \u0412 1798 \u0433\u043E\u0434\u0443 \u043E\u043D \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B
    \u0441\u043C\u0435\u043B\u0443\u044E \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u043E\u0431 \u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0437\u0430\u043A\u043E\u043D\u0435 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u0441\u0442\u0440\u043E\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u0430
    \u043B\u0438\u0448\u044C \u0441\u043F\u0443\u0441\u0442\u044F \u043F\u043E\u0447\u0442\u0438
    100 \u043B\u0435\u0442, \u0432 1896 \u0433\u043E\u0434\u0443. *   **\u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0434\u043B\u044F n=5**: \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0443 \u0443\u0434\u0430\u043B\u043E\u0441\u044C
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u043D\u0435\u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0441\u0442\u044C
    \u0412\u0435\u043B\u0438\u043A\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u0424\u0435\u0440\u043C\u0430 \u0434\u043B\u044F \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044F
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438 n=5 (\u044D\u0442\u043E \u0436\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0438 \u0414\u0438\u0440\u0438\u0445\u043B\u0435).  ### \U0001F4D0 \u042D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044B \u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u0438 
    \u042D\u0442\u043E \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0441\u0442\u0430\u043B\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u0434\u0435\u043B\u043E\u043C
    \u0436\u0438\u0437\u043D\u0438 \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \u0438 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u043E \u0435\u043C\u0443 \u043C\u0438\u0440\u043E\u0432\u0443\u044E
    \u0441\u043B\u0430\u0432\u0443.  *   **\u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434**: \u0415\u0433\u043E \u0442\u0440\u0451\u0445\u0442\u043E\u043C\u043D\u044B\u0439
    **\xAB\u0422\u0440\u0430\u043A\u0442\u0430\u0442 \u043E\u0431 \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u0445\xBB (Trait\xE9 des fonctions
    elliptiques**, 1825\u20131832) \u0441\u0442\u0430\u043B \u043A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u0435\u0439
    \u0435\u0433\u043E \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0438\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. *  
    **\u041A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044F**:
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u043F\u0440\u043E\u0434\u0435\u043B\u0430\u043B
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    \u043F\u043E \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0438
    \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u0432, \u0441\u0432\u0435\u0434\u044F
    \u0438\u0445 \u043A \u0442\u0440\u0451\u043C \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u043C
    \u0444\u043E\u0440\u043C\u0430\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u043D\u043E\u0441\u044F\u0442 \u0435\u0433\u043E
    \u0438\u043C\u044F. \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0435 \u0442\u0430\u0431\u043B\u0438\u0446\u044B
    \u0438\u0445 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439. *   **\u0418\u0440\u043E\u043D\u0438\u044F
    \u0441\u0443\u0434\u044C\u0431\u044B**: \u041F\u043E\u0447\u0442\u0438 \u0441\u0440\u0430\u0437\u0443
    \u043F\u043E\u0441\u043B\u0435 \u0432\u044B\u0445\u043E\u0434\u0430 \u0435\u0433\u043E
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0430, \u0440\u0430\u0431\u043E\u0442\u044B
    \u043C\u043E\u043B\u043E\u0434\u044B\u0445 \u0433\u0435\u043D\u0438\u0435\u0432
    \u2014 \u0410\u0431\u0435\u043B\u044F \u0438 \u042F\u043A\u043E\u0431\u0438 \u2014
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0438 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438, \u043F\u0435\u0440\u0435\u0439\u0434\u044F
    \u043A \u043E\u0431\u0440\u0430\u0442\u043D\u044B\u043C \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C
    (\u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C
    \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0438). \u041E\u0434\u043D\u0430\u043A\u043E
    \u0438\u043C\u0435\u043D\u043D\u043E \u0442\u0440\u0443\u0434\u044B \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \u0441\u0442\u0430\u043B\u0438 \u0442\u0435\u043C \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u043E\u043D\u0438 \u0441\u0442\u0440\u043E\u0438\u043B\u0438
    \u0441\u0432\u043E\u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F.  ###
    \U0001F4C8 \u041C\u0435\u0442\u043E\u0434 \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0438\u0445
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432  *   **\u041F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F
    \u0438 \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442**: \u0412 1806
    \u0433\u043E\u0434\u0443 \u0432 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u043A \u0441\u0432\u043E\u0435\u0439 \u043A\u043D\u0438\u0433\u0435 \u043E \u043A\u043E\u043C\u0435\u0442\u043D\u044B\u0445
    \u043E\u0440\u0431\u0438\u0442\u0430\u0445 (\xABNouvelles m\xE9thodes pour la
    d\xE9termination des orbites des com\xE8tes\xBB) \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    **\u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B**
    \u043C\u0435\u0442\u043E\u0434 \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0438\u0445
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432, \u043D\u0430\u0437\u0432\u0430\u0432
    \u0435\u0433\u043E \xABm\xE9thode des moindres carr\xE9s\xBB. \u042D\u0442\u043E\u0442
    \u043C\u0435\u0442\u043E\u0434 \u0441\u0442\u0430\u043B \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C
    \u043A\u0430\u043C\u043D\u0435\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0438, \u0440\u0435\u0433\u0440\u0435\u0441\u0441\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u0438 \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0438
    \u0441\u0438\u0433\u043D\u0430\u043B\u043E\u0432. *   **\u0421\u043F\u043E\u0440
    \u0441 \u0413\u0430\u0443\u0441\u0441\u043E\u043C**: \u041F\u043E\u0437\u0436\u0435
    \u0413\u0430\u0443\u0441\u0441 \u0437\u0430\u044F\u0432\u0438\u043B, \u0447\u0442\u043E
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u044D\u0442\u043E\u0442
    \u043C\u0435\u0442\u043E\u0434 \u0435\u0449\u0451 \u0432 1795 \u0433\u043E\u0434\u0443,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u043C\u0443
    \u0441\u043F\u043E\u0440\u0443 \u043E \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0435.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u0434\u0430\u043B \u043C\u0435\u0442\u043E\u0434\u0443 \u0438\u043C\u044F \u0438
    \u0432\u0432\u0451\u043B \u0435\u0433\u043E \u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u043E\u0431\u0438\u0445\u043E\u0434.  ### \U0001F9D1\u200D\U0001F3EB \u041F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435
    \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F  *   **\xAB\u041D\u0430\u0447\u0430\u043B\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB**: \u0415\u0433\u043E
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A **\xAB\u041D\u0430\u0447\u0430\u043B\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB (\xC9l\xE9ments de
    g\xE9om\xE9trie**, 1794) \u0441\u0442\u0430\u043B \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u043C \u043F\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0432 \u043C\u0438\u0440\u0435 \u043D\u0430 \u0446\u0435\u043B\u043E\u0435 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0435.
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0438 \u0443\u043F\u0440\u043E\u0441\u0442\u0438\u043B \u0442\u0440\u0443\u0434\u044B
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430, \u0441\u0434\u0435\u043B\u0430\u0432
    \u0438\u0445 \u0431\u043E\u043B\u0435\u0435 \u043B\u043E\u0433\u0438\u0447\u043D\u044B\u043C\u0438
    \u0438 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u043C\u0438 \u0434\u043B\u044F
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432. \u0412 \u0421\u0428\u0410
    \u044D\u0442\u043E\u0442 \u0443\u0447\u0435\u0431\u043D\u0438\u043A \u0432\u044B\u0434\u0435\u0440\u0436\u0430\u043B
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u043E\u0432,
    \u043E\u0434\u0438\u043D \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u2014 33 \u0438\u0437\u0434\u0430\u043D\u0438\u044F.  ### \U0001F9F2 \u0421\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u0438\u0437\u0438\u043A\u0430  \u0420\u0430\u0431\u043E\u0442\u044B \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0441\u0442\u0430\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0437\u0430\u0434\u0430\u0447 \u0432 \u0444\u0438\u0437\u0438\u043A\u0435 \u0438
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0438\u0438.  *   **\u041C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u044B
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430**: \u0412\u0432\u0435\u0434\u0451\u043D\u043D\u044B\u0435
    \u0432 1784 \u0433\u043E\u0434\u0443 \u043F\u0440\u0438 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0438
    \u043F\u0440\u0438\u0442\u044F\u0436\u0435\u043D\u0438\u044F \u0441\u0444\u0435\u0440\u043E\u0438\u0434\u043E\u0432,
    \u043E\u043D\u0438 \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F\u043C\u0438
    \u0432\u0430\u0436\u043D\u043E\u0433\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F. \u0421\u0435\u0433\u043E\u0434\u043D\u044F
    \u043E\u043D\u0438 \u0448\u0438\u0440\u043E\u043A\u043E \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u044E\u0442\u0441\u044F
    \u0432 \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u043A\u0435,
    \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435
    (\u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0428\u0440\u0451\u0434\u0438\u043D\u0433\u0435\u0440\u0430
    \u0434\u043B\u044F \u0430\u0442\u043E\u043C\u0430 \u0432\u043E\u0434\u043E\u0440\u043E\u0434\u0430)
    \u0438 \u0432 \u0441\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u0435\u0442\u043E\u0434\u0430\u0445 \u0434\u043B\u044F \u0447\u0438\u0441\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439.
    *   **\u041F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430**: \u042D\u0442\u043E\u0442
    \u043C\u043E\u0449\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0438\u0442\u044C \u043E\u0442 \u043E\u0434\u043D\u0438\u0445
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 \u043A \u0434\u0440\u0443\u0433\u0438\u043C
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043E\u0442 \u043B\u0430\u0433\u0440\u0430\u043D\u0436\u0438\u0430\u043D\u0430
    \u043A \u0433\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0438\u0430\u043D\u0443
    \u0432 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435) \u0438 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0449\u0438\u043C
    \u0432 \u0442\u0435\u0440\u043C\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435
    \u0434\u043B\u044F \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u0442\u0430\u043A\u0438\u0445 \u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B\u043E\u0432,
    \u043A\u0430\u043A \u044D\u043D\u0442\u0430\u043B\u044C\u043F\u0438\u044F, \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u0430\u044F
    \u044D\u043D\u0435\u0440\u0433\u0438\u044F \u0413\u0435\u043B\u044C\u043C\u0433\u043E\u043B\u044C\u0446\u0430
    \u0438 \u044D\u043D\u0435\u0440\u0433\u0438\u044F \u0413\u0438\u0431\u0431\u0441\u0430."
  achievementsEn: 
  personalLifeRu: "\u0410\u0434\u0440\u0438\u0435\u043D \u041C\u0430\u0440\u0438
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u043F\u0440\u043E\u0436\u0438\u043B
    \u0434\u043E\u043B\u0433\u0443\u044E \u0436\u0438\u0437\u043D\u044C, \u0432\u043D\u0435\u0448\u043D\u0435
    \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u0443\u044E, \u043D\u043E \u043F\u043E\u043B\u043D\u0443\u044E
    \u0441\u043A\u0440\u044B\u0442\u044B\u0445 \u0434\u0440\u0430\u043C \u2014 \u043E\u0442
    \u043F\u043E\u0442\u0435\u0440\u0438 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438
    \u0434\u043E \u0433\u043E\u0440\u0435\u0447\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0441\u043F\u043E\u0440\u043E\u0432.  ### \U0001F4DC \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435,
    \u0441\u0435\u043C\u044C\u044F \u0438 \u0443\u0447\u0451\u0431\u0430  \u0410\u0434\u0440\u0438\u0435\u043D
    \u041C\u0430\u0440\u0438 \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    18 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F 1752 \u0433\u043E\u0434\u0430
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u0432 \u0431\u043E\u0433\u0430\u0442\u043E\u0439
    \u0441\u0435\u043C\u044C\u0435, \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E
    \u0435\u043C\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435. \u041E\u043D
    \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439
    \u041A\u043E\u043B\u043B\u0435\u0436 \u041C\u0430\u0437\u0430\u0440\u0438\u043D\u0438
    (Coll\xE8ge Mazarin) \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u0438 \u0432
    1770 \u0433\u043E\u0434\u0443 \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u043F\u043E \u0444\u0438\u0437\u0438\u043A\u0435 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u0421 \u044D\u0442\u043E\u0433\u043E \u043C\u043E\u043C\u0435\u043D\u0442\u0430
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430 \u043D\u0435\u0440\u0430\u0437\u0440\u044B\u0432\u043D\u043E
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441 \u043D\u0430\u0443\u043A\u043E\u0439. 
    ### \U0001F468\u200D\U0001F3EB \u041D\u0430\u0447\u0430\u043B\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B
    \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C  \u0412
    1775 \u0433\u043E\u0434\u0443 \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u043D\u0430\u0447\u0430\u043B
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0432 \u0412\u043E\u0435\u043D\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u0435
    (\xC9cole Militaire) \u0432 \u041F\u0430\u0440\u0438\u0436\u0435, \u0433\u0434\u0435
    \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0434\u043E 1780
    \u0433\u043E\u0434\u0430. \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0441\u0442\u0430\u043B \u0441\u0442\u0430\u0440\u0442\u043E\u043C \u0435\u0433\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B. \u0412 1783 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A, \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0432\u0430\u0436\u043D\u044B\u043C
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435\u043C \u0435\u0433\u043E
    \u0442\u0430\u043B\u0430\u043D\u0442\u0430.  \u0412 1795 \u0433\u043E\u0434\u0443,
    \u043F\u043E\u0441\u043B\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u041D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u044B,
    \u043E\u043D \u0441\u0442\u0430\u043B \u0442\u0430\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C.
    \u0412 1799 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u043C\u0435\u043D\u0438\u043B
    \u041F\u044C\u0435\u0440\u0430-\u0421\u0438\u043C\u043E\u043D\u0430 \u041B\u0430\u043F\u043B\u0430\u0441\u0430
    \u043D\u0430 \u043F\u043E\u0441\u0442\u0443 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0430\u0442\u043E\u0440\u0430
    \u0432 \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435, \u0430 \u0432 1816 \u0433\u043E\u0434\u0443 \u0441\u0442\u0430\u043B
    \u0442\u0430\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B \u0441\u0432\u044F\u0437\u0430\u043D
    \u0441 \u0411\u044E\u0440\u043E \u0434\u043E\u043B\u0433\u043E\u0442 (Bureau
    des Longitudes).  ### \U0001F5FA\uFE0F \u041F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u0438 \u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C  \u0412 \u0433\u043E\u0434\u044B \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438 \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0435
    \u0443\u0447\u0430\u0441\u0442\u0438\u0435 \u0432 \u0440\u0430\u0431\u043E\u0442\u0435
    \u041A\u043E\u043C\u0438\u0441\u0441\u0438\u0438 \u043F\u043E \u0432\u0432\u0435\u0434\u0435\u043D\u0438\u044E
    \u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B,
    \u0437\u0430\u043D\u0438\u043C\u0430\u044F\u0441\u044C \u0442\u043E\u0447\u043D\u044B\u043C\u0438
    \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F\u043C\u0438. \u0412 1787
    \u0433\u043E\u0434\u0443 \u043E\u043D \u0432\u043C\u0435\u0441\u0442\u0435 \u0441
    \u041A\u0430\u0441\u0441\u0438\u043D\u0438 \u0438 \u041C\u0435\u0448\u0435\u043D\u043E\u043C
    \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B \u0442\u0440\u0438\u0430\u043D\u0433\u0443\u043B\u044F\u0446\u0438\u044E
    \u0434\u043B\u044F \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0438 \u0413\u0440\u0438\u043D\u0432\u0438\u0447\u0441\u043A\u043E\u0439
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0439 \u0438
    \u0434\u0430\u0436\u0435 \u043F\u043E\u0441\u0435\u0442\u0438\u043B \u0423\u0438\u043B\u044C\u044F\u043C\u0430
    \u0413\u0435\u0440\u0448\u0435\u043B\u044F.  \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430 \u0435\u043C\u0443 \u0438 \u043B\u0438\u0447\u043D\u044B\u0435
    \u043F\u043E\u0442\u0440\u044F\u0441\u0435\u043D\u0438\u044F. \u0412 1793 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u0442\u0435\u0440\u044F\u043B \u0441\u0432\u043E\u0451
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435. \u0412 \u0442\u043E\u043C
    \u0436\u0435 \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u041C\u0430\u0440\u0433\u0430\u0440\u0438\u0442\u0435-\u041A\u043B\u043E\u0434\u0438\u043D
    \u041A\u0443\u044D\u043D, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u043C\u043E\u0433\u043B\u0430
    \u0435\u043C\u0443 \u043D\u0430\u043B\u0430\u0434\u0438\u0442\u044C \u0436\u0438\u0437\u043D\u044C. 
    ### \U0001F58B\uFE0F \u0412\u0437\u0430\u0438\u043C\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0451\u043D\u044B\u043C\u0438 
    \u042D\u0442\u043E \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438, \u043F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u043E\u0435 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u043E\u0435.
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430 \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \"\u0437\u043B\u043E\u0439 \u0440\u043E\u043A\" \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u043D\u044B\u0445
    \u0441\u043F\u043E\u0440\u043E\u0432.  *   **\u041A\u0430\u0440\u043B \u0424\u0440\u0438\u0434\u0440\u0438\u0445
    \u0413\u0430\u0443\u0441\u0441**: \u0421\u0430\u043C\u044B\u0439 \u043E\u0441\u0442\u0440\u044B\u0439
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u0440\u0430\u0437\u0433\u043E\u0440\u0435\u043B\u0441\u044F
    \u0432\u043E\u043A\u0440\u0443\u0433 **\u043C\u0435\u0442\u043E\u0434\u0430 \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0438\u0445
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432**. \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u043F\u0435\u0440\u0432\u044B\u043C \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434 \u0432 1806 \u0433\u043E\u0434\u0443,
    \u043D\u0430\u0437\u0432\u0430\u0432 \u0435\u0433\u043E \xABm\xE9thode des moindres
    carr\xE9s\xBB. \u041E\u0434\u043D\u0430\u043A\u043E \u0413\u0430\u0443\u0441\u0441
    \u0437\u0430\u044F\u0432\u0438\u043B, \u0447\u0442\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0441 1795 \u0433\u043E\u0434\u0430, \u043D\u043E \u043D\u0435
    \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B. \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u043E\u0431\u0438\u0436\u0435\u043D
    \u0442\u0435\u043C, \u0447\u0442\u043E \u0413\u0430\u0443\u0441\u0441 \u0432
    \u0441\u0432\u043E\u0435\u0439 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438
    1809 \u0433\u043E\u0434\u0430 \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0440\u0438\u043F\u0438\u0441\u0430\u043B \u043C\u0435\u0442\u043E\u0434
    \u0441\u0435\u0431\u0435. \u0412 1820 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043F\u043E\u043B\u043D\u043E\u0435 \u0433\u043E\u0440\u0435\u0447\u0438 \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u043E\u0435
    \u0437\u0430\u044F\u0432\u043B\u0435\u043D\u0438\u0435, \u0433\u0434\u0435 \u0432\u043E\u0437\u043C\u0443\u0449\u0430\u043B\u0441\u044F
    \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435\u043C \u0413\u0430\u0443\u0441\u0441\u0430,
    \u043E\u0442\u043C\u0435\u0447\u0430\u044F, \u0447\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043D\u0430\u0443\u043A\u0438 \u043D\u0435 \u0434\u043E\u043B\u0436\u043D\u0430
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C\u0441\u044F
    \u043F\u043E\u0434\u043E\u0431\u043D\u044B\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C.
    \u0413\u0430\u0443\u0441\u0441, \u0432 \u0441\u0432\u043E\u044E \u043E\u0447\u0435\u0440\u0435\u0434\u044C,
    \u043D\u0435 \u0441\u043D\u0438\u0437\u043E\u0448\u0451\u043B \u0434\u043E \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E\u0433\u043E
    \u043E\u0442\u0432\u0435\u0442\u0430, \u0447\u0442\u043E \u043B\u0438\u0448\u044C
    \u0443\u0441\u0438\u043B\u0438\u043B\u043E \u043E\u0431\u0438\u0434\u0443 \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430.
    *   **\u0410\u0431\u0435\u043B\u044C \u0438 \u042F\u043A\u043E\u0431\u0438**:
    \u0415\u0449\u0451 \u043E\u0434\u0438\u043D \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u043D\u043D\u044B\u0439
    \u0443\u0434\u0430\u0440 \u0431\u044B\u043B \u043D\u0430\u043D\u0435\u0441\u0451\u043D
    \u0435\u0433\u043E \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0438\u043C
    \u0442\u0440\u0443\u0434\u0430\u043C \u043F\u043E \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430\u043C. \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u043F\u043E\u0442\u0440\u0430\u0442\u0438\u043B \u0433\u043E\u0434\u044B \u043D\u0430
    \u0438\u0445 \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044E
    \u0438 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u0442\u0430\u0431\u043B\u0438\u0446,
    \u043D\u043E \u0441\u0440\u0430\u0437\u0443 \u043F\u043E\u0441\u043B\u0435 \u0432\u044B\u0445\u043E\u0434\u0430
    \u0435\u0433\u043E \u0442\u0440\u0451\u0445\u0442\u043E\u043C\u043D\u043E\u0433\u043E
    \xAB\u0422\u0440\u0430\u043A\u0442\u0430\u0442\u0430 \u043E\u0431 \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u0445\xBB (1825\u20131832) \u043C\u043E\u043B\u043E\u0434\u044B\u0435
    \u0433\u0435\u043D\u0438\u0438 \u0410\u0431\u0435\u043B\u044C \u0438 \u042F\u043A\u043E\u0431\u0438
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0438 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E,
    \u043F\u0435\u0440\u0435\u0439\u0434\u044F \u043A \u043E\u0431\u0440\u0430\u0442\u043D\u044B\u043C
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C \u0438 \u0441\u0434\u0435\u043B\u0430\u0432
    \u0447\u0430\u0441\u0442\u044C \u0440\u0430\u0431\u043E\u0442\u044B \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \u043C\u0435\u043D\u0435\u0435 \u0430\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439. 
    ### \U0001F625 \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0441\u043C\u0435\u0440\u0442\u044C  \u041A\u043E\u043D\u0435\u0446 \u0436\u0438\u0437\u043D\u0438
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430 \u0431\u044B\u043B \u043E\u043C\u0440\u0430\u0447\u0451\u043D
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u044F\u043C\u0438. \u0412 1824
    \u0433\u043E\u0434\u0443 \u0435\u0433\u043E \u043F\u0435\u043D\u0441\u0438\u044F
    \u0438\u0437 \u0412\u043E\u0435\u043D\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u044B
    \u0431\u044B\u043B\u0430 \u043F\u0440\u0435\u043A\u0440\u0430\u0449\u0435\u043D\u0430.
    \u041F\u043E \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0432\u0435\u0440\u0441\u0438\u0439,
    \u044D\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E \u0438\u0437-\u0437\u0430
    \u0431\u044E\u0440\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u0448\u0438\u0431\u043A\u0438, \u043F\u043E \u0434\u0440\u0443\u0433\u043E\u0439
    \u2014 \u0438\u0437-\u0437\u0430 \u0442\u043E\u0433\u043E, \u0447\u0442\u043E
    \u043E\u043D \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0433\u043E\u043B\u043E\u0441\u043E\u0432\u0430\u0442\u044C
    \u0437\u0430 \u043D\u0443\u0436\u043D\u043E\u0433\u043E \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
    \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0430 \u0432 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438. \u041B\u0438\u0448\u044C \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u043D\u044B \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0432 1828 \u0433\u043E\u0434\u0443 \u0435\u0433\u043E \u043F\u0435\u043D\u0441\u0438\u044F
    \u0431\u044B\u043B\u0430 \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0430. 
    \u0412 1831 \u0433\u043E\u0434\u0443, \u043D\u0435\u0437\u0430\u0434\u043E\u043B\u0433\u043E
    \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438, \u043E\u043D \u0431\u044B\u043B
    \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D \u0437\u0432\u0430\u043D\u0438\u044F
    \u043E\u0444\u0438\u0446\u0435\u0440\u0430 \u041E\u0440\u0434\u0435\u043D\u0430
    \u041F\u043E\u0447\u0451\u0442\u043D\u043E\u0433\u043E \u043B\u0435\u0433\u0438\u043E\u043D\u0430.
    \u0410\u0434\u0440\u0438\u0435\u043D \u041C\u0430\u0440\u0438 \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 \u041F\u0430\u0440\u0438\u0436\u0435
    9 \u044F\u043D\u0432\u0430\u0440\u044F 1833 \u0433\u043E\u0434\u0430 \u043F\u043E\u0441\u043B\u0435
    \u0434\u043E\u043B\u0433\u043E\u0439 \u0438 \u043C\u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0431\u043E\u043B\u0435\u0437\u043D\u0438. \u0415\u0433\u043E \u0432\u0434\u043E\u0432\u0430
    \u043F\u0435\u0440\u0435\u0436\u0438\u043B\u0430 \u0435\u0433\u043E \u0431\u043E\u043B\u0435\u0435
    \u0447\u0435\u043C \u043D\u0430 \u0434\u0432\u0430\u0434\u0446\u0430\u0442\u044C
    \u043B\u0435\u0442 \u0438 \u0431\u044B\u043B\u0430 \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D\u0430
    \u0440\u044F\u0434\u043E\u043C \u0441 \u043D\u0438\u043C \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435
    \u041E\u0442\u0435\u0439, \u0433\u0434\u0435 \u043E\u043D\u0438 \u0436\u0438\u043B\u0438. 
    \u0418\u043C\u044F \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430 \u043D\u0430\u0432\u0435\u0447\u043D\u043E
    \u0432\u044B\u0433\u0440\u0430\u0432\u0438\u0440\u043E\u0432\u0430\u043D\u043E
    \u043D\u0430 \u043F\u0435\u0440\u0432\u043E\u043C \u044D\u0442\u0430\u0436\u0435
    \u042D\u0439\u0444\u0435\u043B\u0435\u0432\u043E\u0439 \u0431\u0430\u0448\u043D\u0438
    \u0432 \u0441\u043F\u0438\u0441\u043A\u0435 72 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0443\u0447\u0451\u043D\u044B\u0445 \u0424\u0440\u0430\u043D\u0446\u0438\u0438,
    \u0430 \u0435\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0436\u0438\u0432\u0451\u0442
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F\u0445, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u044B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440."
  personalLifeEn: 
  shortBioRu: "\u0410\u0434\u0440\u0438\u0435\u043D \u041C\u0430\u0440\u0438 \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    (1752\u20131833) \u2014 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0447\u044C\u0451 \u0438\u043C\u044F
    \u0443\u0432\u0435\u043A\u043E\u0432\u0435\u0447\u0435\u043D\u043E \u0432 \u043C\u043D\u043E\u0433\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F\u0445, \u0445\u043E\u0442\u044F \u0435\u0433\u043E
    \u0447\u0430\u0441\u0442\u043E \u043D\u0435\u0437\u0430\u0441\u043B\u0443\u0436\u0435\u043D\u043D\u043E
    \u0437\u0430\u0442\u043C\u0435\u0432\u0430\u043B\u0438 \u0431\u043E\u043B\u0435\u0435
    \u044F\u0440\u043A\u0438\u0435 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438.
    \u041E\u043D \u043F\u0440\u043E\u0436\u0438\u043B \u0434\u043E\u043B\u0433\u0443\u044E,
    \u0432\u043D\u0435\u0448\u043D\u0435 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u0443\u0447\u0451\u043D\u043E\u0433\u043E, \u043D\u043E
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u043F\u043E\u043B\u043D\u0430
    \u043A\u0430\u043A \u0442\u0440\u0438\u0443\u043C\u0444\u043E\u0432, \u0442\u0430\u043A
    \u0438 \u0433\u043E\u0440\u044C\u043A\u0438\u0445 \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u0439. 
    ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u043D\u0430\u0447\u0430\u043B\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B 
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    18 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F 1752 \u0433\u043E\u0434\u0430
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u0432 \u0441\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0441\u0435\u043C\u044C\u0435, \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E
    \u0435\u043C\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435. \u041E\u043D
    \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439
    \u041A\u043E\u043B\u043B\u0435\u0436 \u041C\u0430\u0437\u0430\u0440\u0438\u043D\u0438
    \u0432 1770 \u0433\u043E\u0434\u0443, \u0437\u0430\u0449\u0438\u0442\u0438\u0432
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u043F\u043E
    \u0444\u0438\u0437\u0438\u043A\u0435 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. 
    \u0421 1775 \u043F\u043E 1780 \u0433\u043E\u0434 \u043E\u043D \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0432 \u0412\u043E\u0435\u043D\u043D\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 \u041F\u0430\u0440\u0438\u0436\u0430, \u0433\u0434\u0435
    \u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u043E\u0439 \u0431\u044B\u043B
    \u041F\u044C\u0435\u0440-\u0421\u0438\u043C\u043E\u043D \u041B\u0430\u043F\u043B\u0430\u0441.
    \u0415\u0433\u043E \u0440\u0430\u043D\u043D\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0431\u044B\u0441\u0442\u0440\u043E \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0438
    \u0435\u043C\u0443 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435: \u0432
    1782 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043F\u0440\u0435\u043C\u0438\u044E \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A \u0437\u0430
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442 \u043E \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u044F\u0445
    \u0441\u043D\u0430\u0440\u044F\u0434\u043E\u0432, \u0430 \u0443\u0436\u0435 \u0432
    1783 \u0433\u043E\u0434\u0443 \u0441\u0442\u0430\u043B \u0447\u043B\u0435\u043D\u043E\u043C
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A.  ### \U0001F52D \u0413\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u0438 \u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430  \u0412 \u043A\u043E\u043D\u0446\u0435
    1780-\u0445 \u0433\u043E\u0434\u043E\u0432 \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u043A\u0440\u0443\u043F\u043D\u044B\u0445 \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u043E\u0435\u043A\u0442\u0430\u0445. \u0412 1787 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u041A\u0430\u0441\u0441\u0438\u043D\u0438
    \u0438 \u041C\u0435\u0448\u0435\u043D\u043E\u043C \u043F\u0440\u043E\u0432\u0435\u043B
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u044A\u0435\u043C\u043A\u0443 \u0434\u043B\u044F \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0438 \u0413\u0440\u0438\u043D\u0432\u0438\u0447\u0441\u043A\u043E\u0439
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0439.  \u0412\u043E
    \u0432\u0440\u0435\u043C\u044F \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438, \u0432 1791 \u0433\u043E\u0434\u0443,
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u0432 \u043A\u043E\u043C\u0438\u0441\u0441\u0438\u044E \u043F\u043E \u0432\u0432\u0435\u0434\u0435\u043D\u0438\u044E
    \u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B.
    \u0415\u0433\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0435\u0439
    \u0431\u044B\u043B\u0438 \u0442\u043E\u0447\u043D\u0435\u0439\u0448\u0438\u0435
    \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F \u0434\u0443\u0433\u0438
    \u043C\u0435\u0440\u0438\u0434\u0438\u0430\u043D\u0430 \u043C\u0435\u0436\u0434\u0443
    \u0414\u044E\u043D\u043A\u0435\u0440\u043A\u043E\u043C \u0438 \u0411\u0430\u0440\u0441\u0435\u043B\u043E\u043D\u043E\u0439
    \u0434\u043B\u044F \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u044F
    \u044D\u0442\u0430\u043B\u043E\u043D\u0430 \u043C\u0435\u0442\u0440\u0430.  ###
    \U0001F4DA \u0417\u0440\u0435\u043B\u044B\u0435 \u0433\u043E\u0434\u044B: \u0440\u0430\u0441\u0446\u0432\u0435\u0442
    \u0438 \u043E\u043F\u0430\u043B\u0430  \u0412 1793 \u0433\u043E\u0434\u0443,
    \u0432 \u0440\u0430\u0437\u0433\u0430\u0440 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0442\u0435\u0440\u0440\u043E\u0440\u0430, \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u044F
    \u043D\u0430\u0443\u043A \u0431\u044B\u043B\u0430 \u0437\u0430\u043A\u0440\u044B\u0442\u0430,
    \u0430 \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u0441\u0432\u043E\u0451 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435.
    \u0412 \u0442\u043E\u0442 \u0436\u0435 \u0433\u043E\u0434 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u041C\u0430\u0440\u0433\u0430\u0440\u0438\u0442\u0435-\u041A\u043B\u043E\u0434\u0438\u043D\u0435
    \u041A\u0443\u044D\u043D. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430
    \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u0438, \u0432 1794 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A **\xAB\u041D\u0430\u0447\u0430\u043B\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB (\xC9l\xE9ments de
    g\xE9om\xE9trie)**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u043B
    \u0441\u043E\u0431\u043E\u0439 \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u043D\u043E\u0435
    \u0438 \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u043D\u043E\u0435 \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u0438 \u043D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438
    \u043F\u043E\u0447\u0442\u0438 \u0441\u0442\u0430 \u043B\u0435\u0442 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u043C \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u043C
    \u0432\u043E \u043C\u043D\u043E\u0433\u0438\u0445 \u0441\u0442\u0440\u0430\u043D\u0430\u0445,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0420\u043E\u0441\u0441\u0438\u044E
    \u0438 \u0421\u0428\u0410.  \u0412 1795 \u0433\u043E\u0434\u0443 \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u041D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u044B,
    \u0430 \u0441 1799 \u0433\u043E\u0434\u0430 \u2014 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0430\u0442\u043E\u0440\u043E\u043C
    \u0432 \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435, \u0437\u0430\u043C\u0435\u043D\u0438\u0432 \u043D\u0430
    \u044D\u0442\u043E\u043C \u043F\u043E\u0441\u0442\u0443 \u041B\u0430\u043F\u043B\u0430\u0441\u0430. 
    \u041E\u0434\u043D\u0430\u043A\u043E \u0432 1824 \u0433\u043E\u0434\u0443 \u0441
    \u043D\u0438\u043C \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u0451\u043B \u043D\u0435\u043F\u0440\u0438\u044F\u0442\u043D\u044B\u0439
    \u0438\u043D\u0446\u0438\u0434\u0435\u043D\u0442. \u0418\u0437-\u0437\u0430 \u0431\u044E\u0440\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u0448\u0438\u0431\u043A\u0438 \u0438\u043B\u0438, \u043F\u043E \u0434\u0440\u0443\u0433\u0438\u043C
    \u0434\u0430\u043D\u043D\u044B\u043C, \u0438\u0437-\u0437\u0430 \u0435\u0433\u043E
    \u043E\u0442\u043A\u0430\u0437\u0430 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u0442\u044C
    \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0430 \u0432 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438, \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u043B\u0438\u0448\u0438\u043B\u0441\u044F \u0432\u043E\u0435\u043D\u043D\u043E\u0439
    \u043F\u0435\u043D\u0441\u0438\u0438 \u0438 \u043E\u0441\u0442\u0430\u0442\u043E\u043A
    \u0436\u0438\u0437\u043D\u0438 \u043F\u0440\u043E\u0432\u0451\u043B \u0432 \u043D\u0443\u0436\u0434\u0435. 
    \u0421\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0410\u0434\u0440\u0438\u0435\u043D
    \u041C\u0430\u0440\u0438 \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435
    9 \u044F\u043D\u0432\u0430\u0440\u044F 1833 \u0433\u043E\u0434\u0430 \u043F\u043E\u0441\u043B\u0435
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0438 \u043C\u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439 \u0431\u043E\u043B\u0435\u0437\u043D\u0438. 
    ### \U0001F9EE \u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0438 \xAB\u043F\u0440\u043E\u043A\u043B\u044F\u0442\u0438\u0435\xBB \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0430 
    \u0412\u043A\u043B\u0430\u0434 \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u043E\u0433\u0440\u043E\u043C\u0435\u043D,
    \u043D\u043E \u0435\u0433\u043E \u0447\u0430\u0441\u0442\u043E \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u0430
    \xAB\u0434\u0443\u0440\u043D\u0430\u044F \u0441\u043B\u0430\u0432\u0430\xBB:
    \u0441\u0442\u043E\u0438\u043B\u043E \u0435\u043C\u0443 \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435, \u043A\u0430\u043A \u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u0434\u0440\u0443\u0433\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0441\u0434\u0435\u043B\u0430\u043B \u0442\u043E \u0436\u0435 \u0441\u0430\u043C\u043E\u0435
    \u043D\u0435\u043C\u043D\u043E\u0433\u043E \u0440\u0430\u043D\u044C\u0448\u0435
    \u0438\u043B\u0438 \u043F\u0440\u0438\u0448\u0451\u043B \u043A \u0431\u043E\u043B\u0435\u0435
    \u043E\u0431\u0449\u0438\u043C \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430\u043C.
    \u042D\u0442\u043E \u043D\u0435 \u0443\u043C\u0430\u043B\u044F\u0435\u0442 \u0435\u0433\u043E
    \u0437\u0430\u0441\u043B\u0443\u0433, \u043D\u043E \u0447\u0430\u0441\u0442\u043E
    \u0441\u0442\u0430\u0432\u0438\u0442 \u0435\u0433\u043E \u0432 \u0442\u0435\u043D\u044C
    \u0431\u043E\u043B\u0435\u0435 \u0438\u043C\u0435\u043D\u0438\u0442\u044B\u0445
    \u043A\u043E\u043B\u043B\u0435\u0433.  *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B**: \u0415\u0433\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 **\xAB\u041E\u043F\u044B\u0442 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B\xBB (Essai sur la th\xE9orie des nombres)**, \u0432\u044B\u0448\u0435\u0434\u0448\u0438\u0439
    \u0432 1798 \u0433\u043E\u0434\u0443, \u0441\u0442\u0430\u043B \u043F\u0435\u0440\u0432\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0432\u043E\u0434\u043A\u043E\u0439 \u0437\u043D\u0430\u043D\u0438\u0439
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. \u0412
    \u043D\u0451\u043C \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0439 \u0437\u0430\u043A\u043E\u043D
    \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438 \u0438 \u0432\u0432\u0451\u043B
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0443\u0434\u043E\u0431\u043D\u044B\u0439
    \u0441\u0438\u043C\u0432\u043E\u043B, \u043D\u044B\u043D\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u0430\u043A **\u0441\u0438\u043C\u0432\u043E\u043B \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430**,
    \u0445\u043E\u0442\u044F \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u044D\u0442\u043E\u0433\u043E \u0437\u0430\u043A\u043E\u043D\u0430 \u043F\u043E\u0437\u0436\u0435
    \u0434\u0430\u043B \u0413\u0430\u0443\u0441\u0441. *   **\u041C\u0435\u0442\u043E\u0434
    \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0438\u0445 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432**:
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u043F\u0435\u0440\u0432\u044B\u043C
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u044D\u0442\u043E\u0442
    \u043C\u0435\u0442\u043E\u0434 \u0432 1806 \u0433\u043E\u0434\u0443 \u0432 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u043A \u0441\u0432\u043E\u0435\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 \u043E
    \u043A\u043E\u043C\u0435\u0442\u043D\u044B\u0445 \u043E\u0440\u0431\u0438\u0442\u0430\u0445,
    \u043D\u0430\u0437\u0432\u0430\u0432 \u0435\u0433\u043E \xABm\xE9thode des moindres
    carr\xE9s\xBB. \u041E\u0434\u043D\u0430\u043A\u043E \u0413\u0430\u0443\u0441\u0441
    \u0437\u0430\u044F\u0432\u0438\u043B, \u0447\u0442\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434 \u0435\u0449\u0451 \u0432
    1795 \u0433\u043E\u0434\u0443, \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u043A \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u043C\u0443 \u0441\u043F\u043E\u0440\u0443
    \u043E \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0435. *   **\u042D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044B**: \u0412 \u0441\u0432\u043E\u0435\u043C
    \u0442\u0440\u0451\u0445\u0442\u043E\u043C\u043D\u043E\u043C **\xAB\u0422\u0440\u0430\u043A\u0442\u0430\u0442\u0435
    \u043E\u0431 \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u0445\xBB (Trait\xE9 des fonctions
    elliptiques)** 1825\u20131828 \u0433\u043E\u0434\u043E\u0432 \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u043F\u0440\u043E\u0434\u0435\u043B\u0430\u043B \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043F\u043E \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0438
    \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u0432 \u0438 \u043F\u0440\u0438\u0432\u0435\u043B
    \u0438\u0445 \u043A \u043A\u0430\u043D\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0444\u043E\u0440\u043C\u0430\u043C, \u043D\u044B\u043D\u0435 \u043D\u043E\u0441\u044F\u0449\u0438\u043C
    \u0435\u0433\u043E \u0438\u043C\u044F. \u041E\u0434\u043D\u0430\u043A\u043E \u0432\u0441\u043A\u043E\u0440\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0432\u044B\u0445\u043E\u0434\u0430 \u0435\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430 \u0440\u0430\u0431\u043E\u0442\u044B \u0410\u0431\u0435\u043B\u044F
    \u0438 \u042F\u043A\u043E\u0431\u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u0438\u043B\u0438 \u044D\u0442\u0443
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C, \u0441\u0434\u0435\u043B\u0430\u0432
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430 \u043C\u0435\u043D\u0435\u0435
    \u0430\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u043C\u0438. *   **\u0414\u0440\u0443\u0433\u0438\u0435
    \u0432\u0430\u0436\u043D\u044B\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u044F**:
    \u0418\u043C\u0435\u043D\u0435\u043C \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \u043D\u0430\u0437\u0432\u0430\u043D\u044B **\u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u044B
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430** (\u0432\u0430\u0436\u043D\u043E\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0432 \u0444\u0438\u0437\u0438\u043A\u0435),
    **\u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430** (\u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C\u043E\u0435
    \u0432 \u0442\u0435\u0440\u043C\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435
    \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435 \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0430
    \u043E\u0442 \u043B\u0430\u0433\u0440\u0430\u043D\u0436\u0438\u0430\u043D\u0430
    \u043A \u0433\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0438\u0430\u043D\u0443),
    \u0430 \u0442\u0430\u043A\u0436\u0435 **\u0443\u0441\u043B\u043E\u0432\u0438\u0435
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430** \u0432 \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u043C
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0438.  ### \U0001F3DB\uFE0F
    \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0437\u0430\u0441\u043B\u0443\u0433 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0432\u0441\u0435
    \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u043D\u044B\u0435 \u0441\u043F\u043E\u0440\u044B
    \u0438 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u0438, \u0438\u043C\u044F \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \u043D\u0430\u0432\u0435\u0447\u043D\u043E \u0432\u043F\u0438\u0441\u0430\u043D\u043E
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u043D\u0430\u0443\u043A\u0438.
    \u041E\u043D\u043E \u0432\u044B\u0433\u0440\u0430\u0432\u0438\u0440\u043E\u0432\u0430\u043D\u043E
    \u043D\u0430 \u043F\u0435\u0440\u0432\u043E\u043C \u044D\u0442\u0430\u0436\u0435
    \u042D\u0439\u0444\u0435\u043B\u0435\u0432\u043E\u0439 \u0431\u0430\u0448\u043D\u0438
    \u0432 \u0441\u043F\u0438\u0441\u043A\u0435 72 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0445 \u0443\u0447\u0451\u043D\u044B\u0445.
    \u0412 \u0435\u0433\u043E \u0447\u0435\u0441\u0442\u044C \u043D\u0430\u0437\u0432\u0430\u043D
    \u043A\u0440\u0430\u0442\u0435\u0440 \u043D\u0430 \u041B\u0443\u043D\u0435 \u0438
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0430\u0441\u0442\u0435\u0440\u043E\u0438\u0434\u043E\u0432."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0410\u0434\u0440\u0438\u0435\u043D\u0430
    \u041C\u0430\u0440\u0438 \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430 \u043F\u043E\u043B\u043D\u0430
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043E\u0432
    \u0438 \u043A\u0443\u0440\u044C\u0451\u0437\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u0435\u043B\u0430\u044E\u0442 \u0435\u0433\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0435\u0439, \u0430 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439
    \u0434\u0440\u0430\u043C\u043E\u0439 \u0441 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u043C
    \u0444\u0438\u043D\u0430\u043B\u043E\u043C.  ### \U0001F3AD \u0421\u0430\u043C\u044B\u0439
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043A\u0443\u0440\u044C\u0451\u0437:
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u0431\u0435\u0437 \u043B\u0438\u0446\u0430 
    \u042D\u0442\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u0430\u044F
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u044F,
    \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u0430\u044F \u0441 \u0443\u0447\u0451\u043D\u044B\u043C:
    \u0431\u043E\u043B\u0435\u0435 150 \u043B\u0435\u0442 \u0443 \u043D\u0435\u0433\u043E
    **\u043D\u0435 \u0431\u044B\u043B\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u043B\u0438\u0446\u0430**. \u0412\u043F\u043B\u043E\u0442\u044C \u0434\u043E
    2005 \u0433\u043E\u0434\u0430 \u0432\u043E \u0432\u0441\u0435\u0445 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0430\u0445
    \u0438 \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u044F\u0445
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439,
    \u043A\u0430\u043A \u0441\u0447\u0438\u0442\u0430\u043B\u043E\u0441\u044C, \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0430\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C, \u0447\u0442\u043E \u043D\u0430
    \u043D\u0451\u043C \u0431\u044B\u043B \u0437\u0430\u043F\u0435\u0447\u0430\u0442\u043B\u0451\u043D...
    **\u043F\u043E\u043B\u0438\u0442\u0438\u043A \u041B\u0443\u0438 \u041B\u0435\u0436\u0430\u043D\u0434\u0440**
    (1752\u20131797) \u2014 \u0435\u0433\u043E \u043F\u043E\u043B\u043D\u044B\u0439
    \u0442\u0451\u0437\u043A\u0430 \u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A. 
    *   **\u041A\u0430\u043A \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430
    \u043F\u0443\u0442\u0430\u043D\u0438\u0446\u0430?** \u041F\u0440\u0435\u0434\u043F\u043E\u043B\u0430\u0433\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u0448\u0438\u0431\u043A\u0430 \u0437\u0430\u043A\u0440\u0430\u043B\u0430\u0441\u044C
    \u0432 \u043A\u043D\u0438\u0433\u0435 1900 \u0433\u043E\u0434\u0430 \u0410\u043B\u044C\u0444\u043E\u043D\u0441\u0430
    \u0420\u0435\u0431\u044C\u0435\u0440\u0430. \u041A \u0442\u043E\u043C\u0443 \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u043A
    \u0443\u0436\u0435 \u0434\u0430\u0432\u043D\u043E \u0443\u043C\u0435\u0440\u043B\u0438.
    \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439 \u043F\u043E\u0434\u043F\u0438\u0441\u044C\u044E
    \u043D\u0430 \u043F\u043E\u0440\u0442\u0440\u0435\u0442\u0435 \u0431\u044B\u043B\u0430
    \u0444\u0430\u043C\u0438\u043B\u0438\u044F \"\u041B\u0435\u0436\u0430\u043D\u0434\u0440\",
    \u0438 \u0440\u0435\u0434\u0430\u043A\u0442\u043E\u0440, \u0438\u0449\u0430 \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0434\u043B\u044F \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430,
    \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0435 \u0437\u0430\u043C\u0435\u0442\u0438\u043B
    \u043F\u043E\u0434\u0432\u043E\u0445\u0430. *   **\u0413\u043E\u0440\u044C\u043A\u0430\u044F
    \u0438\u0440\u043E\u043D\u0438\u044F \u0441\u0443\u0434\u044C\u0431\u044B:**
    \u042D\u0442\u043E\u0442 \u041B\u0443\u0438 \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u0431\u044B\u043B \u044F\u043A\u043E\u0431\u0438\u043D\u0446\u0435\u043C \u0438
    \u0441\u044B\u0433\u0440\u0430\u043B \u043A\u043B\u044E\u0447\u0435\u0432\u0443\u044E
    \u0440\u043E\u043B\u044C \u0432 \u0437\u0430\u043A\u0440\u044B\u0442\u0438\u0438
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0439 \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438, \u0438\u0437-\u0437\u0430
    \u0447\u0435\u0433\u043E \u0410\u0434\u0440\u0438\u0435\u043D \u041C\u0430\u0440\u0438,
    \u043F\u043E\u0442\u0435\u0440\u044F\u0432 \u0434\u043E\u0445\u043E\u0434, \u0431\u044B\u043B
    \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D \u0441\u043A\u0440\u044B\u0432\u0430\u0442\u044C\u0441\u044F.
    *   **\u041D\u043E\u0432\u043E\u0435 \u043E\u0431\u0440\u0435\u0442\u0451\u043D\u043D\u043E\u0435
    \u043B\u0438\u0446\u043E:** \u041B\u0438\u0448\u044C \u0432 2008 \u0433\u043E\u0434\u0443
    \u0431\u044B\u043B \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442 \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \u2014 \u0438 \u044D\u0442\u043E **\u043A\u0430\u0440\u0438\u043A\u0430\u0442\u0443\u0440\u0430
    1820 \u0433\u043E\u0434\u0430**, \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u0430\u044F
    \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u043E\u043C \u0416\u044E\u043B\u044C\u0435\u043D\u043E\u043C-\u041B\u0435\u043E\u043F\u043E\u043B\u044C\u0434\u043E\u043C
    \u0411\u0443\u0430\u0438.  \u0412\u043E\u0442 \u0442\u0430\u043A \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u0443\u043C\u043E\u0432
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438 \u043F\u043E\u0447\u0442\u0438 \u0434\u0432\u0430
    \u0432\u0435\u043A\u0430 \u0431\u044B\u043B \"\u0431\u0435\u0437\u043B\u0438\u043A\u0438\u043C\",
    \u0430 \u0435\u0433\u043E \u043C\u0435\u0441\u0442\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u0447\u0443\u0436\u043E\u0439
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0434\u0430\u0436\u0435 \u0448\u0443\u0442\u043A\u0430, \u0447\u0442\u043E \u043E\u043D
    \u043F\u0440\u043E\u0441\u0442\u043E \"\u0432\u043B\u043E\u0436\u0438\u043B \u0432\u0441\u0435
    \u043E\u0447\u043A\u0438 \u0432 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442,
    \u043F\u043E\u0436\u0435\u0440\u0442\u0432\u043E\u0432\u0430\u0432 \u0443\u0434\u0430\u0447\u0435\u0439\". 
    ### \U0001F947 \"\u0421\u0435\u0440\u0435\u0431\u0440\u044F\u043D\u044B\u0439
    \u043F\u0440\u0438\u0437\u0451\u0440\" \u0432 \u0433\u043E\u043D\u043A\u0435
    \u0437\u0430 \u043F\u0435\u0440\u0432\u0435\u043D\u0441\u0442\u0432\u043E  \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \"\u0437\u043B\u043E\u0439
    \u0440\u043E\u043A\" \u0432 \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u0445
    \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0430. \u0421\u0442\u043E\u0438\u043B\u043E
    \u0435\u043C\u0443 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0435\u0441\u044F \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435,
    \u043A\u0430\u043A \u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u043A\u0442\u043E-\u0442\u043E \u0434\u0440\u0443\u0433\u043E\u0439
    \u0441\u0434\u0435\u043B\u0430\u043B \u044D\u0442\u043E \u0436\u0435 \u0440\u0430\u043D\u044C\u0448\u0435
    \u0438\u043B\u0438 \u043F\u0440\u0438\u0448\u0451\u043B \u043A \u0431\u043E\u043B\u0435\u0435
    \u043E\u0431\u0449\u0438\u043C \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430\u043C. 
    *   **\u0421\u043F\u043E\u0440 \u0441 \u0413\u0430\u0443\u0441\u0441\u043E\u043C:**
    \u0421\u0430\u043C\u0430\u044F \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u043D\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u2014 **\u043C\u0435\u0442\u043E\u0434
    \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0438\u0445 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432**.
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u044B\u043C \u0432 1806 \u0433\u043E\u0434\u0443,
    \u0434\u0430\u0432 \u0435\u043C\u0443 \u0438\u043C\u044F [\"m\xE9thode des moindres
    carr\xE9s\"]. \u041E\u0434\u043D\u0430\u043A\u043E \u0413\u0430\u0443\u0441\u0441
    \u0437\u0430\u044F\u0432\u0438\u043B, \u0447\u0442\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434 \u0441 1795 \u0433\u043E\u0434\u0430.
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u043E\u0437\u043C\u0443\u0449\u0451\u043D, \u0447\u0442\u043E \u0432 1820
    \u0433\u043E\u0434\u0443 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0430\u043D\u043E\u043D\u0438\u043C\u043D\u0443\u044E \u0441\u0442\u0430\u0442\u044C\u044E,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u0431\u0432\u0438\u043D\u0438\u043B
    \u0413\u0430\u0443\u0441\u0441\u0430 \u0432 \"\u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439
    \u043D\u0430\u0433\u043B\u043E\u0441\u0442\u0438\" \u0438 \u043F\u0440\u0438\u0441\u0432\u043E\u0435\u043D\u0438\u0438
    \u0447\u0443\u0436\u0438\u0445 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439.
    \u0413\u0430\u0443\u0441\u0441, \u0432 \u0441\u0432\u043E\u044E \u043E\u0447\u0435\u0440\u0435\u0434\u044C,
    \u043D\u0430 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u044B\u0435 \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u044F
    \u043D\u0435 \u043E\u0442\u0432\u0435\u0447\u0430\u043B, \u0447\u0442\u043E \u043B\u0438\u0448\u044C
    \u0441\u0438\u043B\u044C\u043D\u0435\u0435 \u0440\u0430\u0437\u0434\u0440\u0430\u0436\u0430\u043B\u043E
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430. *   **\u041A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0439
    \u0437\u0430\u043A\u043E\u043D \u0432\u0437\u0430\u0438\u043C\u043D\u043E\u0441\u0442\u0438:**
    \u041B\u0435\u0436\u0430\u043D\u0434\u0440 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E\u0442 \u0437\u0430\u043A\u043E\u043D \u0438 \u0432\u0432\u0451\u043B
    \u0443\u0434\u043E\u0431\u043D\u044B\u0439 \u0441\u0438\u043C\u0432\u043E\u043B
    \u0434\u043B\u044F \u0435\u0433\u043E \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    (\u0441\u0438\u043C\u0432\u043E\u043B \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430).
    \u041E\u0434\u043D\u0430\u043A\u043E \u043F\u0440\u043E\u0431\u0435\u043B\u044B
    \u0432 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435
    \u0437\u0430\u043F\u043E\u043B\u043D\u0438\u043B \u0438 \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0434\u0430\u043B \u0438\u043C\u0435\u043D\u043D\u043E \u043C\u043E\u043B\u043E\u0434\u043E\u0439
    \u0413\u0430\u0443\u0441\u0441. *   **\u042D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438:** \u041F\u043E\u0442\u0440\u0430\u0442\u0438\u0432
    \u0431\u043E\u043B\u0435\u0435 30 \u043B\u0435\u0442 \u043D\u0430 \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044E
    \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u0432 \u0438 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446, \u041B\u0435\u0436\u0430\u043D\u0434\u0440
    \u0443\u0432\u0438\u0434\u0435\u043B, \u043A\u0430\u043A \u0435\u0433\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u0431\u044B\u043B \u043F\u0440\u0435\u0432\u0437\u043E\u0439\u0434\u0451\u043D
    \u0440\u0430\u0431\u043E\u0442\u0430\u043C\u0438 \u043C\u043E\u043B\u043E\u0434\u044B\u0445
    \u0433\u0435\u043D\u0438\u0435\u0432 \u2014 \u0410\u0431\u0435\u043B\u044F \u0438
    \u042F\u043A\u043E\u0431\u0438 \u2014 \u0432\u0441\u0435\u0433\u043E \u0447\u0435\u0440\u0435\u0437
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435
    \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438 \u0435\u0433\u043E
    \u0442\u0440\u0451\u0445\u0442\u043E\u043C\u043D\u043E\u0433\u043E \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0430. 
    ### \U0001F30D \u0412\u0441\u0435\u043C\u0438\u0440\u043D\u044B\u0439 \u0443\u0447\u0435\u0431\u043D\u0438\u043A
    \u0438 \u0432\u0435\u0447\u043D\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0432\u0441\u0435
    \u044D\u0442\u0438 \u043D\u0435\u043F\u0440\u0438\u044F\u0442\u043D\u043E\u0441\u0442\u0438,
    \u0435\u0433\u043E \"\u041D\u0430\u0447\u0430\u043B\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\"
    (1794) \u0441\u0442\u0430\u043B\u0438 \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u0432 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438.
    \u0411\u043E\u043B\u0435\u0435 100 \u043B\u0435\u0442 \u043F\u043E \u043D\u0435\u043C\u0443
    \u0443\u0447\u0438\u043B\u0438\u0441\u044C \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u043A\u0438
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438, \u0421\u0428\u0410,
    \u0420\u043E\u0441\u0441\u0438\u0438, \u0415\u0433\u0438\u043F\u0442\u0435 \u0438
    \u043C\u043D\u043E\u0433\u0438\u0445 \u0434\u0440\u0443\u0433\u0438\u0445 \u0441\u0442\u0440\u0430\u043D\u0430\u0445.
    \u041E\u043D \u0441\u0434\u0435\u043B\u0430\u043B \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u043F\u043E\u043D\u044F\u0442\u043D\u043E\u0439 \u0434\u043B\u044F \u043C\u0438\u043B\u043B\u0438\u043E\u043D\u043E\u0432. 
    \u0418, \u043A\u043E\u043D\u0435\u0447\u043D\u043E, \u0435\u0433\u043E \u0438\u043C\u044F
    \u043D\u0430\u0432\u0435\u0447\u043D\u043E \u0432\u044B\u0433\u0440\u0430\u0432\u0438\u0440\u043E\u0432\u0430\u043D\u043E
    \u043D\u0430 \u043F\u0435\u0440\u0432\u043E\u043C \u044D\u0442\u0430\u0436\u0435
    \u042D\u0439\u0444\u0435\u043B\u0435\u0432\u043E\u0439 \u0431\u0430\u0448\u043D\u0438
    \u0441\u0440\u0435\u0434\u0438 72 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0443\u0447\u0451\u043D\u044B\u0445 \u0424\u0440\u0430\u043D\u0446\u0438\u0438."
