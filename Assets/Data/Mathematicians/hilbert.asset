    (\u042D\u043C\u0438\u043B\u044C \u0410\u0440\u0442\u0438\u043D, 1927) |  \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u0442\u0430\u0432\u0438\u043B
    \u0437\u0430\u0434\u0430\u0447\u0438 \u2014 \u043E\u043D \u0432\u0441\u0435\u043B\u044F\u043B
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0432\u0435\u0440\u0443
    \u0432 \u043C\u043E\u0433\u0443\u0449\u0435\u0441\u0442\u0432\u043E \u0438\u0445
    \u043D\u0430\u0443\u043A\u0438. \u0415\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0434\u0435\u0432\u0438\u0437, \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u043D\u044B\u0439
    \u043D\u0430 \u043C\u043E\u0433\u0438\u043B\u0435, **\xABWir m\xFCssen wissen.
    Wir werden wissen\xBB** (\xAB\u041C\u044B \u0434\u043E\u043B\u0436\u043D\u044B
    \u0437\u043D\u0430\u0442\u044C. \u041C\u044B \u0431\u0443\u0434\u0435\u043C \u0437\u043D\u0430\u0442\u044C\xBB)
    , \u0441\u0442\u0430\u043B \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C \u0435\u0433\u043E
    \u043D\u0435\u0441\u0433\u0438\u0431\u0430\u0435\u043C\u043E\u0433\u043E \u043E\u043F\u0442\u0438\u043C\u0438\u0437\u043C\u0430
    \u0438 \u0432\u0435\u0440\u044B \u0432 \u0441\u0438\u043B\u0443 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0440\u0430\u0437\u0443\u043C\u0430."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0414\u0430\u0432\u0438\u0434\u0430 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430,
    \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0435\u0433\u043E
    \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u044B\u0445 \u0442\u0440\u0438\u0443\u043C\u0444\u043E\u0432,
    \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u043A\u0430\u043A \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439 \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u044C\u044E
    \u0438 \u0434\u0440\u0443\u0436\u0431\u043E\u0439, \u0442\u0430\u043A \u0438
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u0438 \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u043B\u0438
    \u0432 \u0442\u0435\u043D\u0438 \u0435\u0433\u043E \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u043E\u0439
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u044B. 
    ### \U0001F491 \u0411\u0440\u0430\u043A \u0441 \u041A\u0435\u0442\u0435 \u0415\u0440\u043E\u0448 
    \u0412 1892 \u0433\u043E\u0434\u0443 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u041A\u0435\u0442\u0435
    \u0415\u0440\u043E\u0448** (K\xE4the Jerosch, 1864\u20131945). \u041E\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u043A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0441\u043A\u043E\u0433\u043E
    \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0430 \u0438, \u043F\u043E \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F\u043C,
    \u043E\u0442\u043B\u0438\u0447\u0430\u043B\u0430\u0441\u044C \u043F\u0440\u044F\u043C\u043E\u0442\u043E\u0439
    \u0438 \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u044C\u044E
    \u0443\u043C\u0430, \u0447\u0442\u043E \u043E\u0447\u0435\u043D\u044C \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0443 \u0441\u0430\u043C\u043E\u0433\u043E
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430. \u0418\u0445 \u0431\u0440\u0430\u043A
    \u0441\u0442\u0430\u043B \u043A\u0440\u0435\u043F\u043A\u0438\u043C \u0441\u043E\u044E\u0437\u043E\u043C,
    \u0438 \u041A\u0435\u0442\u0435 \u043D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438
    \u0432\u0441\u0435\u0439 \u0436\u0438\u0437\u043D\u0438 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C
    \u0435\u0433\u043E \u0432\u0435\u0440\u043D\u043E\u0439 \u0441\u043F\u0443\u0442\u043D\u0438\u0446\u0435\u0439.
    \u0412 1893 \u0433\u043E\u0434\u0443 \u0443 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439 \u0441\u044B\u043D
    **\u0424\u0440\u0430\u043D\u0446**.  ### \U0001F468\u200D\U0001F466 \u041E\u0442\u0446\u043E\u0432\u0441\u0442\u0432\u043E
    \u0438 \u0441\u0435\u043C\u0435\u0439\u043D\u0430\u044F \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F 
    \u0421\u0443\u0434\u044C\u0431\u0430 \u0441\u044B\u043D\u0430 \u0424\u0440\u0430\u043D\u0446\u0430
    \u0441\u0442\u0430\u043B\u0430 \u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u043B\u0438\u0447\u043D\u043E\u0439
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439 \u0441\u0435\u043C\u044C\u0438
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442. \u041C\u0430\u043B\u044C\u0447\u0438\u043A
    \u0441\u0442\u0440\u0430\u0434\u0430\u043B \u043E\u0442 \u043F\u0441\u0438\u0445\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0437\u0430\u0431\u043E\u043B\u0435\u0432\u0430\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0442\u0430\u043A \u0438 \u043D\u0435 \u0431\u044B\u043B\u043E \u0434\u0438\u0430\u0433\u043D\u043E\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043E
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438. \u0415\u0433\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u0438 \u0443\u043C\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u0431\u044B\u043B\u0438 \u0442\u044F\u0436\u0435\u043B\u044B\u043C \u0443\u0434\u0430\u0440\u043E\u043C
    \u0434\u043B\u044F \u043E\u0442\u0446\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B\u043B \u043D\u0435 \u0432 \u0441\u0438\u043B\u0430\u0445 \u043F\u043E\u043C\u043E\u0447\u044C
    \u0440\u0435\u0431\u0435\u043D\u043A\u0443. \u041A\u043E\u0433\u0434\u0430 \u0424\u0440\u0430\u043D\u0446\u0430
    \u043F\u043E\u043C\u0435\u0441\u0442\u0438\u043B\u0438 \u0432 \u043F\u0441\u0438\u0445\u0438\u0430\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u043B\u0438\u043D\u0438\u043A\u0443, \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441 \u0433\u043E\u0440\u044C\u043A\u0443\u044E
    \u0444\u0440\u0430\u0437\u0443: \xAB\u0421 \u044D\u0442\u043E\u0433\u043E \u043C\u043E\u043C\u0435\u043D\u0442\u0430
    \u044F \u0434\u043E\u043B\u0436\u0435\u043D \u0441\u0447\u0438\u0442\u0430\u0442\u044C,
    \u0447\u0442\u043E \u0443 \u043C\u0435\u043D\u044F \u043D\u0435\u0442 \u0441\u044B\u043D\u0430\xBB.
    \u042D\u0442\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0438 \u0435\u0433\u043E
    \u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u044F \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0438
    \u041A\u0435\u0442\u0435 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435 \u0441\u0442\u0440\u0430\u0434\u0430\u043D\u0438\u044F. 
    \u041F\u0440\u0438 \u044D\u0442\u043E\u043C, \u043A\u0430\u043A \u044D\u0442\u043E
    \u043D\u0438 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u043E,
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u043C\u043E\u0433 \u0441 \u044E\u043C\u043E\u0440\u043E\u043C
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u044C\u0441\u044F \u043A \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044F\u043C
    \u0441\u044B\u043D\u0430. \u041E\u043D \u0447\u0430\u0441\u0442\u043E \u0448\u0443\u0442\u0438\u043B,
    \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u043B\u0430\u043D\u0442\u044B \u0424\u0440\u0430\u043D\u0446 \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u043E\u0442 \u043C\u0430\u0442\u0435\u0440\u0438, \u0430 \xAB\u0432\u0441\u0451
    \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0435\xBB \u2014 \u043E\u0442
    \u043D\u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0433\u043E.  ### \U0001F91D
    \u0414\u0440\u0443\u0436\u0431\u0430 \u043A\u0430\u043A \u043E\u043F\u043E\u0440\u0430 
    \u041E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0432 \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u0438\u0433\u0440\u0430\u043B\u0438 \u0434\u0440\u0443\u0436\u0435\u0441\u043A\u0438\u0435
    \u0441\u0432\u044F\u0437\u0438. \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0439
    \u0438 \u0441\u0430\u043C\u043E\u0439 \u043A\u0440\u0435\u043F\u043A\u043E\u0439
    \u0434\u0440\u0443\u0436\u0431\u043E\u0439 \u0441\u0442\u0430\u043B\u0430 \u0434\u0440\u0443\u0436\u0431\u0430
    \u0441 **\u0413\u0435\u0440\u043C\u0430\u043D\u043E\u043C \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u043C**.
    \u041E\u043D\u0438 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0438\u0441\u044C
    \u0432 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u0438
    \u0438\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B \xAB\u043B\u0443\u0447\u0448\u0435\u0439
    \u0438 \u0441\u0430\u043C\u043E\u0439 \u0432\u0435\u0440\u043D\u043E\u0439 \u0434\u0440\u0443\u0436\u0431\u043E\u0439\xBB.
    \u0412\u043C\u0435\u0441\u0442\u0435 \u0441 **\u0410\u0434\u043E\u043B\u044C\u0444\u043E\u043C
    \u0413\u0443\u0440\u0432\u0438\u0446\u0435\u043C** \u043E\u043D\u0438 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0438
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \xAB\u043A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0441\u043A\u0438\u0439
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\xBB \u043C\u043E\u043B\u043E\u0434\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u0447\u044C\u0438
    \u0434\u043E\u043B\u0433\u0438\u0435 \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0438
    \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0438
    \u0441\u0442\u0430\u043B\u0438 \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u043C\u0438.
    \u041F\u0440\u0435\u0436\u0434\u0435\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u0441\u043C\u0435\u0440\u0442\u044C \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0432 1909 \u0433\u043E\u0434\u0443 \u0441\u0442\u0430\u043B\u0430 \u0434\u043B\u044F
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u0442\u044F\u0436\u0435\u043B\u0435\u0439\u0448\u0438\u043C
    \u0443\u0434\u0430\u0440\u043E\u043C.  ### \U0001F30D \u0416\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0435
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u044B \u0438 \u043C\u0438\u0440\u043E\u0432\u043E\u0437\u0437\u0440\u0435\u043D\u0438\u0435 
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u0431\u044B\u043B \u043A\u0440\u0435\u0449\u0435\u043D
    \u0438 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D \u043A\u0430\u043A \u043A\u0430\u043B\u044C\u0432\u0438\u043D\u0438\u0441\u0442
    \u0432 \u041F\u0440\u0443\u0441\u0441\u043A\u043E\u0439 \u0435\u0432\u0430\u043D\u0433\u0435\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0446\u0435\u0440\u043A\u0432\u0438, \u043E\u0434\u043D\u0430\u043A\u043E \u0432
    \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u043E\u043D \u043E\u0442\u043E\u0448\u0435\u043B \u043E\u0442 \u0440\u0435\u043B\u0438\u0433\u0438\u0438
    \u0438 \u0441\u0442\u0430\u043B \u0430\u0433\u043D\u043E\u0441\u0442\u0438\u043A\u043E\u043C.
    \u0415\u0433\u043E \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u043E\u0442\u0440\u0430\u0436\u0430\u043B\u0438
    \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0432\u0435\u0440\u0443 \u0432
    \u0441\u0438\u043B\u0443 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0440\u0430\u0437\u0443\u043C\u0430 \u0438 \u043D\u0430\u0443\u043A\u0438. \u041E\u043D
    \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u0441\u0442\u0438\u043D\u0430 \u043D\u0435 \u0437\u0430\u0432\u0438\u0441\u0438\u0442
    \u043E\u0442 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u0411\u043E\u0433\u0430 \u0438\u043B\u0438 \u043A\u0430\u043A\u0438\u0445-\u043B\u0438\u0431\u043E
    \u0430\u043F\u0440\u0438\u043E\u0440\u043D\u044B\u0445 \u0434\u043E\u043F\u0443\u0449\u0435\u043D\u0438\u0439.
    \u0412 \u044D\u0442\u043E\u043C \u043A\u043E\u043D\u0442\u0435\u043A\u0441\u0442\u0435
    \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u0430 \u0435\u0433\u043E
    \u0444\u0440\u0430\u0437\u0430, \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441\u0435\u043D\u043D\u0430\u044F
    \u0432 \u0437\u0430\u0449\u0438\u0442\u0443 \u0413\u0430\u043B\u0438\u043B\u0435\u044F:
    \xAB\u0422\u043E\u043B\u044C\u043A\u043E \u0438\u0434\u0438\u043E\u0442 \u043C\u043E\u0433
    \u0431\u044B \u043F\u043E\u0432\u0435\u0440\u0438\u0442\u044C, \u0447\u0442\u043E
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0438\u0441\u0442\u0438\u043D\u0435
    \u043D\u0443\u0436\u0435\u043D \u043C\u0443\u0447\u0435\u043D\u0438\u043A; \u044D\u0442\u043E
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
    \u0432 \u0440\u0435\u043B\u0438\u0433\u0438\u0438, \u043D\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u0441\u0435\u0431\u044F \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C\xBB. 
    ### \U0001F48E \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B 
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u0431\u044B\u043B\u0438 \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u044B \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u043B\u0438\u0447\u043D\u044B\u043C\u0438
    \u043F\u043E\u0442\u0435\u0440\u044F\u043C\u0438, \u043D\u043E \u0438 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439
    \u043F\u0440\u0438\u0445\u043E\u0434\u0430 \u043D\u0430\u0446\u0438\u0441\u0442\u043E\u0432
    \u043A \u0432\u043B\u0430\u0441\u0442\u0438, \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0432\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435.
    \u041E\u043D \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u0432\u0435\u0440\u0435\u043D \u0441\u0432\u043E\u0438\u043C \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430\u043C,
    \u0438 \u0435\u0433\u043E \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u044F\u044F
    \u0441\u0442\u043E\u0439\u043A\u043E\u0441\u0442\u044C \u043D\u0430\u0448\u043B\u0430
    \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \u0432 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u043C
    \u0434\u0435\u0432\u0438\u0437\u0435 \xABWir m\xFCssen wissen. Wir werden wissen\xBB,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0442\u0435\u043F\u0435\u0440\u044C
    \u0432\u044B\u0441\u0435\u0447\u0435\u043D \u043D\u0430 \u0435\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u0435."
  personalLifeEn: 
  shortBioRu: "\u0414\u0430\u0432\u0438\u0434 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    (1862\u20131943) \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438,
    \u0447\u044C\u044F \u0440\u0430\u0431\u043E\u0442\u0430 \u043E\u0445\u0432\u0430\u0442\u0438\u043B\u0430
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u0441\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u044B
    \u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0430 \u043F\u0443\u0442\u0438
    \u0435\u0451 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F \u043D\u0430 XX
    \u0432\u0435\u043A. \u0415\u0433\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    \xAB\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C-\u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u043E\u043C\xBB
    \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043D\u044B\u043C \u043C\u0438\u0440\u043E\u0432\u044B\u043C
    \u043B\u0438\u0434\u0435\u0440\u043E\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0432 1910\u20131920-\u0435 \u0433\u043E\u0434\u044B. \u041F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u044E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439 \u043E\u0431\u0437\u043E\u0440
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438 \u0438 \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044F.  ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    (1862\u20131895)  \u0414\u0430\u0432\u0438\u0434 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 23 \u044F\u043D\u0432\u0430\u0440\u044F
    1862 \u0433\u043E\u0434\u0430 \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u0412\u0435\u043B\u0430\u0443
    (\u043D\u044B\u043D\u0435 \u0417\u043D\u0430\u043C\u0435\u043D\u0441\u043A, \u041A\u0430\u043B\u0438\u043D\u0438\u043D\u0433\u0440\u0430\u0434\u0441\u043A\u0430\u044F
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C) \u0438\u043B\u0438 \u0432 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0435.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u041E\u0442\u0442\u043E \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442,
    \u0431\u044B\u043B \u0441\u0443\u0434\u044C\u0451\u0439, \u0430 \u043C\u0430\u0442\u044C,
    \u041C\u0430\u0440\u0438\u044F \u0422\u0435\u0440\u0435\u0437\u0430, \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0435\u0439 \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0435\u0439. 
    \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u043E\u043D
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0432 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u0433\u0434\u0435
    \u0435\u0433\u043E \u043E\u0434\u043D\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A\u0430\u043C\u0438
    \u0438 \u0431\u043B\u0438\u0437\u043A\u0438\u043C\u0438 \u0434\u0440\u0443\u0437\u044C\u044F\u043C\u0438
    \u0441\u0442\u0430\u043B\u0438 \u0410\u0434\u043E\u043B\u044C\u0444 \u0413\u0443\u0440\u0432\u0438\u0446
    \u0438 **\u0413\u0435\u0440\u043C\u0430\u043D \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439**.
    \u0418\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u044B\u0435 \xAB\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0438\xBB, \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043E\u043D\u0438 \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u043B\u0438
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B,
    \u0441\u0442\u0430\u043B\u0438 \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u043C\u0438,
    \u0438 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u043F\u043E\u0437\u0436\u0435
    \u0441\u0434\u0435\u043B\u0430\u043B \u0438\u0445 \u0447\u0430\u0441\u0442\u044C\u044E
    \u0441\u0432\u043E\u0435\u0433\u043E \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u0435\u0442\u043E\u0434\u0430.  \u0412 1885 \u0433\u043E\u0434\u0443 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E, \u0430 \u043F\u043E\u0441\u043B\u0435
    \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u044F \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u043F\u0440\u043E\u0439\u0434\u044F
    \u043F\u0443\u0442\u044C \u043E\u0442 \u043F\u0440\u0438\u0432\u0430\u0442-\u0434\u043E\u0446\u0435\u043D\u0442\u0430
    \u0434\u043E \u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430.  ### \U0001F680
    \u041F\u0443\u0442\u044C \u043A \u0441\u043B\u0430\u0432\u0435 \u0438 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 (1895\u20131930)  \u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u043C
    \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C \u0441\u0442\u0430\u043B 1895
    \u0433\u043E\u0434, \u043A\u043E\u0433\u0434\u0430 \u043F\u043E \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u044E
    **\u0424\u0435\u043B\u0438\u043A\u0441\u0430 \u041A\u043B\u0435\u0439\u043D\u0430**
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u0437\u0430\u043D\u044F\u043B
    \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u2014
    \u0442\u0443 \u0441\u0430\u043C\u0443\u044E, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0440\u0430\u043D\u0435\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438
    \u041A\u0430\u0440\u043B \u0424\u0440\u0438\u0434\u0440\u0438\u0445 \u0413\u0430\u0443\u0441\u0441
    \u0438 \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434 \u0420\u0438\u043C\u0430\u043D.
    \u041E\u043D \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F \u043D\u0430
    \u044D\u0442\u043E\u043C \u043F\u043E\u0441\u0442\u0443 35 \u043B\u0435\u0442. 
    \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u0441\u0442\u0430\u043B
    \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C \u0435\u0433\u043E \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0447\u0430\u0441\u0442\u043E \u0441\u043C\u0435\u043D\u044F\u043B\u0438 \u0434\u0440\u0443\u0433
    \u0434\u0440\u0443\u0433\u0430, \u0437\u043D\u0430\u043C\u0435\u043D\u0443\u044F
    \u043F\u0435\u0440\u0435\u0445\u043E\u0434 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u043A \u043D\u043E\u0432\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F :  -
    **\u0422\u0435\u043E\u0440\u0438\u044F \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432:**
    \u0411\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u0440\u0435\u0448\u0438\u043B
    \xAB\u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443 \u0413\u043E\u0440\u0434\u0430\u043D\u0430\xBB,
    \u0434\u043E\u043A\u0430\u0437\u0430\u0432 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0438
    \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E \u0431\u0430\u0437\u0438\u0441\u0430
    \u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432. \u042D\u0442\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0431\u044B\u043B\u043E \u043D\u0435\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u043C,
    \u0447\u0442\u043E \u0432\u044B\u0437\u0432\u0430\u043B\u043E \u043A\u0440\u0438\u0442\u0438\u043A\u0443
    \u0441\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u044B \u041F\u043E\u043B\u044F
    \u0413\u043E\u0440\u0434\u0430\u043D\u0430, \u0432\u043E\u0441\u043A\u043B\u0438\u043A\u043D\u0443\u0432\u0448\u0435\u0433\u043E:
    \xAB\u042D\u0442\u043E \u043D\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430.
    \u042D\u0442\u043E \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044F!\xBB. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043F\u043E\u0437\u0436\u0435 \u0413\u043E\u0440\u0434\u0430\u043D \u043F\u0440\u0438\u0437\u043D\u0430\u043B
    \u0435\u0433\u043E \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u044C. - **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B:** \u0412 1897 \u0433\u043E\u0434\u0443 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \xAB\u041E\u0442\u0447\u0451\u0442 \u043E \u0447\u0438\u0441\u043B\u0430\u0445\xBB
    (Zahlbericht), \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0430\u043B
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u0442\u0440\u0443\u0434\u043E\u043C
    \u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0432\u0441\u0435 \u0437\u043D\u0430\u043D\u0438\u044F \u0432 \u044D\u0442\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438. - **\u041E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438:** \u0412 1899 \u0433\u043E\u0434\u0443
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \xAB\u041E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB, \u0433\u0434\u0435
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u043D\u043E\u0432\u0443\u044E,
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0430\u043A\u0441\u0438\u043E\u043C
    \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.
    \u041E\u043D \u043F\u0435\u0440\u0432\u044B\u043C \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0439 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0445
    \u043F\u043E\u043D\u044F\u0442\u0438\u0439, \u0442\u0440\u0430\u043A\u0442\u0443\u044F
    \u0430\u043A\u0441\u0438\u043E\u043C\u044B \u043A\u0430\u043A \u043D\u0435\u044F\u0432\u043D\u044B\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F. \u042D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0441\u0442\u0430\u043B\u0430 \u043E\u0431\u0440\u0430\u0437\u0446\u043E\u043C
    \u0434\u043B\u044F \u0432\u0441\u0435\u0439 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439
    \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u043A\u0438. - **\u0424\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0438 \xAB\u0433\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u0432\u043E
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E\xBB:**
    \u0412 1910-\u0445 \u0433\u043E\u0434\u0430\u0445 \u0441\u043E\u0437\u0434\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0438 \u0432\u0432\u0451\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043F\u043E\u0437\u0436\u0435 \u043D\u0430\u0437\u043E\u0432\u0443\u0442 **\u0433\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u0432\u044B\u043C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E\u043C**.
    \u042D\u0442\u0430 \u0442\u0435\u043E\u0440\u0438\u044F \u0441\u0442\u0430\u043B\u0430
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438.
    - **23 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B:** \u0412 1900 \u0433\u043E\u0434\u0443
    \u043D\u0430 \u0412\u0442\u043E\u0440\u043E\u043C \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u043C
    \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0440\u0435\u0447\u044C \u0438 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B
    \u0441\u043F\u0438\u0441\u043E\u043A \u0438\u0437 23 \u043D\u0435\u0440\u0435\u0448\u0451\u043D\u043D\u044B\u0445
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0435,
    \u043F\u043E \u0435\u0433\u043E \u043C\u043D\u0435\u043D\u0438\u044E, \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043D\u0430 \u0433\u0440\u044F\u0434\u0443\u0449\u0438\u0439 \u0432\u0435\u043A.
    \u042D\u0442\u043E\u0442 \u0441\u043F\u0438\u0441\u043E\u043A \u0441\u0442\u0430\u043B
    \u0441\u0432\u043E\u0435\u043E\u0431\u0440\u0430\u0437\u043D\u043E\u0439 \xAB\u0434\u043E\u0440\u043E\u0436\u043D\u043E\u0439
    \u043A\u0430\u0440\u0442\u043E\u0439\xBB \u0434\u043B\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0432\u0441\u0435\u0433\u043E \u043C\u0438\u0440\u0430.  > \u0412 \u044D\u0442\u043E\u0442
    \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D \u0442\u0430\u043A\u0436\u0435
    \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0438\u0440\u043E\u0432\u0430\u043B
    \u0410\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430
    \u0438 \u043F\u043E\u043C\u043E\u0433\u0430\u043B \u0435\u043C\u0443 \u0432 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0438
    \u0432\u044B\u0432\u043E\u0434\u0430 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u043E\u0431\u0449\u0435\u0439 \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438. 
    ### \U0001F48E \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    - **\u041F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430:**
    \u0412 1920-\u0435 \u0433\u043E\u0434\u044B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0438\u043B\u0441\u044F
    \u043D\u0430 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443 \u043F\u043E \u0441\u043F\u0430\u0441\u0435\u043D\u0438\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043E\u0442 \u043A\u0440\u0438\u0437\u0438\u0441\u0430,
    \u0432\u044B\u0437\u0432\u0430\u043D\u043D\u043E\u0433\u043E \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043C\u0438
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432.
    \u0421\u0443\u0442\u044C \u0435\u0451 \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0430\u0441\u044C
    \u0432 \u043F\u043E\u043B\u043D\u043E\u0439 \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438
    \u0432\u0441\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0441 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u043C \xAB\u0444\u0438\u043D\u0438\u0442\u043D\u044B\u043C\xBB
    (\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u043C \u0438 \u043D\u0430\u0433\u043B\u044F\u0434\u043D\u044B\u043C)
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0441\u0442\u0438. 
    - **\u041A\u0440\u0443\u0448\u0435\u043D\u0438\u0435 \u043D\u0430\u0434\u0435\u0436\u0434
    \u0438 \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0413\u0451\u0434\u0435\u043B\u044F:**
    \u0412 1931 \u0433\u043E\u0434\u0443 \u043C\u043E\u043B\u043E\u0434\u043E\u0439
    \u0430\u0432\u0441\u0442\u0440\u0438\u0439\u0441\u043A\u0438\u0439 \u043B\u043E\u0433\u0438\u043A
    **\u041A\u0443\u0440\u0442 \u0413\u0451\u0434\u0435\u043B\u044C** \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u043D\u0435\u043F\u043E\u043B\u043D\u043E\u0442\u0435.
    \u041E\u043D\u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0438, \u0447\u0442\u043E
    \u0432 \u043B\u044E\u0431\u043E\u0439 \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u0441\u043B\u043E\u0436\u043D\u043E\u0439 \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0439
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u0435
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E
    \u043D\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C, \u043D\u0438 \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u044C.
    \u042D\u0442\u043E \u043D\u0430\u043D\u0435\u0441\u043B\u043E \u0441\u043E\u043A\u0440\u0443\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0443\u0434\u0430\u0440 \u043F\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0439
    \u0446\u0435\u043B\u0438 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430.  - **\u042D\u043F\u043E\u0445\u0430
    \u043D\u0430\u0446\u0438\u0437\u043C\u0430:** \u041F\u043E\u0441\u043B\u0435
    \u043F\u0440\u0438\u0445\u043E\u0434\u0430 \u043D\u0430\u0446\u0438\u0441\u0442\u043E\u0432
    \u043A \u0432\u043B\u0430\u0441\u0442\u0438 \u0432 1933 \u0433\u043E\u0434\u0443
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D, \u0431\u044B\u0432\u0448\u0438\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0446\u0435\u043D\u0442\u0440 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0431\u044B\u043B \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D. \u041C\u043D\u043E\u0433\u0438\u0435
    \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u0438
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u0431\u044B\u043B\u0438
    \u0443\u0432\u043E\u043B\u0435\u043D\u044B \u0438 \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u0438.
    \u041A\u043E\u0433\u0434\u0430 \u043C\u0438\u043D\u0438\u0441\u0442\u0440 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434 \u0420\u0443\u0441\u0442 \u0441\u043F\u0440\u043E\u0441\u0438\u043B
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430: \xAB\u041A\u0430\u043A
    \u0442\u0435\u043F\u0435\u0440\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435, \u043F\u043E\u0441\u043B\u0435
    \u0442\u043E\u0433\u043E \u043A\u0430\u043A \u043E\u043D\u0430 \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u043B\u0430\u0441\u044C
    \u043E\u0442 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0433\u043E \u0432\u043B\u0438\u044F\u043D\u0438\u044F?\xBB,
    \u0442\u043E\u0442 \u043E\u0442\u0432\u0435\u0442\u0438\u043B: \xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435? \u0415\u0451
    \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435\u0442\xBB. \u0415\u0433\u043E
    \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u044B \u0432 1943 \u0433\u043E\u0434\u0443
    \u043F\u043E\u0441\u0435\u0442\u0438\u043B\u0438 \u043B\u0438\u0448\u044C \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A.  > **\u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0434\u0435\u0432\u0438\u0437:** \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0432\u0441\u0435 \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u044F,
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u043B
    \u043D\u0435\u043F\u043E\u043A\u043E\u043B\u0435\u0431\u0438\u043C\u0443\u044E
    \u0432\u0435\u0440\u0443 \u0432 \u0441\u0438\u043B\u0443 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0440\u0430\u0437\u0443\u043C\u0430. \u0415\u0433\u043E \u0434\u0435\u0432\u0438\u0437\u043E\u043C,
    \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u043D\u044B\u043C \u043D\u0430 \u043C\u043E\u0433\u0438\u043B\u0435,
    \u0441\u0442\u0430\u043B\u0438 \u0441\u043B\u043E\u0432\u0430: **\xABWir m\xFCssen
    wissen. Wir werden wissen\xBB** (\xAB\u041C\u044B \u0434\u043E\u043B\u0436\u043D\u044B
    \u0437\u043D\u0430\u0442\u044C. \u041C\u044B \u0431\u0443\u0434\u0435\u043C \u0437\u043D\u0430\u0442\u044C\xBB)."
  shortBioEn: 
  interestingFactsRu: "\u0414\u0430\u0432\u0438\u0434 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438, \u043D\u043E \u0438 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u0441 \u044F\u0440\u043A\u0438\u043C \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C,
    \u0447\u0442\u043E \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438 \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u0439.
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0438 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435 \u0444\u0430\u043A\u0442\u044B
    \u0438\u0437 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438, \u0441\u043E\u0431\u0440\u0430\u043D\u043D\u044B\u0435
    \u0438\u0437 \u0440\u0430\u0437\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u0432. 
    ### \U0001F9E0 \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u0430\u044F \u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0441\u0442\u044C 
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E\u0433\u0440\u0443\u0436\u0435\u043D \u0432 \u0441\u0432\u043E\u0438
    \u043C\u044B\u0441\u043B\u0438, \u0447\u0442\u043E \u0447\u0430\u0441\u0442\u043E
    \u043D\u0435 \u0437\u0430\u043C\u0435\u0447\u0430\u043B \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u044F\u0449\u0435\u0433\u043E
    \u0432\u043E\u043A\u0440\u0443\u0433, \u0447\u0442\u043E \u0441\u043B\u0443\u0436\u0438\u043B\u043E
    \u043F\u043E\u0432\u043E\u0434\u043E\u043C \u0434\u043B\u044F \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u043A\u043E\u043C\u0438\u0447\u043D\u044B\u0445 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0439. 
    *   **\u0421\u043C\u0435\u043D\u0430 \u0440\u0443\u0431\u0430\u0448\u043A\u0438:**
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B, \u043A\u043E\u0433\u0434\u0430 \u0443
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u0432 \u0441\u043E\u0431\u0440\u0430\u043B\u0438\u0441\u044C
    \u0433\u043E\u0441\u0442\u0438, \u0436\u0435\u043D\u0430 \u041A\u0435\u0442\u0435
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B\u0430, \u0447\u0442\u043E \u0414\u0430\u0432\u0438\u0434
    \u043D\u0430\u0434\u0435\u043B \u043D\u0435\u0441\u0432\u0435\u0436\u0443\u044E
    \u0440\u0443\u0431\u0430\u0448\u043A\u0443. \u041E\u043D\u0430 \u0432\u0435\u043B\u0435\u043B\u0430
    \u0435\u043C\u0443: \xAB\u0414\u0430\u0432\u0438\u0434, \u0441\u0442\u0443\u043F\u0430\u0439
    \u0432\u043D\u0438\u0437 \u0438 \u043D\u0430\u0434\u0435\u043D\u044C \u0434\u0440\u0443\u0433\u0443\u044E
    \u0440\u0443\u0431\u0430\u0448\u043A\u0443\xBB. \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u043F\u043E\u0441\u043B\u0443\u0448\u043D\u043E \u0443\u0448\u0435\u043B \u0432
    \u0441\u043F\u0430\u043B\u044C\u043D\u044E. \u041A\u043E\u0433\u0434\u0430 \u0447\u0435\u0440\u0435\u0437
    \u0434\u0435\u0441\u044F\u0442\u044C \u043C\u0438\u043D\u0443\u0442 \u0436\u0435\u043D\u0430,
    \u043E\u0431\u0435\u0441\u043F\u043E\u043A\u043E\u0435\u043D\u043D\u0430\u044F
    \u0435\u0433\u043E \u0434\u043E\u043B\u0433\u0438\u043C \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435\u043C,
    \u043F\u043E\u0448\u043B\u0430 \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
    \u0435\u0433\u043E, \u043E\u043D\u0430 \u043D\u0430\u0448\u043B\u0430 \u043C\u0443\u0436\u0430...
    \u0431\u0435\u0437\u043C\u044F\u0442\u0435\u0436\u043D\u043E \u0441\u043F\u044F\u0449\u0438\u043C.
    \u0420\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u044B\u0439 \u0443\u0447\u0435\u043D\u044B\u0439
    \u043C\u0435\u0442\u043E\u0434\u0438\u0447\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0441\u044F
    \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0438 \u043B\u0435\u0433 \u0441\u043F\u0430\u0442\u044C,
    \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u044F \u043A\u043E\u043C\u0430\u043D\u0434\u0443
    \u0447\u0438\u0441\u0442\u043E \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438.
    *   **\u0413\u043E\u0441\u0442\u044C \u0432 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
    \u0434\u043E\u043C\u0435:** \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u043D\u043E\u0432\u043E\u0433\u043E
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u0430 \u043A\u0430\u0444\u0435\u0434\u0440\u044B
    \u043F\u0440\u0438\u043D\u044F\u043B\u0438 \u0432 \u0434\u043E\u043C\u0435 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430.
    \u0413\u043E\u0441\u0442\u044C \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043A\u0440\u0430\u0439\u043D\u0435 \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440\u0447\u0438\u0432\u044B\u043C
    \u0438 \u0438\u0437\u0440\u044F\u0434\u043D\u043E \u0443\u0442\u043E\u043C\u0438\u043B
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430. \u0427\u0442\u043E\u0431\u044B
    \u043F\u0440\u0435\u043A\u0440\u0430\u0442\u0438\u0442\u044C \u0437\u0430\u0442\u044F\u043D\u0443\u0432\u0448\u0438\u0439\u0441\u044F
    \u0432\u0438\u0437\u0438\u0442, \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0432\u0441\u0442\u0430\u043B, \u043D\u0430\u0434\u0435\u043B \u0446\u0438\u043B\u0438\u043D\u0434\u0440
    \u0433\u043E\u0441\u0442\u044F, \u0442\u0440\u043E\u043D\u0443\u043B \u0436\u0435\u043D\u0443
    \u0437\u0430 \u0440\u0443\u043A\u0443 \u0438 \u0441\u043A\u0430\u0437\u0430\u043B:
    \xAB\u0414\u043E\u0440\u043E\u0433\u0430\u044F, \u043C\u043D\u0435 \u043A\u0430\u0436\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043C\u044B \u0437\u0430\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u043C
    \u0443\u0432\u0430\u0436\u0430\u0435\u043C\u043E\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0443\xBB.
    \u0421 \u044D\u0442\u0438\u043C\u0438 \u0441\u043B\u043E\u0432\u0430\u043C\u0438
    \u043E\u043D \u0432\u044B\u0448\u0435\u043B \u0438\u0437 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0434\u043E\u043C\u0430, \u043E\u0441\u0442\u0430\u0432\u0438\u0432 \u0438 \u0433\u043E\u0441\u0442\u044F,
    \u0438 \u0436\u0435\u043D\u0443 \u0432 \u043F\u043E\u043B\u043D\u043E\u043C \u043D\u0435\u0434\u043E\u0443\u043C\u0435\u043D\u0438\u0438.
    *   **\u041F\u043E\u0440\u0432\u0430\u043D\u043D\u044B\u0435 \u0431\u0440\u044E\u043A\u0438:**
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u0440\u0435\u0433\u0443\u043B\u044F\u0440\u043D\u043E
    \u043F\u043E\u044F\u0432\u043B\u044F\u043B\u0441\u044F \u0432 \u043F\u043E\u0440\u0432\u0430\u043D\u043D\u044B\u0445
    \u0431\u0440\u044E\u043A\u0430\u0445, \u0447\u0442\u043E \u0441\u043C\u0443\u0449\u0430\u043B\u043E
    \u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433. \u0417\u0430\u0434\u0430\u0447\u0443
    \u0434\u0435\u043B\u0438\u043A\u0430\u0442\u043D\u043E \u0441\u043E\u043E\u0431\u0449\u0438\u0442\u044C
    \u0435\u043C\u0443 \u043E\u0431 \u044D\u0442\u043E\u043C \u0432\u043E\u0437\u043B\u043E\u0436\u0438\u043B\u0438
    \u043D\u0430 \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u0430 \u0420\u0438\u0445\u0430\u0440\u0434\u0430
    \u041A\u0443\u0440\u0430\u043D\u0442\u0430. \u041A\u0443\u0440\u0430\u043D\u0442
    \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u043D\u0430 \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0443, \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u043F\u0440\u043E\u0439\u0434\u044F \u0447\u0435\u0440\u0435\u0437 \u0437\u0430\u0440\u043E\u0441\u043B\u0438
    \u043A\u043E\u043B\u044E\u0447\u0438\u0445 \u043A\u0443\u0441\u0442\u043E\u0432,
    \u0438 \u0441\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u043F\u043E\u0440\u0432\u0430\u043B
    \u0431\u0440\u044E\u043A\u0438 \u043E\u0431 \u043E\u0434\u0438\u043D \u0438\u0437
    \u043D\u0438\u0445. \u041D\u0430 \u044D\u0442\u043E \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u043D\u0435\u0432\u043E\u0437\u043C\u0443\u0442\u0438\u043C\u043E \u043E\u0442\u0432\u0435\u0442\u0438\u043B:
    \xAB\u0414\u0430 \u043D\u0435\u0442 \u0436\u0435, \u043E\u043D\u0438 \u0442\u0430\u043A\u0438\u0435
    \u0443\u0436\u0435 \u043D\u0435 \u043E\u0434\u043D\u0443 \u043D\u0435\u0434\u0435\u043B\u044E,
    \u0445\u043E\u0442\u044F \u043D\u0438\u043A\u0442\u043E \u044D\u0442\u043E\u0433\u043E
    \u0438 \u043D\u0435 \u0437\u0430\u043C\u0435\u0447\u0430\u0435\u0442\xBB.  ###
    \U0001F4D0 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u043A\u0430\u043A
    \u043F\u043E\u044D\u0437\u0438\u044F (\u0438 \u043D\u0430\u043E\u0431\u043E\u0440\u043E\u0442) 
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u043E\u0431\u043B\u0430\u0434\u0430\u043B
    \u043E\u0441\u043E\u0431\u044B\u043C \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C
    \u044E\u043C\u043E\u0440\u0430, \u043A\u043E\u0433\u0434\u0430 \u0440\u0435\u0447\u044C
    \u0437\u0430\u0445\u043E\u0434\u0438\u043B\u0430 \u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0435.  *   **\u041E
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0435, \u0441\u0442\u0430\u0432\u0448\u0435\u043C
    \u043F\u043E\u044D\u0442\u043E\u043C:** \u041A\u043E\u0433\u0434\u0430 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B \u043F\u043E\u044F\u0432\u043B\u044F\u0442\u044C\u0441\u044F
    \u043D\u0430 \u0437\u0430\u043D\u044F\u0442\u0438\u044F\u0445, \u0432\u044B\u044F\u0441\u043D\u0438\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u043E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u0447\u0442\u043E\u0431\u044B \u0441\u0442\u0430\u0442\u044C \u043F\u043E\u044D\u0442\u043E\u043C.
    \u0423\u0437\u043D\u0430\u0432 \u043E\u0431 \u044D\u0442\u043E\u043C, \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B: \xAB\u041D\u0435 \u043C\u043E\u0433\u0443
    \u0441\u043A\u0430\u0437\u0430\u0442\u044C, \u0447\u0442\u043E \u044F \u0443\u0434\u0438\u0432\u043B\u0435\u043D.
    \u041C\u043D\u0435 \u0432\u0441\u0435\u0433\u0434\u0430 \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u0443 \u043D\u0435\u0433\u043E \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F, \u0447\u0442\u043E\u0431\u044B
    \u0441\u0442\u0430\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C\xBB.
    \u042D\u0442\u043E\u0442 \u0430\u0444\u043E\u0440\u0438\u0437\u043C \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E
    \u043E\u0442\u0440\u0430\u0436\u0430\u0435\u0442 \u0435\u0433\u043E \u0432\u0435\u0440\u0443
    \u0432 \u0442\u043E, \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u2014 \u0432\u044B\u0441\u0448\u0430\u044F \u0444\u043E\u0440\u043C\u0430 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430.
    *   **\u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430 \u0420\u0438\u043C\u0430\u043D\u0430
    \u043D\u0430 \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0430\u0445:** \u0423
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u0431\u044B\u043B \u0441\u0442\u0443\u0434\u0435\u043D\u0442,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B
    \u0435\u043C\u0443 \u0440\u0430\u0431\u043E\u0442\u0443 \u0441 \u043F\u0440\u0435\u0442\u0435\u043D\u0437\u0438\u0435\u0439
    \u043D\u0430 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0413\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u0420\u0438\u043C\u0430\u043D\u0430.
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u043D\u0430\u0448\u0435\u043B
    \u0432 \u043D\u0435\u0439 \u043E\u0448\u0438\u0431\u043A\u0443, \u043D\u043E
    \u0431\u044B\u043B \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D \u0433\u043B\u0443\u0431\u0438\u043D\u043E\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434\u0430. \u041D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
    \u0433\u043E\u0434 \u0441\u0442\u0443\u0434\u0435\u043D\u0442 \u0443\u043C\u0435\u0440.
    \u041D\u0430 \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0430\u0445, \u0441\u0442\u043E\u044F
    \u043F\u043E\u0434 \u0434\u043E\u0436\u0434\u0435\u043C, \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441 \u0440\u0435\u0447\u044C. \u041E\u043D
    \u043D\u0430\u0447\u0430\u043B \u0441 \u0442\u043E\u0433\u043E, \u0447\u0442\u043E
    \u044D\u0442\u043E \u0431\u043E\u043B\u044C\u0448\u0430\u044F \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F,
    \u043D\u043E \u0437\u0430\u0442\u0435\u043C \u0441 \u044D\u043D\u0442\u0443\u0437\u0438\u0430\u0437\u043C\u043E\u043C
    \u0432\u043E\u0441\u043A\u043B\u0438\u043A\u043D\u0443\u043B: \xAB\u0418 \u0432
    \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435, \u0440\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0438\u043C
    \u0444\u0443\u043D\u043A\u0446\u0438\u044E \u043E\u0434\u043D\u043E\u0439 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E\u0439
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439...\xBB \u2014 \u0438
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u0438\u0437\u043B\u0430\u0433\u0430\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0438\u0434\u0435\u044E \u043F\u0440\u044F\u043C\u043E \u043D\u0430\u0434 \u043C\u043E\u0433\u0438\u043B\u043E\u0439. 
    ### \U0001F5E3\uFE0F \u041E\u0441\u0442\u0440\u044B\u0435 \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043D\u0438\u044F
    \u0438 \u043E\u0442\u0432\u0435\u0442\u044B  \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0435\u0439
    \u043F\u0440\u044F\u043C\u043E\u0442\u043E\u0439 \u0438 \u0430\u0444\u043E\u0440\u0438\u0441\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u044C\u044E. 
    *   **\u041E\u0442\u0432\u0435\u0442 \u043D\u0430\u0446\u0438\u0441\u0442\u0441\u043A\u043E\u043C\u0443
    \u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0443:** \u041F\u043E\u0441\u043B\u0435
    \u043F\u0440\u0438\u0445\u043E\u0434\u0430 \u043A \u0432\u043B\u0430\u0441\u0442\u0438
    \u043D\u0430\u0446\u0438\u0441\u0442\u043E\u0432 \u0432 1933 \u0433\u043E\u0434\u0443
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0431\u044B\u043B
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D:
    \u043C\u043D\u043E\u0433\u0438\u0445 \u043A\u043E\u043B\u043B\u0435\u0433-\u0435\u0432\u0440\u0435\u0435\u0432
    \u0443\u0432\u043E\u043B\u0438\u043B\u0438 \u0438 \u0432\u044B\u043D\u0443\u0434\u0438\u043B\u0438
    \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C. \u041E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043C\u0438\u043D\u0438\u0441\u0442\u0440 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434 \u0420\u0443\u0441\u0442 \u0441\u043F\u0440\u043E\u0441\u0438\u043B
    \u0443 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430: \xAB\u041A\u0430\u043A
    \u0442\u0435\u043F\u0435\u0440\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435, \u043F\u043E\u0441\u043B\u0435
    \u0442\u043E\u0433\u043E \u043A\u0430\u043A \u043E\u043D\u0430 \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u043B\u0430\u0441\u044C
    \u043E\u0442 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0433\u043E \u0432\u043B\u0438\u044F\u043D\u0438\u044F?\xBB
    \u041D\u0430 \u044D\u0442\u043E \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0443\u043D\u044B\u043B\u043E \u043E\u0442\u0432\u0435\u0442\u0438\u043B: \xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435? \u0415\u0451
    \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435\u0442\xBB. *   **\xAB\u042D\u0442\u043E
    \u043D\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430, \u044D\u0442\u043E
    \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044F\xBB:** \u0412 1888 \u0433\u043E\u0434\u0443
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0441\u0432\u043E\u044E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u043E \u0431\u0430\u0437\u0438\u0441\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B\u0430
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435,
    \u043D\u043E \u043D\u0435 \u0434\u0430\u0432\u0430\u043B\u0430 \u0441\u043F\u043E\u0441\u043E\u0431\u0430
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F. \u041F\u0430\u0443\u043B\u044C
    \u0413\u043E\u0440\u0434\u0430\u043D, \u0432\u0435\u0434\u0443\u0449\u0438\u0439
    \u044D\u043A\u0441\u043F\u0435\u0440\u0442 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432, \u043D\u0435
    \u043F\u0440\u0438\u043D\u044F\u043B \u0442\u0430\u043A\u043E\u0439 \u043F\u043E\u0434\u0445\u043E\u0434
    \u0438 \u0432\u043E\u0441\u043A\u043B\u0438\u043A\u043D\u0443\u043B: \xAB\u042D\u0442\u043E
    \u043D\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430. \u042D\u0442\u043E
    \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044F!\xBB. \u041F\u043E\u0437\u0436\u0435,
    \u043F\u0440\u0438\u0437\u043D\u0430\u0432 \u0441\u0438\u043B\u0443 \u043C\u0435\u0442\u043E\u0434\u0430
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430, \u0413\u043E\u0440\u0434\u0430\u043D
    \u0441\u043C\u044F\u0433\u0447\u0438\u043B\u0441\u044F \u0438 \u0441\u043A\u0430\u0437\u0430\u043B:
    \xAB\u042F \u0443\u0431\u0435\u0434\u0438\u043B\u0441\u044F, \u0447\u0442\u043E
    \u0434\u0430\u0436\u0435 \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044F \u0438\u043C\u0435\u0435\u0442
    \u0441\u0432\u043E\u0438 \u0437\u0430\u0441\u043B\u0443\u0433\u0438\xBB.  ###
    \U0001F48E \u041D\u0435\u0438\u0437\u043C\u0435\u043D\u043D\u044B\u0439 \u043E\u043F\u0442\u0438\u043C\u0438\u0437\u043C
    \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  *   **\u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u0420\u0438\u043C\u0430\u043D\u0430 \u0447\u0435\u0440\u0435\u0437 500 \u043B\u0435\u0442:**
    \u041D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441 \u043D\u0430\u0437\u043E\u0439\u043B\u0438\u0432\u043E\u0433\u043E
    \u0436\u0443\u0440\u043D\u0430\u043B\u0438\u0441\u0442\u0430 \u043E \u0442\u043E\u043C,
    \u0447\u0442\u043E \u0431\u044B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0441\u0434\u0435\u043B\u0430\u043B, \u0435\u0441\u043B\u0438 \u0431\u044B \u043E\u0436\u0438\u043B
    \u0447\u0435\u0440\u0435\u0437 \u043F\u044F\u0442\u044C\u0441\u043E\u0442 \u043B\u0435\u0442,
    \u043E\u043D \u043D\u0435 \u0437\u0430\u0434\u0443\u043C\u044B\u0432\u0430\u044F\u0441\u044C
    \u043E\u0442\u0432\u0435\u0442\u0438\u043B: \xAB\u042F \u0441\u043F\u0440\u043E\u0441\u0438\u043B
    \u0431\u044B, \u043D\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u043B\u0438
    \u043A\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u0420\u0438\u043C\u0430\u043D\u0430?\xBB. \u042D\u0442\u0430 \u0444\u0440\u0430\u0437\u0430
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442, \u0447\u0442\u043E
    \u043E\u043D \u0441\u0447\u0438\u0442\u0430\u043B \u044D\u0442\u0443 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0432\u0430\u0436\u043D\u044B\u0445
    \u0438 \u0434\u043E\u043B\u0433\u043E\u0441\u0440\u043E\u0447\u043D\u044B\u0445
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. *   **\u0414\u0435\u0432\u0438\u0437
    \u043D\u0430 \u043C\u043E\u0433\u0438\u043B\u0435:** \u0421\u0430\u043C\u044B\u043C
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C \u0430\u0444\u043E\u0440\u0438\u0437\u043C\u043E\u043C
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u0441\u0442\u0430\u043B\u0438
    \u0441\u043B\u043E\u0432\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438
    \u043E\u043D \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B \u0441\u0432\u043E\u044E
    \u0440\u0435\u0447\u044C \u0432 1930 \u0433\u043E\u0434\u0443: **\xABWir m\xFCssen
    wissen. Wir werden wissen\xBB** \u2014 \xAB\u041C\u044B \u0434\u043E\u043B\u0436\u043D\u044B
    \u0437\u043D\u0430\u0442\u044C. \u041C\u044B \u0431\u0443\u0434\u0435\u043C \u0437\u043D\u0430\u0442\u044C\xBB.
    \u042D\u0442\u0430 \u0444\u0440\u0430\u0437\u0430, \u0432\u044B\u0440\u0430\u0436\u0430\u044E\u0449\u0430\u044F
    \u0435\u0433\u043E \u043D\u0435\u043F\u043E\u043A\u043E\u043B\u0435\u0431\u0438\u043C\u0443\u044E
    \u0432\u0435\u0440\u0443 \u0432 \u0441\u0438\u043B\u0443 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0440\u0430\u0437\u0443\u043C\u0430, \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u0430
    \u043D\u0430 \u0435\u0433\u043E \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u043D\u043E\u043C
    \u043A\u0430\u043C\u043D\u0435 \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435. 
    \u042D\u0442\u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u0440\u0438\u0441\u0443\u044E\u0442
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043A\u0430\u043A \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E, \u043D\u043E \u0438 \u043A\u0430\u043A
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C
    \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u043C \u043C\u0438\u0440\u043E\u043C,
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u0438 \u043D\u0435\u043F\u043E\u0432\u0442\u043E\u0440\u0438\u043C\u044B\u043C
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C \u044E\u043C\u043E\u0440\u0430."
