  achievementsRu: "\u0411\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E,
    \u0432\u043A\u043B\u0430\u0434 \u0414\u0430\u0432\u0438\u0434\u0430 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u0432 \u043D\u0430\u0443\u043A\u0443 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0431\u0448\u0438\u0440\u0435\u043D \u0438 \u0433\u043B\u0443\u0431\u043E\u043A,
    \u0447\u0442\u043E \u0435\u0433\u043E \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0441\u0447\u0438\u0442\u0430\u044E\u0442 \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0445 \u0432\u0435\u043B\u0438\u043A\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432-\u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u043E\u0432.
    \u041E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0435\u0448\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438
    \u2014 \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B \u0446\u0435\u043B\u044B\u0435
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F, \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0438\u0432\u0430\u043B
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D
    \u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u043B \u043F\u0443\u0442\u0438
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u0432\u043F\u0435\u0440\u0435\u0434. \u0415\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u043E\u0441\u043B\u0435\u0434\u0438\u0442\u044C
    \u043E\u0442 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0434\u043E \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438.  \u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439
    \u043E\u0431\u0437\u043E\u0440 \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439, \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043F\u043E \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C \u043D\u0430\u0443\u043A\u0438. 
    ### \U0001F4D0 \u041E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0438 \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0435\u0442\u043E\u0434  \u0412 1899 \u0433\u043E\u0434\u0443 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u0439
    \u0442\u0440\u0443\u0434 \xAB\u041E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB (Grundlagen der Geometrie),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0432 \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0438
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u0435\u0442\u043E\u0434\u0430 \u0432 \u0446\u0435\u043B\u043E\u043C. 
    *   **\u041D\u043E\u0432\u044B\u0439 \u0432\u0437\u0433\u043B\u044F\u0434 \u043D\u0430
    \u0430\u043A\u0441\u0438\u043E\u043C\u044B:** \u041E\u043D \u043F\u0435\u0440\u0432\u044B\u043C
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u043F\u043E\u043F\u044B\u0442\u043E\u043A \u0434\u0430\u0432\u0430\u0442\u044C
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u043C
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F\u043C (\u0442\u043E\u0447\u043A\u0430,
    \u043F\u0440\u044F\u043C\u0430\u044F, \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u044C).
    \u0414\u043B\u044F \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u0430\u043A\u0441\u0438\u043E\u043C\u044B
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043E\u0447\u0435\u0432\u0438\u0434\u043D\u044B\u0435
    \u0438\u0441\u0442\u0438\u043D\u044B, \u0430 \u043D\u0435\u044F\u0432\u043D\u044B\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F, \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F, \u043D\u0430\u043B\u0430\u0433\u0430\u0435\u043C\u044B\u0435
    \u043D\u0430 \u044D\u0442\u0438 \u043F\u043E\u043D\u044F\u0442\u0438\u044F. \u042D\u0442\u043E
    \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E, \u0447\u0442\u043E \u0432\u043C\u0435\u0441\u0442\u043E
    \xAB\u0442\u043E\u0447\u043A\u0430 \u2014 \u044D\u0442\u043E \u0442\u043E, \u0447\u0442\u043E
    \u043D\u0435 \u0438\u043C\u0435\u0435\u0442 \u0447\u0430\u0441\u0442\u0435\u0439\xBB,
    \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0430\u043A\u0441\u0438\u043E\u043C\u0443 \xAB\u0447\u0435\u0440\u0435\u0437
    \u043B\u044E\u0431\u044B\u0435 \u0434\u0432\u0435 \u0442\u043E\u0447\u043A\u0438
    \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u043E\u0432\u0435\u0441\u0442\u0438
    \u0440\u043E\u0432\u043D\u043E \u043E\u0434\u043D\u0443 \u043F\u0440\u044F\u043C\u0443\u044E\xBB.
    *   **\u041F\u043E\u043B\u043D\u043E\u0442\u0430 \u0438 \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0441\u0442\u044C:**
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u0434\u0430\u043B \u043F\u043E\u043B\u043D\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0430\u043A\u0441\u0438\u043E\u043C
    \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0438, \u0447\u0442\u043E \u043D\u0435 \u043C\u0435\u043D\u0435\u0435 \u0432\u0430\u0436\u043D\u043E,
    \u0441\u0442\u0440\u043E\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0438\u0445 \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0441\u0442\u044C
    \u0438 \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u044C
    \u0434\u0440\u0443\u0433 \u043E\u0442 \u0434\u0440\u0443\u0433\u0430. \u0414\u043B\u044F
    \u044D\u0442\u043E\u0433\u043E \u043E\u043D \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    \u0440\u044F\u0434 \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u044B\u0445
    \u043C\u043E\u0434\u0435\u043B\u0435\u0439 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043C\u043E\u0434\u0435\u043B\u044C), \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0449\u0438\u0445,
    \u0447\u0442\u043E \u043E\u0434\u043D\u0443 \u0430\u043A\u0441\u0438\u043E\u043C\u0443
    \u043D\u0435\u043B\u044C\u0437\u044F \u0432\u044B\u0432\u0435\u0441\u0442\u0438
    \u0438\u0437 \u0434\u0440\u0443\u0433\u0438\u0445. *   **\u041F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u0435
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430\u043B\u0438\u0437\u043C\u0430:**
    \u0415\u0433\u043E \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434 \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u043C,
    \u0447\u0442\u043E, \u043F\u043E \u0441\u0443\u0442\u0438, \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u043B
    \u0438\u0434\u0435\u0438 \u043C\u0430\u0448\u0438\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0433\u0434\u0435 \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0435
    \u043C\u0430\u043D\u0438\u043F\u0443\u043B\u044F\u0446\u0438\u0438 \u0441 \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u043C\u0438
    \u043C\u043E\u0433\u0443\u0442 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0442\u044C\u0441\u044F
    \u0431\u0435\u0437 \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u0438\u0445
    \xAB\u0441\u043C\u044B\u0441\u043B\u0430\xBB.  ### \U0001F9EE \u0422\u0435\u043E\u0440\u0438\u044F
    \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432 \u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0447\u0438\u0441\u043B\u0430  \u041D\u0430\u0447\u0430\u043B\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u043F\u0443\u0442\u0438 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u0431\u044B\u043B\u043E \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432
    \u2014 \u043E\u0431\u043B\u0430\u0441\u0442\u0438, \u0438\u0437\u0443\u0447\u0430\u044E\u0449\u0435\u0439
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u043E\u0440\u043C, \u043D\u0435 \u043C\u0435\u043D\u044F\u044E\u0449\u0438\u0435\u0441\u044F
    \u043F\u0440\u0438 \u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0445 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F\u0445. 
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438
    \u0431\u0430\u0437\u0438\u0441\u0430:** \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C \u0437\u0434\u0435\u0441\u044C
    \u0441\u0442\u0430\u043B\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \xAB\u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B\xBB
    \u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0438
    \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E \u0431\u0430\u0437\u0438\u0441\u0430
    \u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432. \u042D\u0442\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0431\u044B\u043B\u043E \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u043C,
    \u043D\u043E \u043D\u0435\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u043C:
    \u043E\u043D\u043E \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B\u043E
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435,
    \u043D\u043E \u043D\u0435 \u0434\u0430\u0432\u0430\u043B\u043E \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0430
    \u0434\u043B\u044F \u0435\u0433\u043E \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F.
    \u042D\u0442\u043E \u0432\u044B\u0437\u0432\u0430\u043B\u043E \u043A\u0440\u0438\u0442\u0438\u043A\u0443
    \u0441\u0442\u0430\u0440\u0448\u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u041F\u043E\u043B\u044F \u0413\u043E\u0440\u0434\u0430\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u043E\u0441\u043A\u043B\u0438\u043A\u043D\u0443\u043B: \xAB\u042D\u0442\u043E
    \u043D\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430, \u0430
    \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044F!\xBB \u041E\u0434\u043D\u0430\u043A\u043E
    \u043F\u043E\u0437\u0436\u0435 \u043E\u043D \u043F\u0440\u0438\u0437\u043D\u0430\u043B
    \u0437\u043D\u0430\u0447\u0438\u043C\u043E\u0441\u0442\u044C \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430.
    *   **\xAB\u041E\u0442\u0447\u0451\u0442 \u043E \u0447\u0438\u0441\u043B\u0430\u0445\xBB
    (Zahlbericht):** \u0412 1897 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u043E\u0431\u0437\u043E\u0440 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0432\u0441\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435 \u043D\u0430
    \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442 \u0437\u043D\u0430\u043D\u0438\u044F
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0438
    \u0441\u0442\u0430\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C
    \u0442\u0440\u0443\u0434\u043E\u043C \u043D\u0430 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0433\u043E\u0434\u044B.  ### \U0001F4CA \u0424\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0438 \xAB\u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u0432\u043E
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E\xBB 
    \u0412 \u043D\u0430\u0447\u0430\u043B\u0435 XX \u0432\u0435\u043A\u0430 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u043E\u0431\u0440\u0430\u0442\u0438\u043B\u0441\u044F \u043A \u0442\u0435\u043E\u0440\u0438\u0438
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439.
    \u0418\u0442\u043E\u0433\u043E\u043C \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441\u0442\u0430\u043B\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u043D\u043E\u0432\u043E\u0433\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u2014 \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430.  *   **\u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \xAB\u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u0432\u0430 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430\xBB:**
    \u0420\u0430\u0431\u043E\u0442\u0430\u044F \u0441 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C\u0438, \u043E\u043D
    \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430, \u0433\u0434\u0435
    \u0442\u043E\u0447\u043A\u0438 \u2014 \u044D\u0442\u043E \u0444\u0443\u043D\u043A\u0446\u0438\u0438,
    \u0430 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u0442\u0441\u044F
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u043C. \u042D\u0442\u043E
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E, \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u043E\u0435
    \u043F\u043E\u0437\u0436\u0435 **\u0433\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u0432\u044B\u043C**,
    \u0441\u0442\u0430\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u0432\u0441\u0435\u0439 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438 \u0438 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438. *   **\u0421\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F:** \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0441\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u0443\u044E \u0442\u0435\u043E\u0440\u0438\u044E
    \u0434\u043B\u044F \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u044B\u0445
    \u043E\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u043E\u0432 \u0432 \u0433\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u0432\u043E\u043C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435, \u0447\u0442\u043E
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C \xAB\u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F\xBB \u0438 \xAB\u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438\xBB \u0434\u043B\u044F \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432. *   **\u0420\u0435\u0448\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0412\u0430\u0440\u0438\u043D\u0433\u0430:**
    \u0412 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443 \u0412\u0430\u0440\u0438\u043D\u0433\u0430,
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044E\u0449\u0443\u044E, \u0447\u0442\u043E
    \u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0433\u043E \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    `n` \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0442\u0430\u043A\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E `g(n)`, \u0447\u0442\u043E \u043B\u044E\u0431\u043E\u0435
    \u0446\u0435\u043B\u043E\u0435 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u043A\u0430\u043A \u0441\u0443\u043C\u043C\u0443 \u043D\u0435 \u0431\u043E\u043B\u0435\u0435
    \u0447\u0435\u043C `g(n)` \u0441\u043B\u0430\u0433\u0430\u0435\u043C\u044B\u0445,
    \u043A\u0430\u0436\u0434\u043E\u0435 \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F `n`-\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u044C\u044E
    \u0434\u0440\u0443\u0433\u043E\u0433\u043E \u0447\u0438\u0441\u043B\u0430.  ###
    \u269B\uFE0F \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u0438\u0437\u0438\u043A\u0430  \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u0444\u0438\u0437\u0438\u043A\u0430,
    \u043A\u0430\u043A \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F,
    \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u0442\u044C \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0430
    \u043D\u0430 \u0441\u0442\u0440\u043E\u0433\u043E\u0439 \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u0441\u043D\u043E\u0432\u0435.  *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438:**
    \u0415\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441 \u043A \u0444\u0438\u0437\u0438\u043A\u0435
    \u0431\u044B\u043B \u043D\u0435 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u043C.
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u0440\u0430\u0431\u043E\u0442\u044B
    \u0410\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430
    \u043D\u0430\u0434 \u043E\u0431\u0449\u0435\u0439 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0438\u0440\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0438 \u043F\u043E\u043C\u043E\u0433\u0430\u043B \u0432 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u0430 \u2014 \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u043C\u0435\u0440\u043D\u043E\u0433\u043E
    \u0442\u0435\u043D\u0437\u043E\u0440\u043D\u043E\u0433\u043E \u0430\u043D\u0430\u043B\u0438\u0437\u0430.
    *   **\u0410\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u044F
    \u0444\u0438\u0437\u0438\u043A\u0438:** \u041E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u043F\u0440\u0438\u0437\u044B\u0432\u0430\u043B \u043A \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u0438
    \u0432\u0441\u0435\u0439 \u0444\u0438\u0437\u0438\u043A\u0438, \u0447\u0442\u043E
    \u043D\u0430\u0448\u043B\u043E \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0432 \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    6-\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0435. \u0425\u043E\u0442\u044F
    \u043F\u043E\u043B\u043D\u0430\u044F \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u044F
    \u0432\u0441\u0435\u0439 \u0444\u0438\u0437\u0438\u043A\u0438 \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440 \u043D\u0435 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0430,
    \u0435\u0433\u043E \u043F\u0440\u0438\u0437\u044B\u0432 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u043B
    \u043D\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0431\u0430\u0437 \u0434\u043B\u044F \u0442\u0435\u0440\u043C\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438,
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438,
    \u0430 \u043F\u043E\u0437\u0436\u0435 \u0438 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438 (\u0414\u0436\u043E\u043D \u0444\u043E\u043D
    \u041D\u0435\u0439\u043C\u0430\u043D) \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439 (\u0410\u043D\u0434\u0440\u0435\u0439
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432).  ### \U0001F4A1
    \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430 
    \u0421\u0430\u043C\u043E\u0439 \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u043E\u0439,
    \u0445\u043E\u0442\u044C \u0438 \u0432 \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C
    \u0438\u0442\u043E\u0433\u0435 \u043D\u0435\u0443\u0434\u0430\u0432\u0448\u0435\u0439\u0441\u044F,
    \u0446\u0435\u043B\u044C\u044E \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u0431\u044B\u043B\u0430 \u0437\u0430\u0449\u0438\u0442\u0430 \u0432\u0441\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043E\u0442 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0445
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0439. \u0412
    1920-\u0435 \u0433\u043E\u0434\u044B \u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0441\u0432\u043E\u044E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443.  *   **\u0426\u0435\u043B\u044C
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B:** \u041E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0438 \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u0442\u044C
    \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0441\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0414\u043B\u044F
    \u044D\u0442\u043E\u0433\u043E \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B:    
    1.  \u0424\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u0442\u044C
    \u0432\u0441\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0432 \u0435\u0451 \u0432 \u0438\u0433\u0440\u0443
    \u0441 \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u043C\u0438 \u043F\u043E \u0441\u0442\u0440\u043E\u0433\u0438\u043C
    \u043F\u0440\u0430\u0432\u0438\u043B\u0430\u043C (\u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0430\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430).     2.  \u0421 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \xAB\u0444\u0438\u043D\u0438\u0442\u043D\u044B\u0445\xBB (\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445
    \u0438 \u043D\u0430\u0433\u043B\u044F\u0434\u043D\u044B\u0445) \u043C\u0435\u0442\u0430\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u0435\u0442\u043E\u0434\u043E\u0432 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
    \u0447\u0442\u043E \u0432 \u044D\u0442\u043E\u0439 \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u0432\u044B\u0432\u0435\u0441\u0442\u0438
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u0435\u0433\u043E
    \u043E\u0442\u0440\u0438\u0446\u0430\u043D\u0438\u0435. *   **\u041A\u0440\u0443\u0448\u0435\u043D\u0438\u0435
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u044F:**
    \u0412 1931 \u0433\u043E\u0434\u0443 \u043C\u043E\u043B\u043E\u0434\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A \u041A\u0443\u0440\u0442 \u0413\u0451\u0434\u0435\u043B\u044C
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u0438
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u043D\u0435\u043F\u043E\u043B\u043D\u043E\u0442\u0435,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0430\u043D\u0435\u0441\u043B\u0438
    \u0441\u043E\u043A\u0440\u0443\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0443\u0434\u0430\u0440 \u043F\u043E \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0435
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430. \u0413\u0451\u0434\u0435\u043B\u044C
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0432 \u043B\u044E\u0431\u043E\u0439
    \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E \u0441\u043B\u043E\u0436\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0443, \u0435\u0441\u0442\u044C
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432 \u0440\u0430\u043C\u043A\u0430\u0445 \u044D\u0442\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u043D\u0435\u043B\u044C\u0437\u044F \u043D\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
    \u043D\u0438 \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u044C.
    \u0421\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u0435\u0451 \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0441\u0442\u044C
    \u0435\u0451 \u0436\u0435 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430\u043C\u0438 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E.
    *   **\u041D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0435 \u043F\u043B\u043E\u0434\u044B:**
    \u0425\u043E\u0442\u044F \u0433\u043B\u0430\u0432\u043D\u0430\u044F \u0446\u0435\u043B\u044C
    \u0431\u044B\u043B\u0430 \u043D\u0435\u0434\u043E\u0441\u0442\u0438\u0436\u0438\u043C\u0430,
    \u0441\u0430\u043C\u0430 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u0434\u0430\u043B\u0430
    \u0442\u043E\u043B\u0447\u043E\u043A \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432,
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432
    \u0438 \u0432\u0441\u0435\u0439 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438.  ### \U0001F30D 23 \u041F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430  \u0415\u0433\u043E \u0434\u043E\u043A\u043B\u0430\u0434
    \u043D\u0430 \u0412\u0442\u043E\u0440\u043E\u043C \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u043C
    \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u0432 1900 \u0433\u043E\u0434\u0443
    \u0441\u0442\u0430\u043B, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0441\u0430\u043C\u044B\u043C
    \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u043C \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u043D\u044B\u043C
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u041E\u043D \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B
    \u0441\u043F\u0438\u0441\u043E\u043A \u0438\u0437 23 \u043D\u0435\u0440\u0435\u0448\u0435\u043D\u043D\u044B\u0445
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0435,
    \u043F\u043E \u0435\u0433\u043E \u043C\u043D\u0435\u043D\u0438\u044E, \u0434\u043E\u043B\u0436\u043D\u044B
    \u0431\u044B\u043B\u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043D\u0430 XX \u0432\u0435\u043A.  \u042D\u0442\u043E\u0442 \u0441\u043F\u0438\u0441\u043E\u043A
    \u0441\u0442\u0430\u043B \xAB\u043F\u0443\u0442\u0435\u0432\u043E\u0434\u043D\u043E\u0439
    \u043A\u0430\u0440\u0442\u043E\u0439\xBB \u0434\u043B\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
