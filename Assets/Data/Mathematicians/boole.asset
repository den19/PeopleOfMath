    \u043C\u0435\u0442\u043E\u0434 \u0434\u043B\u044F \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F
    \u043E\u0431\u0449\u0435\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u0430 \u0432
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.
    \u0415\u0433\u043E \u0446\u0435\u043B\u044C \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0430\u0441\u044C
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E\u0431\u044B \u043F\u043E \u0437\u0430\u0434\u0430\u043D\u043D\u044B\u043C
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u044F\u043C \u043E\u0434\u043D\u0438\u0445
    \u0441\u043E\u0431\u044B\u0442\u0438\u0439 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442\u044C
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u044C \u043B\u044E\u0431\u043E\u0433\u043E
    \u0434\u0440\u0443\u0433\u043E\u0433\u043E \u0441\u043E\u0431\u044B\u0442\u0438\u044F,
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u0441 \u043D\u0438\u043C\u0438
    \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0433\u043E.  ### \U0001F4A1
    \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043E\u043D \u043D\u0435 \u043C\u043E\u0433 \u043F\u0440\u0435\u0434\u0432\u0438\u0434\u0435\u0442\u044C 
    \u041F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u0411\u0443\u043B\u044C \u0432\u0440\u044F\u0434
    \u043B\u0438 \u043C\u043E\u0433 \u0432\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0442\u044C,
    \u043A \u043A\u0430\u043A\u0438\u043C \u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u044F\u043C
    \u043F\u0440\u0438\u0432\u0435\u0434\u0451\u0442 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u043D\u0430 \u0440\u0443\u0431\u0435\u0436\u0435
    XIX\u2013XX \u0432\u0435\u043A\u043E\u0432 \u0444\u0438\u0437\u0438\u043A\u0438
    \u043D\u0430\u0447\u0430\u043B\u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C
    \u0435\u0433\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0443 \u0434\u043B\u044F
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0441\u0445\u0435\u043C. \u0410 \u0432 \u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0435
    XX \u0432\u0435\u043A\u0430 \u0431\u0443\u043B\u0435\u0432\u0430 \u0430\u043B\u0433\u0435\u0431\u0440\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0446\u0438\u0444\u0440\u043E\u0432\u044B\u0445 \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u043D\u044B\u0445
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u0432, \u0442\u0430\u043A
    \u043A\u0430\u043A \u0434\u0432\u0430 \u0435\u0451 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    (`\u0418\u0421\u0422\u0418\u041D\u0410`/`\u041B\u041E\u0416\u042C`, `1`/`0`)
    \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u0434\u0432\u0443\u043C \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044F\u043C
    \u0442\u0440\u0430\u043D\u0437\u0438\u0441\u0442\u043E\u0440\u0430 (\u0432\u043A\u043B\u044E\u0447\u0435\u043D\u043E/\u0432\u044B\u043A\u043B\u044E\u0447\u0435\u043D\u043E).
    \u0418\u043C\u0435\u043D\u043D\u043E \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \u043C\u044B \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C
    \u0442\u0430\u043A\u0438\u0435 \u0442\u0435\u0440\u043C\u0438\u043D\u044B, \u043A\u0430\u043A
    \xAB\u0431\u0443\u043B\u0435\u0432\u0430 \u043B\u043E\u0433\u0438\u043A\u0430\xBB
    \u0438 \xAB\u0431\u0443\u043B\u0435\u0432\u044B \u043E\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u044B\xBB
    \u0432 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438
    \u0438 \u043F\u043E\u0438\u0441\u043A\u043E\u0432\u044B\u0445 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0445."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0414\u0436\u043E\u0440\u0434\u0436\u0430 \u0411\u0443\u043B\u044F, \u043F\u0440\u0438
    \u0432\u0441\u0435\u0439 \u0435\u0451 \u0432\u043D\u0435\u0448\u043D\u0435\u0439
    \u0431\u043B\u0430\u0433\u043E\u043F\u0440\u0438\u0441\u0442\u043E\u0439\u043D\u043E\u0441\u0442\u0438,
    \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439 \u0438 \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u043E\u0439
    \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u044C\u044E,
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438 \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C\u0438
    \u0438 \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430 \u043F\u043E\u0441\u043B\u0435
    \u0441\u0435\u0431\u044F \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0432 \u043B\u0438\u0446\u0435
    \u0435\u0433\u043E \u0436\u0435\u043D\u044B \u0438 \u0434\u043E\u0447\u0435\u0440\u0435\u0439. 
    ### \U0001F496 \u0418\u0441\u0442\u043E\u0440\u0438\u044F \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u0430
    \u0438 \u0431\u0440\u0430\u043A\u0430  \u0412 1849 \u0433\u043E\u0434\u0443,
    \u043F\u043E\u043B\u0443\u0447\u0438\u0432 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0432 \u041A\u0443\u0438\u043D\u0437-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0435
    \u0432 \u0438\u0440\u043B\u0430\u043D\u0434\u0441\u043A\u043E\u043C \u041A\u043E\u0440\u043A\u0435,
    \u0414\u0436\u043E\u0440\u0434\u0436 \u0411\u0443\u043B\u044C, \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u0431\u044B\u043B\u043E \u0443\u0436\u0435 \u0437\u0430 \u0442\u0440\u0438\u0434\u0446\u0430\u0442\u044C,
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F \u0441
    \u0441\u0435\u043C\u044C\u0451\u0439 \u0441\u0432\u043E\u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0438,
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u043B\u043E\u043B\u043E\u0433\u0438\u0438. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0442\u0430\u043C \u043E\u043D \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B
    \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u0446\u0443 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u2014 \u041C\u044D\u0440\u0438 \u042D\u0432\u0435\u0440\u0435\u0441\u0442, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u0446\u0435\u0439
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0430
    \u0441\u044D\u0440\u0430 \u0414\u0436\u043E\u0440\u0434\u0436\u0430 \u042D\u0432\u0435\u0440\u0435\u0441\u0442\u0430,
    \u0432 \u0447\u0435\u0441\u0442\u044C \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043D\u0430\u0437\u0432\u0430\u043D\u0430 \u0433\u043E\u0440\u0430.  \u0420\u0430\u0437\u043D\u0438\u0446\u0430
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u043D\u0435 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0430
    \u0443\u0447\u0451\u043D\u043E\u0433\u043E: \u043D\u0430 \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442
    \u0414\u0436\u043E\u0440\u0434\u0436\u0443 \u0431\u044B\u043B\u043E 35, \u0430
    \u041C\u044D\u0440\u0438 \u0432\u0441\u0435\u0433\u043E 17 \u043B\u0435\u0442.
    \u0411\u0443\u043B\u044C, \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0451\u043D\u043D\u044B\u0439
    \u0435\u0451 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044F\u043C\u0438,
    \u043D\u0430\u0447\u0430\u043B \u0434\u0430\u0432\u0430\u0442\u044C \u0435\u0439
    \u0447\u0430\u0441\u0442\u043D\u044B\u0435 \u0443\u0440\u043E\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C \u043F\u0435\u0440\u0435\u0440\u043E\u0441\u043B\u0438
    \u0432 \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0432\u0437\u0430\u0438\u043C\u043D\u0443\u044E
    \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u044C.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0411\u0443\u043B\u044C \u0434\u043E\u043B\u0433\u043E
    \u043D\u0435 \u0440\u0435\u0448\u0430\u043B\u0441\u044F \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435, \u0441\u0447\u0438\u0442\u0430\u044F
    \u0440\u0430\u0437\u043D\u0438\u0446\u0443 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u044B\u043C \u043F\u0440\u0435\u043F\u044F\u0442\u0441\u0442\u0432\u0438\u0435\u043C.
    \u0420\u0435\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F \u041C\u044D\u0440\u0438
    \u043F\u0440\u0438\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0430\u0441\u044C
    \u0438\u043D\u043E\u0433\u043E \u043C\u043D\u0435\u043D\u0438\u044F. \u0411\u0440\u0430\u043A
    \u0431\u044B\u043B \u0437\u0430\u043A\u043B\u044E\u0447\u0451\u043D \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432 **1855 \u0433\u043E\u0434\u0443**, \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u043E\u0442\u0446\u0430 \u041C\u044D\u0440\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B\u043B \u043F\u0440\u043E\u0442\u0438\u0432 \u044D\u0442\u043E\u0433\u043E
    \u0441\u043E\u044E\u0437\u0430. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0432\u0441\u0435 \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u044F,
    \u0438\u0445 \u0431\u0440\u0430\u043A \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C. \u0421\u0430\u043C\u0430
    \u041C\u044D\u0440\u0438 \u043F\u043E\u0437\u0436\u0435 \u043D\u0430\u0437\u043E\u0432\u0451\u0442
    \u0434\u0435\u0432\u044F\u0442\u044C \u043B\u0435\u0442 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \xAB\u0441\u0432\u0435\u0442\u043B\u044B\u043C
    \u0441\u043D\u043E\u043C\xBB.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466
    \u0421\u0435\u043C\u0435\u0439\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0438 \u043E\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u043E  \u0414\u0436\u043E\u0440\u0434\u0436
    \u0411\u0443\u043B\u044C \u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439
    \u0440\u0430\u0434\u043E\u0441\u0442\u044C\u044E \u0438 \u043B\u044E\u0431\u043E\u0432\u044C\u044E
    \u043E\u043A\u0443\u043D\u0443\u043B\u0441\u044F \u0432 \u0440\u043E\u043B\u044C
    \u043C\u0443\u0436\u0430 \u0438 \u043E\u0442\u0446\u0430. \u0418\u0445 \u043F\u0435\u0440\u0432\u044B\u0439
    \u0440\u0435\u0431\u0451\u043D\u043E\u043A, \u0434\u043E\u0447\u044C \u041C\u0430\u0440\u0433\u0430\u0440\u0435\u0442,
    \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u0443\u0436\u0435 \u0447\u0435\u0440\u0435\u0437
    \u0434\u0435\u0432\u044F\u0442\u044C \u043C\u0435\u0441\u044F\u0446\u0435\u0432
    \u043F\u043E\u0441\u043B\u0435 \u0441\u0432\u0430\u0434\u044C\u0431\u044B, \u0438
    \u0411\u0443\u043B\u044C \u0431\u044B\u043B \u0432 \u0432\u043E\u0441\u0442\u043E\u0440\u0433\u0435
    \u043E\u0442 \u043E\u0442\u0446\u043E\u0432\u0441\u0442\u0432\u0430. \u0415\u0433\u043E
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0437\u0443\u044E\u0442
    \u043A\u0430\u043A \u043B\u044E\u0431\u044F\u0449\u0435\u0433\u043E \u043C\u0443\u0436\u0430
    \u0438 \u043F\u0440\u0435\u0434\u0430\u043D\u043D\u043E\u0433\u043E \u043E\u0442\u0446\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0441\u0432\u044F\u0449\u0430\u043B \u0441\u0435\u0431\u044F \u0441\u0435\u043C\u044C\u0435.
    \u0417\u043D\u0430\u0432\u0448\u0438\u0435 \u0411\u0443\u043B\u044F \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    \u043F\u043E\u0447\u0442\u0438 \u0431\u0435\u0437\u0443\u043F\u0440\u0435\u0447\u043D\u043E\u0433\u043E
    \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F, \u0449\u0435\u0434\u0440\u043E\u0433\u043E,
    \u043E\u0442\u0437\u044B\u0432\u0447\u0438\u0432\u043E\u0433\u043E \u0438 \u0432\u0441\u0435\u0433\u0434\u0430
    \u0433\u043E\u0442\u043E\u0432\u043E\u0433\u043E \u043F\u0440\u0438\u0439\u0442\u0438
    \u043D\u0430 \u043F\u043E\u043C\u043E\u0449\u044C, \u0447\u0442\u043E \u0434\u043E\u043F\u043E\u043B\u043D\u044F\u0435\u0442
    \u043E\u0431\u0440\u0430\u0437 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0441\u0435\u043C\u044C\u044F\u043D\u0438\u043D\u0430. \u0412\u0441\u0435\u0433\u043E
    \u0443 \u0441\u0443\u043F\u0440\u0443\u0433\u043E\u0432 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C
    **\u043F\u044F\u0442\u044C \u0434\u043E\u0447\u0435\u0440\u0435\u0439**.  ###
    \U0001F54A\uFE0F \u0422\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u043C\u0435\u0440\u0442\u044C  \u0416\u0438\u0437\u043D\u044C \u0441\u0435\u043C\u044C\u0438
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u043E\u0431\u043E\u0440\u0432\u0430\u043B\u0430\u0441\u044C
    \u0432 \u043A\u043E\u043D\u0446\u0435 \u043D\u043E\u044F\u0431\u0440\u044F 1864
    \u0433\u043E\u0434\u0430. \u041F\u043E \u043F\u0443\u0442\u0438 \u0432 \u043A\u043E\u043B\u043B\u0435\u0434\u0436
    \u0414\u0436\u043E\u0440\u0434\u0436 \u0411\u0443\u043B\u044C \u043F\u043E\u043F\u0430\u043B
    \u043F\u043E\u0434 \u0441\u0438\u043B\u044C\u043D\u044B\u0439 \u043F\u0440\u043E\u043B\u0438\u0432\u043D\u043E\u0439
    \u0434\u043E\u0436\u0434\u044C \u0438, \u0431\u0443\u0434\u0443\u0447\u0438 \u0432\u0435\u0440\u043D\u044B\u043C
    \u0441\u0432\u043E\u0435\u043C\u0443 \u0434\u043E\u043B\u0433\u0443, \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043B
    \u0432\u0441\u0435 \u043B\u0435\u043A\u0446\u0438\u0438, \u043D\u0435 \u0441\u043D\u044F\u0432
    \u043C\u043E\u043A\u0440\u0443\u044E \u043E\u0434\u0435\u0436\u0434\u0443. \u042D\u0442\u043E
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0441\u0438\u043B\u044C\u043D\u043E\u0439
    \u043F\u0440\u043E\u0441\u0442\u0443\u0434\u0435, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u0435\u0440\u0435\u0440\u043E\u0441\u043B\u0430 \u0432 \u0432\u043E\u0441\u043F\u0430\u043B\u0435\u043D\u0438\u0435
    \u043B\u0451\u0433\u043A\u0438\u0445. \u0422\u0440\u0430\u0433\u0435\u0434\u0438\u044F
    \u0443\u0441\u0443\u0433\u0443\u0431\u0438\u043B\u0430\u0441\u044C \u0444\u0430\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u043E\u0448\u0438\u0431\u043A\u043E\u0439: \u0435\u0433\u043E \u0436\u0435\u043D\u0430
    \u041C\u044D\u0440\u0438, \u0443\u0432\u043B\u0435\u043A\u0430\u0432\u0448\u0430\u044F\u0441\u044F
    \u0433\u043E\u043C\u0435\u043E\u043F\u0430\u0442\u0438\u0435\u0439, \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u043B\u0430
    \u0434\u043B\u044F \u043B\u0435\u0447\u0435\u043D\u0438\u044F \u0441\u0432\u043E\u0435\u0433\u043E
    \u043C\u0443\u0436\u0430 \u043C\u0435\u0442\u043E\u0434 \u0437\u0430\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u043D\u0438\u044F
    \u0432 \u0445\u043E\u043B\u043E\u0434\u043D\u044B\u0435 \u043C\u043E\u043A\u0440\u044B\u0435
    \u043F\u0440\u043E\u0441\u0442\u044B\u043D\u0438. \u042D\u0442\u043E \xAB\u043B\u0435\u0447\u0435\u043D\u0438\u0435\xBB
    \u043B\u0438\u0448\u044C \u0443\u0441\u043A\u043E\u0440\u0438\u043B\u043E \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u0441\u0445\u043E\u0434. 8 \u0434\u0435\u043A\u0430\u0431\u0440\u044F
    1864 \u0433\u043E\u0434\u0430, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    49 \u043B\u0435\u0442, \u0414\u0436\u043E\u0440\u0434\u0436 \u0411\u0443\u043B\u044C
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F.  ### \U0001F469\u200D\U0001F467\u200D\U0001F466
    \u0416\u0438\u0437\u043D\u044C \u043F\u043E\u0441\u043B\u0435 \u0411\u0443\u043B\u044F
    \u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F \u0434\u043E\u0447\u0435\u0440\u0438 
    \u0421\u043C\u0435\u0440\u0442\u044C \u043C\u0443\u0436\u0430 \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430
    \u041C\u044D\u0440\u0438 \u0441 \u043F\u044F\u0442\u044C\u044E \u0434\u043E\u0447\u0435\u0440\u044C\u043C\u0438
    \u043D\u0430 \u0440\u0443\u043A\u0430\u0445, \u0441\u0442\u0430\u0440\u0448\u0435\u0439
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0431\u044B\u043B\u043E
    \u0432\u043E\u0441\u0435\u043C\u044C \u043B\u0435\u0442, \u0430 \u043C\u043B\u0430\u0434\u0448\u0435\u0439
    \u2014 \u0432\u0441\u0435\u0433\u043E \u0448\u0435\u0441\u0442\u044C \u043C\u0435\u0441\u044F\u0446\u0435\u0432,
    \u0438 \u0431\u0435\u0437 \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u043A \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044E.
    \u0414\u0440\u0443\u0437\u044C\u044F \u043C\u0443\u0436\u0430 \u0441\u043C\u043E\u0433\u043B\u0438
    \u0432\u044B\u0445\u043B\u043E\u043F\u043E\u0442\u0430\u0442\u044C \u0435\u0439
    \u043B\u0438\u0448\u044C \u043A\u0440\u043E\u0445\u043E\u0442\u043D\u0443\u044E
    \u043F\u0435\u043D\u0441\u0438\u044E. \u0427\u0442\u043E\u0431\u044B \u0432\u044B\u0436\u0438\u0442\u044C,
    \u041C\u044D\u0440\u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0441 \u0441\u0435\u043C\u044C\u0451\u0439 \u0432 \u041B\u043E\u043D\u0434\u043E\u043D,
    \u0433\u0434\u0435 \u0443\u0441\u0442\u0440\u043E\u0438\u043B\u0430\u0441\u044C
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0430\u0440\u0435\u043C
    \u0432 \u043F\u0435\u0440\u0432\u044B\u0439 \u0436\u0435\u043D\u0441\u043A\u0438\u0439
    \u043A\u043E\u043B\u043B\u0435\u0434\u0436 \u0438 \u0434\u0430\u0432\u0430\u043B\u0430
    \u0447\u0430\u0441\u0442\u043D\u044B\u0435 \u0443\u0440\u043E\u043A\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043A\u0440\u0430\u0439\u043D\u044E\u044E
    \u043D\u0443\u0436\u0434\u0443, \u0436\u0438\u0437\u043D\u044C \u0432 \u043A\u0440\u043E\u0445\u043E\u0442\u043D\u043E\u0439
    \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u043A\u0435 \u0438 \u043F\u0440\u043E\u0434\u0430\u0436\u0443
    \u0437\u043E\u043B\u043E\u0442\u043E\u0439 \u043C\u0435\u0434\u0430\u043B\u0438
    \u043C\u0443\u0436\u0430, \u0447\u0442\u043E\u0431\u044B \u043A\u0443\u043F\u0438\u0442\u044C
    \u0434\u0435\u0442\u044F\u043C \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442, \u041C\u044D\u0440\u0438
    \u0441\u0443\u043C\u0435\u043B\u0430 \u0434\u0430\u0442\u044C \u0434\u043E\u0447\u0435\u0440\u044F\u043C
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435. 
    \u0412\u0441\u0435 \u043F\u044F\u0442\u044C \u0434\u043E\u0447\u0435\u0440\u0435\u0439
    \u0411\u0443\u043B\u044F \u0441\u0442\u0430\u043B\u0438 \u043D\u0435\u0437\u0430\u0443\u0440\u044F\u0434\u043D\u044B\u043C\u0438
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044F\u043C\u0438 :  *   **\u041C\u044D\u0440\u0438
    \u042D\u043B\u043B\u0435\u043D** (\u0441\u0442\u0430\u0440\u0448\u0430\u044F
    \u0434\u043E\u0447\u044C) \u0432\u044B\u0448\u043B\u0430 \u0437\u0430\u043C\u0443\u0436
    \u0437\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0438
    \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u044F \u0427\u0430\u0440\u043B\u044C\u0437\u0430
    \u0413\u043E\u0432\u0430\u0440\u0434\u0430 \u0425\u0438\u043D\u0442\u043E\u043D\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0441\u0432\u043E\u0438\u043C\u0438 \u0438\u0434\u0435\u044F\u043C\u0438 \u043E
    \u0447\u0435\u0442\u0432\u0451\u0440\u0442\u043E\u043C \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0438.
    *   **\u041C\u0430\u0440\u0433\u0430\u0440\u0435\u0442** \u0441\u0442\u0430\u043B\u0430
    \u043C\u0430\u0442\u0435\u0440\u044C\u044E \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0433\u043E\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0438 \u0444\u0438\u0437\u0438\u043A\u0430
    \u0414\u0436. \u0418. \u0422\u0435\u0439\u043B\u043E\u0440\u0430. *   **\u0410\u043B\u0438\u0441\u0438\u044F**
    (1860\u20131940) \u0441\u0442\u0430\u043B\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C-\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u043E\u043C
    \u0438 \u0432\u043D\u0435\u0441\u043B\u0430 \u0432\u043A\u043B\u0430\u0434 \u0432
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435 \u0447\u0435\u0442\u044B\u0440\u0451\u0445\u043C\u0435\u0440\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. *   **\u041B\u044E\u0441\u0438**
    (1862\u20131904) \u043F\u043E\u0448\u043B\u0430 \u043F\u043E \u0441\u0442\u043E\u043F\u0430\u043C
    \u043E\u0442\u0446\u0430 \u0432 \u043D\u0430\u0443\u043A\u0443 \u0438 \u0441\u0442\u0430\u043B\u0430
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0445\u0438\u043C\u0438\u0438.
    *   **\u042D\u0442\u0435\u043B\u044C \u041B\u0438\u043B\u0438\u0430\u043D** (1864\u20131960)
    \u2014 \u0441\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0438\u0437 \u0441\u0435\u0441\u0442\u0451\u0440. \u041E\u043D\u0430 \u043F\u0440\u043E\u0441\u043B\u0430\u0432\u0438\u043B\u0430\u0441\u044C
    \u043A\u0430\u043A \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0430
    \u043F\u043E\u0434 \u043F\u0441\u0435\u0432\u0434\u043E\u043D\u0438\u043C\u043E\u043C
    \u042D\u0442\u0435\u043B\u044C \u041B\u0438\u043B\u0438\u0430\u043D \u0412\u043E\u0439\u043D\u0438\u0447,
    \u0430\u0432\u0442\u043E\u0440 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E
    \u0440\u043E\u043C\u0430\u043D\u0430 \xAB\u041E\u0432\u043E\u0434\xBB. \u041E\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0437\u0430\u043C\u0443\u0436\u0435\u043C \u0437\u0430
    \u041C\u0438\u0445\u0430\u0438\u043B\u043E\u043C \u0412\u043E\u0439\u043D\u0438\u0447\u0435\u043C,
    \u043F\u0435\u0440\u0432\u043E\u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \xAB\u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0438
    \u0412\u043E\u0439\u043D\u0438\u0447\u0430\xBB.  \u0421\u0430\u043C \u0414\u0436\u043E\u0440\u0434\u0436
    \u0411\u0443\u043B\u044C \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u0432\u0435\u0440\u0443\u044E\u0449\u0438\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0438 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u0442\u043E\u0440\u043E\u043C.
    \u041E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u043F\u043E\u043C\u043E\u0433\u0430\u043B
    \u0431\u0435\u0434\u043D\u044B\u043C, \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B
    \u0432 \u0432\u0435\u0447\u0435\u0440\u043D\u0435\u0439 \u0448\u043A\u043E\u043B\u0435
    \u0434\u043B\u044F \u0432\u0437\u0440\u043E\u0441\u043B\u044B\u0445 \u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u0438, \u043F\u043E\u043C\u043E\u0433\u0430\u0432\u0448\u0438\u0435
    \u0436\u0435\u043D\u0449\u0438\u043D\u0430\u043C \u043D\u0430\u0439\u0442\u0438
    \u0440\u0430\u0431\u043E\u0442\u0443. \u042D\u0442\u0438 \u0447\u0435\u0440\u0442\u044B
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0430 \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0438 \u0441\u0442\u043E\u0439\u043A\u043E\u0441\u0442\u044C
    \u0438 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0435\u0433\u043E \u0436\u0435\u043D\u0430
    \u0438 \u0434\u043E\u0447\u0435\u0440\u0438 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0438
    \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438."
  personalLifeEn: 
  shortBioRu: "\u0414\u0436\u043E\u0440\u0434\u0436 \u0411\u0443\u043B\u044C (1815\u20131864)
    \u2014 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0438 \u043B\u043E\u0433\u0438\u043A, \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u044B
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438 \u0438, \u0432 \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C
    \u0441\u0447\u0451\u0442\u0435, \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0439 \u043F\u0443\u0442\u044C
    \u2014 \u0437\u0430\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0441\u0430\u043C\u043E\u0443\u0447\u043A\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0441\u0432\u043E\u0435\u043C\u0443 \u0433\u0435\u043D\u0438\u044E \u0438 \u0443\u043F\u043E\u0440\u0441\u0442\u0432\u0443
    \u0441\u0442\u0430\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043D\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0438 \u0447\u043B\u0435\u043D\u043E\u043C
    \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430. 
    ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u043F\u0443\u0442\u044C \u043A \u0437\u043D\u0430\u043D\u0438\u044F\u043C 
    \u0414\u0436\u043E\u0440\u0434\u0436 \u0411\u0443\u043B\u044C \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    2 \u043D\u043E\u044F\u0431\u0440\u044F 1815 \u0433\u043E\u0434\u0430 \u0432 \u041B\u0438\u043D\u043A\u043E\u043B\u044C\u043D\u0435,
    \u0410\u043D\u0433\u043B\u0438\u044F, \u0432 \u0441\u0435\u043C\u044C\u0435 \u043D\u0435\u0431\u043E\u0433\u0430\u0442\u043E\u0433\u043E
    \u0441\u0430\u043F\u043E\u0436\u043D\u0438\u043A\u0430 \u0414\u0436\u043E\u043D\u0430
    \u0411\u0443\u043B\u044F. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430
    \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0435 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435,
    \u043E\u0442\u0435\u0446, \u0443\u0432\u043B\u0435\u043A\u0430\u0432\u0448\u0438\u0439\u0441\u044F
    \u043D\u0430\u0443\u043A\u043E\u0439, \u0434\u0430\u043B \u0441\u044B\u043D\u0443
    \u043F\u0435\u0440\u0432\u044B\u0435 \u0443\u0440\u043E\u043A\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u043E\u0431\u0443\u0447\u0438\u043B \u0435\u0433\u043E \u0438\u0437\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u0438\u044E
    \u043E\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043F\u0440\u0438\u0431\u043E\u0440\u043E\u0432.
    \u0418\u0437-\u0437\u0430 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0445
    \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u0435\u0439 \u0441\u0435\u043C\u044C\u0438
    \u0411\u0443\u043B\u044C \u043D\u0435 \u0441\u043C\u043E\u0433 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F, \u043E\u043A\u043E\u043D\u0447\u0438\u0432
    \u043B\u0438\u0448\u044C \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443. \u0421 16 \u043B\u0435\u0442 \u043E\u043D \u0431\u044B\u043B
    \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u043E\u043C \u0443\u0447\u0438\u0442\u0435\u043B\u044F
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u0435
    \u0432 \u0414\u043E\u043D\u043A\u0430\u0441\u0442\u0435\u0440\u0435, \u0447\u0442\u043E\u0431\u044B
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0442\u044C \u0441\u0435\u043C\u044C\u044E. 
    \u041E\u0434\u043D\u0430\u043A\u043E \u0436\u0430\u0436\u0434\u0430 \u0437\u043D\u0430\u043D\u0438\u0439
    \u0443 \u0411\u0443\u043B\u044F \u0431\u044B\u043B\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u0430.
    \u041E\u043D \u0431\u044B\u043B \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0432\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434\u043E\u043C: \u043A
    12 \u0433\u043E\u0434\u0430\u043C \u043E\u043D \u0443\u0436\u0435 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0438\u043B
    \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u0443\u044E \u043F\u043E\u044D\u0437\u0438\u044E,
    \u0430 \u043A 14 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E \u0432\u043B\u0430\u0434\u0435\u043B
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u043C, \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u043C,
    \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u043C \u0438 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u043C
    \u044F\u0437\u044B\u043A\u0430\u043C\u0438. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043E\u043D \u0438\u0437\u0443\u0447\u0430\u043B \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E.
    \u0412 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0435 \u0432\u0440\u0435\u043C\u044F
    \u043E\u043D \u0447\u0438\u0442\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0436\u0443\u0440\u043D\u0430\u043B\u044B \u0432 \u041C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u041B\u0438\u043D\u043A\u043E\u043B\u044C\u043D\u0430,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B \u041D\u044C\u044E\u0442\u043E\u043D\u0430, \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430
    \u0438 \u041B\u0430\u043F\u043B\u0430\u0441\u0430. \u0415\u0433\u043E \u0442\u0430\u043B\u0430\u043D\u0442
    \u0432 \u0432\u044B\u0441\u0448\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u043B\u0438\u0448\u044C
    \u0432 17 \u043B\u0435\u0442, \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u0440\u0430\u0431\u043E\u0442\u0430\u043C\u0438 \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E. \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    20 \u043B\u0435\u0442 \u043E\u043D \u043E\u0442\u043A\u0440\u044B\u043B \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u0432 \u041B\u0438\u043D\u043A\u043E\u043B\u044C\u043D\u0435. 
    ### \u2797 \u041D\u0430\u0443\u0447\u043D\u0430\u044F \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B 
    \u041D\u0435 \u0438\u043C\u0435\u044F \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u043E\u0433\u043E
    \u0434\u0438\u043F\u043B\u043E\u043C\u0430, \u0411\u0443\u043B\u044C \u043D\u0430\u0447\u0430\u043B
    \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C \u0441\u0432\u043E\u0438
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F \u0432
    \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0436\u0443\u0440\u043D\u0430\u043B\u0430\u0445.  *   **\u041F\u0435\u0440\u0432\u044B\u0435
    \u0443\u0441\u043F\u0435\u0445\u0438:** \u0412 1839 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u043F\u0435\u0440\u0432\u0443\u044E \u0441\u0442\u0430\u0442\u044C\u044E
    \xAB\u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0439\xBB
    \u0432 \xAB\u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0436\u0443\u0440\u043D\u0430\u043B\u0435\xBB. \u0412 1844 \u0433\u043E\u0434\u0443
    \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u0443 \xAB\u041E\u0431 \u043E\u0431\u0449\u0435\u043C
    \u043C\u0435\u0442\u043E\u0434\u0435 \u0430\u043D\u0430\u043B\u0438\u0437\u0430\xBB
    \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u043F\u0435\u0440\u0432\u043E\u0439 \u0437\u043E\u043B\u043E\u0442\u043E\u0439
    \u043C\u0435\u0434\u0430\u043B\u0438 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u0437\u0430 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443. *   **\u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438:** \u0412 1847 \u0433\u043E\u0434\u0443
    \u0411\u0443\u043B\u044C \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u044D\u043F\u043E\u0445\u0430\u043B\u044C\u043D\u044B\u0439 \u043F\u0430\u043C\u0444\u043B\u0435\u0442
    \xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u043B\u043E\u0433\u0438\u043A\u0438, \u0438\u043B\u0438
    \u041E\u043F\u044B\u0442 \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0434\u0435\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u0445 \u0443\u043C\u043E\u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0439\xBB.
    \u0412 \u044D\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 \u043E\u043D
    \u0443\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043B\u043E\u0433\u0438\u043A\u0430 \u043C\u043E\u0436\u0435\u0442
    \u0438 \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u0442\u044C \u0441\u043E\u044E\u0437\u043D\u0438\u0446\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0430 \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438.
    \u042D\u0442\u043E \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u043E \u0435\u043C\u0443
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    \u043B\u043E\u0433\u0438\u043A\u0430 \u041E\u0433\u0430\u0441\u0442\u0435\u0441\u0430
    \u0414\u0435 \u041C\u043E\u0440\u0433\u0430\u043D\u0430. *   **\u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0443\u0440\u0430:**
    \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u044D\u0442\u043E\u0439
    \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438 \u0432 1849 \u0433\u043E\u0434\u0443
    \u0411\u0443\u043B\u044C \u0431\u0435\u0437 \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432 \u041A\u0443\u0438\u043D\u0437-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0435
    \u0432 \u041A\u043E\u0440\u043A\u0435, \u0418\u0440\u043B\u0430\u043D\u0434\u0438\u044F
    (\u043D\u044B\u043D\u0435 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0439
    \u043A\u043E\u043B\u043B\u0435\u0434\u0436 \u041A\u043E\u0440\u043A).  \u0413\u043B\u0430\u0432\u043D\u044B\u043C
    \u0442\u0440\u0443\u0434\u043E\u043C \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438
    \u0441\u0442\u0430\u043B\u0430 \u043A\u043D\u0438\u0433\u0430 \xAB\u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u0437\u0430\u043A\u043E\u043D\u043E\u0432 \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u044B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043B\u043E\u0433\u0438\u043A\u0438 \u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439\xBB,
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u0432 1854 \u0433\u043E\u0434\u0443. \u0412 \u043D\u0435\u0439 \u043E\u043D
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0437\u0440\u0435\u043B\u043E\u0435
    \u0438 \u043F\u043E\u043B\u043D\u043E\u0435 \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0441\u0432\u043E\u0435\u0439 \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u043E\u0437\u0436\u0435 \u0441\u0442\u0430\u043D\u0435\u0442 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u043A\u0430\u043A **\u0431\u0443\u043B\u0435\u0432\u0430 \u0430\u043B\u0433\u0435\u0431\u0440\u0430**.
    \u0411\u0443\u043B\u044C \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442, \u0433\u0434\u0435 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043D\u0438\u044F \u0438
    \u043A\u043B\u0430\u0441\u0441\u044B \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0438\u0441\u044C
    \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u043C\u0438, \u0430 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438
    \u043D\u0430\u0434 \u043D\u0438\u043C\u0438 (\u0442\u0430\u043A\u0438\u0435 \u043A\u0430\u043A
    \u0418, \u0418\u041B\u0418, \u041D\u0415) \u2014 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F\u043C\u0438. \u042D\u0442\u0430
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0430
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442\u044C \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0441\u0442\u044C
    \u0438\u043B\u0438 \u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0439 \u043F\u0443\u0442\u0451\u043C
    \u0447\u0438\u0441\u0442\u043E \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u0430\u043D\u0438\u043F\u0443\u043B\u044F\u0446\u0438\u0439.  \u041F\u043E\u043C\u0438\u043C\u043E
    \u043B\u043E\u0433\u0438\u043A\u0438, \u0411\u0443\u043B\u044C \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0438 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435:
    \xAB\u0422\u0440\u0430\u043A\u0442\u0430\u0442 \u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u0445\xBB (1859) \u0438
    \xAB\u0422\u0440\u0430\u043A\u0442\u0430\u0442 \u043E \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445
    \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u044F\u0445\xBB (1860), \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u043E\u043B\u0433\u0438\u0435 \u0433\u043E\u0434\u044B \u0441\u043B\u0443\u0436\u0438\u043B\u0438
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043F\u043E\u0441\u043E\u0431\u0438\u044F\u043C\u0438.  ### \U0001F4A1 \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0438 \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439
    \u043C\u0438\u0440  \u041F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u0442\u0440\u0443\u0434\u044B
    \u0411\u0443\u043B\u044F \u0446\u0435\u043D\u0438\u043B\u0438\u0441\u044C \u0432
    \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C \u0443\u0437\u043A\u0438\u043C
    \u043A\u0440\u0443\u0433\u043E\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.
    \u0418\u0445 \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0440\u0430\u0441\u043A\u0440\u044B\u043B\u043E\u0441\u044C \u043F\u043E\u0437\u0436\u0435,
    \u043A\u043E\u0433\u0434\u0430: *   \u0412 \u043A\u043E\u043D\u0446\u0435 XIX
    \u0432\u0435\u043A\u0430 \u0444\u0438\u0437\u0438\u043A\u0438 \u0441\u0442\u0430\u043B\u0438
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0431\u0443\u043B\u0435\u0432\u0443
    \u0430\u043B\u0433\u0435\u0431\u0440\u0443 \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0441\u0445\u0435\u043C. *   \u0412 XX \u0432\u0435\u043A\u0435 \u044D\u0442\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u0441\u0442\u0430\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0434\u043B\u044F \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0446\u0438\u0444\u0440\u043E\u0432\u044B\u0445 \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u043D\u044B\u0445
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u0432. \u0414\u0432\u043E\u0438\u0447\u043D\u044B\u0439
    \u043A\u043E\u0434, \u043B\u0435\u0436\u0430\u0449\u0438\u0439 \u0432 \u043E\u0441\u043D\u043E\u0432\u0435
    \u0432\u0441\u0435\u0439 \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0439 \u0442\u0435\u0445\u043D\u0438\u043A\u0438,
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043F\u0440\u044F\u043C\u044B\u043C
    \u0432\u043E\u043F\u043B\u043E\u0449\u0435\u043D\u0438\u0435\u043C \u0431\u0443\u043B\u0435\u0432\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466
    \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u0438 \u0441\u0435\u043C\u044C\u044F 
    \u0412 1855 \u0433\u043E\u0434\u0443 \u0411\u0443\u043B\u044C \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u041C\u044D\u0440\u0438 \u042D\u0432\u0435\u0440\u0435\u0441\u0442,
    \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u0446\u0435 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E
    \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0430 \u0441\u044D\u0440\u0430 \u0414\u0436\u043E\u0440\u0434\u0436\u0430
    \u042D\u0432\u0435\u0440\u0435\u0441\u0442\u0430, \u0432 \u0447\u0435\u0441\u0442\u044C
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043D\u0430\u0437\u0432\u0430\u043D\u0430
    \u0432\u044B\u0441\u043E\u0447\u0430\u0439\u0448\u0430\u044F \u0433\u043E\u0440\u0430
    \u043C\u0438\u0440\u0430. \u0423 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C
    \u043F\u044F\u0442\u044C \u0434\u043E\u0447\u0435\u0440\u0435\u0439, \u043A\u0430\u0436\u0434\u0430\u044F
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u0442\u0430\u043B\u0430
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u0432 \u0441\u0432\u043E\u0435\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438:
    *   **\u0410\u043B\u0438\u0441\u0438\u044F** (1860\u20131940) \u2014 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A-\u0433\u0435\u043E\u043C\u0435\u0442\u0440.
    *   **\u041B\u044E\u0441\u0438** (1862\u20131904) \u2014 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0445\u0438\u043C\u0438\u0438. *   **\u042D\u0442\u0435\u043B\u044C \u041B\u0438\u043B\u0438\u0430\u043D**
    (1864\u20131960) \u2014 \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0430,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F \u043A\u0430\u043A \u0430\u0432\u0442\u043E\u0440
    \u0440\u043E\u043C\u0430\u043D\u0430 \xAB\u041E\u0432\u043E\u0434\xBB (\u043F\u043E\u0434
    \u043F\u0441\u0435\u0432\u0434\u043E\u043D\u0438\u043C\u043E\u043C \u042D\u0442\u0435\u043B\u044C
    \u041B\u0438\u043B\u0438\u0430\u043D \u0412\u043E\u0439\u043D\u0438\u0447). 
    ### \U0001F4D6 \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u043F\u0430\u043C\u044F\u0442\u044C  \u0414\u0436\u043E\u0440\u0434\u0436
    \u0411\u0443\u043B\u044C \u0443\u043C\u0435\u0440 8 \u0434\u0435\u043A\u0430\u0431\u0440\u044F
    1864 \u0433\u043E\u0434\u0430 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    49 \u043B\u0435\u0442 \u043E\u0442 \u0432\u043E\u0441\u043F\u0430\u043B\u0435\u043D\u0438\u044F
    \u043B\u0435\u0433\u043A\u0438\u0445. \u041E\u043D \u043F\u0440\u043E\u0441\u0442\u0443\u0434\u0438\u043B\u0441\u044F,
    \u043A\u043E\u0433\u0434\u0430 \u0432 \u043F\u0440\u043E\u043C\u043E\u043A\u0448\u0435\u0439
    \u043E\u0434\u0435\u0436\u0434\u0435 \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043B
    \u043B\u0435\u043A\u0446\u0438\u044E \u043F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E,
    \u043A\u0430\u043A \u043F\u043E\u043F\u0430\u043B \u043F\u043E\u0434 \u043F\u0440\u043E\u043B\u0438\u0432\u043D\u043E\u0439
    \u0434\u043E\u0436\u0434\u044C \u043F\u043E \u043F\u0443\u0442\u0438 \u0432 \u043A\u043E\u043B\u043B\u0435\u0434\u0436. 
    \u0412 \u0447\u0435\u0441\u0442\u044C \u0414\u0436\u043E\u0440\u0434\u0436\u0430
    \u0411\u0443\u043B\u044F \u043D\u0430\u0437\u0432\u0430\u043D \u043A\u0440\u0430\u0442\u0435\u0440
    \u043D\u0430 \u041B\u0443\u043D\u0435, \u0430 \u0435\u0433\u043E \u0438\u043C\u044F
    \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043A\u0430\u043A \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u0446\u0438\u0444\u0440\u043E\u0432\u0430\u044F \u044D\u043F\u043E\u0445\u0430."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0414\u0436\u043E\u0440\u0434\u0436\u0430
    \u0411\u0443\u043B\u044F \u043F\u043E\u043B\u043D\u0430 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438 \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445 \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0440\u0438\u0441\u0443\u044E\u0442
    \u0435\u0433\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043A\u0430\u043A
    \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u043E\u0433\u043E \u0443\u0447\u0451\u043D\u043E\u0433\u043E,
    \u043D\u043E \u043A\u0430\u043A \u043E\u0447\u0435\u043D\u044C \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E\u0433\u043E,
    \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u043E\u0433\u043E \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430.  \u0412\u043E\u0442 \u0441\u0430\u043C\u0430\u044F
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u0430\u044F \u043F\u043E\u0434\u0431\u043E\u0440\u043A\u0430
    \u0444\u0430\u043A\u0442\u043E\u0432 \u043E \u043D\u0451\u043C.  ### \U0001F476
    \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u043F\u043E\u0434\u0440\u043E\u0441\u0442\u043E\u043A
    \u0438 \u0441\u043A\u0443\u043F\u043E\u0441\u0442\u044C \u043D\u0430 \u043A\u043D\u0438\u0433\u0438 
    *   **\u042E\u043D\u044B\u0439 \u043F\u043E\u043B\u0438\u0433\u043B\u043E\u0442
    \u0438 \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u0435 \u0432 \u043F\u043B\u0430\u0433\u0438\u0430\u0442\u0435:**
    \u041A 14 \u0433\u043E\u0434\u0430\u043C \u0411\u0443\u043B\u044C \u0443\u0436\u0435
    \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E \u0432\u043B\u0430\u0434\u0435\u043B
    \u043B\u0430\u0442\u044B\u043D\u044C\u044E, \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u043C,
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u043C, \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u043C
    \u0438 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u043C \u044F\u0437\u044B\u043A\u0430\u043C\u0438.
    \u0415\u0433\u043E \u0442\u0430\u043B\u0430\u043D\u0442 \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0447\u0435\u0432\u0438\u0434\u0435\u043D, \u0447\u0442\u043E, \u043A\u043E\u0433\u0434\u0430
    \u0432 1830 \u0433\u043E\u0434\u0443 \u043C\u0435\u0441\u0442\u043D\u0430\u044F
    \u0433\u0430\u0437\u0435\u0442\u0430 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B\u0430
    \u0435\u0433\u043E \u043F\u0435\u0440\u0435\u0432\u043E\u0434 \u0434\u0440\u0435\u0432\u043D\u0435\u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043E\u044D\u043C\u044B, \u043E\u0434\u0438\u043D \u0447\u0438\u0442\u0430\u0442\u0435\u043B\u044C
    \u043E\u0431\u0432\u0438\u043D\u0438\u043B \u0435\u0433\u043E \u0432 \u043F\u043B\u0430\u0433\u0438\u0430\u0442\u0435,
    \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u044F\u0441\u044C \u0432\u0435\u0440\u0438\u0442\u044C,
    \u0447\u0442\u043E \u0442\u0430\u043A\u043E\u0439 \u0441\u043B\u043E\u0436\u043D\u044B\u0439
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434 \u043C\u043E\u0433 \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u043F\u043E\u0434\u0440\u043E\u0441\u0442\u043E\u043A. *   **\u042D\u043A\u043E\u043D\u043E\u043C\u0438\u044F
    \u043D\u0430 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0435:**
    \u0412 \u044E\u043D\u043E\u0441\u0442\u0438, \u043A\u043E\u0433\u0434\u0430 \u0411\u0443\u043B\u044C
    \u043D\u0430\u0447\u0430\u043B \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u044C\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439, \u043E\u043D
    \u043E\u0441\u043E\u0437\u043D\u0430\u043D\u043D\u043E \u043F\u043E\u043A\u0443\u043F\u0430\u043B
    \u0438\u043C\u0435\u043D\u043D\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043D\u0438\u0433\u0438, \u0430 \u043D\u0435 \u0445\u0443\u0434\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0443. \u0421\u0432\u043E\u0435\u0439
    \u0436\u0435\u043D\u0435 \u043E\u043D \u043F\u043E\u0437\u0436\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043B\u0441\u044F,
    \u0447\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B \u044D\u0442\u043E \u0438\u0437
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439:
    \u043D\u0430 \u043F\u0440\u043E\u0447\u0442\u0435\u043D\u0438\u0435 \u0438 \u0443\u0441\u0432\u043E\u0435\u043D\u0438\u0435
    \u043E\u0434\u043D\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0430 \u0443\u0445\u043E\u0434\u0438\u043B\u043E
    \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u0431\u043E\u043B\u044C\u0448\u0435
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u0447\u0435\u043C \u043D\u0430 \u0440\u043E\u043C\u0430\u043D
    \u0438\u043B\u0438 \u043F\u043E\u044D\u043C\u0443. \u0422\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u043E\u043D \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043B
    \u0434\u0435\u043D\u044C\u0433\u0438, \u0440\u0435\u0436\u0435 \u043F\u043E\u043A\u0443\u043F\u0430\u044F
    \u043D\u043E\u0432\u044B\u0435 \u043A\u043D\u0438\u0433\u0438.  ### \U0001F3EB
    \u0427\u0443\u0434\u0430\u043A\u043E\u0432\u0430\u0442\u044B\u0439 \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u0438 \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u0439 \u0430\u0440\u0442\u0438\u0441\u0442 
    *   **\u0423\u0432\u043E\u043B\u044C\u043D\u0435\u043D\u0438\u0435 \u0437\u0430
    \u0447\u0442\u0435\u043D\u0438\u0435 \u0432 \u0432\u043E\u0441\u043A\u0440\u0435\u0441\u0435\u043D\u044C\u0435:**
    \u041D\u0430\u0447\u0430\u0432 \u0441\u0432\u043E\u044E \u043A\u0430\u0440\u044C\u0435\u0440\u0443
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F \u0432 16 \u043B\u0435\u0442, \u0411\u0443\u043B\u044C
    \u0431\u044B\u043B \u0443\u0432\u043E\u043B\u0435\u043D \u0438\u0437 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0436\u0435 \u0447\u0430\u0441\u0442\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u044B
    \u0437\u0430... \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u0443\u044E
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0441\u0442\u044C.
    \u0415\u0433\u043E \u043F\u0440\u043E\u0432\u0438\u043D\u043D\u043E\u0441\u0442\u044C
    \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0430\u0441\u044C \u0432 \u0442\u043E\u043C,
    \u0447\u0442\u043E \u043E\u043D \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B
    \u0441\u0435\u0431\u0435 \u0447\u0438\u0442\u0430\u0442\u044C \u043A\u043D\u0438\u0433\u0438
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u043F\u043E
    \u0432\u043E\u0441\u043A\u0440\u0435\u0441\u0435\u043D\u044C\u044F\u043C, \u0438
    \u0434\u0435\u043B\u0430\u043B \u044D\u0442\u043E \u043F\u0440\u044F\u043C\u043E
    \u0432 \u0447\u0430\u0441\u043E\u0432\u043D\u0435. *   **\u0421\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0448\u043A\u043E\u043B\u0430 \u0438 \xAB\u043D\u0435\u0438\u0441\u043F\u043E\u0440\u0447\u0435\u043D\u043D\u044B\u0435\xBB
    \u0434\u0435\u0442\u0438:** \u0412 20 \u043B\u0435\u0442 \u043E\u043D \u043E\u0442\u043A\u0440\u044B\u043B
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E \u0448\u043A\u043E\u043B\u0443-\u043F\u0430\u043D\u0441\u0438\u043E\u043D.
    \u0415\u0433\u043E \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0435\u0442\u043E\u0434 \u0431\u044B\u043B \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u0435\u043D:
    \u043E\u043D \u0431\u0440\u0430\u043B \u043D\u0430 \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0430\u043C\u044B\u0445 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0445
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u043E\u0432, \u043F\u043E\u0442\u043E\u043C\u0443
    \u0447\u0442\u043E \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u043E\u043D\u0438
    \xAB\u0435\u0449\u0451 \u043D\u0435 \u0438\u0441\u043F\u043E\u0440\u0447\u0435\u043D\u044B
    \u043F\u043B\u043E\u0445\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C\xBB.
    *   **\u041C\u0430\u0441\u0442\u0435\u0440 \u043F\u043E \u0447\u0430\u0441\u0442\u0438
    \u043B\u044C\u0432\u0438\u043D\u043E\u0433\u043E \u0440\u044B\u043A\u0430:**
    \u0411\u0443\u043B\u044C \u0431\u044B\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0435\u043D \u0443 \u0434\u0435\u0442\u0435\u0439
    \u0432 \u0441\u0432\u043E\u0451\u043C \u0440\u043E\u0434\u043D\u043E\u043C \u041B\u0438\u043D\u043A\u043E\u043B\u044C\u043D\u0435.
    \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0438,
    \u0447\u0442\u043E \u0441\u043E\u0441\u0435\u0434\u0441\u043A\u0438\u0435 \u043C\u0430\u043B\u044C\u0447\u0438\u0448\u043A\u0438
    \u0447\u0430\u0441\u0442\u043E \u0437\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \u043F\u043E\u0438\u0433\u0440\u0430\u0442\u044C \u0441 \u043D\u0438\u043C\u0438.
    \u0415\u0433\u043E \xAB\u043A\u043E\u0440\u043E\u043D\u043D\u044B\u043C \u043D\u043E\u043C\u0435\u0440\u043E\u043C\xBB
    \u0431\u044B\u043B\u043E \u0443\u043C\u0435\u043D\u0438\u0435 \u0442\u0430\u043A
    \u043F\u0440\u0430\u0432\u0434\u043E\u043F\u043E\u0434\u043E\u0431\u043D\u043E
    \u043F\u043E\u0434\u0440\u0430\u0436\u0430\u0442\u044C \u043B\u044C\u0432\u0438\u043D\u043E\u043C\u0443
    \u0440\u044B\u043A\u0443, \u0447\u0442\u043E \u0434\u0435\u0442\u0438 \u0432
    \u043F\u0440\u0438\u0442\u0432\u043E\u0440\u043D\u043E\u043C \u0443\u0436\u0430\u0441\u0435
    \u0440\u0430\u0437\u0431\u0435\u0433\u0430\u043B\u0438\u0441\u044C, \u0432\u0438\u0437\u0436\u0430
    \u043E\u0442 \u0432\u043E\u0441\u0442\u043E\u0440\u0433\u0430. \u042D\u0442\u043E\u0442
    \u044D\u043F\u0438\u0437\u043E\u0434 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u043E\u043D \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u044B\u043C \u0443\u0447\u0451\u043D\u044B\u043C,
    \u043D\u043E \u0438 \u043E\u0447\u0435\u043D\u044C \u0436\u0438\u0432\u044B\u043C,
    \u043B\u044E\u0431\u044F\u0449\u0438\u043C \u0434\u0435\u0442\u0435\u0439 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C. 
    ### \U0001F468\u200D\U0001F467\u200D\U0001F466 \u0421\u0435\u043C\u044C\u044F,
    \u043E\u0442\u0440\u0430\u0436\u0451\u043D\u043D\u0430\u044F \u0432 \u0432\u0438\u0442\u0440\u0430\u0436\u0435
    \u0438 \u0441\u0435\u0440\u0435\u0431\u0440\u044F\u043D\u044B\u0445 \u043B\u043E\u0436\u043A\u0430\u0445 
    *   **\u0412\u0438\u0442\u0440\u0430\u0436 \u0432 \u0447\u0435\u0441\u0442\u044C
    \u043B\u044E\u0431\u0438\u043C\u043E\u0433\u043E \u0431\u0438\u0431\u043B\u0435\u0439\u0441\u043A\u043E\u0433\u043E
    \u0441\u044E\u0436\u0435\u0442\u0430:** \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u043D\u044B\u0435
    \u0436\u0438\u0442\u0435\u043B\u0438 \u041B\u0438\u043D\u043A\u043E\u043B\u044C\u043D\u0430
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0446\u0435\u043D\u0438\u043B\u0438
    \u0411\u0443\u043B\u044F, \u0447\u0442\u043E \u0440\u0435\u0448\u0438\u043B\u0438
    \u0443\u0432\u0435\u043A\u043E\u0432\u0435\u0447\u0438\u0442\u044C \u0435\u0433\u043E
    \u043F\u0430\u043C\u044F\u0442\u044C \u0432 \u043C\u0435\u0441\u0442\u043D\u043E\u043C
    \u0441\u043E\u0431\u043E\u0440\u0435. \u041D\u0430 \u0432\u0438\u0442\u0440\u0430\u0436\u0435,
    \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u043E\u043C \u0432 \u0435\u0433\u043E
    \u0447\u0435\u0441\u0442\u044C, \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0451\u043D
    \u0431\u0438\u0431\u043B\u0435\u0439\u0441\u043A\u0438\u0439 \u0441\u044E\u0436\u0435\u0442
    \u043F\u0440\u0438\u0437\u0432\u0430\u043D\u0438\u044F \u043F\u0440\u043E\u0440\u043E\u043A\u0430
    \u0421\u0430\u043C\u0443\u0438\u043B\u0430 \u2014 \u043E\u0434\u0438\u043D \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u043B\u044E\u0431\u0438\u043C\u044B\u0445 \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432
    \u0411\u0443\u043B\u044F. \u042D\u0442\u043E\u0442 \u0432\u0438\u0442\u0440\u0430\u0436
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0441\u044F \u0438 \u043F\u043E
    \u0441\u0435\u0439 \u0434\u0435\u043D\u044C. *   **\u041D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E
    \u043F\u0440\u0430\u0434\u0435\u0434\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u0430:** \u041E\u0442\u0435\u0446
    \u0414\u0436\u043E\u0440\u0434\u0436\u0430, \u0414\u0436\u043E\u043D \u0411\u0443\u043B\u044C,
    \u0431\u044B\u043B \u0441\u0430\u043F\u043E\u0436\u043D\u0438\u043A\u043E\u043C,
    \u043D\u043E \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439
    \u0441\u0442\u0440\u0430\u0441\u0442\u044C\u044E \u0431\u044B\u043B\u0430 \u043D\u0430\u0443\u043A\u0430
    \u0438 \u0438\u0437\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u043E\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043F\u0440\u0438\u0431\u043E\u0440\u043E\u0432.
    \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F
    \u0438 \u0434\u0430\u0436\u0435 \u0432\u044B\u0441\u0442\u0430\u0432\u0438\u043B
    \u0435\u0433\u043E \u0432 \u0432\u0438\u0442\u0440\u0438\u043D\u0435 \u0441\u0432\u043E\u0435\u0439
    \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439 \u0441 \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435\u043C
    \u0434\u043B\u044F \u0432\u0441\u0435\u0445 \u0436\u0435\u043B\u0430\u044E\u0449\u0438\u0445.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u043F\u043E \u0438\u0440\u043E\u043D\u0438\u0438
    \u0441\u0443\u0434\u044C\u0431\u044B, \u044D\u0442\u043E \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435
    \u0440\u0430\u0437\u043E\u0440\u0438\u043B\u043E \u0435\u0433\u043E, \u0438 \u043E\u043D
    \u043E\u0431\u0430\u043D\u043A\u0440\u043E\u0442\u0438\u043B\u0441\u044F. \u0421\u043F\u0443\u0441\u0442\u044F
    \u043C\u043D\u043E\u0433\u043E \u043B\u0435\u0442, \u0443\u0436\u0435 \u0431\u0443\u0434\u0443\u0447\u0438
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u043C \u0443\u0447\u0451\u043D\u044B\u043C,
    \u0432\u043D\u0443\u043A \u0414\u0436\u043E\u0440\u0434\u0436\u0430 \u0411\u0443\u043B\u044F,
    \u0441\u044D\u0440 \u0414\u0436\u0435\u0444\u0444\u0440\u0438 \u0422\u0435\u0439\u043B\u043E\u0440,
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0432 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E
    \u044F\u0449\u0438\u0447\u0435\u043A \u043E\u0442 \u0442\u043E\u0433\u043E \u0441\u0430\u043C\u043E\u0433\u043E
    \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u0430. \u041D\u0430 \u0435\u0433\u043E
    \u0434\u043D\u0435 \u0440\u0443\u043A\u043E\u0439 \u0435\u0433\u043E \u0431\u0430\u0431\u0443\u0448\u043A\u0438,
    \u0432\u0434\u043E\u0432\u044B \u0414\u0436\u043E\u0440\u0434\u0436\u0430, \u0431\u044B\u043B\u043E
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043E: \xAB\u041F\u043E\u0445\u043E\u0436\u0435,
    \u043E\u043D \u0432\u0441\u0451 \u043C\u043E\u0433 \u0434\u0435\u043B\u0430\u0442\u044C
    \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E, \u0432\u0441\u0451, \u043A\u0440\u043E\u043C\u0435
    \u0441\u0432\u043E\u0435\u0439 \u0440\u0430\u0431\u043E\u0442\u044B\xBB. \u041F\u0440\u0438
    \u044D\u0442\u043E\u043C \u0422\u0435\u0439\u043B\u043E\u0440 \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0438 \u0441\u0435\u0440\u0435\u0431\u0440\u044F\u043D\u044B\u0435 \u043B\u043E\u0436\u0435\u0447\u043A\u0438
    \u0441 \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u043C\u043C\u043E\u0439 \u043F\u0440\u0430\u0434\u0435\u0434\u0430,
    \u0447\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043E \u0442\u043E\u043C,
    \u0447\u0442\u043E \u0441\u0435\u043C\u044C\u044F \u0437\u043D\u0430\u0432\u0430\u043B\u0430
    \u0438 \u043B\u0443\u0447\u0448\u0438\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u0430. 
    ### \u2764\uFE0F \u0420\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0438 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u0430\u044F
    \u0436\u0435\u043D\u0430  *   **\u0421\u0432\u0430\u0442\u043E\u0432\u0441\u0442\u0432\u043E
    \u0447\u0435\u0440\u0435\u0437 \u0430\u043B\u0433\u0435\u0431\u0440\u0443:**
    \u0411\u0443\u043B\u044C \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    40 \u043B\u0435\u0442 \u043D\u0430 \u041C\u044D\u0440\u0438 \u042D\u0432\u0435\u0440\u0435\u0441\u0442,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u044B\u043B\u0430 \u043D\u0430
    17 \u043B\u0435\u0442 \u0435\u0433\u043E \u043C\u043E\u043B\u043E\u0436\u0435.
    \u0418\u0445 \u0440\u043E\u043C\u0430\u043D \u043D\u0430\u0447\u0430\u043B\u0441\u044F
    \u0441 \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0411\u0443\u043B\u044C
    \u0434\u0430\u0432\u0430\u043B \u0435\u0439 \u0447\u0430\u0441\u0442\u043D\u044B\u0435
    \u0443\u0440\u043E\u043A\u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u044B. \u0421\u0430\u043C\u0430
    \u041C\u044D\u0440\u0438 \u0441 \u043F\u0440\u0438\u0441\u0443\u0449\u0435\u0439
    \u0435\u0439 \u044D\u043A\u0437\u0430\u043B\u044C\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0437\u0436\u0435 \u043F\u0438\u0441\u0430\u043B\u0430: \xAB\u042F
    \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u0437\u043D\u0430\u043B\u0430
    \u043E \u0413\u043E\u0441\u043F\u043E\u0434\u0435, \u043A\u0440\u043E\u043C\u0435
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u0410\u043B\u0433\u0435\u0431\u0440\u0443. \u042F \u0432\u0441\u0435\u0433\u0434\u0430
    \u0441\u0447\u0438\u0442\u0430\u043B\u0430 \u044D\u0442\u043E \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0439
    \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439 \u043B\u044E\u0431\u0438\u0442\u044C
    \u0435\u0433\u043E \u0432\u0441\u0435\u0439 \u0434\u0443\u0448\u043E\u0439 \u0438
    \u0432\u0441\u0435\u043C \u0441\u0435\u0440\u0434\u0446\u0435\u043C\xBB. *  
    **\u041E\u0442\u0437\u044B\u0432\u044B \xAB\u043F\u043E\u0447\u0442\u0438 \u043A\u0430\u043A
    \u0443 \u0441\u0432\u044F\u0442\u043E\u0433\u043E\xBB:** \u041F\u0435\u0440\u0435\u0434
    \u0441\u0432\u0430\u0434\u044C\u0431\u043E\u0439 \u041C\u044D\u0440\u0438 \u0440\u0435\u0448\u0438\u043B\u0430
    \u043D\u0430\u0432\u0435\u0441\u0442\u0438 \u0441\u043F\u0440\u0430\u0432\u043A\u0438
    \u043E \u0441\u0432\u043E\u0451\u043C \u0436\u0435\u043D\u0438\u0445\u0435. \u041E\u0434\u043D\u0430
    \u0438\u0437 \u0437\u043D\u0430\u043A\u043E\u043C\u044B\u0445 \u0434\u0430\u043C
    \u0434\u0430\u043B\u0430 \u0435\u043C\u0443 \u0432\u0435\u0441\u044C\u043C\u0430
    \u0434\u0432\u0443\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u043D\u0443\u044E
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0443:
    \xAB\u041E\u043D \u043C\u043D\u0435 \u043D\u0435 \u043D\u0440\u0430\u0432\u0438\u0442\u0441\u044F...
    \u042F \u043D\u0435 \u043B\u044E\u0431\u043B\u044E \u0442\u0430\u043A\u0438\u0445
    \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0443\u0436 \u0445\u043E\u0440\u043E\u0448\u0438\u0445
    \u043B\u044E\u0434\u0435\u0439... \u043A\u043E\u0433\u0434\u0430 \u0432\u044B
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0435\u0441\u044C \u0440\u044F\u0434\u043E\u043C
    \u0441 \u0442\u0430\u043A\u0438\u043C \u043F\u043E\u0447\u0442\u0438 \u0447\u0442\u043E
    \u0441\u0432\u044F\u0442\u044B\u043C, \u043D\u0435\u0432\u043E\u043B\u044C\u043D\u043E
    \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u0435\u0442 \u043E\u0449\u0443\u0449\u0435\u043D\u0438\u0435,
    \u0447\u0442\u043E \u043E\u043D \u0448\u043E\u043A\u0438\u0440\u043E\u0432\u0430\u043D
    \u0432\u0430\u0448\u0438\u043C \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435\u043C\xBB.
    \u0414\u0440\u0443\u0433\u0430\u044F \u0434\u0430\u043C\u0430 \u0443\u0441\u043F\u043E\u043A\u043E\u0438\u043B\u0430
    \u041C\u044D\u0440\u0438, \u0441\u043A\u0430\u0437\u0430\u0432, \u0447\u0442\u043E
    \u0441 \u043D\u0438\u043C \u043C\u043E\u0436\u043D\u043E \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E
    \u043E\u0442\u043F\u0443\u0441\u0442\u0438\u0442\u044C \u043D\u0430 \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0443
    \u0441\u0432\u043E\u044E \u043D\u0435\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E\u043B\u0435\u0442\u043D\u044E\u044E
    \u0434\u043E\u0447\u044C, \u043D\u0435 \u0431\u043E\u044F\u0441\u044C \u0437\u0430
    \u0435\u0451 \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044E. \u0422\u0430\u043A\u0438\u0435
    \u043E\u0442\u0437\u044B\u0432\u044B, \u0432\u0438\u0434\u0438\u043C\u043E, \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0443\u0431\u0435\u0434\u0438\u043B\u0438 \u041C\u044D\u0440\u0438 \u0432 \u043D\u0430\u0434\u0451\u0436\u043D\u043E\u0441\u0442\u0438
    \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E \u043C\u0443\u0436\u0430. *  
    **\u0413\u043E\u0440\u0430 \u042D\u0432\u0435\u0440\u0435\u0441\u0442:** \u041C\u044D\u0440\u0438
    \u0431\u044B\u043B\u0430 \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u0446\u0435\u0439
    \u0441\u044D\u0440\u0430 \u0414\u0436\u043E\u0440\u0434\u0436\u0430 \u042D\u0432\u0435\u0440\u0435\u0441\u0442\u0430,
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0430,
    \u0432 \u0447\u0435\u0441\u0442\u044C \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043D\u0430\u0437\u0432\u0430\u043D\u0430 \u0432\u044B\u0441\u043E\u0447\u0430\u0439\u0448\u0430\u044F
    \u0433\u043E\u0440\u0430 \u043C\u0438\u0440\u0430. \u0422\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0438\u043C\u044F \u0411\u0443\u043B\u044F
    \u0441\u0432\u044F\u0437\u0430\u043D\u043E \u0441 \u044D\u0442\u043E\u0439 \u0433\u043E\u0440\u043E\u0439
    \u0447\u0435\u0440\u0435\u0437 \u0435\u0433\u043E \u0436\u0435\u043D\u0443. 
    ### \U0001F3A8 \u0418\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B
    \u0438 \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u043A  *   **\u041F\u043E\u044D\u0442
    \u0432 \u0434\u0443\u0448\u0435 \u0438 \u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044C
    \xAB\u0420\u0430\u044F\xBB:** \u0411\u0443\u043B\u044C \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0441 \u0448\u0438\u0440\u043E\u043A\u0438\u043C\u0438 \u0433\u0443\u043C\u0430\u043D\u0438\u0442\u0430\u0440\u043D\u044B\u043C\u0438
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0430\u043C\u0438. \u0415\u0433\u043E
    \u043B\u044E\u0431\u0438\u043C\u044B\u043C \u043F\u043E\u044D\u0442\u043E\u043C
    \u0431\u044B\u043B \u0414\u0430\u043D\u0442\u0435, \u043D\u043E, \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445, \xAB\u0420\u0430\u0439\xBB
    \u043D\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0435\u043C\u0443 \u0433\u043E\u0440\u0430\u0437\u0434\u043E
    \u0431\u043E\u043B\u044C\u0448\u0435, \u0447\u0435\u043C \xAB\u0410\u0434\xBB.
    \u041E\u043D \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0438\u0437\u0443\u0447\u0430\u043B
    \u043C\u0435\u0442\u0430\u0444\u0438\u0437\u0438\u043A\u0443 \u0410\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u044F,
    \u044D\u0442\u0438\u043A\u0443 \u0421\u043F\u0438\u043D\u043E\u0437\u044B \u0438
    \u0442\u0440\u0443\u0434\u044B \u0426\u0438\u0446\u0435\u0440\u043E\u043D\u0430.
    *   **\u041F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F \u0432 \u0420\u043E\u0441\u0441\u0438\u0438
    \u043F\u043E\u0434 \u043F\u0441\u0435\u0432\u0434\u043E\u043D\u0438\u043C\u043E\u043C:**
    \u0411\u0443\u043B\u044C \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0441\u0442\u0430\u0442\u044C\u0438
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0432 \u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u0431\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u0438\u0445, \u043D\u043E \u0438
    \u0432 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0445 \u0436\u0443\u0440\u043D\u0430\u043B\u0430\u0445.
    \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0437 \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442 \u0431\u044B\u043B\u0438 \u043D\u0430\u043F\u0435\u0447\u0430\u0442\u0430\u043D\u044B
    \u0432 \xAB\u0412\u0435\u0441\u0442\u043D\u0438\u043A\u0435 \u0421\u0430\u043D\u043A\u0442-\u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A\xBB,
    \u043F\u0440\u0438\u0447\u0451\u043C \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043F\u0441\u0435\u0432\u0434\u043E\u043D\u0438\u043C **G. Boldt**.  \u042D\u0442\u0438
    \u0444\u0430\u043A\u0442\u044B \u0441\u043E\u0437\u0434\u0430\u044E\u0442 \u043E\u0431\u0440\u0430\u0437
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \xAB\u043E\u0442\u0446\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438\xBB, \u043D\u043E \u0438 \u0436\u0438\u0432\u044B\u043C,
    \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043C
    \u0438 \u043E\u0447\u0435\u043D\u044C \u043E\u0431\u0430\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C
    \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u0430 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043E\u0432, \u0441\u0442\u043E\u043B\u044C
    \u0436\u0435 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0445, \u043A\u0430\u043A
    \u0438 \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430."
