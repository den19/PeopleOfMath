  achievementsRu: "\u041E\u0441\u043D\u043E\u0432\u043D\u043E\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0414\u0436\u043E\u0440\u0434\u0436\u0430 \u0411\u0443\u043B\u044F \u0432 \u043D\u0430\u0443\u043A\u0443
    \u2014 \u044D\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E
    \u043D\u043E\u0432\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u0430 \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u043B\u043E\u0433\u0438\u043A\u0438, \u0447\u0442\u043E \u0432 \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C
    \u0441\u0447\u0451\u0442\u0435 \u0441\u0434\u0435\u043B\u0430\u043B\u043E \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u043C
    \u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u0435 \u0446\u0438\u0444\u0440\u043E\u0432\u044B\u0445
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u0432. \u0415\u0433\u043E
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u0434\u0435\u043B\u044F\u0442\u0441\u044F
    \u043D\u0430 \u0442\u0440\u0438 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438: \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    **\u0430\u043B\u0433\u0435\u0431\u0440\u044B \u043B\u043E\u0433\u0438\u043A\u0438**,
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0430 **\u043E\u0431\u0449\u0435\u0433\u043E
    \u043C\u0435\u0442\u043E\u0434\u0430 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0432\u044B\u0432\u043E\u0434\u0430** \u0438 \u0432\u0430\u0436\u043D\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u0432 **\u0447\u0438\u0441\u0442\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435**.  ### \U0001F9E0
    \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0430\u043B\u0433\u0435\u0431\u0440\u044B
    \u043B\u043E\u0433\u0438\u043A\u0438 (\u0411\u0443\u043B\u0435\u0432\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B)  \u0413\u043B\u0430\u0432\u043D\u0430\u044F
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u0430\u044F
    \u0438\u0434\u0435\u044F \u0411\u0443\u043B\u044F \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0430\u0441\u044C
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438
    \u0432 \u0432\u0438\u0434\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439.  *   **\u0413\u043B\u0430\u0432\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B**: \u0421\u0432\u043E\u0438 \u0438\u0434\u0435\u0438
    \u043E\u043D \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u0432 \u0434\u0432\u0443\u0445
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u0440\u0430\u0431\u043E\u0442\u0430\u0445.
    \u0412 1847 \u0433\u043E\u0434\u0443 \u0432\u044B\u0448\u0435\u043B \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u043D\u044B\u0439
    \u043F\u0430\u043C\u0444\u043B\u0435\u0442 **\xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u043B\u043E\u0433\u0438\u043A\u0438\xBB**,
    \u0430 \u0432 1854-\u043C \u2014 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 **\xAB\u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u0437\u0430\u043A\u043E\u043D\u043E\u0432 \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u044B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043B\u043E\u0433\u0438\u043A\u0438 \u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439\xBB**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043D \u0441\u0447\u0438\u0442\u0430\u043B
    \u0437\u0440\u0435\u043B\u044B\u043C \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C
    \u0441\u0432\u043E\u0435\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B. *  
    **\u0421\u0443\u0442\u044C \u0441\u0438\u0441\u0442\u0435\u043C\u044B**: \u0411\u0443\u043B\u044C
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043C\u0435\u0436\u0434\u0443
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0438 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F\u043C\u0438
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0433\u043B\u0443\u0431\u043E\u043A\u0430\u044F
    \u0430\u043D\u0430\u043B\u043E\u0433\u0438\u044F. \u041E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0441\u0438\u043C\u0432\u043E\u043B\u044B
    \u0434\u043B\u044F \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    \u043A\u043B\u0430\u0441\u0441\u043E\u0432 (\u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432)
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432, \u0433\u0434\u0435 `1` \u2014
    \u044D\u0442\u043E \xAB\u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u0439
    \u043A\u043B\u0430\u0441\u0441\xBB (\u0432\u0441\u0451 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0435\u043C\u044B\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432), \u0430 `0` \u2014 \xAB\u043F\u0443\u0441\u0442\u043E\u0439
    \u043A\u043B\u0430\u0441\u0441\xBB. \u041A \u044D\u0442\u0438\u043C \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u043C
    \u043C\u043E\u0436\u043D\u043E \u0431\u044B\u043B\u043E \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438, \u043F\u043E\u0445\u043E\u0436\u0438\u0435
    \u043D\u0430 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435:    
    *   **\u041B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435
    (\u0418, `\u2227`)** \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u0435\u0442
    \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u044E \u043A\u043B\u0430\u0441\u0441\u043E\u0432.    
    *   **\u041B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u0441\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    (\u0418\u041B\u0418, `\u2228`)** \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u0435\u0442
    \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044E \u043A\u043B\u0430\u0441\u0441\u043E\u0432
    (\u0445\u043E\u0442\u044F \u0432 \u0435\u0433\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u0435
    \u044D\u0442\u043E \u0431\u044B\u043B\u0430 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u044F,
    \u0431\u043B\u0438\u0437\u043A\u0430\u044F \u043A \u0441\u0442\u0440\u043E\u0433\u043E\u0439
    \u0434\u0438\u0437\u044A\u044E\u043D\u043A\u0446\u0438\u0438, \u0438\u0441\u043A\u043B\u044E\u0447\u0430\u044E\u0449\u0435\u0439
    \u043E\u0431\u0449\u0443\u044E \u0447\u0430\u0441\u0442\u044C).     *   **\u041B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0442\u0440\u0438\u0446\u0430\u043D\u0438\u0435 (\u041D\u0415, `\xAC`)**
    \u0432\u044B\u0440\u0430\u0436\u0430\u043B\u043E\u0441\u044C \u0447\u0435\u0440\u0435\u0437
    \xAB\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u0432\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u0435\xBB
    \u0438\u0437 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043A\u043B\u0430\u0441\u0441\u0430, \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u043E
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C \u0434\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u0435
    \u043A\u043B\u0430\u0441\u0441\u0430. *   **\u041A\u043B\u044E\u0447\u0435\u0432\u043E\u0435
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E**: \u0412 \u044D\u0442\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435 \u0441\u0442\u0430\u043B\u043E \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u043C
    \u043A\u043E\u0434\u0438\u0440\u043E\u0432\u0430\u0442\u044C \u043B\u044E\u0431\u044B\u0435
    \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043D\u0438\u044F \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u043C\u0438,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u043E\u043F\u0435\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0438\u043C\u0438 \u043F\u043E \u043F\u0440\u0430\u0432\u0438\u043B\u0430\u043C,
    \u0441\u0445\u043E\u0436\u0438\u043C \u0441 \u0440\u0435\u0448\u0435\u043D\u0438\u0435\u043C
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. \u0411\u0443\u043B\u044C
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B, \u0447\u0442\u043E \u0432
    \u0435\u0433\u043E \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0435 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
    \u043F\u043E\u0434\u0447\u0438\u043D\u044F\u044E\u0442\u0441\u044F \u0437\u0430\u043A\u043E\u043D\u0443
    `x\xB2 = x`. \u0412 \u043E\u0431\u044B\u0447\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u044D\u0442\u043E\u043C\u0443 \u0443\u0441\u043B\u043E\u0432\u0438\u044E \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u044F\u044E\u0442
    \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0438\u0441\u043B\u0430 0 \u0438
    1, \u0447\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B\u043E \u0434\u0432\u043E\u0438\u0447\u043D\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u043C
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u0435\u0433\u043E \u043B\u043E\u0433\u0438\u043A\u0438.  ### \U0001F9E9 \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0430
    \u043E\u0431\u0449\u0435\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u0430 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0432\u044B\u0432\u043E\u0434\u0430  \u0411\u0443\u043B\u044C \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0441\u043E\u0437\u0434\u0430\u043B \u043D\u043E\u0432\u044B\u0439 \u044F\u0437\u044B\u043A
    \u0434\u043B\u044F \u0437\u0430\u043F\u0438\u0441\u0438 \u043B\u043E\u0433\u0438\u043A\u0438.
    \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043C\u0435\u0442\u043E\u0434,
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0438\u0439 \u0434\u0435\u043B\u0430\u0442\u044C
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0435, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0441\u0442\u0440\u043E\u0433\u0438\u0435 \u0432\u044B\u0432\u043E\u0434\u044B. 
    *   **\u041E\u0442 \u043F\u043E\u0441\u044B\u043B\u043E\u043A \u043A \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044E**:
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u043A\u0430\u043A \u043B\u044E\u0431\u043E\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043D\u0438\u0439
    (\u043F\u043E\u0441\u044B\u043B\u043E\u043A) \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0432 \u0432\u0438\u0434\u0435 \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. \u0417\u0430\u0442\u0435\u043C,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u043C\u0435\u0442\u043E\u0434\u044B,
    \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u044E\u0449\u0438\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u043E\u0431\u044B\u0447\u043D\u044B\u0445 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445),
    \u043C\u043E\u0436\u043D\u043E \u0447\u0438\u0441\u0442\u043E \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u044B\u0432\u0435\u0441\u0442\u0438 \u043B\u044E\u0431\u043E\u0435 \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u0441\u043B\u0435\u0434\u0443\u0435\u0442 \u0438\u0437 \u044D\u0442\u0438\u0445
    \u043F\u043E\u0441\u044B\u043B\u043E\u043A. \u042D\u0442\u043E \u0431\u044B\u043B
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u044B\u0439 \u0448\u0430\u0433
    \u0432\u043F\u0435\u0440\u0451\u0434 \u043F\u043E \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044E
    \u0441 \u0430\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u0435\u0432\u043E\u0439
    \u0441\u0438\u043B\u043B\u043E\u0433\u0438\u0441\u0442\u0438\u043A\u043E\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u044B\u043B\u0430 \u043E\u0441\u043D\u043E\u0432\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438 \u043D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438
    \u0431\u043E\u043B\u0435\u0435 \u0434\u0432\u0443\u0445 \u0442\u044B\u0441\u044F\u0447
    \u043B\u0435\u0442. *   **\u0421\u0432\u044F\u0437\u044C \u0441 \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0435\u0439
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F**: \u0411\u0443\u043B\u044C
    \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B \u0441\u0432\u043E\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043A\u0430\u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E,
    \u043D\u043E \u0438 \u043A\u0430\u043A \u043F\u043E\u043F\u044B\u0442\u043A\u0443
    \u043E\u043F\u0438\u0441\u0430\u0442\u044C \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \xAB\u0437\u0430\u043A\u043E\u043D\u044B \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F\xBB.
    \u0412 \u0441\u0432\u043E\u0438\u0445 \u0437\u0430\u043C\u0435\u0442\u043A\u0430\u0445
    \u043E\u043D \u043F\u043E\u0434\u0447\u0451\u0440\u043A\u0438\u0432\u0430\u043B,
    \u0447\u0442\u043E \u043F\u0440\u0435\u0436\u0434\u0435 \u0447\u0435\u043C \u0430\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441 \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u044F,
    \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E \u043F\u043E\u043D\u044F\u0442\u044C
    \u0437\u0430\u043A\u043E\u043D\u044B \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0439
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F, \u0441\u0443\u0436\u0434\u0435\u043D\u0438\u044F
    \u0438 \u043F\u043E\u043D\u044F\u0442\u0438\u044F.  ### \u2795 \u0412\u043A\u043B\u0430\u0434
    \u0432 \u0447\u0438\u0441\u0442\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 
    \u0412\u043A\u043B\u0430\u0434 \u0411\u0443\u043B\u044F \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u043B\u0441\u044F
    \u043B\u043E\u0433\u0438\u043A\u043E\u0439. \u041E\u043D \u0431\u044B\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u0441\u0432\u043E\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438.  *   **\u041D\u0430\u0433\u0440\u0430\u0434\u044B
    \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435**: \u0412 1844
    \u0433\u043E\u0434\u0443 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E \u043D\u0430\u0433\u0440\u0430\u0434\u0438\u043B\u043E
    \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u043E\u0439 \u0437\u043E\u043B\u043E\u0442\u043E\u0439
    \u043C\u0435\u0434\u0430\u043B\u044C\u044E \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u0443
    **\xAB\u041E\u0431 \u043E\u0431\u0449\u0435\u043C \u043C\u0435\u0442\u043E\u0434\u0435
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430\xBB**, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043E\u043D \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u0441\u043F\u043E\u0441\u043E\u0431\u044B
    \u043A\u043E\u043C\u0431\u0438\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u043C\u0435\u0442\u043E\u0434\u043E\u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u044B
    \u0438 \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F. \u0412 1857
    \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D
    \u0447\u043B\u0435\u043D\u043E\u043C \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430. *   **\u041A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0438**: \u0415\u0433\u043E \u0442\u0440\u0443\u0434\u044B
    **\xAB\u0422\u0440\u0430\u043A\u0442\u0430\u0442 \u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u0445\xBB** (1859) \u0438
    **\xAB\u0422\u0440\u0430\u043A\u0442\u0430\u0442 \u043E \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445
    \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u044F\u0445\xBB** (1860) \u0434\u043E\u043B\u0433\u0438\u0435
    \u0433\u043E\u0434\u044B \u0441\u0447\u0438\u0442\u0430\u043B\u0438\u0441\u044C
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0438 \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u044D\u0442\u0438\u0445 \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    **\u0442\u0435\u043E\u0440\u0438\u0438 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432**.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439**:
    \u0412\u043E \u0432\u0442\u043E\u0440\u043E\u0439 \u0447\u0430\u0441\u0442\u0438
    \xAB\u0417\u0430\u043A\u043E\u043D\u043E\u0432 \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F\xBB
    \u043E\u043D \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u044F\u043B \u043F\u043E\u043F\u044B\u0442\u043A\u0443
