  achievementsRu: "\u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0416\u0430\u043D\u0430-\u0411\u0430\u0442\u0438\u0441\u0442\u0430 \u0416\u043E\u0437\u0435\u0444\u0430
    \u0424\u0443\u0440\u044C\u0435 \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043D\u0430\u0431\u043E\u0440 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439,
    \u0430 \u0446\u0435\u043B\u0430\u044F \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0438 \u0444\u0438\u0437\u0438\u043A\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430 \u043F\u043E\u0434\u0445\u043E\u0434
    \u043A \u0440\u0435\u0448\u0435\u043D\u0438\u044E \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447. \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u043D\u0430 \u0442\u0440\u0438 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0445
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F: \"\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0442\u0435\u043F\u043B\u0430\" \u0441
    \u0435\u0451 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u043E\u043C, \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0435
    \u0438 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0435 \u0434\u043B\u044F
    \u0444\u0438\u0437\u0438\u043A\u0430-\u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A\u0430
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043A\u043B\u0438\u043C\u0430\u0442\u0430 \u0438 \u0442\u0435\u0440\u043C\u043E\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u0430. 
    ### \U0001F4DC \"\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0442\u0435\u043F\u043B\u0430\" \u0438
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u043D\u043E\u0432\u043E\u0433\u043E
    \u043C\u0435\u0442\u043E\u0434\u0430  \u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0435
    \u043C\u0435\u0441\u0442\u043E \u0432 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438 \u0424\u0443\u0440\u044C\u0435
    \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \u0442\u0435\u043F\u043B\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0432\u044B\u043B\u0438\u043B\u0430\u0441\u044C
    \u0432 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E
    \u043D\u043E\u0432\u043E\u0433\u043E \u043F\u043E\u0434\u0445\u043E\u0434\u0430
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435.  *   **\u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434.** \u0412 1822 \u0433\u043E\u0434\u0443 \u0424\u0443\u0440\u044C\u0435
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    **\xAB\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0442\u0435\u043F\u043B\u0430\xBB** (*Th\xE9orie
    analytique de la chaleur*). \u042D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434
    \u0441\u0442\u0430\u043B \u0438\u0442\u043E\u0433\u043E\u043C \u0435\u0433\u043E
    \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0438\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439,
    \u043D\u0430\u0447\u0430\u0442\u044B\u0445 \u0435\u0449\u0435 \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u0440\u0435\u0444\u0435\u043A\u0442\u043E\u043C
    \u0432 \u0413\u0440\u0435\u043D\u043E\u0431\u043B\u0435. *   **\u0423\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u0442\u0435\u043F\u043B\u043E\u043F\u0440\u043E\u0432\u043E\u0434\u043D\u043E\u0441\u0442\u0438.**
    \u0424\u0443\u0440\u044C\u0435 \u0432\u044B\u0432\u0435\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    **\u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \u0432 \u0447\u0430\u0441\u0442\u043D\u044B\u0445
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0445**, \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0449\u0435\u0435
    \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u0435
    \u0442\u0435\u043F\u043B\u0430 \u0432 \u0442\u0432\u0435\u0440\u0434\u044B\u0445
    \u0442\u0435\u043B\u0430\u0445. \u042D\u0442\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u0441\u0442\u0430\u043B\u043E \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C
    \u043A\u0430\u043C\u043D\u0435\u043C \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0434\u043B\u044F \u0444\u0438\u0437\u0438\u043A\u0438 \u0442\u0435\u043F\u043B\u0430,
    \u043D\u043E \u0438 \u0434\u043B\u044F \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u0434\u0440\u0443\u0433\u0438\u0445 \u044F\u0432\u043B\u0435\u043D\u0438\u0439,
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u043C\u044B\u0445 \u0434\u0438\u0444\u0444\u0443\u0437\u0438\u043E\u043D\u043D\u044B\u043C\u0438
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0430\u043C\u0438: \u043E\u0442 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043C\u043E\u043B\u0435\u043A\u0443\u043B \u0438 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u0430
    \u0434\u043E \u043C\u043E\u0434\u0435\u043B\u0435\u0439 \u0432 \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438,
    \u0433\u0435\u043E\u043B\u043E\u0433\u0438\u0438 \u0438 \u0434\u0430\u0436\u0435
    \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445 \u043D\u0430\u0443\u043A\u0430\u0445.
    *   **\u041C\u0435\u0442\u043E\u0434 \u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 (\u043C\u0435\u0442\u043E\u0434
    \u0424\u0443\u0440\u044C\u0435).** \u0427\u0442\u043E\u0431\u044B \u0440\u0435\u0448\u0438\u0442\u044C
    \u043D\u043E\u0432\u043E\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435,
    \u0424\u0443\u0440\u044C\u0435 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043C\u043E\u0449\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442 \u2014 **\u043C\u0435\u0442\u043E\u0434
    \u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445**.
    \u0421\u0443\u0442\u044C \u043C\u0435\u0442\u043E\u0434\u0430 \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F
    \u0432 \u043F\u043E\u0438\u0441\u043A\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0432 \u0432\u0438\u0434\u0435 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439, \u043A\u0430\u0436\u0434\u0430\u044F
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0437\u0430\u0432\u0438\u0441\u0438\u0442
    \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0442 \u043E\u0434\u043D\u043E\u0439
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439. \u042D\u0442\u043E
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u0441\u0432\u0435\u0441\u0442\u0438
    \u0441\u043B\u043E\u0436\u043D\u0443\u044E \u0437\u0430\u0434\u0430\u0447\u0443
    \u0432 \u0447\u0430\u0441\u0442\u043D\u044B\u0445 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0445
    \u043A \u0431\u043E\u043B\u0435\u0435 \u043F\u0440\u043E\u0441\u0442\u044B\u043C
    \u043E\u0431\u044B\u043A\u043D\u043E\u0432\u0435\u043D\u043D\u044B\u043C \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C.  ### \U0001F4C8
    \u0420\u044F\u0434\u044B \u0424\u0443\u0440\u044C\u0435: \u0442\u0440\u0438\u0443\u043C\u0444
    \u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0441\u043F\u043E\u0440  \u0414\u043B\u044F \u0440\u0435\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438
    \u0441\u0432\u043E\u0435\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u0430 \u0424\u0443\u0440\u044C\u0435
    \u043F\u043E\u043D\u0430\u0434\u043E\u0431\u0438\u043B\u043E\u0441\u044C \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u0448\u0430\u0433, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u044B\u0437\u0432\u0430\u043B
    \u043E\u0436\u0435\u0441\u0442\u043E\u0447\u0435\u043D\u043D\u044B\u0435 \u0441\u043F\u043E\u0440\u044B
    \u0441\u0440\u0435\u0434\u0438 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0442\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0438 \u043E\u0442\u043A\u0440\u044B\u043B
    \u043D\u043E\u0432\u0443\u044E \u0433\u043B\u0430\u0432\u0443 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0430\u043D\u0430\u043B\u0438\u0437\u0435.  *   **\u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439.** \u0412 \u043E\u0441\u043D\u043E\u0432\u0435
    \u043C\u0435\u0442\u043E\u0434\u0430 \u0424\u0443\u0440\u044C\u0435 \u043B\u0435\u0436\u0438\u0442
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u043B\u044C\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u0432 \u0432\u0438\u0434\u0435 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445
    \u0441\u0443\u043C\u043C \u0441\u0438\u043D\u0443\u0441\u043E\u0432 \u0438 \u043A\u043E\u0441\u0438\u043D\u0443\u0441\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0442\u0435\u043F\u0435\u0440\u044C
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B \u043A\u0430\u043A **\u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0440\u044F\u0434\u044B \u0424\u0443\u0440\u044C\u0435**. *   **\u041D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u0442\u0432\u043E
    \u0438 \u0441\u043A\u0435\u043F\u0441\u0438\u0441.** \u0425\u043E\u0442\u044F
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0434\u0435\u0438
    \u0440\u0430\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u0432 \u0442\u0430\u043A\u0438\u0435
    \u0440\u044F\u0434\u044B \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u0438 \u0440\u0430\u043D\u0435\u0435 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0443 \u0414. \u0411\u0435\u0440\u043D\u0443\u043B\u043B\u0438), \u0438\u043C\u0435\u043D\u043D\u043E
    \u0424\u0443\u0440\u044C\u0435 \u043F\u0435\u0440\u0432\u044B\u043C \u043D\u0430\u0447\u0430\u043B
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C \u0438\u0445 \u0434\u043B\u044F
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447 \u0438 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u0442\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C
    \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    **\u043B\u044E\u0431\u0443\u044E** \u0444\u0443\u043D\u043A\u0446\u0438\u044E,
    \u0434\u0430\u0436\u0435 \u0442\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043D\u0430 \u0440\u0430\u0437\u043D\u044B\u0445 \u0443\u0447\u0430\u0441\u0442\u043A\u0430\u0445
    \u0437\u0430\u0434\u0430\u043D\u0430 \u0440\u0430\u0437\u043D\u044B\u043C\u0438
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u044F\u043C\u0438. \u042D\u0442\u043E
    \u0431\u044B\u043B\u043E \u0441\u043C\u0435\u043B\u043E\u0435 \u0438 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0435
    \u0437\u0430\u044F\u0432\u043B\u0435\u043D\u0438\u0435. \u041A\u043E\u0433\u0434\u0430
    \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0441\u0432\u043E\u0439
    \u043F\u0435\u0440\u0432\u044B\u0439 \u043C\u0435\u043C\u0443\u0430\u0440 \u0432
    1807 \u0433\u043E\u0434\u0443, \u0442\u0430\u043A\u0438\u0435 \u043A\u043E\u0440\u0438\u0444\u0435\u0438,
    \u043A\u0430\u043A \u041B\u0430\u0433\u0440\u0430\u043D\u0436 \u0438 \u041B\u0430\u043F\u043B\u0430\u0441,
    \u043F\u043E\u0434\u0432\u0435\u0440\u0433\u043B\u0438 \u0435\u0433\u043E \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u044E.
    \u041F\u043E\u0437\u0436\u0435 \u0432\u044B\u044F\u0441\u043D\u0438\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435
    \u0424\u0443\u0440\u044C\u0435 \u043D\u0435 \u0441\u043E\u0432\u0441\u0435\u043C
    \u0432\u0435\u0440\u043D\u043E \u0434\u043B\u044F \u0432\u0441\u0435\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439,
    \u043D\u043E \u0435\u0433\u043E \u043F\u043E\u043F\u044B\u0442\u043A\u0430 \u0438\u043D\u0438\u0446\u0438\u0438\u0440\u043E\u0432\u0430\u043B\u0430
    \u0446\u0438\u043A\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 (\u0414\u0438\u0440\u0438\u0445\u043B\u0435,
    \u0420\u0438\u043C\u0430\u043D\u0430 \u0438 \u0434\u0440.), \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u0440\u0438\u0432\u0435\u043B\u0438 \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    **\u0442\u0435\u043E\u0440\u0438\u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E** \u0438 **\u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432**. *   **\u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435.** \u0421\u0435\u0433\u043E\u0434\u043D\u044F
    \u0440\u044F\u0434\u044B \u0424\u0443\u0440\u044C\u0435 \u2014 \u044D\u0442\u043E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442. \u041E\u043D\u0438
    \u043B\u0435\u0436\u0430\u0442 \u0432 \u043E\u0441\u043D\u043E\u0432\u0435 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    **\u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0439 \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0438
    \u0441\u0438\u0433\u043D\u0430\u043B\u043E\u0432**, \u0441\u0436\u0430\u0442\u0438\u044F
    \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439 \u0438 \u0430\u0443\u0434\u0438\u043E
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0444\u043E\u0440\u043C\u0430\u0442
    JPEG), \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u0439 \u0441\u0442\u0440\u0443\u043D,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0432 \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0435
    (\u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0430 \u043A\u0430\u0440\u0434\u0438\u043E\u0433\u0440\u0430\u043C\u043C
    \u0438 \u0434\u0430\u043D\u043D\u044B\u0445 \u0423\u0417\u0418).  ### \U0001F4D0
    \u0412\u043A\u043B\u0430\u0434 \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0443
    \u0438 \u0442\u0435\u043E\u0440\u0438\u044E \u0447\u0438\u0441\u0435\u043B  \u041F\u043E\u043C\u0438\u043C\u043E
    \u0440\u0430\u0431\u043E\u0442 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435, \u0424\u0443\u0440\u044C\u0435 \u0441\u0434\u0435\u043B\u0430\u043B
    \u0432\u0430\u0436\u043D\u044B\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0438 \u0432 \"\u0447\u0438\u0441\u0442\u043E\u0439\" \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. 
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0424\u0443\u0440\u044C\u0435.**
    \u0412 \u0441\u0432\u043E\u0438\u0445 \u043B\u0435\u043A\u0446\u0438\u044F\u0445
    \u0435\u0449\u0435 \u0432 1796 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    **\u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u043E \u0447\u0438\u0441\u043B\u0435
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043A\u043E\u0440\u043D\u0435\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F**, \u043B\u0435\u0436\u0430\u0449\u0438\u0445
    \u043C\u0435\u0436\u0434\u0443 \u0437\u0430\u0434\u0430\u043D\u043D\u044B\u043C\u0438
    \u0433\u0440\u0430\u043D\u0438\u0446\u0430\u043C\u0438. \u042D\u0442\u043E\u0442
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0432 1820 \u0433\u043E\u0434\u0443, \u0432\u043E\u0448\u0435\u043B \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E
    \u043A\u0430\u043A \u043E\u0434\u043D\u0430 \u0438\u0437 \u0432\u0430\u0436\u043D\u044B\u0445
    \u0442\u0435\u043E\u0440\u0435\u043C \u0430\u043B\u0433\u0435\u0431\u0440\u044B
    \u0438 \u043D\u043E\u0441\u0438\u0442 \u0435\u0433\u043E \u0438\u043C\u044F.
    *   **\u0427\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0435 \u043C\u0435\u0442\u043E\u0434\u044B.**
    \u0424\u0443\u0440\u044C\u0435 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043C\u043E\u0441\u0442\u0438
    \u043C\u0435\u0442\u043E\u0434\u0430 \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u0434\u043B\u044F \u0447\u0438\u0441\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439,
    \u0430 \u0435\u0433\u043E \u0438\u0442\u043E\u0433\u043E\u0432\u044B\u0439 \u0442\u0440\u0443\u0434
    \u043F\u043E \u044D\u0442\u043E\u0439 \u0442\u0435\u043C\u0435, **\xAB\u0410\u043D\u0430\u043B\u0438\u0437
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439\xBB**
    (*Analyse des \xE9quations d\xE9termin\xE9es*), \u0431\u044B\u043B \u0438\u0437\u0434\u0430\u043D
    \u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    \u0432 1831 \u0433\u043E\u0434\u0443.  ### \U0001F30D \u041F\u0430\u0440\u043D\u0438\u043A\u043E\u0432\u044B\u0439
    \u044D\u0444\u0444\u0435\u043A\u0442 \u0438 \u0442\u0435\u0440\u043C\u043E\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u043E 
    \u041C\u0435\u043D\u0435\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B,
    \u043D\u043E \u043D\u0435 \u043C\u0435\u043D\u0435\u0435 \u0437\u043D\u0430\u0447\u0438\u043C\u044B
    \u0440\u0430\u0431\u043E\u0442\u044B \u0424\u0443\u0440\u044C\u0435, \u0432\u044B\u0445\u043E\u0434\u044F\u0449\u0438\u0435
    \u0437\u0430 \u0440\u0430\u043C\u043A\u0438 \"\u0447\u0438\u0441\u0442\u043E\u0439\"
    \u043D\u0430\u0443\u043A\u0438 \u0438 \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u0432\u0448\u0438\u0435
    \u0446\u0435\u043B\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F. 
    *   **\u041E\u0442\u0435\u0446 \u043A\u043B\u0438\u043C\u0430\u0442\u043E\u043B\u043E\u0433\u0438\u0438.**
    \u0412 1820-\u0445 \u0433\u043E\u0434\u0430\u0445 \u0424\u0443\u0440\u044C\u0435
    \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0441\u044F
    \u0442\u0435\u043F\u043B\u043E\u0432\u044B\u043C \u0431\u0430\u043B\u0430\u043D\u0441\u043E\u043C
    \u0417\u0435\u043C\u043B\u0438. \u041E\u043D \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u043B,
    \u0447\u0442\u043E \u0417\u0435\u043C\u043B\u044F, \u043F\u043E\u043B\u0443\u0447\u0430\u044F
    \u0442\u0435\u043F\u043B\u043E \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0442
    \u0421\u043E\u043B\u043D\u0446\u0430, \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u0442\u044C
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0445\u043E\u043B\u043E\u0434\u043D\u0435\u0435,
    \u0435\u0441\u043B\u0438 \u0431\u044B \u043D\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E
    \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u044B. \u041E\u043D \u043F\u0440\u0438\u0448\u0435\u043B
    \u043A \u0432\u044B\u0432\u043E\u0434\u0443, \u0447\u0442\u043E \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0430
    \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442 \u043A\u0430\u043A \u0438\u0437\u043E\u043B\u0438\u0440\u0443\u044E\u0449\u0438\u0439
    \u0431\u0430\u0440\u044C\u0435\u0440, \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0430\u044F
    \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0439 \u0441\u0432\u0435\u0442,
    \u043D\u043E \u0437\u0430\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u044F \u0442\u0435\u043F\u043B\u043E\u0432\u043E\u0435
    \u0438\u0437\u043B\u0443\u0447\u0435\u043D\u0438\u0435 \u0417\u0435\u043C\u043B\u0438.
    \u042D\u0442\u043E \u0431\u044B\u043B\u0430 **\u043F\u0435\u0440\u0432\u0430\u044F
    \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0430
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u0430 \u043F\u0430\u0440\u043D\u0438\u043A\u043E\u0432\u043E\u0433\u043E
    \u044D\u0444\u0444\u0435\u043A\u0442\u0430**, \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u0435\u0442
    \u0435\u0433\u043E \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043A\u043B\u0438\u043C\u0430\u0442\u043E\u043B\u043E\u0433\u0438\u0438.
    *   **\u041E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0442\u0435\u0440\u043C\u043E\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u044D\u0444\u0444\u0435\u043A\u0442\u0430.** \u0412 1823 \u0433\u043E\u0434\u0443,
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E \u043E\u0442 \u0425\u0430\u043D\u0441\u0430
    \u041A\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0430 \u042D\u0440\u0441\u0442\u0435\u0434\u0430,
    \u0424\u0443\u0440\u044C\u0435 \u043E\u0442\u043A\u0440\u044B\u043B \u0442\u0435\u0440\u043C\u043E\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u044D\u0444\u0444\u0435\u043A\u0442. \u041E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u043F\u0438\u0441\u0430\u043B \u0435\u0433\u043E, \u043D\u043E \u0438
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043E\u043D \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C \u0441\u0443\u043F\u0435\u0440\u043F\u043E\u0437\u0438\u0446\u0438\u0438,
    \u0438 \u0441\u043E\u0437\u0434\u0430\u043B **\u043F\u0435\u0440\u0432\u044B\u0439
    \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0449\u0438\u0439 \u0442\u0435\u0440\u043C\u043E\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442**, \u0437\u0430\u043B\u043E\u0436\u0438\u0432
    \u043E\u0441\u043D\u043E\u0432\u044B \u0434\u043B\u044F \u0431\u0443\u0434\u0443\u0449\u0435\u0439
    \u0442\u0435\u0440\u043C\u043E\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u044D\u043D\u0435\u0440\u0433\u0435\u0442\u0438\u043A\u0438.  \u0418\u043C\u044F
    \u0424\u0443\u0440\u044C\u0435 \u043F\u043E \u043F\u0440\u0430\u0432\u0443 \u0432\u044B\u0431\u0438\u0442\u043E
    \u043D\u0430 \u042D\u0439\u0444\u0435\u043B\u0435\u0432\u043E\u0439 \u0431\u0430\u0448\u043D\u0435,
    \u0430 \u0435\u0433\u043E \u0438\u0434\u0435\u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044E\u0442
    \u043F\u0438\u0442\u0430\u0442\u044C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443 \u0438 \u0442\u0435\u0445\u043D\u0438\u043A\u0443
    \u2014 \u043E\u0442 \u043A\u043B\u0438\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u043E\u0434\u0435\u043B\u0435\u0439 \u0434\u043E \u0441\u0436\u0430\u0442\u0438\u044F
    \u0434\u0430\u043D\u043D\u044B\u0445 \u0438 \u0446\u0438\u0444\u0440\u043E\u0432\u044B\u0445
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0439."
  achievementsEn: 
  personalLifeRu: "\u041E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438
    \u0416\u0430\u043D\u0430-\u0411\u0430\u0442\u0438\u0441\u0442\u0430 \u0416\u043E\u0437\u0435\u0444\u0430
    \u0424\u0443\u0440\u044C\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E
    \u043E\u0447\u0435\u043D\u044C \u043C\u0430\u043B\u043E. \u041E\u043D \u043D\u0435
    \u0431\u044B\u043B \u0436\u0435\u043D\u0430\u0442, \u0438 \u0443 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432
    \u043D\u0435\u0442 \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u0439 \u043E \u043A\u0430\u043A\u0438\u0445-\u043B\u0438\u0431\u043E
    \u0435\u0433\u043E \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F\u0445. \u0415\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u043D\u0430\u0443\u043A\u0435, \u0430 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0431\u043B\u0438\u0437\u043A\u0430\u044F \u0441\u0432\u044F\u0437\u044C, \u043E
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0435\u0441\u0442\u044C \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F,
    \u043D\u043E\u0441\u0438\u043B\u0430, \u043F\u043E \u0432\u0441\u0435\u0439 \u0432\u0438\u0434\u0438\u043C\u043E\u0441\u0442\u0438,
    \u043F\u043B\u0430\u0442\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440.  ### \U0001F64F \u0420\u0430\u043D\u043D\u0435\u0435
    \u0441\u0438\u0440\u043E\u0442\u0441\u0442\u0432\u043E \u0438 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u0440\u0435\u043B\u0438\u0433\u0438\u0438  \u0421\u0435\u043C\u0435\u0439\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0441\u0430\u043C\u043E\u0433\u043E \u0424\u0443\u0440\u044C\u0435
    \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C \u0441 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438:
    \u043E\u043D \u0440\u0430\u043D\u043E \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u0439. \u0415\u0433\u043E \u043C\u0430\u0442\u044C
    \u0443\u043C\u0435\u0440\u043B\u0430, \u043A\u043E\u0433\u0434\u0430 \u0435\u043C\u0443
    \u0431\u044B\u043B\u043E \u0434\u0435\u0432\u044F\u0442\u044C \u043B\u0435\u0442,
    \u0430 \u043E\u0442\u0435\u0446 \u2014 \u0432 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C
    \u0433\u043E\u0434\u0443. \u0416\u043E\u0437\u0435\u0444 \u0431\u044B\u043B \u0434\u0435\u0432\u044F\u0442\u044B\u043C
    \u0438\u0437 \u0434\u0432\u0435\u043D\u0430\u0434\u0446\u0430\u0442\u0438 \u0434\u0435\u0442\u0435\u0439
    \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u043C \u0431\u0440\u0430\u043A\u0435
    \u043F\u043E\u0440\u0442\u043D\u043E\u0433\u043E.  \u042D\u0442\u043E \u0440\u0430\u043D\u043D\u0435\u0435
    \u0441\u0438\u0440\u043E\u0442\u0441\u0442\u0432\u043E \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u043E \u0435\u0433\u043E
    \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u0439 \u043F\u0443\u0442\u044C.
    \u041E\u043D \u0432\u043E\u0441\u043F\u0438\u0442\u044B\u0432\u0430\u043B\u0441\u044F
    \u043F\u0440\u0438 \u0446\u0435\u0440\u043A\u0432\u0438, \u0438 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u0434\u0430\u0436\u0435 \u0433\u043E\u0442\u043E\u0432\u0438\u043B\u0441\u044F
    \u043A \u0434\u0443\u0445\u043E\u0432\u043D\u043E\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u0435,
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u0432 \u0432 \u0431\u0435\u043D\u0435\u0434\u0438\u043A\u0442\u0438\u043D\u0441\u043A\u043E\u0435
    \u0430\u0431\u0431\u0430\u0442\u0441\u0442\u0432\u043E \u0421\u0435\u043D-\u0411\u0435\u043D\u0443\u0430-\u0441\u044E\u0440-\u041B\u0443\u0430\u0440.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0432 \u0438\u0442\u043E\u0433\u0435 \u043E\u043D
    \u0442\u0430\u043A \u0438 \u043D\u0435 \u043F\u0440\u0438\u043D\u044F\u043B \u043C\u043E\u043D\u0430\u0448\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u0435\u0442\u043E\u0432 \u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B \u0441\u0435\u0431\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u042D\u0442\u043E\u0442 \u0440\u0430\u043D\u043D\u0438\u0439 \u043E\u043F\u044B\u0442,
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043D\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0442\u043F\u0435\u0447\u0430\u0442\u043E\u043A \u043D\u0430 \u0435\u0433\u043E
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440, \u0441\u0434\u0435\u043B\u0430\u0432
    \u0435\u0433\u043E \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u043C \u0438
    \u0430\u0441\u043A\u0435\u0442\u0438\u0447\u043D\u044B\u043C.  ### \U0001F52C
    \u041D\u0430\u0443\u043A\u0430 \u043A\u0430\u043A \u0433\u043B\u0430\u0432\u043D\u0430\u044F
    \u0441\u0442\u0440\u0430\u0441\u0442\u044C \u0438 \u043D\u0435\u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u043D\u0430\u044F
    \u0434\u0440\u0443\u0436\u0431\u0430  \u0412\u0441\u044F \u0436\u0438\u0437\u043D\u044C
    \u0424\u0443\u0440\u044C\u0435 \u0431\u044B\u043B\u0430 \u043F\u043E\u0434\u0447\u0438\u043D\u0435\u043D\u0430
    \u043E\u0434\u043D\u043E\u0439 \u0446\u0435\u043B\u0438 \u2014 \u043D\u0430\u0443\u0447\u043D\u043E\u043C\u0443
    \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u044E. \u0414\u0430\u0436\u0435 \u0432\u043E
    \u0432\u0440\u0435\u043C\u044F \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0433\u043E
    \u043F\u043E\u0445\u043E\u0434\u0430 \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D\u0430,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440\u043E\u043C
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u044F\u0441\u044C \u0441\u043D\u0430\u0431\u0436\u0435\u043D\u0438\u0435\u043C
    \u0430\u0440\u043C\u0438\u0438, \u043E\u043D \u043D\u0430\u0445\u043E\u0434\u0438\u043B
    \u0432\u0440\u0435\u043C\u044F \u0434\u043B\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. \u0415\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434, \xAB\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0442\u0435\u043F\u043B\u0430\xBB, \u0431\u044B\u043B
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D \u0432 \u0413\u0440\u0435\u043D\u043E\u0431\u043B\u0435,
    \u0433\u0434\u0435 \u043E\u043D, \u0437\u0430\u043D\u0438\u043C\u0430\u044F \u043F\u043E\u0441\u0442
    \u043F\u0440\u0435\u0444\u0435\u043A\u0442\u0430, \u043E\u0442\u0434\u0430\u0432\u0430\u043B
    \u043D\u0430\u0443\u043A\u0435 \u0432\u0441\u0435 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F.  \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u043D\u0438\u0442\u044C, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u043B\u0430
    \u0435\u0433\u043E \u0441 \u043C\u0438\u0440\u043E\u043C \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445
    \u043B\u0438\u0447\u043D\u044B\u0445 \u0447\u0443\u0432\u0441\u0442\u0432, \u2014
    \u044D\u0442\u043E \u0434\u0440\u0443\u0436\u0431\u0430 \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    **\u041C\u0430\u0440\u0438-\u0421\u043E\u0444\u0438 \u0416\u0435\u0440\u043C\u0435\u043D**.
    \u0424\u0443\u0440\u044C\u0435 \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0445 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u0432,
    \u043A\u0442\u043E \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B
    \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u0443\u044E \u0436\u0435\u043D\u0449\u0438\u043D\u0443-\u0443\u0447\u0435\u043D\u043E\u0433\u043E
    \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F, \u043A\u043E\u0433\u0434\u0430
    \u0434\u043B\u044F \u0436\u0435\u043D\u0449\u0438\u043D \u043F\u0443\u0442\u044C
    \u0432 \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u043D\u0430\u0443\u043A\u0443
    \u0431\u044B\u043B \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0437\u0430\u043A\u0440\u044B\u0442. \u041E\u043D \u043F\u043E\u043C\u043E\u0433
    \u0435\u0439 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E\u0435
    \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043D\u0430 \u043F\u043E\u0441\u0435\u0449\u0435\u043D\u0438\u0435
    \u0437\u0430\u0441\u0435\u0434\u0430\u043D\u0438\u0439 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A.  \u0412 \u0430\u0440\u0445\u0438\u0432\u0430\u0445
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0441\u044C \u0438\u0445
    \u043F\u0438\u0441\u044C\u043C\u0430. \u041E\u043D\u0438 \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B, \u043D\u043E \u043E\u0434\u043D\u043E
    \u0438\u0437 \u043D\u0438\u0445, \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0435
    \u043D\u0435\u0437\u0430\u0434\u043E\u043B\u0433\u043E \u0434\u043E \u0435\u0433\u043E
    \u0441\u043C\u0435\u0440\u0442\u0438, \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442
    \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E \u0442\u0435\u043F\u043B\u043E\u0435
    \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0438 \u043F\u043E\u0434\u043F\u0438\u0441\u044C.
    \u0412 \u0434\u0440\u0443\u0433\u043E\u043C \u043F\u0438\u0441\u044C\u043C\u0435
    \u0424\u0443\u0440\u044C\u0435 \u043F\u0440\u043E\u0441\u0438\u0442 \u0432\u0440\u0430\u0447\u0430
    \u043E \u043A\u043E\u043D\u0444\u0438\u0434\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u043F\u043E\u043C\u043E\u0449\u0438 \u0434\u043B\u044F \u0441\u0432\u043E\u0435\u0433\u043E
    \xAB\u0434\u043E\u0440\u043E\u0433\u043E\u0433\u043E \u0434\u0440\u0443\u0433\u0430\xBB,
    \u0443 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0431\u044B\u043B\u0438
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0441\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435\u043C,
    \u0445\u043E\u0442\u044F \u0438\u043C\u044F \u0434\u0440\u0443\u0433\u0430 \u043F\u0440\u044F\u043C\u043E
    \u043D\u0435 \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F. \u0421\u043E\u0444\u0438
    \u0416\u0435\u0440\u043C\u0435\u043D, \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C \u043E\u0442 \u0440\u0430\u043A\u0430
    \u0433\u0440\u0443\u0434\u0438, \u0447\u0442\u043E \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u043E
    \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u043E \u0433\u043B\u0443\u0431\u0438\u043D\u0435 \u0435\u0433\u043E \u0447\u0443\u0432\u0441\u0442\u0432,
    \u043D\u043E \u043D\u0435 \u0434\u0430\u0435\u0442 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0439
    \u0434\u043B\u044F \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0432\u044B\u0432\u043E\u0434\u043E\u0432."
  personalLifeEn: 
  shortBioRu: "\u0416\u0430\u043D-\u0411\u0430\u0442\u0438\u0441\u0442 \u0416\u043E\u0437\u0435\u0444
    \u0424\u0443\u0440\u044C\u0435 (1768\u20131830) \u2014 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438 \u0444\u0438\u0437\u0438\u043A,
    \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430 \u0441\u0442\u043E\u043B\u044C
    \u0436\u0435 \u043D\u0430\u0441\u044B\u0449\u0435\u043D\u043D\u043E\u0439 \u0438
    \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u043E\u0439, \u043A\u0430\u043A
    \u0438 \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F.
    \u041E\u043D \u043F\u0440\u043E\u0448\u0451\u043B \u043F\u0443\u0442\u044C \u043E\u0442
    \u0441\u0438\u0440\u043E\u0442\u044B \u0438\u0437 \u0431\u0435\u0434\u043D\u043E\u0439
    \u0441\u0435\u043C\u044C\u0438 \u0434\u043E \u0431\u0430\u0440\u043E\u043D\u0430
    \u0438\u043C\u043F\u0435\u0440\u0438\u0438 \u0438 \u043D\u0435\u043F\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u044F \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A, \u0430
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u0438\u0437\u0438\u043A\u0443.  \u041D\u0438\u0436\u0435 \u043F\u0440\u0438\u0432\u0435\u0434\u0435\u043D\u0430
    \u0435\u0433\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u0430\u044F \u043D\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445.  ### \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0432\u0435\u0445\u0438 \u0436\u0438\u0437\u043D\u0438 \u0438 \u043A\u0430\u0440\u044C\u0435\u0440\u044B 
    \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0441\u043E\u0431\u044B\u0442\u0438\u044F
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u0424\u0443\u0440\u044C\u0435
    \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0432 \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043F\u043E\u0440\u044F\u0434\u043A\u0435:  *   **1768, 21 \u043C\u0430\u0440\u0442\u0430:**
    \u0420\u043E\u0434\u0438\u043B\u0441\u044F \u0432 \u0433\u043E\u0440\u043E\u0434\u0435
    \u041E\u0441\u0435\u0440, \u0424\u0440\u0430\u043D\u0446\u0438\u044F, \u0432
    \u0441\u0435\u043C\u044C\u0435 \u043F\u043E\u0440\u0442\u043D\u043E\u0433\u043E.
    *   **~1777:** \u0420\u0430\u043D\u043E \u043E\u0441\u0438\u0440\u043E\u0442\u0435\u043B,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u0434\u0435\u0432\u044F\u0442\u0438
    \u043B\u0435\u0442 \u0431\u044B\u043B \u043E\u0442\u0434\u0430\u043D \u043D\u0430
    \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0435 \u043E\u0440\u0433\u0430\u043D\u0438\u0441\u0442\u0443
    \u043C\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u0441\u043E\u0431\u043E\u0440\u0430.
    *   **1780-\u0435 \u0433\u0433.:** \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
    \u0435\u043F\u0438\u0441\u043A\u043E\u043F\u0430, \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0432\u043E\u0435\u043D\u043D\u0443\u044E \u0448\u043A\u043E\u043B\u0443
    \u0432 \u041E\u0441\u0435\u0440\u0435, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0438 \u0431\u0435\u043D\u0435\u0434\u0438\u043A\u0442\u0438\u043D\u0446\u044B.
    \u041F\u0440\u043E\u044F\u0432\u0438\u043B \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    *   **1789:** \u041E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432
    \u041F\u0430\u0440\u0438\u0436, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0432 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A
    \u0441\u0432\u043E\u0439 \u043F\u0435\u0440\u0432\u044B\u0439 \u043C\u0435\u043C\u0443\u0430\u0440
    \u043F\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0435. *   **1794\u20131795:**
    \u0421\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0412\u044B\u0441\u0448\u0435\u0439 \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B (\xC9cole Normale) \u0432 \u041F\u0430\u0440\u0438\u0436\u0435.
    *   **1795:** \u041D\u0430\u0447\u0430\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C
    \u0432 \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 (\xC9cole Polytechnique), \u0433\u0434\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0438\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438, \u0442\u0430\u043A\u0438\u043C\u0438
    \u043A\u0430\u043A \u0413\u0430\u0441\u043F\u0430\u0440 \u041C\u043E\u043D\u0436.
    *   **1798\u20131801:** \u041F\u0440\u0438\u043D\u044F\u043B \u0443\u0447\u0430\u0441\u0442\u0438\u0435
    \u0432 \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u043C \u043F\u043E\u0445\u043E\u0434\u0435
    \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D\u0430 \u0411\u043E\u043D\u0430\u043F\u0430\u0440\u0442\u0430.
    \u0411\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u0451\u043C
    \u041A\u0430\u0438\u0440\u0441\u043A\u043E\u0433\u043E \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430.
    *   **1801:** \u0412\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E
    \u0438 \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0437\u0430 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044E \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430 \u043F\u043E \u0438\u0442\u043E\u0433\u0430\u043C
    \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u0438 \u2014 \"\u041E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u0415\u0433\u0438\u043F\u0442\u0430\". *   **1802\u20131814:** \u041D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u043F\u0440\u0435\u0444\u0435\u043A\u0442\u043E\u043C \u0434\u0435\u043F\u0430\u0440\u0442\u0430\u043C\u0435\u043D\u0442\u0430
    \u0418\u0437\u0435\u0440 \u0441 \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u0432
    \u0413\u0440\u0435\u043D\u043E\u0431\u043B\u0435. \u0417\u0430\u043D\u0438\u043C\u0430\u043B
    \u044D\u0442\u043E\u0442 \u043F\u043E\u0441\u0442 13 \u043B\u0435\u0442. *  
    **1807:** \u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0432
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u0441\u0432\u043E\u0439 \u043F\u0435\u0440\u0432\u044B\u0439
    \u043C\u0435\u043C\u0443\u0430\u0440 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \u0442\u0435\u043F\u043B\u0430. *   **1808:** \u041F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0442\u0438\u0442\u0443\u043B \u0431\u0430\u0440\u043E\u043D\u0430 \u0438 \u0431\u044B\u043B
    \u043D\u0430\u0433\u0440\u0430\u0436\u0434\u0451\u043D \u043E\u0440\u0434\u0435\u043D\u043E\u043C
    \u041F\u043E\u0447\u0451\u0442\u043D\u043E\u0433\u043E \u043B\u0435\u0433\u0438\u043E\u043D\u0430.
    *   **1816:** \u041F\u043E\u0441\u043B\u0435 \u043F\u0430\u0434\u0435\u043D\u0438\u044F
    \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D\u0430 \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C \u0421\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0431\u044E\u0440\u043E \u0434\u0435\u043F\u0430\u0440\u0442\u0430\u043C\u0435\u043D\u0442\u0430
    \u0421\u0435\u043D\u0430 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435. *   **1817:**
    \u0418\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A. *  
    **1822:** \u041E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434
    \u2014 \"\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u0442\u0435\u043F\u043B\u0430\". \u0412
    \u044D\u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u0441\u0442\u0430\u043B
    \u043D\u0435\u043F\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u0451\u043C
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A. *   **1826:** \u0418\u0437\u0431\u0440\u0430\u043D
    \u0447\u043B\u0435\u043D\u043E\u043C \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u0438 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u044B \u0437\u0430 \u0441\u0432\u043E\u0438
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u0435\u0433\u0438\u043F\u0442\u043E\u043B\u043E\u0433\u0438\u0438.
    *   **1829:** \u0418\u0437\u0431\u0440\u0430\u043D \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u043C
    \u043F\u043E\u0447\u0451\u0442\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A. *  
    **1830, 16 \u043C\u0430\u044F:** \u0421\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u043F\u043E\u0441\u043B\u0435 \u043F\u0430\u0434\u0435\u043D\u0438\u044F
    \u0441 \u043B\u0435\u0441\u0442\u043D\u0438\u0446\u044B, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0443\u0441\u0443\u0433\u0443\u0431\u0438\u043B\u043E \u0435\u0433\u043E \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u0443\u044E
    \u0431\u043E\u043B\u0435\u0437\u043D\u044C. \u041F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u043D\u0430 \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435 \u041F\u0435\u0440-\u041B\u0430\u0448\u0435\u0437. 
    ---  ### \u0414\u0435\u0442\u0441\u0442\u0432\u043E, \u044E\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435  \u0416\u0430\u043D-\u0411\u0430\u0442\u0438\u0441\u0442
    \u0416\u043E\u0437\u0435\u0444 \u0424\u0443\u0440\u044C\u0435 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    21 \u043C\u0430\u0440\u0442\u0430 1768 \u0433\u043E\u0434\u0430 \u0432 \u0433\u043E\u0440\u043E\u0434\u0435
    \u041E\u0441\u0435\u0440. \u0415\u0433\u043E \u043E\u0442\u0435\u0446 \u0431\u044B\u043B
    \u043F\u043E\u0440\u0442\u043D\u044B\u043C, \u0438 \u0441\u0435\u043C\u044C\u044F
    \u0436\u0438\u043B\u0430 \u0431\u0435\u0434\u043D\u043E. \u0420\u0430\u043D\u043E
    \u043E\u0441\u0438\u0440\u043E\u0442\u0435\u0432 (\u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u0432\u043E\u0441\u044C\u043C\u0438 \u0438\u043B\u0438 \u0434\u0435\u0432\u044F\u0442\u0438
    \u043B\u0435\u0442), \u043C\u0430\u043B\u044C\u0447\u0438\u043A \u043D\u0430\u0448\u0451\u043B
    \u043F\u0440\u0438\u044E\u0442 \u0432 \u0434\u043E\u043C\u0435 \u043E\u0440\u0433\u0430\u043D\u0438\u0441\u0442\u0430
    \u0438 \u0443\u0447\u0438\u0442\u0435\u043B\u044F \u043C\u0443\u0437\u044B\u043A\u0438
    \u043F\u0440\u0438 \u043C\u0435\u0441\u0442\u043D\u043E\u043C \u0441\u043E\u0431\u043E\u0440\u0435. 
    \u0421\u0443\u0434\u044C\u0431\u043E\u043D\u043E\u0441\u043D\u0443\u044E \u0440\u043E\u043B\u044C
    \u0432 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438 \u0441\u044B\u0433\u0440\u0430\u043B
    \u0435\u043F\u0438\u0441\u043A\u043E\u043F \u041E\u0441\u0435\u0440\u0430, \u0437\u0430\u043C\u0435\u0442\u0438\u0432\u0448\u0438\u0439
    \u043D\u0435\u043E\u0431\u044B\u043A\u043D\u043E\u0432\u0435\u043D\u043D\u044B\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u0440\u0435\u0431\u0435\u043D\u043A\u0430.
    \u041F\u043E \u0435\u0433\u043E \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u0438
    \u0424\u0443\u0440\u044C\u0435 \u0431\u044B\u043B \u043F\u0440\u0438\u043D\u044F\u0442
    \u0432 \u0432\u043E\u0435\u043D\u043D\u0443\u044E \u0448\u043A\u043E\u043B\u0443
    \u043F\u0440\u0438 \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u0435 \u0431\u0435\u043D\u0435\u0434\u0438\u043A\u0442\u0438\u043D\u0446\u0435\u0432.
    \u0422\u0430\u043C \u043E\u043D \u0441 \u0443\u043F\u043E\u0440\u0441\u0442\u0432\u043E\u043C
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439,
    \u0447\u0430\u0441\u0442\u043E \u0442\u0430\u0439\u043A\u043E\u043C \u043F\u0440\u043E\u0441\u044B\u043F\u0430\u044F\u0441\u044C
    \u043D\u043E\u0447\u044C\u044E, \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u0438
    \u0441\u0432\u0435\u0442\u0435 \u043E\u0433\u0430\u0440\u043A\u043E\u0432 \u0447\u0438\u0442\u0430\u0442\u044C
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0438. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0432\u043E\u0435\u043D\u043D\u043E\u0433\u043E
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430 \u0438\u043B\u0438 \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u0441\u0442\u0430
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u0430 \u0437\u0430\u043A\u0440\u044B\u0442\u0430:
    \u0432 \u0442\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u0430 \u0432 \u044D\u0442\u0438
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0435 \u043A\u043E\u0440\u043F\u0443\u0441\u0430
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B\u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0434\u0432\u043E\u0440\u044F\u043D. \u0415\u043C\u0443 \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C
    \u0441\u0442\u0430\u0442\u044C \u043F\u043E\u0441\u043B\u0443\u0448\u043D\u0438\u043A\u043E\u043C
    \u0432 \u0430\u0431\u0431\u0430\u0442\u0441\u0442\u0432\u0435 \u0421\u0435\u043D-\u0411\u0435\u043D\u0443\u0430-\u0441\u044E\u0440-\u041B\u0443\u0430\u0440,
    \u043D\u043E \u0432\u0441\u043A\u043E\u0440\u0435 \u043F\u043E\u0441\u043B\u0435
    \u043D\u0430\u0447\u0430\u043B\u0430 \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438 \u043E\u043D \u043F\u043E\u043A\u0438\u043D\u0443\u043B
    \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u044C.  ### \u041D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0438 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430  \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F
    \u043E\u0442\u043A\u0440\u044B\u043B\u0430 \u043F\u0435\u0440\u0435\u0434 \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u043C
    \u0440\u0430\u0437\u043D\u043E\u0447\u0438\u043D\u0446\u0435\u043C \u043D\u043E\u0432\u044B\u0435
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438. \u0412 1794
    \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u0431\u044B\u043B\u0430
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0430 \u0412\u044B\u0441\u0448\u0430\u044F
    \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0430\u044F \u0448\u043A\u043E\u043B\u0430,
    \u0424\u0443\u0440\u044C\u0435 \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0435\u0451 \u043F\u0435\u0440\u0432\u044B\u0445 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432,
    \u0430 \u0432\u0441\u043A\u043E\u0440\u0435 \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C.
    \u0417\u0430\u0442\u0435\u043C \u043E\u043D \u043F\u0435\u0440\u0435\u0448\u0451\u043B
    \u0432 \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0432\u0448\u0443\u044E\u0441\u044F
    \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443, \u0433\u0434\u0435 \u043D\u0430\u0447\u0430\u043B
    \u0447\u0438\u0442\u0430\u0442\u044C \u043B\u0435\u043A\u0446\u0438\u0438 \u043F\u043E
    \u0432\u044B\u0441\u0448\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u0441\u043C\u0435\u043D\u0438\u0432 \u043D\u0430 \u044D\u0442\u043E\u043C \u043F\u043E\u0441\u0442\u0443
    \u0441\u0430\u043C\u043E\u0433\u043E \u0416\u043E\u0437\u0435\u0444\u0430-\u041B\u0443\u0438
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430.  \u0412 \u044D\u0442\u043E\u0442
    \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u043E\u0439,
    \u0440\u0430\u0431\u043E\u0442\u0430\u044F \u043D\u0430\u0434 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439.
    \u0412 1796 \u0433\u043E\u0434\u0443 \u043E\u043D \u0438\u0437\u043B\u043E\u0436\u0438\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u043E \u0447\u0438\u0441\u043B\u0435 \u043A\u043E\u0440\u043D\u0435\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F, \u043B\u0435\u0436\u0430\u0449\u0438\u0445
    \u043C\u0435\u0436\u0434\u0443 \u0437\u0430\u0434\u0430\u043D\u043D\u044B\u043C\u0438
    \u0433\u0440\u0430\u043D\u0438\u0446\u0430\u043C\u0438 (\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430
    \u0432 1820). \u0415\u0433\u043E \u0438\u0442\u043E\u0433\u043E\u0432\u044B\u0439
    \u0442\u0440\u0443\u0434 \u043F\u043E \u044D\u0442\u043E\u0439 \u0442\u0435\u043C\u0435,
    \"\u0410\u043D\u0430\u043B\u0438\u0437 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439\", \u0431\u044B\u043B
    \u0438\u0437\u0434\u0430\u043D \u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u0432 1831 \u0433\u043E\u0434\u0443. 
    ### \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0430\u044F \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u044F 
    \u0412 1798 \u0433\u043E\u0434\u0443 \u0424\u0443\u0440\u044C\u0435 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u0415\u0433\u0438\u043F\u0435\u0442 \u0432 \u0441\u043E\u0441\u0442\u0430\u0432\u0435
    \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u043E\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u0438 \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D\u0430.
    \u041E\u043D \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439 \u0438 \u043D\u0435\u043F\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C
    \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u0451\u043C \u041A\u0430\u0438\u0440\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B\u043B \u0441\u043E\u0437\u0434\u0430\u043D \u043F\u043E \u043E\u0431\u0440\u0430\u0437\u0446\u0443
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438.
    \u041D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438 \u0442\u0440\u0451\u0445
    \u043B\u0435\u0442 \u0432 \u0415\u0433\u0438\u043F\u0442\u0435 \u043E\u043D \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u043E\u0439, \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u044B\u0432\u0430\u044F
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E \u043F\u043E\u0440\u043E\u0445\u0430
    \u0438 \u043E\u0440\u0443\u0436\u0438\u044F \u0434\u043B\u044F \u0430\u0440\u043C\u0438\u0438,
    \u043D\u043E \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0438\u0437\u044B\u0441\u043A\u0430\u043D\u0438\u044F. \u041E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u0435\u043C\u0443\u0430\u0440\u043E\u0432 \u0438 \u0438\u0437\u0443\u0447\u0430\u043B
    \u0434\u0440\u0435\u0432\u043D\u0435\u0435\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0438\u0435
    \u043F\u0430\u043C\u044F\u0442\u043D\u0438\u043A\u0438.  \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E \u0432 1801 \u0433\u043E\u0434\u0443,
    \u0424\u0443\u0440\u044C\u0435 \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0437\u0430 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0443 \u043A
    \u043F\u0435\u0447\u0430\u0442\u0438 \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u043E\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430 \"\u041E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u0415\u0433\u0438\u043F\u0442\u0430\", \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u043B \u0441\u0443\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0432\u0441\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
    \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u0438, \u0438 \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u043A \u043D\u0435\u043C\u0443 \u043E\u0431\u0448\u0438\u0440\u043D\u043E\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u0432\u0432\u0435\u0434\u0435\u043D\u0438\u0435. 
    ### \u041F\u0440\u0435\u0444\u0435\u043A\u0442 \u0434\u0435\u043F\u0430\u0440\u0442\u0430\u043C\u0435\u043D\u0442\u0430
    \u0418\u0437\u0435\u0440 \u0438 \"\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0442\u0435\u043F\u043B\u0430\"  \u0421
    1802 \u043F\u043E 1814 \u0433\u043E\u0434 \u0424\u0443\u0440\u044C\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u043F\u043E\u0441\u0442 \u043F\u0440\u0435\u0444\u0435\u043A\u0442\u0430 (\u0433\u0443\u0431\u0435\u0440\u043D\u0430\u0442\u043E\u0440\u0430)
    \u0434\u0435\u043F\u0430\u0440\u0442\u0430\u043C\u0435\u043D\u0442\u0430 \u0418\u0437\u0435\u0440
    \u0432 \u0413\u0440\u0435\u043D\u043E\u0431\u043B\u0435. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u0443\u044E \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u0443\u044E
    \u043D\u0430\u0433\u0440\u0443\u0437\u043A\u0443, \u0432\u043A\u043B\u044E\u0447\u0430\u044E\u0449\u0443\u044E
    \u043E\u0441\u0443\u0448\u0435\u043D\u0438\u0435 \u0431\u043E\u043B\u043E\u0442,
    \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0434\u043E\u0440\u043E\u0433 \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0432\u043E\u043F\u0440\u043E\u0441\u044B, \u043E\u043D \u043D\u0435 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043D\u0430\u0443\u043A\u0443. \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \u0413\u0440\u0435\u043D\u043E\u0431\u043B\u0435,
    \u0432\u0434\u0430\u043B\u0438 \u043E\u0442 \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0445
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0443\u0433\u043E\u0432, \u043E\u043D \u043D\u0430\u0447\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0442\u0435\u043F\u043B\u0430. 
    \u0412 1807 \u0438 1811 \u0433\u043E\u0434\u0430\u0445 \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0443\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E
    \u043D\u0430\u0443\u043A \u043C\u0435\u043C\u0443\u0430\u0440\u044B \u043E \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u0438
    \u0442\u0435\u043F\u043B\u0430 \u0432 \u0442\u0432\u0451\u0440\u0434\u044B\u0445
    \u0442\u0435\u043B\u0430\u0445. \u0412\u0442\u043E\u0440\u043E\u0439 \u043C\u0435\u043C\u0443\u0430\u0440
    \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D \u043F\u0440\u0435\u043C\u0438\u0438
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438. \u042D\u0442\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0438 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u0438\u0434\u0435\u0438: \u043E\u043D \u0432\u044B\u0432\u0435\u043B \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \u0442\u0435\u043F\u043B\u043E\u043F\u0440\u043E\u0432\u043E\u0434\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u043C\u0435\u0442\u043E\u0434
    \u0435\u0433\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u044F, \u0440\u0430\u0437\u043B\u0430\u0433\u0430\u044F
    \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u044B\u0435 \u0443\u0441\u043B\u043E\u0432\u0438\u044F
    \u0432 \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0440\u044F\u0434\u044B (\u0440\u044F\u0434\u044B \u0424\u0443\u0440\u044C\u0435).
    \u0412 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u0430\u043A \u043C\u043D\u043E\u0433\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430, \u0441\u043E\u043C\u043D\u0435\u0432\u0430\u043B\u0438\u0441\u044C
    \u0432 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u043B\u044C\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u0442\u0430\u043A\u0438\u043C\u0438 \u0440\u044F\u0434\u0430\u043C\u0438, \u0424\u0443\u0440\u044C\u0435
    \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u043B \u043D\u0430 \u0438\u0445
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438. 
    \u041D\u0430\u043A\u043E\u043D\u0435\u0446, \u0432 1822 \u0433\u043E\u0434\u0443,
    \u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u0432 \u041F\u0430\u0440\u0438\u0436, \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 magnum opus \u2014 \"\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u0442\u0435\u043F\u043B\u0430\". \u042D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0441\u0442\u0430\u043B\u0430 \u043E\u0442\u043F\u0440\u0430\u0432\u043D\u043E\u0439
    \u0442\u043E\u0447\u043A\u043E\u0439 \u0434\u043B\u044F \u0446\u0435\u043B\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439. \u0412 \u043D\u0435\u0439 \u043E\u043D:
    *   \u041F\u043E\u0434\u0440\u043E\u0431\u043D\u043E \u0438\u0437\u043B\u043E\u0436\u0438\u043B
    \u043C\u0435\u0442\u043E\u0434 \u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445. *   \u0412\u0432\u0451\u043B
    \u0432 \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u0443\u043F\u043E\u0442\u0440\u0435\u0431\u043B\u0435\u043D\u0438\u0435
    \u0440\u044F\u0434\u044B \u0424\u0443\u0440\u044C\u0435. *   \u0412\u043D\u0451\u0441
    \u0432\u0430\u0436\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434 \u0432 \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437. *   \u0421\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u0442\u0435\u043F\u043B\u043E\u0432\u043E\u0433\u043E
    \u0438\u0437\u043B\u0443\u0447\u0435\u043D\u0438\u044F.  ### \"\u041F\u0430\u0440\u043D\u0438\u043A\u043E\u0432\u044B\u0439
    \u044D\u0444\u0444\u0435\u043A\u0442\" \u0438 \u0434\u0440\u0443\u0433\u0438\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B 
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441 \u0424\u0443\u0440\u044C\u0435 \u043A
    \u0442\u0435\u043F\u043B\u0443 \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u043B\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439. \u0412 1820-\u0445
    \u0433\u043E\u0434\u0430\u0445 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0442\u0430\u0442\u044C\u0438, \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0430\u043B \u043E \u0442\u0435\u043F\u043B\u043E\u0432\u043E\u043C
    \u0431\u0430\u043B\u0430\u043D\u0441\u0435 \u0417\u0435\u043C\u043B\u0438. \u041E\u043D
    \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u0417\u0435\u043C\u043B\u044F,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u043D\u0430\u0433\u0440\u0435\u0432\u0430\u0435\u043C\u043E\u0439
    \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u043C\u0438
    \u043B\u0443\u0447\u0430\u043C\u0438, \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u0442\u044C
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0445\u043E\u043B\u043E\u0434\u043D\u0435\u0435,
    \u0447\u0435\u043C \u0435\u0441\u0442\u044C \u043D\u0430 \u0441\u0430\u043C\u043E\u043C
    \u0434\u0435\u043B\u0435. \u0412 \u043F\u043E\u0438\u0441\u043A\u0430\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430
    \"\u043B\u0438\u0448\u043D\u0435\u0433\u043E\" \u0442\u0435\u043F\u043B\u0430
    \u043E\u043D \u0440\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0435\u043B \u0440\u043E\u043B\u044C
    \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u044B \u043A\u0430\u043A \u0438\u0437\u043E\u043B\u0438\u0440\u0443\u044E\u0449\u0435\u0433\u043E
    \u0431\u0430\u0440\u044C\u0435\u0440\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0430\u0435\u0442 \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0439
    \u0441\u0432\u0435\u0442, \u043D\u043E \u0437\u0430\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442
    \u0442\u0435\u043F\u043B\u043E\u0432\u043E\u0435 \u0438\u0437\u043B\u0443\u0447\u0435\u043D\u0438\u0435.
    \u042D\u0442\u043E\u0442 \u0432\u044B\u0432\u043E\u0434, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043D\u0430 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u0445
    \u0421\u043E\u0441\u0441\u044E\u0440\u0430 \u0441\u043E \u0441\u0442\u0435\u043A\u043B\u044F\u043D\u043D\u044B\u043C\u0438
    \u0431\u0430\u043D\u043A\u0430\u043C\u0438, \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043F\u0435\u0440\u0432\u043E\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u0430 \u043F\u0430\u0440\u043D\u0438\u043A\u043E\u0432\u043E\u0433\u043E
    \u044D\u0444\u0444\u0435\u043A\u0442\u0430.  \u041F\u043E\u043C\u0438\u043C\u043E
    \u044D\u0442\u043E\u0433\u043E, \u0424\u0443\u0440\u044C\u0435 \u0432 1823 \u0433\u043E\u0434\u0443
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E \u043E\u0442\u043A\u0440\u044B\u043B
    \u0442\u0435\u0440\u043C\u043E\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u044D\u0444\u0444\u0435\u043A\u0442 \u0438 \u0441\u043E\u0437\u0434\u0430\u043B
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0449\u0438\u0439
    \u0442\u0435\u0440\u043C\u043E\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442.  ### \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u0412 1817 \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043F\u0435\u0440\u0438\u043F\u0435\u0442\u0438\u0439
    (\u0435\u0433\u043E \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0443\u0440\u0430
    \u0431\u044B\u043B\u0430 \u043E\u0442\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u0430
    \u043A\u043E\u0440\u043E\u043B\u0451\u043C \u0432 1816 \u0433\u043E\u0434\u0443
    \u0438\u0437-\u0437\u0430 \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u0438
    \u0431\u043E\u043D\u0430\u043F\u0430\u0440\u0442\u0438\u0441\u0442\u0430), \u0424\u0443\u0440\u044C\u0435
    \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0432 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A. \u0412
    1822 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B \u0435\u0451
    \u043D\u0435\u043F\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u0451\u043C,
    \u0430 \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u044D\u0442\u0438\u043C \u0438
    \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u0433\u043B\u0430\u0432\u043E\u0439
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438. \u041D\u0430 \u044D\u0442\u043E\u043C \u043F\u043E\u0441\u0442\u0443
    \u043E\u043D \u043F\u0440\u043E\u0438\u0437\u043D\u043E\u0441\u0438\u043B \u0440\u0435\u0447\u0438
    \u0432 \u0447\u0435\u0441\u0442\u044C \u0443\u0448\u0435\u0434\u0448\u0438\u0445
    \u0438\u0437 \u0436\u0438\u0437\u043D\u0438 \u0443\u0447\u0451\u043D\u044B\u0445,
    \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 \u0441\u0432\u043E\u0435\u0433\u043E
    \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u043F\u043E \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0439
    \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u0438 \u0416\u0430\u043D\u0430-\u0424\u0440\u0430\u043D\u0441\u0443\u0430
    \u0428\u0430\u043C\u043F\u043E\u043B\u044C\u043E\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u0424\u0443\u0440\u044C\u0435 \u0432 \u044E\u043D\u043E\u0441\u0442\u0438 \u043F\u043E\u043C\u043E\u0433
    \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u0442\u044C\u0441\u044F
    \u0435\u0433\u0438\u043F\u0442\u043E\u043B\u043E\u0433\u0438\u0435\u0439.  \u0417\u0430\u0441\u043B\u0443\u0433\u0438
    \u0424\u0443\u0440\u044C\u0435 \u0431\u044B\u043B\u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u044B
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438. \u041E\u043D \u043D\u043E\u0441\u0438\u043B
    \u0442\u0438\u0442\u0443\u043B \u0431\u0430\u0440\u043E\u043D\u0430, \u0431\u044B\u043B
    \u043A\u0430\u0432\u0430\u043B\u0435\u0440\u043E\u043C \u043E\u0440\u0434\u0435\u043D\u0430
    \u041F\u043E\u0447\u0451\u0442\u043D\u043E\u0433\u043E \u043B\u0435\u0433\u0438\u043E\u043D\u0430,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u043C\u0438\u0440\u0430, \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A \u0438
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0435 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E. \u0415\u0433\u043E \u0438\u043C\u044F
    \u0432\u044B\u0431\u0438\u0442\u043E \u043D\u0430 \u042D\u0439\u0444\u0435\u043B\u0435\u0432\u043E\u0439
    \u0431\u0430\u0448\u043D\u0435.  \u0416\u0430\u043D-\u0411\u0430\u0442\u0438\u0441\u0442
    \u0416\u043E\u0437\u0435\u0444 \u0424\u0443\u0440\u044C\u0435 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    16 \u043C\u0430\u044F 1830 \u0433\u043E\u0434\u0430 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435,
    \u043E\u0441\u0442\u0430\u0432\u0438\u0432 \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043B\u0435\u0436\u0438\u0442 \u0432 \u043E\u0441\u043D\u043E\u0432\u0435 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439
    \u0447\u0430\u0441\u0442\u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438 \u0438 \u0442\u0435\u0445\u043D\u0438\u043A\u0438
    \u2014 \u043E\u0442 \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0439 \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0438
    \u0441\u0438\u0433\u043D\u0430\u043B\u043E\u0432 \u0434\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0416\u0430\u043D\u0430-\u0411\u0430\u0442\u0438\u0441\u0442\u0430
    \u0416\u043E\u0437\u0435\u0444\u0430 \u0424\u0443\u0440\u044C\u0435 \u043F\u043E\u043B\u043D\u0430
    \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0445 \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043E\u0432
    \u0438 \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u044B\u0445 \u0434\u0435\u0442\u0430\u043B\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432\u044B\u0445\u043E\u0434\u044F\u0442
    \u0434\u0430\u043B\u0435\u043A\u043E \u0437\u0430 \u0440\u0430\u043C\u043A\u0438
    \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u043E\u0440\u043C\u0443\u043B.  ### \U0001F525 1. \"\u041E\u0433\u043D\u0435\u043D\u043D\u0430\u044F\"
    \u043E\u0434\u0435\u0440\u0436\u0438\u043C\u043E\u0441\u0442\u044C \u0438 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u0430\u044F
    \u0441\u043C\u0435\u0440\u0442\u044C  \u0424\u0443\u0440\u044C\u0435 \u0431\u044B\u043B
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0435\u0439
    \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E\u0439 \u043E\u0434\u0435\u0440\u0436\u0438\u043C\u043E\u0441\u0442\u044C\u044E
    \u0442\u0435\u043F\u043B\u043E\u043C \u2014 \u0442\u043E\u0439 \u0441\u0430\u043C\u043E\u0439
    \u043C\u0430\u0442\u0435\u0440\u0438\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u0438\u0437\u0443\u0447\u0430\u043B. \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0438, \u0447\u0442\u043E
    \u043E\u043D \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E \u043C\u0451\u0440\u0437
    \u0438 \u043A\u043E\u043C\u043F\u0435\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E \u044D\u043A\u0441\u0442\u0440\u0430\u0432\u0430\u0433\u0430\u043D\u0442\u043D\u044B\u043C\u0438
    \u0441\u043F\u043E\u0441\u043E\u0431\u0430\u043C\u0438. \u041E\u043D \u043A\u0443\u0442\u0430\u043B\u0441\u044F
    \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u043B\u043E\u0451\u0432
    \u043E\u0434\u0435\u0436\u0434\u044B, \u0430 \u0435\u0433\u043E \u043A\u043E\u043C\u043D\u0430\u0442\u044B
    \u043E\u0442\u0430\u043F\u043B\u0438\u0432\u0430\u043B\u0438\u0441\u044C \u0434\u043E
    \u0442\u0435\u043C\u043F\u0435\u0440\u0430\u0442\u0443\u0440\u044B, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0437\u043D\u0430\u043A\u043E\u043C\u044B\u0435 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438
    \u043A\u0430\u043A \"\u0436\u0430\u0440\u0447\u0435 \u0430\u0434\u0430\". \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0434\u0430\u0436\u0435 \u043F\u043E\u043B\u0443\u043C\u0438\u0444\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0432\u0440\u0430\u0447\u0438 \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u043B\u0438
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0441\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435\u043C,
    \u0430 \u0432 \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C \u0441\u0447\u0451\u0442\u0435
    \u0438 \u0430\u043D\u0435\u0432\u0440\u0438\u0437\u043C\u0443, \u0441\u0442\u0430\u0432\u0448\u0443\u044E
    \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0432 1830 \u0433\u043E\u0434\u0443, \u0441 \u044D\u0442\u043E\u0439 \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u043E\u0439
    \u043A \u0441\u0438\u043B\u044C\u043D\u043E\u043C\u0443 \u043F\u0435\u0440\u0435\u0433\u0440\u0435\u0432\u0443. 
    ### \U0001F3DB\uFE0F 2. \"\u0422\u0430\u043D\u0446\u044B \u0441 \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u043E\u043C\":
    \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u0430\u044F \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u0433\u0440\u0430  \u0424\u0443\u0440\u044C\u0435, \u0432\u0435\u0440\u043D\u044B\u0439
    \u0431\u043E\u043D\u0430\u043F\u0430\u0440\u0442\u0438\u0441\u0442, \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u043F\u043E\u0441\u0442 \u043F\u0440\u0435\u0444\u0435\u043A\u0442\u0430 \u0434\u0435\u043F\u0430\u0440\u0442\u0430\u043C\u0435\u043D\u0442\u0430
    \u0418\u0437\u0435\u0440. \u041A\u043E\u0433\u0434\u0430 \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D
    \u0432 1814 \u0433\u043E\u0434\u0443 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u043F\u0435\u0440\u0432\u0443\u044E \u0441\u0441\u044B\u043B\u043A\u0443
    \u043D\u0430 \u042D\u043B\u044C\u0431\u0443, \u0435\u0433\u043E \u043F\u0443\u0442\u044C
    \u043F\u0440\u043E\u043B\u0435\u0433\u0430\u043B \u0447\u0435\u0440\u0435\u0437
    \u0413\u0440\u0435\u043D\u043E\u0431\u043B\u044C. \u041E\u043F\u0430\u0441\u0430\u044F\u0441\u044C
    \u0432\u0441\u0442\u0440\u0435\u0447\u0438 \u0438 \u043A\u043E\u043C\u043F\u0440\u043E\u043C\u0435\u0442\u0430\u0446\u0438\u0438
    \u043F\u0435\u0440\u0435\u0434 \u043D\u043E\u0432\u044B\u043C\u0438 \u0432\u043B\u0430\u0441\u0442\u044F\u043C\u0438,
    \u0424\u0443\u0440\u044C\u0435 \u0445\u0438\u0442\u0440\u043E\u0441\u0442\u044C\u044E
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B \u043C\u0430\u0440\u0448\u0440\u0443\u0442
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430, \u0438\u0437\u0431\u0435\u0436\u0430\u0432
    \u0432\u0441\u0442\u0440\u0435\u0447\u0438.  \u0412 1815 \u0433\u043E\u0434\u0443
    \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D \u0442\u0440\u0438\u0443\u043C\u0444\u0430\u043B\u044C\u043D\u043E
    \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E
    (\u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435 \"\u0421\u0442\u043E
    \u0434\u043D\u0435\u0439\"), \u0438 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044F
    \u043F\u043E\u0432\u0442\u043E\u0440\u0438\u043B\u0430\u0441\u044C. \u041D\u0430
    \u044D\u0442\u043E\u0442 \u0440\u0430\u0437, \u0436\u0435\u043B\u0430\u044F \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C
    \u043B\u043E\u044F\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0440\u043E\u044F\u043B\u0438\u0441\u0442\u0430\u043C,
    \u0424\u0443\u0440\u044C\u0435 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u043B
    \u0434\u043B\u044F \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430
    \u043F\u0440\u0438\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435, \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0437\u0430\u043F\u0438\u0441\u043A\u0443 \u043E \u0441\u0432\u043E\u0451\u043C
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432
    \u0438... \u0432 \u043F\u0430\u043D\u0438\u043A\u0435 \u0431\u0435\u0436\u0430\u043B
    \u0438\u0437 \u0433\u043E\u0440\u043E\u0434\u0430.  \u0420\u0430\u0437\u0433\u043D\u0435\u0432\u0430\u043D\u043D\u044B\u0439
    \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D \u043F\u043E\u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0441\u043C\u0435\u0449\u0435\u043D\u0438\u044F. \u041E\u0434\u043D\u0430\u043A\u043E,
    \u043A\u043E\u0433\u0434\u0430 \u0434\u0440\u0443\u0437\u044C\u044F \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0443 \"\u0418\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0432\u0432\u0435\u0434\u0435\u043D\u0438\u0435\" \u0424\u0443\u0440\u044C\u0435
    \u043A \"\u041E\u043F\u0438\u0441\u0430\u043D\u0438\u044E \u0415\u0433\u0438\u043F\u0442\u0430\",
    \u043F\u0440\u043E\u043D\u0438\u043A\u043D\u0443\u0442\u043E\u0435 \u043F\u043E\u0445\u0432\u0430\u043B\u0430\u043C\u0438
    \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u044E, \u0433\u043D\u0435\u0432 \u0441\u043C\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u043C\u0438\u043B\u043E\u0441\u0442\u044C. \u041C\u0430\u043B\u043E
    \u0442\u043E\u0433\u043E, \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D \u043F\u0440\u043E\u0441\u0442\u0438\u043B
    \u0424\u0443\u0440\u044C\u0435 \u0438 **\u043D\u0430\u0437\u043D\u0430\u0447\u0438\u043B
    \u0435\u0433\u043E \u043F\u0440\u0435\u0444\u0435\u043A\u0442\u043E\u043C \u0434\u0435\u043F\u0430\u0440\u0442\u0430\u043C\u0435\u043D\u0442\u0430
    \u0420\u043E\u043D\u0430** \u2014 \u0435\u0449\u0451 \u0431\u043E\u043B\u0435\u0435
    \u0432\u044B\u0441\u043E\u043A\u0438\u0439 \u043F\u043E\u0441\u0442. \u0412\u043F\u0440\u043E\u0447\u0435\u043C,
    \u044D\u0442\u0430 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u0440\u043E\u0434\u043B\u0438\u043B\u0430\u0441\u044C
    \u0432\u0441\u0435\u0433\u043E \u043E\u043A\u043E\u043B\u043E \u0434\u0432\u0443\u0445
    \u043C\u0435\u0441\u044F\u0446\u0435\u0432, \u0434\u043E \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u043E\u0440\u0430\u0436\u0435\u043D\u0438\u044F \u0411\u043E\u043D\u0430\u043F\u0430\u0440\u0442\u0430
    \u043F\u0440\u0438 \u0412\u0430\u0442\u0435\u0440\u043B\u043E\u043E.  ### \U0001F4D6
    3. \u041D\u043E\u0447\u043D\u044B\u0435 \u0437\u0430\u043D\u044F\u0442\u0438\u044F
    \u043F\u0440\u0438 \u0441\u0432\u0435\u0442\u0435 \u043E\u0433\u0430\u0440\u043A\u043E\u0432 
    \u0422\u044F\u0433\u0430 \u043A \u0437\u043D\u0430\u043D\u0438\u044F\u043C \u0443
    \u0424\u0443\u0440\u044C\u0435 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C
    \u0441 \u0440\u0430\u043D\u043D\u0438\u0445 \u043B\u0435\u0442. \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    13 \u043B\u0435\u0442 \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u044C\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439, \u0430 \u0432
    14 \u043B\u0435\u0442 \u0443\u0436\u0435 \u043E\u0441\u0432\u043E\u0438\u043B
    \u0432\u0435\u0441\u044C \u0448\u0435\u0441\u0442\u0438\u0442\u043E\u043C\u043D\u044B\u0439
    \u043A\u0443\u0440\u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0439 \u042D\u0442\u044C\u0435\u043D\u043E\u043C
    \u0411\u0435\u0437\u0443. \u0415\u0433\u043E \u0441\u0442\u0440\u0430\u0441\u0442\u044C
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u0435\u043B\u0438\u043A\u0430, \u0447\u0442\u043E \u043E\u043D, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C \u0432\u043E\u0435\u043D\u043D\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B \u043F\u0440\u0438 \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u0435,
    **\u0441\u043E\u0431\u0438\u0440\u0430\u043B \u0432\u044B\u0431\u0440\u043E\u0448\u0435\u043D\u043D\u044B\u0435
    \u0441\u0432\u0435\u0447\u043D\u044B\u0435 \u043E\u0433\u0430\u0440\u043A\u0438**,
    \u0447\u0442\u043E\u0431\u044B, \u0440\u0438\u0441\u043A\u0443\u044F \u0431\u044B\u0442\u044C
    \u043F\u043E\u0439\u043C\u0430\u043D\u043D\u044B\u043C, \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0442\u044C
    \u0443\u0447\u0438\u0442\u044C\u0441\u044F \u043F\u043E \u043D\u043E\u0447\u0430\u043C,
    \u043A\u043E\u0433\u0434\u0430 \u0432\u0441\u0435 \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u043F\u0430\u043B\u0438.  ### \U0001F30D 4. \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \"\u043F\u0430\u0440\u043D\u0438\u043A\u043E\u0432\u043E\u0433\u043E \u044D\u0444\u0444\u0435\u043A\u0442\u0430\"
    \u0438 CT-\u0441\u043A\u0430\u043D\u0435\u0440\u043E\u0432  \u0424\u0443\u0440\u044C\u0435
    \u2014 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043D\u043E \u0438 \u043E\u0434\u0438\u043D \u0438\u0437 \u043F\u0435\u0440\u0432\u043E\u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u0430 **\u043F\u0430\u0440\u043D\u0438\u043A\u043E\u0432\u043E\u0433\u043E
    \u044D\u0444\u0444\u0435\u043A\u0442\u0430**. \u0418\u0437\u0443\u0447\u0430\u044F
    \u0442\u0435\u043F\u043B\u043E\u0432\u043E\u0439 \u0431\u0430\u043B\u0430\u043D\u0441
    \u0417\u0435\u043C\u043B\u0438, \u043E\u043D \u043F\u043E\u043D\u044F\u043B,
    \u0447\u0442\u043E \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442
    \u043A\u0430\u043A \"\u0442\u0435\u043F\u043B\u043E\u0432\u0430\u044F \u043B\u043E\u0432\u0443\u0448\u043A\u0430\",
    \u043F\u043E\u0434\u043E\u0431\u043D\u043E \u0441\u0442\u0435\u043A\u043B\u0443
    \u0432 \u043F\u0430\u0440\u043D\u0438\u043A\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0430\u0435\u0442 \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0439
    \u0441\u0432\u0435\u0442, \u043D\u043E \u0437\u0430\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442
    \u0442\u0435\u043F\u043B\u043E. \u0421\u0432\u043E\u0438 \u0432\u044B\u0432\u043E\u0434\u044B
    \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0432 1827 \u0433\u043E\u0434\u0443. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0430\u0432\u0442\u043E\u0440\u043E\u043C
    **\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0442\u0435\u043F\u043B\u043E\u043F\u0440\u043E\u0432\u043E\u0434\u043D\u043E\u0441\u0442\u0438**,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442,
    \u043A\u0430\u043A \u0442\u0435\u043F\u043B\u043E \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u0435\u0442\u0441\u044F
    \u0447\u0435\u0440\u0435\u0437 \u0442\u0435\u043B\u0430. \u0412 \u043D\u0430\u0448\u0438
    \u0434\u043D\u0438 \u044D\u0442\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u043C
    \u0434\u043B\u044F \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439
    \u0432 \u041C\u0420\u0422 \u0438 \u041A\u0422-\u0441\u043A\u0430\u043D\u0435\u0440\u0430\u0445. 
    ### \U0001F9D1\u200D\U0001F3EB 5. \u0423\u0447\u0438\u0442\u0435\u043B\u044C,
    \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u0432\u0448\u0438\u0439 \u043F\u043B\u0435\u044F\u0434\u0443
    \u0433\u0435\u043D\u0438\u0435\u0432  \u0424\u0443\u0440\u044C\u0435 \u0431\u044B\u043B
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u0443\u0447\u0451\u043D\u044B\u043C, \u043D\u043E \u0438 \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u043C
    \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u043E\u043C. \u0412 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B \u043E\u043D \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043B
    \u0446\u0435\u043B\u043E\u0435 \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0435
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u0441\u0440\u0435\u0434\u0438 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0431\u044B\u043B\u0438
    **\u041F\u0435\u0442\u0435\u0440 \u0413\u0443\u0441\u0442\u0430\u0432 \u0414\u0438\u0440\u0438\u0445\u043B\u0435**
    \u0438 **\u041A\u043B\u043E\u0434-\u041B\u0443\u0438 \u041D\u0430\u0432\u044C\u0435**.
    \u0418\u043C\u0435\u043D\u043D\u043E \u041D\u0430\u0432\u044C\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0424\u0443\u0440\u044C\u0435 \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B
    \u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0435\u0433\u043E
    \u043D\u0435\u0437\u0430\u043A\u043E\u043D\u0447\u0435\u043D\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u043F\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0435. 
    ### \U0001F3FA 6. \u0415\u0433\u0438\u043F\u0442\u043E\u043B\u043E\u0433 \u0438
    \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C  \u0412 \u0441\u043E\u0441\u0442\u0430\u0432\u0435
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u044D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u0438
    \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D\u0430 \u0432 \u0415\u0433\u0438\u043F\u0435\u0442
    \u0424\u0443\u0440\u044C\u0435 \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u0430\u0441\u0441\u0438\u0432\u043D\u044B\u043C \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u0435\u043B\u0435\u043C.
    \u041E\u043D \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    **\u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u0451\u043C \u041A\u0430\u0438\u0440\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430** \u0438 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u043B
    \u0430\u0440\u0445\u0435\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0440\u0430\u0441\u043A\u043E\u043F\u043A\u0430\u043C\u0438. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u043E\u0439, \u043D\u0430\u043B\u0430\u0434\u0438\u0432
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E \u043E\u0440\u0443\u0436\u0438\u044F
    \u0438 \u043F\u043E\u0440\u043E\u0445\u0430 \u0434\u043B\u044F \u0430\u0440\u043C\u0438\u0438.
    \u041F\u043E \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
    \u0438\u043C\u0435\u043D\u043D\u043E \u0435\u043C\u0443 \u0431\u044B\u043B\u043E
    \u043F\u043E\u0440\u0443\u0447\u0435\u043D\u043E \u0440\u0435\u0434\u0430\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u0442\u0440\u0443\u0434\u0430
    \"\u041E\u043F\u0438\u0441\u0430\u043D\u0438\u0435 \u0415\u0433\u0438\u043F\u0442\u0430\". 
    \u0418\u043C\u044F \u0424\u0443\u0440\u044C\u0435 \u0443\u0432\u0435\u043A\u043E\u0432\u0435\u0447\u0435\u043D\u043E
    \u043D\u0430 \u042D\u0439\u0444\u0435\u043B\u0435\u0432\u043E\u0439 \u0431\u0430\u0448\u043D\u0435
    \u0441\u0440\u0435\u0434\u0438 72 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0443\u0447\u0451\u043D\u044B\u0445 \u0424\u0440\u0430\u043D\u0446\u0438\u0438.
    \u0412 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043D\u0430\u0443\u043A\u0438
    \u043E\u043D \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u0430 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B
    \u0444\u0438\u0437\u0438\u043A\u0443 \u0432 \u0442\u043E\u0447\u043D\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443, \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u0443\u044E
