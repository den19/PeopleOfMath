  achievementsRu: "\u041C\u0430\u0439\u043A\u043B \u0410\u0442\u044C\u044F \u0431\u044B\u043B
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u0430 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C
    \"\u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u043E\u0440\u043E\u043C\"
    \u043D\u043E\u0432\u044B\u0445 \u0441\u0432\u044F\u0437\u0435\u0439 \u043C\u0435\u0436\u0434\u0443,
    \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C \u0431\u044B, \u0434\u0430\u043B\u0435\u043A\u0438\u043C\u0438
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C\u0438 \u043D\u0430\u0443\u043A\u0438.
    \u0415\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u2014 \u044D\u0442\u043E
    \u0442\u0440\u0438 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F,
    \u0432 \u043A\u0430\u0436\u0434\u043E\u043C \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0440\u043E\u0440\u044B\u0432. 
    ### \U0001F9E9 1. \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    K-\u0442\u0435\u043E\u0440\u0438\u0438  \u0412 \u043D\u0430\u0447\u0430\u043B\u0435
    1960-\u0445 \u0433\u043E\u0434\u043E\u0432, \u0440\u0430\u0431\u043E\u0442\u0430\u044F
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u043E\u043C
    \u0425\u0438\u0440\u0446\u0435\u0431\u0440\u0443\u0445\u043E\u043C, \u0410\u0442\u044C\u044F
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u043E\u0432\u044B\u0439
    \u043C\u043E\u0449\u043D\u044B\u0439 \u0430\u043F\u043F\u0430\u0440\u0430\u0442
    \u2014 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    K-\u0442\u0435\u043E\u0440\u0438\u044E. \u042D\u0442\u043E\u0442 \u0440\u0430\u0437\u0434\u0435\u043B
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u043C\u043D\u043E\u0433\u043E\u043C\u0435\u0440\u043D\u044B\u0435 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432 \u2014 \u043A\u043E\u043B\u0435\u0446. 
    **\u041F\u0440\u043E\u0441\u0442\u0430\u044F \u0430\u043D\u0430\u043B\u043E\u0433\u0438\u044F:**
    \u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u044C\u0442\u0435, \u0447\u0442\u043E
    \u0443 \u0432\u0430\u0441 \u0435\u0441\u0442\u044C \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u044C.
    \u041A \u043A\u0430\u0436\u0434\u043E\u0439 \u0435\u0435 \u0442\u043E\u0447\u043A\u0435
    \u043C\u043E\u0436\u043D\u043E \"\u043F\u0440\u0438\u043A\u043B\u0435\u0438\u0442\u044C\"
    \u0432\u0435\u043A\u0442\u043E\u0440\u043D\u0443\u044E \u043F\u0440\u044F\u043C\u0443\u044E,
    \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043A\u0430\u043A \u0432 \u043B\u0438\u0441\u0442\u0435
    \u041C\u0451\u0431\u0438\u0443\u0441\u0430. K-\u0442\u0435\u043E\u0440\u0438\u044F
    \u0438\u0437\u0443\u0447\u0430\u0435\u0442 \u0442\u0430\u043A\u0438\u0435 \"\u0440\u0430\u0441\u0441\u043B\u043E\u0435\u043D\u0438\u044F\"
    \u0438 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442, \u043A\u0430\u043A
    \u0438\u0445 \u043C\u043E\u0436\u043D\u043E \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0442\u044C
    \u0438 \u0443\u043C\u043D\u043E\u0436\u0430\u0442\u044C. \u042D\u0442\u043E\u0442
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442 \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C
    \u0438 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B \u0440\u0435\u0448\u0438\u0442\u044C
    \u0440\u044F\u0434 \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447, \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0439
    \u0442\u043E\u0447\u043A\u0435 (\u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0420. \u0411\u043E\u0442\u0442\u043E\u043C).  ### \U0001F3C6 2. \u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u0410\u0442\u044C\u0438\u2013\u0417\u0438\u043D\u0433\u0435\u0440\u0430
    \u043E\u0431 \u0438\u043D\u0434\u0435\u043A\u0441\u0435  \u042D\u0442\u043E **\u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435** \u0410\u0442\u044C\u0438,
    \u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0438 \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E
    (1966), \u0438 \u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E
    (2004). \u0412 1963 \u0433\u043E\u0434\u0443 \u0432\u043C\u0435\u0441\u0442\u0435
    \u0441 \u0418\u0437\u0430\u0434\u043E\u0440\u043E\u043C \u0417\u0438\u043D\u0433\u0435\u0440\u043E\u043C
    \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0442\u0435\u043E\u0440\u0435\u043C\u0443,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u043B\u0430 \u043C\u043E\u0441\u0442\u043E\u043C
    \u043C\u0435\u0436\u0434\u0443 **\u0430\u043D\u0430\u043B\u0438\u0437\u043E\u043C**
    (\u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435\u043C \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439) \u0438 **\u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0435\u0439**
    (\u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435\u043C \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u043E\u0440\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u043E\u0436\u043D\u043E
    \u0434\u0435\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u0442\u044C). 
    **\u0421\u0443\u0442\u044C \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F:**
    \u0414\u043B\u044F \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u043A\u043B\u0430\u0441\u0441\u0430 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 (\u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u043E\u0432) \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0447\u0438\u0441\u043B\u043E \u2014 **\u0438\u043D\u0434\u0435\u043A\u0441**,
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0449\u0438\u0439 \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u044C
    \u043C\u0435\u0436\u0434\u0443 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E\u043C
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u0438 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E\u043C \u0440\u0435\u0448\u0435\u043D\u0438\u0439
    \u0441\u043E\u043F\u0440\u044F\u0436\u0435\u043D\u043D\u043E\u0433\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F.
    \u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0410\u0442\u044C\u0438\u2013\u0417\u0438\u043D\u0433\u0435\u0440\u0430
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442, \u0447\u0442\u043E
    \u044D\u0442\u043E\u0442 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0434\u0435\u043A\u0441 \u043C\u043E\u0436\u043D\u043E \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u044C,
    \u0437\u043D\u0430\u044F \u0442\u043E\u043B\u044C\u043A\u043E **\u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430** \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0437\u0430\u0434\u0430\u043D\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435.  \u042D\u0442\u0430 \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    **\u043E\u0431\u043E\u0431\u0449\u0438\u043B\u0430 \u0441\u0440\u0430\u0437\u0443
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432 XIX \u0432\u0435\u043A\u0430**,
    \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0413\u0430\u0443\u0441\u0441\u0430\u2013\u0411\u043E\u043D\u043D\u0435 \u0438
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u0420\u0438\u043C\u0430\u043D\u0430\u2013\u0420\u043E\u0445\u0430.
    \u041E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430 \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u043A\u0430\u043C\u043D\u0435\u0439 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043D\u0430\u0439\u0434\u044F
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B \u0438 \u043C\u043D\u043E\u0433\u0438\u0445 \u0434\u0440\u0443\u0433\u0438\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445.  ### \U0001F30C 3. \u041F\u0438\u043E\u043D\u0435\u0440
    \u0432 \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438  \u042D\u0442\u043E \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435,
    \u043F\u043E\u0436\u0430\u043B\u0443\u0439, \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435
    \u044F\u0440\u043A\u043E \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
    \u0435\u0433\u043E \u0440\u043E\u043B\u044C \"\u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044F
    \u043C\u043E\u0441\u0442\u043E\u0432\". \u0425\u043E\u0442\u044F \u0432 \u043C\u043E\u043C\u0435\u043D\u0442
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E\u0431 \u0438\u043D\u0434\u0435\u043A\u0441\u0435 \u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C
    \u043A\u0440\u0430\u0439\u043D\u0435 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439,
    \u043A \u043A\u043E\u043D\u0446\u0443 1970-\u0445 \u0433\u043E\u0434\u043E\u0432
    \u043E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C, \u0447\u0442\u043E \u043E\u043D\u0430
    \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u0430\u0436\u043D\u0430
    \u0434\u043B\u044F \u0444\u0438\u0437\u0438\u043A\u0438 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u044B\u0445
    \u0447\u0430\u0441\u0442\u0438\u0446.  *   **\u041A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044F
    \u0438\u043D\u0441\u0442\u0430\u043D\u0442\u043E\u043D\u043E\u0432:** \u0410\u0442\u044C\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u043C\u0435\u0442\u043E\u0434\u044B
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 (\u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0442\u0432\u0438\u0441\u0442\u043E\u0440\u043E\u0432)
    \u0434\u043B\u044F \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0438
    **\u0438\u043D\u0441\u0442\u0430\u043D\u0442\u043E\u043D\u043E\u0432** \u2014
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435\u0442\u0440\u0438\u0432\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u042F\u043D\u0433\u0430-\u041C\u0438\u043B\u043B\u0441\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F.
    \u0414\u043B\u044F \u0438\u0445 \u043F\u043E\u043B\u043D\u043E\u0433\u043E \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u0431\u044B\u043B\u0430 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u0430
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F **ADHM-\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044F**
    (\u0410\u0442\u044C\u044F\u2013\u0414\u0440\u0438\u043D\u0444\u0435\u043B\u044C\u0434\u2013\u0425\u0438\u0442\u0447\u0438\u043D\u2013\u041C\u0430\u043D\u0438\u043D).
    *   **\u0412\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0444\u0438\u0437\u0438\u043A\u043E\u0432:**
    \u041E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441 \u0444\u0438\u0437\u0438\u043A\u0430\u043C\u0438, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u042D\u0434\u0432\u0430\u0440\u0434\u0430 \u0412\u0438\u0442\u0442\u0435\u043D\u0430,
    \u0438 \u0435\u0433\u043E \u0438\u0434\u0435\u0438 \u043B\u0435\u0433\u043B\u0438
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0441\u0442\u0440\u0443\u043D \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u044B\u0445 \u0442\u0435\u043E\u0440\u0438\u0439
    \u043F\u043E\u043B\u044F. \u0410\u0442\u044C\u044F \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u0444\u0438\u0437\u0438\u043A\u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442
    \u0434\u0430\u0436\u0435 \"\u0441\u0430\u043C\u044B\u0435 \u044D\u043A\u0437\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435\"
    \u0447\u0430\u0441\u0442\u0438 \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0435\u043C\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043D \u0441\u0447\u0438\u0442\u0430\u043B
    \u043D\u0438\u043A\u043E\u043C\u0443 \u043D\u0435 \u043D\u0443\u0436\u043D\u044B\u043C\u0438.
    *   **\u041E\u0431\u0440\u0430\u0442\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435:**
    \u042D\u0442\u043E \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043D\u0435 \u0431\u044B\u043B\u043E \u043E\u0434\u043D\u043E\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043C.
    \u0418\u0434\u0435\u0438 \u0438\u0437 \u043A\u0430\u043B\u0438\u0431\u0440\u043E\u0432\u043E\u0447\u043D\u044B\u0445
    \u0442\u0435\u043E\u0440\u0438\u0439 \u043F\u043E\u043B\u044F, \u043F\u0440\u0438\u0448\u0435\u0434\u0448\u0438\u0435
    \u0438\u0437 \u0444\u0438\u0437\u0438\u043A\u0438, \u043F\u043E\u0437\u0436\u0435
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438 \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0443
    \u0421\u0430\u0439\u043C\u043E\u043D\u0443 \u0414\u043E\u043D\u0430\u043B\u044C\u0434\u0441\u043E\u043D\u0443
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u0442\u044C \u043F\u0440\u043E\u0440\u044B\u0432
    \u0432 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0438 \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u043C\u0435\u0440\u043D\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439, \u0437\u0430
    \u0447\u0442\u043E \u0442\u043E\u0442 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E. 
    ### \U0001F4DA \u0414\u0440\u0443\u0433\u0438\u0435 \u0432\u0430\u0436\u043D\u044B\u0435
    \u0432\u043A\u043B\u0430\u0434\u044B *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439:**
    \u0410\u0442\u044C\u044F \u0432\u043D\u0435\u0441 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u2014 \u0440\u0430\u0437\u0434\u0435\u043B \u0430\u043B\u0433\u0435\u0431\u0440\u044B,
    \u0438\u0437\u0443\u0447\u0430\u044E\u0449\u0438\u0439 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0435
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B. *   **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:**
    \u041E\u043D \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u043E\u043C
    \"\u043A\u0430\u043D\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E\"
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0430 \u043F\u043E \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043D\u043E\u0439
    \u043A\u043D\u0438\u0433\u043E\u0439 \u0434\u043B\u044F \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432."
  achievementsEn: 
  personalLifeRu: "\u041F\u043E\u043C\u0438\u043C\u043E \u0441\u0432\u043E\u0435\u0439
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B, \u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0441\u044D\u0440\u0430 \u041C\u0430\u0439\u043A\u043B\u0430
    \u0410\u0442\u044C\u0438 \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C\u0438 \u0438 \u0434\u043E\u043B\u0433\u0438\u043C\u0438
    \u0441\u0432\u044F\u0437\u044F\u043C\u0438 \u0441 \u0441\u0435\u043C\u044C\u0435\u0439,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u043E\u0442\u0440\u0430\u0436\u0430\u043B\u0430
    \u0435\u0433\u043E \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u044E\u044E
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u0443\u044E
    \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u0443\u044E \u043F\u043E\u0437\u0438\u0446\u0438\u044E. 
    ### \U0001F48D \u0421\u0435\u043C\u044C\u044F \u0438 \u0431\u0440\u0430\u043A 
    \u0421\u0430\u043C\u043E\u0439 \u0432\u0430\u0436\u043D\u043E\u0439 \u0447\u0430\u0441\u0442\u044C\u044E
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438
    \u0431\u044B\u043B\u0430 \u0441\u0435\u043C\u044C\u044F. 30 \u0438\u044E\u043B\u044F
    1955 \u0433\u043E\u0434\u0430 \u0410\u0442\u044C\u044F \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u041B\u0438\u043B\u0438 \u0411\u0440\u0430\u0443\u043D. \u0418\u0445
    \u0431\u0440\u0430\u043A \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u043E\u0447\u0435\u043D\u044C
    \u0434\u043E\u043B\u0433\u0438\u043C \u0438 \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C,
    \u043F\u0440\u043E\u0434\u043B\u0438\u0432\u0448\u0438\u043C\u0441\u044F \u043F\u043E\u0447\u0442\u0438
    63 \u0433\u043E\u0434\u0430, \u0432\u043F\u043B\u043E\u0442\u044C \u0434\u043E
    \u043A\u043E\u043D\u0447\u0438\u043D\u044B \u041B\u0438\u043B\u0438 \u0432 \u043C\u0430\u0440\u0442\u0435
    2018 \u0433\u043E\u0434\u0430.  \u0423 \u0441\u0443\u043F\u0440\u0443\u0433\u043E\u0432
    \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0442\u0440\u043E\u0435 \u0441\u044B\u043D\u043E\u0432\u0435\u0439.
    \u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E, \u0438\u0445 \u043F\u043E\u0441\u0442\u0438\u0433\u043B\u0430
    \u0431\u043E\u043B\u044C\u0448\u0430\u044F \u0443\u0442\u0440\u0430\u0442\u0430:
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0441\u044B\u043D\u043E\u0432\u0435\u0439
    \u043F\u043E\u0433\u0438\u0431 \u0432 2002 \u0433\u043E\u0434\u0443 \u0432\u043E
    \u0432\u0440\u0435\u043C\u044F \u043F\u0435\u0448\u0435\u0433\u043E \u043F\u043E\u0445\u043E\u0434\u0430
    \u0432 \u041F\u0438\u0440\u0435\u043D\u0435\u044F\u0445.  ### \U0001F3A8 \u0421\u0435\u043C\u0435\u0439\u043D\u044B\u0435
    \u043A\u043E\u0440\u043D\u0438 \u0438 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440 
    \u041B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u0410\u0442\u044C\u0438 \u0432\u043E
    \u043C\u043D\u043E\u0433\u043E\u043C \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u0435
    \u0438 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u043C\u0443 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u043E\u043C\u0443
    \u0431\u044D\u043A\u0433\u0440\u0430\u0443\u043D\u0434\u0443. \u0415\u0433\u043E
    \u043E\u0442\u0435\u0446, \u042D\u0434\u0443\u0430\u0440\u0434 \u0410\u0442\u044C\u044F,
    \u0431\u044B\u043B \u043B\u0438\u0432\u0430\u043D\u0441\u043A\u0438\u043C \u043F\u0440\u0430\u0432\u043E\u0441\u043B\u0430\u0432\u043D\u044B\u043C
    \u0445\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0438\u043D\u043E\u043C \u0438
    \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u0435\u043C, \u0430 \u043C\u0430\u0442\u044C,
    \u0414\u0436\u0438\u043D \u041B\u0435\u0432\u0435\u043D\u0441, \u2014 \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u043A\u043E\u0439
    \u0438 \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u0446\u0435\u0439. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0431\u0440\u0430\u0442, \u041F\u0430\u0442\u0440\u0438\u043A
    \u0410\u0442\u044C\u044F, \u0441\u0442\u0430\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u044E\u0440\u0438\u0441\u0442\u043E\u043C , \u0447\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u043E \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u043E\u0441\u0442\u0438
    \u0432\u0441\u0435\u0439 \u0441\u0435\u043C\u044C\u0438.  \u042D\u0442\u043E
    \u0441\u043C\u0435\u0448\u0430\u043D\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0441\u0438\u043B\u044C\u043D\u043E \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u043E
    \u043D\u0430 \u0435\u0433\u043E \u043C\u0438\u0440\u043E\u0432\u043E\u0437\u0437\u0440\u0435\u043D\u0438\u0435.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u043A\u0430\u043A \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B
    \u0441\u0430\u043C \u0410\u0442\u044C\u044F, \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C
    \u0431\u0430\u043B\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043B \u043C\u0435\u0436\u0434\u0443
    \u0436\u0435\u043B\u0430\u043D\u0438\u0435\u043C \u0441\u0442\u0430\u0442\u044C
    \"\u0430\u043D\u0433\u043B\u0438\u0447\u0430\u043D\u0438\u043D\u043E\u043C\"
    \u0438 \u0441\u0438\u043C\u043F\u0430\u0442\u0438\u044F\u043C\u0438 \u043A \u0430\u0440\u0430\u0431\u0441\u043A\u043E\u043C\u0443
    \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0437\u043C\u0443, \u0447\u0442\u043E,
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043D\u0430\u0443\u0447\u0438\u043B\u043E
    \u041C\u0430\u0439\u043A\u043B\u0430 \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
    \u043D\u0430 \u043C\u0438\u0440 \u0441 \u0440\u0430\u0437\u043D\u044B\u0445 \u0442\u043E\u0447\u0435\u043A
    \u0437\u0440\u0435\u043D\u0438\u044F.  ### \U0001F33F \u0425\u043E\u0431\u0431\u0438
    \u0438 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F  \u0417\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0410\u0442\u044C\u044F
    \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0435\u0439
    \u043B\u044E\u0431\u043E\u0432\u044C\u044E \u043A \u043F\u0440\u0438\u0440\u043E\u0434\u0435.
    \u041E\u043D \u043B\u044E\u0431\u0438\u043B \u0433\u0443\u043B\u044F\u0442\u044C
    \u043F\u0435\u0448\u043A\u043E\u043C \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0432 \u0441\u0430\u0434\u0443. \u0415\u0433\u043E \u0436\u0435\u043D\u0430
    \u0448\u0443\u0442\u043B\u0438\u0432\u043E \u0436\u0430\u043B\u043E\u0432\u0430\u043B\u0430\u0441\u044C,
    \u0447\u0442\u043E \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043F\u0440\u043E\u0433\u0443\u043B\u043E\u043A
    \u043E\u043D \u043D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442 \u0434\u0443\u043C\u0430\u0442\u044C
    \u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0447\u0442\u043E
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043E \u0435\u0433\u043E \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439
    \u043F\u043E\u0433\u0440\u0443\u0436\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u0432 \u043D\u0430\u0443\u043A\u0443 \u0434\u0430\u0436\u0435 \u0432 \u043C\u0438\u043D\u0443\u0442\u044B
    \u043E\u0442\u0434\u044B\u0445\u0430.  ### \U0001F5E3\uFE0F \u041E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0438 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u0430\u044F \u043F\u043E\u0437\u0438\u0446\u0438\u044F 
    \u0410\u0442\u044C\u044F \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \"\u043A\u0430\u0431\u0438\u043D\u0435\u0442\u043D\u044B\u043C \u0443\u0447\u0435\u043D\u044B\u043C\".
    \u041E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u0443\u044E \u043F\u043E\u0437\u0438\u0446\u0438\u044E
    \u043F\u043E \u0432\u0430\u0436\u043D\u044B\u043C \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u043C.
    \u0411\u0443\u0434\u0443\u0447\u0438 \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 (1990\u20131995), \u043E\u043D
    \u043D\u0435 \u0431\u043E\u044F\u043B\u0441\u044F \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0437\u0430 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0435
    \u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u043D\u0430\u0443\u043A\u0438.  \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u043F\u0430\u0446\u0438\u0444\u0438\u0441\u0442\u043E\u043C. \u042F\u0432\u043B\u044F\u044F\u0441\u044C
    \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C \u041F\u0430\u0433\u0443\u043E\u0448\u0441\u043A\u0438\u0445
    \u043A\u043E\u043D\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0439 \u043F\u043E
    \u043D\u0430\u0443\u043A\u0435 \u0438 \u043C\u0438\u0440\u043E\u0432\u044B\u043C
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430\u043C, \u043E\u043D \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B
    \u0437\u0430 \u044F\u0434\u0435\u0440\u043D\u043E\u0435 \u0440\u0430\u0437\u043E\u0440\u0443\u0436\u0435\u043D\u0438\u0435
    \u0438 \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u044F\u0434\u0435\u0440\u043D\u0443\u044E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443 \u0412\u0435\u043B\u0438\u043A\u043E\u0431\u0440\u0438\u0442\u0430\u043D\u0438\u0438
    \"\u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E
    \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E\u0439, \u043F\u043E\u043B\u043D\u043E\u0439
    \u0442\u0440\u0430\u0442\u043E\u0439 \u0440\u0435\u0441\u0443\u0440\u0441\u043E\u0432\".
    \u0415\u0433\u043E \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0438\u043D\u043E\u0433\u0434\u0430 \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B\u0430
    \u043A \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0430\u043C, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0432 1997 \u0433\u043E\u0434\u0443 \u043E\u043D \u0434\u043E\u0441\u0440\u043E\u0447\u043D\u043E
    \u0443\u0448\u0435\u043B \u0441 \u043F\u043E\u0441\u0442\u0430 \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430
    \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430
    \u043F\u043E\u0441\u043B\u0435 \u0440\u0430\u0437\u043D\u043E\u0433\u043B\u0430\u0441\u0438\u0439
    \u0441 \u0441\u0430\u0434\u043E\u0432\u044B\u043C \u043A\u043E\u043C\u0438\u0442\u0435\u0442\u043E\u043C
    \u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430 \u043F\u043E \u043F\u043E\u0432\u043E\u0434\u0443
    \u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u043A\u0438 \u0441\u0430\u0434\u0430
    \u0434\u043B\u044F \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u0439."
  personalLifeEn: 
  shortBioRu: "\u0421\u044D\u0440 \u041C\u0430\u0439\u043A\u043B \u0424\u0440\u044D\u043D\u0441\u0438\u0441
    \u0410\u0442\u044C\u044F (22 \u0430\u043F\u0440\u0435\u043B\u044F 1929 \u2014
    11 \u044F\u043D\u0432\u0430\u0440\u044F 2019) \u2014 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    XX \u0432\u0435\u043A\u0430, \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u0445\u0432\u0430\u0442\u0438\u043B\u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044E,
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E, \u0430\u043D\u0430\u043B\u0438\u0437
    \u0438 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u0438\u0437\u0438\u043A\u0443. \u0415\u0433\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    \"\u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u0435\u043C \u043C\u043E\u0441\u0442\u043E\u0432\"
    \u043C\u0435\u0436\u0434\u0443 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u043C\u0438
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u043C\u0435\u0436\u0434\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u0438 \u0444\u0438\u0437\u0438\u043A\u043E\u0439.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466
    \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435 
    \u041C\u0430\u0439\u043A\u043B \u0410\u0442\u044C\u044F \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u041B\u043E\u043D\u0434\u043E\u043D\u0435, \u0432 \u0441\u0435\u043C\u044C\u0435
    \u0441 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u043C \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u044B\u043C
    \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u0438\u0435\u043C.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u042D\u0434\u0443\u0430\u0440\u0434
    \u0410\u0442\u044C\u044F, \u0431\u044B\u043B \u043B\u0438\u0432\u0430\u043D\u0446\u0435\u043C
    \u043F\u0440\u0430\u0432\u043E\u0441\u043B\u0430\u0432\u043D\u043E\u0433\u043E
    \u0432\u0435\u0440\u043E\u0438\u0441\u043F\u043E\u0432\u0435\u0434\u0430\u043D\u0438\u044F
    \u0438 \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u0435\u043C, \u0430 \u043C\u0430\u0442\u044C,
    \u0414\u0436\u0438\u043D \u041B\u0435\u0432\u0435\u043D\u0441, \u2014 \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u043A\u043E\u0439.
    \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u043F\u0440\u043E\u0448\u043B\u043E
    \u0432\u0434\u0430\u043B\u0438 \u043E\u0442 \u0411\u0440\u0438\u0442\u0430\u043D\u0438\u0438:
    \u043E\u043D \u043F\u043E\u0441\u0435\u0449\u0430\u043B \u0448\u043A\u043E\u043B\u0443
    \u0432 \u0425\u0430\u0440\u0442\u0443\u043C\u0435 (\u0421\u0443\u0434\u0430\u043D),
    \u0433\u0434\u0435 \u0435\u0433\u043E \u043E\u0442\u0435\u0446 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043D\u0430 \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0441\u043B\u0443\u0436\u0431\u0435, \u0430 \u0437\u0430\u0442\u0435\u043C \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439
    \u0412\u0438\u043A\u0442\u043E\u0440\u0438\u044F-\u043A\u043E\u043B\u043B\u0435\u0434\u0436
    \u0432 \u041A\u0430\u0438\u0440\u0435. \u042D\u0442\u043E\u0442 \u043C\u0443\u043B\u044C\u0442\u0438\u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u044B\u0439
    \u043E\u043F\u044B\u0442, \u0432\u043A\u043B\u044E\u0447\u0430\u0432\u0448\u0438\u0439
    \u0436\u0438\u0437\u043D\u044C \u043D\u0430 \u0411\u043B\u0438\u0436\u043D\u0435\u043C
    \u0412\u043E\u0441\u0442\u043E\u043A\u0435, \u043E\u0447\u0435\u0432\u0438\u0434\u043D\u043E,
    \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B \u0435\u0433\u043E
    \u0448\u0438\u0440\u043E\u043A\u0438\u0439 \u0432\u0437\u0433\u043B\u044F\u0434
    \u043D\u0430 \u043C\u0438\u0440, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0437\u0436\u0435
    \u043F\u0440\u043E\u044F\u0432\u0438\u0442\u0441\u044F \u0438 \u0432 \u0435\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0430\u0445. 
    ### \U0001F393 \u041F\u0443\u0442\u044C \u0432 \u043D\u0430\u0443\u043A\u0435:
    \u043E\u0442 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0430 \u0434\u043E
    \u043C\u0438\u0440\u043E\u0432\u043E\u0433\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F 
    \u0412 1947 \u0433\u043E\u0434\u0443 \u0410\u0442\u044C\u044F \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436
    \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430. \u0415\u0433\u043E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0431\u044B\u043B\u0430 \u0441\u0432\u044F\u0437\u0430\u043D\u0430
    \u0441 \u0432\u0435\u0434\u0443\u0449\u0438\u043C\u0438 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\u043C\u0438
    \u043C\u0438\u0440\u0430:  *   **\u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436
    (1955\u20131961):** \u0417\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u0432 1955
    \u0433\u043E\u0434\u0443 \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0423\u0438\u043B\u044C\u044F\u043C\u0430 \u0425\u043E\u0434\u0436\u0430. *  
    **\u041E\u043A\u0441\u0444\u043E\u0440\u0434 (1961\u20131969):** \u0417\u0430\u043D\u0438\u043C\u0430\u043B
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u0421\u0430\u0432\u0438\u043B\u0438\u0430\u043D\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.
    *   **\u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0432
    \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435, \u0421\u0428\u0410:**
    \u0420\u0430\u0431\u043E\u0442\u0430\u043B \u0442\u0430\u043C \u0432 1955\u20131956
    \u0438 1969\u20131972 \u0433\u043E\u0434\u0430\u0445, \u0447\u0442\u043E \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E
    \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u0446\u0438\u0438
    \u0432 \u043C\u0438\u0440\u043E\u0432\u043E\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E. *   **\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436 (1990\u20131997):** \u0421\u0442\u0430\u043B
    \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u043E\u043C \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430
    \u0438 \u043F\u0435\u0440\u0432\u044B\u043C \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u041D\u044C\u044E\u0442\u043E\u043D\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A. *   **\u042D\u0434\u0438\u043D\u0431\u0443\u0440\u0433:**
    \u0421 1997 \u0433\u043E\u0434\u0430 \u0438 \u0434\u043E \u043A\u043E\u043D\u0446\u0430
    \u0436\u0438\u0437\u043D\u0438 \u0431\u044B\u043B \u043F\u043E\u0447\u0435\u0442\u043D\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u042D\u0434\u0438\u043D\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430.  \u0410\u0442\u044C\u044F
    \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u0432 1962 \u0433\u043E\u0434\u0443,
    \u0430 \u0441 1990 \u043F\u043E 1995 \u0433\u043E\u0434 \u044F\u0432\u043B\u044F\u043B\u0441\u044F
    \u0435\u0433\u043E \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C.
    \u0417\u0430 \u0441\u0432\u043E\u044E \u043A\u0430\u0440\u044C\u0435\u0440\u0443
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043F\u043E\u0447\u0435\u0441\u0442\u0435\u0439, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0440\u044B\u0446\u0430\u0440\u0441\u0442\u0432\u043E \u0432 1983 \u0433\u043E\u0434\u0443
    \u0438 \u041E\u0440\u0434\u0435\u043D \u0417\u0430\u0441\u043B\u0443\u0433 \u0432
    1992 \u0433\u043E\u0434\u0443.  ### \U0001F3C6 \u0413\u043B\u0430\u0432\u043D\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0438 \u043D\u0430\u0433\u0440\u0430\u0434\u044B  \u0410\u0442\u044C\u044F \u0431\u044B\u043B
    \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D \u0434\u0432\u0443\u0445 \u0432\u044B\u0441\u043E\u0447\u0430\u0439\u0448\u0438\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435: 
    *   **\u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0430\u044F \u043C\u0435\u0434\u0430\u043B\u044C
    (1966)** \u2014 \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    K-\u0442\u0435\u043E\u0440\u0438\u0438 \u0438 \u0442\u0435\u043E\u0440\u0435\u043C\u0435
    \u043E\u0431 \u0438\u043D\u0434\u0435\u043A\u0441\u0435. *   **\u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F (2004, \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0418\u0437\u0430\u0434\u043E\u0440\u043E\u043C \u0417\u0438\u043D\u0433\u0435\u0440\u043E\u043C)**
    \u2014 \u0437\u0430 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E\u0431 \u0438\u043D\u0434\u0435\u043A\u0441\u0435. 
    \u0421\u0440\u0435\u0434\u0438 \u0434\u0440\u0443\u0433\u0438\u0445 \u0437\u043D\u0430\u0447\u0438\u043C\u044B\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434 \u2014 \u041C\u0435\u0434\u0430\u043B\u044C
    \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430
    (1968) \u0438 \u041C\u0435\u0434\u0430\u043B\u044C \u041A\u043E\u043F\u043B\u0438
    (1988).  ### \U0001F9E0 \u0412\u043A\u043B\u0430\u0434 \u0432 \u043D\u0430\u0443\u043A\u0443:
    \"\u0421\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C \u043C\u043E\u0441\u0442\u043E\u0432\" 
    \u041C\u0430\u0439\u043A\u043B \u0410\u0442\u044C\u044F \u0431\u044B\u043B \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0435\u0448\u0430\u0442\u0435\u043B\u0435\u043C
    \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u0437\u0430\u0434\u0430\u0447, \u0430
    \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u043C \u043D\u043E\u0432\u044B\u0445
    \u0442\u0435\u043E\u0440\u0438\u0439 \u0438 \u0441\u0432\u044F\u0437\u0435\u0439: 
    1.  **\u0422\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    K-\u0442\u0435\u043E\u0440\u0438\u044F:** \u0412 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0435
    \u0441 \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u043E\u043C \u0425\u0438\u0440\u0446\u0435\u0431\u0440\u0443\u0445\u043E\u043C
    \u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B K-\u0442\u0435\u043E\u0440\u0438\u044E
    \u2014 \u043C\u043E\u0449\u043D\u044B\u0439 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432 \u0447\u0435\u0440\u0435\u0437
    \u0438\u0445 \"\u0432\u0435\u043A\u0442\u043E\u0440\u043D\u044B\u0435 \u0440\u0430\u0441\u0441\u043B\u043E\u0435\u043D\u0438\u044F\"
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043B\u0435\u043D\u0442\u0443
    \u041C\u0451\u0431\u0438\u0443\u0441\u0430). 2.  **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0410\u0442\u044C\u0438\u2013\u0417\u0438\u043D\u0433\u0435\u0440\u0430 \u043E\u0431
    \u0438\u043D\u0434\u0435\u043A\u0441\u0435:** \u042D\u0442\u043E \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0439
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B.
    \u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0443\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442
    \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0441\u0432\u044F\u0437\u044C
    \u043C\u0435\u0436\u0434\u0443 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\u043C\u0438 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u043E\u0439 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u044D\u0442\u0438 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u0437\u0430\u0434\u0430\u043D\u044B. \u041E\u043D\u0430 \u043E\u0431\u043E\u0431\u0449\u0430\u0435\u0442
    \u043C\u043D\u043E\u0433\u0438\u0435 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B, \u0442\u0430\u043A\u0438\u0435
    \u043A\u0430\u043A \u0444\u043E\u0440\u043C\u0443\u043B\u0430 \u0413\u0430\u0443\u0441\u0441\u0430\u2013\u0411\u043E\u043D\u043D\u0435,
    \u0438 \u043D\u0430\u0448\u043B\u0430 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0432 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435. 3.  **\u0421\u0432\u044F\u0437\u044C \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0438 \u0444\u0438\u0437\u0438\u043A\u0438:** \u0412 1970-\u0445 \u0433\u043E\u0434\u0430\u0445
    \u0410\u0442\u044C\u044F \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u043E\u0441\u043E\u0437\u043D\u0430\u043B \u0432\u0430\u0436\u043D\u043E\u0441\u0442\u044C
    \u0438\u0434\u0435\u0439 \u0438\u0437 \u043A\u0430\u043B\u0438\u0431\u0440\u043E\u0432\u043E\u0447\u043D\u044B\u0445
    \u0442\u0435\u043E\u0440\u0438\u0439 \u043F\u043E\u043B\u044F (\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u042F\u043D\u0433\u0430\u2013\u041C\u0438\u043B\u043B\u0441\u0430) \u0434\u043B\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u041E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441 \u0444\u0438\u0437\u0438\u043A\u0430\u043C\u0438, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u042D\u0434\u0432\u0430\u0440\u0434\u0430 \u0412\u0438\u0442\u0442\u0435\u043D\u0430,
    \u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u043E\u0431\u043B\u0430\u0441\u0442\u0438,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439 \u043A\u0430\u043A \"\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u0438\u0437\u0438\u043A\u0430\", \u0438\u0441\u0441\u043B\u0435\u0434\u0443\u044F,
    \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0438\u043D\u0441\u0442\u0430\u043D\u0442\u043E\u043D\u044B
    \u0438 \u043C\u043E\u043D\u043E\u043F\u043E\u043B\u0438.  ### \U0001F4DC \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u0441\u043A\u0430\u043D\u0434\u0430\u043B \u0432\u043E\u043A\u0440\u0443\u0433
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u0420\u0438\u043C\u0430\u043D\u0430 
    \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438 \u0410\u0442\u044C\u044F
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C \u0432 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438. \u0412 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u0435
    2018 \u0433\u043E\u0434\u0430 \u043D\u0430 \u0413\u0435\u0439\u0434\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0441\u043A\u043E\u043C
    \u0444\u043E\u0440\u0443\u043C\u0435 \u043B\u0430\u0443\u0440\u0435\u0430\u0442\u043E\u0432
    \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0441\u0432\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u0420\u0438\u043C\u0430\u043D\u0430
    \u2014 \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u043D\u0435\u0440\u0435\u0448\u0435\u043D\u043D\u044B\u0445
    \"\u0437\u0430\u0434\u0430\u0447 \u0442\u044B\u0441\u044F\u0447\u0435\u043B\u0435\u0442\u0438\u044F\".
    \u041A \u0435\u0433\u043E \u0437\u0430\u044F\u0432\u043B\u0435\u043D\u0438\u044E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0435
    \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E \u043E\u0442\u043D\u0435\u0441\u043B\u043E\u0441\u044C
    \u0441 \u0431\u043E\u043B\u044C\u0448\u0438\u043C \u0441\u043A\u0435\u043F\u0441\u0438\u0441\u043E\u043C,
    \u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443 \u043E\u043D\u043E \u0431\u044B\u043B\u043E
    \u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u043E \u043A\u0440\u0430\u0442\u043A\u0438\u043C
    \u0438 \u043D\u0435 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u043E \u0441\u0442\u0440\u043E\u0433\u0438\u0445
    \u0432\u044B\u043A\u043B\u0430\u0434\u043E\u043A, \u0430 \u043F\u0440\u0435\u0434\u044B\u0434\u0443\u0449\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u0410\u0442\u044C\u0438 \u0432 \u043F\u0440\u0435\u043A\u043B\u043E\u043D\u043D\u043E\u043C
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435, \u043F\u043E \u043C\u043D\u0435\u043D\u0438\u044E
    \u043A\u043E\u043B\u043B\u0435\u0433, \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    \u043D\u0430 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0435 \u0441\u043D\u0438\u0436\u0435\u043D\u0438\u0435
    \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u0438 \u0435\u0433\u043E \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442\u0430\u0446\u0438\u0438.
    \u0422\u0435\u043C \u043D\u0435 \u043C\u0435\u043D\u0435\u0435, \u0441\u0430\u043C
    \u0410\u0442\u044C\u044F \u043D\u0430\u0434\u0435\u044F\u043B\u0441\u044F \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u0442\u044C
    \u043C\u043E\u043B\u043E\u0434\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432. 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u044D\u0442\u0438
    \u0441\u043F\u043E\u0440\u044B, \u041C\u0430\u0439\u043A\u043B \u0410\u0442\u044C\u044F
    \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F \u0444\u0438\u0433\u0443\u0440\u043E\u0439,
    \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0435\u0439 \u043B\u0430\u043D\u0434\u0448\u0430\u0444\u0442
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0415\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u2014 \u044D\u0442\u043E
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0435
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B, \u043D\u043E \u0438 \u0441\u0430\u043C
    \u043F\u043E\u0434\u0445\u043E\u0434, \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u0443\u044E\u0449\u0438\u0439
    \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0434\u0435\u0439."
  shortBioEn: 
  interestingFactsRu: "\u041F\u043E\u043C\u0438\u043C\u043E \u0441\u0442\u0440\u043E\u0433\u0438\u0445
    \u0442\u0435\u043E\u0440\u0435\u043C \u0438 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0432\u0430\u043D\u0438\u0439, \u0436\u0438\u0437\u043D\u044C \u041C\u0430\u0439\u043A\u043B\u0430
    \u0410\u0442\u044C\u0438 \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u0430
    \u044F\u0440\u043A\u0438\u0445 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0438\u0445
    \u0447\u0435\u0440\u0442, \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u0432 \u0438
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445
    \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439. \u0412\u043E\u0442
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u0435\u0433\u043E
    \u043D\u0435\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u0443\u044E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C. 
    ### \U0001F9E0 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \"\u043E\u0437\u0430\u0440\u0435\u043D\u0438\u0435\" \u0432\u043E \u0441\u043D\u0435
    \u0410\u0442\u044C\u044F \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B,
    \u0447\u0442\u043E \u043E\u0434\u043D\u0430\u0436\u0434\u044B \u0435\u043C\u0443
    \u043F\u0440\u0438\u0441\u043D\u0438\u043B\u0441\u044F \u0441\u043B\u043E\u0436\u043D\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0432\u043E\u043F\u0440\u043E\u0441, \u0438 \u043E\u043D \u0440\u0435\u0448\u0438\u043B
    \u0435\u0433\u043E \u0432\u043E \u0441\u043D\u0435. \u041E\u0434\u043D\u0430\u043A\u043E,
    \u043F\u0440\u043E\u0441\u043D\u0443\u0432\u0448\u0438\u0441\u044C, \u043E\u043D
    \u043D\u0435 \u043C\u043E\u0433 \u0432\u0441\u043F\u043E\u043C\u043D\u0438\u0442\u044C
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435. \u041A \u0441\u0447\u0430\u0441\u0442\u044C\u044E,
    \u043A\u0430\u043A \u043E\u043D \u0441\u0430\u043C \u0448\u0443\u0442\u0438\u043B,
    \u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0430 **\u0418\u0437\u0430\u0434\u043E\u0440
    \u0417\u0438\u043D\u0433\u0435\u0440** \u0442\u043E\u0436\u0435 \u0432\u0438\u0434\u0435\u043B
    \u0442\u043E\u0442 \u0436\u0435 \u0441\u043E\u043D \u0438 \u043F\u043E\u043C\u043D\u0438\u043B
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E.
    \u042D\u0442\u043E\u0442 \u0441\u043B\u0443\u0447\u0430\u0439 \u0441\u0442\u0430\u043B
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u043C \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0443\u0433\u0430\u0445, \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u0443\u044F
    \u0438\u0445 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E \u0442\u0435\u0441\u043D\u043E\u0435
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E. 
    ### \U0001F3A8 \u0421\u0435\u043C\u0435\u0439\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u0438 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u044B\u0439 \u043A\u043E\u0434
    \u0415\u0433\u043E \u043C\u0430\u0442\u044C \u0431\u044B\u043B\u0430 \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u0446\u0435\u0439,
    \u0447\u0442\u043E, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u043F\u0440\u0438\u0432\u0438\u043B\u043E
    \u0435\u043C\u0443 \u044D\u0441\u0442\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u041E\u043D \u0447\u0430\u0441\u0442\u043E \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0441 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E\u043C,
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044F, \u0447\u0442\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u0432 \u043D\u0435\u0439 \u2014 \u043A\u0440\u0430\u0441\u043E\u0442\u0430 \u0438
    \u0438\u0437\u044F\u0449\u0435\u0441\u0442\u0432\u043E. \u0415\u0433\u043E \u043E\u0442\u0435\u0446
    \u0431\u044B\u043B \u043B\u0438\u0432\u0430\u043D\u0441\u043A\u0438\u043C \u043F\u0440\u0430\u0432\u043E\u0441\u043B\u0430\u0432\u043D\u044B\u043C
    \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u0435\u043C, \u0438, \u043F\u043E
    \u0441\u043B\u043E\u0432\u0430\u043C \u0410\u0442\u044C\u0438, \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u043E\u0442\u0446\u0443 \u043E\u043D \u043D\u0430\u0443\u0447\u0438\u043B\u0441\u044F
    \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C \u043D\u0430 \u043C\u0438\u0440
    \u0441 \u0440\u0430\u0437\u043D\u044B\u0445 \u0442\u043E\u0447\u0435\u043A \u0437\u0440\u0435\u043D\u0438\u044F,
    \u0447\u0442\u043E \u043F\u043E\u043C\u043E\u0433\u043B\u043E \u0435\u043C\u0443
    \u0441\u043E\u0435\u0434\u0438\u043D\u044F\u0442\u044C, \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C
    \u0431\u044B, \u043D\u0435\u0441\u043E\u0435\u0434\u0438\u043D\u0438\u043C\u044B\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    ### \U0001F30D \u0412\u0438\u0434\u0435\u043D\u0438\u0435 \u043D\u0430\u0443\u043A\u0438
    \u043A\u0430\u043A \u0435\u0434\u0438\u043D\u043E\u0433\u043E \u0446\u0435\u043B\u043E\u0433\u043E
    \u0410\u0442\u044C\u044F \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D,
    \u0447\u0442\u043E \u0433\u0440\u0430\u043D\u0438\u0446\u044B \u043C\u0435\u0436\u0434\u0443
    \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u0438 \u0444\u0438\u0437\u0438\u043A\u043E\u0439 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435\u043D\u043D\u044B.
    \u041E\u043D \u0441 \u0433\u043E\u0440\u0434\u043E\u0441\u0442\u044C\u044E \u0433\u043E\u0432\u043E\u0440\u0438\u043B,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E\u0431 \u0438\u043D\u0434\u0435\u043A\u0441\u0435 \u043D\u0430\u0448\u043B\u0430
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0432 \u0442\u0430\u043A\u0438\u0445
    \"\u044D\u043A\u0437\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445\"
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445, \u043A\u0430\u043A \u0442\u0435\u043E\u0440\u0438\u044F
    \u0441\u0442\u0440\u0443\u043D, \u043E \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u043D \u0434\u0430\u0436\u0435 \u043D\u0435 \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u0432\u0430\u043B
    \u0432 \u043C\u043E\u043C\u0435\u043D\u0442 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F.
    \u041E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0441\u0435\u0431\u044F
    **\"\u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u0435\u043C \u043C\u043E\u0441\u0442\u043E\u0432\"**
    \u0438 \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u044F\u0442
    \u0438\u043C\u0435\u043D\u043D\u043E \u043D\u0430 \u0441\u0442\u044B\u043A\u0435
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D.  ### \U0001F331 \u042F\u0440\u044B\u0439
    \u0437\u0430\u0449\u0438\u0442\u043D\u0438\u043A \u043F\u0440\u0438\u0440\u043E\u0434\u044B
    \u0438 \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A \u044F\u0434\u0435\u0440\u043D\u043E\u0433\u043E
    \u043E\u0440\u0443\u0436\u0438\u044F \u0415\u0433\u043E \u043B\u044E\u0431\u043E\u0432\u044C
    \u043A \u0441\u0430\u0434\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u0443 \u0431\u044B\u043B\u0430
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0445\u043E\u0431\u0431\u0438.
    \u0412 1997 \u0433\u043E\u0434\u0443 \u043E\u043D \u0434\u043E\u0441\u0440\u043E\u0447\u043D\u043E
    \u0443\u0448\u0435\u043B \u0441 \u043F\u043E\u0441\u0442\u0430 \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430
    \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430
    \u043F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u043F\u043E\u0441\u0441\u043E\u0440\u0438\u043B\u0441\u044F
    \u0441 \u0441\u0430\u0434\u043E\u0432\u044B\u043C \u043A\u043E\u043C\u0438\u0442\u0435\u0442\u043E\u043C
    \u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430 \u2014 \u043E\u043D\u0438 \u0445\u043E\u0442\u0435\u043B\u0438
    \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C \u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u043A\u0443
    \u0441\u0430\u0434\u0430 \u0434\u043B\u044F \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u0439,
    \u0438 \u043E\u043D \u0441\u0447\u0435\u043B \u044D\u0442\u043E \u043D\u0435\u043F\u0440\u0438\u0435\u043C\u043B\u0435\u043C\u044B\u043C.
    \u041E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u044F\u0434\u0435\u0440\u043D\u0443\u044E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443 \u0412\u0435\u043B\u0438\u043A\u043E\u0431\u0440\u0438\u0442\u0430\u043D\u0438\u0438
    **\"\u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E
    \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E\u0439 \u0438 \u043F\u0443\u0441\u0442\u043E\u0439
    \u0442\u0440\u0430\u0442\u043E\u0439 \u0440\u0435\u0441\u0443\u0440\u0441\u043E\u0432\"**
    \u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B
    \u0437\u0430 \u0440\u0430\u0437\u043E\u0440\u0443\u0436\u0435\u043D\u0438\u0435. 
    ### \U0001F9D0 \u0421\u043A\u0435\u043F\u0442\u0438\u0446\u0438\u0437\u043C \u043A
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u0436\u0435
    \u0438\u0434\u0435\u044F\u043C (\u0438\u0440\u043E\u043D\u0438\u044F \u0441\u0443\u0434\u044C\u0431\u044B)
    \u0412 1960-\u0445, \u043A\u043E\u0433\u0434\u0430 \u0410\u0442\u044C\u044F \u0438
    \u0417\u0438\u043D\u0433\u0435\u0440 \u0442\u043E\u043B\u044C\u043A\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438
    \u043D\u0430\u0434 \u0441\u0432\u043E\u0435\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \u0442\u0435\u043E\u0440\u0435\u043C\u043E\u0439, \u043E\u043D\u0438 \u043F\u043E\u0434\u0430\u043B\u0438
    \u0437\u0430\u044F\u0432\u043A\u0443 \u043D\u0430 \u0433\u0440\u0430\u043D\u0442
    \u0432 \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u043D\u0430\u0443\u0447\u043D\u044B\u0439 \u0444\u043E\u043D\u0434 \u0421\u0428\u0410.
    \u0417\u0430\u044F\u0432\u043A\u0443 **\u043E\u0442\u043A\u043B\u043E\u043D\u0438\u043B\u0438**,
    \u043F\u043E\u0441\u0447\u0438\u0442\u0430\u0432 \u0438\u0445 \u0438\u0434\u0435\u0438
    \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u043C\u0438
    \u0438 \u0431\u0435\u0441\u043F\u043E\u043B\u0435\u0437\u043D\u044B\u043C\u0438.
    \u041F\u043E\u0437\u0436\u0435 \u044D\u0442\u0430 \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u0442\u044B\u0441\u044F\u0447 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u0444\u0438\u0437\u0438\u043A\u0435, \u0430 \u0441\u0430\u043C \u0410\u0442\u044C\u044F
    \u043B\u044E\u0431\u0438\u043B \u0441 \u0438\u0440\u043E\u043D\u0438\u0435\u0439
    \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u0442\u044C \u044D\u0442\u043E\u0442
    \u043E\u0442\u043A\u0430\u0437.  ### \U0001F399\uFE0F \"\u0414\u0435\u0442\u0441\u043A\u043E\u0435\"
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u0420\u0438\u043C\u0430\u043D\u0430
    \u041D\u0430 \u0441\u043A\u043B\u043E\u043D\u0435 \u043B\u0435\u0442, \u0432
    2018 \u0433\u043E\u0434\u0443, 89-\u043B\u0435\u0442\u043D\u0438\u0439 \u0410\u0442\u044C\u044F
    \u043F\u0440\u0438\u0435\u0445\u0430\u043B \u043D\u0430 \u0413\u0435\u0439\u0434\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0441\u043A\u0438\u0439
    \u0444\u043E\u0440\u0443\u043C \u0441 \u0441\u0435\u043D\u0441\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u043C
    \u0437\u0430\u044F\u0432\u043B\u0435\u043D\u0438\u0435\u043C \u2014 \u043E\u043D
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u0420\u0438\u043C\u0430\u043D\u0430.
    \u0415\u0433\u043E \u043B\u0435\u043A\u0446\u0438\u044F \u0434\u043B\u0438\u043B\u0430\u0441\u044C
    \u0432\u0441\u0435\u0433\u043E \u043E\u043A\u043E\u043B\u043E 5 \u043C\u0438\u043D\u0443\u0442,
    \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043F\u0440\u043E\u0441\u0442\u044B\u0435
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442\u044B, \u0432\u044B\u0432\u043E\u0434\u044F
    \u043D\u0430 \u044D\u043A\u0440\u0430\u043D \"\u0434\u0435\u0442\u0441\u043A\u0438\u0435\"
    \u043A\u0430\u0440\u0442\u0438\u043D\u043A\u0438. \u0425\u043E\u0442\u044F \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
    \u043A\u043E\u043B\u043B\u0435\u0433 \u043F\u0440\u0438\u0437\u043D\u0430\u043B\u0438
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043D\u0435\u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u044B\u043C, \u0441\u0430\u043C
    \u0410\u0442\u044C\u044F \u0441 \u044D\u043D\u0442\u0443\u0437\u0438\u0430\u0437\u043C\u043E\u043C
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E \u0433\u043B\u0430\u0432\u043D\u0430\u044F
    \u0435\u0433\u043E \u0446\u0435\u043B\u044C \u2014 **\u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u0442\u044C
    \u043C\u043E\u043B\u043E\u0434\u043E\u0435 \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0435**
    \u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C, \u0447\u0442\u043E \u0434\u0430\u0436\u0435
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0435 \u0437\u0430\u0434\u0430\u0447\u0438
    \u043D\u0435 \u0441\u0442\u043E\u0438\u0442 \u0431\u043E\u044F\u0442\u044C\u0441\u044F. 
    ### \U0001F4DA \u0421\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u044C \u0432
    \u0431\u044B\u0442\u0443 \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430
    \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0441\u043B\u0430\u0432\u0443, \u0440\u044B\u0446\u0430\u0440\u0441\u043A\u0438\u0439
    \u0442\u0438\u0442\u0443\u043B \u0438 \u043C\u0435\u0441\u0442\u043E \u0432 \u044D\u043B\u0438\u0442\u0435
    \u043D\u0430\u0443\u043A\u0438, \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B\u0438
    \u0435\u0433\u043E \u043A\u0430\u043A \u043A\u0440\u0430\u0439\u043D\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0433\u043E
    \u0438 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u0433\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430.
    \u041E\u043D \u043C\u043E\u0433 \u0447\u0430\u0441\u0430\u043C\u0438 \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0441 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u043E\u043C
    \u0432 \u043A\u043E\u0440\u0438\u0434\u043E\u0440\u0435 \u0438 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u043A\u0438\u0447\u0438\u043B\u0441\u044F \u0441\u0432\u043E\u0438\u043C\u0438
    \u0437\u0430\u0441\u043B\u0443\u0433\u0430\u043C\u0438."
