    \u043C\u0430\u0442\u0435\u0440\u0438 .  ### \U0001F525 \u041E\u0437\u043E\u0440\u043D\u043E\u0439
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442: \u043A\u0430\u0440\u0446\u0435\u0440\u044B
    \u0438 \u043F\u0438\u0440\u043E\u0442\u0435\u0445\u043D\u0438\u043A\u0430  \u042E\u043D\u044B\u0439
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439 \u0431\u044B\u043B
    \u0434\u0430\u043B\u0435\u043A\u043E \u043D\u0435 \u043F\u0430\u0439-\u043C\u0430\u043B\u044C\u0447\u0438\u043A\u043E\u043C.
    \u0415\u0433\u043E \u0431\u0443\u043D\u0442\u0430\u0440\u0441\u043A\u0438\u0439
