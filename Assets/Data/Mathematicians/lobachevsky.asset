    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u041D\u0438\u043A\u043E\u043B\u0430\u044F
    \u0418\u0432\u0430\u043D\u043E\u0432\u0438\u0447\u0430 \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0447\u0435\u0440\u0435\u0434\u0430
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439
    \u0438 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439. \u041E\u043D\u0430
    \u043F\u043E\u043B\u043D\u0430 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0445
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043E\u0432, \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u043B\u0430\u0431\u043E\u0441\u0442\u0435\u0439, \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445
    \u0438 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u044B\u0445 \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u0435\u0433\u043E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043A\u0430\u043A
    \u0433\u0435\u043D\u0438\u044F, \u043D\u043E \u0438 \u043A\u0430\u043A \u0436\u0438\u0432\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u0441 \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u044B\u043C
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C.  ### \U0001F476
    \u0422\u0430\u0439\u043D\u0430 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0438 \"\u043D\u0435\u0437\u0430\u043A\u043E\u043D\u043D\u043E\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u044B\u0439\"
    \u0433\u0435\u043D\u0438\u0439  \u0421\u0430\u043C\u044B\u0439 \u043F\u0438\u043A\u0430\u043D\u0442\u043D\u044B\u0439
    \u0438 \u0434\u043E\u043B\u0433\u043E \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u043C\u044B\u0439
    \u0444\u0430\u043A\u0442 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u2014 \u0435\u0433\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435. \u0414\u043E\u043B\u0433\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u043E\u0442\u0446\u043E\u043C \u041D\u0438\u043A\u043E\u043B\u0430\u044F
    \u0441\u0447\u0438\u0442\u0430\u043B\u0438 \u043C\u0435\u043B\u043A\u043E\u0433\u043E
    \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u0430 \u0418\u0432\u0430\u043D\u0430
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0438,
    \u0447\u0442\u043E \u0431\u0440\u0430\u043A \u0435\u0433\u043E \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u0439
    \u0431\u044B\u043B \u0444\u0438\u043A\u0442\u0438\u0432\u043D\u044B\u043C, \u0438
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C \u043E\u0442\u0446\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0431\u044B\u043B
    **\u0421\u0435\u0440\u0433\u0435\u0439 \u0428\u0435\u0431\u0430\u0440\u0448\u0438\u043D**,
    \u0443\u0435\u0437\u0434\u043D\u044B\u0439 \u0437\u0435\u043C\u043B\u0435\u043C\u0435\u0440
    \u0438 \u043A\u0430\u043F\u0438\u0442\u0430\u043D .  *   **\u0411\u0443\u043C\u0430\u0436\u043D\u0430\u044F
    \u0445\u0438\u0442\u0440\u043E\u0441\u0442\u044C**: \u0428\u0435\u0431\u0430\u0440\u0448\u0438\u043D
    \u0431\u044B\u043B \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u043D\u044B\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C.
    \u0427\u0442\u043E\u0431\u044B \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0442\u044C
    \u0441\u0432\u043E\u044E \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0435\u043C\u044C\u044E (\u0441 \u041F\u0440\u0430\u0441\u043A\u043E\u0432\u044C\u0435\u0439
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u0432\u043D\u043E\u0439
    \u0443 \u043D\u0438\u0445 \u0431\u044B\u043B\u0438 \u043E\u0431\u0449\u0438\u0435
    \u0434\u0435\u0442\u0438), \u043E\u043D \u043F\u043E\u0448\u0435\u043B \u043D\u0430
    \u0445\u0438\u0442\u0440\u043E\u0441\u0442\u044C. \u041E\u043D \u0432\u044B\u0434\u0430\u043B
    \u043A\u0443\u043F\u0446\u0443 \u0444\u0430\u043B\u044C\u0448\u0438\u0432\u044B\u0439
    \u0432\u0435\u043A\u0441\u0435\u043B\u044C \u043D\u0430 1500 \u0440\u0443\u0431\u043B\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0437\u0430\u0442\u0435\u043C \u0431\u044B\u043B
    \"\u043F\u0440\u043E\u0434\u0430\u043D\" \u041F\u0440\u0430\u0441\u043A\u043E\u0432\u044C\u0435.
    \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u0428\u0435\u0431\u0430\u0440\u0448\u0438\u043D\u0430
    \u0432 1800 \u0433\u043E\u0434\u0443 \u044D\u0442\u043E\u0442 \u0432\u0435\u043A\u0441\u0435\u043B\u044C
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B \u0435\u0439 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0447\u0430\u0441\u0442\u044C \u0435\u0433\u043E \u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u0430
    . *   **\u0417\u0430\u0433\u0430\u0434\u043A\u0430 \u0432 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u0445**:
