    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u0442\u0440\u0435\u043C\u044F \u0442\u043E\u0432\u0430\u0440\u0438\u0449\u0430\u043C\u0438
    \u0436\u0435\u0441\u0442\u043E\u043A\u043E \u0438\u0437\u0431\u0438\u043B \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u0430
    \u0438\u043D\u0441\u043F\u0435\u043A\u0442\u043E\u0440\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B \u043D\u0435 \u043B\u044E\u0431\u0438\u043B\u0438
    \u0437\u0430 \u0434\u043E\u043D\u043E\u0441\u044B. \u0412 \u0440\u0430\u043F\u043E\u0440\u0442\u0435
    \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A \u043F\u0438\u0441\u0430\u043B,
    \u0447\u0442\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B \"\u0432\u0441\u044F\u0447\u0435\u0441\u043A\u0438
    \u043C\u0435\u043D\u044F \u0431\u0438\u043B\u0438, \u0445\u043E\u0442\u0435\u043B\u0438
    \u0443\u0431\u0438\u0442\u044C \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438\"
    . \u0417\u0430 \u0442\u0430\u043A\u0438\u0435 \u0432\u044B\u0445\u043E\u0434\u043A\u0438
    \u043E\u043D \u0438\u043C\u0435\u043B \u0432\u0441\u0435 \u0448\u0430\u043D\u0441\u044B
    \u0431\u044B\u0442\u044C \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u043D\u044B\u043C
