    \u0428\u0435\u0431\u0430\u0440\u0448\u0438\u043D\u0430, \u0447\u0442\u043E \u0432
    \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E
    \u043D\u0435\u0437\u0430\u043A\u043E\u043D\u043D\u043E\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u043E\u0433\u043E
    . \u0421\u0430\u043C \u041D\u0438\u043A\u043E\u043B\u0430\u0439 \u0418\u0432\u0430\u043D\u043E\u0432\u0438\u0447
