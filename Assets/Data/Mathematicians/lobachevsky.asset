  achievementsRu: "\u041E\u0441\u043D\u043E\u0432\u043D\u043E\u0439 \u0432\u043A\u043B\u0430\u0434
    \u041D\u0438\u043A\u043E\u043B\u0430\u044F \u0418\u0432\u0430\u043D\u043E\u0432\u0438\u0447\u0430
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u0432
    \u043D\u0430\u0443\u043A\u0443 \u2014 \u044D\u0442\u043E, \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E,
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 **\u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0430 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0438 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043D\u0430\u0448\u043B\u0430 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0432 \u0444\u0438\u0437\u0438\u043A\u0435. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u043D\u0435
    \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u044D\u0442\u0438\u043C \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\u043C. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0432\u0430\u0436\u043D\u044B\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0432 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0440\u0430\u0437\u0434\u0435\u043B\u0430\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u0432\u043D\u0451\u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u043A\u0430\u043A
    \u0440\u0435\u043A\u0442\u043E\u0440 \u0438 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440
    \u043D\u0430\u0443\u043A\u0438.  ### \U0001F52C \u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434: \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438  \u0418\u0434\u0435\u044F
    \u043D\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u043F\u0440\u0438\u0448\u043B\u0430 \u043A \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u043C\u0443
    \u0432 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445
    \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439 \u043E \xAB\u043F\u044F\u0442\u043E\u043C
    \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442\u0435\xBB \u0415\u0432\u043A\u043B\u0438\u0434\u0430.
    \u042D\u0442\u043E\u0442 \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0447\u0435\u0440\u0435\u0437 \u0442\u043E\u0447\u043A\u0443
    \u0432\u043D\u0435 \u043F\u0440\u044F\u043C\u043E\u0439 \u043C\u043E\u0436\u043D\u043E
    \u043F\u0440\u043E\u0432\u0435\u0441\u0442\u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0434\u043D\u0443 \u043F\u0440\u044F\u043C\u0443\u044E, \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u0443\u044E
    \u0434\u0430\u043D\u043D\u043E\u0439. \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439
    \u043F\u0440\u0438\u0448\u0451\u043B \u043A \u0432\u044B\u0432\u043E\u0434\u0443,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043D\u0438\u0435
    \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0436\u0451\u0441\u0442\u043A\u043E\u0435,
    \u0438 \u0437\u0430\u043C\u0435\u043D\u0438\u043B \u0435\u0433\u043E \u043D\u0430
    \u0430\u043B\u044C\u0442\u0435\u0440\u043D\u0430\u0442\u0438\u0432\u0443: **\u043D\u0430
    \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438 \u0447\u0435\u0440\u0435\u0437
    \u0442\u043E\u0447\u043A\u0443, \u043D\u0435 \u043B\u0435\u0436\u0430\u0449\u0443\u044E
    \u043D\u0430 \u043F\u0440\u044F\u043C\u043E\u0439, \u043F\u0440\u043E\u0445\u043E\u0434\u044F\u0442
    \u043F\u043E \u043C\u0435\u043D\u044C\u0448\u0435\u0439 \u043C\u0435\u0440\u0435
    \u0434\u0432\u0435 \u043F\u0440\u044F\u043C\u044B\u0435, \u043D\u0435 \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u044E\u0449\u0438\u0435
    \u0434\u0430\u043D\u043D\u0443\u044E**.  \u042D\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u043E\u0435
    \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0441\u0442\u0430\u043B\u043E
    \u043E\u0442\u043F\u0440\u0430\u0432\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u043E\u0439
    \u0434\u043B\u044F \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F
    \u043D\u043E\u0432\u043E\u0439, \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439 \u043D\u0430\u0437\u0432\u0430\u043B
    **\xAB\u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0430\u0435\u043C\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439\xBB**.  \u0412\u043E\u0442
    \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044F \u0435\u0433\u043E
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0439,
    \u043A\u0430\u0436\u0434\u0430\u044F \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0432\u0435\u0445\u043E\u0439
    \u0432 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0438 \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u0438: 
    *   **1826 \u0433. \u2014 \xAB\u0421\u0436\u0430\u0442\u043E\u0435 \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u043D\u0430\u0447\u0430\u043B \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438...\xBB**:
    7 \u0444\u0435\u0432\u0440\u0430\u043B\u044F \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C
    \u043D\u0430 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435, \u0430 11 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    \u0434\u043E\u043B\u043E\u0436\u0438\u043B \u0435\u0451 \u043D\u0430 \u0437\u0430\u0441\u0435\u0434\u0430\u043D\u0438\u0438
    \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430. \u042D\u0442\u0430
    \u0434\u0430\u0442\u0430 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u0434\u043D\u0451\u043C \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. *   **1829\u20131830
    \u0433\u0433. \u2014 \xAB\u041E \u043D\u0430\u0447\u0430\u043B\u0430\u0445 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB**:
    \u041F\u0435\u0440\u0432\u0430\u044F \u0432 \u043C\u0438\u0440\u0435 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F
    \u043F\u043E \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0432\u044B\u0448\u0435\u0434\u0448\u0430\u044F
    \u0432 \xAB\u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u043C \u0432\u0435\u0441\u0442\u043D\u0438\u043A\u0435\xBB.
    *   **1835\u20131838 \u0433\u0433. \u2014 \xAB\u0412\u043E\u043E\u0431\u0440\u0430\u0436\u0430\u0435\u043C\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F\xBB \u0438 \xAB\u041D\u043E\u0432\u044B\u0435
    \u043D\u0430\u0447\u0430\u043B\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0441 \u043F\u043E\u043B\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u0445\xBB**:
    \u0411\u043E\u043B\u0435\u0435 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0435
    \u0438 \u0440\u0430\u0437\u0432\u0451\u0440\u043D\u0443\u0442\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u044B,
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u0432 \xAB\u0423\u0447\u0451\u043D\u044B\u0445 \u0437\u0430\u043F\u0438\u0441\u043A\u0430\u0445
    \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\xBB.
    *   **1840 \u0433. \u2014 \xAB\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F \u043F\u043E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u0445\xBB**:
    \u041A\u043D\u0438\u0433\u0430, \u0438\u0437\u0434\u0430\u043D\u043D\u0430\u044F
    \u043D\u0430 \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u043C \u044F\u0437\u044B\u043A\u0435
    \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438. \u0418\u043C\u0435\u043D\u043D\u043E
    \u043E\u043D\u0430 \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u043B\u0430 \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435
    **\u041A\u0430\u0440\u043B\u0430 \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430
    \u0413\u0430\u0443\u0441\u0441\u0430**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u044B\u0441\u043E\u043A\u043E \u043E\u0446\u0435\u043D\u0438\u043B \u0442\u0440\u0443\u0434
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E. *  
    **1855 \u0433. \u2014 \xAB\u041F\u0430\u043D\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F\xBB**:
