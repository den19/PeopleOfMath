    \u0437\u0430\u0442\u0435\u043C \u0438 \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439 \u0443\u0432\u043B\u0435\u043A\u0441\u044F
