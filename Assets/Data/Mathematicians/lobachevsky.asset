    \u0447\u0442\u043E \u043D\u0435 \u0431\u044B\u043B\u0438 \u043F\u043E\u043D\u044F\u0442\u044B
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438
    \u0432 \u0420\u043E\u0441\u0441\u0438\u0438 \u0438 \u0434\u0430\u0436\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438
    \u0440\u0435\u0437\u043A\u043E \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u043E\u0442\u0437\u044B\u0432 \u043E\u0442 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u0430
    \u041C.\u0412. \u041E\u0441\u0442\u0440\u043E\u0433\u0440\u0430\u0434\u0441\u043A\u043E\u0433\u043E.
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043D\u0435\u0433\u043E,
    \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u042F\u043D\u043E\u0448 \u0411\u043E\u0439\u044F\u0438, \u0442\u0430\u043A\u0436\u0435
    \u043F\u0440\u0438\u0448\u0435\u0434\u0448\u0438\u0439 \u043A \u043F\u043E\u0434\u043E\u0431\u043D\u044B\u043C
    \u0438\u0434\u0435\u044F\u043C, \u043D\u043E \u043D\u0435 \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u0432
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0438, \u043F\u0440\u0435\u043A\u0440\u0430\u0442\u0438\u043B
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F. \u0413\u0430\u0443\u0441\u0441,
    \u0432\u043B\u0430\u0434\u0435\u0432\u0448\u0438\u0439 \u043D\u0430\u0447\u0430\u043B\u0430\u043C\u0438
    \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u043D\u0435 \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0438\u0445
    \u0438\u0437 \u043E\u043F\u0430\u0441\u0435\u043D\u0438\u044F \u0431\u044B\u0442\u044C
    \u043D\u0435\u043F\u043E\u043D\u044F\u0442\u044B\u043C. \u0418\u043C\u0435\u043D\u043D\u043E
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439 \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u0442\u0432\u0451\u0440\u0434\u043E\u0441\u0442\u044C \u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u0442\u0435\u043E\u0440\u0438\u044E, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043A\u0440\u0438\u0442\u0438\u043A\u0443.  ### \U0001F9EE \u0412\u043A\u043B\u0430\u0434
    \u0432 \u0434\u0440\u0443\u0433\u0438\u0435 \u0440\u0430\u0437\u0434\u0435\u043B\u044B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438  \u041F\u043E\u043C\u0438\u043C\u043E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439
    \u0432\u043D\u0451\u0441 \u0432\u043A\u043B\u0430\u0434 \u0438 \u0432 \u0434\u0440\u0443\u0433\u0438\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438: 
    *   **\u0410\u043B\u0433\u0435\u0431\u0440\u0430**: \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043D\u043E\u0432\u044B\u0439 \u043C\u0435\u0442\u043E\u0434 \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0451\u043D\u043D\u043E\u0433\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439.
    *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437**: \u041F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0440\u044F\u0434 \u0442\u0435\u043E\u0440\u0435\u043C \u043E \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u044F\u0434\u0430\u0445. *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439**:
    \u0412\u044B\u0432\u0435\u043B \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0434\u043B\u044F
    \u043C\u043D\u043E\u0433\u043E\u043A\u0440\u0430\u0442\u043D\u044B\u0445 \u0441\u0432\u0451\u0440\u0442\u043E\u043A
    \u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0433\u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F. 
    ### \U0001F3DB\uFE0F \u0410\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u0430\u044F
    \u0438 \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C  \u041A\u0430\u043A
    \u0440\u0435\u043A\u0442\u043E\u0440 \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 (1827\u20131846),
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439 \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u0441\u0435\u0431\u044F \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C
    \u0438 \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u043C: 
    *   **\u0421\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E**:
    \u041F\u043E\u0434 \u0435\u0433\u043E \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0431\u044B\u043B \u0432\u043E\u0437\u0432\u0435\u0434\u0451\u043D \u0446\u0435\u043B\u044B\u0439
    \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441 \u0437\u0434\u0430\u043D\u0438\u0439,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0443,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0438 \u043C\u0430\u0433\u043D\u0438\u0442\u043D\u0443\u044E \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438,
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u043A\u0430\u0431\u0438\u043D\u0435\u0442,
    \u0445\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u044E,
    \u0430\u043D\u0430\u0442\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0435\u0430\u0442\u0440 \u0438 \u043A\u043B\u0438\u043D\u0438\u043A\u0443.
    *   **\u0418\u0437\u0434\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C**: \u0412
    1834 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \xAB\u0423\u0447\u0451\u043D\u044B\u0435 \u0437\u0430\u043F\u0438\u0441\u043A\u0438
    \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\xBB,
    \u0433\u0434\u0435 \u0438 \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u044B. 
    \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u043F\u0440\u0438\u0448\u043B\u043E
    \u043A \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u043C\u0443
    \u043B\u0438\u0448\u044C \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438,
    \u043A\u043E\u0433\u0434\u0430 \u0432 1860-\u0445 \u0433\u043E\u0434\u0430\u0445
    \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u042D. \u0411\u0435\u043B\u044C\u0442\u0440\u0430\u043C\u0438 \u0438 \u0434\u0440\u0443\u0433\u0438\u0435
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0438, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0439.
    \u041F\u043E\u0437\u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u044B \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043B\u0435\u0433\u043B\u0438 \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0410\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430,
    \u043F\u043E\u043A\u0430\u0437\u0430\u0432\u0448\u0435\u0439, \u0447\u0442\u043E
    \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0435 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E \u0438\u0441\u043A\u0440\u0438\u0432\u043B\u0435\u043D\u043E,
    \u0438 \u0432 \u043D\u0451\u043C \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442
    \u0438\u043C\u0435\u043D\u043D\u043E \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F."
  achievementsEn: 
  personalLifeRu: "\u0411\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u041D\u0438\u043A\u043E\u043B\u0430\u044F
    \u0418\u0432\u0430\u043D\u043E\u0432\u0438\u0447\u0430 \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E \u0442\u043E\u043C,
    \u043A\u0430\u043A \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u0443\u043C \u0438 \u043D\u0435\u0441\u0433\u0438\u0431\u0430\u0435\u043C\u044B\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440 \u043F\u0440\u043E\u0448\u043B\u0438
    \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0438 \u043B\u0438\u0447\u043D\u044B\u0435 \u0443\u0442\u0440\u0430\u0442\u044B,
    \u043D\u043E \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438 \u0441\u043B\u0435\u0434
    \u043D\u0430 \u0432\u0435\u043A\u0430. \u0427\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0441\u043B\u0435\u0434\u0438\u0442\u044C
    \u0435\u0433\u043E \u043F\u0443\u0442\u044C \u0432 \u0434\u0435\u0442\u0430\u043B\u044F\u0445,
    \u043E\u0431\u0440\u0430\u0442\u0438\u043C\u0441\u044F \u043A \u0444\u0430\u043A\u0442\u0430\u043C
    \u0438 \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432. 
    ### \U0001F4DC \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435,
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u043F\u0435\u0440\u0432\u044B\u0435
    \u0448\u0430\u0433\u0438  \u041D\u0438\u043A\u043E\u043B\u0430\u0439 \u0418\u0432\u0430\u043D\u043E\u0432\u0438\u0447
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    **20 \u043D\u043E\u044F\u0431\u0440\u044F (1 \u0434\u0435\u043A\u0430\u0431\u0440\u044F)
    1792 \u0433\u043E\u0434\u0430** \u0432 \u041D\u0438\u0436\u043D\u0435\u043C \u041D\u043E\u0432\u0433\u043E\u0440\u043E\u0434\u0435
    (\u043F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0434\u0430\u043D\u043D\u044B\u043C,
    \u0432 \u041C\u0430\u043A\u0430\u0440\u044C\u0435\u0432\u0441\u043A\u043E\u043C
    \u0443\u0435\u0437\u0434\u0435 \u041D\u0438\u0436\u0435\u0433\u043E\u0440\u043E\u0434\u0441\u043A\u043E\u0439
    \u0433\u0443\u0431\u0435\u0440\u043D\u0438\u0438). \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u0418\u0432\u0430\u043D \u041C\u0430\u043A\u0441\u0438\u043C\u043E\u0432\u0438\u0447,
    \u0431\u044B\u043B \u043D\u0435\u0431\u043E\u0433\u0430\u0442\u044B\u043C \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u043E\u043C,
    \u043F\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044E
    \u0438\u0437 \u0417\u0430\u043F\u0430\u0434\u043D\u043E\u0433\u043E \u043A\u0440\u0430\u044F,
    \u043A\u0430\u0442\u043E\u043B\u0438\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0437\u0436\u0435 \u043F\u0435\u0440\u0435\u0448\u0451\u043B \u0432
    \u043F\u0440\u0430\u0432\u043E\u0441\u043B\u0430\u0432\u0438\u0435. \u041E\u043D
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 1797 \u0433\u043E\u0434\u0443,
    \u043A\u043E\u0433\u0434\u0430 \u041D\u0438\u043A\u043E\u043B\u0430\u044E \u0431\u044B\u043B\u043E
    \u0432\u0441\u0435\u0433\u043E \u043F\u044F\u0442\u044C \u043B\u0435\u0442, \u043E\u0441\u0442\u0430\u0432\u0438\u0432
    \u0441\u0435\u043C\u044C\u044E \u0431\u0435\u0437 \u0441\u0440\u0435\u0434\u0441\u0442\u0432
    \u043A \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044E. 
    \u041C\u0430\u0442\u044C, \u041F\u0440\u0430\u0441\u043A\u043E\u0432\u044C\u044F
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u0432\u043D\u0430,
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0430 \u043D\u0435\u0437\u0430\u0443\u0440\u044F\u0434\u043D\u0443\u044E
    \u044D\u043D\u0435\u0440\u0433\u0438\u044E \u0438 \u043D\u0430\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u044C.
    \u0427\u0442\u043E\u0431\u044B \u0434\u0430\u0442\u044C \u0441\u044B\u043D\u043E\u0432\u044C\u044F\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435, \u043E\u043D\u0430
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430 \u0432 \u041A\u0430\u0437\u0430\u043D\u044C
    \u0438 \u0434\u043E\u0431\u0438\u043B\u0430\u0441\u044C \u0438\u0445 \u0437\u0430\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0432 \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u044E \u043D\u0430 \u043A\u0430\u0437\u0451\u043D\u043D\u043E\u0435
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0435\u0451 \u0433\u0440\u0430\u043C\u043E\u0442\u043D\u043E \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0435
    \u043F\u0440\u043E\u0448\u0435\u043D\u0438\u044F \u0438 \u0440\u0435\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0441\u044B\u0433\u0440\u0430\u043B\u0438 \u0440\u0435\u0448\u0430\u044E\u0449\u0443\u044E
    \u0440\u043E\u043B\u044C \u0432 \u043D\u0430\u0447\u0430\u043B\u0435 \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u0443\u0442\u0438 \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E \u0443\u0447\u0451\u043D\u043E\u0433\u043E. 
    ### \U0001F393 \u0423\u0447\u0451\u0431\u0430 \u0432 \u041A\u0430\u0437\u0430\u043D\u0438:
    \u043E\u0442 \u0448\u0430\u043B\u043E\u0441\u0442\u0435\u0439 \u0434\u043E \u043A\u0430\u043C\u0435\u0440\u043D\u043E\u0433\u043E
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430  \u0412 1802 \u0433\u043E\u0434\u0443
    \u041D\u0438\u043A\u043E\u043B\u0430\u0439 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u0443\u044E \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u044E.
    \u0410\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0430 \u0432 \u0443\u0447\u0435\u0431\u043D\u043E\u043C
    \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0438 \u0431\u044B\u043B\u0430
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0439 \u2014 \u0441\u0440\u0435\u0434\u0438
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432 \u0446\u0430\u0440\u0438\u043B
    \xAB\u0436\u0430\u0440 \u0437\u043D\u0430\u043D\u0438\u0439, \u043F\u044B\u043B\u043A\u043E\u0435
    \u0441\u0442\u0440\u0435\u043C\u043B\u0435\u043D\u0438\u0435 \u043A \u0443\u0447\u0435\u043D\u0438\u044E\xBB.
    \u0423\u0436\u0435 \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0430 \u0433\u043E\u0434\u0430,
    \u0432 1807-\u043C, 14-\u043B\u0435\u0442\u043D\u0438\u0439 \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439
    \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C
    \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0432\u0448\u0435\u0433\u043E\u0441\u044F
    \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430.
    \u0421\u0440\u0435\u0434\u0438 \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u044B\u0445
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u0432 \u0431\u044B\u043B
    \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u0439 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 **\u0413\u0440\u0438\u0433\u043E\u0440\u0438\u0439
    \u0418\u0432\u0430\u043D\u043E\u0432\u0438\u0447 \u041A\u0430\u0440\u0442\u0430\u0448\u0435\u0432\u0441\u043A\u0438\u0439**,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u043A\u0440\u0443\u043F\u043D\u044B\u0439
    \u0443\u0447\u0451\u043D\u044B\u0439 **\u041C\u0430\u0440\u0442\u0438\u043D \u0424\u0451\u0434\u043E\u0440\u043E\u0432\u0438\u0447
    \u0411\u0430\u0440\u0442\u0435\u043B\u044C\u0441**, \u0431\u043B\u0438\u0437\u043A\u0438\u0439
    \u0434\u0440\u0443\u0433 \u041A\u0430\u0440\u043B\u0430 \u0413\u0430\u0443\u0441\u0441\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0437\u0430\u043C\u0435\u0442\u0438\u043B
    \u0438 \u0440\u0430\u0437\u0432\u0438\u043B \u0434\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u044E\u043D\u043E\u0448\u0438.  \u042E\u043D\u043E\u0441\u0442\u044C \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u0430 \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u043E\u0432.
    \u0421 \u043E\u0434\u043D\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B,
    \u0435\u0433\u043E \u0443\u0441\u043F\u0435\u0445\u0438 \u0432 \u043D\u0430\u0443\u043A\u0430\u0445
    \u0431\u044B\u043B\u0438 \u0441\u0442\u043E\u043B\u044C \u0432\u0435\u043B\u0438\u043A\u0438,
    \u0447\u0442\u043E \u0432 1809 \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B
    \u0438\u0437\u0431\u0440\u0430\u043D **\u043A\u0430\u043C\u0435\u0440\u043D\u044B\u043C
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C** \u2014 \u043F\u043E\u0447\u0451\u0442\u043D\u043E\u0435
    \u0437\u0432\u0430\u043D\u0438\u0435 \u0434\u043B\u044F \u043B\u0443\u0447\u0448\u0438\u0445
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0432\u044B\u0434\u0430\u0432\u0430\u043B\u043E\u0441\u044C \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u044C\u0435
    \u043D\u0430 \u043A\u043D\u0438\u0433\u0438 \u0438 \u043F\u043E\u0440\u0443\u0447\u0430\u043B\u0441\u044F
    \u043D\u0430\u0434\u0437\u043E\u0440 \u0437\u0430 \u0442\u043E\u0432\u0430\u0440\u0438\u0449\u0430\u043C\u0438.
    \u0412 \u043E\u0442\u0437\u044B\u0432\u0430\u0445 \u043E \u043D\u0451\u043C \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u043E\u043D \xAB\u043E\u0442\u043B\u0438\u0447\u0430\u043B\u0441\u044F\xBB
    \u043F\u043E\u0447\u0442\u0438 \u043D\u0430 \u0432\u0441\u0435\u0445 \u043B\u0435\u043A\u0446\u0438\u044F\u0445.
    \u0421 \u0434\u0440\u0443\u0433\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B,
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0441\u044C \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043E \u0435\u0433\u043E \u0436\u0438\u0432\u043E\u043C, \u043F\u043E\u0440\u043E\u0439
    \u0448\u0430\u043B\u043E\u0432\u043B\u0438\u0432\u043E\u043C \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0435.
    \u0417\u0430 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u0440\u043E\u0441\u0442\u0443\u043F\u043A\u0438
    \u043E\u043D \u0434\u0430\u0436\u0435 \u0431\u044B\u043B \u043D\u0430\u043A\u0430\u0437\u0430\u043D
    \u043A\u0430\u0440\u0446\u0435\u0440\u043E\u043C, \u043D\u043E \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C, \u043F\u043E \u0441\u043B\u043E\u0432\u0430\u043C \u0438\u043D\u0441\u043F\u0435\u043A\u0442\u043E\u0440\u043E\u0432,
    \xAB\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B \u0447\u0438\u0441\u0442\u043E\u0441\u0435\u0440\u0434\u0435\u0447\u043D\u043E\u0435\u2026
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438 \u0438\u0441\u043F\u0440\u0430\u0432\u043B\u044F\u043B\u0441\u044F\xBB.
    \u0423\u0447\u0451\u0431\u0443 \u043E\u043D \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B
    \u0432 1811 \u0433\u043E\u0434\u0443, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430. 
    ### \U0001F468\u200D\U0001F3EB \u0421\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0438 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0439 \u0438\u0434\u0435\u0438 
    \u041D\u0430\u0443\u0447\u043D\u0430\u044F \u0438 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u0432 \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B\u0430\u0441\u044C \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0431\u044B\u0441\u0442\u0440\u043E. \u041E\u043D \u0441\u043B\u043E\u0432\u043D\u043E
    \u0431\u044B\u043B \u0441\u043E\u0437\u0434\u0430\u043D \u0434\u043B\u044F \u0442\u043E\u0433\u043E,
    \u0447\u0442\u043E\u0431\u044B \u0441\u0442\u0430\u0442\u044C \u0447\u0430\u0441\u0442\u044C\u044E
    \u044D\u0442\u043E\u0433\u043E \u0443\u0447\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u044F: 
    *   **1814 \u0433\u043E\u0434** \u2014 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0451\u043D
    \u0430\u0434\u044A\u044E\u043D\u043A\u0442\u043E\u043C \u0447\u0438\u0441\u0442\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. *   **1816 \u0433\u043E\u0434**
    \u2014 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 24 \u043B\u0435\u0442
    \u0438\u0437\u0431\u0440\u0430\u043D \u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C. *   **1822
    \u0433\u043E\u0434** \u2014 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
    \u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C,
    \u0435\u0433\u043E \u043B\u0435\u043A\u0446\u0438\u0438 \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u043B\u0438
    \u0448\u0438\u0440\u043E\u043A\u0438\u0439 \u0441\u043F\u0435\u043A\u0442\u0440
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D: \u043E\u0442 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0434\u043E \u0444\u0438\u0437\u0438\u043A\u0438 \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438. 
    \u0423\u0436\u0435 \u0441 1817 \u0433\u043E\u0434\u0430 \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439
    \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0430\u0434
    \xAB\u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u044C\u044E, \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440 \u043D\u0435\u043F\u043E\u0431\u0435\u0434\u0438\u043C\u043E\u0439\xBB
    \u2014 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u043F\u044F\u0442\u043E\u0433\u043E \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442\u0430
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430. \u0415\u0433\u043E \u043F\u043E\u043F\u044B\u0442\u043A\u0438
    \u043D\u0430\u0439\u0442\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \xAB\u043E\u0442 \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u043E\u0433\u043E\xBB
    \u043F\u0440\u0438\u0432\u0435\u043B\u0438 \u043A \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E\u043C\u0443
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0443: \u0432\u043C\u0435\u0441\u0442\u043E
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u044F \u043E\u043D
    \u0432\u044B\u0432\u043E\u0434\u0438\u043B \u0432\u0441\u0451 \u043D\u043E\u0432\u044B\u0435
    \u0438 \u043D\u043E\u0432\u044B\u0435 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u043B\u0438
    \u0441\u0442\u0440\u0430\u043D\u043D\u043E, \u043D\u043E \u0431\u044B\u043B\u0438
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u043D\u0435\u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u044B.
    \u0422\u0430\u043A, \u043A 1823 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0440\u0438\u0448\u0451\u043B
    \u043A \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u044E, \u0447\u0442\u043E \u0430\u043A\u0441\u0438\u043E\u043C\u0430
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u043D\u0435\u0434\u043E\u043A\u0430\u0437\u0443\u0435\u043C\u0430
    \u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u0430 \u0438\u043D\u0430\u044F,
    \xAB\u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0430\u0435\u043C\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F\xBB. \u042D\u0442\u043E\u0442
    \u043F\u0440\u043E\u0440\u044B\u0432 \u0431\u044B\u043B \u0437\u0430\u043A\u0440\u0435\u043F\u043B\u0451\u043D
    7 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 1826 \u0433\u043E\u0434\u0430, \u043A\u043E\u0433\u0434\u0430
    \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u043D\u0430
    \u0437\u0430\u0441\u0435\u0434\u0430\u043D\u0438\u0438 \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0430
    \u0441\u0432\u043E\u044E \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C \xAB\u0421\u0436\u0430\u0442\u043E\u0435
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u043D\u0430\u0447\u0430\u043B
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438...\xBB.  ### \u2696\uFE0F
    \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438:
    \u0442\u0440\u0438\u0443\u043C\u0444\u0430\u043B\u044C\u043D\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0438 \u0433\u043E\u0440\u044C\u043A\u043E\u0435 \u043D\u0435\u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u0441 \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E\u043C
    \u2014 \u043E\u0434\u043D\u0430 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u044B\u0445
    \u0441\u0442\u0440\u0430\u043D\u0438\u0446 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434
    \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F \u0441 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u044B\u043C
    \u043D\u0435\u043F\u0440\u0438\u044F\u0442\u0438\u0435\u043C.  *   **\u041C.\u0412.
    \u041E\u0441\u0442\u0440\u043E\u0433\u0440\u0430\u0434\u0441\u043A\u0438\u0439**:
    \u041A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0439 \u0440\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0434\u0430\u043B \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0430\u044E\u0449\u0438\u0439
    \u043E\u0442\u0437\u044B\u0432 \u043D\u0430 \u043C\u0435\u043C\u0443\u0430\u0440
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E \xAB\u041E
    \u043D\u0430\u0447\u0430\u043B\u0430\u0445 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB,
    \u0437\u0430\u044F\u0432\u0438\u0432, \u0447\u0442\u043E \xAB\u0431\u043E\u043B\u044C\u0448\u0430\u044F
    \u0447\u0430\u0441\u0442\u044C \u043A\u043D\u0438\u0433\u0438\u2026 \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C
    \u0441\u0442\u043E\u043B\u044C \u0436\u0435 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439
    \u0434\u043B\u044F \u043C\u0435\u043D\u044F, \u043A\u0430\u043A \u0435\u0441\u043B\u0438
    \u0431\u044B \u044F \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0432\u0438\u0434\u0435\u043B
    \u0435\u0451\xBB. \u0412\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043E\u043D \u043D\u0435 \u0440\u0430\u0437 \u0434\u0430\u0432\u0430\u043B \u0440\u0435\u0437\u043A\u043E
    \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043E\u0446\u0435\u043D\u043A\u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043C
    \u043A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u0443\u0447\u0451\u043D\u043E\u0433\u043E,
    \u0441\u0447\u0438\u0442\u0430\u044F \u0435\u0433\u043E \u0438\u0434\u0435\u0438
    \u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0435\u043C \xAB\u0443\u0440\u043E\u0434\u043B\u0438\u0432\u043E\u0433\u043E
    \u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F\xBB. \u042D\u0442\u0430
    \u043F\u043E\u0437\u0438\u0446\u0438\u044F \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0430 \u0445\u043E\u043B\u043E\u0434\u043D\u044B\u0439
    \u043F\u0440\u0438\u0451\u043C, \u043E\u043A\u0430\u0437\u0430\u043D\u043D\u044B\u0439
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044E \u0432 \u0420\u043E\u0441\u0441\u0438\u0438.
    *   **\u041A\u0430\u0440\u043B \u0424\u0440\u0438\u0434\u0440\u0438\u0445 \u0413\u0430\u0443\u0441\u0441**:
    \u0412\u0435\u043B\u0438\u043A\u0438\u0439 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0438 \u0441\u0430\u043C \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u044F\u043B
    \u0432 \u0442\u043E\u043C \u0436\u0435 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0438,
    \u043D\u043E \u043E\u043F\u0430\u0441\u0430\u043B\u0441\u044F \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u0438 \u0438\u0434\u0435\u0438 \u0438\u0437-\u0437\u0430 \xAB\u043A\u0440\u0438\u043A\u0430
    \u0431\u0435\u043E\u0442\u0438\u0439\u0446\u0435\u0432\xBB (\u0442\u0430\u043A
    \u043E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u043D\u0435\u0432\u0435\u0436\u0434),
    \u0441\u0442\u0430\u043B \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C,
    \u043A\u0442\u043E \u043F\u043E \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u0443
    \u043E\u0446\u0435\u043D\u0438\u043B \u0442\u0440\u0443\u0434 \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E.
    \u041E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0438\u0442\u0430\u043B
    \u0438 \u0432\u044B\u0441\u043E\u043A\u043E \u0446\u0435\u043D\u0438\u043B \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B, \u043D\u043E \u0438 \u0432 1842 \u0433\u043E\u0434\u0443
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0438\u0437\u0431\u0440\u0430\u0442\u044C
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430
    \u043D\u0430\u0443\u043A. \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0444\u043E\u0440\u043C\u0430 \u043F\u0440\u0438\u0436\u0438\u0437\u043D\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0437\u0430\u0441\u043B\u0443\u0433. *   **\u0412.\u042F. \u0411\u0443\u043D\u044F\u043A\u043E\u0432\u0441\u043A\u0438\u0439**:
    \u0414\u0440\u0443\u0433\u043E\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A \u0442\u0430\u043A\u0436\u0435
    \u0432\u044B\u0441\u0442\u0443\u043F\u0438\u043B \u043F\u0440\u043E\u0442\u0438\u0432
    \u043D\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u0432 \u043C\u043D\u0435\u043D\u0438\u0435
    \u041E\u0441\u0442\u0440\u043E\u0433\u0440\u0430\u0434\u0441\u043A\u043E\u0433\u043E. 
    \u041F\u043E\u043C\u0438\u043C\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u043E\u043F\u043F\u043E\u043D\u0435\u043D\u0442\u043E\u0432, \u0432 \u043F\u0440\u0435\u0441\u0441\u0435
    \u043F\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C \u044F\u0437\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0438 \u0433\u0440\u0443\u0431\u044B\u0435 \u0441\u0442\u0430\u0442\u044C\u0438,
    \u0433\u0434\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u0432\u044B\u0441\u043C\u0435\u0438\u0432\u0430\u043B\u0438 \u043A\u0430\u043A
    \u043D\u0435\u043B\u0435\u043F\u0443\u044E \u0444\u0430\u043D\u0442\u0430\u0437\u0438\u044E,
    \u0430 \u0441\u0430\u043C\u043E\u0433\u043E \u0430\u0432\u0442\u043E\u0440\u0430
    \u043E\u0431\u0432\u0438\u043D\u044F\u043B\u0438 \u0432 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043A\u0435
    \u0437\u0434\u0440\u0430\u0432\u043E\u0433\u043E \u0441\u043C\u044B\u0441\u043B\u0430.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0432\u0441\u0451 \u044D\u0442\u043E, \u0443\u0447\u0451\u043D\u044B\u0439
    \u043D\u0435 \u0441\u043B\u043E\u043C\u0438\u043B\u0441\u044F \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F. 
    ### \U0001F3DB\uFE0F \u0412\u043E \u0433\u043B\u0430\u0432\u0435 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430:
    \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C, \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u0442\u043E\u0440
    \u0438 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0430\u0440\u044C 
    \u041F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u043E \u0441 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u043E\u0439 \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B \u0441\u0435\u0431\u044F \u043A\u0430\u043A
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440.
    \u0421 1827 \u043F\u043E 1846 \u0433\u043E\u0434 \u043E\u043D \u0431\u0435\u0441\u0441\u043C\u0435\u043D\u043D\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B \u043F\u043E\u0441\u0442 **\u0440\u0435\u043A\u0442\u043E\u0440\u0430
    \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430**.
    \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u0432\u043E\u0448\u0451\u043B
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u043A\u0430\u043A **\xAB\u044D\u043F\u043E\u0445\u0430
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E\xBB**. 
    \u041D\u0430 \u043F\u043E\u0441\u0442\u0443 \u0440\u0435\u043A\u0442\u043E\u0440\u0430
    \u043E\u043D: *   **\u041F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u0432 \u0446\u0435\u043D\u0442\u0440 \u0432\u043E\u0441\u0442\u043E\u043A\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F**:
    \u0420\u0430\u0437\u0434\u0435\u043B\u0438\u043B \u043A\u0430\u0444\u0435\u0434\u0440\u0443
    \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0445 \u044F\u0437\u044B\u043A\u043E\u0432,
    \u043E\u0442\u043A\u0440\u044B\u043B \u043A\u0430\u0444\u0435\u0434\u0440\u044B
    \u043C\u043E\u043D\u0433\u043E\u043B\u044C\u0441\u043A\u043E\u0433\u043E, \u043A\u0438\u0442\u0430\u0439\u0441\u043A\u043E\u0433\u043E,
    \u0430\u0440\u043C\u044F\u043D\u0441\u043A\u043E\u0433\u043E \u0438 \u0441\u0430\u043D\u0441\u043A\u0440\u0438\u0442\u0441\u043A\u043E\u0433\u043E
    \u044F\u0437\u044B\u043A\u043E\u0432, \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u043C \u044F\u0432\u043B\u0435\u043D\u0438\u0435\u043C
    \u0434\u043B\u044F \u0420\u043E\u0441\u0441\u0438\u0438 \u0438 \u0415\u0432\u0440\u043E\u043F\u044B.
    *   **\u0411\u044B\u043B \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u0435\u043C**:
    \u0420\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u043B \u0432\u043E\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435\u043C
    \u0446\u0435\u043B\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u043E\u0433\u043E
    \u0433\u043E\u0440\u043E\u0434\u043A\u0430 \u2014 \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E
    \u043A\u043E\u0440\u043F\u0443\u0441\u0430, \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0438,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438, \u0430\u043D\u0430\u0442\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0442\u0435\u0430\u0442\u0440\u0430, \u0445\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u0438 \u0438 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0437\u0434\u0430\u043D\u0438\u0439. *   **\u0423\u043F\u0440\u0430\u0432\u043B\u044F\u043B
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u043E\u0439**: \u041B\u0438\u0447\u043D\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0442\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0444\u043E\u043D\u0434\u0430, \u043D\u0430\u043B\u0430\u0434\u0438\u043B \u0441\u0432\u044F\u0437\u0438
    \u0441 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438 \u0443\u0447\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u044F\u043C\u0438
    \u0415\u0432\u0440\u043E\u043F\u044B, \u0441\u0434\u0435\u043B\u0430\u043B \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0443
    \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u0439 \u0434\u043B\u044F \u043F\u0443\u0431\u043B\u0438\u043A\u0438. 
    ### \U0001F3E0 \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C:
    \u043F\u043E\u0437\u0434\u043D\u0438\u0439 \u0431\u0440\u0430\u043A \u0438 \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u044F
    \u0441\u0443\u0434\u044C\u0431\u044B  \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043F\u043E\u0437\u0434\u043D\u043E,
    \u0432 44 \u0433\u043E\u0434\u0430, \u043D\u0430 **\u0412\u0430\u0440\u0432\u0430\u0440\u0435
    \u0410\u043B\u0435\u043A\u0441\u0435\u0435\u0432\u043D\u0435 \u041C\u043E\u0438\u0441\u0435\u0435\u0432\u043E\u0439**,
    \u0431\u043E\u0433\u0430\u0442\u043E\u0439 \u043E\u0440\u0435\u043D\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u043F\u043E\u043C\u0435\u0449\u0438\u0446\u0435. \u041E\u043D\u0438 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0438\u0441\u044C
    \u043D\u0430 \u0431\u0430\u043B\u0443, \u0438, \u043F\u043E \u0441\u043B\u0443\u0445\u0430\u043C,
    \u044E\u043D\u0430\u044F \u0412\u0430\u0440\u0435\u043D\u044C\u043A\u0430, \u043E\u0436\u0438\u0434\u0430\u0432\u0448\u0430\u044F
    \u0443\u0432\u0438\u0434\u0435\u0442\u044C \xAB\u0431\u043E\u0440\u043E\u0434\u0430\u0442\u043E\u0433\u043E
    \u0441\u0442\u0430\u0440\u0446\u0430\xBB, \u0431\u044B\u043B\u0430 \u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0430
    \u0432\u0438\u0434\u043D\u044B\u043C \u0438 \u0443\u043C\u043D\u044B\u043C \u0443\u0447\u0451\u043D\u044B\u043C. 
    \u0418\u0445 \u0431\u0440\u0430\u043A, \u0434\u043B\u0438\u0432\u0448\u0438\u0439\u0441\u044F
    24 \u0433\u043E\u0434\u0430, \u0441\u0442\u0430\u043B \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C
    \u0441\u043E\u044E\u0437\u043E\u043C \u0434\u0432\u0443\u0445 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0435\u0439
    : *   **\u0412\u0430\u0440\u0432\u0430\u0440\u0430 \u0410\u043B\u0435\u043A\u0441\u0435\u0435\u0432\u043D\u0430**
    \u0431\u044B\u043B\u0430 \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439 \u0436\u0438\u0432\u043E\u0439,
    \u0432\u0441\u043F\u044B\u043B\u044C\u0447\u0438\u0432\u043E\u0439 \u0438 \u043E\u0431\u0449\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439,
    \u043B\u044E\u0431\u0438\u043B\u0430 \u043A\u0430\u0440\u0442\u044B \u0438 \u0441\u0432\u0435\u0442\u0441\u043A\u0438\u0435
    \u043F\u0440\u0438\u0451\u043C\u044B. *   **\u041D\u0438\u043A\u043E\u043B\u0430\u0439
    \u0418\u0432\u0430\u043D\u043E\u0432\u0438\u0447**, \u043D\u0430\u043F\u0440\u043E\u0442\u0438\u0432,
    \u0431\u044B\u043B \u0441\u043F\u043E\u043A\u043E\u0435\u043D, \u0440\u0430\u0441\u0441\u0443\u0434\u0438\u0442\u0435\u043B\u0435\u043D
    \u0438 \u0443\u0433\u043B\u0443\u0431\u043B\u0451\u043D \u0432 \u0441\u0432\u043E\u0438
    \u043C\u044B\u0441\u043B\u0438. \u041E\u043D \u0445\u043E\u0434\u0438\u043B \u043F\u043E
    \u043A\u043E\u043C\u043D\u0430\u0442\u0435, \u043F\u043E\u043A\u0443\u0440\u0438\u0432\u0430\u044F
    \u0434\u043B\u0438\u043D\u043D\u0443\u044E \u0442\u0440\u0443\u0431\u043A\u0443,
    \u0438 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E \u0432\u044B\u0441\u043B\u0443\u0448\u0438\u0432\u0430\u043B
    \u0432\u044B\u0433\u043E\u0432\u043E\u0440\u044B \u0436\u0435\u043D\u044B, \u0430
    \u0437\u0430\u0442\u0435\u043C \u043D\u0435\u0438\u0437\u043C\u0435\u043D\u043D\u043E
    \u0434\u043E\u0431\u0438\u0432\u0430\u043B\u0441\u044F \u043F\u0440\u0438\u043C\u0438\u0440\u0435\u043D\u0438\u044F,
    \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u043B\u043E \u0438\u0445 \xAB\u043F\u0440\u0438\u043C\u0435\u0440\u043D\u044B\u043C\u0438
    \u0441\u0443\u043F\u0440\u0443\u0433\u0430\u043C\u0438\xBB.  \u0423 \u043D\u0438\u0445
    \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0447\u0435\u0442\u0432\u0435\u0440\u043E
    \u0441\u044B\u043D\u043E\u0432\u0435\u0439 \u0438 \u0434\u0432\u0435 \u0434\u043E\u0447\u0435\u0440\u0438.
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439 \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u043B\u044E\u0431\u0438\u043B \u0434\u0435\u0442\u0435\u0439, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0441\u0442\u0430\u0440\u0448\u0435\u0433\u043E \u0441\u044B\u043D\u0430 \u0410\u043B\u0435\u043A\u0441\u0435\u044F,
    \u0438 \u0441\u0430\u043C \u0443\u0447\u0438\u043B \u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u0421\u0435\u043C\u044C\u044F \u0441\u0442\u0430\u043B\u0430 \u0434\u043B\u044F
    \u043D\u0435\u0433\u043E \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u043C
    \u0438 \u0440\u0430\u0434\u043E\u0441\u0442\u0438, \u0438 \u0442\u044F\u0436\u0451\u043B\u044B\u0445
    \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u0439. \u041E\u043D \u043F\u0435\u0440\u0435\u0436\u0438\u043B
    \u0441\u043C\u0435\u0440\u0442\u044C \u043C\u043B\u0430\u0434\u0448\u0435\u0433\u043E
    \u0441\u044B\u043D\u0430 \u0432 \u0440\u0430\u043D\u043D\u0435\u043C \u0434\u0435\u0442\u0441\u0442\u0432\u0435,
    \u0430 \u0437\u0430\u0442\u0435\u043C, \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B, \u2014 \u0441\u043C\u0435\u0440\u0442\u044C \u0434\u043E\u0447\u0435\u0440\u0438
    \u041D\u0430\u0434\u0435\u0436\u0434\u044B \u0438 \u0441\u0432\u043E\u0435\u0433\u043E
    \u043B\u044E\u0431\u0438\u043C\u0446\u0430 \u0410\u043B\u0435\u043A\u0441\u0435\u044F.
    \u042D\u0442\u0438 \u0443\u0442\u0440\u0430\u0442\u044B \u0441\u0442\u0430\u043B\u0438
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u043F\u0440\u0438\u0447\u0438\u043D
    \u0435\u0433\u043E \u043F\u0440\u0435\u0436\u0434\u0435\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0438 \u0438 \u0443\u0433\u0430\u0441\u0430\u043D\u0438\u044F.
    \u041A 60 \u0433\u043E\u0434\u0430\u043C \u043E\u043D \u043F\u043E\u0447\u0442\u0438
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043E\u0441\u043B\u0435\u043F. 
    \u0422\u0440\u0430\u0433\u0435\u0434\u0438\u0438 \u0441\u043E\u0432\u043F\u0430\u043B\u0438
    \u0441 \u0443\u0445\u043E\u0434\u043E\u043C \u0441 \u043F\u043E\u0441\u0442\u0430
    \u0440\u0435\u043A\u0442\u043E\u0440\u0430 \u0432 1846 \u0433\u043E\u0434\u0443,
    \u0447\u0442\u043E \u043E\u043D \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u044F\u043B
    \u043A\u0430\u043A \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u043E\u0431\u0438\u0434\u0443.
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u043E\u043D \u043F\u0440\u043E\u0432\u0451\u043B
    \u0432 \u0441\u0432\u043E\u0451\u043C \u0438\u043C\u0435\u043D\u0438\u0438 **\u0411\u0435\u043B\u043E\u0432\u043E\u043B\u0436\u0441\u043A\u0430\u044F
    \u0421\u043B\u043E\u0431\u043E\u0434\u043A\u0430**, \u0433\u0434\u0435 \u0441
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435\u043C \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0441\u0435\u043B\u044C\u0441\u043A\u0438\u043C \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u043E\u043C:
    \u0440\u0430\u0437\u0432\u043E\u0434\u0438\u043B \u0441\u0430\u0434\u044B, \u0437\u0430\u0432\u0451\u043B
    \u043C\u0435\u0440\u0438\u043D\u043E\u0441\u043E\u0432, \u0441\u0442\u0440\u043E\u0438\u043B
    \u043C\u0435\u043B\u044C\u043D\u0438\u0446\u044B. \u0423\u0447\u0451\u043D\u044B\u0439,
    \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0439
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u043E \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435,
    \u043D\u0430\u0445\u043E\u0434\u0438\u043B \u0443\u0442\u0435\u0448\u0435\u043D\u0438\u0435
    \u0432 \u0437\u0435\u043C\u043D\u044B\u0445, \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u0435\u043B\u0430\u0445.  ### \u26B0\uFE0F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0434\u043D\u0438 \u0438 \u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u0438\u0435 
    \u041E\u0441\u043B\u0435\u043F\u0448\u0438\u0439, \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0448\u0438\u0439
    \u043F\u043E\u0442\u0435\u0440\u044E \u0431\u043B\u0438\u0437\u043A\u0438\u0445
    \u0438 \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0435\u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435,
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439 \u043D\u0435
    \u0441\u0434\u0430\u0432\u0430\u043B\u0441\u044F. \u0412 1855 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u0440\u043E\u0434\u0438\u043A\u0442\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439
    \u0442\u0440\u0443\u0434 \u2014 **\xAB\u041F\u0430\u043D\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E\xBB**.
    \u041D\u0438\u043A\u043E\u043B\u0430\u0439 \u0418\u0432\u0430\u043D\u043E\u0432\u0438\u0447
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    **12 (24) \u0444\u0435\u0432\u0440\u0430\u043B\u044F 1856 \u0433\u043E\u0434\u0430**
    \u0432 \u041A\u0430\u0437\u0430\u043D\u0438.  *\u041F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438
    \u0435\u0433\u043E \u0441\u0447\u0438\u0442\u0430\u043B\u0438 \u0447\u0443\u0434\u0430\u043A\u043E\u043C,
    \u0430 \u0435\u0433\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u2014 \u043D\u0435\u043B\u0435\u043F\u043E\u0439 \u0444\u0430\u043D\u0442\u0430\u0437\u0438\u0435\u0439.
    \u041B\u0438\u0448\u044C \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u0441\u043F\u0443\u0441\u0442\u044F, \u043A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E
    \u0438\u0434\u0435\u0438 \u043B\u0435\u0433\u043B\u0438 \u0432 \u043E\u0441\u043D\u043E\u0432\u0443
    \u0444\u0438\u0437\u0438\u043A\u0438 XX \u0432\u0435\u043A\u0430 \u0438, \u0432
    \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430, \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u043E
    \u043E\u0441\u043E\u0437\u043D\u0430\u043B\u043E \u043C\u0430\u0441\u0448\u0442\u0430\u0431
    \u044D\u0442\u043E\u0433\u043E \u0433\u0435\u043D\u0438\u044F.*"
  personalLifeEn: 
  shortBioRu: "\u041D\u0438\u043A\u043E\u043B\u0430\u0439 \u0418\u0432\u0430\u043D\u043E\u0432\u0438\u0447
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439 \u2014 \u0444\u0438\u0433\u0443\u0440\u0430
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043D\u0430\u0443\u043A\u0438,
    \u043F\u043E\u0436\u0430\u043B\u0443\u0439, \u043D\u0435 \u043C\u0435\u043D\u0435\u0435
    \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u0430\u044F, \u0447\u0435\u043C
    \u0435\u0433\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F. \u041E\u043D
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 1 \u0434\u0435\u043A\u0430\u0431\u0440\u044F
    1792 \u0433\u043E\u0434\u0430 \u0432 \u041D\u0438\u0436\u043D\u0435\u043C \u041D\u043E\u0432\u0433\u043E\u0440\u043E\u0434\u0435,
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u043C\u0435\u043B\u043A\u043E\u0433\u043E
    \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u0430, \u0438 \u0435\u0433\u043E
    \u043F\u0443\u0442\u044C \u043A \u0432\u0435\u0440\u0448\u0438\u043D\u0430\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0431\u044B\u043B
    \u0442\u0435\u0440\u043D\u0438\u0441\u0442, \u0430 \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043D\u0435 \u043F\u043E\u043D\u044F\u0442\u043E
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438. 
    ### \U0001F3EB \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u0433\u043E\u0434\u044B
    \u0443\u0447\u0435\u0431\u044B: \u043E\u0442 \xAB\u043F\u0440\u0438\u0437\u043D\u0430\u043A\u043E\u0432
    \u0431\u0435\u0437\u0431\u043E\u0436\u0438\u044F\xBB \u0434\u043E \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430 
    \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u0442\u0446\u0430,
    \u041F\u0440\u0430\u0441\u043A\u043E\u0432\u044C\u044F \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u0432\u043D\u0430,
    \u043E\u0441\u0442\u0430\u0432\u0448\u0438\u0441\u044C \u0441 \u0442\u0440\u0435\u043C\u044F
    \u0441\u044B\u043D\u043E\u0432\u044C\u044F\u043C\u0438, \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u041A\u0430\u0437\u0430\u043D\u044C. \u0412 1802 \u0433\u043E\u0434\u0443
    \u043E\u043D\u0430 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0430
    \u0432\u0441\u0435\u0445 \u0442\u0440\u043E\u0438\u0445 \u0432 \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u0443\u044E
    \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u044E \u043D\u0430 \u043A\u0430\u0437\u0435\u043D\u043D\u043E\u0435
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0437\u0434\u0435\u0441\u044C \u0443 \u041D\u0438\u043A\u043E\u043B\u0430\u044F
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0432\u043E
    \u043C\u043D\u043E\u0433\u043E\u043C \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u043E\u043C\u0443 \u0443\u0447\u0438\u0442\u0435\u043B\u044E
    \u0413.\u0418. \u041A\u0430\u0440\u0442\u0430\u0448\u0435\u0432\u0441\u043A\u043E\u043C\u0443. 
    \u0412 1807 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    14 \u043B\u0435\u0442, \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439
    \u0441\u0442\u0430\u043B \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C
    \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0432\u0448\u0435\u0433\u043E\u0441\u044F
    \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430.
    \u0415\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u041C\u0430\u0440\u0442\u0438\u043D \u0411\u0430\u0440\u0442\u0435\u043B\u044C\u0441,
    \u0434\u0440\u0443\u0433 \u0438 \u0443\u0447\u0438\u0442\u0435\u043B\u044C \u041A\u0430\u0440\u043B\u0430
    \u0413\u0430\u0443\u0441\u0441\u0430. \u0411\u0430\u0440\u0442\u0435\u043B\u044C\u0441
    \u043E\u043A\u0430\u0437\u0430\u043B \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043A\u0430\u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430.  \u0421\u0442\u0443\u0434\u0435\u043D\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u0431\u044B\u043B\u0438 \u043F\u043E\u043B\u043D\u044B \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u043E\u0432.
    \u0421 \u043E\u0434\u043D\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B,
    \u043E\u043D \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u0421 \u0434\u0440\u0443\u0433\u043E\u0439 \u2014 \u0435\u0433\u043E \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0432\u044B\u0437\u044B\u0432\u0430\u043B\u043E \u043D\u0430\u0440\u0435\u043A\u0430\u043D\u0438\u044F.
    \u0412 \u0440\u0430\u043F\u043E\u0440\u0442\u0430\u0445 \u0442\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043C\u043E\u0436\u043D\u043E \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u0442\u044C
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0438:
    \xAB\u044E\u043D\u043E\u0448\u0430 \u0443\u043F\u0440\u044F\u043C\u044B\u0439,
    \u043D\u0435\u0440\u0430\u0441\u043A\u0430\u044F\u043D\u043D\u044B\u0439, \u0432\u0435\u0441\u044C\u043C\u0430
    \u043C\u043D\u043E\u0433\u043E \u043E \u0441\u0435\u0431\u0435 \u043C\u0435\u0447\u0442\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439\xBB
    \u0438 \u0434\u0430\u0436\u0435 \xAB\u043F\u0440\u0438\u0437\u043D\u0430\u043A\u0438
    \u0431\u0435\u0437\u0431\u043E\u0436\u0438\u044F\xBB. \u0417\u0430 \u0448\u0430\u043B\u043E\u0441\u0442\u0438
    \u0438 \u0443\u0447\u0430\u0441\u0442\u0438\u0435 \u0432 \u043C\u0430\u0441\u043A\u0430\u0440\u0430\u0434\u0430\u0445
    \u0435\u0433\u043E \u043B\u0438\u0448\u0430\u043B\u0438 \u0437\u0432\u0430\u043D\u0438\u044F
    \u0438 \u043D\u0430\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0438 \u043A\u0430\u0440\u0446\u0435\u0440\u043E\u043C.
    \u041B\u0438\u0448\u044C \u0437\u0430\u0441\u0442\u0443\u043F\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u0432 \u043F\u043E\u043C\u043E\u0433\u043B\u043E
    \u0435\u043C\u0443 \u0438\u0437\u0431\u0435\u0436\u0430\u0442\u044C \u043E\u0442\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F.
    \u0412 1811 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430. 
    ### \U0001F4DA \u041F\u0443\u0442\u044C \u0432 \u043D\u0430\u0443\u043A\u0435
    \u0438 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u043D\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438  \u041D\u0430\u0443\u0447\u043D\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u0432 \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0431\u044B\u043B\u0430 \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439:
    *   **1814 \u0433\u043E\u0434** \u2014 \u0430\u0434\u044A\u044E\u043D\u043A\u0442.
    *   **1816 \u0433\u043E\u0434** \u2014 \u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u0439
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440. *   **1822 \u0433\u043E\u0434**
    \u2014 \u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u0439 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0438 \u0434\u0435\u043A\u0430\u043D \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u044F.  \u0413\u043B\u0430\u0432\u043D\u044B\u043C
    \u0442\u0440\u0443\u0434\u043E\u043C \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438
    \u0441\u0442\u0430\u043B\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.
    \u041A 1826 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0440\u0438\u0448\u0435\u043B
    \u043A \u043F\u0435\u0440\u0435\u0432\u043E\u0440\u043E\u0442\u0443 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435:
    \u043E\u043D \u0437\u0430\u043C\u0435\u043D\u0438\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043F\u044F\u0442\u044B\u0439 \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u043D\u0430 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435,
    \u0447\u0442\u043E \u0447\u0435\u0440\u0435\u0437 \u0442\u043E\u0447\u043A\u0443
    \u0432\u043D\u0435 \u043F\u0440\u044F\u043C\u043E\u0439 \u043C\u043E\u0436\u043D\u043E
    \u043F\u0440\u043E\u0432\u0435\u0441\u0442\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043F\u0440\u044F\u043C\u044B\u0445, \u043D\u0435 \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u044E\u0449\u0438\u0445
    \u0434\u0430\u043D\u043D\u0443\u044E.  **7 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    1826 \u0433\u043E\u0434\u0430** \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u043D\u0430 \u0437\u0430\u0441\u0435\u0434\u0430\u043D\u0438\u0438
    \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C \xAB\u0421\u0436\u0430\u0442\u043E\u0435
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u043D\u0430\u0447\u0430\u043B
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0441\u043E \u0441\u0442\u0440\u043E\u0433\u0438\u043C
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u0445\xBB.
    \u042D\u0442\u0430 \u0434\u0430\u0442\u0430 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u0434\u043D\u0435\u043C \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043D\u0435 \u0431\u044B\u043B\u0430 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430
    \u0438\u0437-\u0437\u0430 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u044F
    \u0436\u0443\u0440\u043D\u0430\u043B\u0430, \u0430 \u0435\u0451 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C
    \u043D\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C.
    \u041F\u0435\u0440\u0432\u0430\u044F \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0430\u0441\u044C \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432 1829\u20131830 \u0433\u043E\u0434\u0430\u0445 \u0432 \xAB\u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u043C
    \u0432\u0435\u0441\u0442\u043D\u0438\u043A\u0435\xBB. \u041E\u043D \u043D\u0430\u0437\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443 **\xAB\u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0430\u0435\u043C\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439\xBB**.  ### \U0001F3DB\uFE0F
    \u0420\u0435\u043A\u0442\u043E\u0440 \u0438 \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430  **\u0412
    1827 \u0433\u043E\u0434\u0443** \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439
    \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u043B \u044D\u0442\u043E\u0442 \u043F\u043E\u0441\u0442
    **19 \u043B\u0435\u0442**. \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0438\u043E\u0434
    \u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0439 \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438.  *  
    **\u0421\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E**:
    \u041F\u043E\u0434 \u0435\u0433\u043E \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0431\u044B\u043B \u0432\u043E\u0437\u0432\u0435\u0434\u0435\u043D \u0446\u0435\u043B\u044B\u0439
    \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441 \u0437\u0434\u0430\u043D\u0438\u0439:
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0430, \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438 \u043C\u0430\u0433\u043D\u0438\u0442\u043D\u0430\u044F \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438,
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u043A\u0430\u0431\u0438\u043D\u0435\u0442,
    \u0445\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u044F,
    \u0430\u043D\u0430\u0442\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0435\u0430\u0442\u0440, \u043A\u043B\u0438\u043D\u0438\u043A\u0430. *  
    **\u0418\u0437\u0434\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0430\u044F \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C**:
    \u0412 1834 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \xAB\u0423\u0447\u0435\u043D\u044B\u0435 \u0437\u0430\u043F\u0438\u0441\u043A\u0438
    \u041A\u0430\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\xBB.
    *   **\u0420\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0432\u043E\u0441\u0442\u043E\u043A\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F**:
    \u041E\u043D \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044E \u043A\u0430\u0444\u0435\u0434\u0440
    \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0445 \u044F\u0437\u044B\u043A\u043E\u0432
    \u0438 \u043F\u0435\u0447\u0430\u0442\u0430\u043D\u0438\u044E \u043A\u043D\u0438\u0433
    \u0441 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0445 \u0448\u0440\u0438\u0444\u0442\u043E\u0432.
    *   **\u0421\u0442\u0438\u0445\u0438\u0439\u043D\u044B\u0435 \u0431\u0435\u0434\u0441\u0442\u0432\u0438\u044F**:
    \u0415\u0433\u043E \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u0439
    \u0442\u0430\u043B\u0430\u043D\u0442 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u0438
    \u0445\u043E\u043B\u0435\u0440\u044B \u0432 1830 \u0433\u043E\u0434\u0443 \u0438
    \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u043E\u0436\u0430\u0440\u0430 \u0432 \u041A\u0430\u0437\u0430\u043D\u0438
    \u0432 1842 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u043E\u043D
    \u0441\u043F\u0430\u0441 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u043E\u0442 \u0431\u043E\u043B\u044C\u0448\u0438\u0445 \u043F\u043E\u0442\u0435\u0440\u044C. 
    ### \U0001F614 \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B:
    \u043D\u0435\u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438 \u0443\u0442\u0440\u0430\u0442\u044B 
    \u0413\u043B\u0430\u0432\u043D\u0430\u044F \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0430\u0441\u044C
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043D\u0435 \u0431\u044B\u043B\u043E
    \u043F\u043E\u043D\u044F\u0442\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438. 
    *   **\u041D\u0435\u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435**: \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430 \xAB\u041E \u043D\u0430\u0447\u0430\u043B\u0430\u0445
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB, \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u043D\u0430\u044F
    \u0432 1832 \u0433\u043E\u0434\u0443 \u0432 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u044E
    \u043D\u0430\u0443\u043A, \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 \u0440\u0435\u0437\u043A\u043E
    \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u043E\u0442\u0437\u044B\u0432 \u043E\u0442 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u0430
    \u041C.\u0412. \u041E\u0441\u0442\u0440\u043E\u0433\u0440\u0430\u0434\u0441\u043A\u043E\u0433\u043E.
    \u0412 \u0440\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u0441\u0441\u0435
    \u0432\u044B\u0445\u043E\u0434\u0438\u043B\u0438 \u0438\u0437\u0434\u0435\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0435
    \u0441\u0442\u0430\u0442\u044C\u0438. \u041B\u0438\u0448\u044C \u043E\u0434\u0438\u043D
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u2014 \u041A\u0430\u0440\u043B \u0424\u0440\u0438\u0434\u0440\u0438\u0445
    \u0413\u0430\u0443\u0441\u0441, \u0442\u0430\u043A\u0436\u0435 \u0432\u043B\u0430\u0434\u0435\u0432\u0448\u0438\u0439
    \u043D\u0430\u0447\u0430\u043B\u0430\u043C\u0438 \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u043D\u043E \u043F\u043E\u0431\u043E\u044F\u0432\u0448\u0438\u0439\u0441\u044F
    \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C \u0438\u0445,
    \u2014 \u043F\u043E \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u0443
    \u043E\u0446\u0435\u043D\u0438\u043B \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u044B.
    \u041F\u043E \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044E
    \u0413\u0430\u0443\u0441\u0441\u0430 \u0432 1842 \u0433\u043E\u0434\u0443 \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439
    \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430. 
    *   **\u041E\u0442\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u0435**: \u0412
    1846 \u0433\u043E\u0434\u0443 \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E,
    \u0432\u043E\u043F\u0440\u0435\u043A\u0438 \u0435\u0433\u043E \u043E\u0436\u0438\u0434\u0430\u043D\u0438\u044F\u043C,
    \u043E\u0442\u0441\u0442\u0440\u0430\u043D\u0438\u043B\u0438 \u043E\u0442 \u0440\u0435\u043A\u0442\u043E\u0440\u0441\u0442\u0432\u0430
    \u0438 \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u043B\u0438 \u043E\u0442
    \u043A\u0430\u0444\u0435\u0434\u0440\u044B. \u0424\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E
    \u043E\u043D \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u043E\u043C \u043F\u043E\u043F\u0435\u0447\u0438\u0442\u0435\u043B\u044F
    \u0443\u0447\u0435\u0431\u043D\u043E\u0433\u043E \u043E\u043A\u0440\u0443\u0433\u0430,
    \u043D\u043E \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u044D\u0442\u043E
    \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E \u043F\u043E\u0447\u0435\u0442\u043D\u0443\u044E
    \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0443.  *   **\u0423\u0433\u0430\u0441\u0430\u043D\u0438\u0435**:
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u0431\u044B\u043B\u0438 \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u044B
    \u0443\u0445\u0443\u0434\u0448\u0435\u043D\u0438\u0435\u043C \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F,
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u044F\u043C\u0438 \u0438 \u0441\u043C\u0435\u0440\u0442\u044C\u044E
    \u0441\u0442\u0430\u0440\u0448\u0435\u0433\u043E \u0441\u044B\u043D\u0430 \u0432
    1852 \u0433\u043E\u0434\u0443. \u041F\u043E\u0447\u0442\u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043E\u0441\u043B\u0435\u043F\u043D\u0443\u0432, \u043E\u043D \u0434\u0438\u043A\u0442\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439
    \u0442\u0440\u0443\u0434 \u2014 **\xAB\u041F\u0430\u043D\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E\xBB**,
    \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u044B\u0439 \u0432 1855
    \u0433\u043E\u0434\u0443.  \u041D\u0438\u043A\u043E\u043B\u0430\u0439 \u0418\u0432\u0430\u043D\u043E\u0432\u0438\u0447
    \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u0438\u0439 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    **24 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 1856 \u0433\u043E\u0434\u0430**
    \u0432 \u041A\u0430\u0437\u0430\u043D\u0438, \u0442\u0430\u043A \u0438 \u043D\u0435
    \u0434\u043E\u0436\u0434\u0430\u0432\u0448\u0438\u0441\u044C \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438. \u0421\u043B\u0430\u0432\u0430
    \u043F\u0440\u0438\u0448\u043B\u0430 \u043A \u043D\u0435\u043C\u0443 \u043B\u0438\u0448\u044C
    \u0441\u043F\u0443\u0441\u0442\u044F \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F,
    \u043A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E \u0438\u0434\u0435\u0438 \u043B\u0435\u0433\u043B\u0438
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u043D\u043E\u0432\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0435\u043E\u0440\u0438\u0439 \u0438 \u0434\u0430\u0436\u0435 \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0438
    \u043D\u0430 \u0444\u0438\u0437\u0438\u043A\u0443, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u043D\u0430 \u0442\u0435\u043E\u0440\u0438\u044E \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430. \u0410\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0423\u0438\u043B\u044C\u044F\u043C
    \u041A\u043B\u0438\u0444\u0444\u043E\u0440\u0434 \u043D\u0430\u0437\u0432\u0430\u043B
