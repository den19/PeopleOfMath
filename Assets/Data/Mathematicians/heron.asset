  achievementsRu: "\u0415\u0441\u043B\u0438 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u0413\u0435\u0440\u043E\u043D\u0430 \u2014 \u044D\u0442\u043E \xAB\u0431\u0435\u043B\u043E\u0435
    \u043F\u044F\u0442\u043D\u043E\xBB \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438,
    \u0442\u043E \u0435\u0433\u043E **\u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u0438 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435**
    \u2014 \u044D\u0442\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0441\u0442\u0440\u043E\u0438\u043B\u0430\u0441\u044C \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0432\u043F\u043B\u043E\u0442\u044C
    \u0434\u043E \u044D\u043F\u043E\u0445\u0438 \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F.  
    \u0427\u0442\u043E\u0431\u044B \u043F\u043E\u043D\u044F\u0442\u044C \u043C\u0430\u0441\u0448\u0442\u0430\u0431
    \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u044F, \u043D\u0443\u0436\u043D\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043D\u0430 \u0447\u0435\u0442\u044B\u0440\u0435 \u0433\u043B\u043E\u0431\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u0444\u0435\u0440\u044B: **\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430**,
    **\u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430 \u0438 \u0441\u0442\u0430\u0442\u0438\u043A\u0430**,
    **\u0433\u0438\u0434\u0440\u043E- \u0438 \u043F\u043D\u0435\u0432\u043C\u043E\u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u043A\u0430**
    \u0438 **\u0433\u0435\u043E\u0434\u0435\u0437\u0438\u044F (\u043E\u043F\u0442\u0438\u043A\u0430)**.  
    \u041D\u0438\u0436\u0435 \u2014 \u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u043E
    \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u044B\u0439 \u0440\u0430\u0437\u0431\u043E\u0440
    \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434\u0430 \u0432 \u043A\u0430\u0436\u0434\u0443\u044E
    \u0438\u0437 \u044D\u0442\u0438\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439. 
    ---  ### 1. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430: \u041E\u0442
    \xAB\u041C\u0435\u0442\u0440\u0438\u043A\u0438\xBB \u0434\u043E \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432  \u0413\u0435\u0440\u043E\u043D
    \u043D\u0435 \u0431\u044B\u043B \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A\u043E\u043C
    \u0432\u0440\u043E\u0434\u0435 \u0415\u0432\u043A\u043B\u0438\u0434\u0430. \u0415\u0433\u043E
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0430 **\u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u0430\u044F,
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430**, \u043D\u0443\u0436\u043D\u0430\u044F
    \u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u043E\u0440\u0430\u043C, \u0437\u0435\u043C\u043B\u0435\u043C\u0435\u0440\u0430\u043C
    \u0438 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430\u043C.  *   **\u0424\u043E\u0440\u043C\u0443\u043B\u0430
    \u0413\u0435\u0440\u043E\u043D\u0430 (\u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435):** \u0412 \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435
    \xAB\u041C\u0435\u0442\u0440\u0438\u043A\u0430\xBB \u043E\u043D \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u0442
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0434\u043B\u044F \u043F\u043B\u043E\u0449\u0430\u0434\u0438
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430 \u043F\u043E
    \u0442\u0440\u0435\u043C \u0441\u0442\u043E\u0440\u043E\u043D\u0430\u043C:     
    \\( S = \\sqrt{p(p-a)(p-b)(p-c)} \\), \u0433\u0434\u0435 \\( p \\) \u2014 \u043F\u043E\u043B\u0443\u043F\u0435\u0440\u0438\u043C\u0435\u0442\u0440.     
    \u0412\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0439 \u043D\u044E\u0430\u043D\u0441:
    \u0413\u0435\u0440\u043E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0434\u0430\u043B \u0444\u043E\u0440\u043C\u0443\u043B\u0443, \u043E\u043D \u043F\u0440\u0438\u0432\u0435\u043B
    **\u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E**,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430
    \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0439 \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u0438.
    \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u0437\u043D\u0430\u044E\u0442,
    \u0447\u0442\u043E \u044D\u0442\u0443 \u0444\u043E\u0440\u043C\u0443\u043B\u0443
    \u0437\u043D\u0430\u043B \u0435\u0449\u0435 \u0410\u0440\u0445\u0438\u043C\u0435\u0434,
    \u043D\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u0413\u0435\u0440\u043E\u043D
    \u0437\u0430\u043F\u0438\u0441\u0430\u043B \u0435\u0435 \u0432 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u043C
    \u0432\u0438\u0434\u0435 \u0438 \u0432\u0432\u0435\u043B \u0432 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u0443\u044E
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0443. *   **\u0410\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    \u0438\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F \u043A\u043E\u0440\u043D\u0435\u0439
    (\u0418\u0442\u0435\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439 \u043C\u0435\u0442\u043E\u0434
    \u0413\u0435\u0440\u043E\u043D\u0430):** \u0412 \u0442\u043E\u0439 \u0436\u0435
    \xAB\u041C\u0435\u0442\u0440\u0438\u043A\u0435\xBB \u043E\u043D \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442,
    \u043A\u0430\u043A \u0431\u044B\u0441\u0442\u0440\u043E \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0439 \u0438 \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043A\u043E\u0440\u0435\u043D\u044C. \u0414\u043B\u044F \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u043E\u0433\u043E
    \u043A\u043E\u0440\u043D\u044F \u0438\u0437 \u0447\u0438\u0441\u043B\u0430 \\(
    A \\) \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u043B \u0431\u0440\u0430\u0442\u044C
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u0435 \\( a \\)
    \u0438 \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u0442\u044C \u043D\u043E\u0432\u043E\u0435
    \\( x = \\frac{a + A/a}{2} \\). \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u0439
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u0437\u0430\u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0439 \u043C\u0435\u0442\u043E\u0434,
    \u0441\u0445\u043E\u0434\u044F\u0449\u0438\u0439\u0441\u044F \u043A \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0443
    \u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E
    (\u043F\u043E \u0441\u0443\u0442\u0438, \u043C\u0435\u0442\u043E\u0434 \u041D\u044C\u044E\u0442\u043E\u043D\u0430,
    \u043D\u043E \u043D\u0430 16 \u0432\u0435\u043A\u043E\u0432 \u0440\u0430\u043D\u044C\u0448\u0435).
    *   **\u0420\u0435\u0448\u0435\u043D\u0438\u0435 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439:** \u0413\u0435\u0440\u043E\u043D
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0432\u0438\u0434\u0430 \\( x^2 + 2bx = c \\). \u041E\u043D \u043D\u0435 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u043C\u0438 \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u043C\u0438,
    \u0430 \u0434\u0430\u0432\u0430\u043B \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0438\u043D\u0442\u0435\u0440\u043F\u0440\u0435\u0442\u0430\u0446\u0438\u044E
    (\u0434\u043E\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u044F \u0444\u0438\u0433\u0443\u0440\u0443
    \u0434\u043E \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430), \u043D\u043E
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0438\u0447\u0435\u0441\u043A\u0438
    \u044D\u0442\u043E \u0431\u044B\u043B\u0438 \u0442\u043E\u0447\u043D\u044B\u0435
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B. *   **\u0412\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435
    \u043F\u043B\u043E\u0449\u0430\u0434\u0435\u0439 \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0444\u0438\u0433\u0443\u0440:** \u041E\u043D \u0434\u0430\u043B \u043F\u0440\u0430\u0432\u0438\u043B\u0430
    \u0434\u043B\u044F \u0440\u0430\u0441\u0447\u0435\u0442\u0430 \u043F\u043B\u043E\u0449\u0430\u0434\u0438
    \u0441\u0435\u0433\u043C\u0435\u043D\u0442\u043E\u0432 \u043A\u0440\u0443\u0433\u0430,
    \u044D\u043B\u043B\u0438\u043F\u0441\u043E\u0432 (\u043F\u0440\u0430\u0432\u0434\u0430,
    \u0441 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u043F\u043E\u0433\u0440\u0435\u0448\u043D\u043E\u0441\u0442\u044C\u044E,
    \u0442\u0430\u043A \u043A\u0430\u043A \u043E\u043D \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u0435\u043C \\(
    \\pi \\approx 22/7 \\)) \u0438 \u043D\u0435\u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432,
    \u0440\u0430\u0437\u0431\u0438\u0432\u0430\u044F \u0438\u0445 \u043D\u0430 \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0438. 
    ---  ### 2. \u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430 \u0438 \u0421\u0442\u0430\u0442\u0438\u043A\u0430:
    \xAB\u0417\u043E\u043B\u043E\u0442\u043E\u0435 \u043F\u0440\u0430\u0432\u0438\u043B\u043E\xBB
    \u0438 \u0442\u0435\u043E\u0440\u0438\u044F \u043F\u0440\u043E\u0441\u0442\u044B\u0445
    \u043C\u0430\u0448\u0438\u043D  \u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0440\u0443\u0434 \u0413\u0435\u0440\u043E\u043D\u0430 \u2014 \u0442\u0440\u0430\u043A\u0442\u0430\u0442
    \xAB\u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430\xBB (\u0434\u043E\u0448\u0435\u0434\u0448\u0438\u0439
    \u0434\u043E \u043D\u0430\u0441 \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C
    \u0432 \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0445 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0430\u0445).
    \u0417\u0434\u0435\u0441\u044C \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439 \u043F\u0440\u043E\u0440\u044B\u0432
    \u0432 \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441\u0438\u043B.  *   **\u041A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044F
    \u043F\u044F\u0442\u0438 \u043F\u0440\u043E\u0441\u0442\u0435\u0439\u0448\u0438\u0445
    \u043C\u0430\u0448\u0438\u043D:** \u0413\u0435\u0440\u043E\u043D \u043F\u0435\u0440\u0432\u044B\u043C
    \u0447\u0435\u0442\u043A\u043E \u0432\u044B\u0434\u0435\u043B\u0438\u043B \u0438
    \u043E\u043F\u0438\u0441\u0430\u043B \u043F\u044F\u0442\u044C \u0431\u0430\u0437\u043E\u0432\u044B\u0445
    \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432:
    **\u0440\u044B\u0447\u0430\u0433, \u0432\u043E\u0440\u043E\u0442 (\u043B\u0435\u0431\u0435\u0434\u043A\u0430),
    \u043A\u043B\u0438\u043D, \u0432\u0438\u043D\u0442 \u0438 \u0431\u043B\u043E\u043A**.
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0432\u0441\u0435
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u043C\u0430\u0448\u0438\u043D\u044B
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043A\u0430\u0442\u0430\u043F\u0443\u043B\u044C\u0442\u044B
    \u0438\u043B\u0438 \u043A\u0440\u0430\u043D\u044B) \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0446\u0438\u0435\u0439 \u044D\u0442\u0438\u0445
    \u043F\u044F\u0442\u0438 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432.
    *   **\u0417\u043E\u043B\u043E\u0442\u043E\u0435 \u043F\u0440\u0430\u0432\u0438\u043B\u043E
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438:** \u041E\u043D \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043B, \u0447\u0442\u043E \u043F\u0440\u0438
    \u0440\u0430\u0431\u043E\u0442\u0435 \u043B\u044E\u0431\u043E\u0433\u043E \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u0430
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0441\u0438\u043B\u044B
    \u043D\u0430 \u0435\u0435 \u043F\u043B\u0435\u0447\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E\u0439 \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u043E\u0439.
    \u041E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E \u0442\u0430\u043A: *\xAB\u0414\u0430\u043D\u043D\u044B\u0439
    \u0433\u0440\u0443\u0437 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C
    \u043F\u0435\u0440\u0435\u0434\u0432\u0438\u043D\u0443\u0442 \u0434\u0430\u043D\u043D\u043E\u0439
    \u0441\u0438\u043B\u043E\u0439, \u0435\u0441\u043B\u0438 \u0441\u0438\u043B\u0430
    \u0441\u0442\u043E\u0438\u0442 \u043A \u0433\u0440\u0443\u0437\u0443 \u0432 \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u043C
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0438 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0439,
    \u043F\u0440\u043E\u0439\u0434\u0435\u043D\u043D\u044B\u0445 \u0438\u043C\u0438\xBB*.
    \u0424\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438, \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0432\u044B\u0438\u0433\u0440\u044B\u0448 \u0432 \u0441\u0438\u043B\u0435
    \u043D\u0435\u0438\u0437\u0431\u0435\u0436\u043D\u043E \u0432\u0435\u0434\u0435\u0442
    \u043A \u043F\u0440\u043E\u0438\u0433\u0440\u044B\u0448\u0443 \u0432 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438
    (\u0438\u043B\u0438 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0438).
    *   **\u0426\u0435\u043D\u0442\u0440 \u0442\u044F\u0436\u0435\u0441\u0442\u0438:**
    \u0420\u0430\u0437\u0432\u0438\u0432\u0430\u044F \u0438\u0434\u0435\u0438 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430,
    \u0413\u0435\u0440\u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434\u044B \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0446\u0435\u043D\u0442\u0440\u0430 \u0442\u044F\u0436\u0435\u0441\u0442\u0438
    \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u043F\u043B\u043E\u0441\u043A\u0438\u0445
    \u0444\u0438\u0433\u0443\u0440 \u0438 \u0442\u0435\u043B, \u0447\u0442\u043E
    \u0431\u044B\u043B\u043E \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u0430\u0436\u043D\u043E \u0434\u043B\u044F \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u044B\u0445 \u043F\u043E\u0434\u044A\u0435\u043C\u043D\u044B\u0445
    \u043A\u0440\u0430\u043D\u043E\u0432.  ---  ### 3. \u0413\u0438\u0434\u0440\u043E-
    \u0438 \u041F\u043D\u0435\u0432\u043C\u043E\u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u043A\u0430
    (\u0412\u043A\u043B\u0430\u0434 \u0432 \u044D\u043D\u0435\u0440\u0433\u0435\u0442\u0438\u043A\u0443) 
    \u0422\u0440\u0430\u043A\u0442\u0430\u0442 **\xAB\u041F\u043D\u0435\u0432\u043C\u0430\u0442\u0438\u043A\u0430\xBB**
    \u2014 \u044D\u0442\u043E \u0441\u0430\u043C\u0430\u044F \u0444\u0430\u043D\u0442\u0430\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0447\u0430\u0441\u0442\u044C \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044F
    \u0413\u0435\u0440\u043E\u043D\u0430. \u0417\u0434\u0435\u0441\u044C \u043E\u043D
    \u043D\u0430 \u0441\u043E\u0442\u043D\u0438 \u043B\u0435\u0442 \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u043E \u0432
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0442\u0435\u043F\u043B\u043E\u0432\u043E\u0439 \u044D\u043D\u0435\u0440\u0433\u0438\u0438
    \u0432 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E. 
    *   **\u042D\u043E\u043B\u0438\u043F\u0438\u043B (\u041F\u0435\u0440\u0432\u044B\u0439
    \u043F\u0430\u0440\u043E\u0432\u043E\u0439 \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u044C):**
    \u042D\u0442\u043E \u043C\u0435\u0434\u043D\u044B\u0439 \u0433\u0435\u0440\u043C\u0435\u0442\u0438\u0447\u043D\u044B\u0439
    \u0448\u0430\u0440 \u043D\u0430 \u043E\u0441\u0438, \u0441 \u0434\u0432\u0443\u043C\u044F
    \u0438\u0437\u043E\u0433\u043D\u0443\u0442\u044B\u043C\u0438 \u043F\u0430\u0442\u0440\u0443\u0431\u043A\u0430\u043C\u0438.
    \u041F\u0440\u0438 \u043D\u0430\u0433\u0440\u0435\u0432\u0430\u043D\u0438\u0438
    \u0432\u043E\u0434\u044B \u0432 \u043D\u0438\u0436\u043D\u0435\u043C \u043A\u043E\u0442\u043B\u0435
    \u043F\u0430\u0440 \u043F\u043E\u0441\u0442\u0443\u043F\u0430\u043B \u0432 \u0448\u0430\u0440
    \u0438 \u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E
    \u0432\u044B\u0440\u044B\u0432\u0430\u043B\u0441\u044F \u0438\u0437 \u043F\u0430\u0442\u0440\u0443\u0431\u043A\u043E\u0432.
    \u0420\u0435\u0430\u043A\u0442\u0438\u0432\u043D\u0430\u044F \u0441\u0438\u043B\u0430
    \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0430 \u0448\u0430\u0440
    \u0432\u0440\u0430\u0449\u0430\u0442\u044C\u0441\u044F \u0441\u043E \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E
    \u0434\u043E 1500\u20133500 \u043E\u0431/\u043C\u0438\u043D. **\u0412\u043A\u043B\u0430\u0434
    \u0432 \u043D\u0430\u0443\u043A\u0443:** \u0413\u0435\u0440\u043E\u043D \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0442\u0435\u043F\u043B\u043E\u0432\u0430\u044F
    \u044D\u043D\u0435\u0440\u0433\u0438\u044F (\u043F\u0430\u0440) \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0430
    \u0432 \u043A\u0438\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u044D\u043D\u0435\u0440\u0433\u0438\u044E \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F.
    \u041E\u043D \u043E\u043F\u0438\u0441\u0430\u043B \u0437\u0430\u043A\u043E\u043D
    \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u044F \u0438\u043C\u043F\u0443\u043B\u044C\u0441\u0430
    \u0434\u043B\u044F \u0440\u0435\u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0437\u0430 1800 \u043B\u0435\u0442
    \u0434\u043E \u0426\u0438\u043E\u043B\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E.
    *   **\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    (\u0421\u0436\u0430\u0442\u044B\u0439 \u0432\u043E\u0437\u0434\u0443\u0445):**
    \u0413\u0435\u0440\u043E\u043D \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043D\u0430\u043A\u0430\u0447\u0438\u0432\u0430\u043B\u043E
    \u0432\u043E\u0437\u0434\u0443\u0445 \u0432 \u0433\u0435\u0440\u043C\u0435\u0442\u0438\u0447\u043D\u044B\u0439
    \u0441\u043E\u0441\u0443\u0434. \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u044D\u0442\u0443 \u044D\u043D\u0435\u0440\u0433\u0438\u044E, \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B:    
    *   **\u0424\u043E\u043D\u0442\u0430\u043D \u0413\u0435\u0440\u043E\u043D\u0430:**
    \u0412\u043E\u0434\u0430 \u0432\u044B\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u0432\u0432\u0435\u0440\u0445 \u0431\u0435\u0437 \u043D\u0430\u0441\u043E\u0441\u0430
    \u2014 \u0437\u0430 \u0441\u0447\u0435\u0442 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0432\u044B\u0442\u0435\u0441\u043D\u044F\u0435\u043C\u043E\u0433\u043E \u0441\u0436\u0430\u0442\u043E\u0433\u043E
    \u0432\u043E\u0437\u0434\u0443\u0445\u0430 \u0438\u0437 \u0432\u0435\u0440\u0445\u043D\u0435\u0433\u043E
    \u0441\u043E\u0441\u0443\u0434\u0430. \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437
    \u0433\u0438\u0434\u0440\u043E\u0430\u043A\u043A\u0443\u043C\u0443\u043B\u044F\u0442\u043E\u0440\u0430.    
    *   **\u0410\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u0432\u0435\u0440\u0438 \u0445\u0440\u0430\u043C\u0430:** \u041F\u0440\u0438
    \u0432\u043E\u0437\u0436\u0438\u0433\u0430\u043D\u0438\u0438 \u043E\u0433\u043D\u044F
    \u043D\u0430 \u0430\u043B\u0442\u0430\u0440\u0435 \u0432\u043E\u0437\u0434\u0443\u0445
    \u0432 \u043C\u0435\u0434\u043D\u043E\u043C \u0448\u0430\u0440\u0435 \u043F\u043E\u0434
    \u0430\u043B\u0442\u0430\u0440\u0435\u043C \u043D\u0430\u0433\u0440\u0435\u0432\u0430\u043B\u0441\u044F,
    \u0440\u0430\u0441\u0448\u0438\u0440\u044F\u043B\u0441\u044F \u0438 \u0432\u044B\u0442\u0435\u0441\u043D\u044F\u043B
    \u0432\u043E\u0434\u0443 \u0432 \u0432\u0435\u0434\u0440\u0430, \u043F\u043E\u0434\u0432\u0435\u0448\u0435\u043D\u043D\u044B\u0435
    \u043D\u0430 \u0446\u0435\u043F\u044F\u0445. \u0412\u0435\u0434\u0440\u0430 \u043F\u0435\u0440\u0435\u0432\u0435\u0448\u0438\u0432\u0430\u043B\u0438
    \u0433\u0440\u0443\u0437, \u0438 \u0434\u0432\u0435\u0440\u0438 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u043B\u0438\u0441\u044C.
    \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u0439 \u0432
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438 **\u0442\u0435\u0440\u043C\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0440\u0438\u0432\u043E\u0434**. *   **\u0421\u0438\u0444\u043E\u043D
    \u0438 \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430 \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0435\u0439:**
    \u0413\u0435\u0440\u043E\u043D \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u043E
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u043F\u0440\u0438\u043D\u0446\u0438\u043F
    \u0441\u043E\u043E\u0431\u0449\u0430\u044E\u0449\u0438\u0445\u0441\u044F \u0441\u043E\u0441\u0443\u0434\u043E\u0432
    \u0438 \u0441\u043E\u0437\u0434\u0430\u043B \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C
    \u0434\u043B\u044F \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0435\u043B\u0438\u0432\u0430\u043D\u0438\u044F \u0432\u0438\u043D\u0430
    \u0438 \u0432\u043E\u0434\u044B \u0432 \u0437\u0430\u0434\u0430\u043D\u043D\u044B\u0445
    \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u044F\u0445 (\u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437
    \u0434\u043E\u0437\u0430\u0442\u043E\u0440\u0430), \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u0443\u044E \u0447\u0430\u0448\u0443
    (\u043F\u0438\u0444\u0430\u0433\u043E\u0440\u0435\u0439\u0441\u043A\u0430\u044F
    \u0447\u0430\u0448\u0430), \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043E\u043F\u043E\u0440\u043E\u0436\u043D\u044F\u0435\u0442\u0441\u044F,
    \u0435\u0441\u043B\u0438 \u043D\u0430\u043B\u0438\u0442\u044C \u0431\u043E\u043B\u044C\u0448\u0435
    \u0434\u043E\u043F\u0443\u0441\u0442\u0438\u043C\u043E\u0433\u043E \u0443\u0440\u043E\u0432\u043D\u044F
    \u2014 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u044D\u0444\u0444\u0435\u043A\u0442
    \u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430.  ---  ### 4. \u0413\u0435\u043E\u0434\u0435\u0437\u0438\u044F,
    \u043E\u043F\u0442\u0438\u043A\u0430 \u0438 \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043F\u0440\u0438\u0431\u043E\u0440\u044B  \u0417\u0434\u0435\u0441\u044C \u0413\u0435\u0440\u043E\u043D
    \u0432\u044B\u0441\u0442\u0443\u043F\u0438\u043B \u043A\u0430\u043A \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C
    \u0442\u043E\u0447\u043D\u044B\u0445 \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432, \u0431\u0435\u0437
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E
    \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u043D\u043D\u0435\u043B\u0435\u0439, \u0434\u043E\u0440\u043E\u0433
    \u0438 \u0430\u043A\u0432\u0435\u0434\u0443\u043A\u043E\u0432.  *   **\u0414\u0438\u043E\u043F\u0442\u0440
    (\u041E\u0442\u0435\u0446 \u0442\u0435\u043E\u0434\u043E\u043B\u0438\u0442\u0430):**
    \u0412 \u0442\u0440\u0443\u0434\u0435 \xAB\u041E \u0434\u0438\u043E\u043F\u0442\u0440\u0435\xBB
    \u0413\u0435\u0440\u043E\u043D \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442
    \u043F\u0440\u0438\u0431\u043E\u0440 \u0441 \u0437\u0443\u0431\u0447\u0430\u0442\u043E\u0439
    \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0435\u0439 \u0438 \u0432\u0438\u0437\u0438\u0440\u043D\u044B\u043C
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B \u0441 \u0432\u044B\u0441\u043E\u043A\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E \u0438\u0437\u043C\u0435\u0440\u044F\u0442\u044C
    \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438 \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0433\u043B\u044B. **\u0412\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434:** \u041E\u043D \u043F\u0440\u0438\u043B\u043E\u0436\u0438\u043B
    \u043A \u0434\u0438\u043E\u043F\u0442\u0440\u0443 \u043C\u0435\u0442\u043E\u0434\u0438\u043A\u0443
    \u0437\u0435\u043C\u0435\u043B\u044C\u043D\u043E\u0439 \u0441\u044A\u0435\u043C\u043A\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E \u0441\u0443\u0442\u0438
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0432\u0432\u0435\u0434\u0435\u043D\u0438\u0435\u043C
    **\u043F\u0440\u044F\u043C\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442**.
    \u041E\u043D \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B, \u043A\u0430\u043A,
    \u043E\u0442\u043C\u0435\u0440\u044F\u044F \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    \u043F\u043E \u0434\u0432\u0443\u043C \u043F\u0435\u0440\u043F\u0435\u043D\u0434\u0438\u043A\u0443\u043B\u044F\u0440\u043D\u044B\u043C
    \u043E\u0441\u044F\u043C, \u043C\u043E\u0436\u043D\u043E \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0442\u043E\u0447\u043D\u044B\u0439 \u043F\u043B\u0430\u043D \u043C\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u043D\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u044F\u0441\u044C \u0441\u043B\u043E\u0436\u043D\u043E\u0439
    \u0442\u0440\u0438\u0430\u043D\u0433\u0443\u043B\u044F\u0446\u0438\u0435\u0439.
    *   **\u041E\u0434\u043E\u043C\u0435\u0442\u0440 (\u0421\u0447\u0435\u0442\u0447\u0438\u043A
    \u043A\u0438\u043B\u043E\u043C\u0435\u0442\u0440\u043E\u0432):** \u0423\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E
    \u0432 \u0432\u0438\u0434\u0435 \u0442\u0435\u043B\u0435\u0436\u043A\u0438 \u0441
    \u043A\u043E\u043B\u0435\u0441\u0430\u043C\u0438. \u041A\u0430\u0436\u0434\u043E\u0435
    \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u043A\u043E\u043B\u0435\u0441\u0430
    \u0447\u0435\u0440\u0435\u0437 \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0448\u0435\u0441\u0442\u0435\u0440\u0435\u043D
    \u0441\u0434\u0432\u0438\u0433\u0430\u043B\u043E \u0441\u0442\u0440\u0435\u043B\u043A\u0443
    \u043D\u0430 \u0446\u0438\u0444\u0435\u0440\u0431\u043B\u0430\u0442\u0435. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u043D \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u043B \u043F\u0435\u0440\u0435\u0434\u0430\u0442\u043E\u0447\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430 \u0448\u0435\u0441\u0442\u0435\u0440\u0435\u043D
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435
    1 \u043A 100 \u0438\u043B\u0438 1 \u043A 1000) \u0442\u0430\u043A, \u0447\u0442\u043E
    \u043A\u0430\u0436\u0434\u044B\u0439 \u043F\u0440\u043E\u0439\u0434\u0435\u043D\u043D\u044B\u0439
    \u0441\u0442\u0430\u0434\u0438\u0439 (185 \u043C) \u043E\u0442\u043C\u0435\u0447\u0430\u043B\u0441\u044F
    \u043F\u0430\u0434\u0435\u043D\u0438\u0435\u043C \u043A\u0430\u043C\u0435\u0448\u043A\u0430
    \u0432 \u0447\u0430\u0448\u0443. \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u0439
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C \u043D\u0430
    \u043E\u0441\u043D\u043E\u0432\u0435 \u0437\u0443\u0431\u0447\u0430\u0442\u044B\u0445
    \u043A\u043E\u043B\u0435\u0441. *   **\u0417\u0430\u043A\u043E\u043D \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044F
    \u0441\u0432\u0435\u0442\u0430 (\u041A\u0430\u0442\u043E\u043F\u0442\u0440\u0438\u043A\u0430):**
    \u0413\u0435\u0440\u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \u043F\u0440\u0438 \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u0438 \u0441\u0432\u0435\u0442\u0430
    \u043E\u0442 \u043F\u043B\u043E\u0441\u043A\u043E\u0433\u043E \u0437\u0435\u0440\u043A\u0430\u043B\u0430
    \u0443\u0433\u043E\u043B \u043F\u0430\u0434\u0435\u043D\u0438\u044F \u0440\u0430\u0432\u0435\u043D
    \u0443\u0433\u043B\u0443 \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044F.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0432 \u0434\u0440\u0443\u0433\u043E\u043C: \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u044D\u0442\u043E, \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u0432 **\u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F**. \u041E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0440\u043E\u0434\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442
    *\xAB\u043A\u0440\u0430\u0442\u0447\u0430\u0439\u0448\u0438\u043C \u043F\u0443\u0442\u0435\u043C\xBB*;
    \u0441\u0432\u0435\u0442 \u0438\u0434\u0435\u0442 \u0438\u0437 \u0442\u043E\u0447\u043A\u0438
    A \u0432 \u0442\u043E\u0447\u043A\u0443 B \u0447\u0435\u0440\u0435\u0437 \u0437\u0435\u0440\u043A\u0430\u043B\u043E
    \u0442\u0430\u043A, \u0447\u0442\u043E\u0431\u044B \u0434\u043B\u0438\u043D\u0430
    \u043F\u0443\u0442\u0438 \u0431\u044B\u043B\u0430 \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0439.
    \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u0439 \u0432
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u0444\u0438\u0437\u0438\u043A\u0438
    \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439 \u043F\u0440\u0438\u043D\u0446\u0438\u043F
    (\u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0424\u0435\u0440\u043C\u0430 \u0431\u044B\u043B
    \u043E\u0442\u043A\u0440\u044B\u0442 \u0432 XVII \u0432\u0435\u043A\u0435). *  
    **\u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u0437\u0440\u0435\u043D\u0438\u044F:**
    \u041E\u043D \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u043B \u043F\u0440\u043E\u0446\u0435\u0441\u0441
    \u0437\u0440\u0435\u043D\u0438\u044F \u043D\u0435 \xAB\u0432\u044B\u0445\u043E\u0434\u043E\u043C
    \u043B\u0443\u0447\u0435\u0439 \u0438\u0437 \u0433\u043B\u0430\u0437\xBB (\u043A\u0430\u043A
    \u0441\u0447\u0438\u0442\u0430\u043B \u0415\u0432\u043A\u043B\u0438\u0434), \u0430
    \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u043B\u0443\u0447\u0438
    \u0438\u0434\u0443\u0442 \u043E\u0442 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430
    \u0441\u0432\u0435\u0442\u0430 \u043A \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0443
    \u0438 \u043E\u0442\u0440\u0430\u0436\u0430\u044E\u0442\u0441\u044F \u0432 \u0433\u043B\u0430\u0437,
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0430\u044F\u0441\u044C \u043A \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438.  ---  ### 5. \u0412\u043E\u0435\u043D\u043D\u0430\u044F
    \u0438 \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0438\u044F  *   **\u0411\u0430\u043B\u043B\u0438\u0441\u0442\u0438\u043A\u0430:**
    \u0412 \u0441\u0432\u043E\u0438\u0445 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    \u043E\u043D \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u043B
    \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438 \u043F\u043E\u043B\u0435\u0442\u0430
    \u0441\u043D\u0430\u0440\u044F\u0434\u043E\u0432 \u0434\u043B\u044F \u043A\u0430\u0442\u0430\u043F\u0443\u043B\u044C\u0442,
    \u0443\u0447\u0438\u0442\u044B\u0432\u0430\u044F \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0438\u043B\u0443 \u043D\u0430\u0442\u044F\u0436\u0435\u043D\u0438\u044F
    \u0442\u0435\u0442\u0438\u0432\u044B, \u043D\u043E \u0438 \u0443\u0433\u043E\u043B
    \u0432\u043E\u0437\u0432\u044B\u0448\u0435\u043D\u0438\u044F, \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u044F
    \u043F\u0435\u0440\u0432\u044B\u0435 \u0442\u0430\u0431\u043B\u0438\u0446\u044B
    \u0434\u043B\u044F \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u0439\u0441\u043A\u0438\u0445
    \u0440\u0430\u0441\u0447\u0435\u0442\u043E\u0432. *   **\u041D\u0438\u0432\u0435\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435:**
    \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043C\u0435\u0442\u043E\u0434
    \u043D\u0438\u0432\u0435\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    (\u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438 \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438)
    \u043F\u0440\u0438 \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435
    \u0442\u0443\u043D\u043D\u0435\u043B\u0435\u0439 \u0447\u0435\u0440\u0435\u0437
    \u0433\u043E\u0440\u044B. \u0427\u0442\u043E\u0431\u044B \u0440\u0430\u0431\u043E\u0447\u0438\u0435,
    \u043A\u043E\u043F\u0430\u0432\u0448\u0438\u0435 \u0441 \u0434\u0432\u0443\u0445
    \u0441\u0442\u043E\u0440\u043E\u043D, \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B\u0438\u0441\u044C,
    \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u043B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
    \u0434\u0438\u043E\u043F\u0442\u0440 \u0434\u043B\u044F \u0442\u043E\u0447\u043D\u043E\u0439
    \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0438 \u0432\u044B\u0441\u043E\u0442\u043D\u044B\u0445
    \u043E\u0442\u043C\u0435\u0442\u043E\u043A \u0447\u0435\u0440\u0435\u0437 \u0432\u0435\u0440\u0448\u0438\u043D\u0443
    \u0433\u043E\u0440\u044B.  ---  ### \U0001F3DB\uFE0F \u0418\u0442\u043E\u0433:
    \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u0435\u0440, \u043D\u0435
    \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0438\u0439 \u044D\u043F\u043E\u0445\u0443 
    \u0413\u0435\u0440\u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0431\u0430\u0437\u0443 \u0434\u043B\u044F **\u043A\u0438\u0431\u0435\u0440\u043D\u0435\u0442\u0438\u043A\u0438**
    (\u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u0441 \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u0439
    \u0441\u0432\u044F\u0437\u044C\u044E \u2014 \u0432\u0441\u043F\u043E\u043C\u043D\u0438\u043C
    \u0434\u0432\u0435\u0440\u0438 \u0445\u0440\u0430\u043C\u0430), **\u0442\u0435\u043F\u043B\u043E\u044D\u043D\u0435\u0440\u0433\u0435\u0442\u0438\u043A\u0438**
    (\u043F\u0430\u0440\u043E\u0432\u043E\u0439 \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u044C)
    \u0438 **\u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0442\u0435\u0445\u043D\u0438\u043A\u0438** (\u043E\u0434\u043E\u043C\u0435\u0442\u0440).  
    \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 **\u0447\u0438\u0441\u0442\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443** \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u043E\u043D **\u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043B
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438**.
    \u0414\u043E \u0413\u0435\u0440\u043E\u043D\u0430 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430
    \u0431\u044B\u043B\u0430 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E\u043C
    \u0440\u0435\u043C\u0435\u0441\u043B\u0435\u043D\u043D\u0438\u043A\u043E\u0432;
    \u043F\u043E\u0441\u043B\u0435 \u0413\u0435\u0440\u043E\u043D\u0430 \u043E\u043D\u0430
    \u0441\u0442\u0430\u043B\u0430 \u0442\u043E\u0447\u043D\u043E\u0439 \u043D\u0430\u0443\u043A\u043E\u0439,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u043E\u0439 \u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0432\u044B\u043A\u043B\u0430\u0434\u043A\u0430\u0445 \u0438 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0430\u0445.   \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u0435\u0440\u0435\u0436\u0438\u043B\u0438
    \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u043C \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0430\u043C.
    \u0412 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u0410\u043B\u044C-\u0414\u0436\u0430\u0437\u0430\u0440\u0438
    \u0432 XII \u0432\u0435\u043A\u0435 \u043E\u043F\u0438\u0440\u0430\u043B\u0441\u044F
    \u043D\u0430 \xAB\u041F\u043D\u0435\u0432\u043C\u0430\u0442\u0438\u043A\u0443\xBB
    \u0413\u0435\u0440\u043E\u043D\u0430, \u0430 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u0434\u0430 \u0412\u0438\u043D\u0447\u0438 \u0432 XV \u0432\u0435\u043A\u0435
    \u0438\u0437\u0443\u0447\u0430\u043B \u0435\u0433\u043E \u0447\u0435\u0440\u0442\u0435\u0436\u0438
    \u0438 \u0434\u0435\u043B\u0430\u043B \u043D\u0430 \u0438\u0445 \u043E\u0441\u043D\u043E\u0432\u0435
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435 \u044D\u0441\u043A\u0438\u0437\u044B
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u043E\u0432."
  achievementsEn: 
  personalLifeRu: "\u0427\u0442\u043E \u043A\u0430\u0441\u0430\u0435\u0442\u0441\u044F
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438 \u0413\u0435\u0440\u043E\u043D\u0430
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E,
    \u0437\u0434\u0435\u0441\u044C, \u043A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u043F\u0440\u0438\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u043A\u043E\u043D\u0441\u0442\u0430\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C,
    \u0447\u0442\u043E **\u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0438\u0447\u0435\u0433\u043E**. \u041A\u0430\u043A \u0431\u044B \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E
    \u043C\u044B \u043D\u0438 \u0445\u043E\u0442\u0435\u043B\u0438 \u044D\u0442\u043E
    \u043E\u043F\u0438\u0441\u0430\u0442\u044C, \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438 \u0445\u0440\u0430\u043D\u044F\u0442
    \u043F\u043E\u043B\u043D\u043E\u0435 \u043C\u043E\u043B\u0447\u0430\u043D\u0438\u0435
    \u043E \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u0435, \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0438
    \u0438 \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u0445
    \u0436\u0438\u0437\u043D\u0438.  ### \U0001F4DC \u0418\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0438\u0448\u0438\u043D\u0430  \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u0438 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u044B \u0435\u0434\u0438\u043D\u043E\u0434\u0443\u0448\u043D\u044B:
    \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u0439 \u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u044D\u0442\u043E\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043D\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C.
    \u041C\u044B \u043D\u0435 \u0437\u043D\u0430\u0435\u043C:  *   \u041A\u0435\u043C
    \u0431\u044B\u043B\u0438 \u0435\u0433\u043E \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438.
    *   \u0411\u044B\u043B \u043B\u0438 \u043E\u043D \u0436\u0435\u043D\u0430\u0442
    \u0438 \u0431\u044B\u043B\u0438 \u043B\u0438 \u0443 \u043D\u0435\u0433\u043E
    \u0434\u0435\u0442\u0438. *   \u0427\u0435\u043C \u043E\u043D \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0432\u043D\u0435 \u0441\u0432\u043E\u0435\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0438 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u043E\u0439 \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    *   \u041A\u0430\u043A\u0438\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u043E\u043D \u0431\u044B\u043B \u0432 \u0431\u044B\u0442\u0443.  \u0412\u0441\u0435
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0435\u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F,
    \u043F\u043E \u0441\u0443\u0442\u0438, \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0442
    \u0441\u043E\u0431\u043E\u0439 \u043F\u0435\u0440\u0435\u0441\u043A\u0430\u0437
    \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0442\u0440\u0443\u0434\u043E\u0432
    \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0439, \u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443
    \u044D\u0442\u043E \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435,
    \u0447\u0442\u043E \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C \u043E\u0442
    \u044D\u0442\u043E\u0433\u043E \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u0443\u043C\u0430.  ### \U0001F4A1 \u041E\u0442\u043A\u0443\u0434\u0430 \u043C\u044B
    \u0437\u043D\u0430\u0435\u043C \u043E \u043D\u0435\u043C?  \u041E\u0441\u043D\u043E\u0432\u043D\u0430\u044F
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F \u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438 \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0430
    \u043A\u043E\u0441\u0432\u0435\u043D\u043D\u044B\u043C\u0438 \u043C\u0435\u0442\u043E\u0434\u0430\u043C\u0438. 
    *   **\u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0437\u0430\u0446\u0435\u043F\u043A\u0430:** \u0412 \u0441\u0432\u043E\u0435\u043C
    \u0442\u0440\u0443\u0434\u0435 \xAB\u041E \u0434\u0438\u043E\u043F\u0442\u0440\u0435\xBB
    \u0413\u0435\u0440\u043E\u043D \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442
    \u043B\u0443\u043D\u043D\u043E\u0435 \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u0435.
    \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435 \u0440\u0430\u0441\u0447\u0435\u0442\u044B
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0438, \u0447\u0442\u043E \u044D\u0442\u043E
    \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u0435 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E
    **13 \u043C\u0430\u0440\u0442\u0430 62 \u0433\u043E\u0434\u0430 \u043D. \u044D.**.
    *   **\u0412\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u043A:**
    \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0441
    \u0432\u044B\u0441\u043E\u043A\u043E\u0439 \u0434\u043E\u043B\u0435\u0439 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0438
    \u043E\u0442\u043D\u0435\u0441\u0442\u0438 \u0435\u0433\u043E \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u043A\u043E **\u0432\u0442\u043E\u0440\u043E\u0439 \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0435
    I \u0432\u0435\u043A\u0430 \u043D. \u044D.**.  \u0422\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0435\u0433\u043E \u0442\u043E\u0447\u043D\u043E\u0435
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F \u0437\u0430\u0433\u0430\u0434\u043A\u043E\u0439,
    \u0445\u043E\u0442\u044F \u0435\u0433\u043E \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435
    \xAB\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0438\u0439\xBB
    \u043D\u0435\u0434\u0432\u0443\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u043D\u043E
    \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 \u043D\u0430 \u0442\u043E,
    \u0447\u0442\u043E \u043E\u043D \u0436\u0438\u043B \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438 \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0439
    \u2014 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0435\u043C \u043D\u0430\u0443\u0447\u043D\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430.  ### \u270D\uFE0F \u0413\u0435\u0440\u043E\u0439 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438?  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E \u043C\u044B \u043D\u0435 \u0437\u043D\u0430\u0435\u043C
    \u0434\u0435\u0442\u0430\u043B\u0435\u0439 \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438, \u043C\u044B \u043C\u043E\u0436\u0435\u043C \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u043E \u0435\u0433\u043E \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0438,
    \u043E\u0441\u043D\u043E\u0432\u044B\u0432\u0430\u044F\u0441\u044C \u043D\u0430
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0435:  *   **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:**
    \u0415\u0433\u043E \u0442\u0440\u0443\u0434\u044B \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443\u044E\u0442
    \u043E \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0438,
    \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E
    \u0434\u0430\u043B\u0435\u043A\u043E \u043D\u0435 \u043A\u0430\u0436\u0434\u043E\u043C\u0443
    \u0436\u0438\u0442\u0435\u043B\u044E \u0420\u0438\u043C\u0441\u043A\u043E\u0439
    \u0438\u043C\u043F\u0435\u0440\u0438\u0438. \u041E\u043D \u0431\u044B\u043B \u0437\u043D\u0430\u043A\u043E\u043C
    \u0441 \u0442\u0440\u0443\u0434\u0430\u043C\u0438 \u043C\u043D\u043E\u0433\u0438\u0445
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432:
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430, \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430,
    \u041A\u0442\u0435\u0441\u0438\u0431\u0438\u044F. *   **\u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u044F:**
    \u041E\u043D \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430\u043C
    \u043A\u0430\u043A **\xAB\u043C\u0435\u0445\u0430\u043D\u0438\u043A\xBB** (ho
    mechanikos). \u041E\u043D \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B,
    \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u044B \u0434\u043B\u044F \u0442\u0435\u0430\u0442\u0440\u043E\u0432
    \u0438 \u0445\u0440\u0430\u043C\u043E\u0432, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043F\u0438\u0441\u0430\u043B \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u044B.
    \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0438
    \u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0442, \u0447\u0442\u043E \u043E\u043D
    \u043C\u043E\u0433 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C
    \u0432 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u043C \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u043C
    \u041C\u0443\u0441\u0435\u0439\u043E\u043D\u0435 \u2014 \u0446\u0435\u043D\u0442\u0440\u0435
    \u043D\u0430\u0443\u043A\u0438 \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F.
    *   **\u0421\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u0441\u0442\u0430\u0442\u0443\u0441:**
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u043D\u043E\u0441\u0438\u043B\u0438
    \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u043E\u0439 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440
    \u0438 \u0447\u0430\u0441\u0442\u043E \u0431\u044B\u043B\u0438 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u044B
    \u043D\u0430 \u0443\u0434\u0438\u0432\u043B\u0435\u043D\u0438\u0435 \u0438 \u0440\u0430\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435
    \u043F\u0443\u0431\u043B\u0438\u043A\u0438 (\u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u0430\u0442\u0440\u044B, \u0445\u0440\u0430\u043C\u043E\u0432\u044B\u0435
    \xAB\u0447\u0443\u0434\u0435\u0441\u0430\xBB), \u0430 \u043D\u0435 \u043D\u0430
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447 \u043C\u0430\u0441\u0441\u043E\u0432\u043E\u0433\u043E
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u0430.  ###
    \u2757 \u0412\u0430\u0436\u043D\u043E\u0435 \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0435\u0440\u0435\u0436\u0435\u043D\u0438\u0435 
    \u0412 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432 \u0440\u0430\u0437\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0432\u0438\u0434\u0435\u043E, \u043C\u043E\u0436\u043D\u043E \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u0442\u044C
    \u0441\u043C\u0435\u043B\u044B\u0435 \u0442\u0435\u043E\u0440\u0438\u0438, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043E \u0441\u0432\u044F\u0437\u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0439
    \u0413\u0435\u0440\u043E\u043D\u0430 \u0441 \u0431\u0438\u0431\u043B\u0435\u0439\u0441\u043A\u0438\u043C\u0438
    \u0447\u0443\u0434\u0435\u0441\u0430\u043C\u0438, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u0441 \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435\u043C
    \u0432\u043E\u0434\u044B \u0432 \u0432\u0438\u043D\u043E \u043D\u0430 \u0441\u0432\u0430\u0434\u044C\u0431\u0435
    \u0432 \u041A\u0430\u043D\u0435 \u0413\u0430\u043B\u0438\u043B\u0435\u0439\u0441\u043A\u043E\u0439.
    \u041F\u043E\u0434\u043E\u0431\u043D\u044B\u0435 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u044F
    \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F \u043B\u0438\u0448\u044C \u0441\u043F\u0435\u043A\u0443\u043B\u044F\u0446\u0438\u044F\u043C\u0438
    \u0438 \u043D\u0435 \u0438\u043C\u0435\u044E\u0442 \u043F\u043E\u0434 \u0441\u043E\u0431\u043E\u0439
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432.
    \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0413\u0435\u0440\u043E\u043D
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B \u043F\u043E\u0445\u043E\u0436\u0438\u0435
    \xAB\u0432\u043E\u043B\u0448\u0435\u0431\u043D\u044B\u0435\xBB \u0441\u043E\u0441\u0443\u0434\u044B
    \u0434\u043B\u044F \u0440\u0430\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F
    \u0437\u043D\u0430\u0442\u0438, \u043D\u043E \u043B\u044E\u0431\u0430\u044F \u0441\u0432\u044F\u0437\u044C
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438 \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0439
    \u0441 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u043C\u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044F\u043C\u0438 \u0438\u043B\u0438
    \u0441\u043E\u0431\u044B\u0442\u0438\u044F\u043C\u0438 \u2014 \u044D\u0442\u043E
    \u043B\u0438\u0448\u044C \u0434\u043E\u043C\u044B\u0441\u043B\u044B.  \u0422\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0413\u0435\u0440\u043E\u043D\u0430 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u043E\u0441\u0442\u0430\u043D\u0435\u0442\u0441\u044F
    \u0434\u043B\u044F \u043D\u0430\u0441 \xAB\u0431\u0435\u043B\u044B\u043C \u043F\u044F\u0442\u043D\u043E\u043C\xBB.
    \u0415\u0433\u043E \u0438\u0441\u0442\u0438\u043D\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F,
    \u0430 \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438\u0434\u0435\u0438, \u043D\u0430 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0438\u0435 \u0441\u0432\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u0438 \u0434\u043E\u0448\u0435\u0434\u0448\u0438\u0435
    \u0434\u043E \u043D\u0430\u0441 \u0432 \u0432\u0438\u0434\u0435 \u0444\u043E\u0440\u043C\u0443\u043B,
    \u0447\u0435\u0440\u0442\u0435\u0436\u0435\u0439 \u0438 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432. \u0415\u0441\u043B\u0438
    \u0432\u044B \u0437\u0430\u0445\u043E\u0442\u0438\u0442\u0435 \u0443\u0437\u043D\u0430\u0442\u044C
    \u0431\u043E\u043B\u044C\u0448\u0435 \u043E \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442\u0430\u0445 \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F\u0445,
    \u044F \u0441 \u0440\u0430\u0434\u043E\u0441\u0442\u044C\u044E \u0440\u0430\u0441\u0441\u043A\u0430\u0436\u0443
    \u043E \u043D\u0438\u0445 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0435."
  personalLifeEn: 
  shortBioRu: "\u0413\u0435\u0440\u043E\u043D \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0438\u0439
    \u2014 \u043E\u0434\u043D\u0430 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u044F\u0440\u043A\u0438\u0445
    \u0438 \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u044B\u0445 \u0444\u0438\u0433\u0443\u0440
    \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0439 \u043D\u0430\u0443\u043A\u0438.
    \u0415\u0433\u043E \u0447\u0430\u0441\u0442\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0430,
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0430 \u0446\u0435\u043B\u044B\u0445 \u043F\u043E\u043B\u0442\u043E\u0440\u044B
    \u0442\u044B\u0441\u044F\u0447\u0438 \u043B\u0435\u0442 \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B
    \u0441\u0432\u043E\u0451 \u0432\u0440\u0435\u043C\u044F. \u041E\u0434\u043D\u0430\u043A\u043E,
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0435\u0433\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C, \u0434\u0435\u0442\u0430\u043B\u0438
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438
    \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C\u0438, \u0430
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0438\u0437 \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0439 \u0442\u0430\u043A
    \u0438 \u043D\u0435 \u043D\u0430\u0448\u043B\u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u044F \u0432 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u043C
    \u043C\u0438\u0440\u0435.  ### \U0001F4C5 \u0422\u0430\u0439\u043D\u0430 \u0436\u0438\u0437\u043D\u0438
    \u0438 \u0434\u0430\u0442\u0438\u0440\u043E\u0432\u043A\u0430  \u041F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u0413\u0435\u0440\u043E\u043D\u0430
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0443\u0442\u0435\u0440\u044F\u043D\u044B. \u041C\u044B \u043D\u0435 \u0437\u043D\u0430\u0435\u043C
    \u043D\u0438 \u0442\u043E\u0447\u043D\u044B\u0445 \u0434\u0430\u0442 \u0435\u0433\u043E
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0438 \u0441\u043C\u0435\u0440\u0442\u0438,
    \u043D\u0438 \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438. \u041E\u0441\u043D\u043E\u0432\u043D\u0430\u044F
    \u0437\u0430\u0433\u0430\u0434\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0434\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F \u0432\u043E\u043B\u043D\u043E\u0432\u0430\u043B\u0430
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432, \u2014 \u044D\u0442\u043E
    \u0432\u0440\u0435\u043C\u044F, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043E\u043D \u0436\u0438\u043B.  *   **\u0414\u0438\u0430\u043F\u0430\u0437\u043E\u043D
    \u0434\u0430\u0442:** \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u0447\u0442\u043E
    \u043E\u043D \u0436\u0438\u043B \u043F\u043E\u0441\u043B\u0435 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430
    (\u0443\u043C\u0435\u0440 \u0432 212 \u0433. \u0434\u043E \u043D. \u044D.) \u0438
    \u0434\u043E \u041F\u0430\u043F\u043F\u0430 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    (\u043E\u043A. 300 \u0433. \u043D. \u044D.), \u0447\u0442\u043E \u0434\u0430\u0432\u0430\u043B\u043E
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439 \u0440\u0430\u0437\u0431\u0440\u043E\u0441
    \u0432 \u0434\u0432\u0435 \u0441 \u043B\u0438\u0448\u043D\u0438\u043C \u0441\u043E\u0442\u043D\u0438
    \u043B\u0435\u0442. *   **\u041A\u043B\u044E\u0447 \u043A \u0440\u0430\u0437\u0433\u0430\u0434\u043A\u0435:**
    \u0412 \u0441\u0432\u043E\u0435\u043C \u0442\u0440\u0443\u0434\u0435 \xAB\u041E
    \u0434\u0438\u043E\u043F\u0442\u0440\u0435\xBB \u0413\u0435\u0440\u043E\u043D
    \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u0442 \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u043F\u0440\u0438\u043C\u0435\u0440\u0430 \u043B\u0443\u043D\u043D\u043E\u0435
    \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435,
    \u043A\u0430\u043A \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u0432\u044B\u044F\u0441\u043D\u0438\u0442\u044C,
    \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E **13 \u043C\u0430\u0440\u0442\u0430
    62 \u0433\u043E\u0434\u0430 \u043D. \u044D.**. \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044F\u043C
    \u0441 \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u0434\u043E\u043B\u0435\u0439
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0438 \u043E\u0442\u043D\u0435\u0441\u0442\u0438
    \u0435\u0433\u043E \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u043A\u043E \u0432\u0442\u043E\u0440\u043E\u0439 \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0435
    **I \u0432\u0435\u043A\u0430 \u043D. \u044D.**. *   **\u041C\u0435\u0441\u0442\u043E
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438:** \u0413\u0435\u0440\u043E\u043D
    \u0436\u0438\u043B \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438
    \u0415\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0439** \u2014 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0435\u043C
    \u043D\u0430\u0443\u0447\u043D\u043E\u043C \u0438 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430. \u0412\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043E\u043D
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u043C
    \u041C\u0443\u0441\u0435\u0439\u043E\u043D\u0435 (\u0445\u0440\u0430\u043C\u0435
    \u043C\u0443\u0437), \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u043A\u043B\u044E\u0447\u0430\u043B
    \u0432 \u0441\u0435\u0431\u044F \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0443\u044E
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0443.  ### \U0001F52C
    \u042D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u044F \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438  \u0413\u0435\u0440\u043E\u043D \u043D\u0435 \u0431\u044B\u043B
    \u0443\u0437\u043A\u0438\u043C \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u043E\u043C.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0442
    \u0441\u043E\u0431\u043E\u0439 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0443\u044E
    \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u044E \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0445
    \u0437\u043D\u0430\u043D\u0438\u0439 \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438,
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u0443\u044E\u0449\u0443\u044E
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u0435\u0433\u043E
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    \u2014 \u0415\u0432\u043A\u043B\u0438\u0434\u0430, \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430,
    \u0421\u0442\u0440\u0430\u0442\u043E\u043D\u0430 \u0438\u0437 \u041B\u0430\u043C\u043F\u0441\u0430\u043A\u0430.
    \u0415\u0433\u043E \u0441\u0442\u0438\u043B\u044C \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u0431\u044B\u043B \u0434\u043E\u0433\u043C\u0430\u0442\u0438\u0447\u043D\u044B\u043C
    \u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u044B\u043C: \u043E\u043D
    \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B \u043F\u0440\u0430\u0432\u0438\u043B\u0430
    \u0438 \u043F\u0440\u0438\u043C\u0435\u0440\u044B, \u043D\u0435 \u0432\u0441\u0435\u0433\u0434\u0430
    \u0434\u0430\u0432\u0430\u044F \u0441\u0442\u0440\u043E\u0433\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430. 
    \u0421\u0440\u0435\u0434\u0438 \u0435\u0433\u043E \u043C\u043D\u043E\u0433\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432 \u0432\u044B\u0434\u0435\u043B\u044F\u044E\u0442\u0441\u044F
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439:  **1. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430**
    *   **\xAB\u041C\u0435\u0442\u0440\u0438\u043A\u0430\xBB:** \u042D\u0442\u043E
    \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0440\u0443\u0434 \u0413\u0435\u0440\u043E\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B\u043B \u0443\u0442\u0435\u0440\u044F\u043D \u0438 \u0432\u043D\u043E\u0432\u044C
    \u043D\u0430\u0439\u0434\u0435\u043D \u043B\u0438\u0448\u044C \u0432 1896 \u0433\u043E\u0434\u0443.
    \u042D\u0442\u043E \u0441\u0431\u043E\u0440\u043D\u0438\u043A \u043F\u0440\u0430\u0432\u0438\u043B
    \u0438 \u0444\u043E\u0440\u043C\u0443\u043B \u0434\u043B\u044F \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u043F\u043B\u043E\u0449\u0430\u0434\u0435\u0439 \u0438 \u043E\u0431\u044A\u0435\u043C\u043E\u0432
    \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445 \u0444\u0438\u0433\u0443\u0440.
    *   **\u0424\u043E\u0440\u043C\u0443\u043B\u0430 \u0413\u0435\u0440\u043E\u043D\u0430:**
    \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \xAB\u041C\u0435\u0442\u0440\u0438\u043A\u0435\xBB
    \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u0444\u043E\u0440\u043C\u0443\u043B\u0430, \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0430\u044F
    \u043D\u0430\u0439\u0442\u0438 \u043F\u043B\u043E\u0449\u0430\u0434\u044C \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430
    \u043F\u043E \u0434\u043B\u0438\u043D\u0430\u043C \u0442\u0440\u0435\u0445 \u0435\u0433\u043E
    \u0441\u0442\u043E\u0440\u043E\u043D. \u0425\u043E\u0442\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u0447\u0442\u043E \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u043E\u0442\u043A\u0440\u044B\u043B
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434, \u0438\u043C\u0435\u043D\u043D\u043E
    \u0413\u0435\u0440\u043E\u043D \u0437\u0430\u043F\u0438\u0441\u0430\u043B \u0438
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0435\u0435. *   **\u0414\u0440\u0443\u0433\u0438\u0435 \u043C\u0435\u0442\u043E\u0434\u044B:**
    \u0412 \u0440\u0430\u0431\u043E\u0442\u0430\u0445 \u0413\u0435\u0440\u043E\u043D\u0430
    \u0442\u0430\u043A\u0436\u0435 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442\u0441\u044F
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u044B \u0434\u043B\u044F \u0438\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0445 \u0438 \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u043E\u0440\u043D\u0435\u0439 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0438\u0442\u0435\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u0430\u044F \u0444\u043E\u0440\u043C\u0443\u043B\u0430,
    \u043D\u043E\u0441\u044F\u0449\u0430\u044F \u0435\u0433\u043E \u0438\u043C\u044F)
    \u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. 
    **2. \u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430 \u0438 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0438\u044F**
    \u0412 \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435 \xAB\u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430\xBB
    \u0413\u0435\u0440\u043E\u043D \u043E\u043F\u0438\u0441\u0430\u043B \u043F\u044F\u0442\u044C
    \u043F\u0440\u043E\u0441\u0442\u0435\u0439\u0448\u0438\u0445 \u043C\u0430\u0448\u0438\u043D:
    **\u0440\u044B\u0447\u0430\u0433, \u0432\u043E\u0440\u043E\u0442, \u043A\u043B\u0438\u043D,
    \u0432\u0438\u043D\u0442 \u0438 \u0431\u043B\u043E\u043A**, \u0438 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \xAB\u0437\u043E\u043B\u043E\u0442\u043E\u0435 \u043F\u0440\u0430\u0432\u0438\u043B\u043E
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438\xBB: \u0432\u044B\u0438\u0433\u0440\u044B\u0448
    \u0432 \u0441\u0438\u043B\u0435 \u0432\u0441\u0435\u0433\u0434\u0430 \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u0442
    \u043A \u043F\u0440\u043E\u0438\u0433\u0440\u044B\u0448\u0443 \u0432 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0438. 
    **3. \u041F\u043D\u0435\u0432\u043C\u0430\u0442\u0438\u043A\u0430 \u0438 \u0433\u0438\u0434\u0440\u0430\u0432\u043B\u0438\u043A\u0430**
    \u0421\u0430\u043C\u044B\u0435 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F \u0413\u0435\u0440\u043E\u043D\u0430
    \u043E\u043F\u0438\u0441\u0430\u043D\u044B \u0432 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0435
    \xAB\u041F\u043D\u0435\u0432\u043C\u0430\u0442\u0438\u043A\u0430\xBB: *   **\u042D\u043E\u043B\u0438\u043F\u0438\u043B:**
    \u042D\u0442\u043E \u043F\u0435\u0440\u0432\u044B\u0439 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043F\u0430\u0440\u043E\u0432\u043E\u0439 \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u044C,
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0449\u0438\u0439
    \u0441\u043E\u0431\u043E\u0439 \u0448\u0430\u0440, \u0432\u0440\u0430\u0449\u0430\u044E\u0449\u0438\u0439\u0441\u044F
    \u043F\u043E\u0434 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435\u043C \u0441\u0442\u0440\u0443\u0439
    \u043F\u0430\u0440\u0430. \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
    \u0440\u0435\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0438, \u0447\u0442\u043E
    \u043E\u043D \u043C\u043E\u0433 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044C
    \u0434\u043E 3500 \u043E\u0431\u043E\u0440\u043E\u0442\u043E\u0432 \u0432 \u043C\u0438\u043D\u0443\u0442\u0443.
    *   **\u0410\u0432\u0442\u043E\u043C\u0430\u0442 \u0434\u043B\u044F \u043F\u0440\u043E\u0434\u0430\u0436\u0438
    \xAB\u0441\u0432\u044F\u0442\u043E\u0439\xBB \u0432\u043E\u0434\u044B:** \u041C\u043E\u043D\u0435\u0442\u043D\u044B\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u044B\u0434\u0430\u0432\u0430\u043B \u043F\u043E\u0440\u0446\u0438\u044E
    \u0432\u043E\u0434\u044B \u0434\u043B\u044F \u043E\u043C\u043E\u0432\u0435\u043D\u0438\u044F
    \u043F\u043E\u0441\u043B\u0435 \u043E\u043F\u0443\u0441\u043A\u0430\u043D\u0438\u044F
    \u043C\u043E\u043D\u0435\u0442\u044B. *   **\u0410\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u0432\u0435\u0440\u0438:** \u041C\u0435\u0445\u0430\u043D\u0438\u0437\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u043B
    \u0434\u0432\u0435\u0440\u0438 \u0445\u0440\u0430\u043C\u0430, \u043A\u043E\u0433\u0434\u0430
    \u043D\u0430 \u0436\u0435\u0440\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0435
    \u0440\u0430\u0437\u0432\u043E\u0434\u0438\u043B\u0438 \u043E\u0433\u043E\u043D\u044C,
    \u0438 \u0437\u0430\u043A\u0440\u044B\u0432\u0430\u043B \u0438\u0445, \u043A\u043E\u0433\u0434\u0430
    \u043E\u0433\u043E\u043D\u044C \u0442\u0443\u0448\u0438\u043B\u0438. *   **\u0424\u043E\u043D\u0442\u0430\u043D
    \u0413\u0435\u0440\u043E\u043D\u0430:** \u0423\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0432\u043E\u0434\u0430 \u0431\u044C\u0435\u0442
    \u0441\u0442\u0440\u0443\u0435\u0439 \u0432\u0432\u0435\u0440\u0445 \u0437\u0430
    \u0441\u0447\u0435\u0442 \u044D\u043D\u0435\u0440\u0433\u0438\u0438 \u0441\u0436\u0430\u0442\u043E\u0433\u043E
    \u0432\u043E\u0437\u0434\u0443\u0445\u0430, \u0431\u0435\u0437 \u0432\u043D\u0435\u0448\u043D\u0435\u0433\u043E
    \u043D\u0430\u0441\u043E\u0441\u0430.  **4. \u0413\u0435\u043E\u0434\u0435\u0437\u0438\u044F
    \u0438 \u043E\u043F\u0442\u0438\u043A\u0430** *   **\u0414\u0438\u043E\u043F\u0442\u0440:**
    \u0412 \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435 \xAB\u041E \u0434\u0438\u043E\u043F\u0442\u0440\u0435\xBB
    \u0413\u0435\u0440\u043E\u043D \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442
    \u044D\u0442\u043E\u0442 \u043F\u0440\u0438\u0431\u043E\u0440 \u2014 \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E \u0442\u0435\u043E\u0434\u043E\u043B\u0438\u0442\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F \u0443\u0433\u043B\u043E\u0432
    \u043D\u0430 \u043C\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u0438. \u041E\u043D
    \u0442\u0430\u043A\u0436\u0435 \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u043F\u0440\u0430\u0432\u0438\u043B\u0430
    \u0437\u0435\u043C\u0435\u043B\u044C\u043D\u043E\u0439 \u0441\u044A\u0435\u043C\u043A\u0438,
    \u043F\u043E \u0441\u0443\u0442\u0438, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u043D\u0430 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0438 \u043F\u0440\u044F\u043C\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442. *   **\u041E\u0434\u043E\u043C\u0435\u0442\u0440:**
    \u041F\u0440\u0438\u0431\u043E\u0440 \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0439\u0434\u0435\u043D\u043D\u043E\u0433\u043E \u043F\u0443\u0442\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0437\u0443\u0431\u0447\u0430\u0442\u0443\u044E \u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0443
    \u0438 \u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u043F\u043E
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0443 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u0442\u0430\u043A\u0441\u043E\u043C\u0435\u0442\u0440\u0430. *   **\u0417\u0430\u043A\u043E\u043D
    \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044F \u0441\u0432\u0435\u0442\u0430:**
    \u0412 \u0442\u0440\u0443\u0434\u0435 \xAB\u041A\u0430\u0442\u043E\u043F\u0442\u0440\u0438\u043A\u0430\xBB
    \u043E\u043D \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043B \u0437\u0430\u043A\u043E\u043D
    \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044F, \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u0432
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F, \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443 \u0441\u0432\u0435\u0442 \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0442
    \u0441\u0430\u043C\u044B\u0439 \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0439
    \u043F\u0443\u0442\u044C \u2014 \u0447\u0430\u0441\u0442\u043D\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439
    \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0435\u0433\u043E
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430 \u0424\u0435\u0440\u043C\u0430. 
    ### \U0001F3DB\uFE0F \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0438
    \u0437\u0430\u0431\u0432\u0435\u043D\u0438\u0435  \u0413\u0435\u0440\u043E\u043D
    \u0441\u043E\u0437\u0434\u0430\u043B \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u044B, \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u044D\u043E\u043B\u0438\u043F\u0438\u043B \u0438 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0435\u0430\u0442\u0440) \u0431\u044B\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C\u0438
    \u0447\u0443\u0434\u0435\u0441\u0430\u043C\u0438 \u0442\u0435\u0445\u043D\u0438\u043A\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0432 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u043C
    \u043C\u0438\u0440\u0435 \u043E\u043D\u0438 \u043D\u0435 \u043D\u0430\u0448\u043B\u0438
    \u0448\u0438\u0440\u043E\u043A\u043E\u0433\u043E \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u044F \u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C \u043A\u0430\u043A \u0434\u043E\u0440\u043E\u0433\u0438\u0435
    \u0438\u0433\u0440\u0443\u0448\u043A\u0438, \u0442\u0435\u0430\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0435
    \u044D\u0444\u0444\u0435\u043A\u0442\u044B \u0438\u043B\u0438 \u0434\u043B\u044F
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \xAB\u0447\u0443\u0434\u0435\u0441\xBB
    \u0432 \u0445\u0440\u0430\u043C\u0430\u0445, \u0447\u0442\u043E\u0431\u044B \u0443\u043A\u0440\u0435\u043F\u0438\u0442\u044C
    \u0432\u0435\u0440\u0443 \u043F\u0440\u0438\u0445\u043E\u0436\u0430\u043D.  \u0412
    \u044D\u043F\u043E\u0445\u0443 \u0421\u0440\u0435\u0434\u043D\u0435\u0432\u0435\u043A\u043E\u0432\u044C\u044F
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0435\u0433\u043E \u0438\u0434\u0435\u0438
    \u0431\u044B\u043B\u0438 \u0437\u0430\u0431\u044B\u0442\u044B. \u0418\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u0430\u043C \u0432\u043E\u0437\u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u043B\u0438\u0448\u044C \u0441\u043F\u0443\u0441\u0442\u044F \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F,
    \u0430 \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043F\u0440\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u043E\u0439
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438 \u0435\u0433\u043E \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F
    \u0441\u0442\u0430\u043B\u0438 \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u043A\u0430\u043A \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u0435
    \u043C\u043D\u043E\u0433\u0438\u0445 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0439.  \u0413\u0435\u0440\u043E\u043D
    \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043A\u0430\u043A \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0439 \u043F\u0440\u0438\u043C\u0435\u0440
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u043E\u0433\u043E \u0433\u0435\u043D\u0438\u044F,
    \u0447\u044C\u0438 \u0438\u0434\u0435\u0438 \u043D\u0430\u043C\u043D\u043E\u0433\u043E
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438 \u0441\u0432\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F, \u043D\u043E \u043D\u0435 \u0441\u043C\u043E\u0433\u043B\u0438
    \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C \u043C\u0438\u0440, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043E\u043D \u0436\u0438\u043B."
  shortBioEn: 
  interestingFactsRu: "\u0411\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u0413\u0435\u0440\u043E\u043D\u0430
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u043E\u043A\u0443\u0442\u0430\u043D\u0430 \u0442\u0430\u0439\u043D\u043E\u0439,
    \u043D\u043E \u0432\u043E\u0442 \u0435\u0433\u043E \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F
    \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0438\u0434\u0435\u0438 \u2014
    \u044D\u0442\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439 \u043A\u043B\u0430\u0434\u0435\u0437\u044C
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432. \u041E\u043D \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043D\u0430\u043C\u043D\u043E\u0433\u043E \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0438\u043C
    \u0441\u0432\u043E\u0451 \u0432\u0440\u0435\u043C\u044F, \u0438 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0438\u0437 \u0435\u0433\u043E \u0442\u0432\u043E\u0440\u0435\u043D\u0438\u0439
    \u043A\u0430\u0436\u0443\u0442\u0441\u044F \u043F\u043E\u0447\u0442\u0438 \u0444\u0430\u043D\u0442\u0430\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0434\u043B\u044F \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0433\u043E \u043C\u0438\u0440\u0430. 
    ### \U0001F4A8 \u041F\u0430\u0440\u043E\u0432\u0430\u044F \u0442\u0443\u0440\u0431\u0438\u043D\u0430
    \u2014 2000 \u043B\u0435\u0442 \u043D\u0430\u0437\u0430\u0434  \u041F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442: \u0413\u0435\u0440\u043E\u043D \u0438\u0437\u043E\u0431\u0440\u0451\u043B
    **\u044D\u043E\u043B\u0438\u043F\u0438\u043B** \u2014 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043F\u0435\u0440\u0432\u043E\u0439 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043F\u0430\u0440\u043E\u0432\u043E\u0439 \u0442\u0443\u0440\u0431\u0438\u043D\u043E\u0439.
    \u042D\u0442\u043E \u0431\u044B\u043B \u043C\u0435\u0434\u043D\u044B\u0439 \u0448\u0430\u0440,
    \u0437\u0430\u043A\u0440\u0435\u043F\u043B\u0451\u043D\u043D\u044B\u0439 \u043D\u0430
    \u043E\u0441\u0438 \u043D\u0430\u0434 \u043A\u043E\u0442\u043B\u043E\u043C \u0441
    \u0432\u043E\u0434\u043E\u0439. \u041A\u043E\u0433\u0434\u0430 \u0432\u043E\u0434\u0443
    \u043D\u0430\u0433\u0440\u0435\u0432\u0430\u043B\u0438, \u043F\u0430\u0440 \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0432 \u0448\u0430\u0440 \u0438 \u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439
    \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E \u0432\u044B\u0440\u044B\u0432\u0430\u043B\u0441\u044F
    \u0447\u0435\u0440\u0435\u0437 \u0438\u0437\u043E\u0433\u043D\u0443\u0442\u044B\u0435
    \u0441\u043E\u043F\u043B\u0430, \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u044F
    \u0448\u0430\u0440 \u0432\u0440\u0430\u0449\u0430\u0442\u044C\u0441\u044F. \u041F\u043E
    \u0440\u0435\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044F\u043C,
    \u043E\u043D \u043C\u043E\u0433 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044C
    \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C \u0434\u043E 3500 \u043E\u0431\u043E\u0440\u043E\u0442\u043E\u0432
    \u0432 \u043C\u0438\u043D\u0443\u0442\u0443! \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u043D\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438
    \u043A\u0430\u043A \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u044C \u2014
    \u044D\u0442\u043E \u0431\u044B\u043B\u043E \u0441\u043A\u043E\u0440\u0435\u0435
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435 \u0437\u0440\u0435\u043B\u0438\u0449\u0435
    \u0438\u043B\u0438 \u0445\u0440\u0430\u043C\u043E\u0432\u0430\u044F \u0434\u0438\u043A\u043E\u0432\u0438\u043D\u043A\u0430. 
    ### \U0001FA99 \u041F\u0435\u0440\u0432\u044B\u0439 \u0432 \u043C\u0438\u0440\u0435
    \u0432\u0435\u043D\u0434\u0438\u043D\u0433\u043E\u0432\u044B\u0439 \u0430\u0432\u0442\u043E\u043C\u0430\u0442 
    \u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u044C\u0442\u0435 \u0441\u0435\u0431\u0435,
    \u0447\u0442\u043E \u043F\u0435\u0440\u0432\u044B\u0439 \u0430\u0432\u0442\u043E\u043C\u0430\u0442
    \u0434\u043B\u044F \u043F\u0440\u043E\u0434\u0430\u0436\u0438 \u0431\u044B\u043B
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0451\u043D... \u0434\u043B\u044F
    \u043F\u0440\u043E\u0434\u0430\u0436\u0438 \u0441\u0432\u044F\u0442\u043E\u0439
    \u0432\u043E\u0434\u044B \u0432 \u0435\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0438\u0445
    \u0445\u0440\u0430\u043C\u0430\u0445. \u041F\u0440\u0438\u043D\u0446\u0438\u043F
    \u0431\u044B\u043B \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E \u043F\u0440\u043E\u0441\u0442:
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0431\u0440\u043E\u0441\u0430\u043B
    \u043C\u043E\u043D\u0435\u0442\u0443 \u0432 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0442\u0432\u0435\u0440\u0441\u0442\u0438\u0435. \u041E\u043D\u0430 \u043F\u0430\u0434\u0430\u043B\u0430
    \u043D\u0430 \u0440\u044B\u0447\u0430\u0433-\u043F\u043B\u0430\u0442\u0444\u043E\u0440\u043C\u0443,
    \u0432\u0435\u0441 \u043C\u043E\u043D\u0435\u0442\u044B \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u043B
    \u043A\u043B\u0430\u043F\u0430\u043D, \u0438 \u043E\u0442\u0442\u0443\u0434\u0430
    \u0432\u044B\u0442\u0435\u043A\u0430\u043B\u0430 \u043F\u043E\u0440\u0446\u0438\u044F
    \xAB\u043E\u0441\u0432\u044F\u0449\u0451\u043D\u043D\u043E\u0439\xBB \u0432\u043E\u0434\u044B
    \u0434\u043B\u044F \u043E\u043C\u043E\u0432\u0435\u043D\u0438\u044F. \u041A\u043E\u0433\u0434\u0430
    \u043C\u043E\u043D\u0435\u0442\u0430 \u0441\u043E\u0441\u043A\u0430\u043B\u044C\u0437\u044B\u0432\u0430\u043B\u0430
    \u0441 \u043F\u043B\u0430\u0442\u0444\u043E\u0440\u043C\u044B, \u043A\u043B\u0430\u043F\u0430\u043D
    \u0437\u0430\u043A\u0440\u044B\u0432\u0430\u043B\u0441\u044F. \u042D\u0442\u043E
    \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439 \u0431\u0438\u0437\u043D\u0435\u0441-\u043F\u043E\u0434\u0445\u043E\u0434
    \u043A \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u0438\u044E \u0440\u0435\u043D\u0442\u0430\u0431\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0445\u0440\u0430\u043C\u043E\u0432!  ### \U0001F6AA \u0410\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u0432\u0435\u0440\u0438 \u0445\u0440\u0430\u043C\u0430  \u0413\u0435\u0440\u043E\u043D
    \u043D\u0435 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0435 \u0434\u043B\u044F
    \u0432\u043E\u0434\u044B. \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u043D\u0438\u044F \u0434\u0432\u0435\u0440\u0435\u0439
    \u0434\u043B\u044F \u0445\u0440\u0430\u043C\u043E\u0432. \u0421\u0435\u043A\u0440\u0435\u0442
    \u0431\u044B\u043B \u0432 \u043E\u0433\u043D\u0435 \u043D\u0430 \u0436\u0435\u0440\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0435.
    \u041A\u043E\u0433\u0434\u0430 \u0436\u0440\u0435\u0446 \u0440\u0430\u0437\u0432\u043E\u0434\u0438\u043B
    \u043E\u0433\u043E\u043D\u044C, \u043D\u0430\u0433\u0440\u0435\u0432\u0430\u043B\u0441\u044F
    \u0432\u043E\u0437\u0434\u0443\u0445 \u0432 \u0437\u0430\u043F\u0435\u0447\u0430\u0442\u0430\u043D\u043D\u043E\u043C
    \u0441\u043E\u0441\u0443\u0434\u0435 \u043F\u043E\u0434 \u0430\u043B\u0442\u0430\u0440\u0451\u043C.
    \u0420\u0430\u0441\u0448\u0438\u0440\u044F\u044F\u0441\u044C, \u0432\u043E\u0437\u0434\u0443\u0445
    \u0432\u044B\u0442\u0435\u0441\u043D\u044F\u043B \u0432\u043E\u0434\u0443 \u0432
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0432\u0435\u0441\u043E\u0432 \u0438
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0432\u0435\u0441\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u043B\u0430\u0432\u043D\u043E \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u043B\u0438
    \u043C\u0430\u0441\u0441\u0438\u0432\u043D\u044B\u0435 \u0434\u0432\u0435\u0440\u0438.
    \u041A\u043E\u0433\u0434\u0430 \u043E\u0433\u043E\u043D\u044C \u0442\u0443\u0448\u0438\u043B\u0438,
    \u0432\u043E\u0437\u0434\u0443\u0445 \u043E\u0441\u0442\u044B\u0432\u0430\u043B,
    \u0438 \u0434\u0432\u0435\u0440\u0438 \u0437\u0430\u043A\u0440\u044B\u0432\u0430\u043B\u0438\u0441\u044C.
    \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0449\u0438\u0439
    \u0442\u0435\u043F\u043B\u043E\u0432\u0443\u044E \u044D\u043D\u0435\u0440\u0433\u0438\u044E
    \u0434\u043B\u044F \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u0438,
    \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0449\u0438\u0439 \u043D\u0430 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0435
    \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u0439 \u0441\u0432\u044F\u0437\u0438
    \u2014 \u043A\u0430\u043A \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u043A\u0438\u0431\u0435\u0440\u043D\u0435\u0442\u0438\u043A\u0430.  ### \U0001F3AD
    \u041F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u0443\u0435\u043C\u044B\u0439
    \u0442\u0435\u0430\u0442\u0440 \u043C\u0430\u0440\u0438\u043E\u043D\u0435\u0442\u043E\u043A 
    \u0413\u0435\u0440\u043E\u043D \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0435 **\u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u0430\u0442\u0440\u044B** \u2014 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u043E\u0433\u043B\u0438 \u0434\u043B\u0438\u0442\u044C\u0441\u044F
    \u0434\u043E 10 \u043C\u0438\u043D\u0443\u0442. \u0414\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043A\u0443\u043A\u043E\u043B \u0431\u044B\u043B\u0438 \xAB\u0437\u0430\u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u044B\xBB
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0432\u0435\u0440\u0451\u0432\u043E\u043A,
    \u043D\u0430\u043C\u043E\u0442\u0430\u043D\u043D\u044B\u0445 \u043D\u0430 \u0432\u0440\u0430\u0449\u0430\u044E\u0449\u0438\u0439\u0441\u044F
    \u0432\u0430\u043B \u0441\u043E \u0448\u0442\u044B\u0440\u044C\u043A\u0430\u043C\u0438.
    \u0412\u0440\u0430\u0449\u0430\u044F\u0441\u044C, \u0432\u0430\u043B \u0434\u0451\u0440\u0433\u0430\u043B
    \u0437\u0430 \u0432\u0435\u0440\u0451\u0432\u043A\u0438 \u0432 \u043D\u0443\u0436\u043D\u043E\u0439
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438,
    \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u044F \u043A\u0443\u043A\u043E\u043B
    \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F, \u0430 \u0434\u0435\u043A\u043E\u0440\u0430\u0446\u0438\u0438
    \u043C\u0435\u043D\u044F\u0442\u044C\u0441\u044F. \xAB\u0417\u0432\u0443\u043A
    \u0433\u0440\u043E\u043C\u0430\xBB \u0434\u043B\u044F \u0441\u043F\u0435\u043A\u0442\u0430\u043A\u043B\u044F
    \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B\u0441\u044F \u043F\u0430\u0434\u0435\u043D\u0438\u0435\u043C
    \u043C\u0435\u0442\u0430\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0448\u0430\u0440\u0438\u043A\u043E\u0432 \u043D\u0430 \u0441\u043A\u0440\u044B\u0442\u044B\u0439
    \u0431\u0430\u0440\u0430\u0431\u0430\u043D. \u041F\u043E \u0441\u0443\u0442\u0438,
    \u044D\u0442\u043E \u0431\u044B\u043B \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0440\u0443\u0435\u043C\u043E\u0433\u043E
    \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430.  ### \U0001F4CF
    \xAB\u041D\u0430\u0432\u0438\u0433\u0430\u0442\u043E\u0440\xBB \u0438 \u043E\u0434\u043E\u043C\u0435\u0442\u0440
    \u0434\u043B\u044F \u0420\u0438\u043C\u0441\u043A\u043E\u0439 \u0438\u043C\u043F\u0435\u0440\u0438\u0438 
    \u0413\u0435\u0440\u043E\u043D \u0431\u044B\u043B \u0438 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C-\u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0441\u0442\u043E\u043C.
    \u041E\u043D \u043E\u043F\u0438\u0441\u0430\u043B **\u0434\u0438\u043E\u043F\u0442\u0440**
    \u2014 \u0442\u043E\u0447\u043D\u044B\u0439 \u043F\u0440\u0438\u0431\u043E\u0440
    \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F \u0443\u0433\u043B\u043E\u0432,
    \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u0442\u0435\u043E\u0434\u043E\u043B\u0438\u0442\u0430. \u0421 \u0435\u0433\u043E
    \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043C\u043E\u0436\u043D\u043E \u0431\u044B\u043B\u043E
    \u0440\u0435\u0448\u0430\u0442\u044C \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u043D\u0430 \u043C\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u0438:
    \u0438\u0437\u043C\u0435\u0440\u044F\u0442\u044C \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    \u0434\u043E \u043D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432, \u043F\u0440\u043E\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0442\u044C
    \u043F\u0440\u044F\u043C\u044B\u0435 \u043B\u0438\u043D\u0438\u0438, \u0430 \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u2014 \u0441\u0442\u0440\u043E\u0438\u0442\u044C \u0442\u0443\u043D\u043D\u0435\u043B\u0438
    \u0441\u043A\u0432\u043E\u0437\u044C \u0433\u043E\u0440\u044B, \u0442\u043E\u0447\u043D\u043E
    \u0441\u0432\u043E\u0434\u044F \u0440\u0430\u0431\u043E\u0442\u044B \u0441 \u0434\u0432\u0443\u0445
    \u0441\u0442\u043E\u0440\u043E\u043D.  \u0414\u0440\u0443\u0433\u043E\u0435 \u0435\u0433\u043E
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435 \u2014 **\u043E\u0434\u043E\u043C\u0435\u0442\u0440**,
    \u043F\u0440\u0438\u0431\u043E\u0440 \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0439\u0434\u0435\u043D\u043D\u043E\u0433\u043E \u043F\u0443\u0442\u0438.
    \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u0442\u0435\u043B\u0435\u0436\u043A\u0430
    \u0441 \u043A\u043E\u043B\u0451\u0441\u0430\u043C\u0438 \u043F\u043E\u0434\u043E\u0431\u0440\u0430\u043D\u043D\u043E\u0433\u043E
    \u0434\u0438\u0430\u043C\u0435\u0442\u0440\u0430, \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0447\u0435\u0440\u0435\u0437 \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u0437\u0443\u0431\u0447\u0430\u0442\u044B\u0445 \u043A\u043E\u043B\u0451\u0441
    \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B\u043E \u0432 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C, \u0441\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u044E\u0449\u0438\u0439
    \u043A\u0430\u043C\u0435\u0448\u043A\u0438 \u0432 \u043B\u043E\u0442\u043E\u043A.
    \u041F\u043E \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0443 \u0443\u043F\u0430\u0432\u0448\u0438\u0445
    \u043A\u0430\u043C\u0435\u0448\u043A\u043E\u0432 \u043C\u043E\u0436\u043D\u043E
    \u0431\u044B\u043B\u043E \u0442\u043E\u0447\u043D\u043E \u0443\u0437\u043D\u0430\u0442\u044C
    \u043F\u0440\u043E\u0439\u0434\u0435\u043D\u043D\u043E\u0435 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435,
    \u043A\u0430\u043A \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C
    \u0442\u0430\u043A\u0441\u043E\u043C\u0435\u0442\u0440\u0435.  ### \U0001F9EA
    \u0412\u043A\u043B\u0430\u0434 \u0432 \u043D\u0430\u0443\u043A\u0443: \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F 
    \u041F\u043E\u043C\u0438\u043C\u043E \xAB\u0438\u0433\u0440\u0443\u0448\u0435\u043A\xBB,
    \u0413\u0435\u0440\u043E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u044B\u0439
    \u0441\u043B\u0435\u0434 \u0432 \u043D\u0430\u0443\u043A\u0435:  *   **\u0424\u043E\u0440\u043C\u0443\u043B\u0430
    \u0413\u0435\u0440\u043E\u043D\u0430:** \u0428\u043A\u043E\u043B\u044C\u043D\u0430\u044F
    \u0444\u043E\u0440\u043C\u0443\u043B\u0430 \u0434\u043B\u044F \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043F\u043B\u043E\u0449\u0430\u0434\u0438 \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430
    \u043F\u043E \u0442\u0440\u0451\u043C \u0441\u0442\u043E\u0440\u043E\u043D\u0430\u043C,
    \u0445\u043E\u0442\u044F \u043E\u043D \u0438 \u0441\u0430\u043C \u0441\u0441\u044B\u043B\u0430\u043B\u0441\u044F
    \u043D\u0430 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430 \u043A\u0430\u043A
    \u043D\u0430 \u0435\u0451 \u0430\u0432\u0442\u043E\u0440\u0430. *   **\u041F\u0440\u0438\u043D\u0446\u0438\u043F
    \u0424\u0435\u0440\u043C\u0430:** \u0412 \u0441\u0432\u043E\u0451\u043C \u0442\u0440\u0443\u0434\u0435
    \u043F\u043E \u043E\u043F\u0442\u0438\u043A\u0435 \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0441\u0432\u0435\u0442 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u0435\u0442\u0441\u044F
    \u043F\u043E \u043A\u0440\u0430\u0442\u0447\u0430\u0439\u0448\u0435\u043C\u0443
    \u043F\u0443\u0442\u0438, \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u0432
    \u0447\u0430\u0441\u0442\u043D\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0438\u0306
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430 \u0424\u0435\u0440\u043C\u0430
    \u043D\u0430 16 \u0432\u0435\u043A\u043E\u0432 \u0440\u0430\u043D\u044C\u0448\u0435
    \u0441\u0430\u043C\u043E\u0433\u043E \u0424\u0435\u0440\u043C\u0430! *   **\xAB\u0417\u043E\u043B\u043E\u0442\u043E\u0435
    \u043F\u0440\u0430\u0432\u0438\u043B\u043E \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438\xBB:**
    \u041E\u043D \u043E\u043F\u0438\u0441\u0430\u043B \u043F\u044F\u0442\u044C \u043F\u0440\u043E\u0441\u0442\u0435\u0439\u0448\u0438\u0445
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432 \u0438 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B
    \u043F\u0440\u0430\u0432\u0438\u043B\u043E, \u0447\u0442\u043E \u0432\u044B\u0438\u0433\u0440\u044B\u0448
    \u0432 \u0441\u0438\u043B\u0435 \u0432\u0441\u0435\u0433\u0434\u0430 \u0434\u0430\u0451\u0442
    \u043F\u0440\u043E\u0438\u0433\u0440\u044B\u0448 \u0432 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0438. 
    ### \U0001F30A \u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441 \u0435\u0433\u043E
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044F  \u0421\u0430\u043C\u044B\u0439
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u0438,
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0433\u0440\u0443\u0441\u0442\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442: **\u043F\u043E\u0447\u0442\u0438 \u0432\u0441\u0435
    \u044D\u0442\u0438 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F \u0431\u044B\u043B\u0438
    \u0437\u0430\u0431\u044B\u0442\u044B \u0438\u043B\u0438 \u043E\u0442\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u044B
    \u0432 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u0438 \u0438 \u0432
    \u0421\u0440\u0435\u0434\u043D\u0438\u0435 \u0432\u0435\u043A\u0430**. \u041E\u043D\u0438
    \u043D\u0435 \u0438\u043C\u0435\u043B\u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u044F \u0432 \u043C\u0438\u0440\u0435,
    \u0433\u0434\u0435 \u0432\u0441\u044E \u0442\u044F\u0436\u0451\u043B\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0434\u0435\u043B\u0430\u043B\u0438 \u0440\u0430\u0431\u044B.
    \u042D\u043E\u043B\u0438\u043F\u0438\u043B \u0431\u044B\u043B \u043B\u0438\u0448\u044C
    \u0437\u0430\u0431\u0430\u0432\u043D\u043E\u0439 \u0438\u0433\u0440\u0443\u0448\u043A\u043E\u0439,
    \u0430 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u044B \u2014 \u0445\u0440\u0430\u043C\u043E\u0432\u044B\u043C\u0438
    \u0447\u0443\u0434\u0435\u0441\u0430\u043C\u0438 \u0434\u043B\u044F \u0443\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0438\u044F
    \u0432\u0435\u0440\u044B. \u0418\u0441\u0442\u0438\u043D\u043D\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0413\u0435\u0440\u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043B\u0438\u0448\u044C
    \u0441\u043F\u0443\u0441\u0442\u044F \u043F\u043E\u0447\u0442\u0438 \u0434\u0432\u0435
    \u0442\u044B\u0441\u044F\u0447\u0438 \u043B\u0435\u0442, \u0432 \u044D\u043F\u043E\u0445\u0443
    \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0438 \u043F\u0440\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u043E\u0439
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438.  \u0412 \u0437\u043D\u0430\u043A
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434\u0430
    \u0432 1976 \u0433\u043E\u0434\u0443 \u0435\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C
    \u0431\u044B\u043B \u043D\u0430\u0437\u0432\u0430\u043D \u043A\u0440\u0430\u0442\u0435\u0440
    \u043D\u0430 \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u0435
    \u041B\u0443\u043D\u044B."
