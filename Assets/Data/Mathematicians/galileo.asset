  achievementsRu: "\u0413\u0430\u043B\u0438\u043B\u0435\u043E \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u2014 \u0433\u0438\u0433\u0430\u043D\u0442 \u043D\u0430 \u043F\u043B\u0435\u0447\u0430\u0445
    \u0433\u0438\u0433\u0430\u043D\u0442\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0432 \u043D\u0430\u0443\u043A\u0435,
    \u0430 \u0432 \u0441\u0430\u043C\u043E\u043C \u043C\u0435\u0442\u043E\u0434\u0435
    \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u044F \u043C\u0438\u0440\u0430. \u041E\u043D
    \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B \u0444\u0438\u0437\u0438\u043A\u0443
    \u0438\u0437 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445
    \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0439 \u0432 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443 \u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438.  \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0439\u0448\u0438\u0439 \u043E\u0431\u0437\u043E\u0440
    \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439,
    \u0440\u0430\u0437\u0431\u0438\u0442\u044B\u0439 \u043F\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u043C
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C.  ### 1. \u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430
    \u0438 \u0444\u0438\u0437\u0438\u043A\u0430 (\u041A\u0438\u043D\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0438 \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0430)  \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u041D\u044C\u044E\u0442\u043E\u043D
    \u043F\u043E\u0437\u0436\u0435 \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    \u0441\u0432\u043E\u0438 \u0437\u0430\u043A\u043E\u043D\u044B. \u0413\u043B\u0430\u0432\u043D\u043E\u0435
    \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u0437\u0434\u0435\u0441\u044C \u2014 \u043F\u0435\u0440\u0435\u0445\u043E\u0434
    \u043E\u0442 \u0443\u043C\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0430\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F. 
    *   **\u0417\u0430\u043A\u043E\u043D \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0433\u043E
    \u043F\u0430\u0434\u0435\u043D\u0438\u044F.** \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E
    (\u043A\u0430\u0442\u0430\u044F \u0448\u0430\u0440\u044B \u043F\u043E \u043D\u0430\u043A\u043B\u043E\u043D\u043D\u044B\u043C
    \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u044F\u043C, \u0447\u0442\u043E\u0431\u044B
    \u0437\u0430\u043C\u0435\u0434\u043B\u0438\u0442\u044C \u043F\u0430\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u044C \u0432\u0440\u0435\u043C\u044F)
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E **\u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C
    \u043F\u0430\u0434\u0430\u044E\u0449\u0435\u0433\u043E \u0442\u0435\u043B\u0430
    \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043F\u0430\u0434\u0435\u043D\u0438\u044F**,
    \u0430 **\u043F\u0440\u043E\u0439\u0434\u0435\u043D\u043D\u044B\u0439 \u043F\u0443\u0442\u044C
    \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u043E\u043D\u0430\u043B\u0435\u043D
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0443 \u0432\u0440\u0435\u043C\u0435\u043D\u0438**
    (\\( s \\propto t^2 \\)). \u0421\u0430\u043C\u043E\u0435 \u0432\u0430\u0436\u043D\u043E\u0435:
    \u043E\u043D \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B, \u0447\u0442\u043E
    **\u0443\u0441\u043A\u043E\u0440\u0435\u043D\u0438\u0435 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0433\u043E
    \u043F\u0430\u0434\u0435\u043D\u0438\u044F \u043D\u0435 \u0437\u0430\u0432\u0438\u0441\u0438\u0442
    \u043E\u0442 \u043C\u0430\u0441\u0441\u044B \u0442\u0435\u043B\u0430** (\u0432
    \u0432\u0430\u043A\u0443\u0443\u043C\u0435 \u043F\u0435\u0440\u043E \u0438 \u043F\u0443\u043B\u044F
    \u0443\u043F\u0430\u0434\u0443\u0442 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E),
    \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0432 \u0410\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u044F,
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0432\u0448\u0435\u0433\u043E,
    \u0447\u0442\u043E \u0442\u044F\u0436\u0435\u043B\u044B\u0435 \u0442\u0435\u043B\u0430
    \u043F\u0430\u0434\u0430\u044E\u0442 \u0431\u044B\u0441\u0442\u0440\u0435\u0435.
    *   **\u0414\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u043F\u043E \u0438\u043D\u0435\u0440\u0446\u0438\u0438
    (\u0417\u0430\u043A\u043E\u043D \u0438\u043D\u0435\u0440\u0446\u0438\u0438).**
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043E\u0442\u043A\u0440\u044B\u043B
    **\u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438**:
    \u0435\u0441\u043B\u0438 \u0442\u0435\u043B\u043E \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F
    \u043F\u043E \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E \u0433\u043B\u0430\u0434\u043A\u043E\u0439
    \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438 \u0438 \u043D\u0430 \u043D\u0435\u0433\u043E
    \u043D\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u044E\u0442 \u0441\u0438\u043B\u044B
    (\u0442\u0440\u0435\u043D\u0438\u0435), \u043E\u043D\u043E \u0431\u0443\u0434\u0435\u0442
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0442\u044C \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F
    \u0432\u0435\u0447\u043D\u043E \u0441 \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E\u0439
    \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E. \u041F\u043E \u0441\u0443\u0442\u0438,
    \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\u0438\u043D\u0435\u0440\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043E\u0442\u0441\u0447\u0435\u0442\u0430**
    \u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u043F\u043E\u043A\u043E\u044F \u0438 \u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0433\u043E
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435\u0440\u0430\u0437\u043B\u0438\u0447\u0438\u043C\u044B. *   **\u0411\u0430\u043B\u043B\u0438\u0441\u0442\u0438\u043A\u0430
    (\u0414\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u0441\u043D\u0430\u0440\u044F\u0434\u043E\u0432).**
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043E\u0442\u043A\u0440\u044B\u043B,
    \u0447\u0442\u043E \u0442\u0435\u043B\u043E, \u0431\u0440\u043E\u0448\u0435\u043D\u043D\u043E\u0435
    \u043F\u043E\u0434 \u0443\u0433\u043B\u043E\u043C \u043A \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0443,
    \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F \u043F\u043E **\u043F\u0430\u0440\u0430\u0431\u043E\u043B\u0435**.
    \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u044D\u0442\u043E
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u043C\u043E\u0436\u043D\u043E
    \u0440\u0430\u0437\u043B\u043E\u0436\u0438\u0442\u044C \u043D\u0430 \u0434\u0432\u0430
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u044B\u0445: \u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0435
    \u043F\u043E \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u0438
    \u0438 \u0440\u0430\u0432\u043D\u043E\u0443\u0441\u043A\u043E\u0440\u0435\u043D\u043D\u043E\u0435
    \u043F\u043E \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u0438. \u042D\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u0434\u0435\u043B\u0430 \u0438 \u043D\u0435\u0431\u0435\u0441\u043D\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438. *   **\u0421\u043E\u043F\u0440\u043E\u0442\u0438\u0432\u043B\u0435\u043D\u0438\u0435
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432.** \u0412 \u0442\u0440\u0443\u0434\u0435
    \xAB\u0411\u0435\u0441\u0435\u0434\u044B...\xBB \u043E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u043D\u0430\u0443\u043A\u0438 \u043E \u043F\u0440\u043E\u0447\u043D\u043E\u0441\u0442\u0438
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432, \u0432\u044B\u0432\u0435\u0434\u044F
    \u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u044C \u043F\u0440\u043E\u0447\u043D\u043E\u0441\u0442\u0438
    \u0431\u0430\u043B\u043A\u0438 \u043E\u0442 \u0435\u0435 \u043F\u043E\u043F\u0435\u0440\u0435\u0447\u043D\u043E\u0433\u043E
    \u0441\u0435\u0447\u0435\u043D\u0438\u044F \u0438 \u0434\u043B\u0438\u043D\u044B. 
    ### 2. \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F (\u0422\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F)  \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043D\u0435 \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F,
    \u043D\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u043D **\u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0434\u043E \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430
    \u043D\u0430\u0443\u043A\u0438** (\u0441 3-\u043A\u0440\u0430\u0442\u043D\u044B\u043C
    \u0434\u043E 32-\u043A\u0440\u0430\u0442\u043D\u043E\u0433\u043E \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u0438\u044F)
    \u0438 \u043F\u0435\u0440\u0432\u044B\u043C \u043D\u0430\u043F\u0440\u0430\u0432\u0438\u043B
    \u0435\u0433\u043E \u043D\u0430 \u043D\u0435\u0431\u043E \u0432 1609\u20131610
    \u0433\u043E\u0434\u0430\u0445. \u0417\u0430 \u043E\u0434\u0438\u043D \u0433\u043E\u0434
    \u043E\u043D \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u043B \u0430\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E
    \u043A\u0430\u0440\u0442\u0438\u043D\u0443 \u043C\u0438\u0440\u0430:  *   **\u041B\u0443\u043D\u0430.**
    \u041E\u043D \u0443\u0432\u0438\u0434\u0435\u043B, \u0447\u0442\u043E \u041B\u0443\u043D\u0430
    \u0433\u043E\u0440\u0438\u0441\u0442\u0430, \u043F\u043E\u043A\u0440\u044B\u0442\u0430
    \u043A\u0440\u0430\u0442\u0435\u0440\u0430\u043C\u0438 \u0438 \xAB\u043C\u043E\u0440\u044F\u043C\u0438\xBB.
    \u042D\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E, \u0447\u0442\u043E
    \u043D\u0435\u0431\u0435\u0441\u043D\u044B\u0435 \u0442\u0435\u043B\u0430 \u043D\u0435
    \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F \xAB\u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u043C\u0438 \u0441\u0444\u0435\u0440\u0430\u043C\u0438\xBB,
    \u0430 \u0438\u043C\u0435\u044E\u0442 \u0437\u0435\u043C\u043D\u0443\u044E \u043F\u0440\u0438\u0440\u043E\u0434\u0443.
    *   **\u0421\u043F\u0443\u0442\u043D\u0438\u043A\u0438 \u042E\u043F\u0438\u0442\u0435\u0440\u0430
    (\u041C\u0435\u0434\u0438\u0446\u0435\u0439\u0441\u043A\u0438\u0435 \u0437\u0432\u0435\u0437\u0434\u044B).**
    \u041E\u0442\u043A\u0440\u044B\u043B 4 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0445
    \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430 (\u0418\u043E, \u0415\u0432\u0440\u043E\u043F\u0430,
    \u0413\u0430\u043D\u0438\u043C\u0435\u0434, \u041A\u0430\u043B\u043B\u0438\u0441\u0442\u043E).
    \u042D\u0442\u043E \u0431\u044B\u043B \u0440\u0435\u0448\u0430\u044E\u0449\u0438\u0439
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442 \u043F\u0440\u043E\u0442\u0438\u0432
    \u0433\u0435\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0437\u043C\u0430: \u0435\u0441\u043B\u0438
    \u0432\u043E\u043A\u0440\u0443\u0433 \u042E\u043F\u0438\u0442\u0435\u0440\u0430
    \u0432\u0440\u0430\u0449\u0430\u044E\u0442\u0441\u044F \u0442\u0435\u043B\u0430,
    \u0437\u043D\u0430\u0447\u0438\u0442, \u0417\u0435\u043C\u043B\u044F \u043D\u0435
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u0432\u043E \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439. *   **\u0424\u0430\u0437\u044B
    \u0412\u0435\u043D\u0435\u0440\u044B.** \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043E\u0442\u043A\u0440\u044B\u043B, \u0447\u0442\u043E \u0412\u0435\u043D\u0435\u0440\u0430
    \u0441\u043C\u0435\u043D\u044F\u0435\u0442 \u0441\u0432\u043E\u0438 \u0444\u0430\u0437\u044B
    \u043E\u0442 \u0443\u0437\u043A\u043E\u0433\u043E \u0441\u0435\u0440\u043F\u0430
    \u0434\u043E \u043F\u043E\u043B\u043D\u043E\u0433\u043E \u0434\u0438\u0441\u043A\u0430
    (\u043A\u0430\u043A \u041B\u0443\u043D\u0430). \u0412 \u0441\u0438\u0441\u0442\u0435\u043C\u0435
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F \u044D\u0442\u043E \u0431\u044B\u043B\u043E
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u043C, \u0430 \u0432
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435 \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430
    \u2014 \u043B\u0435\u0433\u043A\u043E \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043C\u044B\u043C.
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u0441\u0430\u043C\u044B\u043C \u0443\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0412\u0435\u043D\u0435\u0440\u0430
    \u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F \u0432\u043E\u043A\u0440\u0443\u0433
    \u0421\u043E\u043B\u043D\u0446\u0430, \u0430 \u043D\u0435 \u0432\u043E\u043A\u0440\u0443\u0433
    \u0417\u0435\u043C\u043B\u0438. *   **\u0421\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0435
    \u043F\u044F\u0442\u043D\u0430.** \u041D\u0430\u0431\u043B\u044E\u0434\u0430\u044F
    \u0437\u0430 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435\u043C \u043F\u044F\u0442\u0435\u043D,
    \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0421\u043E\u043B\u043D\u0446\u0435
    \u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F \u0432\u043E\u043A\u0440\u0443\u0433
    \u0441\u0432\u043E\u0435\u0439 \u043E\u0441\u0438. \u0422\u0430\u043A\u0436\u0435
    \u043E\u043D \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u043F\u044F\u0442\u043D\u0430
    \u0438\u043C\u0435\u044E\u0442 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u0443\u044E
    \u043F\u0440\u0438\u0440\u043E\u0434\u0443, \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0432
    \u043C\u043D\u0435\u043D\u0438\u0435 \u043E \xAB\u043D\u0435\u0438\u0437\u043C\u0435\u043D\u043D\u043E\u0441\u0442\u0438\xBB
    \u043D\u0435\u0431\u0435\u0441. *   **\u0417\u0432\u0435\u0437\u0434\u043D\u043E\u0435
    \u043D\u0435\u0431\u043E.** \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u0443\u0432\u0438\u0434\u0435\u043B,
    \u0447\u0442\u043E \u041C\u043B\u0435\u0447\u043D\u044B\u0439 \u041F\u0443\u0442\u044C
    \u2014 \u044D\u0442\u043E \u043D\u0435 \xAB\u043C\u043E\u043B\u043E\u0447\u043D\u0430\u044F
    \u0440\u0435\u043A\u0430\xBB, \u0430 \u0441\u043A\u043E\u043F\u043B\u0435\u043D\u0438\u0435
    \u0431\u0435\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u0441\u043B\u0430\u0431\u044B\u0445
    \u0437\u0432\u0435\u0437\u0434.  ### 3. \u041C\u0435\u0442\u043E\u0434\u043E\u043B\u043E\u0433\u0438\u044F
    \u043D\u0430\u0443\u043A\u0438 (\u041D\u0430\u0443\u0447\u043D\u044B\u0439 \u043C\u0435\u0442\u043E\u0434) 
    \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0432\u0430\u0436\u043D\u0435\u0435
    \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0445 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439
    \u0431\u044B\u043B\u043E \u0442\u043E, \u043A\u0430\u043A \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0438\u0445 \u0441\u0434\u0435\u043B\u0430\u043B. \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    **\u043E\u0442\u0446\u043E\u043C \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438**.  *   **\u0418\u0434\u0435\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442 (\u041C\u044B\u0441\u043B\u0435\u043D\u043D\u044B\u0439
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442).** \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B \u043C\u0435\u0442\u043E\u0434
    \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u0431\u044B\u043B\u043E
    \u043F\u0440\u043E\u0432\u0435\u0441\u0442\u0438 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432 \u0442\u0443 \u044D\u043F\u043E\u0445\u0443, \u043D\u043E \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B
    \u0430\u0431\u0441\u0443\u0440\u0434\u043D\u043E\u0441\u0442\u044C \u0441\u0442\u0430\u0440\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043C\u044B\u0441\u043B\u0435\u043D\u043D\u044B\u0439 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442
    \u043E \u0434\u0432\u0443\u0445 \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445
    \u043A\u0430\u043C\u043D\u044F\u0445, \u043F\u0430\u0434\u0430\u044E\u0449\u0438\u0445
    \u0441 \u0440\u0430\u0437\u043D\u043E\u0439 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C\u044E,
    \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B, \u0447\u0442\u043E \u0432\u0441\u0435
    \u0442\u0435\u043B\u0430 \u0434\u043E\u043B\u0436\u043D\u044B \u043F\u0430\u0434\u0430\u0442\u044C
    \u0441 \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u044B\u043C \u0443\u0441\u043A\u043E\u0440\u0435\u043D\u0438\u0435\u043C.
    *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u044F
    \u0444\u0438\u0437\u0438\u043A\u0438.** \u041E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F: \xAB\u041A\u043D\u0438\u0433\u0430
    \u043F\u0440\u0438\u0440\u043E\u0434\u044B \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u0430
    \u043D\u0430 \u044F\u0437\u044B\u043A\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB.
    \u041E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u043B
    \u044F\u0432\u043B\u0435\u043D\u0438\u044F, \u0430 \u0438\u0437\u043C\u0435\u0440\u044F\u043B
    \u0438\u0445 (\u0432\u0440\u0435\u043C\u044F, \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435,
    \u0443\u0433\u043E\u043B) \u0438 \u0432\u044B\u0432\u043E\u0434\u0438\u043B \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0437\u0430\u043A\u043E\u043D\u044B, \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u043C\u044B\u0435
    \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u043C\u0438. *   **\u041F\u0440\u0438\u043D\u0446\u0438\u043F
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F.** \u0421\u0442\u0440\u043E\u0433\u0430\u044F
    \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0430: \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u0430\u043A\u043E\u043D\u044B \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u044B
    \u0432\u043E \u0432\u0441\u0435\u0445 \u0438\u043D\u0435\u0440\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0445 \u043E\u0442\u0441\u0447\u0435\u0442\u0430.
    \u042D\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442, \u0447\u0442\u043E
    \u043D\u0438 \u043E\u0434\u0438\u043D \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442 (\u0431\u0440\u043E\u0441\u0430\u043D\u0438\u0435
    \u043C\u044F\u0447\u0430, \u043F\u0430\u0434\u0435\u043D\u0438\u0435 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430)
    \u0432\u043D\u0443\u0442\u0440\u0438 \u0437\u0430\u043A\u0440\u044B\u0442\u043E\u0433\u043E
    \u043A\u043E\u0440\u0430\u0431\u043B\u044F, \u0434\u0432\u0438\u0436\u0443\u0449\u0435\u0433\u043E\u0441\u044F
    \u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u043E, \u043D\u0435 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442
    \u0432\u0430\u043C \u0443\u0437\u043D\u0430\u0442\u044C, \u0441\u0442\u043E\u0438\u0442\u0435
    \u043B\u0438 \u0432\u044B \u043D\u0430 \u043C\u0435\u0441\u0442\u0435 \u0438\u043B\u0438
    \u043F\u043B\u044B\u0432\u0435\u0442\u0435.  ### 4. \u0414\u0440\u0443\u0433\u0438\u0435
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F \u0438 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B
    (\u041A\u043E\u0441\u0432\u0435\u043D\u043D\u044B\u0435 \u0432\u043A\u043B\u0430\u0434\u044B) 
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u043B\u0441\u044F
    \u0442\u0435\u043E\u0440\u0438\u0435\u0439, \u043E\u043D \u0431\u044B\u043B \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u043C
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C:  *   **\u0413\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u0435\u0441\u044B.** \u0418\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u044B
    \u0432 1586 \u0433\u043E\u0434\u0443 \u0434\u043B\u044F \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u043B\u043E\u0442\u043D\u043E\u0441\u0442\u0438 \u0438 \u0441\u043E\u0441\u0442\u0430\u0432\u0430
    \u043C\u0435\u0442\u0430\u043B\u043B\u043E\u0432. *   **\u0422\u0435\u0440\u043C\u043E\u0441\u043A\u043E\u043F
    (\u041F\u0440\u043E\u043E\u0431\u0440\u0430\u0437 \u0442\u0435\u0440\u043C\u043E\u043C\u0435\u0442\u0440\u0430).**
    \u041E\u043A\u043E\u043B\u043E 1593 \u0433\u043E\u0434\u0430 \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u043F\u0440\u0438\u0431\u043E\u0440, \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0449\u0438\u0439
    \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0442\u0435\u043C\u043F\u0435\u0440\u0430\u0442\u0443\u0440\u044B
    \u0432\u043E\u0437\u0434\u0443\u0445\u0430 (\u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435
    \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u044F \u0433\u0430\u0437\u0430).
    *   **\u041C\u0438\u043A\u0440\u043E\u0441\u043A\u043E\u043F.** \u041E\u043D
    \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044E \u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u0434\u043B\u044F \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F
    \u043D\u0430\u0441\u0435\u043A\u043E\u043C\u044B\u0445. *   **\u0426\u0438\u0440\u043A\u0443\u043B\u044C.**
    \u0418\u0437\u043E\u0431\u0440\u0435\u043B \u0432\u043E\u0435\u043D\u043D\u044B\u0439
    \u0446\u0438\u0440\u043A\u0443\u043B\u044C-\u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u043E\u043D\u0430\u043B
    \u0434\u043B\u044F \u0431\u044B\u0441\u0442\u0440\u043E\u0433\u043E \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u043A\u043E\u0440\u043D\u0435\u0439 \u0438 \u043F\u043B\u043E\u0449\u0430\u0434\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u043E\u0434\u0430\u0432\u0430\u043B\u0441\u044F
    \u043A\u0430\u043A \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E \u0434\u043B\u044F
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u0432 \u0438 \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u0441\u0442\u043E\u0432. 
    ### 5. \u0412\u043A\u043B\u0430\u0434 \u0432 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E
    \u0438 \u0431\u043E\u0440\u044C\u0431\u0430 \u0437\u0430 \u0441\u0432\u043E\u0431\u043E\u0434\u0443
    \u043D\u0430\u0443\u043A\u0438  \u0425\u043E\u0442\u044F \u044D\u0442\u043E \u0438
    \u043D\u0435 \u0444\u0438\u0437\u0438\u043A\u0430, \u0435\u0433\u043E \u044D\u043F\u0438\u0441\u0442\u043E\u043B\u044F\u0440\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0438 \u0437\u0430\u0449\u0438\u0442\u0430
    \u0433\u0435\u043B\u0438\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0437\u043C\u0430
    \u0438\u043C\u0435\u044E\u0442 \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435:  *   **\u041F\u0440\u0438\u043D\u0446\u0438\u043F
    \u0442\u043E\u043B\u043A\u043E\u0432\u0430\u043D\u0438\u044F \u041F\u0438\u0441\u0430\u043D\u0438\u044F.**
    \u0412 \u043F\u0438\u0441\u044C\u043C\u0430\u0445 \u043A \u041A\u0430\u0441\u0442\u0435\u043B\u043B\u0438
    \u0438 \u0434\u2019\u042D\u0441\u0442\u0438 \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0442\u0435\u0437\u0438\u0441: **\u0421\u0432\u044F\u0449\u0435\u043D\u043D\u043E\u0435
    \u041F\u0438\u0441\u0430\u043D\u0438\u0435 \u0443\u0447\u0438\u0442, \u043A\u0430\u043A
    \u043F\u043E\u043F\u0430\u0441\u0442\u044C \u043D\u0430 \u043D\u0435\u0431\u043E,
    \u043D\u043E \u043D\u0435 \u0442\u043E\u043C\u0443, \u043A\u0430\u043A \u0443\u0441\u0442\u0440\u043E\u0435\u043D\u043E
    \u043D\u0435\u0431\u043E.** \u041E\u043D \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u043B,
    \u0447\u0442\u043E \u0442\u0430\u043C, \u0433\u0434\u0435 \u0411\u0438\u0431\u043B\u0438\u044F
    \u0432\u0441\u0442\u0443\u043F\u0430\u0435\u0442 \u0432 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0435
    \u0441 \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u043D\u044B\u043C\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438
    \u0444\u0430\u043A\u0442\u0430\u043C\u0438, \u0441\u043B\u0435\u0434\u0443\u0435\u0442
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C \u0430\u043B\u043B\u0435\u0433\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0442\u043E\u043B\u043A\u043E\u0432\u0430\u043D\u0438\u0435. \u042D\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u043E\u0442\u043F\u0440\u0430\u0432\u043D\u043E\u0439
    \u0442\u043E\u0447\u043A\u043E\u0439 \u0434\u043B\u044F \u0434\u0438\u0430\u043B\u043E\u0433\u0430
    \u043D\u0430\u0443\u043A\u0438 \u0438 \u0440\u0435\u043B\u0438\u0433\u0438\u0438. 
    ---  ### \u041A\u0440\u0430\u0442\u043A\u0438\u0439 \u0438\u0442\u043E\u0433:
    \u0427\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u0442\u043A\u0440\u044B\u043B
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439?  \u0414\u043B\u044F \u0443\u0434\u043E\u0431\u0441\u0442\u0432\u0430
    \u043F\u0435\u0440\u0435\u0447\u0438\u0441\u043B\u0438\u043C \u0435\u0433\u043E
    \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435 \xAB\u0447\u0435\u043C\u043F\u0438\u043E\u043D\u0441\u043A\u0438\u0435\xBB
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u0432 \u0432\u0438\u0434\u0435
    \u0441\u043F\u0438\u0441\u043A\u0430:  1.  **\u0418\u043D\u0435\u0440\u0446\u0438\u044F:**
    \u0422\u0435\u043B\u043E \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F \u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u043E,
    \u0435\u0441\u043B\u0438 \u043D\u0435 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0430
    \u0441\u0438\u043B\u0430. 2.  **\u0420\u0430\u0432\u043D\u043E\u0443\u0441\u043A\u043E\u0440\u0435\u043D\u043D\u043E\u0435
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435:** \u0421\u043A\u043E\u0440\u043E\u0441\u0442\u044C
    \u043F\u0430\u0434\u0435\u043D\u0438\u044F \u0440\u0430\u0441\u0442\u0435\u0442
    \u043B\u0438\u043D\u0435\u0439\u043D\u043E, \u043F\u0443\u0442\u044C \u2014 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u043E.
    3.  **\u041D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u044C
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0439:** \u0413\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0438 \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u0430\u044F
    \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0449\u0438\u0435 \u043F\u043E\u043B\u0435\u0442\u0430
    \u0441\u043D\u0430\u0440\u044F\u0434\u0430 \u043D\u0435 \u0432\u043B\u0438\u044F\u044E\u0442
    \u0434\u0440\u0443\u0433 \u043D\u0430 \u0434\u0440\u0443\u0433\u0430. 4.  **\u0413\u043E\u0440\u044B
    \u043D\u0430 \u041B\u0443\u043D\u0435:** \u041D\u0435\u0431\u0435\u0441\u0430
    \u043D\u0435\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u044B. 5. 
    **\u0421\u043F\u0443\u0442\u043D\u0438\u043A\u0438 \u042E\u043F\u0438\u0442\u0435\u0440\u0430:**
    \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442 \u0446\u0435\u043D\u0442\u0440\u044B
    \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F, \u043E\u0442\u043B\u0438\u0447\u043D\u044B\u0435
    \u043E\u0442 \u0417\u0435\u043C\u043B\u0438. 6.  **\u0424\u0430\u0437\u044B \u0412\u0435\u043D\u0435\u0440\u044B:**
    \u0412\u0435\u043D\u0435\u0440\u0430 \u0442\u043E\u0447\u043D\u043E \u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F
    \u0432\u043E\u043A\u0440\u0443\u0433 \u0421\u043E\u043B\u043D\u0446\u0430. 7. 
    **\u0412\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0421\u043E\u043B\u043D\u0446\u0430:**
    \u0414\u043E\u043A\u0430\u0437\u0430\u043D\u043E \u043F\u044F\u0442\u043D\u0430\u043C\u0438. 
    **\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0438\u0442\u043E\u0433:** \u0414\u043E
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u0444\u0438\u0437\u0438\u043A\u0430
    \u0431\u044B\u043B\u0430 \u0432\u0435\u0442\u0432\u044C\u044E \u043D\u0430\u0442\u0443\u0440\u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438.
    \u041F\u043E\u0441\u043B\u0435 \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u043E\u043D\u0430
    \u0441\u0442\u0430\u043B\u0430 **\u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u043D\u0430\u0443\u043A\u043E\u0439**, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u043D\u0430 \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0438, \u0440\u0430\u0441\u0447\u0435\u0442\u0435
    \u0438 \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0435 \u0433\u0438\u043F\u043E\u0442\u0435\u0437.
    \u0411\u0435\u0437 \u0435\u0433\u043E \xAB\u0411\u0435\u0441\u0435\u0434\xBB
    \u043D\u0435 \u0431\u044B\u043B\u043E \u0431\u044B \u0437\u0430\u043A\u043E\u043D\u043E\u0432
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430, \u0430 \u0431\u0435\u0437 \u0435\u0433\u043E
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u043D\u0435 \u0431\u044B\u043B\u043E \u0431\u044B \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430 (\u043A\u043E\u0442\u043E\u0440\u0430\u044F,
    \u043A\u0441\u0442\u0430\u0442\u0438, \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043F\u0440\u044F\u043C\u044B\u043C \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435\u043C
    \u0435\u0433\u043E \u0436\u0435 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430)."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0413\u0430\u043B\u0438\u043B\u0435\u043E \u0413\u0430\u043B\u0438\u043B\u0435\u044F
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F, \u043F\u043E\u043B\u043D\u0430\u044F
    \u044F\u0440\u043A\u0438\u0445 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0440\u0430\u0437\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u043B\u0430\u0441\u044C
    \u043D\u0430 \u0444\u043E\u043D\u0435 \u0435\u0433\u043E \u0433\u0440\u043E\u043C\u043A\u0438\u0445
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439
    \u0438 \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0430 \u0441 \u0446\u0435\u0440\u043A\u043E\u0432\u044C\u044E.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0430
    \u043A\u0430\u043A \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0441\u043B\u043E\u0436\u043D\u044B\u043C \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C,
    \u0442\u0430\u043A \u0438 \u0441\u0442\u0440\u043E\u0433\u0438\u043C\u0438 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u043D\u043E\u0440\u043C\u0430\u043C\u0438 \u0418\u0442\u0430\u043B\u0438\u0438
    XVII \u0432\u0435\u043A\u0430.  ### \u0421\u0435\u043C\u044C\u044F \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435 
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u043E\u0431\u0435\u0434\u043D\u0435\u0432\u0448\u0438\u0445
    \u0434\u0432\u043E\u0440\u044F\u043D. \u0415\u0433\u043E \u043E\u0442\u0446\u043E\u043C
    \u0431\u044B\u043B \u0412\u0438\u043D\u0447\u0435\u043D\u0446\u043E \u0413\u0430\u043B\u0438\u043B\u0435\u0439,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043C\u0443\u0437\u044B\u043A\u0430\u043D\u0442,
    \u043B\u044E\u0442\u043D\u0438\u0441\u0442 \u0438 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A
    \u043C\u0443\u0437\u044B\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043A\u0430\u0437\u0430\u043B \u0431\u043E\u043B\u044C\u0448\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0440\u0430\u043D\u043D\u0435\u0435
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0441\u044B\u043D\u0430. \u0412
    \u0441\u0435\u043C\u044C\u0435 \u0412\u0438\u043D\u0447\u0435\u043D\u0446\u043E
    \u0438 \u0414\u0436\u0443\u043B\u0438\u0438 \u0410\u043C\u043C\u0430\u043D\u043D\u0430\u0442\u0438
    \u0431\u044B\u043B\u043E \u0448\u0435\u0441\u0442\u0435\u0440\u043E \u0434\u0435\u0442\u0435\u0439,
    \u043D\u043E \u0432\u044B\u0436\u0438\u0442\u044C \u0443\u0434\u0430\u043B\u043E\u0441\u044C
    \u0447\u0435\u0442\u0432\u0435\u0440\u044B\u043C. \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0431\u044B\u043B \u0441\u0442\u0430\u0440\u0448\u0438\u043C \u0438\u0437 \u043D\u0438\u0445,
    \u0443 \u043D\u0435\u0433\u043E \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B\u0438
    \u0441\u0435\u0441\u0442\u0440\u044B \u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F
    \u0438 \u041B\u0438\u0432\u0438\u044F \u0438 \u043C\u043B\u0430\u0434\u0448\u0438\u0439
    \u0431\u0440\u0430\u0442 \u041C\u0438\u043A\u0435\u043B\u0430\u043D\u0434\u0436\u0435\u043B\u043E,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0448\u0435\u043B \u043F\u043E
    \u0441\u0442\u043E\u043F\u0430\u043C \u043E\u0442\u0446\u0430 \u0438 \u0441\u0442\u0430\u043B
    \u043A\u043E\u043C\u043F\u043E\u0437\u0438\u0442\u043E\u0440\u043E\u043C-\u043B\u044E\u0442\u043D\u0438\u0441\u0442\u043E\u043C.
    \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u0442\u0446\u0430
    \u0432 1591 \u0433\u043E\u0434\u0443 \u043D\u0430 \u0413\u0430\u043B\u0438\u043B\u0435\u044F,
    \u043A\u0430\u043A \u043D\u0430 \u0441\u0442\u0430\u0440\u0448\u0435\u0433\u043E
    \u0432 \u0440\u043E\u0434\u0443, \u043B\u0435\u0433\u043B\u0430 \u043E\u0431\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u044C
    \u0437\u0430\u0431\u043E\u0442\u0438\u0442\u044C\u0441\u044F \u043E \u0441\u0435\u043C\u044C\u0435,
    \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432\u0430\u0442\u044C
    \u043F\u0440\u0438\u0434\u0430\u043D\u043E\u0435 \u0434\u043B\u044F \u0441\u0435\u0441\u0442\u0435\u0440,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0434\u043B\u044F \u043D\u0435\u0433\u043E
    \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u043C \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u043C
    \u0431\u0440\u0435\u043C\u0435\u043D\u0435\u043C.  ### \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u041C\u0430\u0440\u0438\u043D\u043E\u0439 \u0413\u0430\u043C\u0431\u0430
    \u0438 \u0434\u0435\u0442\u0438  \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0431\u044B\u043B \u0436\u0435\u043D\u0430\u0442, \u043E\u0434\u043D\u0430\u043A\u043E
    \u0443 \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u0438 \u0434\u043E\u043B\u0433\u0438\u0435
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 **\u041C\u0430\u0440\u0438\u043D\u043E\u0439
    \u0413\u0430\u043C\u0431\u0430 (Marina Gamba)** \u2014 \u0432\u0435\u043D\u0435\u0446\u0438\u0430\u043D\u043A\u043E\u0439,
    \u0441 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0441\u0432\u043E\u0435\u0433\u043E
    \u043F\u0440\u0435\u0431\u044B\u0432\u0430\u043D\u0438\u044F \u0432 \u041F\u0430\u0434\u0443\u0435.
    \u042D\u0442\u043E\u0442 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u0438\u0439
    \u0441\u043E\u044E\u0437 \u043F\u0440\u043E\u0434\u043B\u0438\u043B\u0441\u044F
    \u043E\u043A\u043E\u043B\u043E \u0434\u0435\u0441\u044F\u0442\u0438 \u043B\u0435\u0442.
    \u0412 \u044D\u0442\u0438\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u0445
    \u0443 \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C
    \u0442\u0440\u043E\u0435 \u0434\u0435\u0442\u0435\u0439, \u043F\u0440\u0438\u0447\u0435\u043C
    \u0432\u0441\u0435 \u043E\u043D\u0438 \u0431\u044B\u043B\u0438 \u0440\u043E\u0436\u0434\u0435\u043D\u044B
    \u0432\u043D\u0435 \u0431\u0440\u0430\u043A\u0430:  *   **\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F
    (Virginia)** (\u0440\u043E\u0434. 1600) \u2014 \u0441\u0442\u0430\u0440\u0448\u0430\u044F
    \u0434\u043E\u0447\u044C \u0438 \u043B\u044E\u0431\u0438\u043C\u0438\u0446\u0430
    \u043E\u0442\u0446\u0430. *   **\u041B\u0438\u0432\u0438\u044F (Livia)** (\u0440\u043E\u0434.
    1601) \u2014 \u0432\u0442\u043E\u0440\u0430\u044F \u0434\u043E\u0447\u044C. *  
    **\u0412\u0438\u043D\u0447\u0435\u043D\u0446\u043E (Vincenzo)** (\u0440\u043E\u0434.
    1606) \u2014 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0441\u044B\u043D, \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u044B\u0439 \u0432
    \u0447\u0435\u0441\u0442\u044C \u0434\u0435\u0434\u0430.  \u041B\u0438\u0448\u044C
    \u0432 1619 \u0433\u043E\u0434\u0443 \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u043B
    \u0438 \u0443\u0437\u0430\u043A\u043E\u043D\u0438\u043B \u0441\u0432\u043E\u0435\u0433\u043E
    \u0441\u044B\u043D\u0430 \u0412\u0438\u043D\u0447\u0435\u043D\u0446\u043E , \u0447\u0442\u043E
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0442\u043E\u043C\u0443
    \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u0436\u0435\u043D\u0438\u0442\u044C\u0441\u044F
    \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C \u0440\u043E\u0434. 
    ### \u0421\u0443\u0434\u044C\u0431\u0430 \u0434\u043E\u0447\u0435\u0440\u0435\u0439:
    \u043F\u043E\u0441\u0442\u0440\u0438\u0433 \u0432 \u043C\u043E\u043D\u0430\u0445\u0438\u043D\u0438 
    \u0421\u0443\u0434\u044C\u0431\u0430 \u0434\u043E\u0447\u0435\u0440\u0435\u0439
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u0441\u043B\u043E\u0436\u0438\u043B\u0430\u0441\u044C
    \u0438\u043D\u0430\u0447\u0435. \u0418\u0437-\u0437\u0430 \u0438\u0445 \u043D\u0435\u0437\u0430\u043A\u043E\u043D\u043D\u043E\u0433\u043E
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F
    \u043E\u043D\u0438 \u0441\u0447\u0438\u0442\u0430\u043B\u0438\u0441\u044C \u043D\u0435\u043F\u043E\u0434\u0445\u043E\u0434\u044F\u0449\u0438\u043C\u0438
    \u0434\u043B\u044F \u0432\u044B\u0433\u043E\u0434\u043D\u043E\u0433\u043E \u0437\u0430\u043C\u0443\u0436\u0435\u0441\u0442\u0432\u0430,
    \u0430 \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0442\u044C \u0438\u0445
    \u0434\u043E\u0441\u0442\u043E\u0439\u043D\u044B\u043C \u043F\u0440\u0438\u0434\u0430\u043D\u044B\u043C
    \u0431\u044B\u043B\u043E \u0434\u043B\u044F \u0413\u0430\u043B\u0438\u043B\u0435\u044F
    \u043D\u0435\u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0440\u043E\u0441\u043A\u043E\u0448\u044C\u044E, \u0443\u0447\u0438\u0442\u044B\u0432\u0430\u044F
    \u0435\u0433\u043E \u0438 \u0431\u0435\u0437 \u0442\u043E\u0433\u043E \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0435
    \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0435 \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043F\u0435\u0440\u0435\u0434 \u0441\u0435\u0441\u0442\u0440\u0430\u043C\u0438.
    \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u043F\u0440\u0438\u0435\u043C\u043B\u0435\u043C\u044B\u043C
    \u0432\u044B\u0445\u043E\u0434\u043E\u043C \u0434\u043B\u044F \u0434\u0435\u0432\u0443\u0448\u0435\u043A
    \u0438\u0437 \u0442\u0430\u043A\u043E\u0439 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438
    \u0431\u044B\u043B\u0430 \u043C\u043E\u043D\u0430\u0448\u0435\u0441\u043A\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C. \u041E\u0431\u0435 \u0434\u043E\u0447\u0435\u0440\u0438
    \u0431\u044B\u043B\u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u044B
    \u0432 \u0431\u0435\u0434\u043D\u044B\u0439 \u0444\u0440\u0430\u043D\u0446\u0438\u0441\u043A\u0430\u043D\u0441\u043A\u0438\u0439
    \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u044C \u0421\u0430\u043D-\u041C\u0430\u0442\u0442\u0435\u043E
    \u0432 \u0410\u0440\u0447\u0435\u0442\u0440\u0438, \u0433\u0434\u0435 \u043F\u0440\u043E\u0432\u0435\u043B\u0438
    \u0432\u0441\u044E \u0441\u0432\u043E\u044E \u0436\u0438\u0437\u043D\u044C. 
    *   **\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F**, \u043F\u0440\u0438\u043D\u044F\u0432\u0448\u0430\u044F
    \u0438\u043C\u044F **\u041C\u0430\u0440\u0438\u044F \u0427\u0435\u043B\u0435\u0441\u0442\u0430
    (Suor Maria Celeste)**, \u0431\u044B\u043B\u0430, \u043F\u043E \u0432\u0441\u0435\u0439
    \u0432\u0438\u0434\u0438\u043C\u043E\u0441\u0442\u0438, \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435
    \u043E\u0434\u0430\u0440\u0435\u043D\u043D\u043E\u0439 \u0438\u0437 \u0434\u0435\u0442\u0435\u0439
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F. \u041E\u043D\u0430 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0430
    \u0441 \u043E\u0442\u0446\u043E\u043C \u0442\u0435\u043F\u043B\u044B\u0435 \u0438
    \u0431\u043B\u0438\u0437\u043A\u0438\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F,
    \u0447\u0442\u043E \u0445\u043E\u0440\u043E\u0448\u043E \u0432\u0438\u0434\u043D\u043E
    \u043F\u043E \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432\u0448\u0435\u0439\u0441\u044F
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435: \u0438\u0437 124 \u043F\u0438\u0441\u0435\u043C,
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0445 \u0435\u044E \u043E\u0442\u0446\u0443,
    \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0435\u0442 \u0437\u0430\u0431\u043E\u0442\u043B\u0438\u0432\u044B\u043C
    \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0440\u0435\u0433\u0443\u043B\u044F\u0440\u043D\u043E \u043F\u043E\u0441\u044B\u043B\u0430\u043B
    \u0435\u0439 \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u044B, \u0446\u0432\u0435\u0442\u044B
    \u0438 \u043F\u043E\u043C\u043E\u0433\u0430\u043B \u043F\u043E \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u0443
    \u0432 \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u0435 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0447\u0438\u043D\u0438\u043B \u0447\u0430\u0441\u044B \u0438 \u043E\u043A\u043D\u0430).
    \u041E\u043D\u0430, \u0432 \u0441\u0432\u043E\u044E \u043E\u0447\u0435\u0440\u0435\u0434\u044C,
    \u0448\u0438\u043B\u0430 \u0435\u043C\u0443 \u043E\u0434\u0435\u0436\u0434\u0443
    \u0438 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0430
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B. \u041F\u0438\u0441\u044C\u043C\u0430
    \u0441\u0430\u043C\u043E\u0433\u043E \u0413\u0430\u043B\u0438\u043B\u0435\u044F,
    \u0441\u043A\u043E\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043E, \u0431\u044B\u043B\u0438
    \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u044B \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u0435\u043C
    \u043F\u043E\u0441\u043B\u0435 \u0441\u0443\u0434\u0430 \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u0438
    1633 \u0433\u043E\u0434\u0430. \u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F-\u041C\u0430\u0440\u0438\u044F
    \u0427\u0435\u043B\u0435\u0441\u0442\u0430 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C
    \u0432 1634 \u0433\u043E\u0434\u0443, \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u0442\u044F\u0436\u0435\u043B\u044B\u043C \u0443\u0434\u0430\u0440\u043E\u043C
    \u0434\u043B\u044F \u0443\u0447\u0435\u043D\u043E\u0433\u043E. *   \u0412\u0442\u043E\u0440\u0430\u044F
    \u0434\u043E\u0447\u044C, **\u041B\u0438\u0432\u0438\u044F**, \u0432 \u043C\u043E\u043D\u0430\u0448\u0435\u0441\u0442\u0432\u0435
    **\u0410\u0440\u043A\u0430\u043D\u0434\u0436\u0435\u043B\u0430 (Suor Arcangela)**,
    \u0431\u044B\u043B\u0430 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u0434\u0440\u0443\u0433\u0438\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C.
    \u0418\u0437 \u043F\u0438\u0441\u0435\u043C \u0438 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043E\u043D\u0430
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0435\u0442 \u043A\u0430\u043A \u0441\u043B\u043E\u0436\u043D\u0430\u044F,
    \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u043D\u043D\u0430\u044F, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0441\u0442\u0440\u0430\u0434\u0430\u044E\u0449\u0430\u044F \u0438\u043F\u043E\u0445\u043E\u043D\u0434\u0440\u0438\u0435\u0439
    \u0438 \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u0438\u0437\u043C\u043E\u043C
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043D\u0435 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0430
    \u0441 \u043E\u0442\u0446\u043E\u043C \u0442\u0435\u0441\u043D\u044B\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0439. 
    ### \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0441\u044B\u043D\u043E\u043C 
    \u0412 1629 \u0433\u043E\u0434\u0443 \u0435\u0433\u043E \u0441\u044B\u043D \u0412\u0438\u043D\u0447\u0435\u043D\u0446\u043E
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u0438 \u043F\u043E\u0441\u0435\u043B\u0438\u043B\u0441\u044F
    \u0443 \u043E\u0442\u0446\u0430, \u0430 \u043D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
    \u0433\u043E\u0434 \u0443 \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432\u043D\u0443\u043A, \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u044B\u0439
    \u0432 \u0435\u0433\u043E \u0447\u0435\u0441\u0442\u044C. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0432\u0441\u043A\u043E\u0440\u0435 \u0412\u0438\u043D\u0447\u0435\u043D\u0446\u043E
    \u0441 \u0441\u0435\u043C\u044C\u0435\u0439 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B,
    \u0441\u043F\u0430\u0441\u0430\u044F\u0441\u044C \u043E\u0442 \u043E\u0447\u0435\u0440\u0435\u0434\u043D\u043E\u0439
    \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u0438 \u0447\u0443\u043C\u044B. \u0412
    \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u0435 1631 \u0433\u043E\u0434\u0430
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043F\u0435\u0440\u0435\u0431\u0440\u0430\u043B\u0441\u044F
    \u0432 \u0410\u0440\u0447\u0435\u0442\u0440\u0438, \u0447\u0442\u043E\u0431\u044B
    \u0431\u044B\u0442\u044C \u0431\u043B\u0438\u0436\u0435 \u043A \u043B\u044E\u0431\u0438\u043C\u043E\u0439
    \u0434\u043E\u0447\u0435\u0440\u0438 \u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u0438.
    \u041F\u043E\u0441\u043B\u0435 \u0441\u0443\u0434\u0430 1633 \u0433\u043E\u0434\u0430
    \u043E\u043D \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0441\u044F \u043F\u043E\u0434
    \u0434\u043E\u043C\u0430\u0448\u043D\u0438\u043C \u0430\u0440\u0435\u0441\u0442\u043E\u043C
    \u043D\u0430 \u0441\u0432\u043E\u0435\u0439 \u0432\u0438\u043B\u043B\u0435 \u0432
    \u0410\u0440\u0447\u0435\u0442\u0440\u0438 \u0438 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0442\u0430\u043C \u0436\u0435 \u0432 1642 \u0433\u043E\u0434\u0443 , \u043F\u0435\u0440\u0435\u0436\u0438\u0432
    \u0441\u0432\u043E\u044E \u043B\u044E\u0431\u0438\u043C\u0443\u044E \u0434\u043E\u0447\u044C
    \u043D\u0430 \u0432\u043E\u0441\u0435\u043C\u044C \u043B\u0435\u0442. \u041F\u043E
    \u0438\u0440\u043E\u043D\u0438\u0438 \u0441\u0443\u0434\u044C\u0431\u044B, \u043C\u0435\u0441\u0442\u043E
    \u0435\u0433\u043E \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F
    \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E
    \u043E\u0442 \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u044F, \u0433\u0434\u0435
    \u0436\u0438\u043B\u0438 \u0435\u0433\u043E \u0434\u043E\u0447\u0435\u0440\u0438."
  personalLifeEn: 
  shortBioRu: "\u0413\u0430\u043B\u0438\u043B\u0435\u043E \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0434\u0438\u043D
    \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043D\u0430\u0443\u043A\u0438,
    \u043D\u043E \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u0447\u044C\u044F
    \u0436\u0438\u0437\u043D\u044C \u0441\u0442\u0430\u043B\u0430 \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0430 \u043C\u0435\u0436\u0434\u0443
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u0435\u043C
    \u0438 \u0434\u043E\u0433\u043C\u0430\u0442\u0438\u0437\u043C\u043E\u043C. \u0415\u0433\u043E
    \u043F\u0443\u0442\u044C \u2014 \u043E\u0442 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0445
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439 \u0434\u043E \u0441\u0443\u0434\u0430
    \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u0438 \u0438 \u043E\u0442\u0440\u0435\u0447\u0435\u043D\u0438\u044F,
    \u2014 \u044D\u0442\u043E \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0430\u044E\u0442\u0441\u044F
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C, \u043C\u0443\u0436\u0435\u0441\u0442\u0432\u043E
    \u0438 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F.  \u041D\u0438\u0436\u0435
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430 \u0435\u0433\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F. 
    ### \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    (1564\u20131585)  \u0413\u0430\u043B\u0438\u043B\u0435\u043E \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 15 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    1564 \u0433\u043E\u0434\u0430 \u0432 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u0435 \u041F\u0438\u0437\u0430, \u0432 \u0437\u043D\u0430\u0442\u043D\u043E\u0439,
    \u043D\u043E \u043E\u0431\u0435\u0434\u043D\u0435\u0432\u0448\u0435\u0439 \u0434\u0432\u043E\u0440\u044F\u043D\u0441\u043A\u043E\u0439
    \u0441\u0435\u043C\u044C\u0435. \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u0412\u0438\u043D\u0447\u0435\u043D\u0446\u043E \u0413\u0430\u043B\u0438\u043B\u0435\u0439,
    \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C \u043C\u0443\u0437\u044B\u043A\u0430\u043D\u0442\u043E\u043C
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u0438
    \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u043D \u043E\u043A\u0430\u0437\u0430\u043B
    \u0431\u043E\u043B\u044C\u0448\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0440\u0430\u043D\u043D\u0435\u0435 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u0441\u044B\u043D\u0430.  \u041F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043F\u043E\u043B\u0443\u0447\u0430\u043B
    \u0434\u043E\u043C\u0430\u0448\u043D\u0435\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0443\u0447\u0438\u043B\u0441\u044F \u0432
    \u0448\u043A\u043E\u043B\u0435 \u0432 \u041F\u0438\u0437\u0435. \u0412 1574 \u0433\u043E\u0434\u0443
    \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432\u043E \u0424\u043B\u043E\u0440\u0435\u043D\u0446\u0438\u044E, \u0438 \u0435\u0433\u043E
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0438 \u0432 \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u044C
    \u0412\u0430\u043B\u043B\u043E\u043C\u0431\u0440\u043E\u0437\u0430, \u0433\u0434\u0435
    \u043E\u043D \u0434\u0430\u0436\u0435 \u0441\u0442\u0430\u043B \u043F\u043E\u0441\u043B\u0443\u0448\u043D\u0438\u043A\u043E\u043C.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u043F\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u043D\u0438\u044E
    \u043E\u0442\u0446\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u043B
    \u043F\u0440\u043E\u0442\u0438\u0432 \u043C\u043E\u043D\u0430\u0448\u0435\u0441\u043A\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0441\u044B\u043D\u0430, \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u044C. 
    \u0421\u043B\u0435\u0434\u0443\u044F \u0432\u043E\u043B\u0435 \u043E\u0442\u0446\u0430,
    \u0432 1581 \u0433\u043E\u0434\u0443 \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u041F\u0438\u0437\u0430\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u0447\u0442\u043E\u0431\u044B
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0443.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439
    \u0441\u0442\u0440\u0430\u0441\u0442\u044C\u044E \u0441\u0442\u0430\u043B\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430.
    \u041E\u043D \u0443\u0432\u043B\u0435\u043A\u0441\u044F \u0447\u0442\u0435\u043D\u0438\u0435\u043C
    \u0442\u0440\u0443\u0434\u043E\u0432 \u0415\u0432\u043A\u043B\u0438\u0434\u0430
    \u0438 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C. \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0432\u043B\u0435\u043A\u0441\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439 \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u043E\u0439,
    \u0447\u0442\u043E \u0431\u0440\u043E\u0441\u0438\u043B \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0443
    \u0438 \u0432 1585 \u0433\u043E\u0434\u0443, \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E
    \u043D\u0435 \u043E\u043A\u043E\u043D\u0447\u0438\u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442,
    \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u0432\u043E \u0424\u043B\u043E\u0440\u0435\u043D\u0446\u0438\u044E,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C
    \u0441\u0435\u0431\u044F \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E \u0442\u043E\u0447\u043D\u044B\u0445
    \u043D\u0430\u0443\u043A.  ### \u041D\u0430\u0447\u0430\u043B\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B (1586\u20131591)  \u0412 \u044D\u0442\u043E\u0442
    \u0440\u0430\u043D\u043D\u0438\u0439 \u0444\u043B\u043E\u0440\u0435\u043D\u0442\u0438\u0439\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0443\u0436\u0435 \u043D\u0430\u0447\u0430\u043B \u0434\u0435\u043B\u0430\u0442\u044C
    \u0441\u0432\u043E\u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0448\u0430\u0433\u0438. \u0412 1586 \u0433\u043E\u0434\u0443 \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442 **\xAB\u041C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0435
    \u0432\u0435\u0441\u044B\xBB**, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043E\u043F\u0438\u0441\u0430\u043B \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u043D\u044B\u0435
    \u0438\u043C \u0433\u0438\u0434\u0440\u043E\u0441\u0442\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u0435\u0441\u044B \u0434\u043B\u044F \u0431\u044B\u0441\u0442\u0440\u043E\u0433\u043E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u0441\u043E\u0441\u0442\u0430\u0432\u0430
    \u043C\u0435\u0442\u0430\u043B\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u043F\u043B\u0430\u0432\u043E\u0432. \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430 \u0435\u043C\u0443 \u043F\u0435\u0440\u0432\u0443\u044E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C \u0441\u0440\u0435\u0434\u0438
    \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432. 
    \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0441\u0432\u043E\u0438\u043C
    \u0440\u0430\u0431\u043E\u0442\u0430\u043C \u0438 \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
    \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u0434\u0440\u0443\u0437\u0435\u0439,
    \u0432 1589 \u0433\u043E\u0434\u0443 \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043C\u0435\u0441\u0442\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432 \u041F\u0438\u0437\u0430\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u0445\u043E\u0442\u044F
    \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u044C\u0435 \u0431\u044B\u043B\u043E
    \u0432\u0435\u0441\u044C\u043C\u0430 \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u043C.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u0438 \u0433\u043E\u0434\u044B
    \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u043E\u0442\u043A\u0440\u044B\u0442\u043E
    \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u0442\u044C \u043F\u0440\u043E\u0442\u0438\u0432
    \u0433\u043E\u0441\u043F\u043E\u0434\u0441\u0442\u0432\u043E\u0432\u0430\u0432\u0448\u0435\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438 \u0410\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u044F.
    \u0412 \u0441\u0432\u043E\u0435\u043C \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435
    **\xAB\u041E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438\xBB** (1590) \u043E\u043D
    \u043F\u043E\u0434\u0432\u0435\u0440\u0433 \u043A\u0440\u0438\u0442\u0438\u043A\u0435
    \u0430\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u0435\u0432\u0441\u043A\u0438\u0439
    \u0437\u0430\u043A\u043E\u043D \u043F\u0430\u0434\u0435\u043D\u0438\u044F \u0442\u0435\u043B,
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044F, \u0447\u0442\u043E \u0443\u0441\u043A\u043E\u0440\u0435\u043D\u0438\u0435
    \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0433\u043E \u043F\u0430\u0434\u0435\u043D\u0438\u044F
    \u043D\u0435 \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u043E\u0442 \u043C\u0430\u0441\u0441\u044B
    \u0442\u0435\u043B\u0430. \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435,
    \u043E\u043D \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E, \u0431\u0440\u043E\u0441\u0430\u044F \u0448\u0430\u0440\u044B
    \u0440\u0430\u0437\u043D\u043E\u0433\u043E \u0432\u0435\u0441\u0430 \u0441 \u041F\u0438\u0437\u0430\u043D\u0441\u043A\u043E\u0439
    \u0431\u0430\u0448\u043D\u0438, \u0445\u043E\u0442\u044F \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0439
    \u044D\u0442\u043E\u043C\u0443 \u043D\u0435\u0442.  ### \u0420\u0430\u0441\u0446\u0432\u0435\u0442
    \u0432 \u041F\u0430\u0434\u0443\u0435 (1592\u20131610)  \u0412 1592 \u0433\u043E\u0434\u0443
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043F\u0435\u0440\u0435\u0448\u0435\u043B
    \u043D\u0430 \u043A\u0430\u0444\u0435\u0434\u0440\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439 \u041F\u0430\u0434\u0443\u0430\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0441\u044F \u043F\u043E\u0434 \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0412\u0435\u043D\u0435\u0446\u0438\u0430\u043D\u0441\u043A\u043E\u0439 \u0440\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0438.
    \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    **\u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C
    \u0438 \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C \u0432 \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u0438**.  \u0412 \u041F\u0430\u0434\u0443\u0435 \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0441\u0434\u0435\u043B\u0430\u043B \u0441\u0432\u043E\u0438 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u0432 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435:
    *   \u041E\u043D \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B **\u0437\u0430\u043A\u043E\u043D
    \u0438\u043D\u0435\u0440\u0446\u0438\u0438** \u0438 **\u043F\u0440\u0438\u043D\u0446\u0438\u043F
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438**,
    \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u0432 \u0437\u0430\u043A\u0440\u044B\u0442\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u0435,
    \u0434\u0432\u0438\u0436\u0443\u0449\u0435\u0439\u0441\u044F \u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u043E
    \u0438 \u043F\u0440\u044F\u043C\u043E\u043B\u0438\u043D\u0435\u0439\u043D\u043E,
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C,
    \u043F\u043E\u043A\u043E\u0438\u0442\u0441\u044F \u043E\u043D\u0430 \u0438\u043B\u0438
    \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F (\u043F\u043E\u0437\u0436\u0435
    \u044D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E
    \u043A\u0430\u043A \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F). *   \u041E\u043D \u043E\u0442\u043A\u0440\u044B\u043B
    **\u0437\u0430\u043A\u043E\u043D\u044B \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0433\u043E
    \u043F\u0430\u0434\u0435\u043D\u0438\u044F** \u0438 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u0442\u0435\u043B \u043F\u043E \u043D\u0430\u043A\u043B\u043E\u043D\u043D\u043E\u0439
    \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438. *   \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u044F
    \u0442\u0435\u043B\u0430, \u0431\u0440\u043E\u0448\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u043E\u0434 \u0443\u0433\u043B\u043E\u043C \u043A \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0443,
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F **\u043F\u0430\u0440\u0430\u0431\u043E\u043B\u043E\u0439**.
    *   \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u043E\u0432\u0435\u043B
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F \u043F\u043E
    \u043F\u0440\u043E\u0447\u043D\u043E\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432
    \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u043B **\u0442\u0435\u0440\u043C\u043E\u0441\u043A\u043E\u043F**
    \u2014 \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437 \u0442\u0435\u0440\u043C\u043E\u043C\u0435\u0442\u0440\u0430. 
    \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u0441\u0442\u0430\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0433\u0435\u043B\u0438\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u041D\u0438\u043A\u043E\u043B\u0430\u044F
    \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430.  ### \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u0438 \u043F\u0443\u0442\u044C
    \u043A \u0441\u043B\u0430\u0432\u0435 (1609\u20131616)  \u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u043C
    \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C \u0432 \u0436\u0438\u0437\u043D\u0438
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u0441\u0442\u0430\u043B 1609 \u0433\u043E\u0434,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D, \u0443\u0437\u043D\u0430\u0432 \u043E\u0431
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0438 \u0432 \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u0438
    \u043F\u043E\u0434\u0437\u043E\u0440\u043D\u043E\u0439 \u0442\u0440\u0443\u0431\u044B,
    \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u043F\u0435\u0440\u0432\u044B\u0439 \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u2014 \u0441 **32-\u043A\u0440\u0430\u0442\u043D\u044B\u043C
    \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u0438\u0435\u043C**. \u041D\u0430\u043F\u0440\u0430\u0432\u0438\u0432
    \u0435\u0433\u043E \u043D\u0430 \u043D\u0435\u0431\u043E, \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0440\u044F\u0434 \u043E\u0448\u0435\u043B\u043E\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u0432 \u043A\u043D\u0438\u0433\u0435
    **\xAB\u0417\u0432\u0451\u0437\u0434\u043D\u044B\u0439 \u0432\u0435\u0441\u0442\u043D\u0438\u043A\xBB**
    (1610): *   **\u041B\u0443\u043D\u0430** \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C
    \u043D\u0435 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E \u0433\u043B\u0430\u0434\u043A\u043E\u0439
    \u0441\u0444\u0435\u0440\u043E\u0439, \u0430 \u043F\u043E\u043A\u0440\u044B\u0442\u043E\u0439
    \u0433\u043E\u0440\u0430\u043C\u0438 \u0438 \u043A\u0440\u0430\u0442\u0435\u0440\u0430\u043C\u0438,
    \u043F\u043E\u0434\u043E\u0431\u043D\u043E \u0417\u0435\u043C\u043B\u0435. *  
    **\u041C\u043B\u0435\u0447\u043D\u044B\u0439 \u041F\u0443\u0442\u044C** \u0441\u043E\u0441\u0442\u043E\u0438\u0442
    \u0438\u0437 \u0431\u0435\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u0437\u0432\u0435\u0437\u0434.
    *   \u041E\u043D \u043E\u0442\u043A\u0440\u044B\u043B **\u0447\u0435\u0442\u044B\u0440\u0435
    \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430 \u042E\u043F\u0438\u0442\u0435\u0440\u0430**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0430\u0437\u0432\u0430\u043B
    \xAB\u041C\u0435\u0434\u0438\u0446\u0435\u0439\u0441\u043A\u0438\u043C\u0438
    \u0437\u0432\u0451\u0437\u0434\u0430\u043C\u0438\xBB \u0432 \u0447\u0435\u0441\u0442\u044C
    \u0442\u043E\u0441\u043A\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u0433\u0435\u0440\u0446\u043E\u0433\u0430
    \u041A\u043E\u0437\u0438\u043C\u043E II \u041C\u0435\u0434\u0438\u0447\u0438. 
    \u042D\u0442\u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0438
    \u0413\u0430\u043B\u0438\u043B\u0435\u044E \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0443\u044E
    \u0441\u043B\u0430\u0432\u0443. \u0412 1610 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043F\u0440\u0438\u043D\u044F\u043B \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0433\u0435\u0440\u0446\u043E\u0433\u0430 \u041A\u043E\u0437\u0438\u043C\u043E
    II \u041C\u0435\u0434\u0438\u0447\u0438 \u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432\u043E \u0424\u043B\u043E\u0440\u0435\u043D\u0446\u0438\u044E, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u043E\u0433\u043E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0431\u0435\u0437 \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u043F\u043E \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u044E.
    \u0412 1611 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441 \u0442\u0440\u0438\u0443\u043C\u0444\u043E\u043C
    \u043F\u043E\u0441\u0435\u0442\u0438\u043B \u0420\u0438\u043C, \u0433\u0434\u0435
    \u0435\u0433\u043E \u043F\u0440\u0438\u043D\u044F\u043B\u0438 \u043F\u0440\u0438
    \u043F\u0430\u043F\u0441\u043A\u043E\u043C \u0434\u0432\u043E\u0440\u0435.  \u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044F
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F, \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043E\u0442\u043A\u0440\u044B\u043B \u0444\u0430\u0437\u044B \u0412\u0435\u043D\u0435\u0440\u044B,
    \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0435 \u043F\u044F\u0442\u043D\u0430
    \u0438 \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0421\u043E\u043B\u043D\u0446\u0430,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0435\u0449\u0435 \u043E\u0434\u043D\u0438\u043C
    \u043D\u0435\u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0436\u0438\u043C\u044B\u043C
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0432 \u043F\u043E\u043B\u044C\u0437\u0443
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430. 
    ### \u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u0441 \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u0435\u0439
    (1616\u20131632)  \u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u0443\u0441\u043F\u0435\u0445\u0438
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u0438 \u0435\u0433\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0430\u044F
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0430 \u0433\u0435\u043B\u0438\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0437\u043C\u0430
    \u0432\u044B\u0437\u0432\u0430\u043B\u0438 \u0432\u0440\u0430\u0436\u0434\u0435\u0431\u043D\u043E\u0441\u0442\u044C
    \u0441\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u044B \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0446\u0435\u0440\u043A\u0432\u0438. \u0412 1613 \u0433\u043E\u0434\u0443 \u043F\u0438\u0441\u044C\u043C\u043E
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u043A \u0430\u0431\u0431\u0430\u0442\u0443
    \u041A\u0430\u0441\u0442\u0435\u043B\u043B\u0438, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043E\u043D \u0437\u0430\u0449\u0438\u0449\u0430\u043B \u0443\u0447\u0435\u043D\u0438\u0435
    \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430 \u0438 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u0411\u0438\u0431\u043B\u0438\u044E \u0441\u043B\u0435\u0434\u0443\u0435\u0442
    \u0442\u043E\u043B\u043A\u043E\u0432\u0430\u0442\u044C \u0430\u043B\u043B\u0435\u0433\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438,
    \u0435\u0441\u043B\u0438 \u043E\u043D\u0430 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0442
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0444\u0430\u043A\u0442\u0430\u043C,
    \u043F\u043E\u0441\u043B\u0443\u0436\u0438\u043B\u043E \u043F\u043E\u0432\u043E\u0434\u043E\u043C
    \u0434\u043B\u044F \u0434\u043E\u043D\u043E\u0441\u0430 \u0432 \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u044E. 
    \u0412 1616 \u0433\u043E\u0434\u0443 \u0446\u0435\u0440\u043A\u043E\u0432\u044C
    \u043E\u0431\u044A\u044F\u0432\u0438\u043B\u0430 \u0443\u0447\u0435\u043D\u0438\u0435
    \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430 \u0435\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C,
    \u0430 \u0435\u0433\u043E \u043A\u043D\u0438\u0433\u0443 \u0432\u043A\u043B\u044E\u0447\u0438\u043B\u0438
    \u0432 \u0418\u043D\u0434\u0435\u043A\u0441 \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043D\u044B\u0445
    \u043A\u043D\u0438\u0433. \u0413\u0430\u043B\u0438\u043B\u0435\u044E \u0447\u0430\u0441\u0442\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0431\u044B\u043B\u043E \u043F\u0440\u0438\u043A\u0430\u0437\u0430\u043D\u043E
    \u043F\u0440\u0435\u043A\u0440\u0430\u0442\u0438\u0442\u044C \u0437\u0430\u0449\u0438\u0442\u0443
    \u044D\u0442\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438, \u0438 \u043E\u043D
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E \u043F\u043E\u0434\u0447\u0438\u043D\u0438\u043B\u0441\u044F. 
    \u0412 1623 \u0433\u043E\u0434\u0443 \u043D\u0430 \u043F\u0430\u043F\u0441\u043A\u0438\u0439
    \u043F\u0440\u0435\u0441\u0442\u043E\u043B \u0432\u0437\u043E\u0448\u0435\u043B
    \u0434\u0440\u0443\u0433 \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B
    \u041C\u0430\u0444\u0444\u0435\u043E \u0411\u0430\u0440\u0431\u0435\u0440\u0438\u043D\u0438
    \u043F\u043E\u0434 \u0438\u043C\u0435\u043D\u0435\u043C \u0423\u0440\u0431\u0430\u043D\u0430
    VIII. \u0413\u0430\u043B\u0438\u043B\u0435\u0439, \u043F\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u0432
    \u043D\u0430\u0434\u0435\u0436\u0434\u0443, \u0440\u0435\u0448\u0438\u043B \u0432\u043E\u0437\u043E\u0431\u043D\u043E\u0432\u0438\u0442\u044C
    \u0434\u0438\u0430\u043B\u043E\u0433 \u0441 \u0446\u0435\u0440\u043A\u043E\u0432\u044C\u044E.
    \u041E\u043D \u0437\u0430\u0434\u0443\u043C\u0430\u043B \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C
    \u043A\u043D\u0438\u0433\u0443, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0431\u0435\u0441\u043F\u0440\u0438\u0441\u0442\u0440\u0430\u0441\u0442\u043D\u043E
    \u0441\u0440\u0430\u0432\u043D\u0438\u043B \u0431\u044B \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F \u0438 \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430.
    \u041F\u043E\u0441\u043B\u0435 \u0434\u043E\u043B\u0433\u0438\u0445 \u0446\u0435\u043D\u0437\u0443\u0440\u043D\u044B\u0445
    \u0441\u043E\u0433\u043B\u0430\u0441\u043E\u0432\u0430\u043D\u0438\u0439 \u0432
    1632 \u0433\u043E\u0434\u0443 \u0432\u043E \u0424\u043B\u043E\u0440\u0435\u043D\u0446\u0438\u0438
    \u0431\u044B\u043B \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D
    \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434
    \u2014 **\xAB\u0414\u0438\u0430\u043B\u043E\u0433 \u043E \u0434\u0432\u0443\u0445
    \u0433\u043B\u0430\u0432\u043D\u0435\u0439\u0448\u0438\u0445 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0445
    \u043C\u0438\u0440\u0430\xBB**.  \u041E\u0434\u043D\u0430\u043A\u043E \u043A\u043D\u0438\u0433\u0430
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C \u043D\u0435 \u0431\u0435\u0441\u043F\u0440\u0438\u0441\u0442\u0440\u0430\u0441\u0442\u043D\u043E\u0439.
    \u0412 \u043D\u0435\u0439, \u0432 \u0444\u043E\u0440\u043C\u0435 \u0431\u0435\u0441\u0435\u0434\u044B
    \u0442\u0440\u0435\u0445 \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u043E\u0432,
    \u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043A \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430
    (\u0421\u0430\u043B\u044C\u0432\u0438\u0430\u0442\u0438) \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0430\u043B
    \u0443\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C \u0438
    \u043C\u0443\u0434\u0440\u044B\u043C, \u0430 \u0435\u0433\u043E \u043E\u043F\u043F\u043E\u043D\u0435\u043D\u0442,
    \u0430\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u0438\u0430\u043D\u0435\u0446
    (\u0421\u0438\u043C\u043F\u043B\u0438\u0447\u043E), \u2014 \u0433\u043B\u0443\u043F\u043E\u0432\u0430\u0442\u044B\u043C
    \u043F\u0435\u0434\u0430\u043D\u0442\u043E\u043C. \u042D\u0442\u043E \u0431\u044B\u043B\u043E
    \u044F\u0432\u043D\u044B\u043C \u043D\u0430\u0440\u0443\u0448\u0435\u043D\u0438\u0435\u043C
    \u043F\u0440\u0435\u0436\u043D\u0435\u0433\u043E \u043E\u0431\u0435\u0449\u0430\u043D\u0438\u044F
    \u043D\u0435 \u0437\u0430\u0449\u0438\u0449\u0430\u0442\u044C \u0433\u0435\u043B\u0438\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0437\u043C. 
    ### \u0421\u0443\u0434 \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0436\u0438\u0437\u043D\u0438 (1633\u20131642)  \u041A\u043D\u0438\u0433\u0430
    \u0432\u044B\u0437\u0432\u0430\u043B\u0430 \u0433\u043D\u0435\u0432 \u043F\u0430\u043F\u044B
    \u0423\u0440\u0431\u0430\u043D\u0430 VIII, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u0441\u0435\u0431\u044F
    \u043E\u0431\u043C\u0430\u043D\u0443\u0442\u044B\u043C. \u0412 1633 \u0433\u043E\u0434\u0443
    69-\u043B\u0435\u0442\u043D\u0435\u0433\u043E \u0431\u043E\u043B\u044C\u043D\u043E\u0433\u043E
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u0432\u044B\u0437\u0432\u0430\u043B\u0438
    \u0432 \u0420\u0438\u043C \u043D\u0430 \u0441\u0443\u0434 \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u0438.
    \u041F\u043E\u0434 \u0443\u0433\u0440\u043E\u0437\u043E\u0439 \u043F\u044B\u0442\u043A\u0438
    \u043E\u043D \u0431\u044B\u043B \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u043E\u0442\u0440\u0435\u0447\u044C\u0441\u044F \u043E\u0442 \u0441\u0432\u043E\u0438\u0445
    \u0432\u0437\u0433\u043B\u044F\u0434\u043E\u0432. **22 \u0438\u044E\u043D\u044F
    1633 \u0433\u043E\u0434\u0430** \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043D\u0430
    \u043A\u043E\u043B\u0435\u043D\u044F\u0445 \u0432 \u0446\u0435\u0440\u043A\u0432\u0438
    \u0421\u0430\u043D\u0442\u0430-\u041C\u0430\u0440\u0438\u044F-\u0441\u043E\u043F\u0440\u0430-\u041C\u0438\u043D\u0435\u0440\u0432\u0430
    \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441
    \u0442\u0435\u043A\u0441\u0442 \u043E\u0442\u0440\u0435\u0447\u0435\u043D\u0438\u044F. 
    \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435,
    \u043F\u043E\u0441\u043B\u0435 \u043E\u0442\u0440\u0435\u0447\u0435\u043D\u0438\u044F
    \u043E\u043D \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441 \u0444\u0440\u0430\u0437\u0443:
    **\xAB\u0418 \u0432\u0441\u0451-\u0442\u0430\u043A\u0438 \u043E\u043D\u0430 \u0432\u0435\u0440\u0442\u0438\u0442\u0441\u044F!\xBB**
    \u041E\u0434\u043D\u0430\u043A\u043E \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432 \u0441\u0447\u0438\u0442\u0430\u044E\u0442
    \u044D\u0442\u0443 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u0432\u044B\u043C\u044B\u0441\u043B\u043E\u043C. 
    \u041F\u0440\u0438\u0433\u043E\u0432\u043E\u0440 \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u0438
    \u043E\u0431\u044A\u044F\u0432\u043B\u044F\u043B \u0413\u0430\u043B\u0438\u043B\u0435\u044F
    \xAB\u0441\u0438\u043B\u044C\u043D\u043E \u0437\u0430\u043F\u043E\u0434\u043E\u0437\u0440\u0435\u043D\u043D\u044B\u043C
    \u0432 \u0435\u0440\u0435\u0441\u0438\xBB. \u0415\u0433\u043E \u043A\u043D\u0438\u0433\u0430
    \u0431\u044B\u043B\u0430 \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u0430,
    \u0430 \u0441\u0430\u043C \u043E\u043D \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\u0435\u043D
    \u043A \u043F\u043E\u0436\u0438\u0437\u043D\u0435\u043D\u043D\u043E\u043C\u0443
    \u0442\u044E\u0440\u0435\u043C\u043D\u043E\u043C\u0443 \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044E,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0431\u044B\u043B\u043E \u0437\u0430\u043C\u0435\u043D\u0435\u043D\u043E
    **\u0434\u043E\u043C\u0430\u0448\u043D\u0438\u043C \u0430\u0440\u0435\u0441\u0442\u043E\u043C**
    \u043D\u0430 \u0432\u0438\u043B\u043B\u0435 \u0410\u0440\u0447\u0435\u0442\u0440\u0438,
    \u0431\u043B\u0438\u0437 \u0424\u043B\u043E\u0440\u0435\u043D\u0446\u0438\u0438.
    \u0415\u043C\u0443 \u0431\u044B\u043B\u043E \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043E
    \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C \u043D\u043E\u0432\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B.  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0432\u0441\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u0438\u044F,
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043D\u0435 \u043F\u0440\u0435\u043A\u0440\u0430\u0442\u0438\u043B
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u044B.
    \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0442\u0440\u0430\u043A\u0442\u0430\u0442
    **\xAB\u0411\u0435\u0441\u0435\u0434\u044B \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430,
    \u043A\u0430\u0441\u0430\u044E\u0449\u0438\u0435\u0441\u044F \u0434\u0432\u0443\u0445
    \u043D\u043E\u0432\u044B\u0445 \u043E\u0442\u0440\u0430\u0441\u043B\u0435\u0439
    \u043D\u0430\u0443\u043A\u0438\xBB** (1638), \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u0432\u0435\u0440\u0448\u0438\u043D\u043E\u0439 \u0435\u0433\u043E
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439.
    \u041A\u043D\u0438\u0433\u0430 \u0431\u044B\u043B\u0430 \u0442\u0430\u0439\u043D\u043E
    \u043F\u0435\u0440\u0435\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0430 \u0432
    \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u044E \u0438 \u0438\u0437\u0434\u0430\u043D\u0430
    \u0442\u0430\u043C, \u0442\u0430\u043A \u043A\u0430\u043A \u0432 \u0418\u0442\u0430\u043B\u0438\u0438
    \u043D\u0430 \u043D\u0435\u0435 \u043B\u0435\u0436\u0430\u043B \u0437\u0430\u043F\u0440\u0435\u0442. 
    \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043F\u043E\u0447\u0442\u0438
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043E\u0441\u043B\u0435\u043F.
    **\u041E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 8 \u044F\u043D\u0432\u0430\u0440\u044F
    1642 \u0433\u043E\u0434\u0430** \u0432 \u0410\u0440\u0447\u0435\u0442\u0440\u0438,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 77 \u043B\u0435\u0442.
    \u0418\u0437-\u0437\u0430 \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0430
    \u0441 \u0446\u0435\u0440\u043A\u043E\u0432\u044C\u044E \u0435\u0433\u043E \u0434\u043E\u043B\u0433\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u043D\u0435 \u043C\u043E\u0433\u043B\u0438 \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0438\u0442\u044C
    \u0432 \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0439 \u0443\u0441\u044B\u043F\u0430\u043B\u044C\u043D\u0438\u0446\u0435
    \u0432\u043E \u0424\u043B\u043E\u0440\u0435\u043D\u0446\u0438\u0438, \u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432 1737 \u0433\u043E\u0434\u0443 \u0435\u0433\u043E \u043F\u0440\u0430\u0445
    \u0431\u044B\u043B \u043F\u0435\u0440\u0435\u0437\u0430\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u0432 \u0431\u0430\u0437\u0438\u043B\u0438\u043A\u0435 \u0421\u0430\u043D\u0442\u0430-\u041A\u0440\u043E\u0447\u0435,
    \u0440\u044F\u0434\u043E\u043C \u0441 \u043C\u043E\u0433\u0438\u043B\u0430\u043C\u0438
    \u041C\u0438\u043A\u0435\u043B\u0430\u043D\u0434\u0436\u0435\u043B\u043E \u0438
    \u041C\u0430\u043A\u0438\u0430\u0432\u0435\u043B\u043B\u0438.  \u0422\u043E\u043B\u044C\u043A\u043E
    \u0432 1992 \u0433\u043E\u0434\u0443 \u041F\u0430\u043F\u0430 \u0420\u0438\u043C\u0441\u043A\u0438\u0439
    \u0418\u043E\u0430\u043D\u043D \u041F\u0430\u0432\u0435\u043B II \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u043F\u0440\u0438\u0437\u043D\u0430\u043B \u043E\u0448\u0438\u0431\u043A\u0443
    \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u0438 \u0438 \u0440\u0435\u0430\u0431\u0438\u043B\u0438\u0442\u0438\u0440\u043E\u0432\u0430\u043B
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0413\u0430\u043B\u0438\u043B\u0435\u043E
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u2014 \u044D\u0442\u043E \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0443\u0445\u0438\u0435 \u0434\u0430\u0442\u044B
    \u0438 \u0444\u043E\u0440\u043C\u0443\u043B\u044B. \u042D\u0442\u043E \u043A\u043B\u0430\u0434\u0435\u0437\u044C
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u0439,
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u043B\u0430\u0431\u043E\u0441\u0442\u0435\u0439,
    \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u0432 \u0438 \u043F\u0440\u043E\u0437\u0440\u0435\u043D\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u0434\u0435\u043B\u0430\u043B\u0438
    \u0435\u0433\u043E \u0436\u0438\u0432\u044B\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u0430 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0431\u0440\u043E\u043D\u0437\u043E\u0432\u044B\u043C
    \u043F\u0430\u043C\u044F\u0442\u043D\u0438\u043A\u043E\u043C. \u0412\u043E\u0442
    \u0441\u0430\u043C\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u043E \u043D\u0435\u043C, \u0441\u043E\u0431\u0440\u0430\u043D\u043D\u044B\u0435
    \u0432 \u043C\u0435\u043B\u044C\u0447\u0430\u0439\u0448\u0438\u0445 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0441\u0442\u044F\u0445. 
    ### 1. \xAB\u0418 \u0432\u0441\u0451-\u0442\u0430\u043A\u0438 \u043E\u043D\u0430
    \u0432\u0435\u0440\u0442\u0438\u0442\u0441\u044F!\xBB \u2014 \u041F\u0440\u0430\u0432\u0434\u0430
    \u0438 \u0432\u044B\u043C\u044B\u0441\u0435\u043B \u042D\u0442\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442 \u043E \u0413\u0430\u043B\u0438\u043B\u0435\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    **\u043D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B**.
    \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043D\u0435 \u043D\u0430\u0448\u043B\u0438
    \u043D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u044F
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441 \u044D\u0442\u0443 \u0444\u0440\u0430\u0437\u0443
    \u043F\u043E\u0441\u043B\u0435 \u043E\u0442\u0440\u0435\u0447\u0435\u043D\u0438\u044F
    \u0432 1633 \u0433\u043E\u0434\u0443. *   **\u041E\u0442\u043A\u0443\u0434\u0430
    \u044D\u0442\u043E \u0432\u0437\u044F\u043B\u043E\u0441\u044C?** \u0412\u043F\u0435\u0440\u0432\u044B\u0435
    \u044D\u0442\u0430 \u043B\u0435\u0433\u0435\u043D\u0434\u0430 \u043F\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C
    \u0432 \u043F\u0435\u0447\u0430\u0442\u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0447\u0435\u0440\u0435\u0437 100 \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438, \u0432 1757 \u0433\u043E\u0434\u0443,
    \u0432 \u043A\u043D\u0438\u0433\u0435 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u043E\u0433\u043E
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u043E\u0440\u0430 \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435
    \u0411\u0430\u0440\u0435\u0442\u0442\u0438. *   **\u041F\u043E\u0447\u0435\u043C\u0443
    \u044D\u0442\u043E \u043D\u0435\u043F\u0440\u0430\u0432\u0434\u043E\u043F\u043E\u0434\u043E\u0431\u043D\u043E?**
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u0431\u044B\u043B \u0443\u043C\u043D\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0438 \u043F\u043E\u043D\u0438\u043C\u0430\u043B,
    \u0447\u0442\u043E \u043F\u043E\u0441\u043B\u0435 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E\u0433\u043E
    \u043E\u0442\u0440\u0435\u0447\u0435\u043D\u0438\u044F \u043C\u0430\u043B\u0435\u0439\u0448\u0430\u044F
    \u043A\u0440\u0430\u043C\u043E\u043B\u044C\u043D\u0430\u044F \u0444\u0440\u0430\u0437\u0430
    \u0432 \u0441\u0442\u0435\u043D\u0430\u0445 \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u0438
    \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u0430 \u0431\u044B \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u0443\u044E
    \u043A\u0430\u0437\u043D\u044C \u043D\u0430 \u043A\u043E\u0441\u0442\u0440\u0435.
    \u0421\u043A\u043E\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043E, \u043E\u043D
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u0440\u043E\u0431\u043E\u0440\u043C\u043E\u0442\u0430\u043B \u043D\u0435\u0447\u0442\u043E
    \u043F\u043E\u0434\u043E\u0431\u043D\u043E\u0435 *\u043F\u0440\u043E \u0441\u0435\u0431\u044F*
    \u043D\u0430\u043C\u043D\u043E\u0433\u043E \u043F\u043E\u0437\u0436\u0435, \u0432
    \u043A\u0440\u0443\u0433\u0443 \u0441\u0432\u043E\u0438\u0445 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432,
    \u043D\u043E \u0442\u043E\u0447\u043D\u043E \u043D\u0435 \u0432 \u0437\u0430\u043B\u0435
    \u0441\u0443\u0434\u0430.  ### 2. \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0438 \u041F\u0438\u0437\u0430\u043D\u0441\u043A\u0430\u044F \u0431\u0430\u0448\u043D\u044F:
    \u041C\u0438\u0444 \u043E \u0431\u0440\u043E\u0441\u0430\u043D\u0438\u0438 \u044F\u0434\u0435\u0440
    \u041A\u0430\u0436\u0434\u044B\u0439 \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u043A
    \u0437\u043D\u0430\u0435\u0442 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u043E
    \u0442\u043E\u043C, \u043A\u0430\u043A \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0441\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043B \u0441 \u041F\u0438\u0437\u0430\u043D\u0441\u043A\u043E\u0439
    \u0431\u0430\u0448\u043D\u0438 \u0434\u0432\u0430 \u044F\u0434\u0440\u0430 \u0440\u0430\u0437\u043D\u043E\u0433\u043E
    \u0432\u0435\u0441\u0430, \u0447\u0442\u043E\u0431\u044B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
    \u0447\u0442\u043E \u043E\u043D\u0438 \u0443\u043F\u0430\u0434\u0443\u0442 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E.
    \u042D\u0442\u043E \u0435\u0449\u0435 \u043E\u0434\u043D\u0430 **\u043A\u0440\u0430\u0441\u0438\u0432\u0430\u044F
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430**. *   \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u043B \u044D\u0442\u0443 \u0438\u0441\u0442\u043E\u0440\u0438\u044E,
    \u2014 \u0443\u0447\u0435\u043D\u0438\u043A \u0438 \u0431\u0438\u043E\u0433\u0440\u0430\u0444
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F, \u0412\u0438\u043D\u0447\u0435\u043D\u0446\u043E
    \u0412\u0438\u0432\u0438\u0430\u043D\u0438. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043E\u043D \u0437\u0430\u043F\u0438\u0441\u0430\u043B \u0435\u0451 \u0441\u043F\u0443\u0441\u0442\u044F
    \u043C\u043D\u043E\u0433\u043E \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0443\u0447\u0438\u0442\u0435\u043B\u044F.
    *   \u0421\u0430\u043C \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u0432 \u0441\u0432\u043E\u0438\u0445
    \u0442\u0440\u0443\u0434\u0430\u0445 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442 \u043E\u0431
    \u044D\u0442\u043E\u043C \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0435.
    \u041E\u043D \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B \u043E\u043F\u044B\u0442\u044B
    \u0441 **\u043D\u0430\u043A\u043B\u043E\u043D\u043D\u044B\u043C\u0438 \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u044F\u043C\u0438**,
    \u0433\u0434\u0435 \u0448\u0430\u0440\u044B \u0441\u043A\u0430\u0442\u044B\u0432\u0430\u043B\u0438\u0441\u044C
    \u0432\u043D\u0438\u0437. \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0440\u043E\u0449\u0435 \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 (\u0432\u0435\u0434\u044C \u0441\u0435\u043A\u0443\u043D\u0434\u043E\u043C\u0435\u0440\u043E\u0432
    \u0442\u043E\u0433\u0434\u0430 \u043D\u0435 \u0431\u044B\u043B\u043E, \u0438
    \u043E\u043D \u043E\u0442\u043C\u0435\u0440\u044F\u043B \u0432\u0440\u0435\u043C\u044F
    \u043F\u043E \u0431\u0438\u0435\u043D\u0438\u044E \u0441\u0432\u043E\u0435\u0433\u043E
    \u043F\u0443\u043B\u044C\u0441\u0430 \u0438\u043B\u0438 \u043F\u043E \u0432\u043E\u0434\u044F\u043D\u044B\u043C
    \u0447\u0430\u0441\u0430\u043C). \u0411\u0440\u043E\u0441\u0430\u0442\u044C \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B
    \u0441 \u0432\u044B\u0441\u043E\u0442\u044B 50 \u043C\u0435\u0442\u0440\u043E\u0432
    \u0431\u044B\u043B\u043E \u0431\u044B \u043A\u0440\u0430\u0439\u043D\u0435 \u043D\u0435\u0442\u043E\u0447\u043D\u043E
    \u0438\u0437-\u0437\u0430 \u0441\u043E\u043F\u0440\u043E\u0442\u0438\u0432\u043B\u0435\u043D\u0438\u044F
    \u0432\u043E\u0437\u0434\u0443\u0445\u0430.  ### 3. \u041F\u0435\u0440\u0432\u044B\u0439
    \u0432 \u043C\u0438\u0440\u0435 \xAB\u043C\u043E\u0437\u0433\u043E\u0432\u043E\u0439
    \u0448\u0442\u0443\u0440\u043C\xBB (\u0418\u043B\u0438 \u043A\u0430\u043A \u043E\u043D
    \u0447\u0443\u0442\u044C \u043D\u0435 \u0441\u0442\u0430\u043B \u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u043E\u0440\u043E\u043C)
    \u0412 1580-\u0445 \u0433\u043E\u0434\u0430\u0445 \u0413\u0430\u043B\u0438\u043B\u0435\u0439,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u043C\u043E\u043B\u043E\u0434\u044B\u043C
    \u0438 \u0431\u0435\u0434\u043D\u044B\u043C \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C,
    \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043D\u0430\u0439\u0442\u0438 \u0441\u043F\u043E\u0441\u043E\u0431
    \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C. \u041E\u043D \u0432\u0441\u0435\u0440\u044C\u0435\u0437
    \u0437\u0430\u0434\u0443\u043C\u0430\u043B \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u0442\u044C
    \u0441\u0432\u043E\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u043D\u0430\u043D\u0438\u044F \u043A... **\u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u0443\u0440\u0435
    \u0438 \u0433\u0440\u0430\u0434\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443**.
    \u041E\u043D \u043F\u043E\u0434\u0430\u043B \u0437\u0430\u044F\u0432\u043A\u0443
    \u043D\u0430 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430 \u0432 \u0412\u0435\u043D\u0435\u0446\u0438\u0438,
    \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u0443\u044F, \u0447\u0442\u043E
    \u0441\u043C\u043E\u0436\u0435\u0442 \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0430\u0442\u044C
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435 \u0442\u044F\u0436\u0435\u0441\u0442\u0438
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0440\u044B\u0447\u0430\u0433\u043E\u0432, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043E\u0431\u043C\u0435\u043B\u044F\u0442\u044C \u0440\u0435\u043A\u0438 \u0438
    \u0441\u0442\u0440\u043E\u0438\u0442\u044C \u0434\u0430\u043C\u0431\u044B. \u0415\u0433\u043E
    \u043D\u0435 \u0432\u0437\u044F\u043B\u0438, \u043D\u043E \u044D\u0442\u043E
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442, \u0447\u0442\u043E
    \u043E\u043D \u0431\u044B\u043B \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u043E\u043C, \u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \xAB\u043A\u0430\u0431\u0438\u043D\u0435\u0442\u043D\u044B\u043C \u0443\u0447\u0435\u043D\u044B\u043C\xBB. 
    ### 4. \u041E\u043D \u043D\u0435 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u043B
    \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F, \u043D\u043E \u0441\u0434\u0435\u043B\u0430\u043B
    \u0435\u0433\u043E \u0431\u0438\u0437\u043D\u0435\u0441\u043E\u043C \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043F\u0440\u043E\u0441\u043B\u0430\u0432\u0438\u043B\u0441\u044F \u043A\u0430\u043A
    \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u0430,
    \u043D\u043E **\u0438\u0437\u043E\u0431\u0440\u0435\u043B \u0435\u0433\u043E
    \u043D\u0435 \u043E\u043D**. \u0412 1608 \u0433\u043E\u0434\u0443 \u0433\u043E\u043B\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439
    \u043E\u043F\u0442\u0438\u043A \u0425\u0430\u043D\u0441 \u041B\u0438\u043F\u043F\u0435\u0440\u0441\u0433\u0435\u0439
    \u043F\u0440\u043E\u0441\u0442\u043E \u0437\u0430\u043F\u0430\u0442\u0435\u043D\u0442\u043E\u0432\u0430\u043B
    \u043F\u043E\u0434\u0437\u043E\u0440\u043D\u0443\u044E \u0442\u0440\u0443\u0431\u0443.
    *   \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043D\u0435 \u0432\u0438\u0434\u0435\u043B
    \u044D\u0442\u043E\u0433\u043E \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430
    \u0432\u0436\u0438\u0432\u0443\u044E, \u043B\u0438\u0448\u044C \u0443\u0441\u043B\u044B\u0448\u0430\u043B
    \u043E \u0435\u0433\u043E \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F.
    \u0411\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E \u0437\u0430 \u043E\u0434\u043D\u0443
    \u043D\u043E\u0447\u044C \u043E\u043D \u0434\u043E\u0433\u0430\u0434\u0430\u043B\u0441\u044F,
    \u043A\u0430\u043A \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442 \u043B\u0438\u043D\u0437\u044B,
    \u0438 \u0437\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043D\u0435\u0434\u0435\u043B\u044C
    \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0441\u0434\u0435\u043B\u0430\u043B \u043F\u0440\u0438\u0431\u043E\u0440 \u0441
    \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u0438\u0435\u043C \u0432 8 \u0440\u0430\u0437,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0438 \u0432 32 \u0440\u0430\u0437\u0430.
    *   \u041D\u043E \u0441\u0430\u043C\u043E\u0435 \u0437\u0430\u0431\u0430\u0432\u043D\u043E\u0435:
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043D\u0435 \u0441\u0442\u0430\u043B
    \u0434\u0435\u043B\u0438\u0442\u044C\u0441\u044F \u0447\u0435\u0440\u0442\u0435\u0436\u0430\u043C\u0438
    \u0441\u043E \u0432\u0441\u0435\u043C\u0438. \u041E\u043D **\u043F\u0440\u043E\u0434\u0430\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u044B**
    \u0432\u0435\u043D\u0435\u0446\u0438\u0430\u043D\u0441\u043A\u0438\u043C \u043A\u0443\u043F\u0446\u0430\u043C
    \u043A\u0430\u043A \u043F\u043E\u0434\u0437\u043E\u0440\u043D\u044B\u0435 \u0442\u0440\u0443\u0431\u044B
    \u0434\u043B\u044F \u0441\u0443\u0434\u043E\u0432, \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044F,
    \u0447\u0442\u043E \u043E\u043D\u0438 \u043F\u043E\u043C\u043E\u0433\u0443\u0442
    \u0432\u0438\u0434\u0435\u0442\u044C \u0432\u0440\u0430\u0436\u0435\u0441\u043A\u0438\u0435
    \u043A\u043E\u0440\u0430\u0431\u043B\u0438 \u043D\u0430 \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0435
    \u0437\u0430 \u0434\u0432\u0430 \u0447\u0430\u0441\u0430 \u0434\u043E \u0438\u0445
    \u043F\u0440\u0438\u0431\u044B\u0442\u0438\u044F. \u041E\u043D \u0445\u043E\u0440\u043E\u0448\u043E
    \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u0430 \u044D\u0442\u043E\u043C,
    \u043F\u043E\u043A\u0430 \u043A\u043E\u043D\u043A\u0443\u0440\u0435\u043D\u0442\u044B
    \u043D\u0435 \u0440\u0430\u0441\u043A\u0443\u0441\u0438\u043B\u0438 \u0435\u0433\u043E
    \u0441\u0435\u043A\u0440\u0435\u0442.  ### 5. \u041A\u043E\u043D\u043A\u0443\u0440\u0441
    \u043D\u0430 \xAB\u0441\u0430\u043C\u044B\u0439 \u0442\u043E\u0447\u043D\u044B\u0439
    \u043F\u0443\u043B\u044C\u0441\xBB \u041F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443
    \u0441\u0435\u043A\u0443\u043D\u0434\u043E\u043C\u0435\u0440\u043E\u0432 \u0432
    XVII \u0432\u0435\u043A\u0435 \u043D\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E,
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u0431\u044B\u043B \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u0438\u0437\u043C\u0435\u0440\u044F\u0442\u044C \u0432\u0440\u0435\u043C\u044F
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0442\u0435\u043B \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    **\u043F\u0443\u043B\u044C\u0441\u043E\u043C** \u0438\u043B\u0438 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    **\u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043C\u0435\u0442\u0440\u043E\u043D\u043E\u043C\u0430**.
    *   \u0412 \u041F\u0430\u0434\u0443\u0435 \u0443 \u043D\u0435\u0433\u043E \u0431\u044B\u043B
    \u0441\u0442\u0430\u0440\u0448\u0438\u0439 \u043A\u043E\u043B\u043B\u0435\u0433\u0430
    \u2014 \u0432\u0440\u0430\u0447 \u0421\u0430\u043D\u0442\u043E\u0440\u0438\u043E,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0438\u0437\u043E\u0431\u0440\u0435\u043B
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0432 \u043C\u0438\u0440\u0435 \u0442\u0435\u0440\u043C\u043E\u043C\u0435\u0442\u0440
    \u0438 \u0432\u0435\u0441\u044B \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F
    \u043F\u0443\u043B\u044C\u0441\u0430. *   \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0436\u0435 \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B \u0438\u0437\u043C\u0435\u0440\u044F\u0442\u044C
    \u043F\u0430\u0434\u0435\u043D\u0438\u0435 \u0448\u0430\u0440\u043E\u0432 \u043F\u043E
    \u043D\u0430\u043A\u043B\u043E\u043D\u043D\u043E\u0439 \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438,
    \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u044F \u0432\u0440\u0435\u043C\u044F
    \u0441 \u043F\u0435\u043D\u0438\u0435\u043C \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0433\u043E\u043B\u043E\u0441\u043E\u0432. \u041E\u043D \u043F\u0435\u043B \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u044B\u0435
    \u0433\u0430\u043C\u043C\u044B, \u0441\u0447\u0438\u0442\u0430\u044F \u0442\u0430\u043A\u0442\u044B,
    \u0447\u0442\u043E\u0431\u044B \u043E\u0442\u0431\u0438\u0432\u0430\u0442\u044C
    \u0440\u0438\u0442\u043C. \u041C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u043E\u0442
    \u043E\u0442\u0446\u0430-\u043B\u044E\u0442\u043D\u0438\u0441\u0442\u0430 \u043E\u0447\u0435\u043D\u044C
    \u043F\u043E\u043C\u043E\u0433\u043B\u043E \u0435\u043C\u0443 \u0432 \u0444\u0438\u0437\u0438\u043A\u0435! 
    ### 6. \u041E\u043D \u0434\u0430\u0432\u0430\u043B \u0438\u043C\u0435\u043D\u0430
    \u043F\u043B\u0430\u043D\u0435\u0442\u0430\u043C \u0432 \u043E\u0431\u043C\u0435\u043D
    \u043D\u0430 \u0434\u0435\u043D\u044C\u0433\u0438 \u041E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u0432
    \u0447\u0435\u0442\u044B\u0440\u0435 \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0430
    \u042E\u043F\u0438\u0442\u0435\u0440\u0430 \u0432 1610 \u0433\u043E\u0434\u0443,
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043F\u043E\u043D\u0438\u043C\u0430\u043B,
    \u0447\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043D\u0443\u0436\u043D\u043E
    \xAB\u043F\u0440\u043E\u0434\u0430\u0442\u044C\xBB \u0441 \u0432\u044B\u0433\u043E\u0434\u043E\u0439.
    \u041E\u043D \u043D\u0430\u0437\u0432\u0430\u043B \u0438\u0445 **\xAB\u041C\u0435\u0434\u0438\u0446\u0435\u0439\u0441\u043A\u0438\u043C\u0438
    \u0437\u0432\u0451\u0437\u0434\u0430\u043C\u0438\xBB** (\u0432 \u0447\u0435\u0441\u0442\u044C
    \u043F\u0440\u0430\u0432\u044F\u0449\u0435\u0439 \u0444\u043B\u043E\u0440\u0435\u043D\u0442\u0438\u0439\u0441\u043A\u043E\u0439
    \u0434\u0438\u043D\u0430\u0441\u0442\u0438\u0438 \u041C\u0435\u0434\u0438\u0447\u0438),
    \u0445\u043E\u0442\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u044B
    \u043F\u043E\u0437\u0436\u0435 \u043F\u0435\u0440\u0435\u0438\u043C\u0435\u043D\u043E\u0432\u0430\u043B\u0438
    \u0438\u0445 \u0432 \u0433\u0430\u043B\u0438\u043B\u0435\u0435\u0432\u044B \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0438.
    *   \u041E\u043D \u043F\u043E\u0441\u043B\u0430\u043B \u0433\u0435\u0440\u0446\u043E\u0433\u0443
    \u041A\u043E\u0437\u0438\u043C\u043E II \u041C\u0435\u0434\u0438\u0447\u0438
    \u043C\u043E\u0434\u0435\u043B\u044C \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u0430
    \u0438 \u043A\u043D\u0438\u0433\u0443 \xAB\u0417\u0432\u0451\u0437\u0434\u043D\u044B\u0439
    \u0432\u0435\u0441\u0442\u043D\u0438\u043A\xBB \u0441 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0438\u0435\u043C.
    *   \u0412 \u043E\u0442\u0432\u0435\u0442 \u0433\u0435\u0440\u0446\u043E\u0433
    \u043D\u0430\u0437\u043D\u0430\u0447\u0438\u043B \u0413\u0430\u043B\u0438\u043B\u0435\u044F
    \u0441\u0432\u043E\u0438\u043C \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u044B\u043C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u043C \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C \u043E\u043A\u043B\u0430\u0434\u043E\u043C
    (\u0432 \u0434\u0432\u0430 \u0440\u0430\u0437\u0430 \u0431\u043E\u043B\u044C\u0448\u0435,
    \u0447\u0435\u043C \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435)
    \u0438 \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u043B \u043E\u0442 \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C. \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0441\u0442\u0430\u043B \u0443\u0447\u0435\u043D\u044B\u043C \u0441 \u0437\u0430\u0440\u043F\u043B\u0430\u0442\u043E\u0439
    \u0432 \xAB\u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0435 \u043F\u043B\u0430\u0432\u0430\u043D\u0438\u0435\xBB. 
    ### 7. \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u0438 \u043F\u0430\u043F\u0430
    \u0440\u0438\u043C\u0441\u043A\u0438\u0439: \u0414\u0440\u0443\u0436\u0431\u0430,
    \u043F\u0435\u0440\u0435\u0448\u0435\u0434\u0448\u0430\u044F \u0432\u043E \u0432\u0440\u0430\u0436\u0434\u0443
    \u0414\u043E \u0441\u0443\u0434\u0430 \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0434\u0440\u0443\u0436\u0438\u043B \u0441 \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u043E\u043C
    \u041C\u0430\u0444\u0444\u0435\u043E \u0411\u0430\u0440\u0431\u0435\u0440\u0438\u043D\u0438
    (\u0431\u0443\u0434\u0443\u0449\u0438\u043C \u043F\u0430\u043F\u043E\u0439 \u0423\u0440\u0431\u0430\u043D\u043E\u043C
    VIII). \u0412 1624 \u0433\u043E\u0434\u0443 \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043F\u0440\u0438\u0435\u0445\u0430\u043B \u043A \u043D\u0435\u043C\u0443 \u0432
    \u0420\u0438\u043C \u043D\u0430 \u0430\u0443\u0434\u0438\u0435\u043D\u0446\u0438\u044E
    \u0446\u0435\u043B\u044B\u0445 **\u0448\u0435\u0441\u0442\u044C \u0440\u0430\u0437
    \u043F\u043E\u0434\u0440\u044F\u0434**! \u041F\u0430\u043F\u0430 \u0434\u0430\u0440\u0438\u043B
    \u0435\u043C\u0443 \u0446\u0435\u043D\u043D\u044B\u0435 \u043F\u043E\u0434\u0430\u0440\u043A\u0438
    \u0438 \u0431\u043B\u0430\u0433\u043E\u0441\u043B\u043E\u0432\u043B\u044F\u043B
    \u043D\u0430 \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u0438\u0435 \xAB\u0414\u0438\u0430\u043B\u043E\u0433\u043E\u0432\xBB.
    *   \u041E\u0434\u043D\u0430\u043A\u043E \u0432 \u043A\u043D\u0438\u0433\u0435
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u0432\u043B\u043E\u0436\u0438\u043B
    \u0434\u043E\u0432\u043E\u0434\u044B \u043F\u0430\u043F\u044B \u0423\u0440\u0431\u0430\u043D\u0430
    VIII \u0432 \u0443\u0441\u0442\u0430 \u0433\u043B\u0443\u043F\u043E\u0432\u0430\u0442\u043E\u0433\u043E
    \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430 \u043F\u043E \u0438\u043C\u0435\u043D\u0438
    **\u0421\u0438\u043C\u043F\u043B\u0438\u0447\u043E** (\u0447\u0442\u043E \u0437\u043D\u0430\u0447\u0438\u0442
    \xAB\u041F\u0440\u043E\u0441\u0442\u0430\u043A\xBB \u0438\u043B\u0438 \xAB\u0414\u0443\u0440\u0430\u0447\u043E\u043A\xBB).
    *   \u041A\u043E\u0433\u0434\u0430 \u043F\u0430\u043F\u0430 \u044D\u0442\u043E
    \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043B, \u043E\u043D \u0431\u044B\u043B
    \u0432 \u044F\u0440\u043E\u0441\u0442\u0438 \u043D\u0435 \u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0438\u0437-\u0437\u0430 \u043D\u0430\u0443\u043A\u0438, \u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0438\u0437-\u0437\u0430 \u043B\u0438\u0447\u043D\u043E\u0433\u043E \u043E\u0441\u043A\u043E\u0440\u0431\u043B\u0435\u043D\u0438\u044F.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0433\u043D\u0435\u0432 \u043F\u043E\u043D\u0442\u0438\u0444\u0438\u043A\u0430,
    \u0430 \u043D\u0435 \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0441\u043A\u0438\u0435
    \u0441\u043F\u043E\u0440\u044B, \u043F\u0440\u0438\u0432\u0435\u043B \u043A \u0436\u0435\u0441\u0442\u043A\u043E\u043C\u0443
    \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\u0443 1633 \u0433\u043E\u0434\u0430. 
    ### 8. \u041F\u043E\u043C\u0438\u0434\u043E\u0440\u044B \u0438 \u0441\u0443\u043F:
    \u0423\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435 \u0441\u043F\u0430\u0441\u0435\u043D\u0438\u0435
    \u0417\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0435\u0441\u044F\u0446\u0435\u0432
    \u0434\u043E \u0441\u0443\u0434\u0430 \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0442\u044F\u0436\u0435\u043B\u043E \u0437\u0430\u0431\u043E\u043B\u0435\u043B.
    \u0412\u0440\u0430\u0447\u0438 \u043F\u0440\u0435\u0434\u043F\u0438\u0441\u0430\u043B\u0438
    \u0435\u043C\u0443 \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u0434\u0438\u0435\u0442\u0443.
    \u0418\u043D\u043A\u0432\u0438\u0437\u0438\u0442\u043E\u0440\u044B \u0431\u043E\u044F\u043B\u0438\u0441\u044C,
    \u0447\u0442\u043E \u043E\u043D \u0443\u043C\u0440\u0435\u0442 \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0441\u043C\u0435\u0440\u0442\u044C\u044E \u0434\u043E \u0442\u043E\u0433\u043E,
    \u043A\u0430\u043A \u043F\u0440\u0438\u0437\u043D\u0430\u044E\u0442 \u0435\u0433\u043E
    \u0432\u0438\u043D\u043E\u0432\u043D\u044B\u043C, \u0438 \u044D\u0442\u043E \u0441\u043E\u0440\u0432\u0435\u0442
    \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441. *   **\u0417\u0430\u0431\u0430\u0432\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442:** \u041E\u043D\u0438 \u043F\u0440\u0438\u043A\u0430\u0437\u0430\u043B\u0438
    \u043A\u043E\u0440\u043C\u0438\u0442\u044C \u0435\u0433\u043E \u043A\u0443\u0440\u0438\u043D\u044B\u043C
    \u0431\u0443\u043B\u044C\u043E\u043D\u043E\u043C \u0438 \u044F\u0439\u0446\u0430\u043C\u0438,
    \u0447\u0442\u043E\u0431\u044B \u043E\u043D \u043E\u043A\u0440\u0435\u043F \u0438
    \u0434\u043E\u0436\u0438\u043B \u0434\u043E \u0441\u0443\u0434\u0430. *   \u041D\u043E
    \u043F\u043E \u0438\u0440\u043E\u043D\u0438\u0438 \u0441\u0443\u0434\u044C\u0431\u044B,
    \u0438\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u043E \u0432\u0440\u0435\u043C\u044F
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0442\u0440\u0430\u043A\u0442\u0430\u0442
    \u043E \u0442\u043E\u043C, \u043A\u0430\u043A \u043B\u0443\u0447\u0448\u0435
    \u0432\u0430\u0440\u0438\u0442\u044C \u044F\u0439\u0446\u0430, \u0447\u0442\u043E\u0431\u044B
    \u043E\u043D\u0438 \u043D\u0435 \u043B\u043E\u043F\u0430\u043B\u0438\u0441\u044C.
    \u0410 \u0435\u0449\u0435 \u043E\u043D \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0446\u0435\u0432,
    \u043A\u0442\u043E \u043D\u0430\u0447\u0430\u043B \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u043F\u0440\u043E\u043F\u0430\u0433\u0430\u043D\u0434\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    **\u043F\u043E\u043C\u0438\u0434\u043E\u0440\u044B** \u0432 \u043F\u0438\u0449\u0443
    (\u0445\u043E\u0442\u044F \u0434\u043E \u0441\u043E\u0443\u0441\u0430 \u0431\u043E\u043B\u043E\u043D\u044C\u0435\u0437\u0435
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u043E\u0441\u044C \u0435\u0449\u0451
    300 \u043B\u0435\u0442).  ### 9. \u0421\u0430\u043C\u0430\u044F \u043F\u0440\u0435\u0434\u0430\u043D\u043D\u0430\u044F
    \u0436\u0435\u043D\u0449\u0438\u043D\u0430 \u0432 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438
    \u2014 \u043C\u043E\u043D\u0430\u0445\u0438\u043D\u044F \u041C\u044B \u0437\u043D\u0430\u0435\u043C
    \u043E \u0442\u0440\u0435\u0445 \u0434\u0435\u0442\u044F\u0445 \u0413\u0430\u043B\u0438\u043B\u0435\u044F.
    \u041D\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u044B\u0439
    \u0442\u0440\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u0444\u0430\u043A\u0442
    \u2014 \u044D\u0442\u043E \u0435\u0433\u043E \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430
    \u0441 \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u0435\u0439
    (\u0421\u0435\u0441\u0442\u0440\u043E\u0439 \u041C\u0430\u0440\u0438\u0435\u0439
    \u0427\u0435\u043B\u0435\u0441\u0442\u043E\u0439), \u043A\u043E\u0433\u0434\u0430
    \u043E\u043D \u0431\u044B\u043B \u043F\u043E\u0434 \u0434\u043E\u043C\u0430\u0448\u043D\u0438\u043C
    \u0430\u0440\u0435\u0441\u0442\u043E\u043C. *   \u041E\u043D\u0430 \u0436\u0438\u043B\u0430
    \u0432 \u0441\u043E\u0441\u0435\u0434\u043D\u0435\u043C \u043C\u043E\u043D\u0430\u0441\u0442\u044B\u0440\u0435.
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u043D\u0435 \u043C\u043E\u0433 \u0435\u0435
    \u043D\u0430\u0432\u0435\u0449\u0430\u0442\u044C (\u043F\u043E \u043F\u0440\u0438\u043A\u0430\u0437\u0443
    \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u0438), \u043D\u043E \u043E\u043D\u0430
    \u043F\u0440\u0438\u0441\u044B\u043B\u0430\u043B\u0430 \u0435\u043C\u0443 **\u043F\u0435\u0447\u0435\u043D\u044C\u0435,
    \u0432\u0430\u0440\u0435\u043D\u044C\u0435 \u0438 \u0432\u044B\u0448\u0438\u0442\u044B\u0435
    \u043F\u043B\u0430\u0442\u043A\u0438**. *   \u041E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u043F\u043E\u043C\u043E\u0449\u043D\u0438\u043A\u043E\u043C:
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0430 \u0435\u0433\u043E
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0438 \u043D\u0430\u0431\u0435\u043B\u043E
    (\u0443 \u043D\u0435\u0433\u043E \u0431\u044B\u043B \u0443\u0436\u0430\u0441\u043D\u044B\u0439
    \u043F\u043E\u0447\u0435\u0440\u043A), \u043F\u043E\u043A\u0430 \u043D\u0435
    \u0443\u043C\u0435\u0440\u043B\u0430 \u0432 1634 \u0433\u043E\u0434\u0443 \u043E\u0442
    \u0434\u0438\u0437\u0435\u043D\u0442\u0435\u0440\u0438\u0438. \u0415\u0435 \u0441\u043C\u0435\u0440\u0442\u044C
    \u0441\u043B\u043E\u043C\u0430\u043B\u0430 \u0413\u0430\u043B\u0438\u043B\u0435\u044F
    \u0431\u043E\u043B\u044C\u0448\u0435, \u0447\u0435\u043C \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440
    \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u0438. \u041E\u043D \u0433\u043E\u0434\u0430\u043C\u0438
    \u043D\u0435 \u043C\u043E\u0433 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u043E\u0442 \u0433\u043E\u0440\u044F.  ### 10. \u0415\u0433\u043E \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0438\u043B\u0438
    \xAB\u043D\u0435 \u043F\u043E \u0447\u0438\u043D\u0443\xBB \u0446\u0435\u043B\u044B\u0445
    95 \u043B\u0435\u0442 \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u0443\u043C\u0435\u0440
    \u0432 1642 \u0433\u043E\u0434\u0443 \u043F\u043E\u0434 \u0434\u043E\u043C\u0430\u0448\u043D\u0438\u043C
    \u0430\u0440\u0435\u0441\u0442\u043E\u043C. \u0426\u0435\u0440\u043A\u043E\u0432\u044C
    \u0437\u0430\u043F\u0440\u0435\u0442\u0438\u043B\u0430 \u0445\u043E\u0440\u043E\u043D\u0438\u0442\u044C
    \u0435\u0433\u043E \u0441 \u043F\u043E\u0447\u0435\u0441\u0442\u044F\u043C\u0438
    \u0432 \u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u0431\u0430\u0437\u0438\u043B\u0438\u043A\u0435
    \u0424\u043B\u043E\u0440\u0435\u043D\u0446\u0438\u0438 (\u0421\u0430\u043D\u0442\u0430-\u041A\u0440\u043E\u0447\u0435)
    \u0440\u044F\u0434\u043E\u043C \u0441 \u041C\u0438\u043A\u0435\u043B\u0430\u043D\u0434\u0436\u0435\u043B\u043E.
    \u0415\u0433\u043E \u0442\u0435\u043B\u043E \u043F\u0440\u043E\u0441\u0442\u043E
    \u0437\u0430\u0441\u0443\u043D\u0443\u043B\u0438 \u0432 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0443\u044E
    \u0431\u043E\u043A\u043E\u0432\u0443\u044E \u043A\u043E\u043C\u043D\u0430\u0442\u043A\u0443.
    *   \u0422\u043E\u043B\u044C\u043A\u043E \u0432 **1737 \u0433\u043E\u0434\u0443**
    (\u0447\u0435\u0440\u0435\u0437 95 \u043B\u0435\u0442) \u0435\u0433\u043E \u043E\u0441\u0442\u0430\u043D\u043A\u0438
    \u043F\u0435\u0440\u0435\u043D\u0435\u0441\u043B\u0438 \u0432 \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u043C\u0430\u0432\u0437\u043E\u043B\u0435\u0439 \u0431\u0430\u0437\u0438\u043B\u0438\u043A\u0438.
    *   **\u0416\u0443\u0442\u043A\u0430\u044F \u0434\u0435\u0442\u0430\u043B\u044C:**
    \u041F\u0440\u0438 \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0435 \u043C\u043E\u0449\u0435\u0439
    \u0432 1737 \u0433\u043E\u0434\u0443 \u0432 \u0433\u0440\u043E\u0431\u0443 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B\u0438,
    \u0447\u0442\u043E \u0442\u0435\u043B\u043E \u043C\u0443\u043C\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u043B\u043E\u0441\u044C.
    \u0423\u0447\u0435\u043D\u044B\u0435 \u0432\u044B\u043D\u0443\u043B\u0438 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0447\u0430\u0441\u0442\u0435\u0439 \u0442\u0435\u043B\u0430 \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u0440\u0435\u043B\u0438\u043A\u0432\u0438\u0439: **\u0441\u0440\u0435\u0434\u043D\u0438\u0439
    \u043F\u0430\u043B\u0435\u0446 \u043F\u0440\u0430\u0432\u043E\u0439 \u0440\u0443\u043A\u0438**,
    \u0437\u0443\u0431 \u0438 \u043F\u044F\u0442\u044B\u0439 \u043F\u043E\u0437\u0432\u043E\u043D\u043E\u043A.
    \u042D\u0442\u0438 \xAB\u0441\u0443\u0432\u0435\u043D\u0438\u0440\u044B\xBB \u043F\u043E\u0437\u0436\u0435
    \u0431\u044B\u043B\u0438 \u043F\u0440\u043E\u0434\u0430\u043D\u044B \u0438 \u0434\u043E\u043B\u0433\u043E
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u043F\u043E \u0430\u043D\u0442\u0438\u043A\u0432\u0430\u0440\u043D\u044B\u043C
    \u043B\u0430\u0432\u043A\u0430\u043C. \u0421\u0435\u0439\u0447\u0430\u0441 \u043E\u043D\u0438
    \u0445\u0440\u0430\u043D\u044F\u0442\u0441\u044F \u0432 \u043C\u0443\u0437\u0435\u0435
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u0432\u043E \u0424\u043B\u043E\u0440\u0435\u043D\u0446\u0438\u0438.
    \u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0443\u0432\u0438\u0434\u0435\u0442\u044C
    \u0435\u0433\u043E \u043F\u0430\u043B\u0435\u0446, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u0435\u0440\u0436\u0430\u043B \u043F\u0435\u0440\u043E, \u043D\u0430\u043F\u0438\u0441\u0430\u0432\u0448\u0435\u0435
    \xAB\u0414\u0438\u0430\u043B\u043E\u0433\u0438\xBB.  ### 11. \u0421\u043B\u0435\u043F\u043E\u0442\u0430
    \u043E\u0442 \u0421\u043E\u043B\u043D\u0446\u0430 \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u043E\u0441\u043B\u0435\u043F \u0437\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043B\u0435\u0442 \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438. \u041E\u0431\u044B\u0447\u043D\u043E
    \u044D\u0442\u043E \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u044E\u0442 \u0441\u043E
    \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u044C\u044E \u0438\u043B\u0438 \u0433\u043B\u0430\u0443\u043A\u043E\u043C\u043E\u0439,
    \u043D\u043E \u0435\u0441\u0442\u044C \u0438 \u0434\u0440\u0443\u0433\u0430\u044F
    \u0432\u0435\u0440\u0441\u0438\u044F. *   \u041E\u043D \u0447\u0430\u0441\u0442\u043E
    \u0438 \u043F\u043E\u0434\u043E\u043B\u0433\u0443 \u0441\u043C\u043E\u0442\u0440\u0435\u043B
    \u043D\u0430 \u0421\u043E\u043B\u043D\u0446\u0435 \u0447\u0435\u0440\u0435\u0437
    \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F, \u043D\u0435 \u0438\u043C\u0435\u044F
    \u0437\u0430\u0449\u0438\u0442\u043D\u044B\u0445 \u0444\u0438\u043B\u044C\u0442\u0440\u043E\u0432,
    \u0447\u0442\u043E\u0431\u044B \u0437\u0430\u0440\u0438\u0441\u043E\u0432\u0430\u0442\u044C
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u043F\u044F\u0442\u0435\u043D
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0441\u0432\u0435\u0442\u0438\u043B\u0430. *   \u042D\u0442\u043E \u043F\u043E\u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E
    \u0432\u044B\u0436\u0438\u0433\u0430\u043B\u043E \u0441\u0435\u0442\u0447\u0430\u0442\u043A\u0443
    \u0433\u043B\u0430\u0437\u0430. \u0412\u0440\u0430\u0447\u0438 \u0442\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043D\u0435 \u0437\u043D\u0430\u043B\u0438
    \u043E \u0432\u0440\u0435\u0434\u0435 \u0443\u043B\u044C\u0442\u0440\u0430\u0444\u0438\u043E\u043B\u0435\u0442\u0430,
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E *\u0441\u043C\u043E\u0442\u0440\u0435\u043B
    \u043D\u0430 \u0438\u0441\u0442\u0438\u043D\u0443 \u0434\u043E \u0442\u0435\u0445
    \u043F\u043E\u0440, \u043F\u043E\u043A\u0430 \u043D\u0435 \u043E\u0441\u043B\u0435\u043F*. 
    ### 12. \u041E\u043F\u0430\u0441\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430:
    \u041F\u0435\u0440\u0435\u0432\u043E\u0437\u043A\u0430 \xAB\u0417\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043D\u043E\u0439
    \u043A\u043D\u0438\u0433\u0438\xBB \u0412 1638 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430
    \u0413\u0430\u043B\u0438\u043B\u0435\u0439 \u0443\u0436\u0435 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043E\u0441\u043B\u0435\u043F, \u043E\u043D \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B
    \u0441\u0432\u043E\u0439 \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0440\u0443\u0434 \xAB\u0411\u0435\u0441\u0435\u0434\u044B...\xBB. \u0412
    \u0418\u0442\u0430\u043B\u0438\u0438 \u0435\u0433\u043E \u043F\u0435\u0447\u0430\u0442\u0430\u0442\u044C
    \u0431\u044B\u043B\u043E \u043D\u0435\u043B\u044C\u0437\u044F (\u0426\u0435\u0440\u043A\u043E\u0432\u044C
    \u0437\u0430\u043F\u0440\u0435\u0442\u0438\u043B\u0430 \u0432\u0441\u0435 \u0435\u0433\u043E
    \u043A\u043D\u0438\u0433\u0438). *   \u0413\u0430\u043B\u0438\u043B\u0435\u0439
    \u0442\u0430\u0439\u043D\u043E \u043F\u0435\u0440\u0435\u043F\u0440\u0430\u0432\u0438\u043B
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C \u0432 **\u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u044E**
    (\u0441\u0442\u0440\u0430\u043D\u0443 \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u043E\u0432)
    \u0432 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u043C \u0434\u0438\u043F\u043B\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0431\u0430\u0433\u0430\u0436\u0435. *   \u0427\u0442\u043E\u0431\u044B \u043A\u043D\u0438\u0433\u0443
    \u043D\u0435 \u043F\u0435\u0440\u0435\u0445\u0432\u0430\u0442\u0438\u043B\u0438,
    \u0442\u0435\u043A\u0441\u0442 \u0431\u044B\u043B \u0437\u0430\u0448\u0438\u0444\u0440\u043E\u0432\u0430\u043D
    \u0438\u043B\u0438 \u0437\u0430\u043C\u0430\u0441\u043A\u0438\u0440\u043E\u0432\u0430\u043D
    \u043F\u043E\u0434 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0438
    \u043A \u0440\u0438\u0441\u0443\u043D\u043A\u0430\u043C. \u041A\u043E\u0433\u0434\u0430
    \u043A\u043D\u0438\u0433\u0430 \u0432\u044B\u0448\u043B\u0430 \u0432 \u0441\u0432\u0435\u0442,
    \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0440\u0430\u0441\u043F\u0440\u043E\u0434\u0430\u043D\u0430
    \u0437\u0430 \u0441\u0447\u0438\u0442\u0430\u043D\u043D\u044B\u0435 \u0434\u043D\u0438,
    \u0430 \u0447\u0438\u0442\u0430\u0442\u0435\u043B\u0438 \u043F\u0435\u0440\u0435\u0434\u0430\u0432\u0430\u043B\u0438
    \u0435\u0451 \u0438\u0437 \u0440\u0443\u043A \u0432 \u0440\u0443\u043A\u0438,
    \u043A\u0430\u043A \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043D\u0443\u044E
    \u043F\u043E\u044D\u0437\u0438\u044E."
