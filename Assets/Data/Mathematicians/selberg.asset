  achievementsRu: "\u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433,
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 XX \u0432\u0435\u043A\u0430,
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0441\u043B\u0435\u0434 \u0432 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B \u0438 \u0441\u043C\u0435\u0436\u043D\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445, \u0430 \u0435\u0433\u043E \u0438\u043C\u044F
    \u043D\u043E\u0441\u044F\u0442 \u0434\u0435\u0441\u044F\u0442\u043A\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u043D\u044F\u0442\u0438\u0439 \u2014 \u043E\u0442 \u0440\u0435\u0448\u0435\u0442\u0430
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430 \u0434\u043E \u043A\u043B\u0430\u0441\u0441\u0430
    \u0438 \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0438.
    \u0412\u0435\u0440\u0448\u0438\u043D\u043E\u0439 \u0435\u0433\u043E \u0440\u0430\u043D\u043D\u0435\u0433\u043E
    \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430 \u0441\u0442\u0430\u043B\u043E
    \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u043E\u0435 \u0432 1948 \u0433\u043E\u0434\u0443
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B, \u0437\u0430
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0432 1950 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438.
    \u041A\u043B\u044E\u0447\u0435\u0432\u0443\u044E \u0440\u043E\u043B\u044C \u0432
    \u044D\u0442\u043E\u043C \u043F\u0440\u043E\u0440\u044B\u0432\u0435 \u0441\u044B\u0433\u0440\u0430\u043B\u0430
    \u0432\u044B\u0432\u0435\u0434\u0435\u043D\u043D\u0430\u044F \u0438\u043C \u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430 (\u0442\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u043E),
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0432\u0448\u0430\u044F \u043E\u0431\u043E\u0439\u0442\u0438\u0441\u044C
    \u0431\u0435\u0437 \u0441\u043B\u043E\u0436\u043D\u043E\u0433\u043E \u0430\u043D\u0430\u043B\u0438\u0437\u0430,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u043D\u044B\u0439
    \u0438\u043C \u0432 1947 \u0433\u043E\u0434\u0443 \u043C\u0435\u0442\u043E\u0434
    \u0440\u0435\u0448\u0435\u0442\u0430, \u0441\u0442\u0430\u0432\u0448\u0438\u0439
    \u043C\u043E\u0449\u043D\u0435\u0439\u0448\u0438\u043C \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u043E\u0446\u0435\u043D\u043A\u0438 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B \u0438
    \"\u043F\u043E\u0447\u0442\u0438 \u043F\u0440\u043E\u0441\u0442\u044B\u0445\"
    \u0447\u0438\u0441\u0435\u043B \u0432 \u0441\u0430\u043C\u044B\u0445 \u0440\u0430\u0437\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447\u0430\u0445 \u2014 \u043E\u0442 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u0435\u0439
    \u0434\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441\u0438\u0439 \u0438\u0437 \u043F\u0440\u043E\u0441\u0442\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B. \u041D\u0435 \u043C\u0435\u043D\u0435\u0435 \u044D\u043F\u043E\u0445\u0430\u043B\u044C\u043D\u043E\u0439
    \u0441\u0442\u0430\u043B\u0430 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430
    1942 \u0433\u043E\u0434\u0430, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0434\u043E\u043B\u044F \u043D\u0435\u0442\u0440\u0438\u0432\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u043D\u0443\u043B\u0435\u0439 \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0438
    \u0420\u0438\u043C\u0430\u043D\u0430 \u043B\u0435\u0436\u0438\u0442 \u043D\u0430
    \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043F\u0440\u044F\u043C\u043E\u0439,
    \u2014 \u044D\u0442\u043E\u0442 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0441\u0438\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u0445 \u043A\u0432\u0430\u043D\u0442\u0430\u0442\u0438\u0432\u043D\u044B\u0445
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0439
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B
    \u0420\u0438\u043C\u0430\u043D\u0430. \u041E\u0434\u043D\u0430\u043A\u043E, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0441\u0430\u043C\u044B\u043C \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C
    \u0441\u0442\u0430\u043B\u0430 \u0444\u043E\u0440\u043C\u0443\u043B\u0430 \u0441\u043B\u0435\u0434\u0430
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u0432 1956 \u0433\u043E\u0434\u0443 \u0438 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0432\u0448\u0430\u044F
    \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0441\u0432\u044F\u0437\u044C
    \u043C\u0435\u0436\u0434\u0443 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u0447\u0438\u0441\u0435\u043B,
    \u0441\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445 \u0444\u043E\u0440\u043C
    \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439, \u0447\u0442\u043E
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u044B
    \u0434\u043B\u044F \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B \u041B\u0435\u043D\u0433\u043B\u0435\u043D\u0434\u0441\u0430
    \u0438 \u043D\u0430\u0448\u043B\u043E \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0432 \u0441\u0430\u043C\u044B\u0445 \u0440\u0430\u0437\u043D\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0444\u0438\u0437\u0438\u043A\u0438.
    \u0412 \u0434\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u0435 \u043A \u044D\u0442\u0438\u043C
    \u043F\u0440\u043E\u0440\u044B\u0432\u0430\u043C \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043C\u0435\u0442\u043E\u0434
    \"\u043C\u043E\u043B\u043B\u0438\u0444\u0438\u043A\u0430\u0442\u043E\u0440\u043E\u0432\"
    \u0434\u043B\u044F \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0438,
    \u0432\u0432\u0435\u043B \u0432 \u043D\u0430\u0443\u043A\u0443 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430, \u0438\u043C\u0435\u044E\u0449\u0438\u0439
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0445 \u043C\u0430\u0442\u0440\u0438\u0446
    \u0438 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u044B\u0445 \u0441\u0438\u0441\u0442\u0435\u043C
    \u043C\u043D\u043E\u0433\u0438\u0445 \u0442\u0435\u043B, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0432\u043D\u0435\u0441 \u0440\u0435\u0448\u0430\u044E\u0449\u0438\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u0434\u0438\u0441\u043A\u0440\u0435\u0442\u043D\u044B\u0445
    \u0433\u0440\u0443\u043F\u043F \u0438 \u0436\u0435\u0441\u0442\u043A\u043E\u0441\u0442\u0438
    \u0440\u0435\u0448\u0435\u0442\u043E\u043A."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430
    \u0431\u044B\u043B\u0430 \u0442\u0435\u0441\u043D\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u0430
    \u0441 \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u0435\u0439 \u0438, \u0432
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438,
    \u0441 \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u043E\u0439 \u0432
    \u0421\u0428\u0410. \u0412 1947 \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0435 \u0425\u0435\u0434\u0432\u0438\u0433
    \u041B\u0438\u0431\u0435\u0440\u043C\u0430\u043D\u043D (Hedvig Liebermann), \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0432 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0432
    \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435 \u0432 \u0433\u0440\u0443\u043F\u043F\u0435
    \u0414\u0436\u043E\u043D\u0430 \u0444\u043E\u043D \u041D\u0435\u0439\u043C\u0430\u043D\u0430,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u043E\u0439
    \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u0438 \u0444\u0438\u0437\u0438\u043A\u0438
    \u043F\u043B\u0430\u0437\u043C\u044B. \u0412 \u044D\u0442\u043E\u043C \u0431\u0440\u0430\u043A\u0435,
    \u0434\u043B\u0438\u0432\u0448\u0435\u043C\u0441\u044F \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    \u0425\u0435\u0434\u0432\u0438\u0433 \u0432 1995 \u0433\u043E\u0434\u0443, \u0443
    \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0434\u0432\u043E\u0435
    \u0434\u0435\u0442\u0435\u0439: \u0434\u043E\u0447\u044C \u0418\u043D\u0433\u0440\u0438\u0434
    \u041C\u0430\u0440\u0438\u044F \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    (\u0432\u044B\u0448\u0435\u0434\u0448\u0430\u044F \u0437\u0430\u043C\u0443\u0436
    \u0437\u0430 \u0434\u0440\u0430\u043C\u0430\u0442\u0443\u0440\u0433\u0430 \u041C\u0443\u0441\u0442\u0430\u0444\u0443
    \u041C\u0430\u0442\u0443\u0440\u0430) \u0438 \u0441\u044B\u043D \u041B\u0430\u0440\u0441
    \u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433. \u0412
    2003 \u0433\u043E\u0434\u0443, \u0441\u043F\u0443\u0441\u0442\u044F \u0432\u043E\u0441\u0435\u043C\u044C
    \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u043F\u0435\u0440\u0432\u043E\u0439 \u0436\u0435\u043D\u044B, \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439
    \u0440\u0430\u0437 \u2014 \u043D\u0430 \u0411\u0435\u0442\u0442\u0438 \u0424\u0440\u044D\u043D\u0441\u0438\u0441
    (\xAB\u041C\u0438\u043A\u043A\u0438\xBB) \u041A\u043E\u043C\u043F\u0442\u043E\u043D
    (Betty Frances Compton). \u041E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0443 \u0441\u0435\u0431\u044F \u0434\u043E\u043C\u0430 \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435
    6 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 2007 \u0433\u043E\u0434\u0430 \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 90 \u043B\u0435\u0442 \u043E\u0442
    \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u043E\u0439 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438,
    \u043E\u0441\u0442\u0430\u0432\u0438\u0432 \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F
    \u0432\u0434\u043E\u0432\u0443, \u0434\u0432\u043E\u0438\u0445 \u0434\u0435\u0442\u0435\u0439,
    \u0447\u0435\u0442\u0432\u0435\u0440\u044B\u0445 \u0432\u043D\u0443\u043A\u043E\u0432
    \u0438 \u0434\u0432\u0443\u0445 \u043F\u0430\u0434\u0447\u0435\u0440\u0438\u0446."
  personalLifeEn: 
