  achievementsRu: "\u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F
    \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u043E \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u043C\u043E\u0436\u043D\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439,
    \u043A\u0430\u0436\u0434\u043E\u0435 \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u043F\u0440\u043E\u0440\u044B\u0432\u043D\u044B\u0435
    \u0438\u0434\u0435\u0438 \u0438 \u043C\u0435\u0442\u043E\u0434\u044B.  ### \U0001F9EC
    \u0420\u0430\u043D\u043D\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u044B: \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B  \u041D\u0430\u0447\u0430\u043B\u043E
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430
    \u0431\u044B\u043B\u043E \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043E
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430\u043C
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B, \u0438 \u0437\u0434\u0435\u0441\u044C
    \u043E\u043D \u0441\u0440\u0430\u0437\u0443 \u0436\u0435 \u0434\u043E\u0431\u0438\u043B\u0441\u044F
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432. 
    *   **\u0420\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043D\u0443\u043B\u0435\u0439 \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0438:**
    \u0412 1942 \u0433\u043E\u0434\u0443, \u0440\u0430\u0431\u043E\u0442\u0430\u044F
    \u0432 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438 \u0432 \u043E\u043A\u043A\u0443\u043F\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438, \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0440\u043E\u0440\u044B\u0432
    \u0432 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0438 \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0438
    \u0420\u0438\u043C\u0430\u043D\u0430. \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E **\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0434\u043E\u043B\u044F** \u0432\u0441\u0435\u0445 \u043D\u0435\u0442\u0440\u0438\u0432\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u043D\u0443\u043B\u0435\u0439 \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0438
    \u043B\u0435\u0436\u0438\u0442 \u043D\u0430 \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u0440\u044F\u043C\u043E\u0439 `Re(s) = 1/2`. \u042D\u0442\u043E \u0431\u044B\u043B
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u0442\u0430\u043A\u043E\u0433\u043E \u0440\u043E\u0434\u0430 \u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u0448\u0430\u0433 \u0432\u043F\u0435\u0440\u0435\u0434 \u0432 \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0438
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B
    \u0420\u0438\u043C\u0430\u043D\u0430. *   **\"\u042D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0435\"
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B:**
    \u0412 1948 \u0433\u043E\u0434\u0443 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u043E \u0442\u043E\u043B\u044C\u043A\u043E
    \u043C\u0435\u0442\u043E\u0434\u044B \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430, \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u0441\u043B\u043E\u0436\u043D\u043E\u0433\u043E \u0430\u043D\u0430\u043B\u0438\u0437\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u043B\u0441\u044F
    \u0440\u0430\u043D\u0435\u0435. \u042D\u0442\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0441\u0442\u0430\u043B\u043E \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0441\u0435\u043D\u0441\u0430\u0446\u0438\u0435\u0439.
    \u041F\u043E\u0447\u0442\u0438 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u043A \u0430\u043D\u0430\u043B\u043E\u0433\u0438\u0447\u043D\u043E\u043C\u0443
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0443 \u043F\u0440\u0438\u0448\u0435\u043B
    \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u041F\u0430\u043B \u042D\u0440\u0434\u0451\u0448, \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u043A \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439 \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0438
    \u043E \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0435, \u043E\u0434\u043D\u0430\u043A\u043E
    \u0441\u0442\u0430\u0442\u044C\u0438 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430
    \u0431\u044B\u043B\u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u044B
    \u043F\u0435\u0440\u0432\u044B\u043C\u0438. \u0417\u0430 \u044D\u0442\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    \u0432 1950 \u0433\u043E\u0434\u0443. *   **\u041C\u0435\u0442\u043E\u0434 \u0440\u0435\u0448\u0435\u0442\u0430
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430 (Selberg sieve):** \u0412
    1940-\u0445 \u0433\u043E\u0434\u0430\u0445 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u043E\u0432\u044B\u0439
    \u043C\u043E\u0449\u043D\u044B\u0439 \u043C\u0435\u0442\u043E\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0440\u0435\u0448\u0435\u0442. \u0415\u0433\u043E \u0441\u0443\u0442\u044C \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0437\u0430\u043C\u0435\u043D\u0435 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u041C\u0451\u0431\u0438\u0443\u0441\u0430 \u0432 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0440\u0435\u0448\u0435\u0442\u0435 \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430
    \u043D\u0430 \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0432\u0435\u0441\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043F\u0442\u0438\u043C\u0438\u0437\u0438\u0440\u0443\u044E\u0442\u0441\u044F
    \u0434\u043B\u044F \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0438. \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C \u0431\u043E\u043B\u0435\u0435
    \u0442\u043E\u0447\u043D\u044B\u0435 \u0432\u0435\u0440\u0445\u043D\u0438\u0435
    \u0438 \u043D\u0438\u0436\u043D\u0438\u0435 \u043E\u0446\u0435\u043D\u043A\u0438
    \u0434\u043B\u044F \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430
    \u0447\u0438\u0441\u0435\u043B \u0432 \"\u043F\u0440\u043E\u0441\u0435\u044F\u043D\u043D\u044B\u0445\"
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430\u0445. \u042D\u0442\u043E\u0442
    \u043C\u0435\u0442\u043E\u0434 \u043D\u0430\u0448\u0435\u043B \u0448\u0438\u0440\u043E\u0447\u0430\u0439\u0448\u0435\u0435
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B.  ### \U0001F4D0 \u0424\u043E\u0440\u043C\u0443\u043B\u0430
    \u0441\u043B\u0435\u0434\u0430 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430
    \u0438 \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0435 \u0444\u043E\u0440\u043C\u044B 
    \u042D\u0442\u043E, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0441\u0430\u043C\u043E\u0435
    \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0441\u043E\u0435\u0434\u0438\u043D\u0438\u043B\u043E \u0430\u043D\u0430\u043B\u0438\u0437,
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0438 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0447\u0438\u0441\u0435\u043B.  *   **\u0424\u043E\u0440\u043C\u0443\u043B\u0430
    \u0441\u043B\u0435\u0434\u0430 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430
    (Selberg Trace Formula):** \u0412 1956 \u0433\u043E\u0434\u0443 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0443,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B
    \u0441\u0432\u043E\u044E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0441\u043B\u0435\u0434\u0430. \u042D\u0442\u0430
    \u0444\u043E\u0440\u043C\u0443\u043B\u0430 \u0443\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442
    \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0438 \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u0443\u044E
    \u0441\u0432\u044F\u0437\u044C \u043C\u0435\u0436\u0434\u0443 \u0434\u0432\u0443\u043C\u044F,
    \u043D\u0430 \u043F\u0435\u0440\u0432\u044B\u0439 \u0432\u0437\u0433\u043B\u044F\u0434,
    \u0440\u0430\u0437\u043D\u044B\u043C\u0438 \u043C\u0438\u0440\u0430\u043C\u0438
    :     *   **\u0421\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F:** \u0421\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F \u043E\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430
    \u041B\u0430\u043F\u043B\u0430\u0441\u0430 \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435
    \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043D\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u044B).     *   **\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:**
    \u0414\u043B\u0438\u043D\u044B \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0445
    \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0439
    \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u043E\u0439 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438.     
    \u0424\u043E\u0440\u043C\u0443\u043B\u0430 \u0441\u043B\u0435\u0434\u0430 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u0442\u044C \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E
    \u0438\u0437 \u043E\u0434\u043D\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0432 \u0434\u0440\u0443\u0433\u0443\u044E. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0441 \u0435\u0451 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043C\u043E\u0436\u043D\u043E
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0434\u043B\u0438\u043D \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0445
    \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    (\u0430\u043D\u0430\u043B\u043E\u0433 \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B \u0434\u043B\u044F
    \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445) 
    \u0438\u043B\u0438 \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E
    \u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F\u0445
    \u043E\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430 \u041B\u0430\u043F\u043B\u0430\u0441\u0430,
    \u0447\u0442\u043E \u0432\u0430\u0436\u043D\u043E \u0434\u043B\u044F \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0433\u043E
    \u0445\u0430\u043E\u0441\u0430.  *   **\u0414\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u044F
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430:** \u041A\u0430\u043A
    \u043F\u0440\u044F\u043C\u043E\u0435 \u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0435
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B \u0441\u043B\u0435\u0434\u0430, \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0432\u0432\u0435\u043B \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u044E,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u0442\u0441\u044F
    \u0447\u0435\u0440\u0435\u0437 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u043F\u043E \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043A\u043B\u0430\u0441\u0441\u0430\u043C \u0441\u043E\u043F\u0440\u044F\u0436\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441\u043E \u0441\u043F\u0435\u043A\u0442\u0440\u043E\u043C
    \u043E\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430 \u041B\u0430\u043F\u043B\u0430\u0441\u0430.
    \u0415\u0451 \u043D\u0443\u043B\u0438 \u0438 \u043F\u043E\u043B\u044E\u0441\u0430
    \u043D\u0435\u0441\u0443\u0442 \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E \u043E \u0441\u043F\u0435\u043A\u0442\u0440\u0435
    \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438.
    *   **\u041E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u044F:** \u0418\u0434\u0435\u0438
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430 \u0431\u044B\u043B\u0438
    \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u044B
    \u043D\u0430 \u0431\u043E\u043B\u0435\u0435 \u043E\u0431\u0449\u0438\u0435 \u0433\u0440\u0443\u043F\u043F\u044B
    \u041B\u0438 \u0438 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430,
    \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043D\u0430 `PSL(2, \u211D)\u207F`
    \u0434\u043B\u044F \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F \u0433\u0438\u0431\u0440\u0438\u0434\u043D\u044B\u0445
    \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445 \u0444\u043E\u0440\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432\u0435\u0434\u0443\u0442 \u0441\u0435\u0431\u044F
    \u043A\u0430\u043A \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0444\u043E\u0440\u043C\u044B \u0432 \u043E\u0434\u043D\u0438\u0445 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u0430\u0445
    \u0438 \u043A\u0430\u043A \u0444\u043E\u0440\u043C\u044B \u041C\u0430\u0430\u0441\u0441\u0430
    \u0432 \u0434\u0440\u0443\u0433\u0438\u0445. \u0424\u043E\u0440\u043C\u0443\u043B\u0430
    \u0441\u043B\u0435\u0434\u0430 \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
    \u043A \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E \u0447\u0438\u0441\u0435\u043B
    \u043A\u043B\u0430\u0441\u0441\u043E\u0432 \u0431\u0438\u043D\u0430\u0440\u043D\u044B\u0445
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0445 \u0444\u043E\u0440\u043C. 
    ### \U0001F4D6 \u0414\u0440\u0443\u0433\u0438\u0435 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0432\u043A\u043B\u0430\u0434\u044B  \u041F\u043E\u043C\u0438\u043C\u043E \u044D\u0442\u0438\u0445
    \u0434\u0432\u0443\u0445 \u0433\u0438\u0433\u0430\u043D\u0442\u0441\u043A\u0438\u0445
    \u0442\u0435\u043C, \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430
    \u0432\u043A\u043B\u044E\u0447\u0430\u0435\u0442 \u0432 \u0441\u0435\u0431\u044F
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0434\u0440\u0443\u0433\u0438\u0445
    \u0432\u0430\u0436\u043D\u044B\u0445 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432: 
    *   **\u041C\u0435\u0442\u043E\u0434 \u0420\u0430\u043D\u043A\u0438\u043D\u0430-\u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430:**
    \u0412\u043C\u0435\u0441\u0442\u0435 \u0441 \u0420. \u0410. \u0420\u0430\u043D\u043A\u0438\u043D\u044B\u043C
    \u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043C\u043E\u0449\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0435\u0442\u043E\u0434 \u0434\u043B\u044F \u043E\u0446\u0435\u043D\u043A\u0438
    \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u043E\u0432
    \u0424\u0443\u0440\u044C\u0435 \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u044B\u0445
    \u0444\u043E\u0440\u043C \u0438 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0445
    L-\u0444\u0443\u043D\u043A\u0446\u0438\u0439. *   **\u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u041B\u0438\u043D\u043D\u0438\u043A\u0430-\u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430:**
    \u041F\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0432\u0430\u0436\u043D\u0443\u044E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443 \u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439
    \u043E\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430 \u041B\u0430\u043F\u043B\u0430\u0441\u0430
    \u0434\u043B\u044F \u043A\u043E\u043D\u0433\u0440\u0443\u044D\u043D\u0446-\u043F\u043E\u0434\u0433\u0440\u0443\u043F\u043F,
    \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u0443\u044E \u0441 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u043E\u0439
    \u043E\u0446\u0435\u043D\u043A\u0438 \u043F\u0435\u0440\u0432\u043E\u0433\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F.
    \u0421\u0430\u043C \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433 \u0432 1965
    \u0433\u043E\u0434\u0443 \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u043E\u0446\u0435\u043D\u043A\u0443 `\u03BB\u2081 \u2265 3/16`, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0434\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C
    \u043D\u0435\u043F\u0440\u0435\u0432\u0437\u043E\u0439\u0434\u0435\u043D\u043D\u043E\u0439.
    *   **\u0424\u043E\u0440\u043C\u0443\u043B\u0430 \u0427\u043E\u0443\u043B\u044B-\u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430:**
    \u0412 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    \u0441 \u0421\u0430\u0440\u0432\u0430\u0434\u0430\u043C\u0430\u043D\u043E\u043C
    \u0427\u043E\u0443\u043B\u043E\u0439 \u043E\u043D \u0432\u044B\u0432\u0435\u043B
    \u0442\u043E\u0447\u043D\u0443\u044E \u0444\u043E\u0440\u043C\u0443\u043B\u0443
    \u0434\u043B\u044F \u043F\u0435\u0440\u0438\u043E\u0434\u043E\u0432 \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0438\u0432\u044B\u0445, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445
    \u0441 \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0435\u0439
    \u042D\u043F\u0448\u0442\u0435\u0439\u043D\u0430. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0440\u0435\u0448\u0435\u0442:** \u041E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u043C\u0435\u0442\u043E\u0434 \u0440\u0435\u0448\u0435\u0442\u0430,
    \u043D\u043E \u0438 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \"\u043F\u0440\u043E\u0441\u0435\u0438\u0432\u0430\u044E\u0449\u0438\u0445 \u043F\u043B\u043E\u0442\u043D\u043E\u0441\u0442\u0435\u0439\"
    \u0438 \u0434\u0440\u0443\u0433\u0438\u043C \u0441\u044E\u0436\u0435\u0442\u0430\u043C
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. 
    ### \U0001F4DA \u0421\u043E\u0431\u0440\u0430\u043D\u0438\u0435 \u0442\u0440\u0443\u0434\u043E\u0432 
    \u0412\u0441\u0435 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430
    \u0431\u044B\u043B\u0438 \u0441\u043E\u0431\u0440\u0430\u043D\u044B \u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u044B
    \u0432 \u0434\u0432\u0443\u0445 \u0442\u043E\u043C\u0430\u0445, \u0447\u0442\u043E
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u043F\u0440\u043E\u0441\u043B\u0435\u0434\u0438\u0442\u044C
    \u044D\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0435\u0433\u043E \u043C\u044B\u0441\u043B\u0438
    \u0438 \u043E\u0446\u0435\u043D\u0438\u0442\u044C \u043C\u0430\u0441\u0448\u0442\u0430\u0431
    \u0435\u0433\u043E \u0432\u043B\u0438\u044F\u043D\u0438\u044F. \u041F\u0435\u0440\u0432\u044B\u0439
    \u0442\u043E\u043C \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u0435\u0433\u043E
    \u0440\u0430\u043D\u043D\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0440\u0435\u0448\u0435\u0442, \u0430 \u0442\u0430\u043A\u0436\u0435 \u043B\u0435\u043A\u0446\u0438\u0438
    \u043F\u043E \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0430\u043D\u0430\u043B\u0438\u0437\u0443, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F \u0445\u043E\u0434\u0438\u043B\u0438
    \u0432 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044F\u0445 \u0438 \u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445 \u0444\u043E\u0440\u043C."
  achievementsEn: 
  personalLifeRu: "\u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u043D\u043E
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0441 \u043E\u0447\u0435\u043D\u044C
    \u043D\u0430\u0441\u044B\u0449\u0435\u043D\u043D\u043E\u0439 \u0438 \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u043E\u0439
    \u0441\u0443\u0434\u044C\u0431\u043E\u0439. \u0415\u0433\u043E \u043B\u0438\u0447\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0442\u0435\u0441\u043D\u043E \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u0430
    \u0441 \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439 XX \u0432\u0435\u043A\u0430
    \u0438 \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F\u043C\u0438.
    \u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0445\u0440\u043E\u043D\u0438\u043A\u0430
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.  ### \U0001F476 \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0421\u0435\u043C\u044C\u044F  \u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **14 \u0438\u044E\u043D\u044F 1917
    \u0433\u043E\u0434\u0430** \u0432 \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u0435 **\u041B\u0430\u043D\u0433\u0435\u0441\u0443\u043D\u043D**
    (Langesund). \u041E\u043D \u0431\u044B\u043B \u0441\u0430\u043C\u044B\u043C \u043C\u043B\u0430\u0434\u0448\u0438\u043C
    \u0438\u0437 \u0434\u0435\u0432\u044F\u0442\u0438 \u0434\u0435\u0442\u0435\u0439
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, **\u041E\u043B\u0435 \u041C\u0438\u0445\u0430\u044D\u043B\u044C
    \u041B\u044E\u0434\u0432\u0438\u0433\u0441\u0435\u043D \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433**,
    \u0431\u044B\u043B \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u043C \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0432 48
    \u043B\u0435\u0442 \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E. \u041C\u0430\u0442\u044C,
    **\u0410\u043D\u043D\u0430 \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430 \u0411\u0440\u0438\u0433\u0442\u0441\u0434\u0430\u0442\u0442\u0435\u0440
    \u0421\u043A\u0435\u0439\u0435**, \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B\u0430
    \u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0435\u0439. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u0431\u044B\u043B\u0438
    \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0439 \u0447\u0435\u0440\u0442\u043E\u0439:
    \u0442\u0440\u043E\u0435 \u0438\u0437 \u0431\u0440\u0430\u0442\u044C\u0435\u0432
    \u0410\u0442\u043B\u0435 \u2014 **\u0425\u0435\u043D\u0440\u0438\u043A**, **\u0421\u0438\u0433\u043C\u0443\u043D\u0434**
    \u0438 **\u0410\u0440\u043D\u0435** \u2014 \u0442\u0430\u043A\u0436\u0435 \u0441\u0442\u0430\u043B\u0438
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430\u043C\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    ### \U0001F4DA \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u042E\u043D\u043E\u0441\u0442\u044C:
    \u041F\u0443\u0442\u044C \u0432 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 
    \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0410\u0442\u043B\u0435 \u043F\u0440\u043E\u0448\u043B\u043E
    \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u0433\u043E\u0440\u043E\u0434\u0430\u0445
    \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438, \u043A\u0443\u0434\u0430 \u043F\u0435\u0440\u0435\u0435\u0437\u0436\u0430\u043B\u0430
    \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u044F \u043F\u043E \u0440\u0430\u0431\u043E\u0442\u0435
    \u043E\u0442\u0446\u0430: \u0412\u043E\u0441\u0441, \u0411\u0435\u0440\u0433\u0435\u043D,
    \u0430 \u0441 1932 \u0433\u043E\u0434\u0430 \u2014 \u0419\u0451\u0432\u0438\u043A.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E, \u0432\u043E\u043F\u0440\u0435\u043A\u0438
    \u043E\u0436\u0438\u0434\u0430\u043D\u0438\u044F\u043C, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430 \u0443\u0447\u0438\u043B\u0438
    \u043D\u0435 \u043E\u0442\u0435\u0446, \u0430 \u043A\u043D\u0438\u0433\u0438
    \u0438\u0437 \u0435\u0433\u043E \u0431\u043E\u0433\u0430\u0442\u043E\u0439 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0438. 
    \u0415\u0433\u043E \u043F\u0443\u0442\u044C \u0432 \u0431\u043E\u043B\u044C\u0448\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u043D\u0430\u0447\u0430\u043B\u0441\u044F
    \u0440\u0430\u043D\u043E: *   **\u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    7 \u043B\u0435\u0442** \u043E\u043D \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u044C
    \u043C\u0435\u0436\u0434\u0443 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430\u043C\u0438 \u0434\u0430\u0435\u0442
    \u043D\u0435\u0447\u0435\u0442\u043D\u044B\u0435 \u0447\u0438\u0441\u043B\u0430.
    *   **\u0412 13 \u043B\u0435\u0442** \u043E\u043D \u043D\u0430\u0442\u043A\u043D\u0443\u043B\u0441\u044F
    \u043D\u0430 \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u0434\u043B\u044F \u0447\u0438\u0441\u043B\u0430 \u03C0 (`\u03C0/4 = 1 - 1/3
    + 1/5 -...`). \u041F\u043E\u0437\u0436\u0435 \u043E\u043D \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0431\u044B\u043B\u043E \"\u0442\u0430\u043A\u043E\u0435
    \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0435 \u0438 \u043A\u0440\u0430\u0441\u0438\u0432\u043E\u0435
    \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435\", \u0447\u0442\u043E
    \u043E\u043D \u0440\u0435\u0448\u0438\u043B \u0432\u043E \u0447\u0442\u043E \u0431\u044B
    \u0442\u043E \u043D\u0438 \u0441\u0442\u0430\u043B\u043E \u043F\u043E\u043D\u044F\u0442\u044C,
    \u043A\u0430\u043A \u043E\u043D\u043E \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442\u0441\u044F.
    *   \u041F\u043E\u0432\u043E\u0440\u043E\u0442\u043D\u044B\u0439 \u043C\u043E\u043C\u0435\u043D\u0442
    \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B \u0432 **17 \u043B\u0435\u0442**,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043B
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435 \u0442\u0440\u0443\u0434\u043E\u0432
    \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    **\u0421\u0440\u0438\u043D\u0438\u0432\u0430\u0441\u044B \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430**.
    \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0430
    \u043D\u0430 \u043D\u0435\u0433\u043E \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u0438\u0435 \u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0430
    \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u0439
    \u043F\u0443\u0442\u044C \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B.
    \u0412\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u044B\u0439
    \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u043E\u043C, \u043E\u043D
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u044E \u043F\u0435\u0440\u0432\u0443\u044E
    \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u0441\u0442\u0430\u0442\u044C\u044E
    \"\u041E\u0431 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u0430\u0445\", \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430
    \u0432 1936 \u0433\u043E\u0434\u0443.  \u0412 1935 \u0433\u043E\u0434\u0443 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u0448\u043A\u043E\u043B\u0443 \u0432
    \u0419\u0451\u0432\u0438\u043A\u0435 \u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u041E\u0441\u043B\u043E**. 
    ### \U0001F393 \u0423\u0447\u0451\u0431\u0430 \u0438 \u0412\u043E\u0435\u043D\u043D\u044B\u0435
    \u0413\u043E\u0434\u044B  \u0412 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u043E\u043D \u0443\u0447\u0438\u043B\u0441\u044F \u0443 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    **\u041A\u0430\u0440\u043B\u0430 \u0421\u0442\u0451\u0440\u043C\u0435\u0440\u0430**,
    \u0447\u044C\u0438 \u043B\u0435\u043A\u0446\u0438\u0438 \u043E\u043D \u0438\u0437\u0443\u0447\u0430\u043B
    \u0435\u0449\u0435 \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435, \u0438
    **\u0422\u043E\u0440\u0441\u0442\u0435\u0439\u043D\u0430 \u0421\u043A\u043E\u043B\u0435\u043C\u0430**.
    \u041E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430 \u0432 1939 \u0433\u043E\u0434\u0443. 
    \u041D\u0430\u0447\u0430\u043B\u043E \u0412\u0442\u043E\u0440\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u043D\u0430\u0440\u0443\u0448\u0438\u043B\u043E
    \u0435\u0433\u043E \u043F\u043B\u0430\u043D\u044B \u043F\u043E\u0435\u0445\u0430\u0442\u044C
    \u0432 \u0413\u0430\u043C\u0431\u0443\u0440\u0433 \u0434\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441 \u042D\u0440\u0438\u0445\u043E\u043C \u0413\u0435\u043A\u043A\u0435. \u0412\u043C\u0435\u0441\u0442\u043E
    \u044D\u0442\u043E\u0433\u043E \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 **\u0423\u043F\u043F\u0441\u0430\u043B\u0443 (\u0428\u0432\u0435\u0446\u0438\u044F)**,
    \u0433\u0434\u0435 \u0431\u044B\u043B\u0430 \u043B\u0443\u0447\u0448\u0430\u044F
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0430, \u0438 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u041E\u0441\u043B\u043E \u0432 \u0434\u0435\u043A\u0430\u0431\u0440\u0435
    1939 \u0433\u043E\u0434\u0430.  \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0439
    \u043E\u043A\u043A\u0443\u043F\u0430\u0446\u0438\u0438 \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438 \u0421\u043E\u043F\u0440\u043E\u0442\u0438\u0432\u043B\u0435\u043D\u0438\u044F
    \u0438 **\u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0440\u0430\u0437
    \u0431\u044B\u043B \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D \u0432 \u0442\u044E\u0440\u044C\u043C\u0443**.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u044D\u0442\u043E,
    \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0432 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438. \u0415\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0442\u0435\u0445
    \u043B\u0435\u0442 \u0431\u044B\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0438\u0441\u044F, \u0447\u0442\u043E,
    \u043A\u043E\u0433\u0434\u0430 \u0434\u0430\u0442\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0425\u0430\u0440\u0430\u043B\u044C\u0434\u0430
    \u0411\u043E\u0440\u0430 \u0441\u043F\u0440\u043E\u0441\u0438\u043B\u0438, \u0447\u0442\u043E
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u043E \u0432 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0432\u043E\u0439\u043D\u044B, \u043E\u043D \u043A\u0440\u0430\u0442\u043A\u043E
    \u043E\u0442\u0432\u0435\u0442\u0438\u043B: **\"\u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\"**. 
    \u0412 1943 \u0433\u043E\u0434\u0443, \u043D\u0435\u0437\u0430\u0434\u043E\u043B\u0433\u043E
    \u0434\u043E \u0437\u0430\u043A\u0440\u044B\u0442\u0438\u044F \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u041E\u0441\u043B\u043E \u043E\u043A\u043A\u0443\u043F\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u043C\u0438
    \u0432\u043B\u0430\u0441\u0442\u044F\u043C\u0438, \u043E\u043D \u0443\u0441\u043F\u0435\u0448\u043D\u043E
    \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E.  ### \U0001F1FA\U0001F1F8
    \u0420\u0430\u0431\u043E\u0442\u0430 \u0432 \u0421\u0428\u0410 \u0438 \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u041A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438  \u041F\u043E\u0441\u043B\u0435
    \u0432\u043E\u0439\u043D\u044B, \u0432 **1947 \u0433\u043E\u0434\u0443**, \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0421\u0428\u0410. \u0421\u043D\u0430\u0447\u0430\u043B\u0430
    \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0434\u043E\u0446\u0435\u043D\u0442\u043E\u043C
    \u0432 **\u0421\u0438\u0440\u0430\u043A\u0443\u0437\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435**,
    \u043D\u043E \u0443\u0436\u0435 \u0432 1949 \u0433\u043E\u0434\u0443 \u043F\u0435\u0440\u0435\u0448\u0435\u043B
    \u0432 **\u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 (IAS)
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435**, \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0431\u044B\u043B\u0430 \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0432\u0441\u044F
    \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430. \u0412 1951 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 \u0438 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u0438\u043C \u0434\u043E \u0432\u044B\u0445\u043E\u0434\u0430 \u043D\u0430 \u043F\u0435\u043D\u0441\u0438\u044E
    \u0432 1987 \u0433\u043E\u0434\u0443.  \u0412 1950 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D **\u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438** \u0437\u0430 \u0441\u0432\u043E\u0435
    \"\u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0435\"
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B.  **\u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u041F\u043E\u043B\u043E\u043C \u042D\u0440\u0434\u0451\u0448\u0435\u043C:**
    \u042D\u0442\u043E \u043E\u0434\u043D\u0430 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u0438 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u044B\u0445
    \u0441\u0442\u0440\u0430\u043D\u0438\u0446 \u0432 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438.
    \u0412 1948 \u0433\u043E\u0434\u0443 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0438 \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    **\u041F\u0430\u043B \u042D\u0440\u0434\u0451\u0448** \u043F\u043E\u0447\u0442\u0438
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E, \u043D\u043E
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E, \u043F\u0440\u0438\u0448\u043B\u0438
    \u043A \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u043C\u0443
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B. \u0412\u043E\u0437\u043D\u0438\u043A\u043B\u0430
    \u043E\u0441\u0442\u0440\u0430\u044F \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u044F
    \u043E \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0435. \u0421\u0442\u0430\u0442\u044C\u0438
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430 \u0431\u044B\u043B\u0438
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u044B \u043F\u0435\u0440\u0432\u044B\u043C\u0438,
    \u0438 \u043F\u0440\u0435\u043C\u0438\u044E \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043E\u043D \u043E\u0434\u0438\u043D, \u0447\u0442\u043E \u0432\u044B\u0437\u0432\u0430\u043B\u043E
    \u043D\u0435\u0433\u043E\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u0441\u043E
    \u0441\u0442\u043E\u0440\u043E\u043D\u044B \u042D\u0440\u0434\u0451\u0448\u0430
    \u0438 \u0435\u0433\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043A\u043E\u0432.
    \u041C\u043D\u043E\u0433\u0438\u0435 \u043F\u043E\u043B\u0430\u0433\u0430\u043B\u0438,
    \u0447\u0442\u043E \u043D\u0430\u0433\u0440\u0430\u0434\u0443 \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C. \u041F\u043E \u0441\u043B\u043E\u0432\u0430\u043C
    \u043A\u043E\u043B\u043B\u0435\u0433, \u042D\u0440\u0434\u0451\u0448 \u0431\u044B\u043B
    \"\u043F\u0440\u0438\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u044B\u043C collaborator'\u043E\u043C\"
    (\u0441\u043E\u0430\u0432\u0442\u043E\u0440\u043E\u043C), \u0430 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u2014 \"\u043E\u0434\u0438\u043D\u043E\u0447\u043A\u043E\u0439\" (loner), \u0447\u0442\u043E
    \u0438 \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \"\u043F\u0440\u043E\u0432\u0430\u043B\u0443
    \u0432 \u043A\u043E\u043C\u043C\u0443\u043D\u0438\u043A\u0430\u0446\u0438\u0438\"
    \u043C\u0435\u0436\u0434\u0443 \u043D\u0438\u043C\u0438.  ### \U0001F48D \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0438 \u0421\u043C\u0435\u0440\u0442\u044C  \u0412
    **1947 \u0433\u043E\u0434\u0443** \u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u0425\u0435\u0434\u0432\u0438\u0433
    \u041B\u0438\u0431\u0435\u0440\u043C\u0430\u043D\u043D**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0442\u0430\u043A\u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430
    \u0432 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. \u0423
    \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0434\u0432\u043E\u0435
    \u0434\u0435\u0442\u0435\u0439: \u0434\u043E\u0447\u044C **\u0418\u043D\u0433\u0440\u0438\u0434**
    \u0438 \u0441\u044B\u043D **\u041B\u0430\u0440\u0441**. \u0425\u0435\u0434\u0432\u0438\u0433
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C \u0432 1995 \u0433\u043E\u0434\u0443.
    \u041F\u043E\u0437\u0436\u0435, \u0432 2003 \u0433\u043E\u0434\u0443, \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439
    \u0440\u0430\u0437 \u043D\u0430 \u0411\u0435\u0442\u0442\u0438 \u041A\u043E\u043C\u043F\u0442\u043E\u043D
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433.  \u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F **6 \u0430\u0432\u0433\u0443\u0441\u0442\u0430
    2007 \u0433\u043E\u0434\u0430** \u0432 \u0441\u0432\u043E\u0435\u043C \u0434\u043E\u043C\u0435
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435 \u043E\u0442 **\u0441\u0435\u0440\u0434\u0435\u0447\u043D\u043E\u0439
    \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438**
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 90 \u043B\u0435\u0442. 
    \u041D\u0430\u0434\u0435\u044E\u0441\u044C, \u044D\u0442\u043E\u0442 \u0440\u0430\u0441\u0441\u043A\u0430\u0437
    \u043F\u043E\u043C\u043E\u0433 \u0432\u0430\u043C \u0443\u0432\u0438\u0434\u0435\u0442\u044C
    \u0437\u0430 \u0432\u0435\u043B\u0438\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0436\u0438\u0432\u043E\u0433\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    \u0441\u043E \u0441\u0432\u043E\u0435\u0439 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439
    \u0438\u0441\u0442\u043E\u0440\u0438\u0435\u0439. \u0415\u0441\u043B\u0438 \u0432\u0430\u0441
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0443\u0435\u0442 \u043A\u0430\u043A\u043E\u0439-\u0442\u043E
    \u0438\u0437 \u044D\u0442\u0438\u0445 \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0435 \u2014 \u044F \u0433\u043E\u0442\u043E\u0432
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C."
  personalLifeEn: 
  shortBioRu: "\u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    (1917\u20132007) \u2014 \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445 \u0444\u043E\u0440\u043C
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0441\u043B\u0435\u0434 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    XX \u0432\u0435\u043A\u0430. \u041E\u043D \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u043A\u0430\u043A \u0430\u0432\u0442\u043E\u0440 \xAB\u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0433\u043E\xBB
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B \u0438
    \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u0441\u043B\u0435\u0434\u0430 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430. 
    ### \U0001F9EC \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435  \u0410\u0442\u043B\u0435
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    14 \u0438\u044E\u043D\u044F 1917 \u0433\u043E\u0434\u0430 \u0432 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u043C
    \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u043E\u043C \u0433\u043E\u0440\u043E\u0434\u0435
    \u041B\u0430\u043D\u0433\u0435\u0441\u0443\u043D\u043D (\u0422\u0435\u043B\u0435\u043C\u0430\u0440\u043A).
    \u041E\u043D \u0431\u044B\u043B \u0441\u0430\u043C\u044B\u043C \u043C\u043B\u0430\u0434\u0448\u0438\u043C
    \u0438\u0437 \u0434\u0435\u0432\u044F\u0442\u0438 \u0434\u0435\u0442\u0435\u0439
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u043E\u0432
    \u0410\u043D\u043D\u044B \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u044B \u0438
    \u041E\u043B\u0435 \u041C\u0438\u0445\u0430\u044D\u043B\u044F \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u043E\u0432.
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C
    \u0443 \u043D\u0435\u0433\u043E \u0440\u0430\u043D\u043E: \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u043E\u043A\u043E\u043B\u043E \u0441\u0435\u043C\u0438 \u043B\u0435\u0442 \u043E\u043D
    \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B \u0437\u0430\u043A\u043E\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C,
    \u0447\u0442\u043E \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u044C \u043C\u0435\u0436\u0434\u0443
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430\u043C\u0438 \u0434\u0430\u0435\u0442
    \u043D\u0435\u0447\u0435\u0442\u043D\u044B\u0435 \u0447\u0438\u0441\u043B\u0430.
    \u0414\u0432\u043E\u0435 \u0435\u0433\u043E \u0431\u0440\u0430\u0442\u044C\u0435\u0432,
    \u0421\u0438\u0433\u043C\u0443\u043D\u0434 \u0438 \u0425\u0435\u043D\u0440\u0438\u043A,
    \u0442\u0430\u043A\u0436\u0435 \u0441\u0442\u0430\u043B\u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430\u043C\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  \u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u0439
    \u043C\u043E\u043C\u0435\u043D\u0442 \u0432 \u0435\u0433\u043E \u0441\u0443\u0434\u044C\u0431\u0435
    \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u043B \u0432 1934 \u0433\u043E\u0434\u0443,
    \u043A\u043E\u0433\u0434\u0430 17-\u043B\u0435\u0442\u043D\u0438\u0439 \u0410\u0442\u043B\u0435
    \u043D\u0430\u0448\u0435\u043B \u0443 \u043E\u0434\u043D\u043E\u0433\u043E \u0438\u0437
    \u0431\u0440\u0430\u0442\u044C\u0435\u0432 \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435
    \u0442\u0440\u0443\u0434\u043E\u0432 \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0421\u0440\u0438\u043D\u0438\u0432\u0430\u0441\u044B
    \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430. \u042D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0430
    \u043D\u0430 \u044E\u043D\u043E\u0448\u0443 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u0438\u0435 \u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0430
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u0435\u0433\u043E
    \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u0445 \u0437\u0430\u043D\u044F\u0442\u0438\u0439.
    \u0412 \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u044E \u043F\u0435\u0440\u0432\u0443\u044E
    \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u0441\u0442\u0430\u0442\u044C\u044E
    \xAB\u041E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u0430\u0445\xBB. \u0412\u0441\u043A\u043E\u0440\u0435
    \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u041E\u0441\u043B\u043E.  \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433 \u043E\u0431\u043B\u0430\u0434\u0430\u043B
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439 \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0435\u0439,
    \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0449\u0430\u044F \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043E\u043D \u043D\u0430\u0448\u0435\u043B \u0442\u043E\u0447\u043D\u0443\u044E
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0434\u043B\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u0438
    \u0440\u0430\u0437\u0431\u0438\u0435\u043D\u0438\u044F (partition function),
    \u043D\u043E, \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u0432, \u0447\u0442\u043E
    \u0435\u0433\u043E \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B \u0413\u0430\u043D\u0441
    \u0420\u0430\u0434\u0435\u043C\u0430\u0445\u0435\u0440, \u0440\u0435\u0448\u0438\u043B
    \u043D\u0435 \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u044E \u0440\u0430\u0431\u043E\u0442\u0443, \u0445\u043E\u0442\u044F
    \u0435\u0433\u043E \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
    \u0431\u044B\u043B\u0438 \u0431\u043E\u043B\u0435\u0435 \u0442\u043E\u0447\u043D\u044B\u043C\u0438. 
    ### \U0001F4BB \u0412\u043E\u0435\u043D\u043D\u044B\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u043F\u0440\u043E\u0440\u044B\u0432\u043D\u044B\u0435 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B 
    \u0412\u0442\u043E\u0440\u0430\u044F \u043C\u0438\u0440\u043E\u0432\u0430\u044F
    \u0432\u043E\u0439\u043D\u0430 \u0437\u0430\u0441\u0442\u0430\u043B\u0430 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430
    \u0432 \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438. \u041E\u043D \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0441\u043E\u043F\u0440\u043E\u0442\u0438\u0432\u043B\u0435\u043D\u0438\u0438
    \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u043C\u0443 \u0432\u0442\u043E\u0440\u0436\u0435\u043D\u0438\u044E
    \u0438 \u0434\u0430\u0436\u0435 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0440\u0430\u0437 \u0431\u044B\u043B \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D
    \u0432 \u0442\u044E\u0440\u044C\u043C\u0443. \u041F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E,
    \u043A\u0430\u043A \u043E\u043A\u043A\u0443\u043F\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u0432\u043B\u0430\u0441\u0442\u0438 \u0437\u0430\u043A\u0440\u044B\u043B\u0438
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u043E\u043D
    \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0432 \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438,
    \u0440\u0430\u0431\u043E\u0442\u0430\u044F \u0432 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438
    \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044F \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u044F\u0436\u0435\u043B\u044B\u0435
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F, \u044D\u0442\u0438 \u0433\u043E\u0434\u044B
    \u0441\u0442\u0430\u043B\u0438 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u043C\u0438.
    \u041E\u043D \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0438
    \u0420\u0438\u043C\u0430\u043D\u0430 \u0438 \u0432 1942 \u0433\u043E\u0434\u0443
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0434\u043E\u043B\u044F \u0432\u0441\u0435\u0445 \u0435\u0435 \u043D\u0435\u0442\u0440\u0438\u0432\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u043D\u0443\u043B\u0435\u0439 \u043B\u0435\u0436\u0438\u0442 \u043D\u0430 \u0442\u0430\u043A
    \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u043E\u0439 \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u0440\u044F\u043C\u043E\u0439 Re(s)=1/2. \u042D\u0442\u043E \u0431\u044B\u043B
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432 \u0432 \u044D\u0442\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438.  \u0412 1943 \u0433\u043E\u0434\u0443,
    \u0437\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0434\u043D\u0435\u0439
    \u0434\u043E \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u041E\u0441\u043B\u043E \u0431\u044B\u043B \u0437\u0430\u043A\u0440\u044B\u0442
    \u043E\u043A\u043A\u0443\u043F\u0430\u043D\u0442\u0430\u043C\u0438, \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0443\u0441\u043F\u0435\u0448\u043D\u043E \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E.
    \u0415\u0433\u043E \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u0432\u043E\u0435\u043D\u043D\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u0447\u0442\u043E \u0434\u0430\u0442\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0425\u0430\u0440\u0430\u043B\u044C\u0434
    \u0411\u043E\u0440 \u043D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441 \u043E \u0442\u043E\u043C,
    \u0447\u0442\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u043E
    \u0432 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0432\u043E\u0439\u043D\u044B, \u043A\u0440\u0430\u0442\u043A\u043E
    \u043E\u0442\u0432\u0435\u0442\u0438\u043B: \xAB\u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\xBB. 
    ### \U0001F33F \u041F\u043E\u0441\u043B\u0435 \u0432\u043E\u0439\u043D\u044B:
    \xAB\u042D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0435\xBB
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0438 \u043F\u0440\u0435\u043C\u0438\u044F \u0424\u0438\u043B\u0434\u0441\u0430 
    \u041F\u043E\u0441\u043B\u0435 \u0432\u043E\u0439\u043D\u044B \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0437\u0430\u043D\u044F\u043B\u0441\u044F \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u0440\u0435\u0448\u0435\u0442 (sieve theory), \u0441\u043E\u0437\u0434\u0430\u0432
    \u0432 1947 \u0433\u043E\u0434\u0443 \u043C\u043E\u0449\u043D\u044B\u0439 \xAB\u043C\u0435\u0442\u043E\u0434
    \u0440\u0435\u0448\u0435\u0442\u0430 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430\xBB
    (Selberg sieve), \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043D\u0430\u0448\u0435\u043B
    \u0448\u0438\u0440\u043E\u043A\u043E\u0435 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B. \u041A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u0435\u0439
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u0441\u0442\u0430\u043B
    1948 \u0433\u043E\u0434, \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    **\xAB\u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0435\xBB
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B**.
    \u042D\u0442\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u043E\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u043B\u0430\u0445, \u0430 \u043D\u0435 \u043D\u0430 \u0441\u043B\u043E\u0436\u043D\u043E\u043C
    \u0430\u043D\u0430\u043B\u0438\u0437\u0435, \u043A\u0430\u043A \u044D\u0442\u043E
    \u0434\u0435\u043B\u0430\u043B\u043E\u0441\u044C \u0440\u0430\u043D\u0435\u0435,
    \u0441\u0442\u0430\u043B\u043E \u0441\u0435\u043D\u0441\u0430\u0446\u0438\u0435\u0439.
    \u041A \u044D\u0442\u043E\u043C\u0443 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0443
    \u043F\u043E\u0447\u0442\u0438 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E,
    \u043D\u043E \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E, \u043F\u0440\u0438\u0448\u0435\u043B
    \u0438 \u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u041F\u0430\u043B \u042D\u0440\u0434\u0451\u0448, \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u043A \u0434\u043E\u043B\u0433\u043E\u0439 \u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439
    \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0438 \u043E \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0435.
    \u0412 \u0438\u0442\u043E\u0433\u0435 \u0441\u0442\u0430\u0442\u044C\u0438 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430
    \u0431\u044B\u043B\u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u044B
    \u043F\u0435\u0440\u0432\u044B\u043C\u0438.  \u0417\u0430 \u044D\u0442\u0438
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u0432 1950 \u0433\u043E\u0434\u0443
    \u043D\u0430 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u043C
    \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435 (\u0421\u0428\u0410)
    \u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433 \u0431\u044B\u043B
    \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438, \u0441\u0430\u043C\u043E\u0439 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0439
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043B\u044F \u043C\u043E\u043B\u043E\u0434\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.  ### \U0001F3DB\uFE0F
    \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u0438\u0439 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0438 \u0444\u043E\u0440\u043C\u0443\u043B\u0430 \u0441\u043B\u0435\u0434\u0430 
    \u0412 1947 \u0433\u043E\u0434\u0443 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0421\u0428\u0410 \u043F\u043E
    \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u044E \u041A\u0430\u0440\u043B\u0430
    \u041B\u044E\u0434\u0432\u0438\u0433\u0430 \u0417\u0438\u0433\u0435\u043B\u044F,
    \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u0432 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442
    \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 (IAS)
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435. \u041D\u0435\u0434\u043E\u043B\u0433\u043E
    \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u0432 \u0432 \u0421\u0438\u0440\u0430\u043A\u0443\u0437\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u0432
    1949 \u0433\u043E\u0434\u0443 \u043E\u043D \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D, \u0433\u0434\u0435 \u0432
    1951 \u0433\u043E\u0434\u0443 \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C. \u0412 \u044D\u0442\u043E\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u043E\u043D \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0441\u0432\u043E\u0435\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B, \u0441\u0442\u0430\u0432 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    emeritus \u0432 1987 \u0433\u043E\u0434\u0443.  \u0412 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u0435\u0433\u043E
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0441\u043C\u0435\u0441\u0442\u0438\u043B\u043E\u0441\u044C
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u0442\u0435\u043E\u0440\u0438\u0438
    \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u0438 \u0441\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438. \u0412 1956 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u044E
    \u0441\u0430\u043C\u0443\u044E \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u0443\u044E,
    \u043F\u043E \u043C\u043D\u0435\u043D\u0438\u044E \u043A\u043E\u043B\u043B\u0435\u0433,
    \u0440\u0430\u0431\u043E\u0442\u0443, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0442\u0430\u043A
    \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u0443\u044E **\xAB\u0444\u043E\u0440\u043C\u0443\u043B\u0443
    \u0441\u043B\u0435\u0434\u0430 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430\xBB
    (Selberg Trace Formula)**. \u042D\u0442\u0430 \u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0430 \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E
    \u0441\u0432\u044F\u0437\u044C \u043C\u0435\u0436\u0434\u0443 \u0434\u043B\u0438\u043D\u0430\u043C\u0438
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0445 \u0433\u0435\u043E\u0434\u0435\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430 \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u043E\u0439 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F\u043C\u0438 \u043E\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430
    \u041B\u0430\u043F\u043B\u0430\u0441\u0430, \u0447\u0442\u043E \u043D\u0430\u0448\u043B\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0432 \u0441\u0430\u043C\u044B\u0445
    \u0440\u0430\u0437\u043D\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445
    \u2014 \u043E\u0442 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B
    \u0434\u043E \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u0444\u0438\u0437\u0438\u043A\u0438. 
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0438 \u0447\u0438\u0442\u0430\u0442\u044C \u043B\u0435\u043A\u0446\u0438\u0438
    \u0434\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439 \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0438.
    \u041E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0434\u0440\u0443\u0433\u0438\u0445 \u043D\u0430\u0433\u0440\u0430\u0434, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u041F\u0440\u0435\u043C\u0438\u044E \u0412\u043E\u043B\u044C\u0444\u0430 \u043F\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0432 1986 \u0433\u043E\u0434\u0443
    \u0438 \u043F\u043E\u0447\u0435\u0442\u043D\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E
    \u0410\u0431\u0435\u043B\u044F \u0432 2002 \u0433\u043E\u0434\u0443 \u2014 \u0432
    \u0433\u043E\u0434 \u0435\u0435 \u0443\u0447\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u044F.
    \u0415\u0433\u043E \u0438\u0437\u0431\u0440\u0430\u043D\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B
    \u0431\u044B\u043B\u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u044B
    \u0432 \u0434\u0432\u0443\u0445 \u0442\u043E\u043C\u0430\u0445.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466
    \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C  \u0412 1947
    \u0433\u043E\u0434\u0443 \u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u0425\u0435\u0434\u0432\u0438\u0433
    \u041B\u0438\u0431\u0435\u0440\u043C\u0430\u043D\u043D, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0442\u0430\u043A\u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430
    \u0432 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. \u0423
    \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0434\u0432\u043E\u0435
    \u0434\u0435\u0442\u0435\u0439 \u2014 \u0434\u043E\u0447\u044C \u0418\u043D\u0433\u0440\u0438\u0434
    \u0438 \u0441\u044B\u043D \u041B\u0430\u0440\u0441. \u0425\u0435\u0434\u0432\u0438\u0433
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C \u0432 1995 \u0433\u043E\u0434\u0443.
    \u0412 2003 \u0433\u043E\u0434\u0443 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439
    \u0440\u0430\u0437, \u043D\u0430 \u0411\u0435\u0442\u0442\u0438 \u041A\u043E\u043C\u043F\u0442\u043E\u043D
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433.  \u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u043E\u0442 \u0441\u0435\u0440\u0434\u0435\u0447\u043D\u043E\u0439
    \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438
    6 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 2007 \u0433\u043E\u0434\u0430 \u0432
    \u0441\u0432\u043E\u0435\u043C \u0434\u043E\u043C\u0435 \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 90 \u043B\u0435\u0442."
  shortBioEn: 
  interestingFactsRu: "\u0411\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u0410\u0442\u043B\u0435
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430 \u043F\u043E\u043B\u043D\u0430
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0432\u0435\u043B\u0438\u043A\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439, \u043D\u043E \u0438
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0438\u0445 \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u0432,
    \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445 \u043F\u0440\u043E\u0438\u0441\u0448\u0435\u0441\u0442\u0432\u0438\u0439
    \u0438 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0434\u0435\u0442\u0430\u043B\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u0435\u0433\u043E
    \u0436\u0438\u0432\u044B\u043C \u0438 \u043D\u0435\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C.  ### \U0001F9E0 \u0412\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434
    \u0438 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E\u0435 \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435 
    - **\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u0447\u0435\u0440\u0435\u0437
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u044E:**
    \u041F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E, \u043D\u043E
    \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430
    \u0441 \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C\u0438 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u043E\u0441\u044C
    \u0447\u0435\u0440\u0435\u0437 \u0444\u043E\u0440\u043C\u0443\u043B\u044B \u042D\u0439\u043B\u0435\u0440\u0430.
    \u0414\u0440\u0443\u0433\u0438\u043C\u0438 \u0441\u043B\u043E\u0432\u0430\u043C\u0438,
    \u043E\u043D \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u043D\u0438\u043C\u0438 \u043A\u0430\u043A \u0441 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u043C\u0438
    \u044D\u043A\u0441\u043F\u043E\u043D\u0435\u043D\u0442\u0430\u043C\u0438, \u043D\u0435
    \u0438\u043C\u0435\u044F \u043F\u0440\u0435\u0434\u0432\u0430\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430. \u0415\u0433\u043E
    \"\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0431\u044B\u043B\u043E
    \u043E\u0442\u0440\u044B\u0432\u043E\u0447\u043D\u044B\u043C\" (spotty) \u2014
    \u043E\u043D \u043F\u0440\u043E\u0441\u0442\u043E \u0432\u0437\u044F\u043B \u044D\u0442\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0432\u0435\u0440\u0448\u0438\u043D\u0443 \u0441\u0445\u043E\u0434\u0443, \u043C\u0438\u043D\u0443\u044F
    \u0431\u0430\u0437\u043E\u0432\u044B\u0435 \u0441\u0442\u0443\u043F\u0435\u043D\u0438.
    - **\u041F\u0435\u0440\u0432\u043E\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435:**
    \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u043E\u043A\u043E\u043B\u043E
    \u0441\u0435\u043C\u0438 \u043B\u0435\u0442 \u043E\u043D \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u044C
    \u043C\u0435\u0436\u0434\u0443 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430\u043C\u0438 \u0434\u0430\u0435\u0442
    \u043D\u0435\u0447\u0435\u0442\u043D\u044B\u0435 \u0447\u0438\u0441\u043B\u0430.
    \u0412 15 \u043B\u0435\u0442 \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u0437\u0430\u043C\u0435\u0442\u043A\u0443 \u0432 \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0436\u0443\u0440\u043D\u0430\u043B *Normat* \u043E \u0432\u0437\u0430\u0438\u043C\u043E\u0441\u0432\u044F\u0437\u0438
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430 \u0438 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E
    \u0440\u044F\u0434\u0430. - **\u0421\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435:** \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0435\u0433\u043E \u0443\u0447\u0438\u043B\u0438 \u043D\u0435 \u0432 \u0448\u043A\u043E\u043B\u0435,
    \u0430 \u043A\u043D\u0438\u0433\u0438 \u0438\u0437 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0438
    \u043E\u0442\u0446\u0430. \u041E\u043D \u043E\u0441\u0432\u043E\u0438\u043B \u043C\u0435\u0442\u043E\u0434\u044B
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0430 \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0435 \u044F\u0437\u044B\u043A\u0438
    \u2014 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0441\u0442\u0430\u0440\u0448\u0435\u0439
    \u0441\u0435\u0441\u0442\u0440\u044B.  ### \U0001F4DD \u0417\u0430\u0431\u0430\u0432\u043D\u044B\u0435
    \u044D\u043F\u0438\u0437\u043E\u0434\u044B \u0441 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F\u043C\u0438 
    - **\u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D \u0438 \"\u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u0435\":**
    \u0412\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434\u0430\u043C\u0438 \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430,
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u0441\u0432\u043E\u044E \u043F\u0435\u0440\u0432\u0443\u044E \u0441\u0442\u0430\u0442\u044C\u044E
    \u043E \u0442\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u044F\u0445
    \u043D\u0430 \u0440\u0435\u0446\u0435\u043D\u0437\u0438\u044E \u0441\u0430\u043C\u043E\u043C\u0443
    \u0413. \u041D. \u0423\u043E\u0442\u0441\u043E\u043D\u0443, \u043D\u043E \u0442\u043E\u0442,
    \u043F\u043E \u0441\u043B\u043E\u0432\u0430\u043C \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430,
    \u0431\u044B\u043B \"\u043E\u0447\u0435\u043D\u044C \u043C\u0435\u0434\u043B\u0438\u0442\u0435\u043B\u0435\u043D\"
    \u0441 \u043E\u0442\u0432\u0435\u0442\u043E\u043C. - **\u041E\u043F\u0435\u0440\u0435\u0436\u0435\u043D\u0438\u0435
    \u043D\u0430 \u0444\u0438\u043D\u0438\u0448\u0435:** \u0421\u0430\u043C\u044B\u043C
    \u0431\u043E\u043B\u044C\u0448\u0438\u043C \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0435\u0433\u043E \u044E\u043D\u043E\u0441\u0442\u0438 \u0441\u0442\u0430\u043B\u043E
    \u0442\u043E, \u0447\u0442\u043E \u043E\u043D \u043D\u0430\u0448\u0435\u043B
    \u0442\u043E\u0447\u043D\u0443\u044E \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0434\u043B\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u0438
    \u0440\u0430\u0437\u0431\u0438\u0435\u043D\u0438\u044F (partition function),
    \u043D\u043E, \u043F\u043E\u043A\u0430 \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B,
    \u0413\u0430\u043D\u0441 \u0420\u0430\u0434\u0435\u043C\u0430\u0445\u0435\u0440
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u044E
    \u0432\u0435\u0440\u0441\u0438\u044E. \u0425\u043E\u0442\u044F \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430 \u0431\u044B\u043B\u0438
    \u0442\u043E\u0447\u043D\u0435\u0435, \u043E\u043D \u0440\u0435\u0448\u0438\u043B
    \u043D\u0435 \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u0438\u0445, \u0447\u0442\u043E\u0431\u044B \u043D\u0435 \u0432\u0441\u0442\u0443\u043F\u0430\u0442\u044C
    \u0432 \u0441\u043F\u043E\u0440.  ### \u2694\uFE0F \u0412\u043E\u0435\u043D\u043D\u044B\u0435
    \u0431\u0443\u0434\u043D\u0438  - **\"\u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\"
    \u043A\u0430\u043A \u043E\u0442\u0432\u0435\u0442:** \u041A\u043E\u0433\u0434\u0430
    \u0434\u0430\u0442\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0425\u0430\u0440\u0430\u043B\u044C\u0434\u0430 \u0411\u043E\u0440\u0430 \u0441\u043F\u0440\u043E\u0441\u0438\u043B\u0438,
    \u0447\u0442\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u043E
    \u0432 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0412\u0442\u043E\u0440\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B, \u043E\u043D
    \u043A\u043E\u0440\u043E\u0442\u043A\u043E \u043E\u0442\u0432\u0435\u0442\u0438\u043B:
    \"\u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\". \u042D\u0442\u043E \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442,
    \u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0439\u0441\u044F
    \u0431\u044B\u043B\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430
    \u0432 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438 \u043E\u043A\u043A\u0443\u043F\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438. - **\u0421\u043E\u043B\u0434\u0430\u0442
    \u0438 \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u043D\u044B\u0439:**
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0431\u043E\u044F\u0445 \u0441 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u043C\u0438
    \u0437\u0430\u0445\u0432\u0430\u0442\u0447\u0438\u043A\u0430\u043C\u0438 \u0432
    \u0413\u0443\u0434\u0431\u0440\u0430\u043D\u0434\u0441\u0434\u0430\u043B\u0435\u043D\u0435
    \u0438 \u043F\u043E\u043F\u0430\u043B \u0432 \u043F\u043B\u0435\u043D \u0432
    \u043B\u0430\u0433\u0435\u0440\u0435 \u0422\u0440\u0430\u043D\u0434\u0443\u043C.
    \u041F\u043E\u0437\u0436\u0435, \u0437\u0430\u0449\u0438\u0442\u0438\u0432 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u0432 1943
    \u0433\u043E\u0434\u0443, \u043E\u043D \u0431\u044B\u043B \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E
    \u0430\u0440\u0435\u0441\u0442\u043E\u0432\u0430\u043D \u0433\u0435\u0441\u0442\u0430\u043F\u043E
    \u0438 \u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0435\u043D \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u0440\u0438 \u0443\u0441\u043B\u043E\u0432\u0438\u0438, \u0447\u0442\u043E
    \u043F\u043E\u043A\u0438\u043D\u0435\u0442 \u041E\u0441\u043B\u043E.  ### \U0001F525
    \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438
    \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u044B  - **\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0430:**
    \u0412\u0441\u044F \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u0434\u0440\u0430\u043C\u0430 \u0441 \"\u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u044B\u043C\"
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B \u0438
    \u0441\u043F\u043E\u0440\u043E\u043C \u043E \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u0435
    \u0441 \u041F\u043E\u043B\u043E\u043C \u042D\u0440\u0434\u0451\u0448\u0435\u043C,
    \u043F\u043E \u0441\u0443\u0442\u0438, \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430
    \u0438\u0437-\u0437\u0430 \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0434\u0432\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0431\u044B\u043B\u0438
    \u043F\u043E\u043B\u043D\u044B\u043C\u0438 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044F\u043C\u0438
    \u043F\u043E \u0441\u0442\u0438\u043B\u044E \u0440\u0430\u0431\u043E\u0442\u044B.
    \u042D\u0440\u0434\u0451\u0448 \u0431\u044B\u043B \"\u043F\u0440\u0438\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u043E\u043C\", \u0430 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u2014 \"\u043E\u0434\u0438\u043D\u043E\u0447\u043A\u043E\u0439\". \u042D\u0442\u043E
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \"\u043F\u0440\u043E\u0432\u0430\u043B\u0443
    \u0432 \u043A\u043E\u043C\u043C\u0443\u043D\u0438\u043A\u0430\u0446\u0438\u0438\"
    \u0438 \u043A \u0442\u043E\u043C\u0443, \u0447\u0442\u043E \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u0435\u0434\u0438\u043D\u043E\u043B\u0438\u0447\u043D\u043E \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E,
    \u0445\u043E\u0442\u044F \u043C\u043D\u043E\u0433\u0438\u0435 \u0441\u0447\u0438\u0442\u0430\u043B\u0438,
    \u0447\u0442\u043E \u0435\u0435 \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C. - **\u0422\u0440\u0443\u0431\u043A\u0430
    \u0438 \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0430:** \u0412 \u043A\u043E\u043D\u0446\u0435
    1970-\u0445 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433 \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B
    \u043A \u0441\u0435\u0431\u0435 \u0434\u043E\u043C\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0438 \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u043B \u0437\u0430\u044F\u0434\u043B\u044B\u043C
    \u043A\u0443\u0440\u0438\u043B\u044C\u0449\u0438\u043A\u043E\u043C \u0442\u0440\u0443\u0431\u043A\u0438.
    \u0416\u0435\u043D\u0430 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430,
    \u0425\u0435\u0434\u0432\u0438\u0433, \u043F\u043E\u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u0430
    \u043D\u0435 \u043A\u0443\u0440\u0438\u0442\u044C \u0432 \u0434\u043E\u043C\u0435.
    \u041F\u043E\u0441\u043B\u0435 \u0443\u0436\u0438\u043D\u0430, \u043A\u043E\u0433\u0434\u0430
    \u0433\u043E\u0441\u0442\u044C \u0441\u043E\u0431\u0440\u0430\u043B\u0441\u044F
    \u0432\u044B\u0439\u0442\u0438 \u043D\u0430 \u0443\u043B\u0438\u0446\u0443 \u043F\u043E\u043A\u0443\u0440\u0438\u0442\u044C,
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433 \u043D\u0430\u0441\u0442\u043E\u044F\u043B
    \u043D\u0430 \u0442\u043E\u043C, \u0447\u0442\u043E\u0431\u044B \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0435\u043C\u0443 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u044E. \u041F\u0440\u043E\u0433\u0443\u043B\u043A\u0430
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0430\u0441\u044C, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0441\u0438\u043B\u044C\u043D\u044B\u0439 \u0445\u043E\u043B\u043E\u0434
    \u0438 \u0432\u0435\u0442\u0435\u0440, \u043A\u043E\u0442\u043E\u0440\u044B\u0439,
    \u043D\u0430\u0437\u043B\u043E \u0432\u0441\u0435\u043C \u0443\u0441\u0438\u043B\u0438\u044F\u043C
    \u043A\u0443\u0440\u0438\u043B\u044C\u0449\u0438\u043A\u0430, \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u044F\u043B
    \u0434\u044B\u043C \u043F\u0440\u044F\u043C\u043E \u0432 \u043B\u0438\u0446\u043E
    \u0441\u0430\u043C\u043E\u043C\u0443 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0443.
    - **\"\u0428\u043F\u0438\u043E\u043D\u0441\u043A\u0430\u044F\" \u043C\u0438\u0441\u0441\u0438\u044F:**
    \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u0436\u0435\u043D\u044B
    \u0425\u0435\u0434\u0432\u0438\u0433 \u0432 1995 \u0433\u043E\u0434\u0443, \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u043D\u0430 \u043A\u043E\u043D\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u044E
    \u0432 \u041A\u0438\u0442\u0430\u0439. \u041F\u043E \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
    \u043E\u043D \u0441 \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u043E\u0439
    \u0443\u043B\u044B\u0431\u043A\u043E\u0439 \u0438 \u0431\u043B\u0435\u0441\u043A\u043E\u043C
    \u0432 \u0433\u043B\u0430\u0437\u0430\u0445 \u043F\u0440\u0438\u0437\u043D\u0430\u043B\u0441\u044F
    \u043A\u043E\u043B\u043B\u0435\u0433\u0435, \u0447\u0442\u043E \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0441\u044F
    \u0432 \u041F\u0430\u043B\u043E-\u0410\u043B\u044C\u0442\u043E \u0432\u043E\u0432\u0441\u0435
    \u043D\u0435 \u0434\u043B\u044F \u043B\u0435\u043A\u0446\u0438\u0439, \u0430
    \u0434\u043B\u044F \u0442\u043E\u0433\u043E, \u0447\u0442\u043E\u0431\u044B \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0441\u0432\u043E\u0435\u0439
    \u0434\u0430\u0432\u043D\u0435\u0439 \u043F\u043E\u0434\u0440\u0443\u0433\u0435
    \u0411\u0435\u0442\u0442\u0438 (\u041C\u0438\u043A\u043A\u0438) \u0424\u0435\u0439\u0442.
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0437\u0430\u0441\u0442\u0438\u0433\u043D\u0443\u0442\u0430
    \u0432\u0440\u0430\u0441\u043F\u043B\u043E\u0445, \u043D\u043E \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u043B\u0430\u0441\u044C. 
    ### \U0001F3A9 \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \"\u0431\u0430\u0431\u0443\u0448\u043A\u0438\u043D\u044B \u0441\u043A\u0430\u0437\u043A\u0438\" 
    \u0412 \u043F\u0440\u0435\u043A\u043B\u043E\u043D\u043D\u043E\u043C \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B,
    \u0447\u0442\u043E \u0443 \u043D\u0435\u0433\u043E \u0435\u0441\u0442\u044C \u0446\u0435\u043B\u0430\u044F
    \u043A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u044F \u043D\u0435\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043D
    \u0445\u0440\u0430\u043D\u0438\u0442 \u0432 \u0441\u0442\u043E\u043B\u0435. \u042D\u0442\u0438
    \u0441\u043B\u0443\u0445\u0438 \u0432\u044B\u0437\u044B\u0432\u0430\u043B\u0438
    \u0442\u0440\u0435\u043F\u0435\u0442 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435, \u0445\u043E\u0442\u044F
    \u043D\u0438\u043A\u0442\u043E \u043D\u0435 \u0437\u043D\u0430\u043B \u043D\u0430\u0432\u0435\u0440\u043D\u044F\u043A\u0430,
    \u043F\u0440\u0430\u0432\u0434\u0430 \u044D\u0442\u043E \u0438\u043B\u0438 \u043D\u0435\u0442.
    \u041D\u0430 90-\u043B\u0435\u0442\u043D\u0438\u0439 \u044E\u0431\u0438\u043B\u0435\u0439
    \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u0443\u0441\u0442\u0440\u043E\u0438\u043B\u0438
    \u0435\u043C\u0443 \u0443\u0436\u0438\u043D \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u043E\u043C
    \u043A\u043B\u0443\u0431\u0435, \u043D\u043E \u0443\u0436\u0435 \u0442\u043E\u0433\u0434\u0430
    \u043E\u043D \u0431\u044B\u043B \u043D\u0435\u0437\u0434\u043E\u0440\u043E\u0432
    \u2014 \u044D\u0442\u043E \u0431\u044B\u043B\u0430 \u0438\u0445 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F
    \u0432\u0441\u0442\u0440\u0435\u0447\u0430.  \u042D\u0442\u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433\u0430
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u043E\u0441\u0442\u0430\u0432\u0438\u0432\u0448\u0435\u0433\u043E \"\u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0441\u043B\u0435\u0434 \u0432 \u043C\u0438\u0440\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\"
    , \u043D\u043E \u0438 \u043A\u0430\u043A \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E,
    \u0436\u0438\u0432\u0443\u044E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u043E\u0447\u0435\u0442\u0430\u043B\u0430
    \u0432 \u0441\u0435\u0431\u0435 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u0443\u044E
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u044E, \u0443\u043F\u043E\u0440\u0441\u0442\u0432\u043E,
    \u0443\u043C\u0435\u043D\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0432 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438 \u0438 \u0447\u0443\u0432\u0441\u0442\u0432\u043E
    \u044E\u043C\u043E\u0440\u0430. \u0415\u0441\u043B\u0438 \u043A\u0430\u043A\u043E\u0439-\u0442\u043E
    \u0438\u0437 \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432 \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B
    \u0432\u0430\u0441 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E, \u044F \u043C\u043E\u0433\u0443
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u0442\u044C \u043E \u043D\u0435\u043C
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0435."
