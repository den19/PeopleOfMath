  interestingFactsEn:
  shortBioRu: "\u0410\u0442\u043B\u0435 \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433
    (1917\u20132007) \u2014 \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A\u043E\u0432 \u0447\u0438\u0441\u0435\u043B
    XX \u0432\u0435\u043A\u0430, \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0440\u0430\u0437\u0434\u0435\u043B\u044B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0420\u043E\u0434\u0438\u0432\u0448\u0438\u0441\u044C \u0432 \u0441\u0435\u043C\u044C\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0432 \u041B\u0430\u043D\u0433\u0435\u0441\u0443\u043D\u043D\u0435,
    \u043E\u043D \u0441 \u044E\u043D\u044B\u0445 \u043B\u0435\u0442 \u0443\u0432\u043B\u0435\u043A\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0442\u0440\u0443\u0434\u0430\u043C \u0420\u0430\u043C\u0430\u043D\u0443\u0434\u0436\u0430\u043D\u0430
    \u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u041E\u0441\u043B\u043E, \u0433\u0434\u0435 \u0432 1943 \u0433\u043E\u0434\u0443,
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u044E
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u0439
    \u043E\u043A\u043A\u0443\u043F\u0430\u0446\u0438\u0438, \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E.
    \u0423\u0436\u0435 \u0432 1942 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u043F\u0440\u043E\u0440\u044B\u0432,
    \u0434\u043E\u043A\u0430\u0437\u0430\u0432, \u0447\u0442\u043E \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0434\u043E\u043B\u044F \u043D\u0435\u0442\u0440\u0438\u0432\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u043D\u0443\u043B\u0435\u0439 \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0438
    \u0420\u0438\u043C\u0430\u043D\u0430 \u043B\u0435\u0436\u0438\u0442 \u043D\u0430
    \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043F\u0440\u044F\u043C\u043E\u0439,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u043C
    \u0448\u0430\u0433\u043E\u043C \u0432 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0438
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B
    \u0420\u0438\u043C\u0430\u043D\u0430. \u0412\u0435\u0440\u0448\u0438\u043D\u043E\u0439
    \u0435\u0433\u043E \u0440\u0430\u043D\u043D\u0435\u0433\u043E \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430
    \u0441\u0442\u0430\u043B\u043E \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u043E\u0435
    \u0432 1948 \u0433\u043E\u0434\u0443 \xAB\u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0435\xBB
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B, \u0437\u0430
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0432 1950 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    (\u044D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430, \u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u0430\u044F
    \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u043E \u0441 \u042D\u0440\u0434\u0451\u0448\u0435\u043C,
    \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442\u043D\u044B\u0439 \u0441\u043F\u043E\u0440).
    \u0412 \u043F\u043E\u0441\u043B\u0435\u0432\u043E\u0435\u043D\u043D\u044B\u0435
    \u0433\u043E\u0434\u044B \u0421\u0435\u043B\u044C\u0431\u0435\u0440\u0433 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u0421\u0428\u0410 \u0438 \u0441\u0432\u044F\u0437\u0430\u043B \u0441\u0432\u043E\u044E
    \u0436\u0438\u0437\u043D\u044C \u0441 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u043E\u043C
    \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0432
    \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435, \u0433\u0434\u0435 \u0432
    1956 \u0433\u043E\u0434\u0443 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B,
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0441\u0432\u043E\u044E \u0441\u0430\u043C\u0443\u044E
    \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443,
    \u0432\u044B\u0432\u0435\u0434\u044F \u0444\u043E\u0440\u043C\u0443\u043B\u0443
    \u0441\u043B\u0435\u0434\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0430
    \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0441\u0432\u044F\u0437\u044C
    \u043C\u0435\u0436\u0434\u0443 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u0447\u0438\u0441\u0435\u043B,
    \u0441\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439
    \u0438 \u0441\u0442\u0430\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u0446\u0435\u043B\u044B\u0445 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u0444\u0438\u0437\u0438\u043A\u0438. \u0417\u0430 \u0441\u0432\u043E\u0438
    \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043E\u043D \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u041F\u0440\u0435\u043C\u0438\u0438 \u0412\u043E\u043B\u044C\u0444\u0430 \u0432
    1986 \u0433\u043E\u0434\u0443 \u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0434\u0440\u0443\u0433\u0438\u0445 \u043D\u0430\u0433\u0440\u0430\u0434, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0447\u043B\u0435\u043D\u0441\u0442\u0432\u043E \u0432 \u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044F\u0445 \u043C\u0438\u0440\u0430,
    \u0430 \u0435\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u043A\u0430\u043A
    \xAB\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0434\u043B\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432\xBB \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430\u0443\u043A\u0438."
