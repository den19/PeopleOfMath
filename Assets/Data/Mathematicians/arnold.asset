    \u043F\u043E\u043D\u044F\u043B \u0441\u0443\u0442\u044C, \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0440\u0435\u0448\u0438\u0432 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0437\u0430\u0434\u0430\u0447\u0443 \u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u043F\u0440\u0438\u043B\u0438\u0432\u043E\u0432.  *   **\"\u041E\u0445\u043E\u0442\u0430
    \u043D\u0430 \u0432\u0435\u0434\u044C\u043C\" \u0438 \u043E\u0442\u043A\u0430\u0437
    \u043E\u0442 \u0443\u0447\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430.**
    \u0412 19 \u043B\u0435\u0442 \u0410\u0440\u043D\u043E\u043B\u044C\u0434 \u043F\u043E
    \u0437\u0430\u0434\u0430\u043D\u0438\u044E \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430
    \u0440\u0435\u0448\u0438\u043B 13-\u044E \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430. \u041F\u043E\u0441\u043B\u0435
    \u044D\u0442\u043E\u0433\u043E \u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    **\u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0441\u0447\u0438\u0442\u0430\u0442\u044C
    \u0435\u0433\u043E \u0441\u0432\u043E\u0438\u043C \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C**.
    \u0412\u043F\u0440\u043E\u0447\u0435\u043C, \u0434\u043E \u0441\u0430\u043C\u043E\u0439
    \u0441\u043C\u0435\u0440\u0442\u0438 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430
    \u043E\u043D\u0438 \u043C\u043D\u043E\u0433\u043E \u0441\u043F\u043E\u0440\u0438\u043B\u0438,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u043E \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  *   **\"\u0414\u0443\u044D\u043B\u044C\"
    \u0441 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u043C \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u043C.**
    \u0421\u043F\u043E\u0440\u044F \u043E \u043F\u0440\u0438\u0440\u043E\u0434\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0441 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u0416\u0430\u043D-\u041F\u044C\u0435\u0440\u043E\u043C
    \u0421\u0435\u0440\u0440\u043E\u043C, \u0410\u0440\u043D\u043E\u043B\u044C\u0434
    \u0434\u043E\u0432\u0435\u043B \u043E\u043F\u043F\u043E\u043D\u0435\u043D\u0442\u0430
    \u0434\u043E \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0442\u043E\u0442
    \u0432\u044B\u0437\u0432\u0430\u043B \u0435\u0433\u043E \u043D\u0430 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u0443\u044E
    \"\u0434\u0443\u044D\u043B\u044C\" \u0432 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435.
    \u041F\u043E \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F\u043C
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430, \u0421\u0435\u0440\u0440 \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B,
    \u0447\u0442\u043E \u043D\u043E\u043B\u044C \u2014 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E, \u0430 \u0410\u0440\u043D\u043E\u043B\u044C\u0434
    \u043E\u0442\u0441\u0442\u0430\u0438\u0432\u0430\u043B \u0441\u0432\u043E\u0435:
    \"\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u2014 \u0447\u0430\u0441\u0442\u044C
    \u0444\u0438\u0437\u0438\u043A\u0438, \u043D\u0430\u0443\u043A\u0430 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F,
    \u043E\u0442\u043B\u0438\u0447\u0430\u044E\u0449\u0430\u044F\u0441\u044F \u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u0435\u043C, \u0447\u0442\u043E \u0432 \u0444\u0438\u0437\u0438\u043A\u0435
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u044B \u0441\u0442\u043E\u044F\u0442
    \u043C\u0438\u043B\u043B\u0438\u0430\u0440\u0434\u044B \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432,
    \u0430 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u2014
    \u0435\u0434\u0438\u043D\u0438\u0446\u044B \u0440\u0443\u0431\u043B\u0435\u0439\". 
    *   **\u0417\u0430\u043D\u044F\u0442\u043D\u0430\u044F \u0437\u0430\u0434\u0430\u0447\u0430
    \u0438 \"\u043D\u0435\u0432\u0438\u0434\u0438\u043C\u044B\u0439\" \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442.**
    \u041D\u0430\u0431\u043B\u044E\u0434\u0430\u044F \u0437\u0430 \u0442\u0440\u0435\u0441\u043A\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u043B\u044C\u0434\u043E\u043C, \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
