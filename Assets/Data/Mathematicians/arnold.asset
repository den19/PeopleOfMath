    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u043F\u043E\u043B\u043D\u0430
    \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u0439,
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445 \u043C\u044B\u0441\u043B\u0435\u0439
    \u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u043A\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u044F\u0440\u043A\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0437\u0443\u044E\u0442
    \u0435\u0433\u043E \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u044B\u0439
    \u0438 \u043E\u0441\u0442\u0440\u044B\u0439 \u0443\u043C.  \u0412\u043E\u0442
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u0430\u043C\u044B\u0445
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0445 \u0444\u0430\u043A\u0442\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u0435\u0433\u043E \u0441 \u0440\u0430\u0437\u043D\u044B\u0445 \u0441\u0442\u043E\u0440\u043E\u043D: 
    *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0441 \u043F\u0435\u043B\u0435\u043D\u043E\u043A.**
    \u0412 \u043F\u044F\u0442\u044C \u043B\u0435\u0442 \u0410\u0440\u043D\u043E\u043B\u044C\u0434
    \u0443\u0436\u0435 \"\u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B\"
    \u043E\u0442\u0446\u0443-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B. \u041E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043E\u043D \u0437\u0430\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u043E\u0442\u0435\u0446
    \u0431\u0435\u0437\u0443\u0441\u043F\u0435\u0448\u043D\u043E \u043F\u044B\u0442\u0430\u0435\u0442\u0441\u044F
