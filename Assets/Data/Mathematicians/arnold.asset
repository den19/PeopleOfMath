    \u0418\u0433\u043E\u0440\u0435\u0432\u0438\u0447 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0449\u0438\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C. \u041E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
