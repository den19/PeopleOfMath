    **\xAB\u0412\u043B\u0430\u0434\u0430\u0440\u043D\u043E\u043B\u044C\u0434\u0430\xBB**.
    \u0415\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u0448\u043A\u043E\u043B\u0430,
    \u043D\u0430\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u044E\u0449\u0430\u044F
    \u0434\u0435\u0441\u044F\u0442\u043A\u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432,
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442 \u0435\u0433\u043E
