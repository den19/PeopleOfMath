    \u043D\u043E\u0432\u044B\u0435 \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F
    \u0443\u0447\u0435\u043D\u044B\u0445."
  shortBioEn: 
  interestingFactsRu: "\u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440 \u0418\u0433\u043E\u0440\u0435\u0432\u0438\u0447
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434 \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u043D\u043E \u0438 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
