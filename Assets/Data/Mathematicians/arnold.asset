    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0437\u0430\u0434\u0430\u0447\u0443,
    \u0430 \u043A\u043E\u0433\u0434\u0430 \u043B\u0435\u0434 \u043F\u0440\u043E\u0432\u0430\u043B\u0438\u043B\u0441\u044F,
    \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0432 \u043F\u0440\u043E\u0440\u0443\u0431\u0438.
    \u042D\u0442\u043E\u0442 \u0441\u043B\u0443\u0447\u0430\u0439 \u043E\u043D \u0441\u0430\u043C
    \u043E\u043F\u0438\u0441\u0430\u043B \u043A\u0430\u043A \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u0435
    \"\u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
