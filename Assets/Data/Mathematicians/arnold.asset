  achievementsRu: "\u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440 \u0418\u0433\u043E\u0440\u0435\u0432\u0438\u0447
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434 \u0431\u044B\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0437\u0430\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u043B\u0438
    \u0446\u0435\u043B\u044B\u0435 \u043D\u043E\u0432\u044B\u0435 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0432 \u043D\u0430\u0443\u043A\u0435. \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u043E\u0433\u0440\u043E\u043C\u0435\u043D, \u043D\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439 \u043C\u043E\u0436\u043D\u043E
    \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u044C \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0438
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0443\u044E \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0438 \u0444\u0438\u0437\u0438\u043A\u0435. 
    \u0412\u043E\u0442 \u0435\u0433\u043E \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u0438 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u043D\u0430\u0443\u043A\u0443:  ### \u2B50 \u0420\u0435\u0448\u0435\u043D\u0438\u0435
    13-\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    (1957) \u042D\u0442\u043E \u043F\u0435\u0440\u0432\u0430\u044F \u0433\u0440\u043E\u043C\u043A\u0430\u044F
    \u043F\u043E\u0431\u0435\u0434\u0430 \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D \u043E\u0434\u0435\u0440\u0436\u0430\u043B
    \u0435\u0449\u0435 \u0432 20 \u043B\u0435\u0442, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C \u041C\u0413\u0423.  *  
    **\u0421\u0443\u0442\u044C \u0437\u0430\u0434\u0430\u0447\u0438:** \u041E\u0434\u043D\u0430
    \u0438\u0437 23 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447, \u043F\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0445
    \u0414\u0430\u0432\u0438\u0434\u043E\u043C \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C
    \u0432 1900 \u0433\u043E\u0434\u0443, \u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u043B\u0430:
    \u043C\u043E\u0436\u043D\u043E \u043B\u0438 \u043B\u044E\u0431\u0443\u044E \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u0443\u044E
    \u0444\u0443\u043D\u043A\u0446\u0438\u044E \u043E\u0442 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u043A\u0430\u043A \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0446\u0438\u044E
    (\u0441\u0443\u043F\u0435\u0440\u043F\u043E\u0437\u0438\u0446\u0438\u044E) \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u043E\u0442 \u043C\u0435\u043D\u044C\u0448\u0435\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445?
    \u0412 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u043C\u043E\u0436\u043D\u043E
    \u043B\u0438 \u043E\u0431\u043E\u0439\u0442\u0438\u0441\u044C \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C\u0438
    \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0442 \u0434\u0432\u0443\u0445 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445?
    *   **\u0420\u0435\u0448\u0435\u043D\u0438\u0435:** \u0410\u0440\u043D\u043E\u043B\u044C\u0434
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E **\u043B\u044E\u0431\u0430\u044F
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u0430\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u044F
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u0447\u0435\u0440\u0435\u0437 \u0441\u0443\u043F\u0435\u0440\u043F\u043E\u0437\u0438\u0446\u0438\u044E
    \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E \u0447\u0438\u0441\u043B\u0430
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u0434\u0432\u0443\u0445 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445**.
    \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u0441\u0434\u0435\u043B\u0430\u043B\u0430
    \u0435\u0433\u043E \u0438\u043C\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u0432\u043E \u0432\u0441\u0435\u043C \u043C\u0438\u0440\u0435 \u0438 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430
    \u043F\u0440\u0435\u043C\u0438\u044E \u041C\u043E\u0441\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430.  ### \U0001F680 \u0422\u0435\u043E\u0440\u0438\u044F
    \u041A\u0410\u041C (\u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430-\u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430-\u041C\u043E\u0437\u0435\u0440\u0430)
    \u042D\u0442\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u044B\u0439
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0446\u0438\u043A\u043B
    \u0440\u0430\u0431\u043E\u0442 \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430,
    \u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u041B\u0435\u043D\u0438\u043D\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E
    \u0432 1965 \u0433\u043E\u0434\u0443.  *   **\u0412 \u0447\u0435\u043C \u0441\u0443\u0442\u044C:**
    \u0422\u0435\u043E\u0440\u0438\u044F \u041A\u0410\u041C \u043E\u0442\u0432\u0435\u0447\u0430\u0435\u0442
    \u043D\u0430 \u043E\u0434\u0438\u043D \u0438\u0437 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u0432 \u043D\u0435\u0431\u0435\u0441\u043D\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438 \u0438 \u0444\u0438\u0437\u0438\u043A\u0438:
    **\u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u044B
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0441\u0438\u0441\u0442\u0435\u043C\u044B**
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0421\u043E\u043B\u043D\u0435\u0447\u043D\u0430\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430) \u043F\u0440\u0438 \u043C\u0430\u043B\u044B\u0445
    \u0432\u043E\u0437\u043C\u0443\u0449\u0435\u043D\u0438\u044F\u0445? \u041E\u043D\u0430
    \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442, \u0447\u0442\u043E
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043D\u044B\u0435
    \u0442\u043E\u0440\u044B (\u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    \u0432 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B)
    \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u044E\u0442\u0441\u044F \u043F\u0440\u0438
    \u043C\u0430\u043B\u044B\u0445 \u0432\u043E\u0437\u043C\u0443\u0449\u0435\u043D\u0438\u044F\u0445
    \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u0443\u0435\u043C\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B. *   **\u0420\u043E\u043B\u044C \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430:**
    \u041E\u043D \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0442\u0440\u0435\u0445
    \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u0439 \u044D\u0442\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 (\u0432\u043C\u0435\u0441\u0442\u0435 \u0441\u043E
    \u0441\u0432\u043E\u0438\u043C \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C
    \u0410.\u041D. \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u044B\u043C
    \u0438 \u042E\u0440\u0433\u0435\u043D\u043E\u043C \u041C\u043E\u0437\u0435\u0440\u043E\u043C).
    \u041E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0440\u0430\u0437\u0432\u0438\u043B
    \u0438\u0434\u0435\u0438 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430,
    \u043D\u043E \u0438 \u043E\u0442\u043A\u0440\u044B\u043B \u044F\u0432\u043B\u0435\u043D\u0438\u0435
    **\"\u0434\u0438\u0444\u0444\u0443\u0437\u0438\u0438 \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430\"**
    \u2014 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C \u043D\u0435\u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438
    \u0432 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0445 \u0441 \u0431\u043E\u043B\u0435\u0435
    \u0447\u0435\u043C \u0434\u0432\u0443\u043C\u044F \u0441\u0442\u0435\u043F\u0435\u043D\u044F\u043C\u0438
    \u0441\u0432\u043E\u0431\u043E\u0434\u044B. \u042D\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0445 \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438
    \u043C\u043E\u0433\u0443\u0442 \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E
    \"\u0434\u0440\u0435\u0439\u0444\u043E\u0432\u0430\u0442\u044C\" \u0441\u043A\u0432\u043E\u0437\u044C
    \u0444\u0430\u0437\u043E\u0432\u043E\u0435 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E,
    \u0443\u0445\u043E\u0434\u044F \u0441\u043A\u043E\u043B\u044C \u0443\u0433\u043E\u0434\u043D\u043E
    \u0434\u0430\u043B\u0435\u043A\u043E \u043E\u0442 \u0441\u0432\u043E\u0435\u0433\u043E
    \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044F.
    \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0438\u043C\u0435\u0435\u0442
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0434\u043B\u044F \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u0434\u043E\u043B\u0433\u043E\u0441\u0440\u043E\u0447\u043D\u043E\u0433\u043E
    \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u0438\u0441\u0442\u0435\u043C. 
    ### \U0001F300 \u0414\u0438\u0444\u0444\u0443\u0437\u0438\u044F \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430
    \u042D\u0442\u043E \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0432\u044B\u0440\u043E\u0441\u043B\u043E
    \u0438\u0437 \u0442\u0435\u043E\u0440\u0438\u0438 \u041A\u0410\u041C \u0438 \u0437\u0430\u0441\u043B\u0443\u0436\u0438\u0432\u0430\u0435\u0442
    \u043E\u0441\u043E\u0431\u043E\u0433\u043E \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F. 
    *   **\u041A\u043B\u044E\u0447\u0435\u0432\u0430\u044F \u0438\u0434\u0435\u044F:**
    \u0412 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u0430\u043A \u0442\u0435\u043E\u0440\u0438\u044F
    \u041A\u0410\u041C \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0434\u043B\u044F \u0441\u0438\u0441\u0442\u0435\u043C \u0441
    \u0434\u0432\u0443\u043C\u044F \u0441\u0442\u0435\u043F\u0435\u043D\u044F\u043C\u0438
    \u0441\u0432\u043E\u0431\u043E\u0434\u044B \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
    (\u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u044B, \u0432\u0440\u043E\u0434\u0435
    \u044D\u043D\u0435\u0440\u0433\u0438\u0438) \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F
    \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u044B\u043C\u0438, \u0410\u0440\u043D\u043E\u043B\u044C\u0434
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E **\u0434\u043B\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C \u0441 \u0442\u0440\u0435\u043C\u044F \u0438
    \u0431\u043E\u043B\u0435\u0435 \u0441\u0442\u0435\u043F\u0435\u043D\u044F\u043C\u0438
    \u0441\u0432\u043E\u0431\u043E\u0434\u044B \u044D\u0442\u043E \u043D\u0435 \u0442\u0430\u043A**.
    \u0412\u043E\u0437\u043D\u0438\u043A\u0430\u0435\u0442 \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u044B\u0439,
    \u043D\u043E \u0433\u043B\u043E\u0431\u0430\u043B\u044C\u043D\u044B\u0439 \u0434\u0440\u0435\u0439\u0444
    \u0432 \u0444\u0430\u0437\u043E\u0432\u043E\u043C \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0438 \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u0434\u0438\u0444\u0444\u0443\u0437\u0438\u0435\u0439 \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430.
    \u042D\u0442\u043E \u044F\u0432\u043B\u0435\u043D\u0438\u0435 \u2014 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432
    \u0445\u0430\u043E\u0441\u0430 \u0432 \u043C\u043D\u043E\u0433\u043E\u043C\u0435\u0440\u043D\u044B\u0445
    \u0434\u0438\u043D\u0430\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0445. 
    ### \U0001F52C \u0421\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F \u0438 \u0434\u0440\u0443\u0433\u0438\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0412\u043A\u043B\u0430\u0434 \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430
    \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u0434\u0438\u043D\u0430\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C. \u041E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0446\u0435\u043B\u044B\u0445 \u043D\u043E\u0432\u044B\u0445
    \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    *   **\u0421\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F:** \u0410\u0440\u043D\u043E\u043B\u044C\u0434
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u043E \u0447\u0438\u0441\u043B\u0435 \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u044B\u0445
    \u0442\u043E\u0447\u0435\u043A \u0441\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u043E\u043C\u043E\u0440\u0444\u0438\u0437\u043C\u043E\u0432
    (\u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439, \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u044E\u0449\u0438\u0445
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0443 \u0444\u0430\u0437\u043E\u0432\u043E\u0433\u043E
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430). \u042D\u0442\u043E
    \u0434\u0430\u043B\u043E \u043C\u043E\u0449\u043D\u044B\u0439 \u0438\u043C\u043F\u0443\u043B\u044C\u0441
    \u043A \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0441\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0435\u0439:** \u041E\u043D
    \u0432\u043D\u0435\u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044E
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0435\u0439 \u0433\u043B\u0430\u0434\u043A\u0438\u0445
    \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439, \u0447\u0442\u043E
    \u043D\u0430\u0448\u043B\u043E \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0432 \u043E\u043F\u0442\u0438\u043A\u0435 (\u043A\u0430\u0443\u0441\u0442\u0438\u043A\u0438),
    \u0433\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445.
    *   **\u0412\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:** \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043E \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u043E\u0432\u0430\u043B\u043E\u0432 \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u043F\u043B\u043E\u0441\u043A\u0438\u0445 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0438\u0432\u044B\u0445 (1971) \u043F\u0440\u0438\u0432\u0435\u043B\u0430
    \u043A \u0432\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044E \u044D\u0442\u043E\u0433\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    ### \U0001F9D1\u200D\U0001F3EB \u041F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u043A\u0430
    \u0438 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0438 \u0410\u0440\u043D\u043E\u043B\u044C\u0434
    \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C,
    \u043D\u043E \u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u043E\u043C. \u0415\u0433\u043E \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0438,
    \u0442\u0430\u043A\u0438\u0435 \u043A\u0430\u043A **\"\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438\"** \u0438 **\"\u041E\u0431\u044B\u043A\u043D\u043E\u0432\u0435\u043D\u043D\u044B\u0435
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\"**, \u0441\u0442\u0430\u043B\u0438
    \u043A\u043B\u0430\u0441\u0441\u0438\u043A\u043E\u0439 \u0438 \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043D\u044B
    \u043D\u0430 \u043C\u043D\u043E\u0433\u0438\u0435 \u044F\u0437\u044B\u043A\u0438
    \u043C\u0438\u0440\u0430. \u041E\u043D \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u043C \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \"\u0431\u0443\u0440\u0431\u0430\u043A\u0438\u0441\u0442\u0441\u043A\u043E\u0433\u043E\"
    \u043F\u043E\u0434\u0445\u043E\u0434\u0430, \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u044F
    \u043D\u0430 \u0442\u043E\u043C, \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u0442\u044C \u0442\u0435\u0441\u043D\u043E
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441 \u0444\u0438\u0437\u0438\u043A\u043E\u0439
    \u0438 \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u043C \u043C\u0438\u0440\u043E\u043C. 
    ### \U0001F3C6 \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0415\u0433\u043E
    \u0437\u0430\u0441\u043B\u0443\u0433\u0438 \u043E\u0442\u043C\u0435\u0447\u0435\u043D\u044B
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E\u043C \u0432\u044B\u0441\u0448\u0438\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    **\u041B\u0435\u043D\u0438\u043D\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E
    (1965), \u043F\u0440\u0435\u043C\u0438\u044E \u0412\u043E\u043B\u044C\u0444\u0430
    (2001), \u0413\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E \u0420\u0424 (2007) \u0438 \u043F\u0440\u0435\u043C\u0438\u044E
    \u0428\u0430\u043E (2008)**. \u041E\u043D \u0431\u044B\u043B \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u043C
    \u0420\u0410\u041D \u0438 \u0447\u043B\u0435\u043D\u043E\u043C \u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439 \u043C\u0438\u0440\u0430. \u0412
    \u0435\u0433\u043E \u0447\u0435\u0441\u0442\u044C \u043D\u0430\u0437\u0432\u0430\u043D\u044B
    \u043C\u043D\u043E\u0433\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F: \"\u044F\u0437\u044B\u043A\u0438
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430\", \"\u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430\" (\"\u043A\u043E\u0448\u043A\u0430
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430\"), \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043C\u0430\u043B\u0430\u044F \u043F\u043B\u0430\u043D\u0435\u0442\u0430 **\xAB\u0412\u043B\u0430\u0434\u0430\u0440\u043D\u043E\u043B\u044C\u0434\u0430\xBB**."
  achievementsEn: 
  personalLifeRu: "\u0412 \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438
    \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440 \u0418\u0433\u043E\u0440\u0435\u0432\u0438\u0447
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434, \u043F\u043E\u0434\u043E\u0431\u043D\u043E
    \u0441\u0432\u043E\u0435\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438,
    \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445
    \u0438 \u043F\u0440\u043E\u0447\u043D\u044B\u0445 \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u0435\u0439.
    \u0421\u0435\u043C\u044C\u044F, \u0434\u043E\u043C, \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F
    \u2014 \u0432\u0441\u0451 \u044D\u0442\u043E \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u043E
    \u0432\u0430\u0436\u043D\u0443\u044E \u0447\u0430\u0441\u0442\u044C \u0435\u0433\u043E
    \u044F\u0440\u043A\u043E\u0439 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438. 
    ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466 \u0421\u0435\u043C\u044C\u044F
    \u0438 \u0434\u0435\u0442\u0438  \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440
    \u0418\u0433\u043E\u0440\u0435\u0432\u0438\u0447 \u0431\u044B\u043B \u0434\u0432\u0430\u0436\u0434\u044B
    \u0436\u0435\u043D\u0430\u0442.  *   **\u041F\u0435\u0440\u0432\u044B\u0439 \u0431\u0440\u0430\u043A:**
    \u0415\u0433\u043E \u043F\u0435\u0440\u0432\u043E\u0439 \u0436\u0435\u043D\u043E\u0439
    \u0441\u0442\u0430\u043B\u0430 **\u041D\u0430\u0434\u0435\u0436\u0434\u0430 \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u043D\u0430
    \u0411\u0440\u0443\u0448\u043B\u0438\u043D\u0441\u043A\u0430\u044F**. \u041E\u043D\u0438
    \u043F\u043E\u0436\u0435\u043D\u0438\u043B\u0438\u0441\u044C 29 \u043C\u0430\u0440\u0442\u0430
    1959 \u0433\u043E\u0434\u0430. \u0412 \u044D\u0442\u043E\u043C \u0431\u0440\u0430\u043A\u0435
    25 \u043C\u0430\u044F 1959 \u0433\u043E\u0434\u0430 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0435\u0433\u043E \u0441\u044B\u043D **\u0418\u0433\u043E\u0440\u044C \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440\u043E\u0432\u0438\u0447
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434**. *   **\u0412\u0442\u043E\u0440\u043E\u0439
    \u0431\u0440\u0430\u043A:** \u0412 1976 \u0433\u043E\u0434\u0443 \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440
    \u0418\u0433\u043E\u0440\u0435\u0432\u0438\u0447 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 **\u042D\u043B\u0435\u043E\u043D\u043E\u0440\u0435 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u0432\u043D\u0435
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434** (\u0432 \u0434\u0435\u0432\u0438\u0447\u0435\u0441\u0442\u0432\u0435
    \u0412\u043E\u0440\u043E\u043D\u0438\u043D\u043E\u0439). \u0412 \u044D\u0442\u043E\u043C
    \u0431\u0440\u0430\u043A\u0435 \u043E\u043D \u0432\u043E\u0441\u043F\u0438\u0442\u044B\u0432\u0430\u043B
    \u043F\u0440\u0438\u0435\u043C\u043D\u043E\u0433\u043E \u0441\u044B\u043D\u0430
    **\u0414\u043C\u0438\u0442\u0440\u0438\u044F \u0411\u043E\u0440\u0438\u0441\u043E\u0432\u0438\u0447\u0430
    \u0412\u043E\u0440\u043E\u043D\u0438\u043D\u0430** (1968 \u0433\u043E\u0434\u0430
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F).  \u0421\u0435\u043C\u044C\u044F
    \u0431\u044B\u043B\u0430 \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0432\u0430\u0436\u043D\u043E\u0439
    \u043E\u043F\u043E\u0440\u043E\u0439. \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u0447\u0442\u043E \u0434\u0435\u0442\u0438 \u0438 \u0432\u043D\u0443\u043A\u0438
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430 \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438, \u043C\u043D\u043E\u0433\u0438\u0435
    \u0438\u0437 \u043D\u0438\u0445 \u0441\u0442\u0430\u043B\u0438 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u0430\u043C\u0438
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u044B\u0445
    \u043D\u0430\u0443\u043A.  ### \U0001F3DB\uFE0F \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u044B
    \u0438 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F  \u041B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430 \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u043B\u0430\u0441\u044C
    \u043E\u0434\u043D\u043E\u0439 \u043B\u0438\u0448\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439.
    \u041E\u043D \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043C
    \u0438 \u043E\u0431\u043B\u0430\u0434\u0430\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E\u043C
    \u0442\u0430\u043B\u0430\u043D\u0442\u043E\u0432.  *   **\u0412\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434\u043D\u044B\u0435
    \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0438:** \u0421 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
    \u043E\u043D \u0431\u044B\u043B \u043F\u0440\u0438\u0443\u0447\u0435\u043D \u043A
    \u0432\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434\u0443 \u0438 \u043D\u0430
    \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438 \u0432\u0441\u0435\u0439
    \u0436\u0438\u0437\u043D\u0438 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u044B\u043C \u0432\u0435\u043B\u043E\u0441\u0438\u043F\u0435\u0434\u0438\u0441\u0442\u043E\u043C.
    \u041E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u043B \u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435,
    \u043F\u043E\u0440\u043E\u0439 \u0441\u0442\u043E\u043A\u0438\u043B\u043E\u043C\u0435\u0442\u0440\u043E\u0432\u044B\u0435
    \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0438 \u043F\u043E \u041F\u043E\u0434\u043C\u043E\u0441\u043A\u043E\u0432\u044C\u044E
    \u0438 \u043E\u043A\u0440\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044F\u043C
    \u041F\u0430\u0440\u0438\u0436\u0430. \u041F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u043E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0435\u0437\u0434\u0438\u043B,
    \u043D\u043E \u0438, \u043A\u0430\u043A \u0438\u0441\u0442\u0438\u043D\u043D\u044B\u0439
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C,
    \u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u043B \u043C\u0435\u0441\u0442\u0430,
    \u0433\u0434\u0435 \u0440\u043E\u0441\u043B\u0438 \u0433\u0440\u0438\u0431\u044B
    \u0438\u043B\u0438 \u044F\u0433\u043E\u0434\u044B. *   **\u041B\u044E\u0431\u043E\u0432\u044C
    \u043A \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0435 \u0438 \u044F\u0437\u044B\u043A\u0430\u043C:**
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434 \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u043D\u044B\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C.
    \u041E\u043D \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u043B
    \u043D\u0430 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u043C,
    \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u043C \u0438 \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0430\u0445. \u0415\u0433\u043E \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043E\u0439 \u0431\u044B\u043B\u043E
    \u0441\u0442\u043E\u043B\u044C \u0436\u0435 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C:
    \u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B \u0433\u0443\u043C\u0430\u043D\u0438\u0442\u0430\u0440\u043D\u043E\u0435
    \"\u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\", \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u0432
    \u0441\u0432\u044F\u0437\u044C \u044D\u043F\u0438\u0433\u0440\u0430\u0444\u0430
    \u043A \u043F\u0443\u0448\u043A\u0438\u043D\u0441\u043A\u043E\u043C\u0443 \xAB\u0415\u0432\u0433\u0435\u043D\u0438\u044E
    \u041E\u043D\u0435\u0433\u0438\u043D\u0443\xBB \u0441 \u0442\u0435\u043A\u0441\u0442\u043E\u043C
    \u0440\u043E\u043C\u0430\u043D\u0430 \u0428\u043E\u0434\u0435\u0440\u043B\u043E
    \u0434\u0435 \u041B\u0430\u043A\u043B\u043E \xAB\u041E\u043F\u0430\u0441\u043D\u044B\u0435
    \u0441\u0432\u044F\u0437\u0438\xBB. \u042D\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u043E \u0435\u0433\u043E \u0442\u043E\u043D\u043A\u043E\u043C \u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u0438
    \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u044B \u0438 \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u043E\u043C
    \u0432\u0437\u0433\u043B\u044F\u0434\u0435 \u043D\u0430, \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C
    \u0431\u044B, \u0434\u0430\u043B\u0435\u043A\u0438\u0435 \u043E\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432\u0435\u0449\u0438. *   **\u042D\u043A\u0441\u043A\u0443\u0440\u0441\u043E\u0432\u043E\u0434:**
    \u0415\u0433\u043E \u0434\u0440\u0443\u0437\u044C\u044F \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u043E\u0442\u043C\u0435\u0447\u0430\u043B\u0438, \u0447\u0442\u043E \u043E\u043D
    \u0431\u044B\u043B \u043D\u0435\u043E\u0431\u044B\u0447\u0430\u0439\u043D\u043E
    \u044F\u0440\u043A\u0438\u043C \u0438 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u043D\u044B\u043C
    \u044D\u043A\u0441\u043A\u0443\u0440\u0441\u043E\u0432\u043E\u0434\u043E\u043C,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u043F\u043E \u041F\u0430\u0440\u0438\u0436\u0443,
    \u0447\u0442\u043E \u0442\u043E\u0436\u0435 \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u043E \u0435\u0433\u043E \u043B\u044E\u0431\u0432\u0438 \u043A \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0438 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0443.  ### \u26B0\uFE0F
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B 
    \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440 \u0418\u0433\u043E\u0440\u0435\u0432\u0438\u0447
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434 \u0441\u043A\u043E\u0440\u043E\u043F\u043E\u0441\u0442\u0438\u0436\u043D\u043E
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 \u041F\u0430\u0440\u0438\u0436\u0435
    3 \u0438\u044E\u043D\u044F 2010 \u0433\u043E\u0434\u0430, \u043D\u0435 \u0434\u043E\u0436\u0438\u0432
    \u0447\u0443\u0442\u044C \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435\u0434\u0435\u043B\u0438
    \u0434\u043E \u0441\u0432\u043E\u0435\u0433\u043E 73-\u043B\u0435\u0442\u0438\u044F.
    \u041E\u043D \u0431\u044B\u043B \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    15 \u0438\u044E\u043D\u044F 2010 \u0433\u043E\u0434\u0430 \u0432 \u041C\u043E\u0441\u043A\u0432\u0435
    \u043D\u0430 \u041D\u043E\u0432\u043E\u0434\u0435\u0432\u0438\u0447\u044C\u0435\u043C
    \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435. 12 \u0438\u044E\u043D\u044F
    2013 \u0433\u043E\u0434\u0430 \u043D\u0430 \u0435\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u0435
    \u0431\u044B\u043B \u043E\u0442\u043A\u0440\u044B\u0442 \u043F\u0430\u043C\u044F\u0442\u043D\u0438\u043A. 
    \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0437\u0430
    \u0441\u0442\u0440\u043E\u0433\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C
    \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0441\u043A\u0440\u044B\u0432\u0430\u043B\u0441\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A,
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u043B\u044E\u0431\u0438\u0432\u0448\u0438\u0439
    \u0436\u0438\u0437\u043D\u044C, \u0441\u0435\u043C\u044C\u044E, \u043F\u0440\u0438\u0440\u043E\u0434\u0443
    \u0438 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E."
  personalLifeEn: 
  shortBioRu: "\u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440 \u0418\u0433\u043E\u0440\u0435\u0432\u0438\u0447
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434 (1937\u20132010) \u2014 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    XX \u0432\u0435\u043A\u0430, \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0434\u0438\u043D\u0430\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B, \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044E,
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u0438\u0437\u0438\u043A\u0443 \u0438 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0434\u0440\u0443\u0433\u0438\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438.
    \u0415\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u2014
    \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0433\u043E
    \u0443\u043C\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441 \u0440\u0430\u043D\u043D\u0438\u0445
    \u043B\u0435\u0442 \u0440\u0435\u0448\u0430\u043B \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0438 \u043D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438
    \u0432\u0441\u0435\u0439 \u0436\u0438\u0437\u043D\u0438 \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F
    \u043A \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043A\u0430\u043A \u0447\u0430\u0441\u0442\u0438 \u0444\u0438\u0437\u0438\u043A\u0438
    \u0438 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043C\u0438\u0440\u0430. 
    ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435  \u0410\u0440\u043D\u043E\u043B\u044C\u0434
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 12 \u0438\u044E\u043D\u044F 1937 \u0433\u043E\u0434\u0430
    \u0432 \u041E\u0434\u0435\u0441\u0441\u0435 \u0432 \u0441\u0435\u043C\u044C\u0435
    \u0441 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438
    \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u044F\u043C\u0438.  *   **\u0421\u0435\u043C\u044C\u044F:**
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u0418\u0433\u043E\u0440\u044C \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440\u043E\u0432\u0438\u0447
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434, \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u0438 \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A. \u041C\u0430\u0442\u044C, \u041D\u0438\u043D\u0430
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u0432\u043D\u0430
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434 (\u0443\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u0430\u044F
    \u0418\u0441\u0430\u043A\u043E\u0432\u0438\u0447), \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E\u0432\u0435\u0434\u043E\u043C
    \u0432 \u041F\u0443\u0448\u043A\u0438\u043D\u0441\u043A\u043E\u043C \u043C\u0443\u0437\u0435\u0435.
    \u0412 \u0441\u0435\u043C\u044C\u0435 \u0431\u044B\u043B\u043E \u043C\u043D\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u044B\u0445, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0435\u0433\u043E \u0432\u043D\u0443\u0447\u0430\u0442\u043E\u0433\u043E \u0434\u044F\u0434\u044E,
    \u0444\u0438\u0437\u0438\u043A\u0430 \u041B.\u0418. \u041C\u0430\u043D\u0434\u0435\u043B\u044C\u0448\u0442\u0430\u043C\u0430.
    *   **\u0418\u043D\u0442\u0435\u0440\u0435\u0441 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435:**
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u043F\u0440\u043E\u0441\u043D\u0443\u043B\u0441\u044F \u0443 \u043D\u0435\u0433\u043E
    \u043E\u0447\u0435\u043D\u044C \u0440\u0430\u043D\u043E, \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E
    \u0441 \u043F\u044F\u0442\u0438 \u043B\u0435\u0442, \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u0438 \u0440\u0435\u0448\u0430\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0432 \u0441\u0435\u043C\u044C\u0435. \u0412
    12 \u043B\u0435\u0442 \u043E\u043D \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F
    \u0441 \u0437\u0430\u0434\u0430\u0447\u0435\u0439, \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0441\u0442\u0430\u043B\u043E \u0434\u043B\u044F
    \u043D\u0435\u0433\u043E \"\u043E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u0438\u0435\u043C\"
    \u0438 \u043F\u0440\u0435\u0434\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u043E
    \u0435\u0433\u043E \u043F\u0443\u0442\u044C. *   **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B:** \u0412 1954 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u043D\u0430 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442 \u041C\u0413\u0423, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u0432 1959 \u0433\u043E\u0434\u0443.
    \u0421\u0442\u0443\u0434\u0435\u043D\u0447\u0435\u0441\u043A\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0432 \u041C\u0413\u0423 \u0431\u044B\u043B\u0438 \u0437\u043E\u043B\u043E\u0442\u044B\u043C
    \u0432\u0435\u043A\u043E\u043C: \u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044F\u043C\u0438
    \u0438 \u0441\u0442\u0430\u0440\u0448\u0438\u043C\u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438
    \u0431\u044B\u043B\u0438 \u0442\u0430\u043A\u0438\u0435 \u0433\u0438\u0433\u0430\u043D\u0442\u044B,
    \u043A\u0430\u043A \u0410.\u041D. \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432,
    \u0418.\u041C. \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434, \u041B.\u0421.
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D, \u0430 \u0441\u0440\u0435\u0434\u0438
    \u043E\u0434\u043D\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A\u043E\u0432
    \u2014 \u0431\u0443\u0434\u0443\u0449\u0438\u0435 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  ### \U0001F4A1
    \u0413\u043B\u0430\u0432\u043D\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u0438 \u0432\u043A\u043B\u0430\u0434 
    \u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u043E.
    \u0415\u0433\u043E \u0447\u0430\u0441\u0442\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \"\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C-\u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u0438\u0441\u0442\u043E\u043C\"
    \u0437\u0430 \u0432\u043A\u043B\u0430\u0434 \u0432 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0448\u0438\u0440\u043E\u043A\u0438\u0439 \u0441\u043F\u0435\u043A\u0442\u0440
    \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439.  *   **\u0420\u0435\u0448\u0435\u043D\u0438\u0435
    13-\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    (1957):** \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 19 \u043B\u0435\u0442,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C,
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0441\u0432\u043E\u044E \u043F\u0435\u0440\u0432\u0443\u044E \u0433\u0440\u043E\u043C\u043A\u0443\u044E
    \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u043F\u043E\u0431\u0435\u0434\u0443.
    \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043B\u044E\u0431\u0430\u044F
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u0430\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u044F
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u043A\u0430\u043A \u0441\u0443\u043F\u0435\u0440\u043F\u043E\u0437\u0438\u0446\u0438\u044F
    (\u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0446\u0438\u044F) \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u043E\u0442
    \u0434\u0432\u0443\u0445 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445,
    \u0440\u0435\u0448\u0438\u0432 \u0442\u0435\u043C \u0441\u0430\u043C\u044B\u043C
    \u043E\u0434\u043D\u0443 \u0438\u0437 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C \u0414\u0430\u0432\u0438\u0434\u0430
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430. \u0417\u0430 \u044D\u0442\u043E
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0432 1958 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0440\u0435\u043C\u0438\u044E
    \u041C\u043E\u0441\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u041A\u0410\u041C (\u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430-\u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430-\u041C\u043E\u0437\u0435\u0440\u0430):**
    \u042D\u0442\u043E \u043E\u0434\u043D\u0430 \u0438\u0437 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u0442\u0435\u043E\u0440\u0438\u0439 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435, \u0440\u0435\u0448\u0430\u044E\u0449\u0430\u044F
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443 \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438
    \u0432\u043E\u0437\u043C\u0443\u0449\u0435\u043D\u043D\u044B\u0445 \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u0443\u0435\u043C\u044B\u0445
    \u0433\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u043E\u0432\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u043F\u043B\u0430\u043D\u0435\u0442).
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430,
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E \u0440\u0430\u0437\u0432\u0438\u043B
    \u0435\u0433\u043E \u043F\u043E\u0434\u0445\u043E\u0434 \u0438 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u042E\u0440\u0433\u0435\u043D\u043E\u043C \u041C\u043E\u0437\u0435\u0440\u043E\u043C
    \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u0442\u0440\u043E\u0439\u043D\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0430 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0438 \u0434\u0438\u043D\u0430\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C. *   **\u0414\u0438\u0444\u0444\u0443\u0437\u0438\u044F
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430:** \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0432 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0445 \u0441
    \u0431\u043E\u043B\u0435\u0435 \u0447\u0435\u043C \u0434\u0432\u0443\u043C\u044F
    \u0441\u0442\u0435\u043F\u0435\u043D\u044F\u043C\u0438 \u0441\u0432\u043E\u0431\u043E\u0434\u044B
    \u0434\u0430\u0436\u0435 \u043F\u0440\u0438 \u043C\u0430\u043B\u044B\u0445 \u0432\u043E\u0437\u043C\u0443\u0449\u0435\u043D\u0438\u044F\u0445
    \u043C\u043E\u0436\u0435\u0442 \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u0442\u044C
    \u0433\u043B\u043E\u0431\u0430\u043B\u044C\u043D\u0430\u044F \u043D\u0435\u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u044C,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F \u043A\u0430\u043A \"\u0434\u0438\u0444\u0444\u0443\u0437\u0438\u044F
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430\". \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u0438\u043C\u0435\u043B\u043E \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0434\u043B\u044F \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F
    \u0434\u043E\u043B\u0433\u043E\u0441\u0440\u043E\u0447\u043D\u043E\u0433\u043E
    \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C, \u043E\u0442 \u0421\u043E\u043B\u043D\u0435\u0447\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u0434\u043E \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438
    \u043C\u043E\u043B\u0435\u043A\u0443\u043B. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0435\u0439:** \u0412\u043C\u0435\u0441\u0442\u0435
    \u0441 \u0420\u0435\u043D\u0435 \u0422\u043E\u043C\u043E\u043C, \u0410\u0440\u043D\u043E\u043B\u044C\u0434
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0435\u0439
    \u0433\u043B\u0430\u0434\u043A\u0438\u0445 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u043B\u0430 \u0441\u0442\u0440\u043E\u0433\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \"\u0442\u0435\u043E\u0440\u0438\u0438
    \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\". \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0432\u043D\u0435\u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044E
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u044E\u0442 \u0432 \u043E\u043F\u0442\u0438\u043A\u0435
    (\u043A\u0430\u0443\u0441\u0442\u0438\u043A\u0438), \u0433\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445.
    *   **\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0441\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438:** \u0410\u0440\u043D\u043E\u043B\u044C\u0434
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u043E \u0447\u0438\u0441\u043B\u0435 \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u044B\u0445
    \u0442\u043E\u0447\u0435\u043A \u0441\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u043E\u043C\u043E\u0440\u0444\u0438\u0437\u043C\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0434\u0430\u043B\u0430 \u043D\u0430\u0447\u0430\u043B\u043E
    \u0446\u0435\u043B\u043E\u043C\u0443 \u0440\u0430\u0437\u0434\u0435\u043B\u0443
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u2014 \u0441\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438. *   **\u0420\u0430\u0431\u043E\u0442\u044B
    \u043F\u043E \u0433\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435:**
    \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u043E\u0434\u0445\u043E\u0434\u044B \u043A \u0437\u0430\u0434\u0430\u0447\u0430\u043C
    \u0433\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u0440\u0438\u0432\u0435\u043B\u0438
    \u043A \u043D\u043E\u0432\u044B\u043C \u0442\u0435\u043E\u0440\u0435\u043C\u0430\u043C
    \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438 \u0438
    \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u044E \"\u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438\". 
    ### \U0001F4DA \u041F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0438
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u043D\u0430 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 
    \u0410\u0440\u043D\u043E\u043B\u044C\u0434 \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C,
    \u043D\u043E \u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u043E\u043C.  *   **\u041F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C:**
    \u041E\u043D \u0431\u044B\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u041C\u0413\u0423 \u0441 1965 \u043F\u043E 1986 \u0433\u043E\u0434, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u0438\u043C. \u0412.\u0410.
    \u0421\u0442\u0435\u043A\u043B\u043E\u0432\u0430. \u0421 1993 \u0433\u043E\u0434\u0430
    \u043E\u043D \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B
    \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u041F\u0430\u0440\u0438\u0436-\u0414\u043E\u0444\u0438\u043D. *   **\u0410\u0432\u0442\u043E\u0440
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u0432:**
    \u0415\u0433\u043E \u043A\u043D\u0438\u0433\u0438, \u0442\u0430\u043A\u0438\u0435
    \u043A\u0430\u043A \"\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438\" \u0438 \"\u041E\u0431\u044B\u043A\u043D\u043E\u0432\u0435\u043D\u043D\u044B\u0435
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\", \u0441\u0442\u0430\u043B\u0438
    \u043C\u0438\u0440\u043E\u0432\u044B\u043C\u0438 \u0431\u0435\u0441\u0442\u0441\u0435\u043B\u043B\u0435\u0440\u0430\u043C\u0438
    \u0438 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u043C\u0438
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0430\u043C\u0438, \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043D\u043D\u044B\u043C\u0438
    \u043D\u0430 \u043C\u043D\u043E\u0433\u0438\u0435 \u044F\u0437\u044B\u043A\u0438.
    *   **\u041A\u0440\u0438\u0442\u0438\u043A \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043C\u0430:**
    \u041E\u043D \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u0438 \u044F\u0440\u044B\u043C \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u043C
    \"\u0431\u0443\u0440\u0431\u0430\u043A\u0438\u0441\u0442\u0441\u043A\u043E\u0433\u043E\"
    \u043F\u043E\u0434\u0445\u043E\u0434\u0430 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u043F\u043E \u0435\u0433\u043E \u043C\u043D\u0435\u043D\u0438\u044E,
    \u043E\u0442\u0440\u044B\u0432\u0430\u043B \u0435\u0435 \u043E\u0442 \u0444\u0438\u0437\u0438\u043A\u0438
    \u0438 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438, \u043F\u043E\u0434\u043C\u0435\u043D\u044F\u044F
    \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0435 \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043C\u043E\u043C.
    \u041E\u043D \u0447\u0430\u0441\u0442\u043E \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B
    \u0432 \u043F\u0440\u0438\u043C\u0435\u0440 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u0438\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0437\u043D\u0430\u043B \u043E \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438
    \u0441\u043B\u043E\u0436\u0435\u043D\u0438\u044F, \u043D\u043E \u043D\u0435 \u043C\u043E\u0433
    \u043F\u043E\u0441\u0447\u0438\u0442\u0430\u0442\u044C 2+3. \u0415\u0433\u043E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0430\u0444\u043E\u0440\u0438\u0437\u043C:
    **\"\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u2014 \u044D\u0442\u043E
    \u0447\u0430\u0441\u0442\u044C \u0444\u0438\u0437\u0438\u043A\u0438, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u044B \u0434\u0435\u0448\u0435\u0432\u044B\"**. 
    ### \U0001F3C6 \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B  \u041C\u0430\u0441\u0448\u0442\u0430\u0431
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438 \u0410\u0440\u043D\u043E\u043B\u044C\u0434\u0430
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D \u0432\u043E \u0432\u0441\u0435\u043C
    \u043C\u0438\u0440\u0435. \u041E\u043D \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u043D\u0430\u0443\u043A, \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A, \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A \u0421\u0428\u0410,
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0435 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E, \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A \u0438
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0434\u0440\u0443\u0433\u0438\u0435.  \u0421\u0440\u0435\u0434\u0438
    \u0435\u0433\u043E \u043C\u043D\u043E\u0433\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434: *   **\u041B\u0435\u043D\u0438\u043D\u0441\u043A\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F (1965)** \u2014 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0410.\u041D. \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u044B\u043C
    \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0435
    \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438 \u0433\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u043E\u0432\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C. *   **\u041F\u0440\u0435\u043C\u0438\u044F
    \u0412\u043E\u043B\u044C\u0444\u0430 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    (2001)** \u2014 \u0437\u0430 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0438 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. *   **\u041F\u0440\u0435\u043C\u0438\u044F
    \u0428\u0430\u043E (2008)** \u2014 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u041B.\u0414. \u0424\u0430\u0434\u0434\u0435\u0435\u0432\u044B\u043C
    \u0437\u0430 \u0432\u043A\u043B\u0430\u0434 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u0438\u0437\u0438\u043A\u0443. *   **\u0413\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F \u0420\u0424 (2007)**. *   **\u041A\u0440\u0430\u0444\u043E\u0440\u0434\u0441\u043A\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F (1982)**.  ### \U0001F54A\uFE0F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u0414\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0445 \u0434\u043D\u0435\u0439
