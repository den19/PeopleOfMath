    \u043D\u0430 \u043F\u043E\u043B\u0443, \u0432\u0440\u0430\u0449\u0430\u044F \u0435\u0451
    \u0432\u043E\u043A\u0440\u0443\u0433 \u043E\u0441\u0438. \u0411\u0443\u0434\u0443\u0449\u0438\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A \u0441\u043A\u0430\u0437\u0430\u043B:
    \"\u0422\u044B \u043F\u043E\u0432\u0435\u0440\u043D\u0443\u043B \u0442\u0430\u0431\u0443\u0440\u0435\u0442\u043A\u0443
    \u0443\u0436\u0435 \u0431\u043E\u043B\u044C\u0448\u0435 \u0447\u0435\u043C \u043D\u0430
    90 \u0433\u0440\u0430\u0434\u0443\u0441\u043E\u0432. \u0417\u043D\u0430\u0447\u0438\u0442,
    \u043A\u0440\u0438\u0432 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u043B,
    \u043D\u043E \u0438 \u0442\u0430\u0431\u0443\u0440\u0435\u0442\u043A\u0430, \u043E\u0434\u043D\u0443
    \u0438\u0437 \u043D\u043E\u0436\u0435\u043A \u043D\u0430\u0434\u043E \u043F\u043E\u0434\u043F\u0438\u043B\u0438\u0442\u044C\".
    \u0412 10 \u043B\u0435\u0442 \u0435\u0433\u043E \u043D\u0435 \u0443\u0441\u0442\u0440\u043E\u0438\u043B\u043E
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0435 \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u0435
    \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \"\u043C\u0438\u043D\u0443\u0441 \u043D\u0430
    \u043C\u0438\u043D\u0443\u0441 \u0434\u0430\u0435\u0442 \u043F\u043B\u044E\u0441\"
