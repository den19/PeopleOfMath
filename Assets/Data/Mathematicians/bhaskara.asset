    \u0431\u043E\u043B\u0435\u0435 \u0436\u0438\u0432\u044B\u043C.  ### \U0001F3B2
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0432 \u0441\u0442\u0438\u0445\u0430\u0445
