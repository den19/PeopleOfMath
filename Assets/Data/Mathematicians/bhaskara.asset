  achievementsRu: "\u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u2014 \u044D\u0442\u043E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u043F\u0438\u0441\u043E\u043A
    \u0444\u043E\u0440\u043C\u0443\u043B, \u0430 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0430\u044F
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F \u0432 \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043D\u0430 500\u2013600 \u043B\u0435\u0442
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0430 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443.  ### 1. \u0410\u043B\u0433\u0435\u0431\u0440\u0430
    (\xAB\u0411\u0438\u0434\u0436\u0430\u0433\u0430\u043D\u0438\u0442\u0430\xBB):
    \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0433\u043E
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F  \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0440\u043E\u0440\u044B\u0432
    \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0435, \u043F\u0435\u0440\u0435\u0439\u0434\u044F
    \u043E\u0442 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0445 \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u0445
    \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u0432 \u043A \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u043C
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u044F\u043C \u0441 \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u043C\u0438. 
    *   **\u0421\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043D\u043E\u0442\u0430\u0446\u0438\u044F:** \u041E\u043D \u043F\u0435\u0440\u0432\u044B\u043C
    \u0432 \u043C\u0438\u0440\u0435 \u043D\u0430\u0447\u0430\u043B \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u0431\u0443\u043A\u0432\u044B
    \u0434\u043B\u044F \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u0432\u0435\u043B\u0438\u0447\u0438\u043D.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043E\u043D \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0430\u043B
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435 \u043A\u0430\u043A
    *\u0439\u0430* (\u043E\u0442 \u0441\u043B\u043E\u0432\u0430 *\u0439\u0430\u0432\u0430\u0442-\u0442\u0430\u0432\u0430\u0442*
    \u2014 \xAB\u0441\u0442\u043E\u043B\u044C\u043A\u043E-\u0442\u043E\xBB), \u0430
    \u0432\u0442\u043E\u0440\u043E\u0435 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435
    \u2014 \u043A\u0430\u043A *\u043A\u0430\u043B\u0430* (\xAB\u0447\u0435\u0440\u043D\u044B\u0439\xBB).
    \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u043E \u0435\u043C\u0443
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0432 \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u0435, \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0449\u0430\u044F
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E \u0430\u043B\u0433\u0435\u0431\u0440\u0443.
    *   **\u0420\u0435\u0448\u0435\u043D\u0438\u0435 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439:** \u041E\u043D \u0447\u0435\u0442\u043A\u043E
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043F\u0440\u0430\u0432\u0438\u043B\u043E, \u0447\u0442\u043E **\u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u043E\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \u0438\u043C\u0435\u0435\u0442
    \u0434\u0432\u0430 \u043A\u043E\u0440\u043D\u044F**. \u0412 \u0441\u0432\u043E\u0435\u043C
    \u0442\u0440\u0443\u0434\u0435 \u043E\u043D \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0435\u0442
    \u0441\u043B\u0443\u0447\u0430\u0438 \u0441 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0438 \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u043A\u043E\u0440\u043D\u044F\u043C\u0438, \u043F\u0440\u0438\u0447\u0435\u043C
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u043E\u043D \u043F\u0440\u0438\u0437\u043D\u0430\u0435\u0442
    \u043A\u0430\u043A \u043F\u043E\u043B\u043D\u043E\u043F\u0440\u0430\u0432\u043D\u044B\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F (\u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F
    \u043A\u0430\u043A \u043C\u043D\u043E\u0433\u0438\u0435 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438 \u0434\u0430\u0436\u0435 \u0440\u0430\u043D\u043D\u0438\u0435 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043E\u0442\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u043B\u0438
    \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430 \u043A\u0430\u043A \xAB\u043D\u0435\u043B\u0435\u043F\u044B\u0435\xBB).
    *   **\u0426\u0438\u043A\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u043C\u0435\u0442\u043E\u0434
    \xAB\u0427\u0430\u043A\u0440\u0430\u0432\u0430\u043B\u0430\xBB (\u0420\u0435\u0448\u0435\u043D\u0438\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u041F\u0435\u043B\u043B\u044F):**
    \u042D\u0442\u043E \u0435\u0433\u043E **\u0437\u043E\u043B\u043E\u0442\u043E\u0439
    \u0432\u0435\u043D\u0435\u0446**. \u041E\u043D \u0440\u0435\u0448\u0438\u043B
    \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \u0432\u0438\u0434\u0430
    \\( x^2 = 1 + p y^2 \\). \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0432\u043E\u0434\u0438\u043B \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u0441\u043B\u0443\u0447\u0430\u0438 \u043A \u043F\u0440\u043E\u0441\u0442\u044B\u043C,
    \u043F\u043E\u043B\u0443\u0447\u0430\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0432 \u0446\u0435\u043B\u044B\u0445 \u0447\u0438\u0441\u043B\u0430\u0445.     
    *   *\u041F\u0440\u0438\u043C\u0435\u0440:* \u0414\u043B\u044F \\( p = 61 \\)
    \u043E\u043D \u043D\u0430\u0448\u0435\u043B \u0440\u0435\u0448\u0435\u043D\u0438\u0435:
    \\( x = 1,766,319,049 \\) \u0438 \\( y = 226,153,980 \\). (\u0415\u0432\u0440\u043E\u043F\u0435\u0439\u0446\u044B,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0424\u0435\u0440\u043C\u0430 \u0438
    \u042D\u0439\u043B\u0435\u0440\u0430, \u0441\u043C\u043E\u0433\u043B\u0438 \u043F\u043E\u0432\u0442\u043E\u0440\u0438\u0442\u044C
    \u044D\u0442\u043E\u0442 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0435\u0440\u0435\u0437 500 \u043B\u0435\u0442!).
    *   **\u0410\u043D\u0430\u043B\u0438\u0437 \u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043D\u0430 \u043D\u043E\u043B\u044C:** \u041E\u043D \u043F\u0440\u0438\u0431\u043B\u0438\u0437\u0438\u043B\u0441\u044F
    \u043A \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044E \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438.
    \u0412 \xAB\u0411\u0438\u0434\u0436\u0430\u0433\u0430\u043D\u0438\u0442\u0435\xBB
    \u043E\u043D \u043F\u0438\u0448\u0435\u0442: *\xAB\u0412\u0435\u043B\u0438\u0447\u0438\u043D\u0430,
    \u0434\u0435\u043B\u0435\u043D\u043D\u0430\u044F \u043D\u0430 \u043D\u043E\u043B\u044C,
    \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u0434\u0440\u043E\u0431\u044C\u044E,
    \u0437\u043D\u0430\u043C\u0435\u043D\u0430\u0442\u0435\u043B\u044C \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0440\u0430\u0432\u0435\u043D \u043D\u0443\u043B\u044E. \u042D\u0442\u0443 \u0434\u0440\u043E\u0431\u044C
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E
    \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u043E\u0439\xBB.*
    \u041E\u043D \u043F\u0435\u0440\u0432\u044B\u043C \u0432\u0432\u0435\u043B \u0438\u0434\u0435\u044E,
    \u0447\u0442\u043E \\( a/0 = \\infty \\), \u0445\u043E\u0442\u044F \u0438 \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E
    \u043F\u043E\u043B\u0430\u0433\u0430\u043B, \u0447\u0442\u043E \\( \\infty \\times
    0 = a \\).  ---  ### 2. \u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430
    \u0438 \u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B (\xAB\u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438\xBB):
    \u041E\u043F\u0435\u0440\u0435\u0436\u0430\u044F \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0443 
    \xAB\u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438\xBB (\u043D\u0430\u0437\u0432\u0430\u043D\u043D\u0430\u044F
    \u0432 \u0447\u0435\u0441\u0442\u044C \u0435\u0433\u043E \u0434\u043E\u0447\u0435\u0440\u0438
    \u043F\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435) \u2014 \u044D\u0442\u043E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0437\u0430\u0434\u0430\u0447\u043D\u0438\u043A.
    \u042D\u0442\u043E \u043A\u043B\u0430\u0434\u0435\u0437\u044C \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u044B\u0445
    \u0434\u043E\u0433\u0430\u0434\u043E\u043A, \u0441\u0442\u0430\u0432\u0448\u0438\u0445
    \u0441\u0442\u0440\u043E\u0433\u0438\u043C\u0438 \u0442\u0435\u043E\u0440\u0435\u043C\u0430\u043C\u0438
    \u043F\u043E\u0437\u0436\u0435.  *   **\u041F\u0440\u0438\u0437\u043D\u0430\u043A\u0438
    \u0434\u0435\u043B\u0438\u043C\u043E\u0441\u0442\u0438:** \u041E\u043D \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438
    \u0434\u0435\u043B\u0438\u043C\u043E\u0441\u0442\u0438 \u0447\u0438\u0441\u0435\u043B
    (\u043D\u0430 3, 7, 11, 13 \u0438 \u0442.\u0434.), \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u0438\u0437\u0443\u0447\u0430\u044E\u0442
    \u0432 \u0448\u043A\u043E\u043B\u0435, \u043D\u043E \u0432 \u0431\u043E\u043B\u0435\u0435
    \u0441\u043B\u043E\u0436\u043D\u043E\u0439 \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u0438.
    *   **\u041A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0430:**
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u0434\u0430\u043B \u0447\u0435\u0442\u043A\u0438\u0435
    \u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0435 \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u0434\u043B\u044F \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    **\u0447\u0438\u0441\u043B\u0430 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A
    \u0438 \u0441\u043E\u0447\u0435\u0442\u0430\u043D\u0438\u0439**.      *   *\u0424\u043E\u0440\u043C\u0443\u043B\u0430
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A:* \\(
    P_n = 1 \\times 2 \\times 3 \\times... \\times n \\) (\u0444\u0430\u043A\u0442\u043E\u0440\u0438\u0430\u043B).    
    *   *\u0411\u0438\u043D\u043E\u043C\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u044B:* \u041E\u043D
    \u0437\u043D\u0430\u043B, \u043A\u0430\u043A \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u0442\u044C
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0446\u0438\u0439,
    \u0438 \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u043B\u0430\u0434\u0435\u043B
    \u0431\u0438\u043D\u043E\u043C\u043E\u043C \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u0434\u043B\u044F \u0446\u0435\u043B\u044B\u0445 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0441\u0442\u0435\u043F\u0435\u043D\u0435\u0439, \u0445\u043E\u0442\u044F \u0438
    \u043D\u0435 \u0437\u0430\u043F\u0438\u0441\u0430\u043B \u0435\u0433\u043E \u0432
    \u043E\u0431\u0449\u0435\u043C \u0432\u0438\u0434\u0435. \u041E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u044D\u0442\u0438 \u0437\u043D\u0430\u043D\u0438\u044F \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0437\u0430\u0434\u0430\u0447 \u043E \u0441\u043E\u0447\u0435\u0442\u0430\u043D\u0438\u0438
    \u0432\u043A\u0443\u0441\u043E\u0432 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u043F\u043E\u0441\u043E\u0431\u043E\u0432
    \u0441\u043C\u0435\u0448\u0430\u0442\u044C 6 \u0438\u043D\u0433\u0440\u0435\u0434\u0438\u0435\u043D\u0442\u043E\u0432).
    *   **\u041A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0435 \u0438 \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043E\u0440\u043D\u0438:** \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u043E \u0431\u044B\u0441\u0442\u0440\u044B\u0435
    \u0438\u0442\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u0435 \u043C\u0435\u0442\u043E\u0434\u044B
    \u0434\u043B\u044F \u0438\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F
    \u043A\u043E\u0440\u043D\u0435\u0439 \u0438\u0437 \u0431\u043E\u043B\u044C\u0448\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u0438\u043C\u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430\u043C\u0438
    \u0434\u043B\u044F \u0440\u0430\u0441\u0447\u0435\u0442\u043E\u0432 \u0441 \u0432\u044B\u0441\u043E\u043A\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E.  ---  ### 3. \u0422\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    \u0438 \u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F: \u041E\u0442 \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0435\u0439
    \u043A \u0441\u0444\u0435\u0440\u0430\u043C  \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445 \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u043D\u0435 \u0441\u0442\u0430\u0442\u0438\u0447\u043D\u043E,
    \u0430 \u0432 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438 (\u0432 \u0441\u0432\u044F\u0437\u0438
    \u0441 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0435\u0439). 
    *   **\u0421\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:**
    \u041E\u043D \u0434\u0430\u043B \u0442\u043E\u0447\u043D\u044B\u0435 \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u0434\u043B\u044F \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0434\u043B\u0438\u043D\u044B \u0434\u0443\u0433\u0438 \u043D\u0430 \u0441\u0444\u0435\u0440\u0435.
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u043A\u0440\u0438\u0442\u0438\u0447\u043D\u043E
    \u0434\u043B\u044F \u043D\u0430\u0432\u0438\u0433\u0430\u0446\u0438\u0438 \u0438
    \u0440\u0430\u0441\u0447\u0435\u0442\u0430 \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0432\u043E\u0441\u0445\u043E\u0434\u0430/\u0437\u0430\u0445\u043E\u0434\u0430
    \u0437\u0432\u0435\u0437\u0434. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430:** \u041E\u043D \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u0437\u043D\u0430\u043B \u0442\u0435\u043E\u0440\u0435\u043C\u0443,
    \u043E\u043D \u0434\u0430\u043B **\u0434\u0432\u0430 \u0440\u0430\u0437\u043D\u044B\u0445
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430**
    (\u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u043F\u043E\u0434\u043E\u0431\u0438\u0435
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432
    \u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u043F\u043B\u043E\u0449\u0430\u0434\u0438),
    \u0438 \u043E\u0431\u0430 \u0431\u044B\u043B\u0438 \u0441\u0442\u0440\u043E\u0433\u0438\u043C\u0438
    \u0438 \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u044B\u043C\u0438. *  
    **\u0423\u0442\u043E\u0447\u043D\u0435\u043D\u0438\u0435 \u0447\u0438\u0441\u043B\u0430
    \u03C0:** \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0434\u0440\u0435\u0432\u043D\u0438\u0445,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0447\u0430\u0441\u0442\u043E \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u0433\u0440\u0443\u0431\u044B\u043C \u0447\u0438\u0441\u043B\u043E\u043C 3,
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0434\u0432\u0430 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F:      *  
    \u041F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u043D\u043E\u0435 \u0434\u043B\u044F
    \u0431\u044B\u0442\u043E\u0432\u044B\u0445 \u0437\u0430\u0434\u0430\u0447: \\(
    \\sqrt{10} \\approx 3,1622 \\).     *   \u0422\u043E\u0447\u043D\u043E\u0435
    \u0434\u043B\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438:
    \\( 3,141666... \\) (\u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043B\u0443\u0447\u0448\u0438\u0445
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u0439 \u0434\u043B\u044F
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438,
    \u0442\u043E\u0447\u043D\u043E\u0435 \u0434\u043E \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E
    \u0437\u043D\u0430\u043A\u0430). *   **\u0418\u0434\u0435\u0438 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F:**
    \u0418\u0437\u0443\u0447\u0430\u044F \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435
    \u043F\u043B\u0430\u043D\u0435\u0442, \u043E\u043D \u0432\u0432\u0435\u043B \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044E
    \xAB\u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E\u0439 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438\xBB
    \u0438 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B,
    \u0447\u0442\u043E \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u0438
    \u0441\u0438\u043D\u0443\u0441\u043E\u0432 \u0434\u043E\u0441\u0442\u0438\u0433\u0430\u0435\u0442\u0441\u044F
    \u0432 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0445
    \u0442\u043E\u0447\u043A\u0430\u0445. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0441\u0447\u0438\u0442\u0430\u044E\u0442, \u0447\u0442\u043E \u043E\u043D \u043F\u043E\u0434\u043E\u0448\u0435\u043B
    \u0432\u043F\u043B\u043E\u0442\u043D\u0443\u044E \u043A \u043F\u043E\u043D\u044F\u0442\u0438\u044E
    **\u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u043E\u0439**, \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044F,
    \u043A\u0430\u043A \u0438\u0437\u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F \u043F\u0440\u0438 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E
    \u043C\u0430\u043B\u043E\u043C \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0438
    \u0430\u0440\u0433\u0443\u043C\u0435\u043D\u0442\u0430 (\u0445\u043E\u0442\u044F
    \u043E\u043D \u043D\u0435 \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E \u043A\u0430\u043A \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B,
    \u043A\u0430\u043A \u041D\u044C\u044E\u0442\u043E\u043D).  ---  ### 4. \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F
    (\xAB\u0413\u043E\u043B\u0430\u0434\u0445\u0430\u0439\u044F\xBB \u0438 \xAB\u0413\u0440\u0430\u043D\u0445\u0430\u0433\u0430\u043D\u0438\u0442\u0430\xBB):
    \u041F\u0435\u0440\u0435\u0445\u043E\u0434 \u043A \u0444\u0438\u0437\u0438\u043A\u0435 
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u0441\u0447\u0438\u0442\u0430\u043B
    \u0441\u0435\u0431\u044F \u0432 \u043F\u0435\u0440\u0432\u0443\u044E \u043E\u0447\u0435\u0440\u0435\u0434\u044C
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C, \u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0431\u044B\u043B\u0430 \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C. 
    *   **\u041E\u0442\u043A\u0430\u0437 \u043E\u0442 \u044D\u043F\u0438\u0446\u0438\u043A\u043B\u043E\u0432:**
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F,
    \u043E\u043D \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u043E\u0442
    \u0438\u0434\u0435\u0438 \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u043A\u0440\u0443\u0433\u043E\u0432\u044B\u0445
    \u043E\u0440\u0431\u0438\u0442 \u043F\u043B\u0430\u043D\u0435\u0442. \u041E\u043D
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u043C\u043E\u0434\u0435\u043B\u044C,
    \u0433\u0434\u0435 \u043F\u043B\u0430\u043D\u0435\u0442\u044B \u0434\u0432\u0438\u0436\u0443\u0442\u0441\u044F
    \u043F\u043E \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043E\u0440\u0431\u0438\u0442\u0430\u043C, \u0445\u043E\u0442\u044F \u0438 \u043D\u0435
    \u0434\u043E\u0432\u0435\u043B \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0440\u0430\u0441\u0447\u0435\u0442
    \u044D\u0442\u043E\u0439 \u043C\u043E\u0434\u0435\u043B\u0438 (\u044D\u0442\u043E
    \u0441\u0434\u0435\u043B\u0430\u0435\u0442 \u041A\u0435\u043F\u043B\u0435\u0440
    \u0447\u0435\u0440\u0435\u0437 400 \u043B\u0435\u0442). *   **\u041E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u0435
    \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u0438:** \u0412 \u0442\u0440\u0443\u0434\u0435
    \xAB\u0413\u043E\u043B\u0430\u0434\u0445\u0430\u0439\u044F\xBB \u043E\u043D \u0434\u0430\u0435\u0442
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0434\u043B\u044F XII \u0432\u0435\u043A\u0430 \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u0435
    \u043F\u0440\u0438\u0447\u0438\u043D\u044B, \u043F\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B \u043F\u0430\u0434\u0430\u044E\u0442
    \u043D\u0430 \u0417\u0435\u043C\u043B\u044E: *\xAB\u0417\u0435\u043C\u043B\u044F
    \u043F\u0440\u0438\u0442\u044F\u0433\u0438\u0432\u0430\u0435\u0442 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B
    \u0441\u0432\u043E\u0435\u0439 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0441\u0438\u043B\u043E\u0439. \u042D\u0442\u0430 \u0441\u0438\u043B\u0430 \u043F\u0440\u0438\u0442\u044F\u0436\u0435\u043D\u0438\u044F
    \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u0438\u0445 \u043F\u0430\u0434\u0430\u0442\u044C
    \u043D\u0430 \u0437\u0435\u043C\u043B\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0446\u0435\u043D\u0442\u0440\u043E\u043C\xBB.*
    \u042D\u0442\u043E \u043F\u0435\u0440\u0432\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0430, \u0431\u043B\u0438\u0437\u043A\u0430\u044F
    \u043A \u0437\u0430\u043A\u043E\u043D\u0443 \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0433\u043E
    \u0442\u044F\u0433\u043E\u0442\u0435\u043D\u0438\u044F (\u0437\u0430\u0434\u043E\u043B\u0433\u043E
    \u0434\u043E \u041D\u044C\u044E\u0442\u043E\u043D\u0430!). *   **\u0412\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435
    \u0441\u0438\u043D\u043E\u0434\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u0435\u0440\u0438\u043E\u0434\u0430 \u043F\u043B\u0430\u043D\u0435\u0442:**
    \u041E\u043D \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B \u0441 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E \u0432\u0440\u0435\u043C\u044F,
    \u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043F\u043B\u0430\u043D\u0435\u0442\u0430
    \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F \u0432
    \u0442\u0443 \u0436\u0435 \u0442\u043E\u0447\u043A\u0443 \u043D\u0435\u0431\u0430.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0435\u0433\u043E \u0440\u0430\u0441\u0447\u0435\u0442\u044B
    \u0441\u0438\u0434\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u0435\u0440\u0438\u043E\u0434\u0430 \u0421\u0430\u0442\u0443\u0440\u043D\u0430
    \u0438 \u042E\u043F\u0438\u0442\u0435\u0440\u0430 \u043E\u0442\u043B\u0438\u0447\u0430\u043B\u0438\u0441\u044C
    \u043E\u0442 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0434\u0430\u043D\u043D\u044B\u0445 \u043C\u0435\u043D\u0435\u0435 \u0447\u0435\u043C
    \u043D\u0430 1%. *   **\u041F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u0435
    \xAB\u0412\u0435\u0447\u043D\u043E\u0433\u043E \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u044F\xBB:**
    \u0412 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435 \u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0447\u0435\u0440\u0442\u0435\u0436 \u043A\u043E\u043B\u0435\u0441\u0430 \u0441
    \u043D\u0430\u043A\u043B\u043E\u043D\u043D\u044B\u043C\u0438 \u0442\u0440\u0443\u0431\u043A\u0430\u043C\u0438,
    \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u044B\u043C\u0438 \u0440\u0442\u0443\u0442\u044C\u044E.
    \u041F\u0440\u0438 \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438 \u0440\u0442\u0443\u0442\u044C
    \u043F\u0435\u0440\u0435\u0442\u0435\u043A\u0430\u043B\u0430, \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u044F
    \u0434\u0438\u0441\u0431\u0430\u043B\u0430\u043D\u0441. \u0425\u043E\u0442\u044F
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438 \u0442\u0430\u043A\u043E\u0439
    \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u044C \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u043D\u0435 \u043C\u043E\u0433 (\u0438\u0437-\u0437\u0430 \u0442\u0440\u0435\u043D\u0438\u044F),
    \u0441\u0430\u043C **\u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0438\u043D\u0435\u0440\u0446\u0438\u0438
    \u0438 \u043C\u043E\u043C\u0435\u043D\u0442\u0430 \u0441\u0438\u043B\u044B**
    \u0431\u044B\u043B \u043F\u0440\u043E\u0430\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D
    \u0438\u043C \u043D\u0430 \u0443\u0440\u043E\u0432\u043D\u0435, \u043D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u043C
    \u0435\u0433\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430\u043C. 
    ---  ### \u0420\u0435\u0437\u044E\u043C\u0435: \u041C\u0435\u0441\u0442\u043E
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043D\u0430\u0443\u043A\u0438 
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 II \u2014 \u044D\u0442\u043E
    \u043C\u043E\u0441\u0442 \u043C\u0435\u0436\u0434\u0443 \u0434\u0440\u0435\u0432\u043D\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u043D\u043E\u0432\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u0443\u043D\u0438\u043A\u0430\u043B\u0435\u043D
    \u0442\u0435\u043C, \u0447\u0442\u043E \u043E\u043D **\u0434\u043E\u043A\u0430\u0437\u0430\u043B**
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0442\u0435\u043E\u0440\u0435\u043C\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u043E \u043D\u0435\u0433\u043E
    \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u0441\u0442\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B\u0438\u0441\u044C.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0447\u0435\u0440\u0435\u0437 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u044B
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442 \u043D\u0430 \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0439
    (\u0430 \u0437\u0430\u0442\u0435\u043C \u0438 \u043D\u0430 \u043B\u0430\u0442\u044B\u043D\u044C)
    \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0435 \u0443\u0447\u0435\u043D\u044B\u0435
    \u044D\u043F\u043E\u0445\u0438 \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0438\u0441\u044C
    \u0441 \u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439
    \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u043E\u0439. 
    \u0415\u0441\u043B\u0438 \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0442\u044C
    \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u043E, \u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0435
    \u0432\u0435\u043B\u0438\u043A\u043E\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u2014 \u044D\u0442\u043E **\u0438\u043D\u0442\u0435\u0433\u0440\u0430\u0446\u0438\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438**.
    \u041E\u043D \u0440\u0435\u0448\u0430\u043B \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u043E\u0439
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0414\u0435\u043A\u0430\u0440\u0442\u0430,
    \u043D\u043E \u043D\u0430 \u0448\u0435\u0441\u0442\u044C \u0432\u0435\u043A\u043E\u0432
    \u0440\u0430\u043D\u044C\u0448\u0435."
  achievementsEn: 
  personalLifeRu: "\u0414\u0435\u0442\u0430\u043B\u0438 \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u044B
    II, \u043A\u0430\u043A \u044D\u0442\u043E \u0447\u0430\u0441\u0442\u043E \u0431\u044B\u0432\u0430\u0435\u0442
    \u0441 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0444\u0438\u0433\u0443\u0440\u0430\u043C\u0438 \u0442\u043E\u0439 \u044D\u043F\u043E\u0445\u0438,
    \u043E\u043A\u0443\u0442\u0430\u043D\u044B \u043F\u0435\u043B\u0435\u043D\u043E\u0439
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0438 \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u044B
    \u0441 \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u043C\u0438. \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u0440\u0430\u0441\u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0442 \u043B\u0438\u0448\u044C
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u043C\u0438 \u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u044B\u043C\u0438
    \u0444\u0430\u043A\u0442\u0430\u043C\u0438, \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C
    \u043F\u043E\u0447\u0435\u0440\u043F\u043D\u0443\u0442\u044B\u043C\u0438 \u0438\u0437
    \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432 \u0438 \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u0445
    \u043D\u0430\u0434\u043F\u0438\u0441\u0435\u0439, \u0430 \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0432\u043E\u0441\u043F\u043E\u043B\u043D\u044F\u044E\u0442 \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0435
    \u043F\u0440\u0435\u0434\u0430\u043D\u0438\u044F.  \u0412\u043E\u0442 \u0447\u0442\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043E \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438, \u0440\u0430\u0437\u0434\u0435\u043B\u044F\u044F
    \u0444\u0430\u043A\u0442\u044B \u0438 \u043B\u0435\u0433\u0435\u043D\u0434\u044B. 
    ### \U0001F4DC \u0414\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B: \u0441\u0435\u043C\u044C\u044F, \u0434\u0438\u043D\u0430\u0441\u0442\u0438\u044F
    \u0438 \u0443\u0447\u0435\u043D\u0438\u043A\u0438  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0441\u043A\u0443\u0434\u043D\u043E\u0441\u0442\u044C \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u0439,
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u0435\u0442\u0430\u043B\u0438
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u044B
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E: 
    *   **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u043E\u0442\u0435\u0446:** \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0432 1114 \u0433\u043E\u0434\u0443.
    \u041E\u043D \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B \u0438\u0437
    \u0441\u0435\u043C\u044C\u0438 **\u0434\u0435\u0448\u0430\u0441\u0442\u0445\u0430-\u0431\u0440\u0430\u0445\u043C\u0430\u043D\u043E\u0432**
    (\u044D\u0442\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0433\u0440\u0443\u043F\u043F\u0430
    \u0431\u0440\u0430\u0445\u043C\u0430\u043D\u043E\u0432 \u0432 \u0418\u043D\u0434\u0438\u0438).
    \u0415\u0433\u043E \u043E\u0442\u0446\u0430 \u0437\u0432\u0430\u043B\u0438 **\u041C\u0430\u0445\u0435\u0448\u0432\u0430\u0440\u0430**
    (\u0438\u043B\u0438 \u041C\u0430\u0445\u0430\u0434\u0435\u0432\u0430). \u041E\u043D
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0442\u0446\u043E\u043C,
    \u0430 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C \u0438 \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0438 \u0441\u0442\u0430\u043B \u043F\u0435\u0440\u0432\u044B\u043C
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u044B.
    *   **\u0414\u0438\u043D\u0430\u0441\u0442\u0438\u044F \u0443\u0447\u0435\u043D\u044B\u0445:**
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u043D\u0430\u043D\u0438\u044F \u0432 \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u0435
    \u0431\u044B\u043B\u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0434\u0435\u043B\u043E\u043C. \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u0447\u0442\u043E \u0435\u0433\u043E \u043F\u0440\u0430\u043F\u0440\u0430\u043F\u0440\u0430\u0434\u0435\u0434
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B \u043F\u043E\u0442\u043E\u043C\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E. \u042D\u0442\u0443 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u044E
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B,
    \u043F\u0435\u0440\u0435\u0434\u0430\u0432 \u0437\u043D\u0430\u043D\u0438\u044F
    \u0441\u0432\u043E\u0435\u043C\u0443 \u0441\u044B\u043D\u0443 \u043F\u043E \u0438\u043C\u0435\u043D\u0438
    **\u041B\u043E\u043A\u0448\u0430\u043C\u0443\u0434\u0440\u0430** (Lokasamudra).
    *   **\u0412\u043D\u0443\u043A \u0438 \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0448\u043A\u043E\u043B\u0430:** \u0415\u0433\u043E \u0432\u043D\u0443\u043A,
    **\u0427\u0430\u043D\u0433\u0430\u0434\u0435\u0432\u0430** (Changadeva), \u0442\u0430\u043A\u0436\u0435
    \u043F\u043E\u0448\u0435\u043B \u043F\u043E \u0441\u0442\u043E\u043F\u0430\u043C
    \u043F\u0440\u0435\u0434\u043A\u043E\u0432 \u0438 \u0441\u0442\u0430\u043B \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C
    \u043F\u0440\u0438 \u0434\u0432\u043E\u0440\u0435 \u0446\u0430\u0440\u044F \u0421\u0438\u043D\u0433\u0445\u0430\u043D\u044B
    \u0438\u0437 \u0434\u0438\u043D\u0430\u0441\u0442\u0438\u0438 \u042F\u0434\u0430\u0432\u0430.
    \u0412 1207 \u0433\u043E\u0434\u0443 (\u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u044B)
    \u0427\u0430\u043D\u0433\u0430\u0434\u0435\u0432\u0430 \u043F\u043E\u043C\u043E\u0433
    \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u044C \u0448\u043A\u043E\u043B\u0443
    \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u041F\u0430\u0442\u0430\u043D \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u0434\u043B\u044F \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F \u0442\u0440\u0443\u0434\u043E\u0432
    \u0441\u0432\u043E\u0435\u0433\u043E \u0434\u0435\u0434\u0430, \u0447\u0442\u043E
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043E \u0432\u044B\u0441\u043E\u043A\u043E\u043C
    \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0438 \u043A \u0435\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044E
    \u0432\u043D\u0443\u0442\u0440\u0438 \u0441\u0435\u043C\u044C\u0438. *   **\u0421\u043C\u0435\u0440\u0442\u044C:**
    \u041E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 1185
    \u0433\u043E\u0434\u0443 \u0432 \u0423\u0434\u0434\u0436\u0430\u0439\u043D\u0435,
    \u0433\u0434\u0435 \u0438 \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u043B\u044F\u043B
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u044E.  ###
    \u2764\uFE0F \u041B\u0435\u0433\u0435\u043D\u0434\u0430 \u043E \u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438:
    \xAB\u041F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u0430\u044F\xBB \u0434\u043E\u0447\u044C 
    \u0421\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0438 \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u043D\u0430\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0438\u0437 \u0436\u0438\u0437\u043D\u0438 \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u044B
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441 \u0435\u0433\u043E \u0434\u043E\u0447\u0435\u0440\u044C\u044E
    \u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438, \u0432 \u0447\u0435\u0441\u0442\u044C
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B
    \u0441\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0442\u0440\u0443\u0434 \u043F\u043E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0435.
    \u041D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \xAB\u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438\xBB
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0438\u0442\u0441\u044F \u043A\u0430\u043A
    \xAB\u041F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u0430\u044F\xBB \u0438\u043B\u0438
    \xAB\u0418\u0433\u0440\u0438\u0432\u0430\u044F\xBB.  \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432
    \u044D\u0442\u043E\u0439 \u043B\u0435\u0433\u0435\u043D\u0434\u044B, \u043D\u043E
    \u0441\u0443\u0442\u044C \u0438\u0445 \u0435\u0434\u0438\u043D\u0430:  *   **\u0422\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0431\u0440\u0430\u043A:** \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u043E\u043C,
    \u0438\u0437\u0443\u0447\u0438\u043B \u0433\u043E\u0440\u043E\u0441\u043A\u043E\u043F
    \u0441\u0432\u043E\u0435\u0439 \u0434\u043E\u0447\u0435\u0440\u0438 \u0438 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043E\u043D\u0430 \u043E\u0432\u0434\u043E\u0432\u0435\u0435\u0442
    \u0432\u0441\u043A\u043E\u0440\u0435 \u043F\u043E\u0441\u043B\u0435 \u0437\u0430\u043C\u0443\u0436\u0435\u0441\u0442\u0432\u0430,
    \u0435\u0441\u043B\u0438 \u0441\u0432\u0430\u0434\u044C\u0431\u0430 \u0441\u043E\u0441\u0442\u043E\u0438\u0442\u0441\u044F
    \u043D\u0435 \u0432 \u0441\u0442\u0440\u043E\u0433\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0439,
    \u0431\u043B\u0430\u0433\u043E\u043F\u0440\u0438\u044F\u0442\u043D\u044B\u0439
    \u0447\u0430\u0441. *   **\u0420\u043E\u043A\u043E\u0432\u0430\u044F \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0441\u0442\u044C:**
    \u0427\u0442\u043E\u0431\u044B \u0441\u043F\u0430\u0441\u0442\u0438 \u0434\u043E\u0447\u044C,
    \u043E\u043D \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u0432\u043E\u0434\u044F\u043D\u044B\u0435
    \u0447\u0430\u0441\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u043E\u043B\u0436\u043D\u044B
    \u0431\u044B\u043B\u0438 \u0442\u043E\u0447\u043D\u043E \u043E\u0442\u043C\u0435\u0440\u0438\u0442\u044C
    \u044D\u0442\u043E\u0442 \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u0439
    \u043C\u043E\u043C\u0435\u043D\u0442. \u041E\u043D \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B
    \u043F\u0440\u0438\u0431\u043E\u0440 \u0432 \u043A\u043E\u043C\u043D\u0430\u0442\u0435
    \u0438 \u0441\u0442\u0440\u043E\u0433\u043E \u043D\u0430\u043A\u0430\u0437\u0430\u043B
    \u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438 \u043D\u0435 \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0442\u044C
    \u043A \u043D\u0435\u043C\u0443. \u041E\u0434\u043D\u0430\u043A\u043E \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u0441\u0442\u0432\u043E
    \u0432\u0437\u044F\u043B\u043E \u0432\u0435\u0440\u0445: \u0434\u0435\u0432\u0443\u0448\u043A\u0430
    \u043F\u043E\u0434\u043E\u0448\u043B\u0430 \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
    \u043D\u0430 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C, \u0438 \u0432
    \u044D\u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442 \u0436\u0435\u043C\u0447\u0443\u0436\u0438\u043D\u0430
    \u0438\u0437 \u0435\u0451 \u043D\u043E\u0441\u043E\u0432\u043E\u0433\u043E \u043A\u043E\u043B\u044C\u0446\u0430
    \u0443\u043F\u0430\u043B\u0430 \u0432 \u0432\u043E\u0434\u0443 \u0438 \u0437\u0430\u043A\u0443\u043F\u043E\u0440\u0438\u043B\u0430
    \u0441\u043B\u0438\u0432\u043D\u043E\u0435 \u043E\u0442\u0432\u0435\u0440\u0441\u0442\u0438\u0435,
    \u043D\u0430\u0440\u0443\u0448\u0438\u0432 \u0445\u043E\u0434 \u0447\u0430\u0441\u043E\u0432.
    *   **\u0423\u0442\u0435\u0448\u0435\u043D\u0438\u0435 \u0432 \u043D\u0430\u0443\u043A\u0435:**
    \u0412\u0440\u0435\u043C\u044F \u0431\u044B\u043B\u043E \u0443\u043F\u0443\u0449\u0435\u043D\u043E,
    \u0441\u0432\u0430\u0434\u044C\u0431\u0430 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0430\u0441\u044C
    \u0432 \u043D\u0435\u0431\u043B\u0430\u0433\u043E\u043F\u0440\u0438\u044F\u0442\u043D\u044B\u0439
    \u0447\u0430\u0441, \u0438 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u0435
    \u0441\u0431\u044B\u043B\u043E\u0441\u044C: \u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438
    \u0441\u0442\u0430\u043B\u0430 \u0432\u0434\u043E\u0432\u043E\u0439. \u0427\u0442\u043E\u0431\u044B
    \u0443\u0442\u0435\u0448\u0438\u0442\u044C \u0434\u043E\u0447\u044C \u0432 \u0435\u0435
    \u0433\u043E\u0440\u0435 (\u0430 \u0432\u0434\u043E\u0432\u0430 \u0432 \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u043E\u043C
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435 \u043D\u0435 \u043C\u043E\u0433\u043B\u0430
    \u0431\u043E\u043B\u044C\u0448\u0435 \u0432\u044B\u0439\u0442\u0438 \u0437\u0430\u043C\u0443\u0436),
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0434\u043B\u044F \u043D\u0435\u0451 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442, \u043D\u0430\u043F\u043E\u043B\u043D\u0438\u0432
    \u0435\u0433\u043E \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0437\u0430\u0434\u0430\u0447\u0430\u043C\u0438 \u0438 \u0441\u0442\u0438\u0445\u0430\u043C\u0438.
    \u0422\u0430\u043A \u0438\u043C\u044F \u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438
    \u0441\u0442\u0430\u043B\u043E \u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u043C. 
    \u0412\u0430\u0436\u043D\u043E \u043E\u0442\u043C\u0435\u0442\u0438\u0442\u044C,
    \u0447\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F
    \u043A \u044D\u0442\u043E\u0439 \u043B\u0435\u0433\u0435\u043D\u0434\u0435 \u0441
    \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E\u0441\u0442\u044C\u044E.
    \u041F\u043E \u043C\u043D\u0435\u043D\u0438\u044E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439,
    \u043D\u0435\u0442 \u0443\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438
    \u0431\u044B\u043B\u0430 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0439 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0433\u0443\u0440\u043E\u0439, \u0430 \u043D\u0435 \u0432\u044B\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u044B\u043C
    \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435\u043C \u0438\u043B\u0438
    \u0434\u0430\u0436\u0435 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u044B\u043C
    \u043F\u0440\u0438\u0435\u043C\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B,
    \u0447\u0442\u043E\u0431\u044B \u0441\u0434\u0435\u043B\u0430\u0442\u044C \u0441\u0432\u043E\u0439
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0431\u043E\u043B\u0435\u0435 \u0436\u0438\u0432\u044B\u043C \u0438 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u043C.
    \u0421\u0430\u043C\u0430 \u043B\u0435\u0433\u0435\u043D\u0434\u0430 \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0435\u0442\u0441\u044F \u0432 \u043F\u0435\u0440\u0441\u0438\u0434\u0441\u043A\u043E\u043C
    \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0438 \u043A \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0435, \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u044C, \u0447\u0442\u043E
    \u043E\u043D\u0430 \u043C\u043E\u0433\u043B\u0430 \u0431\u044B\u0442\u044C \u0431\u043E\u043B\u0435\u0435
    \u043F\u043E\u0437\u0434\u043D\u0438\u043C \u0434\u043E\u0431\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C. 
    \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u044B
    II \u0434\u043B\u044F \u043D\u0430\u0441 \u2014 \u044D\u0442\u043E, \u0441 \u043E\u0434\u043D\u043E\u0439
    \u0441\u0442\u043E\u0440\u043E\u043D\u044B, \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u043D\u0430\u044F
    \u0446\u0435\u043F\u043E\u0447\u043A\u0430 \u0443\u0447\u0435\u043D\u044B\u0445-\u0431\u0440\u0430\u0445\u043C\u0430\u043D\u043E\u0432,
    \u0430 \u0441 \u0434\u0440\u0443\u0433\u043E\u0439 \u2014 \u043A\u0440\u0430\u0441\u0438\u0432\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E\u0431 \u043E\u0442\u0446\u043E\u0432\u0441\u043A\u043E\u0439
    \u043B\u044E\u0431\u0432\u0438, \u0441\u0442\u0430\u0432\u0448\u0430\u044F \u043D\u0435\u043E\u0442\u044A\u0435\u043C\u043B\u0435\u043C\u043E\u0439
    \u0447\u0430\u0441\u0442\u044C\u044E \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u044F."
  personalLifeEn: 
  shortBioRu: "\u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 II (\u0442\u0430\u043A\u0436\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043A\u0430\u043A \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430
    \u0410\u0447\u0430\u0440\u044C\u044F, \u0447\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442
    \xAB\u0443\u0447\u0438\u0442\u0435\u043B\u044C \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430\xBB)
    \u2014 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0439 \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C
    XII \u0432\u0435\u043A\u0430, \u0447\u044C\u0438 \u0442\u0440\u0443\u0434\u044B
    \u043D\u0430\u043C\u043D\u043E\u0433\u043E \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438
    \u0441\u0432\u043E\u0451 \u0432\u0440\u0435\u043C\u044F. \u041E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 1114 \u0433\u043E\u0434\u0443 \u0438 \u0443\u043C\u0435\u0440 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0432 1185 \u0433\u043E\u0434\u0443.  ### \U0001F9EC \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0439 \u043F\u0443\u0442\u044C 
    \u041E \u0436\u0438\u0437\u043D\u0438 \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u044B
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C \u043D\u0435\u043C\u043D\u043E\u0433\u043E
    \u0444\u0430\u043A\u0442\u043E\u0432, \u043E\u0434\u043D\u0430\u043A\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u0447\u0442\u043E \u043E\u043D \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B
    \u0438\u0437 \u0441\u0435\u043C\u044C\u0438 \u0431\u0440\u0430\u0445\u043C\u0430\u043D\u043E\u0432.
    \u0415\u0433\u043E \u043E\u0442\u0446\u0430 \u0437\u0432\u0430\u043B\u0438 \u041C\u0430\u0445\u0435\u0448\u0432\u0430\u0440\u0430,
    \u0438 \u043E\u043D \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u043E\u043C. \u0421\u0430\u043C
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u043C\u0435\u0441\u0442\u0435\u0447\u043A\u0435 \u0411\u0438\u0434\u0436\u0443\u0434\u0430-\u0411\u0438\u0434\u0430
    (\u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439 \u0411\u0438\u0434\u0436\u0430\u043F\u0443\u0440
    \u0432 \u0448\u0442\u0430\u0442\u0435 \u041A\u0430\u0440\u043D\u0430\u0442\u0430\u043A\u0430),
    \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043D\u043E\u043C
    \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E \u043E\u0442 \u0433\u043E\u0440
    \u0421\u0430\u0445\u0438\u0430\u0434\u0440\u0438.  \u0413\u043B\u0430\u0432\u043D\u044B\u043C
    \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u0435\u0433\u043E \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0441\u0442\u0430\u043B \u0433\u043E\u0440\u043E\u0434 \u0423\u0434\u0434\u0436\u0430\u0439\u043D
    \u2014 \u0432\u0435\u0434\u0443\u0449\u0438\u0439 \u0446\u0435\u043D\u0442\u0440
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438 \u0434\u0440\u0435\u0432\u043D\u0435\u0439 \u0418\u043D\u0434\u0438\u0438.
    \u0422\u0430\u043C \u043E\u043D \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u043B\u044F\u043B
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u044E, \u0441\u0442\u0430\u0432
    \u043F\u0440\u0435\u0435\u043C\u043D\u0438\u043A\u043E\u043C \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B.
    \u0415\u0433\u043E \u0441\u043B\u0430\u0432\u0430 \u0431\u044B\u043B\u0430 \u0441\u0442\u043E\u043B\u044C
    \u0432\u0435\u043B\u0438\u043A\u0430, \u0447\u0442\u043E \u0432 XIII \u0432\u0435\u043A\u0435
    \u0435\u0433\u043E \u0432\u043D\u0443\u043A, \u0427\u0430\u043D\u0433\u0430\u0434\u0435\u0432\u0430,
    \u0431\u044B\u043B \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C
    \u043F\u0440\u0438 \u0434\u0432\u043E\u0440\u0435 \u0446\u0430\u0440\u044F \u0421\u0438\u043D\u0433\u0430\u0445\u0430\u043D\u044B
    \u0438\u0437 \u0434\u0438\u043D\u0430\u0441\u0442\u0438\u0438 \u042F\u0434\u0430\u0432\u0430,
    \u0430 \u0434\u043B\u044F \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F \u0442\u0440\u0443\u0434\u043E\u0432
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u044B \u0431\u044B\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u044B
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u0448\u043A\u043E\u043B\u044B. 
    ### \U0001F48E \u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434:
    \xAB\u0421\u0438\u0434\u0434\u0445\u0430\u043D\u0442\u0430-\u0448\u0438\u0440\u043E\u043C\u0430\u043D\u0438\xBB 
    \u0412 1150 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    36 \u043B\u0435\u0442, \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B
    \u0441\u0432\u043E\u0439 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \xAB\u0421\u0438\u0434\u0434\u0445\u0430\u043D\u0442\u0430-\u0448\u0438\u0440\u043E\u043C\u0430\u043D\u0438\xBB
    (\xAB\u0412\u0435\u043D\u0435\u0446 \u0443\u0447\u0435\u043D\u0438\u044F\xBB).
    \u042D\u0442\u043E \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0441\u043E\u0441\u0442\u043E\u0438\u0442
    \u0438\u0437 \u0447\u0435\u0442\u044B\u0440\u0451\u0445 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0447\u0430\u0441\u0442\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u043E\u0437\u0434\u043D\u0435\u0435 \u0441\u0442\u0430\u043B\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u043C\u0438
    \u043A\u043D\u0438\u0433\u0430\u043C\u0438:  1.  **\xAB\u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438\xBB
    (\xAB\u041F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u0430\u044F\xBB)** \u2014
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442 \u043F\u043E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0435
    \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. 2.  **\xAB\u0411\u0438\u0434\u0436\u0430\u0433\u0430\u043D\u0438\u0442\u0430\xBB
    (\xAB\u0421\u0447\u0435\u0442 \u0441\u0435\u043C\u044F\u043D\xBB \u0438\u043B\u0438
    \xAB\u0418\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435 \u043A\u043E\u0440\u043D\u0435\u0439\xBB)**
    \u2014 \u0442\u0440\u0443\u0434 \u043F\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0435.
    3.  **\xAB\u0413\u043E\u043B\u0430\u0434\u0445\u0430\u0439\u044F\xBB (\xAB\u0421\u0444\u0435\u0440\u0430\xBB)**
    \u2014 \u0440\u0430\u0437\u0434\u0435\u043B, \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u044B\u0439
    \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0438 \u043D\u0435\u0431\u0435\u0441\u043D\u043E\u0439 \u0441\u0444\u0435\u0440\u0435.
    4.  **\xAB\u0413\u0440\u0430\u043D\u0445\u0430\u0433\u0430\u043D\u0438\u0442\u0430\xBB
    (\xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u043F\u043B\u0430\u043D\u0435\u0442\xBB)**
    \u2014 \u0447\u0430\u0441\u0442\u044C, \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0449\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442.  ### \U0001F522 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F, \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0438\u0435
    \u0432\u0440\u0435\u043C\u044F  \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u044B
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0442 \u0438\u0434\u0435\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u0431\u044B\u043B\u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u044B
    \u043B\u0438\u0448\u044C \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F \u0441\u043F\u0443\u0441\u0442\u044F. 
    **- \u0410\u043B\u0433\u0435\u0431\u0440\u0430 \u0438 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439:** \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u0432 \u043C\u0438\u0440\u0435 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043E\u0441\u043E\u0437\u043D\u0430\u043B, \u0447\u0442\u043E \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u043E\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \u043C\u043E\u0436\u0435\u0442
    \u0438\u043C\u0435\u0442\u044C \u0434\u0432\u0430 \u043A\u043E\u0440\u043D\u044F,
    \u0438, \u0445\u043E\u0442\u044F \u0438 \u0441 \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u0435\u043C,
    \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043A\u043E\u0440\u043D\u0435\u0439. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u0431\u0443\u043A\u0432\u044B
    \u0434\u043B\u044F \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u0432\u0435\u043B\u0438\u0447\u0438\u043D,
    \u0447\u0442\u043E \u043E\u0447\u0435\u043D\u044C \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043D\u043E\u0442\u0430\u0446\u0438\u044E.  **- \u0420\u0430\u0431\u043E\u0442\u0430
    \u0441 \u043D\u0443\u043B\u0435\u043C \u0438 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C\u044E:**
    \u041E\u043D \u043F\u0440\u043E\u0434\u0432\u0438\u043D\u0443\u043B\u0441\u044F
    \u0432 \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0438 \u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043D\u0430 \u043D\u043E\u043B\u044C, \u0437\u0430\u044F\u0432\u0438\u0432,
    \u0447\u0442\u043E \u0447\u0438\u0441\u043B\u043E, \u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0435
    \u043D\u0430 \u043D\u043E\u043B\u044C, \u0434\u0430\u0435\u0442 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C
    (`a/0 = \u221E`). \u042D\u0442\u043E \u0431\u044B\u043B \u0432\u0430\u0436\u043D\u044B\u0439
    \u0448\u0430\u0433 \u0432\u043F\u0435\u0440\u0435\u0434 \u043F\u043E \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044E
    \u0441 \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438,
    \u0445\u043E\u0442\u044F \u0435\u0433\u043E \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0435
    \u0432\u0441\u0451 \u0435\u0449\u0435 \u0431\u044B\u043B\u043E \u043D\u0435\u043F\u043E\u043B\u043D\u044B\u043C
    (\u043E\u043D, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E
    \u043F\u043E\u043B\u0430\u0433\u0430\u043B, \u0447\u0442\u043E `a/0 * 0 = a`). 
    **- \u041D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F:** \u0412\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u044B
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0442\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u043E\u0433\u043E
    **\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u041F\u0435\u043B\u043B\u044F**
    (`x\xB2 = 1 + py\xB2`). \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0434\u043B\u044F
    \u044D\u0442\u043E\u0433\u043E \u0446\u0438\u043A\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0435\u0442\u043E\u0434 \xAB\u0447\u0430\u043A\u0440\u0430\u0432\u0430\u043B\u0430\xBB,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043C\u0435\u0442\u043E\u0434\u043E\u0432 \u0435\u0433\u043E \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432.
    \u0412\u043F\u0435\u0447\u0430\u0442\u043B\u044F\u0435\u0442, \u0447\u0442\u043E
    \u043E\u043D \u043D\u0430\u0448\u0435\u043B \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0435
    \u0446\u0435\u043B\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0434\u043B\u044F \u0442\u0430\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439, \u043A\u0430\u043A `x\xB2
    = 1 + 61y\xB2` (`x = 1,766,319,049`, `y = 226,153,980`). \u042D\u0442\u0430 \u0437\u0430\u0434\u0430\u0447\u0430
    \u0431\u044B\u043B\u0430 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0430
    \u043A\u0430\u043A \u0432\u044B\u0437\u043E\u0432 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C \u041F\u044C\u0435\u0440\u043E\u043C
    \u0424\u0435\u0440\u043C\u0430 \u043B\u0438\u0448\u044C \u0432 1657 \u0433\u043E\u0434\u0443! 
    **- \u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u0438 \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u044F:**
    \u0412 \xAB\u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438\xBB \u043E\u043D
    \u0434\u0430\u0435\u0442 \u0434\u0432\u0430 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u041F\u0438\u0444\u0430\u0433\u043E\u0440\u0430
    \u0438 \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u0435\u0442 \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0447\u0438\u0441\u043B\u0430
    \u03C0, \u0440\u0430\u0432\u043D\u043E\u0435 3,141666. \u0412 \u0441\u0432\u043E\u0438\u0445
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442\u0430\u0445 \u043E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B,
    \u0431\u043B\u0438\u0437\u043A\u0438\u0435 \u043A \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E, \u0438, \u043F\u043E
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0434\u0430\u043D\u043D\u044B\u043C,
    \u0431\u044B\u043B \u0437\u043D\u0430\u043A\u043E\u043C \u0441 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430\u043C\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u0437\u0436\u0435 \u043B\u0435\u0433\u043B\u0438
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430.  **- \u0418\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0439
    \u0433\u0435\u043D\u0438\u0439:** \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0435
    \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0440\u0430\u043D\u043D\u0438\u0445
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u043F\u0440\u043E\u0435\u043A\u0442\u043E\u0432
    **\u0432\u0435\u0447\u043D\u043E\u0433\u043E \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u044F**
    (\u043F\u0435\u0440\u043F\u0435\u0442\u0443\u0443\u043C \u043C\u043E\u0431\u0438\u043B\u0435).
    \u0412 \u0435\u0433\u043E \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0438 \u0444\u0438\u0433\u0443\u0440\u0438\u0440\u0443\u0435\u0442
    \u043A\u043E\u043B\u0435\u0441\u043E \u0441 \u0441\u043E\u0441\u0443\u0434\u0430\u043C\u0438,
    \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E \u0437\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u044B\u043C\u0438
    \u0440\u0442\u0443\u0442\u044C\u044E, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0434\u043E\u043B\u0436\u043D\u043E \u0431\u044B\u043B\u043E \u0432\u0440\u0430\u0449\u0430\u0442\u044C\u0441\u044F
    \u0432\u0435\u0447\u043D\u043E \u0438\u0437-\u0437\u0430 \u043F\u0435\u0440\u0435\u0442\u0435\u043A\u0430\u043D\u0438\u044F
    \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0438.  ### \U0001F4D6 \u041B\u0435\u0433\u0435\u043D\u0434\u0430
    \u043E \xAB\u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438\xBB  \u0421 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435\u043C
    \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E \u0442\u0440\u0443\u0434\u0430
    \u043F\u043E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0435 \u0441\u0432\u044F\u0437\u0430\u043D\u0430
    \u043A\u0440\u0430\u0441\u0438\u0432\u0430\u044F \u043B\u0435\u0433\u0435\u043D\u0434\u0430.
    \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u0435\u0439, \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430
    \u043D\u0430\u0437\u0432\u0430\u043B \u043A\u043D\u0438\u0433\u0443 \u0432 \u0447\u0435\u0441\u0442\u044C
    \u0441\u0432\u043E\u0435\u0439 \u0434\u043E\u0447\u0435\u0440\u0438 \u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438,
    \u0447\u0442\u043E\u0431\u044B \u0443\u0442\u0435\u0448\u0438\u0442\u044C \u0435\u0435.
    \u041E\u043D \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B \u0431\u043B\u0430\u0433\u043E\u043F\u0440\u0438\u044F\u0442\u043D\u044B\u0439
    \u0447\u0430\u0441 \u0434\u043B\u044F \u0435\u0435 \u0441\u0432\u0430\u0434\u044C\u0431\u044B
    \u0438 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0432\u043E\u0434\u044F\u043D\u044B\u0445
    \u0447\u0430\u0441\u043E\u0432 \u0445\u043E\u0442\u0435\u043B \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C
    \u0442\u043E\u0447\u043D\u044B\u0439 \u043C\u043E\u043C\u0435\u043D\u0442. \u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438,
    \u0438\u0437 \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u0441\u0442\u0432\u0430
    \u0437\u0430\u0433\u043B\u044F\u043D\u0443\u0432 \u0432 \u0441\u043E\u0441\u0443\u0434
    \u0441 \u0447\u0430\u0441\u0430\u043C\u0438, \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E
    \u0443\u0440\u043E\u043D\u0438\u043B\u0430 \u0432 \u043D\u0435\u0433\u043E \u0436\u0435\u043C\u0447\u0443\u0436\u0438\u043D\u0443
    \u0441\u043E \u0441\u0432\u043E\u0435\u0439 \u043E\u0434\u0435\u0436\u0434\u044B,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0437\u0430\u043A\u0443\u043F\u043E\u0440\u0438\u043B\u0430
    \u043E\u0442\u0432\u0435\u0440\u0441\u0442\u0438\u0435. \u0421\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u0439
    \u0447\u0430\u0441 \u0431\u044B\u043B \u0443\u043F\u0443\u0449\u0435\u043D, \u0438,
    \u0447\u0442\u043E\u0431\u044B \u0443\u0442\u0435\u0448\u0438\u0442\u044C \u0434\u043E\u0447\u044C,
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0434\u043B\u044F \u043D\u0435\u0435 \u043A\u043D\u0438\u0433\u0443 \u043F\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u0440\u043E\u0441\u043B\u0430\u0432\u0438\u043B\u0430 \u0438\u0445 \u043E\u0431\u043E\u0438\u0445
    \u043D\u0430 \u0432\u0435\u043A\u0430. \u0414\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E\u0441\u0442\u044C
    \u044D\u0442\u043E\u0439 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043D\u0435
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0430, \u043D\u043E
    \u043E\u043D\u0430 \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435 \u043A \u043D\u0430\u0443\u043A\u0435
    \u0432 \u0442\u0443 \u044D\u043F\u043E\u0445\u0443.  \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u044B II \u0441\u0442\u0430\u043B\u043E
    \u0432\u0435\u0440\u0448\u0438\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438 \u0441\u0440\u0435\u0434\u043D\u0435\u0432\u0435\u043A\u043E\u0432\u043E\u0439
    \u0418\u043D\u0434\u0438\u0438, \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u044B
    \u043D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0439
    \u0441\u043B\u0443\u0436\u0438\u043B\u0438 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0430\u043C\u0438
    \u0438 \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u043D\u0430\u0443\u043A\u0438 \u043A\u0430\u043A \u0432 \u0410\u0437\u0438\u0438,
    \u0442\u0430\u043A \u0438 \u0432 \u0415\u0432\u0440\u043E\u043F\u0435."
  shortBioEn: 
  interestingFactsRu: "\u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 II, \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E,
    \u0431\u044B\u043B \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0447\u0451\u043D\u044B\u043C, \u043D\u043E \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0442\u0440\u0443\u0434\u044B \u043E\u043A\u0443\u0442\u0430\u043D\u044B
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E\u043C \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u0439.
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u0435\u0433\u043E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043A\u0430\u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430, \u043D\u043E \u0438
    \u043A\u0430\u043A \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430, \u043F\u043E\u044D\u0442\u0430
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u044F.  ### \u2699\uFE0F \u041A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u043E\u0440
    \u0432\u0435\u0447\u043D\u043E\u0433\u043E \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u044F
    \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0441\u0430\u043C\u044B\u0439
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u0444\u0430\u043A\u0442:
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u2014 \u0430\u0432\u0442\u043E\u0440
    **\u043E\u0434\u043D\u043E\u0433\u043E \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043F\u0440\u043E\u0435\u043A\u0442\u043E\u0432
    \u0432\u0435\u0447\u043D\u043E\u0433\u043E \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u044F**
    (\u043F\u0435\u0440\u043F\u0435\u0442\u0443\u0443\u043C \u043C\u043E\u0431\u0438\u043B\u0435).
    \u0412 \u0441\u0432\u043E\u0451\u043C \u0441\u0442\u0438\u0445\u043E\u0442\u0432\u043E\u0440\u0435\u043D\u0438\u0438
    \u043E\u043A\u043E\u043B\u043E 1150 \u0433\u043E\u0434\u0430 \u043E\u043D \u043E\u043F\u0438\u0441\u0430\u043B
    \u043A\u043E\u043B\u0435\u0441\u043E, \u043F\u043E \u043E\u0431\u043E\u0434\u0443
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0431\u044B\u043B\u0438 \u0437\u0430\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u044B
    \u043D\u0430\u043A\u043B\u043E\u043D\u043D\u044B\u0435 \u0441\u043E\u0441\u0443\u0434\u044B,
    \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E \u0437\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u044B\u0435
    \u0440\u0442\u0443\u0442\u044C\u044E. \u0418\u0434\u0435\u044F \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0430\u0441\u044C
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u043F\u0440\u0438 \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438
    \u043A\u043E\u043B\u0435\u0441\u0430 \u0440\u0442\u0443\u0442\u044C \u043F\u0435\u0440\u0435\u0442\u0435\u043A\u0430\u043B\u0430
    \u0431\u044B \u0432 \u0441\u043E\u0441\u0443\u0434\u0430\u0445, \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u044F
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u044B\u0439 \u0434\u0438\u0441\u0431\u0430\u043B\u0430\u043D\u0441
    \u0438 \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u044F \u043A\u043E\u043B\u0435\u0441\u043E
    \u0432\u0440\u0430\u0449\u0430\u0442\u044C\u0441\u044F \u0432\u0435\u0447\u043D\u043E.
    \u0425\u043E\u0442\u044F \u0441 \u0442\u043E\u0447\u043A\u0438 \u0437\u0440\u0435\u043D\u0438\u044F
    \u0444\u0438\u0437\u0438\u043A\u0438 \u044D\u0442\u043E\u0442 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C
    \u043D\u0435 \u043C\u043E\u0433 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0438\u0437-\u0437\u0430 \u0442\u0440\u0435\u043D\u0438\u044F, \u0441\u0430\u043C\u0430
    \u0438\u0434\u0435\u044F \u0438 \u0430\u043D\u0430\u043B\u0438\u0437 \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u0432
    \u0441\u0438\u043B \u0442\u044F\u0436\u0435\u0441\u0442\u0438 \u0434\u043B\u044F
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0431\u044B\u043B\u0438 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u043C\u0438.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0441 \u043A\u043E\u043B\u0435\u0441\u0430
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u044B \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C
    \u043C\u043D\u043E\u0433\u043E\u0432\u0435\u043A\u043E\u0432\u0430\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043F\u043E\u043F\u044B\u0442\u043E\u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F
    \u0432\u0435\u0447\u043D\u043E\u0433\u043E \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u044F,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u043B\u0430
    \u0434\u0430\u0436\u0435 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E \u0434\u0430
    \u0412\u0438\u043D\u0447\u0438.  ### \U0001F48E \u0412\u044B\u0437\u043E\u0432,
    \u0431\u0440\u043E\u0448\u0435\u043D\u043D\u044B\u0439 \u0447\u0435\u0440\u0435\u0437
    500 \u043B\u0435\u0442 \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    **\u0446\u0438\u043A\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u043C\u0435\u0442\u043E\u0434
    \xAB\u0427\u0430\u043A\u0440\u0430\u0432\u0430\u043B\u0430\xBB** (\u0447\u0442\u043E
    \u0432 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0435 \u0441 \u0441\u0430\u043D\u0441\u043A\u0440\u0438\u0442\u0430
    \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442 \xAB\u043A\u043E\u043B\u0435\u0441\u043E\xBB,
    \u043D\u0430\u043C\u0435\u043A\u0430\u044F \u043D\u0430 \u0446\u0438\u043A\u043B\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043F\u0440\u0438\u0440\u043E\u0434\u0443 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0430)
    \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u041F\u0435\u043B\u043B\u044F
    (\\( x^2 = 1 + py^2 \\)).  \u041E\u043D \u043D\u0430\u0448\u0451\u043B \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0435
    \u0446\u0435\u043B\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u043E\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0434\u043B\u044F \u0441\u043B\u0443\u0447\u0430\u044F
    \\( p=61 \\): *   \\( x = 1,766,319,049 \\) *   \\( y = 226,153,980 \\)  **\u0421\u0430\u043C\u043E\u0435
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435:**
    \u0441\u043F\u0443\u0441\u0442\u044F \u043F\u044F\u0442\u044C \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0439,
    \u0432 1657 \u0433\u043E\u0434\u0443, \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u041F\u044C\u0435\u0440
    \u0424\u0435\u0440\u043C\u0430 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0440\u043E\u0432\u043D\u043E \u044D\u0442\u0443 \u0436\u0435 \u0437\u0430\u0434\u0430\u0447\u0443
    (\\( x^2 = 61y^2 + 1 \\)) \u043A\u0430\u043A \u0432\u044B\u0437\u043E\u0432 \u0441\u0432\u043E\u0438\u043C
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C \u0432 \u0415\u0432\u0440\u043E\u043F\u0435.
    \u0415\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0441\u043C\u043E\u0433\u043B\u0438 \u0440\u0435\u0448\u0438\u0442\u044C \u0435\u0451
    \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0435\u0440\u0435\u0437 \u043F\u043E\u043B\u0432\u0435\u043A\u0430,
    \u0438 \u0438\u0445 \u043C\u0435\u0442\u043E\u0434\u044B (\u0446\u0435\u043F\u043D\u044B\u0435
    \u0434\u0440\u043E\u0431\u0438) \u0431\u044B\u043B\u0438 \u0433\u043E\u0440\u0430\u0437\u0434\u043E
    \u0441\u043B\u043E\u0436\u043D\u0435\u0435 \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u043E\u0433\u043E
    \u043C\u0435\u0442\u043E\u0434\u0430 \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u044B.
    \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u0438\u0441\u0442\u043E\u0440\u0438\u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0413\u0435\u0440\u043C\u0430\u043D
    \u0413\u0430\u043D\u043A\u0435\u043B\u044C \u043D\u0430\u0437\u0432\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434 \xAB\u0427\u0430\u043A\u0440\u0430\u0432\u0430\u043B\u0430\xBB
    **\xAB\u043B\u0443\u0447\u0448\u0438\u043C, \u0447\u0442\u043E \u0431\u044B\u043B\u043E
    \u0434\u043E\u0441\u0442\u0438\u0433\u043D\u0443\u0442\u043E \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B \u0434\u043E \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430\xBB**. 
    ### \U0001F4D6 \u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438: \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043A\u0430\u043A \u0443\u0442\u0435\u0448\u0435\u043D\u0438\u0435 \u0421\u0430\u043C\u044B\u0439
    \u0442\u0440\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u0438
    \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u043D\u044B\u0439 \u0444\u0430\u043A\u0442
    \u0441\u0432\u044F\u0437\u0430\u043D \u0441 \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u043C
    \u0442\u0440\u0443\u0434\u043E\u043C \u043F\u043E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0435
    \u2014 **\xAB\u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438\xBB**, \u0447\u0442\u043E
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0438\u0442\u0441\u044F \u043A\u0430\u043A
    \xAB\u041F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u0430\u044F\xBB \u0438\u043B\u0438
    \xAB\u0418\u0433\u0440\u0438\u0432\u0430\u044F\xBB.  \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u043B\u0435\u0433\u0435\u043D\u0434\u0435, \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430
    \u043D\u0430\u0437\u0432\u0430\u043B \u043A\u043D\u0438\u0433\u0443 \u0432 \u0447\u0435\u0441\u0442\u044C
    \u0441\u0432\u043E\u0435\u0439 \u0434\u043E\u0447\u0435\u0440\u0438 \u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438.
    \u041E\u043D \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B, \u0447\u0442\u043E
    \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u0439 \u0447\u0430\u0441
    \u0434\u043B\u044F \u0435\u0451 \u0441\u0432\u0430\u0434\u044C\u0431\u044B \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u0442
    \u0432 \u0441\u0442\u0440\u043E\u0433\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F. \u0427\u0442\u043E\u0431\u044B \u043D\u0435 \u043F\u0440\u043E\u043F\u0443\u0441\u0442\u0438\u0442\u044C
    \u0435\u0433\u043E, \u043E\u043D \u0441\u043C\u0430\u0441\u0442\u0435\u0440\u0438\u043B
    \u0432\u043E\u0434\u044F\u043D\u044B\u0435 \u0447\u0430\u0441\u044B \u2014 \u0447\u0430\u0448\u0443
    \u0441 \u043E\u0442\u0432\u0435\u0440\u0441\u0442\u0438\u0435\u043C, \u043F\u043B\u0430\u0432\u0430\u044E\u0449\u0443\u044E
    \u0432 \u0441\u043E\u0441\u0443\u0434\u0435 \u0441 \u0432\u043E\u0434\u043E\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0434\u043E\u043B\u0436\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0437\u0430\u0442\u043E\u043D\u0443\u0442\u044C \u0432
    \u043D\u0443\u0436\u043D\u044B\u0439 \u043C\u043E\u043C\u0435\u043D\u0442.  \u041D\u043E
    \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u0430\u044F \u043D\u0435\u0432\u0435\u0441\u0442\u0430
    \u043F\u043E\u0434\u043E\u0448\u043B\u0430 \u043A \u043F\u0440\u0438\u0431\u043E\u0440\u0443,
    \u0438 \u0436\u0435\u043C\u0447\u0443\u0436\u0438\u043D\u0430 \u0438\u0437 \u0435\u0451
    \u0443\u043A\u0440\u0430\u0448\u0435\u043D\u0438\u044F \u0443\u043F\u0430\u043B\u0430
    \u0432 \u0432\u043E\u0434\u0443 \u0438 \u0437\u0430\u043A\u0443\u043F\u043E\u0440\u0438\u043B\u0430
    \u043E\u0442\u0432\u0435\u0440\u0441\u0442\u0438\u0435. \u0411\u043B\u0430\u0433\u043E\u043F\u0440\u0438\u044F\u0442\u043D\u044B\u0439
    \u0447\u0430\u0441 \u0431\u044B\u043B \u0443\u043F\u0443\u0449\u0435\u043D, \u0438
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u0435 \u0441\u0431\u044B\u043B\u043E\u0441\u044C
    \u2014 \u043E\u043D\u0430 \u043D\u0435 \u0441\u043C\u043E\u0433\u043B\u0430 \u0432\u044B\u0439\u0442\u0438
    \u0437\u0430\u043C\u0443\u0436 \u0438\u043B\u0438 \u0441\u0442\u0430\u043B\u0430
    \u0432\u0434\u043E\u0432\u043E\u0439. \u0427\u0442\u043E\u0431\u044B \u0443\u0442\u0435\u0448\u0438\u0442\u044C
    \u0434\u043E\u0447\u044C, \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u0438
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0434\u043B\u044F \u043D\u0435\u0451
    \u043A\u043D\u0438\u0433\u0443 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u043D\u0430\u0432\u0435\u043A\u0438 \u043E\u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u0438\u0432
    \u0435\u0451 \u0438\u043C\u044F.  **\u0412\u0430\u0436\u043D\u043E \u043E\u0442\u043C\u0435\u0442\u0438\u0442\u044C:**
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F
    \u043A \u044D\u0442\u043E\u0439 \u043B\u0435\u0433\u0435\u043D\u0434\u0435 \u0441
    \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E\u0441\u0442\u044C\u044E.
    \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438
    \u0431\u044B\u043B\u0430 \u0436\u0435\u043D\u043E\u0439 \u0438\u043B\u0438 \u0443\u0447\u0435\u043D\u0438\u0446\u0435\u0439,
