    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0432 \u0441\u0442\u0438\u0445\u043E\u0442\u0432\u043E\u0440\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u0435 \u0438 \u0447\u0430\u0441\u0442\u043E \u043E\u0431\u0440\u0430\u0449\u0430\u043B\u0441\u044F
    \u0432 \u043D\u0438\u0445 \u043A \xAB\u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E\u0439
    \u0434\u0435\u0432\u0443\u0448\u043A\u0435\xBB.  \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0432 \xAB\u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438\xBB \u0435\u0441\u0442\u044C
    \u0442\u0430\u043A\u0438\u0435 \u0437\u0430\u0434\u0430\u0447\u0438:  *   \"\u041E,
    \u041B\u0438\u043B\u0430\u0432\u0430\u0442\u0438, \u0443\u043C\u043D\u0430\u044F
    \u0434\u0435\u0432\u043E\u0447\u043A\u0430, \u0435\u0441\u043B\u0438 \u0442\u044B
    \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0448\u044C \u0441\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0438 \u0432\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u0435, \u0441\u043A\u0430\u0436\u0438
    \u043C\u043D\u0435 \u0441\u0443\u043C\u043C\u0443 \u0447\u0438\u0441\u0435\u043B
    2, 5, 32, 193, 18, 10 \u0438 100, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u0438\u0445 \u0432\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u044F \u0438\u0437
    10000.\" *   \"\u0414\u0438\u0442\u044F \u0441 \u043E\u043B\u0435\u043D\u044C\u0438\u043C\u0438
    \u0433\u043B\u0430\u0437\u0430\u043C\u0438, \u0441\u043A\u0430\u0436\u0438 \u043C\u043D\u0435,
    \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0431\u0443\u0434\u0435\u0442 135
    \u0443\u043C\u043D\u043E\u0436\u0438\u0442\u044C \u043D\u0430 12, \u0435\u0441\u043B\u0438
    \u0442\u044B \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0448\u044C \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435
    \u043F\u043E \u0447\u0430\u0441\u0442\u044F\u043C \u0438 \u043F\u043E \u0440\u0430\u0437\u0440\u044F\u0434\u0430\u043C.\" 
    \u0410 \u0432\u043E\u0442 \u043E\u0434\u043D\u0430 \u0438\u0437 \u043F\u043E\u044D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447 \u043D\u0430 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439:  > \u0417\u0430\u043D\u0438\u043C\u0430\u044F\u0441\u044C
    \u043B\u044E\u0431\u043E\u0432\u044C\u044E, \u043E\u0436\u0435\u0440\u0435\u043B\u044C\u0435
    \u0441\u043B\u043E\u043C\u0430\u043B\u043E\u0441\u044C. > \u0420\u044F\u0434
    \u0436\u0435\u043C\u0447\u0443\u0436\u0438\u043D \u0440\u0430\u0441\u0441\u044B\u043F\u0430\u043B\u0441\u044F.
    > \u0428\u0435\u0441\u0442\u0430\u044F \u0447\u0430\u0441\u0442\u044C \u0443\u043F\u0430\u043B\u0430
    \u043D\u0430 \u043F\u043E\u043B. > \u041F\u044F\u0442\u0430\u044F \u0447\u0430\u0441\u0442\u044C
    \u2014 \u043D\u0430 \u043A\u0440\u043E\u0432\u0430\u0442\u044C. > \u042E\u043D\u0430\u044F
    \u0436\u0435\u043D\u0449\u0438\u043D\u0430 \u0441\u043F\u0430\u0441\u043B\u0430
    \u0442\u0440\u0435\u0442\u044C. > \u0414\u0435\u0441\u044F\u0442\u0430\u044F
    \u0447\u0430\u0441\u0442\u044C \u0431\u044B\u043B\u0430 \u043F\u043E\u0434\u043E\u0431\u0440\u0430\u043D\u0430
    \u0435\u0451 \u0432\u043E\u0437\u043B\u044E\u0431\u043B\u0435\u043D\u043D\u044B\u043C.
    > \u0415\u0441\u043B\u0438 \u043D\u0430 \u043D\u0438\u0442\u043A\u0435 \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C
    \u0448\u0435\u0441\u0442\u044C \u0436\u0435\u043C\u0447\u0443\u0436\u0438\u043D,
    > \u0421\u043A\u043E\u043B\u044C\u043A\u043E \u0436\u0435\u043C\u0447\u0443\u0436\u0438\u043D
    \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E?  \u042D\u0442\u0438
    \u0437\u0430\u0434\u0430\u0447\u0438 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0440\u0430\u0437\u0432\u043B\u0435\u043A\u0430\u043B\u0438, \u043D\u043E \u0438
    \u0443\u0447\u0438\u043B\u0438 \u0440\u0435\u0448\u0430\u0442\u044C \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438 \u0447\u0435\u0440\u0435\u0437
    \u0436\u0438\u0432\u044B\u0435, \u043F\u043E\u043D\u044F\u0442\u043D\u044B\u0435
    \u043E\u0431\u0440\u0430\u0437\u044B.  ### \U0001F522 \u041F\u0435\u0440\u0432\u043E\u043F\u0440\u043E\u0445\u043E\u0434\u0435\u0446
    \u0432 \u0440\u0430\u0431\u043E\u0442\u0435 \u0441 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445, \u043A\u0442\u043E **\u043E\u0441\u043E\u0437\u043D\u0430\u043B
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044E \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438**,
    \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u0443\u044E \u0441 \u0434\u0435\u043B\u0435\u043D\u0438\u0435\u043C
    \u043D\u0430 \u043D\u043E\u043B\u044C. \u041E\u043D \u0447\u0451\u0442\u043A\u043E
    \u0437\u0430\u044F\u0432\u0438\u043B, \u0447\u0442\u043E **\u0432\u0435\u043B\u0438\u0447\u0438\u043D\u0430,
    \u0434\u0435\u043B\u0451\u043D\u043D\u0430\u044F \u043D\u0430 \u043D\u043E\u043B\u044C,
    \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C\u044E**
    (\\( a/0 = \\infty \\)). \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E
    \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0435 \u0431\u044B\u043B\u043E
    \u0435\u0449\u0451 \u043D\u0435\u043F\u043E\u043B\u043D\u044B\u043C: \u043E\u043D
    \u0442\u0430\u043A\u0436\u0435 \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E \\(
    \\infty \\times 0 = a \\). \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430
    \u044D\u0442\u0443 \u043E\u0448\u0438\u0431\u043A\u0443, \u0441\u0430\u043C \u0444\u0430\u043A\u0442
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u043E\u043D \u043F\u044B\u0442\u0430\u043B\u0441\u044F
    \u043E\u0441\u043C\u044B\u0441\u043B\u0438\u0442\u044C \u044D\u0442\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u044E \u0432 XII \u0432\u0435\u043A\u0435,
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043E \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438. 
    ### \U0001F30C \u041F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u0435
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u041C\u043D\u043E\u0433\u0438\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u0441\u0447\u0438\u0442\u0430\u044E\u0442,
    \u0447\u0442\u043E \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430 \u043F\u043E\u0434\u043E\u0448\u0451\u043B
    \u043A \u0438\u0434\u0435\u044F\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u043B\u0435\u0433\u043B\u0438 \u0432
    \u043E\u0441\u043D\u043E\u0432\u0443 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u0438 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430. \u0412 \u0435\u0433\u043E
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442\u0430\u0445 \u043F\u0440\u043E\u0441\u043B\u0435\u0436\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0435 **\u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u0430**.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043E\u043D \u0437\u043D\u0430\u043B,
    \u0447\u0442\u043E \\( \\delta \\sin x \\approx \\cos x \\, \\delta x \\), \u0430
    \u0442\u0430\u043A\u0436\u0435 \u0447\u0442\u043E \u0432 \u0442\u043E\u0447\u043A\u0435
    \u044D\u043A\u0441\u0442\u0440\u0435\u043C\u0443\u043C\u0430 \u0444\u0443\u043D\u043A\u0446\u0438\u0438
    \u0435\u0451 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442 \u043E\u0431\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F
    \u0432 \u043D\u043E\u043B\u044C. \u041E\u043D \u043D\u0435 \u0441\u043E\u0437\u0434\u0430\u043B
    \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438,
    \u043D\u043E \u044D\u0442\u0438 \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u044B\u0435
    \u0434\u043E\u0433\u0430\u0434\u043A\u0438 \u043D\u0430 \u043F\u044F\u0442\u044C
    \u0432\u0435\u043A\u043E\u0432 \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438
    \u0441\u0432\u043E\u0451 \u0432\u0440\u0435\u043C\u044F."
