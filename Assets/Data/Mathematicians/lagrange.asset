  achievementsRu: "\u041E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0449\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0416\u043E\u0437\u0435\u0444\u0430 \u041B\u0443\u0438
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430 \u0432 \u043D\u0430\u0443\u043A\u0443
    \u2014 \u044D\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u044F\u0437\u044B\u043A\u0430
    \u0438 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F \u0444\u0438\u0437\u0438\u043A\u0430
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430. \u0415\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u0430\u044F \u0437\u0430\u0441\u043B\u0443\u0433\u0430
    \u2014 \u0432 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u043E\u0431\u043E\u0431\u0449\u0430\u0442\u044C
    \u0438 \u0441\u0438\u043D\u0442\u0435\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0440\u0430\u0437\u0440\u043E\u0437\u043D\u0435\u043D\u043D\u044B\u0435 \u0437\u043D\u0430\u043D\u0438\u044F
    \u0432 \u0441\u0442\u0440\u043E\u0439\u043D\u044B\u0435, \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u044B\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438. \u0412\u0435\u043D\u0446\u043E\u043C \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u0441\u0442\u0430\u043B \u0442\u0440\u0443\u0434,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0423\u0438\u043B\u044C\u044F\u043C
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B
    \xAB\u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u043F\u043E\u044D\u043C\u043E\u0439\xBB,
    \u2014 \xAB\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430\xBB.  ### \U0001F4D6 \xAB\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430\xBB: \u0412\u0435\u0440\u0448\u0438\u043D\u0430
    \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u0441\u0438\u043D\u0442\u0435\u0437\u0430 
    \u042D\u0442\u0430 \u043A\u043D\u0438\u0433\u0430, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u0432 1788 \u0433\u043E\u0434\u0443, \u0441\u0442\u0430\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0435\u0439 \u0432 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435.
    \u0415\u0451 \u0433\u043B\u0430\u0432\u043D\u0430\u044F \u0438\u0434\u0435\u044F
    \u2014 \u0441\u0432\u0435\u0441\u0442\u0438 \u0432\u0441\u044E \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443
    (\u0438 \u0441\u0442\u0430\u0442\u0438\u043A\u0443, \u0438 \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0443)
    \u043A \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u043C \u043E\u0431\u0449\u0438\u043C
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u043C, \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043A\u0430\u043A \u0447\u0430\u0441\u0442\u043D\u044B\u0435 \u0441\u043B\u0443\u0447\u0430\u0438
    \u043C\u043E\u0436\u043D\u043E \u0432\u044B\u0432\u0435\u0441\u0442\u0438 \u0432\u0441\u0435
    \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435 \u0437\u0430\u043A\u043E\u043D\u044B. 
    *   **\u041E\u0442\u043A\u0430\u0437 \u043E\u0442 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438**:
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436 \u0433\u043E\u0440\u0434\u0438\u043B\u0441\u044F
    \u0442\u0435\u043C, \u0447\u0442\u043E \u0432 \u0435\u0433\u043E \u043A\u043D\u0438\u0433\u0435
    \xAB\u043D\u0435\u043B\u044C\u0437\u044F \u043D\u0430\u0439\u0442\u0438 \u043D\u0438
    \u043E\u0434\u043D\u043E\u0433\u043E \u0447\u0435\u0440\u0442\u0435\u0436\u0430\xBB.
    \u041C\u0435\u0445\u0430\u043D\u0438\u043A\u0430 \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0431\u044B\u043B\u0430 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u043A\u0430\u043A \u0447\u0438\u0441\u0442\u043E \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043D\u0430\u0443\u043A\u0430, \u0440\u0430\u0437\u0434\u0435\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    *   **\u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u044B**: \u0412 \u043E\u0441\u043D\u043E\u0432\u0443
    \u0441\u0442\u0430\u0442\u0438\u043A\u0438 \u043E\u043D \u043F\u043E\u043B\u043E\u0436\u0438\u043B
    **\u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0445
    \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0435\u043D\u0438\u0439**, \u0430
    \u0434\u043B\u044F \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E
    \u0441\u043E\u0435\u0434\u0438\u043D\u0438\u043B \u0435\u0433\u043E \u0441 **\u043F\u0440\u0438\u043D\u0446\u0438\u043F\u043E\u043C
    \u0414'\u0410\u043B\u0430\u043C\u0431\u0435\u0440\u0430**, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0442\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u044B\u0439
    **\u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0414'\u0410\u043B\u0430\u043C\u0431\u0435\u0440\u0430
    \u2014 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430**. \u042D\u0442\u043E
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0435\u043C\u0443 \u0432\u044B\u0432\u0435\u0441\u0442\u0438
    **\u043E\u0431\u0449\u0435\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438** \u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u0442\u0435\u043B. *   **\xAB\u041E\u0431\u043E\u0431\u0449\u0451\u043D\u043D\u044B\u0435
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B\xBB**: \u042D\u0442\u043E
    \u043E\u0434\u043D\u043E \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0432\u0430\u0436\u043D\u044B\u0445
    \u043D\u043E\u0432\u043E\u0432\u0432\u0435\u0434\u0435\u043D\u0438\u0439 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430.
    \u0412\u043C\u0435\u0441\u0442\u043E \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u043A\u0430\u0436\u0434\u043E\u0439 \u0442\u043E\u0447\u043A\u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0432 \u0434\u0435\u043A\u0430\u0440\u0442\u043E\u0432\u044B\u0445 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u0430\u0445
    (x, y, z), \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C \u043B\u044E\u0431\u043E\u0435
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u044B\u0445
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 (\u0443\u0433\u043B\u044B,
    \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F \u0438 \u0442.\u0434.),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043B\u0443\u0447\u0448\u0435 \u0432\u0441\u0435\u0433\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434\u044F\u0442 \u0434\u043B\u044F \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0438. \u0418\u0445 \u0447\u0438\u0441\u043B\u043E
    \u0440\u0430\u0432\u043D\u043E \u0447\u0438\u0441\u043B\u0443 **\u0441\u0442\u0435\u043F\u0435\u043D\u0435\u0439
    \u0441\u0432\u043E\u0431\u043E\u0434\u044B** \u0441\u0438\u0441\u0442\u0435\u043C\u044B.
    *   **\u0423\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430**:
    \u0414\u043B\u044F \u044D\u0442\u0438\u0445 \u043D\u043E\u0432\u044B\u0445 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442
    \u043E\u043D \u0432\u044B\u0432\u0435\u043B \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u044B\u0435
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0442\u0435\u043F\u0435\u0440\u044C
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B \u043A\u0430\u043A **\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430 \u0432\u0442\u043E\u0440\u043E\u0433\u043E
    \u0440\u043E\u0434\u0430**. \u041E\u043D\u0438 \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u044E\u0442\u0441\u044F
    \u0447\u0435\u0440\u0435\u0437 \u043A\u0438\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    (T) \u0438 \u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u0443\u044E
    (U) \u044D\u043D\u0435\u0440\u0433\u0438\u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0438 \u0438\u0445 \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u044C \u2014 **\u0444\u0443\u043D\u043A\u0446\u0438\u044E
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430** (L = T \u2013 U). *   **\u041C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u0438
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430**: \u0414\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0437\u0430\u0434\u0430\u0447 \u0441\u043E \u0441\u043B\u043E\u0436\u043D\u044B\u043C\u0438
    \u0441\u0432\u044F\u0437\u044F\u043C\u0438, \u043A\u043E\u0433\u0434\u0430 \u043D\u0435\u0443\u0434\u043E\u0431\u043D\u043E
    \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0438\u0442\u044C \u043A \u043E\u0431\u043E\u0431\u0449\u0451\u043D\u043D\u044B\u043C
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u0430\u043C, \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043C\u0435\u0442\u043E\u0434
    **\u043C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u0435\u0439 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430**.
    \u042D\u0442\u043E \u043C\u043E\u0449\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442 \u0434\u043B\u044F
    \u043F\u043E\u0438\u0441\u043A\u0430 \u0443\u0441\u043B\u043E\u0432\u043D\u043E\u0433\u043E
    \u044D\u043A\u0441\u0442\u0440\u0435\u043C\u0443\u043C\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0448\u0438\u0440\u043E\u043A\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0438 \u0441\u0435\u0433\u043E\u0434\u043D\u044F.  \u0418\u0437 \u0441\u0432\u043E\u0435\u0433\u043E
    \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0433\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436 \u0441\u0442\u0440\u043E\u0433\u043E
    \u0432\u044B\u0432\u0435\u043B **\u0442\u0440\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B** : 1.  **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438 \u0446\u0435\u043D\u0442\u0440\u0430
    \u043C\u0430\u0441\u0441**: \u0446\u0435\u043D\u0442\u0440 \u043C\u0430\u0441\u0441
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F
    \u0442\u0430\u043A, \u043A\u0430\u043A \u0435\u0441\u043B\u0438 \u0431\u044B
    \u0432 \u043D\u0451\u043C \u0431\u044B\u043B\u0430 \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0435\u043D\u0430
    \u0432\u0441\u044F \u043C\u0430\u0441\u0441\u0430 \u0438 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u044B
    \u0432\u0441\u0435 \u0432\u043D\u0435\u0448\u043D\u0438\u0435 \u0441\u0438\u043B\u044B.
    2.  **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E\u0431 \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0438
    \u043C\u043E\u043C\u0435\u043D\u0442\u0430 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F (\u043A\u0438\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u043E\u043C\u0435\u043D\u0442\u0430)**: \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u0430\u044F
    \u043F\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043E\u0442 \u043A\u0438\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u043E\u043C\u0435\u043D\u0442\u0430 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0440\u0430\u0432\u043D\u0430 \u0441\u0443\u043C\u043C\u0435 \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u0432
    \u0432\u0441\u0435\u0445 \u0432\u043D\u0435\u0448\u043D\u0438\u0445 \u0441\u0438\u043B.
    3.  **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E\u0431 \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0438
    \u043A\u0438\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u044D\u043D\u0435\u0440\u0433\u0438\u0438**:
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B \u043A\u0438\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u044D\u043D\u0435\u0440\u0433\u0438\u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0440\u0430\u0432\u0435\u043D \u0441\u0443\u043C\u043C\u0430\u0440\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 \u0432\u0441\u0435\u0445 \u0441\u0438\u043B
    \u043D\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u043C
    \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0435\u043D\u0438\u0438.  ### \U0001F52D
    \u0414\u0440\u0443\u0433\u0438\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043D\u0430\u0443\u043A\u0438  \u0413\u0435\u043D\u0438\u0439 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u0438 \u0432\u043E \u043C\u043D\u043E\u0433\u0438\u0445
    \u0434\u0440\u0443\u0433\u0438\u0445 \u0441\u0444\u0435\u0440\u0430\u0445 : 
    **\u0412\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0435 \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435**
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436 \u043F\u043E \u0441\u0443\u0442\u0438
    \u0441\u043E\u0437\u0434\u0430\u043B \u044D\u0442\u043E \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u0432
    \u043E\u0431\u0449\u0438\u0439 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0435\u0442\u043E\u0434 (\u043C\u0435\u0442\u043E\u0434 \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u0439)
    \u0434\u043B\u044F \u043F\u043E\u0438\u0441\u043A\u0430 \u0444\u0443\u043D\u043A\u0446\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u0431\u0440\u0430\u0449\u0430\u044E\u0442
    \u0432 \u043C\u0438\u043D\u0438\u043C\u0443\u043C \u0438\u043B\u0438 \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0435 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044B.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0432\u043D\u0451\u0441 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439.  **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B** \u0412\u043D\u0451\u0441 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u044D\u0442\u0443 \u043E\u0431\u043B\u0430\u0441\u0442\u044C.
    \u0421\u0430\u043C\u043E\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u2014 \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    **\u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0412\u0438\u043B\u044C\u0441\u043E\u043D\u0430**:
    \u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0433\u043E \u043F\u0440\u043E\u0441\u0442\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 p \u0447\u0438\u0441\u043B\u043E `(p-1)! + 1`
    \u0434\u0435\u043B\u0438\u0442\u0441\u044F \u043D\u0430 p.  **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439** \u0412 \u0441\u0432\u043E\u0451\u043C
    \u043C\u0435\u043C\u0443\u0430\u0440\u0435 \xAB\u0420\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F
    \u043E\u0431 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0440\u0435\u0448\u0435\u043D\u0438\u0438 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439\xBB
    (1770-1771) \u043E\u043D \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434\u044B \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0432\u044B\u0441\u0448\u0438\u0445
    \u0441\u0442\u0435\u043F\u0435\u043D\u0435\u0439, \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u044F
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438 \u0438\u0445
    \u043A\u043E\u0440\u043D\u0435\u0439. \u0425\u043E\u0442\u044F \u0435\u043C\u0443
    \u043D\u0435 \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u043D\u0430\u0439\u0442\u0438
    \u043E\u0431\u0449\u0435\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0432\u044B\u0448\u0435 4-\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438,
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0430
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0434\u043B\u044F **\u0442\u0435\u043E\u0440\u0438\u0438
    \u0433\u0440\u0443\u043F\u043F**, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043F\u043E\u0437\u0436\u0435 \u0440\u0430\u0437\u0432\u0438\u043B\u0438 \u0410\u0431\u0435\u043B\u044C
    \u0438 \u0413\u0430\u043B\u0443\u0430.  **\u041D\u0435\u0431\u0435\u0441\u043D\u0430\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430** \u0412\u043D\u0451\u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u044D\u0442\u0443 \u043E\u0431\u043B\u0430\u0441\u0442\u044C,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u0438\u0437\u0443\u0447\u0430\u044F
    \u0437\u0430\u0434\u0430\u0447\u0443 \u0442\u0440\u0451\u0445 \u0442\u0435\u043B.
    \u041E\u043D \u0440\u0435\u0448\u0438\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443 **\u043B\u0438\u0431\u0440\u0430\u0446\u0438\u0438
    \u041B\u0443\u043D\u044B** (\u0435\u0451 \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u0439),
    \u0437\u0430 \u0447\u0442\u043E \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0440\u0435\u043C\u0438\u044E
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u0432 1764 \u0433\u043E\u0434\u0443. \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043F\u0440\u0438\u0432\u0435\u043B\u0430 \u043A \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u044E
    **\u0442\u043E\u0447\u0435\u043A \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430**
    \u2014 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439 \u0432 \u043A\u043E\u0441\u043C\u043E\u0441\u0435,
    \u0433\u0434\u0435 \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u0441\u0438\u043B\u044B \u0434\u0432\u0443\u0445 \u043C\u0430\u0441\u0441\u0438\u0432\u043D\u044B\u0445
    \u0442\u0435\u043B \u0443\u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0448\u0438\u0432\u0430\u044E\u0442
    \u0446\u0435\u043D\u0442\u0440\u043E\u0431\u0435\u0436\u043D\u0443\u044E \u0441\u0438\u043B\u0443. 
    **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437** \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u0442\u0435\u043E\u0440\u0438\u044E
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u0443\u044E
    \u043D\u0430 \u0440\u0430\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0438 \u0432
    \u0441\u0442\u0435\u043F\u0435\u043D\u043D\u044B\u0435 \u0440\u044F\u0434\u044B
    (\u043A\u043D\u0438\u0433\u0430 \xAB\u0422\u0435\u043E\u0440\u0438\u044F \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439\xBB, 1797). \u0422\u0430\u043A\u0436\u0435
    \u043E\u043D \u0434\u0430\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0434\u043B\u044F **\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0433\u043E
    \u0447\u043B\u0435\u043D\u0430 \u0440\u044F\u0434\u0430 \u0422\u0435\u0439\u043B\u043E\u0440\u0430**
    \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B **\u043C\u0435\u0442\u043E\u0434
    \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u0438 \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u044B\u0445**
    \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439.  \u0412\u043A\u043B\u0430\u0434
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430 \u0432 \u043D\u0430\u0443\u043A\u0443
    \u0441\u0442\u0430\u043B \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u043C\u043D\u043E\u0433\u0438\u0445 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0445
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439. \u0415\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u044B
    \u0438 \u043F\u043E\u0434\u0445\u043E\u0434\u044B, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0432 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435 \u0438 \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u043C
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0438, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u0438 \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0437\u043D\u0430\u043D\u0438\u044F."
  achievementsEn: 
  personalLifeRu: "\u0411\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u0416\u043E\u0437\u0435\u0444\u0430
    \u041B\u0443\u0438 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430 \u2014 \u044D\u0442\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0430\u043B \u0441\u0430\u043C\u044B\u043C
    \u044F\u0440\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0441\u0442\u0435\u0447\u0435\u043D\u0438\u044E \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u0438 \u0441\u0432\u043E\u0435\u043C\u0443 \u043D\u0435\u0443\u043A\u0440\u043E\u0442\u0438\u043C\u043E\u043C\u0443
    \u0441\u0442\u0440\u0435\u043C\u043B\u0435\u043D\u0438\u044E \u043A \u0437\u043D\u0430\u043D\u0438\u044F\u043C.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0439 \u043F\u0443\u0442\u044C
    \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u043D\u0430 \u0442\u0440\u0438 \u0447\u0435\u0442\u043A\u0438\u0445 \u043F\u0435\u0440\u0438\u043E\u0434\u0430,
    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0445
    \u0433\u043E\u0440\u043E\u0434\u0430\u043C \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438:
    \u0422\u0443\u0440\u0438\u043D, \u0411\u0435\u0440\u043B\u0438\u043D \u0438 \u041F\u0430\u0440\u0438\u0436. 
    ### \U0001F4DC \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435 
    \u0416\u043E\u0437\u0435\u0444 \u041B\u0443\u0438 \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **25 \u044F\u043D\u0432\u0430\u0440\u044F
    1736 \u0433\u043E\u0434\u0430** \u0432 **\u0422\u0443\u0440\u0438\u043D\u0435**,
    \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u0441\u0442\u043E\u043B\u0438\u0446\u0435
    \u0421\u0430\u0440\u0434\u0438\u043D\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u0442\u0432\u0430
    (\u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F \u0418\u0442\u0430\u043B\u0438\u044F).
    \u041F\u0440\u0438 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0438 \u0435\u0433\u043E
    \u043D\u0430\u0440\u0435\u043A\u043B\u0438 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u043C
    \u0438\u043C\u0435\u043D\u0435\u043C **\u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435
    \u041B\u043E\u0434\u043E\u0432\u0438\u043A\u043E \u041B\u0430\u0433\u0440\u0430\u043D\u0434\u0436\u0430**.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435
    \u0424\u0440\u0430\u043D\u0447\u0435\u0441\u043A\u043E \u041B\u043E\u0434\u043E\u0432\u0438\u043A\u043E,
    \u0431\u044B\u043B \u0432\u043E\u0435\u043D\u043D\u044B\u043C \u043A\u0430\u0437\u043D\u0430\u0447\u0435\u0435\u043C
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0441\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u043C.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0438\u0437-\u0437\u0430 \u043D\u0435\u0443\u0434\u0430\u0447\u043D\u044B\u0445
    \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0445 \u0441\u043F\u0435\u043A\u0443\u043B\u044F\u0446\u0438\u0439
    \u043A \u043C\u043E\u043C\u0435\u043D\u0442\u0443 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E\u043B\u0435\u0442\u0438\u044F
    \u0441\u044B\u043D\u0430 \u0441\u0435\u043C\u044C\u044F \u043F\u043E\u0442\u0435\u0440\u044F\u043B\u0430
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u0441\u0451
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435.  \u041B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u043E,
    \u0447\u0442\u043E \u0441\u0430\u043C \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u0441\u0447\u0438\u0442\u0430\u043B
    \u044D\u0442\u043E \u0440\u0430\u0437\u043E\u0440\u0435\u043D\u0438\u0435 \u0443\u0434\u0430\u0447\u0435\u0439:
    *\"\u0415\u0441\u043B\u0438 \u0431\u044B \u044F \u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435, \u043C\u043D\u0435, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u043D\u0435 \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C \u0431\u044B \u0441\u0432\u044F\u0437\u0430\u0442\u044C
    \u0441\u0432\u043E\u044E \u0441\u0443\u0434\u044C\u0431\u0443 \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439\"*.
    \u041E\u043D \u0431\u044B\u043B \u043C\u043B\u0430\u0434\u0448\u0438\u043C \u0438\u0437
    11 \u0434\u0435\u0442\u0435\u0439, \u043D\u043E \u0432\u044B\u0436\u0438\u043B,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C. 
    ### \U0001F393 \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u043F\u0443\u0442\u044C \u0432 \u043D\u0430\u0443\u043A\u0443  \u041F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u043E\u0442\u0435\u0446 \u0432\u0438\u0434\u0435\u043B \u0416\u043E\u0437\u0435\u0444\u0430
    \u043D\u0430 \u044E\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0442\u0435\u0437\u0435, \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u0435\u0433\u043E \u0443\u0447\u0438\u0442\u044C\u0441\u044F \u0432 **\u0422\u0443\u0440\u0438\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442**. \u0421\u043D\u0430\u0447\u0430\u043B\u0430
    \u044E\u043D\u043E\u0448\u0430 \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0444\u0438\u043B\u043E\u043B\u043E\u0433\u0438\u0435\u0439
    \u0438 \u0434\u0440\u0435\u0432\u043D\u0438\u043C\u0438 \u044F\u0437\u044B\u043A\u0430\u043C\u0438.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430\u0441\u044C, \u043A\u043E\u0433\u0434\u0430
    \u0432 \u0435\u0433\u043E \u0440\u0443\u043A\u0438 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E
    \u043F\u043E\u043F\u0430\u043B \u0442\u0440\u0430\u043A\u0442\u0430\u0442 \u043F\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043F\u0442\u0438\u043A\u0435. \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0435\u0433\u043E \u0443\u0432\u043B\u0435\u043A\u043B\u043E,
    \u0447\u0442\u043E \u043E\u043D \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u043B\u0441\u044F \u043D\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443.  \u0417\u0430 \u043A\u043E\u0440\u043E\u0442\u043A\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F (\u0432\u0441\u0435\u0433\u043E \u0437\u0430 \u043F\u0430\u0440\u0443
    \u043B\u0435\u0442) \u041B\u0430\u0433\u0440\u0430\u043D\u0436, **\u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0431\u0435\u0437 \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439**, \u043E\u0441\u0432\u043E\u0438\u043B
    \u0432\u0441\u044E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E
    \u0435\u043C\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0443. \u041A 16 \u0433\u043E\u0434\u0430\u043C
    \u0435\u0433\u043E \u0437\u043D\u0430\u043D\u0438\u0439 \u0431\u044B\u043B\u043E
    \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E, \u0447\u0442\u043E\u0431\u044B
    \u043D\u0430\u0447\u0430\u0442\u044C \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C. 
    ### \U0001F9D1\u200D\U0001F3EB \u0422\u0443\u0440\u0438\u043D\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434: \u043D\u0430\u0447\u0430\u043B\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B
    (1754\u20131766)  \u0412 **1755 \u0433\u043E\u0434\u0443**, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u0432\u0441\u0435\u0433\u043E **19 \u043B\u0435\u0442**, \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D **\u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 \u0422\u0443\u0440\u0438\u043D\u0430**. \u041E\u043D
    \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043C\u043E\u043B\u043E\u0434,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B
    \u0431\u044B\u043B\u0438 \u0441\u0442\u0430\u0440\u0448\u0435 \u0435\u0433\u043E. 
    \u0412 \u0422\u0443\u0440\u0438\u043D\u0435 \u043E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B, \u043D\u043E \u0438
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u043D\u0430\u0443\u043A\u043E\u0439. \u0412 **1757 \u0433\u043E\u0434\u0443**
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u043C\u043E\u043B\u043E\u0434\u044B\u043C\u0438
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438 \u043E\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \"\u0427\u0430\u0441\u0442\u043D\u043E\u0435 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E\",
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0432\u0441\u043A\u043E\u0440\u0435
    \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u043E\u0441\u044C \u0432
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **\u0422\u0443\u0440\u0438\u043D\u0441\u043A\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A**.
    \u0412 1759 \u0433\u043E\u0434\u0443 \u0432\u044B\u0448\u0435\u043B \u043F\u0435\u0440\u0432\u044B\u0439
    \u0442\u043E\u043C \u0442\u0440\u0443\u0434\u043E\u0432 \u044D\u0442\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430, \u0433\u0434\u0435 \u0431\u044B\u043B\u0438
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u044B \u043F\u0438\u043E\u043D\u0435\u0440\u0441\u043A\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430
    \u043F\u043E \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E, \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439 \u0438
    \u0430\u043A\u0443\u0441\u0442\u0438\u043A\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0440\u0430\u0437\u0443 \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438
    \u0435\u0433\u043E \u0432 \u043E\u0434\u0438\u043D \u0440\u044F\u0434 \u0441
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438
    \u0415\u0432\u0440\u043E\u043F\u044B.  ### \U0001F451 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434: \u0433\u043E\u0434\u044B \u0440\u0430\u0441\u0446\u0432\u0435\u0442\u0430
    (1766\u20131787)  \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0441\u0442\u0430\u043B \u0441\u0430\u043C\u044B\u043C \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u043C
    \u0432 \u043A\u0430\u0440\u044C\u0435\u0440\u0435 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430. 
    *   **\u041F\u0435\u0440\u0435\u0435\u0437\u0434 \u0432 \u0411\u0435\u0440\u043B\u0438\u043D**:
    \u0412 **1766 \u0433\u043E\u0434\u0443** \u043E\u043D \u043F\u0440\u0438\u043D\u044F\u043B
    \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435 \u043F\u0440\u0443\u0441\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u044F **\u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430
    II** \u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0411\u0435\u0440\u043B\u0438\u043D,
    \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u0432 \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A. \u041A\u043E\u0440\u043E\u043B\u044C,
    \u043B\u044E\u0431\u0438\u0432\u0448\u0438\u0439 \u043E\u043A\u0440\u0443\u0436\u0430\u0442\u044C
    \u0441\u0435\u0431\u044F \u0432\u0435\u043B\u0438\u043A\u0438\u043C\u0438 \u0443\u043C\u0430\u043C\u0438,
    \u0431\u044B\u043B \u0440\u0430\u0434 \u0438\u043C\u0435\u0442\u044C \u043F\u0440\u0438
    \u0434\u0432\u043E\u0440\u0435 \"\u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0435\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0415\u0432\u0440\u043E\u043F\u044B\".
    \u042D\u0442\u043E\u043C\u0443 \u043F\u0435\u0440\u0435\u0435\u0437\u0434\u0443
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \u0441\u0442\u0430\u0440\u0448\u0438\u0435 \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u0438 \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u0438 \u2014
    **\u041B\u0435\u043E\u043D\u0430\u0440\u0434 \u042D\u0439\u043B\u0435\u0440**
    \u0438 **\u0416\u0430\u043D \u041B\u0435\u0440\u043E\u043D \u0414'\u0410\u043B\u0430\u043C\u0431\u0435\u0440**. 
    *   **\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u0432
    \u0411\u0435\u0440\u043B\u0438\u043D\u0435**: \u0412 **1767 \u0433\u043E\u0434\u0443**
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0441\u0432\u043E\u0435\u0439 \u043A\u0443\u0437\u0438\u043D\u0435
    **\u0412\u0438\u0442\u0442\u043E\u0440\u0438\u0438 \u041A\u043E\u043D\u0442\u0438**.
    \u0411\u0440\u0430\u043A \u0431\u044B\u043B \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C,
    \u043D\u043E \u043D\u0435\u0434\u043E\u043B\u0433\u0438\u043C. \u0412 1783 \u0433\u043E\u0434\u0443
    \u0435\u0433\u043E \u0436\u0435\u043D\u0430 \u0442\u044F\u0436\u0435\u043B\u043E
    \u0437\u0430\u0431\u043E\u043B\u0435\u043B\u0430, \u0438 \u041B\u0430\u0433\u0440\u0430\u043D\u0436,
    \u0437\u0430\u0431\u044B\u0432\u0430\u044F \u043E \u0441\u043D\u0435, \u0443\u0445\u0430\u0436\u0438\u0432\u0430\u043B
    \u0437\u0430 \u043D\u0435\u0439. \u0415\u0435 \u0441\u043C\u0435\u0440\u0442\u044C
    \u0441\u0442\u0430\u043B\u0430 \u0442\u044F\u0436\u0435\u043B\u0435\u0439\u0448\u0438\u043C
    \u0443\u0434\u0430\u0440\u043E\u043C \u0434\u043B\u044F \u0443\u0447\u0435\u043D\u043E\u0433\u043E,
    \u0438 \u043E\u043D \u0438\u0441\u043A\u0430\u043B \u0443\u0442\u0435\u0448\u0435\u043D\u0438\u0435
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0432 \u0440\u0430\u0431\u043E\u0442\u0435.  ### \u2696\uFE0F \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434: \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0438 \u0437\u0430\u043A\u0430\u0442 (1787\u20131813)  \u041F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u043A\u043E\u0440\u043E\u043B\u044F \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430
    II \u0432 1786 \u0433\u043E\u0434\u0443 \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u043F\u043E\u043A\u0438\u043D\u0443\u043B \u0411\u0435\u0440\u043B\u0438\u043D
    \u0438 \u0432 **1787 \u0433\u043E\u0434\u0443** \u043F\u043E \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u044E
    \u041B\u044E\u0434\u043E\u0432\u0438\u043A\u0430 XVI \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 **\u041F\u0430\u0440\u0438\u0436**. \u0412\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438
    \u0435\u0433\u043E \u0436\u0434\u0430\u043B \u0442\u0440\u0438\u0443\u043C\u0444\u0430\u043B\u044C\u043D\u044B\u0439
    \u043F\u0440\u0438\u0435\u043C: \u043E\u043D \u0441\u0442\u0430\u043B \u0447\u043B\u0435\u043D\u043E\u043C
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A, \u0438 \u0435\u043C\u0443 \u0431\u044B\u043B\u0430
    \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u043A\u043E\u043C\u0444\u043E\u0440\u0442\u0430\u0431\u0435\u043B\u044C\u043D\u0430\u044F
    \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0430 \u0432 \u041B\u0443\u0432\u0440\u0435. 
    *   **\u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F \u0438 \u043D\u043E\u0432\u044B\u0439
    \u0431\u0440\u0430\u043A**: \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0443\u044E
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u043F\u0435\u0440\u0435\u0436\u0438\u043B \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E.
    \u041A \u043D\u0435\u043C\u0443, \u043A\u0430\u043A \u043A \u0432\u0435\u043B\u0438\u043A\u043E\u043C\u0443
    \u0443\u0447\u0435\u043D\u043E\u043C\u0443, \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0435
    \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043E\u0442\u043D\u0435\u0441\u043B\u043E\u0441\u044C \u0441\u043D\u0438\u0441\u0445\u043E\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043D\u0430\u0437\u043D\u0430\u0447\u0438\u0432 \u043F\u0435\u043D\u0441\u0438\u044E
    \u0438 \u0432\u043A\u043B\u044E\u0447\u0438\u0432 \u0432 \u043A\u043E\u043C\u0438\u0441\u0441\u0438\u044E
    \u043F\u043E \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0435 **\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043C\u0435\u0440 \u0438 \u0432\u0435\u0441\u043E\u0432**.
    \u0412 **1792 \u0433\u043E\u0434\u0443** \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u0432\u043E \u0432\u0442\u043E\u0440\u043E\u0439 \u0440\u0430\u0437 \u2014 \u043D\u0430
    **\u0420\u0435\u043D\u0435-\u0424\u0440\u0430\u043D\u0441\u0443\u0430\u0437\u0435-\u0410\u0434\u0435\u043B\u0430\u0438\u0434\u0435
    \u041B\u0435\u043C\u043E\u043D\u044C\u0435**, \u0434\u043E\u0447\u0435\u0440\u0438
    \u0441\u0432\u043E\u0435\u0433\u043E \u0434\u0440\u0443\u0433\u0430-\u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430.
    \u042D\u0442\u043E\u0442 \u0431\u0440\u0430\u043A \u0431\u044B\u043B \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C. 
    *   **\u041F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0438
    \u043F\u043E\u0447\u0435\u0441\u0442\u0438**: \u0412 \u041F\u0430\u0440\u0438\u0436\u0435
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436 \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435\u043C.
    \u041E\u043D \u0431\u044B\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0432 \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u0445
    **\u041D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u0435**
    (\u0441 1795) \u0438 **\u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435** (\u0441 1797), \u0433\u0434\u0435 \u0447\u0438\u0442\u0430\u043B
    \u043A\u0443\u0440\u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430.  \u041F\u0440\u0438\u0448\u0435\u0434\u0448\u0438\u0439
    \u043A \u0432\u043B\u0430\u0441\u0442\u0438 **\u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D
    \u0411\u043E\u043D\u0430\u043F\u0430\u0440\u0442** \u0431\u043B\u0430\u0433\u043E\u0432\u043E\u043B\u0438\u043B
    \u043A \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0443, \u043E\u0441\u044B\u043F\u0430\u043B
    \u0435\u0433\u043E \u043F\u043E\u0447\u0435\u0441\u0442\u044F\u043C\u0438, \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u043B
    \u0442\u0438\u0442\u0443\u043B \u0433\u0440\u0430\u0444\u0430, \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u0441\u0435\u043D\u0430\u0442\u043E\u0440\u0430 \u0438 \u043E\u0440\u0434\u0435\u043D
    \u041F\u043E\u0447\u0435\u0442\u043D\u043E\u0433\u043E \u043B\u0435\u0433\u0438\u043E\u043D\u0430.
    \u0418\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440 \u0446\u0435\u043D\u0438\u043B
    \u0431\u0435\u0441\u0435\u0434\u044B \u0441 \u0443\u0447\u0435\u043D\u044B\u043C
    \u0438 \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0435\u0433\u043E **\"\u0432\u0435\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u043F\u0438\u0440\u0430\u043C\u0438\u0434\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A\"**.  ### \u26B0\uFE0F \u0421\u043C\u0435\u0440\u0442\u044C
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0441\u043B\u043E\u0432\u0430 
    \u0416\u043E\u0437\u0435\u0444 \u041B\u0443\u0438 \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 \u041F\u0430\u0440\u0438\u0436\u0435
    **10 \u0430\u043F\u0440\u0435\u043B\u044F 1813 \u0433\u043E\u0434\u0430** \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 77 \u043B\u0435\u0442. \u041F\u043E
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u0435\u0433\u043E \u043A\u043E\u043D\u0447\u0438\u043D\u0430 \u0431\u044B\u043B\u0430
    \u0441\u0442\u043E\u043B\u044C \u0436\u0435 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E\u0439,
    \u043A\u0430\u043A \u0438 \u0432\u0441\u044F \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C.
    \u0415\u0433\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0441\u043B\u043E\u0432\u0430,
    \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u043D\u044B\u0435 \u043A \u0434\u0440\u0443\u0437\u044C\u044F\u043C,
    \u0431\u044B\u043B\u0438: *\"\u042F \u0441\u0434\u0435\u043B\u0430\u043B \u0441\u0432\u043E\u0451
    \u0434\u0435\u043B\u043E\u2026 \u042F \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0438\u043A\u043E\u0433\u043E \u043D\u0435 \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B
    \u0438 \u043D\u0435 \u0434\u0435\u043B\u0430\u043B \u043D\u0438\u043A\u043E\u043C\u0443
    \u0437\u043B\u0430\"*.  \u041F\u043E \u043F\u0440\u0438\u043A\u0430\u0437\u0443
    \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D\u0430 \u0435\u0433\u043E \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0438\u043B\u0438
    \u0441 \u0432\u044B\u0441\u0448\u0438\u043C\u0438 \u043F\u043E\u0447\u0435\u0441\u0442\u044F\u043C\u0438
    \u0432 \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u043C **\u041F\u0430\u043D\u0442\u0435\u043E\u043D\u0435**. 
    ### \U0001F91D \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441
    \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438 
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445
    \u0433\u0435\u043D\u0438\u0435\u0432, \u041B\u0430\u0433\u0440\u0430\u043D\u0436,
    \u043A\u0430\u0436\u0435\u0442\u0441\u044F, \u043D\u0435 \u0438\u0441\u043A\u0430\u043B
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u043E\u0432 \u0438 \u0440\u0435\u0434\u043A\u043E
    \u0432\u0441\u0442\u0443\u043F\u0430\u043B \u0432 \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0441\u043F\u043E\u0440\u044B. \u041E\u043D
    \u0431\u044B\u043B \u0441\u0434\u0435\u0440\u0436\u0430\u043D \u0438 \u043D\u0435
    \u043B\u044E\u0431\u0438\u043B \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u0439,
    \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0432 \u0442\u0438\u0448\u0438\u043D\u0435. \u0412 \u0441\u043B\u0443\u0447\u0430\u0435
    \u0441\u043F\u043E\u0440\u0430 \u043E\u043D \u0447\u0430\u0441\u0442\u043E \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u043B\u0441\u044F
    \u0444\u0440\u0430\u0437\u043E\u0439 *\"\u041D\u0435 \u0437\u043D\u0430\u044E\"*. 
    \u0415\u0433\u043E \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441\u043E
    \u0441\u0442\u0430\u0440\u0448\u0438\u043C\u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438
    \u0431\u044B\u043B\u0438 \u043E\u0431\u0440\u0430\u0437\u0446\u043E\u043C \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0438:
    *   **\u041B\u0435\u043E\u043D\u0430\u0440\u0434 \u042D\u0439\u043B\u0435\u0440**
    \u0441\u0442\u0430\u043B \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C. \u041F\u043E\u043B\u0443\u0447\u0438\u0432
    \u043E\u0442 \u044E\u043D\u043E\u0433\u043E \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430
    \u043F\u0438\u0441\u044C\u043C\u043E \u0441 \u0440\u0435\u0448\u0435\u043D\u0438\u0435\u043C
    \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u0437\u0430\u0434\u0430\u0447, \u042D\u0439\u043B\u0435\u0440
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E
    \u043F\u043E\u0445\u0432\u0430\u043B\u0438\u043B \u0435\u0433\u043E, \u043D\u043E
    \u0438 \u0432\u0441\u044F\u0447\u0435\u0441\u043A\u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044E \u0432
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0443\u0433\u0430\u0445. *   **\u0416\u0430\u043D \u041B\u0435\u0440\u043E\u043D
    \u0414'\u0410\u043B\u0430\u043C\u0431\u0435\u0440** \u0442\u0430\u043A\u0436\u0435
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B
    \u0438 \u043F\u043E\u043E\u0449\u0440\u044F\u043B \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E
    \u0443\u0447\u0451\u043D\u043E\u0433\u043E, \u0437\u0430\u0431\u043E\u0442\u044F\u0441\u044C
    \u043E \u0435\u0433\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435 \u0438
    \u043F\u0440\u043E\u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438. *   \u0415\u0433\u043E
    \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C\u0438 \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044F\u043C\u0438
    \u0431\u044B\u043B\u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0433\u043E
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F, \u0442\u0430\u043A\u0438\u0435
    \u043A\u0430\u043A **\u0416\u0430\u043D \u0411\u0430\u0442\u0438\u0441\u0442
    \u0416\u043E\u0437\u0435\u0444 \u0424\u0443\u0440\u044C\u0435** \u0438 **\u0421\u0438\u043C\u0435\u043E\u043D
    \u0414\u0435\u043D\u0438 \u041F\u0443\u0430\u0441\u0441\u043E\u043D**. \u0415\u0433\u043E
    \u0438\u0434\u0435\u0438 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u043B\u0438
    \u041D\u0438\u043B\u044C\u0441\u0430 \u0410\u0431\u0435\u043B\u044F \u0438 \u042D\u0432\u0430\u0440\u0438\u0441\u0442\u0430
    \u0413\u0430\u043B\u0443\u0430 \u043D\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0443\u043F\u043F."
  personalLifeEn: 
  shortBioRu: "\u0416\u043E\u0437\u0435\u0444 \u041B\u0443\u0438 \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u2014 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A
    \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u043E\u0433\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F,
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0443\u0447\u0451\u043D\u044B\u0445 XVIII \u0432\u0435\u043A\u0430 \u043D\u0430\u0440\u044F\u0434\u0443
    \u0441 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E\u043C \u042D\u0439\u043B\u0435\u0440\u043E\u043C.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u0438 \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E \u043E\u043F\u0438\u0441\u0430\u043D\u044B
    \u043D\u0438\u0436\u0435.  ### \U0001F4DC \u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u044E\u043D\u043E\u0441\u0442\u044C: \u043F\u0443\u0442\u044C \u0432
    \u043D\u0430\u0443\u043A\u0443  \u0411\u0443\u0434\u0443\u0449\u0438\u0439 \u0433\u0435\u043D\u0438\u0439
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **25 \u044F\u043D\u0432\u0430\u0440\u044F
    1736 \u0433\u043E\u0434\u0430** \u0432 **\u0422\u0443\u0440\u0438\u043D\u0435**
    (\u0421\u0430\u0440\u0434\u0438\u043D\u0441\u043A\u043E\u0435 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u0442\u0432\u043E,
    \u043D\u044B\u043D\u0435 \u0418\u0442\u0430\u043B\u0438\u044F) \u0438 \u043F\u0440\u0438
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0438 \u0431\u044B\u043B \u043D\u0430\u0437\u0432\u0430\u043D
    **\u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435 \u041B\u043E\u0434\u043E\u0432\u0438\u043A\u043E
    \u041B\u0430\u0433\u0440\u0430\u043D\u0434\u0436\u0430**. \u041E\u043D \u0431\u044B\u043B
    \u0441\u0442\u0430\u0440\u0448\u0438\u043C \u0440\u0435\u0431\u0435\u043D\u043A\u043E\u043C
    \u0432 \u0441\u0435\u043C\u044C\u0435, \u0433\u0434\u0435 \u0432\u0441\u0435\u0433\u043E
    \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C 11 \u0434\u0435\u0442\u0435\u0439,
    \u043D\u043E \u0434\u043E \u0432\u0437\u0440\u043E\u0441\u043B\u043E\u0433\u043E
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0430 \u0434\u043E\u0436\u0438\u043B\u0438
    \u043B\u0438\u0448\u044C \u0434\u0432\u043E\u0435.  \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435 \u0424\u0440\u0430\u043D\u0447\u0435\u0441\u043A\u043E
    \u041B\u043E\u0434\u043E\u0432\u0438\u043A\u043E, \u0431\u044B\u043B \u043A\u0430\u0437\u043D\u0430\u0447\u0435\u0435\u043C
    \u043F\u0440\u0438 \u0434\u0432\u043E\u0440\u0435 \u0441\u0430\u0440\u0434\u0438\u043D\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u044F, \u043D\u043E \u0438\u0437-\u0437\u0430
    \u0440\u0438\u0441\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0445 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0445
    \u0441\u043F\u0435\u043A\u0443\u043B\u044F\u0446\u0438\u0439 \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435. \u041F\u043E\u0437\u0436\u0435
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436 \u0433\u043E\u0432\u043E\u0440\u0438\u043B:
    *\"\u0415\u0441\u043B\u0438 \u0431\u044B \u044F \u0431\u044B\u043B \u0431\u043E\u0433\u0430\u0442,
    \u044F, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043D\u0435 \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u0431\u044B \u0441\u0435\u0431\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435\"*. 
    *   **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0438
    \u0440\u0430\u043D\u043D\u0438\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B**:
    \u041E\u0442\u0435\u0446 \u043F\u0440\u043E\u0447\u0438\u043B \u0416\u043E\u0437\u0435\u0444\u0430
    \u043A \u043A\u0430\u0440\u044C\u0435\u0440\u0435 \u044E\u0440\u0438\u0441\u0442\u0430,
    \u0438 \u044E\u043D\u043E\u0448\u0430 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0422\u0443\u0440\u0438\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442.
    \u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043E\u043D \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043B\u0430\u0442\u044B\u043D\u044C\u044E
    \u0438 \u043D\u0430\u0445\u043E\u0434\u0438\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0441\u043A\u0443\u0447\u043D\u043E\u0439. *   **\u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u0439
    \u043C\u043E\u043C\u0435\u043D\u0442**: \u0418\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u0442\u043E\u0447\u043D\u044B\u043C \u043D\u0430\u0443\u043A\u0430\u043C
    \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B\u0441\u044F \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E,
    \u043F\u043E\u0441\u043B\u0435 \u043F\u0440\u043E\u0447\u0442\u0435\u043D\u0438\u044F
    \u0440\u0430\u0431\u043E\u0442\u044B \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430 \u042D\u0434\u043C\u0443\u043D\u0434\u0430
    \u0413\u0430\u043B\u043B\u0435\u044F \u043E \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0438
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0432 \u043E\u043F\u0442\u0438\u043A\u0435.
    *   **\u041F\u0435\u0440\u0432\u044B\u0435 \u0443\u0441\u043F\u0435\u0445\u0438**:
    \u041D\u0430\u0447\u0430\u0432 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E,
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436 \u0443\u0436\u0435 \u0432 **1754 \u0433\u043E\u0434\u0443**
    (\u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 18 \u043B\u0435\u0442)
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u044E
    \u043F\u0435\u0440\u0432\u0443\u044E \u043D\u0430\u0443\u0447\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443, \u0430 \u0432 **1755 \u0433\u043E\u0434\u0443**
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B \u043F\u0438\u0441\u044C\u043C\u043E
    \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u0443 \u042D\u0439\u043B\u0435\u0440\u0443
    \u0441 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u043C\u0438
    \u0438\u0434\u0435\u044F\u043C\u0438 \u043F\u043E \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E, \u0440\u0435\u0448\u0438\u0432
    \u0437\u0430\u0434\u0430\u0447\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0435 \u043F\u043E\u0434\u0434\u0430\u0432\u0430\u043B\u0438\u0441\u044C
    \u0441\u0430\u043C\u043E\u043C\u0443 \u042D\u0439\u043B\u0435\u0440\u0443.  ###
    \U0001F3C6 \u0422\u0443\u0440\u0438\u043D\u0441\u043A\u0438\u0439 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0438 \u043D\u0430\u0447\u0430\u043B\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F
    (1755\u20131766)  \u041C\u043E\u043B\u043E\u0434\u043E\u0439 \u0443\u0447\u0451\u043D\u044B\u0439
    \u0431\u044B\u0441\u0442\u0440\u043E \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435.  *   **\u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u0430\u044F
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C**: \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u0432\u0441\u0435\u0433\u043E **19 \u043B\u0435\u0442**, **28 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F
    1755 \u0433\u043E\u0434\u0430**, \u041B\u0430\u0433\u0440\u0430\u043D\u0436 \u0431\u044B\u043B
    \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 \u0422\u0443\u0440\u0438\u043D\u0430. *   **\u0422\u0443\u0440\u0438\u043D\u0441\u043A\u0430\u044F
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044F**: \u041E\u043D \u0431\u044B\u043B
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430
    \u0432 \u0422\u0443\u0440\u0438\u043D\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u043E\u0441\u044C
    \u0432 \u0422\u0443\u0440\u0438\u043D\u0441\u043A\u0443\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E
    \u043D\u0430\u0443\u043A. \u0412 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F\u0445
    \u044D\u0442\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430,
    \"M\xE9langes de Turin\", \u0431\u044B\u043B\u0438 \u043D\u0430\u043F\u0435\u0447\u0430\u0442\u0430\u043D\u044B
    \u0435\u0433\u043E \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435,
    \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439. *  
    **\u041F\u0435\u0440\u0432\u044B\u0439 \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u0439
    \u0443\u0441\u043F\u0435\u0445**: \u0412 **1764 \u0433\u043E\u0434\u0443** \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0430\u044F
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044F \u043D\u0430\u0443\u043A \u043F\u0440\u0438\u0441\u0443\u0434\u0438\u043B\u0430
    \u0435\u043C\u0443 \u043F\u0440\u0435\u043C\u0438\u044E \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u0443
    \u043F\u043E \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0435 \u043B\u0438\u0431\u0440\u0430\u0446\u0438\u0438
    \u041B\u0443\u043D\u044B (\u0435\u0451 \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u0439).
    \u0412 **1766 \u0433\u043E\u0434\u0443** \u043E\u043D \u0441\u043D\u043E\u0432\u0430
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0440\u0435\u043C\u0438\u044E
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u0437\u0430 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u043E\u0432
    \u042E\u043F\u0438\u0442\u0435\u0440\u0430.  ### \U0001F451 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434: \u0433\u043E\u0434\u044B \u0440\u0430\u0441\u0446\u0432\u0435\u0442\u0430
    (1766\u20131787)  \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u0441\u0430\u043C\u043E\u0435
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u043E\u0435 \u0432\u0440\u0435\u043C\u044F
    \u0432 \u043A\u0430\u0440\u044C\u0435\u0440\u0435 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430. 
    *   **\u041F\u0435\u0440\u0435\u0435\u0437\u0434 \u0432 \u0411\u0435\u0440\u043B\u0438\u043D**:
    \u0412 **1766 \u0433\u043E\u0434\u0443**, \u043F\u043E \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u0438
    \u042D\u0439\u043B\u0435\u0440\u0430 \u0438 \u0414'\u0410\u043B\u0430\u043C\u0431\u0435\u0440\u0430,
    \u043F\u0440\u0443\u0441\u0441\u043A\u0438\u0439 \u043A\u043E\u0440\u043E\u043B\u044C
    \u0424\u0440\u0438\u0434\u0440\u0438\u0445 II \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430 \u0432 \u0411\u0435\u0440\u043B\u0438\u043D,
    \u0447\u0442\u043E\u0431\u044B \"\u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0439
    \u043A\u043E\u0440\u043E\u043B\u044C \u0415\u0432\u0440\u043E\u043F\u044B\" \u0438\u043C\u0435\u043B
    \u043F\u0440\u0438 \u0441\u0432\u043E\u0451\u043C \u0434\u0432\u043E\u0440\u0435
    \"\u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0415\u0432\u0440\u043E\u043F\u044B\". \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u043B \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A, \u0441\u043C\u0435\u043D\u0438\u0432
    \u043D\u0430 \u044D\u0442\u043E\u043C \u043F\u043E\u0441\u0442\u0443 \u042D\u0439\u043B\u0435\u0440\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0443\u0435\u0445\u0430\u043B \u0432
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433. *   **\u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C**: \u0412 **1767 \u0433\u043E\u0434\u0443** \u043E\u043D
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u0441\u0432\u043E\u0435\u0439
    \u043A\u0443\u0437\u0438\u043D\u0435 \u0412\u0438\u0442\u0442\u043E\u0440\u0438\u0438
    \u041A\u043E\u043D\u0442\u0438. \u0411\u0440\u0430\u043A \u0431\u044B\u043B \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C,
    \u043D\u043E \u0431\u0435\u0437\u0434\u0435\u0442\u043D\u044B\u043C. \u0412 **1783
    \u0433\u043E\u0434\u0443** \u0435\u0433\u043E \u0441\u0443\u043F\u0440\u0443\u0433\u0430
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C. *   **\u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F**:    
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B**:
    \u0414\u043E\u043A\u0430\u0437\u0430\u043B \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0439 \u0424\u0435\u0440\u043C\u0430
    \u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **\u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u0412\u0438\u043B\u044C\u0441\u043E\u043D\u0430**: \u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0433\u043E
    \u043F\u0440\u043E\u0441\u0442\u043E\u0433\u043E \u0447\u0438\u0441\u043B\u0430
    `p` \u0447\u0438\u0441\u043B\u043E `(p-1)! + 1` \u0434\u0435\u043B\u0438\u0442\u0441\u044F
    \u043D\u0430 `p`.     *   **\u0410\u043B\u0433\u0435\u0431\u0440\u0430**: \u0412
    \u0440\u0430\u0431\u043E\u0442\u0435 **\"\u0420\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F
    \u043E\u0431 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0440\u0435\u0448\u0435\u043D\u0438\u0438 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439\"**
    (1770-1771) \u043E\u043D \u0432\u043F\u043B\u043E\u0442\u043D\u0443\u044E \u043F\u043E\u0434\u043E\u0448\u0451\u043B
    \u043A \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0443\u043F\u043F \u043F\u043E\u0434\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A,
    \u0437\u0430\u043B\u043E\u0436\u0438\u0432 \u043E\u0441\u043D\u043E\u0432\u0443
    \u0434\u043B\u044F \u0431\u0443\u0434\u0443\u0449\u0438\u0445 \u0440\u0430\u0431\u043E\u0442
    \u0410\u0431\u0435\u043B\u044F \u0438 \u0413\u0430\u043B\u0443\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B\u0438, \u0447\u0442\u043E \u043E\u0431\u0449\u0438\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0432\u044B\u0448\u0435
    4-\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u043D\u0435 \u0440\u0435\u0448\u0430\u044E\u0442\u0441\u044F
    \u0432 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0430\u0445.     *   **\u041D\u0435\u0431\u0435\u0441\u043D\u0430\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430**: \u0412 **1772 \u0433\u043E\u0434\u0443**
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0432\u0430\u0436\u043D\u044B\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0432 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    **\u0437\u0430\u0434\u0430\u0447\u0435 \u0442\u0440\u0451\u0445 \u0442\u0435\u043B**,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044E
    \u0442\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u044B\u0445
    **\u0442\u043E\u0447\u0435\u043A \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430**
    \u2014 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439 \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0432 \u0441\u0438\u0441\u0442\u0435\u043C\u0435 \u0434\u0432\u0443\u0445 \u043C\u0430\u0441\u0441\u0438\u0432\u043D\u044B\u0445
    \u0442\u0435\u043B. *   **\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434**:
    \u0412 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D
    \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u043B \u0441\u0432\u043E\u0439
    magnum opus \u2014 \u043A\u043D\u0438\u0433\u0443 **\"\u0410\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430\"**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430
    \u0432 **1788 \u0433\u043E\u0434\u0443** \u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0435\u0433\u043E \u043F\u0435\u0440\u0435\u0435\u0437\u0434\u0430 \u0432 \u041F\u0430\u0440\u0438\u0436.
    \u042D\u0442\u043E \u0431\u044B\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u043E\u043D
    \u0441\u0432\u0435\u043B \u0432\u0441\u044E \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443
    \u043A \u0435\u0434\u0438\u043D\u044B\u043C \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C \u0438 \u0433\u0434\u0435,
    \u043F\u043E \u0435\u0433\u043E \u0433\u043E\u0440\u0434\u043E\u043C\u0443 \u0437\u0430\u043C\u0435\u0447\u0430\u043D\u0438\u044E,
    **\"\u043D\u0435\u043B\u044C\u0437\u044F \u043D\u0430\u0439\u0442\u0438 \u043D\u0438
    \u043E\u0434\u043D\u043E\u0433\u043E \u0447\u0435\u0440\u0442\u0435\u0436\u0430\"**. 
    ### \U0001F956 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0439 \u043F\u0435\u0440\u0438\u043E\u0434:
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C (1787\u20131813) 
    \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430
    II \u0432 **1787 \u0433\u043E\u0434\u0443** \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u043F\u0440\u0438\u043D\u044F\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u044F
    \u041B\u044E\u0434\u043E\u0432\u0438\u043A\u0430 XVI \u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u041F\u0430\u0440\u0438\u0436.  *   **\u0410\u043A\u0430\u0434\u0435\u043C\u0438\u044F
    \u0438 \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F**: \u041E\u043D
    \u0441\u0442\u0430\u043B \u0447\u043B\u0435\u043D\u043E\u043C \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A. \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0430\u044F
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F \u043E\u0431\u043E\u0448\u043B\u0430\u0441\u044C
    \u0441 \u043D\u0438\u043C \u0441\u043D\u0438\u0441\u0445\u043E\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E:
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0435\u043D\u0441\u0438\u044E
    \u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0440\u0430\u0431\u043E\u0442\u0435 \u043A\u043E\u043C\u0438\u0441\u0441\u0438\u0438
    \u043F\u043E \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0435 **\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043C\u0435\u0440 \u0438 \u0432\u0435\u0441\u043E\u0432**.
    *   **\u041D\u043E\u0432\u044B\u0439 \u0431\u0440\u0430\u043A**: \u0412 **1792
    \u0433\u043E\u0434\u0443** \u043E\u043D \u0432\u0442\u043E\u0440\u0438\u0447\u043D\u043E
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u0420\u0435\u043D\u0435-\u0424\u0440\u0430\u043D\u0441\u0443\u0430\u0437\u0435-\u0410\u0434\u0435\u043B\u0430\u0438\u0434\u0435
    \u041B\u0435\u043C\u043E\u043D\u044C\u0435, \u0434\u043E\u0447\u0435\u0440\u0438
    \u0441\u0432\u043E\u0435\u0433\u043E \u0434\u0440\u0443\u0433\u0430-\u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430.
    \u042D\u0442\u043E\u0442 \u0431\u0440\u0430\u043A \u0442\u0430\u043A\u0436\u0435
    \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C.
    *   **\u041F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C**:    
    *   \u0412 **1795 \u0433\u043E\u0434\u0443** \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0432 \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0439
    \u041D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u0435.    
    *   \u0421 **1797 \u0433\u043E\u0434\u0430** \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0432 \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435, \u043F\u0440\u0438 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438
    \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u0442\u043E\u0436\u0435
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B.     *   \u0415\u0433\u043E
    \u043B\u0435\u043A\u0446\u0438\u0438 \u043B\u0435\u0433\u043B\u0438 \u0432 \u043E\u0441\u043D\u043E\u0432\u0443
    \u0442\u0440\u0443\u0434\u043E\u0432 **\"\u0422\u0435\u043E\u0440\u0438\u044F
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439\"** (1797) \u0438 **\"\u041B\u0435\u043A\u0446\u0438\u0438
    \u043E\u0431 \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u0439\"**
    (1801). \u0412 \u044D\u0442\u0438\u0445 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    \u043E\u043D \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F \u0434\u0430\u0442\u044C
    \u0441\u0442\u0440\u043E\u0433\u043E\u0435, \u0447\u0438\u0441\u0442\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0430\u043D\u0430\u043B\u0438\u0437\u0443, \u0432\u0432\u0435\u043B \u0444\u043E\u0440\u043C\u0443\u043B\u0443
    \u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u0433\u043E \u0447\u043B\u0435\u043D\u0430
    \u0440\u044F\u0434\u0430 \u0422\u0435\u0439\u043B\u043E\u0440\u0430 \u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    **\u043C\u0435\u0442\u043E\u0434 \u043C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u0435\u0439
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430** \u0434\u043B\u044F \u043F\u043E\u0438\u0441\u043A\u0430
    \u0443\u0441\u043B\u043E\u0432\u043D\u043E\u0433\u043E \u044D\u043A\u0441\u0442\u0440\u0435\u043C\u0443\u043C\u0430.
    *   **\u041F\u043E\u0447\u0435\u0441\u0442\u0438 \u043E\u0442 \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D\u0430**:
    \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D \u0411\u043E\u043D\u0430\u043F\u0430\u0440\u0442,
    \u0432\u043E\u0441\u0445\u0438\u0449\u0430\u0432\u0448\u0438\u0439\u0441\u044F
    \u0443\u0447\u0451\u043D\u044B\u043C, \u043E\u0441\u044B\u043F\u0430\u043B \u0435\u0433\u043E
    \u043F\u043E\u0447\u0435\u0441\u0442\u044F\u043C\u0438: \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u043B
    \u0442\u0438\u0442\u0443\u043B \u0433\u0440\u0430\u0444\u0430, \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u0441\u0435\u043D\u0430\u0442\u043E\u0440\u0430 \u0438 \u043E\u0440\u0434\u0435\u043D
    \u041F\u043E\u0447\u0435\u0442\u043D\u043E\u0433\u043E \u043B\u0435\u0433\u0438\u043E\u043D\u0430. 
    ### \U0001F4DD \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  *   **\u041A\u043E\u043D\u0447\u0438\u043D\u0430**:
    \u0416\u043E\u0437\u0435\u0444 \u041B\u0443\u0438 \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 \u041F\u0430\u0440\u0438\u0436\u0435
    **10 \u0430\u043F\u0440\u0435\u043B\u044F 1813 \u0433\u043E\u0434\u0430** \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 77 \u043B\u0435\u0442. \u041F\u043E
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u043E\u043D \u0443\u0448\u0435\u043B \u0438\u0437 \u0436\u0438\u0437\u043D\u0438
    \u0442\u0430\u043A \u0436\u0435 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E,
    \u043A\u0430\u043A \u0438 \u0436\u0438\u043B, \u0438 \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441:
    *\"\u042F \u0441\u0434\u0435\u043B\u0430\u043B \u0441\u0432\u043E\u0451 \u0434\u0435\u043B\u043E...
    \u042F \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0438\u043A\u043E\u0433\u043E
    \u043D\u0435 \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B \u0438 \u043D\u0435
    \u0434\u0435\u043B\u0430\u043B \u043D\u0438\u043A\u043E\u043C\u0443 \u0437\u043B\u0430\"*.
    *   **\u041F\u043E\u0447\u0435\u0441\u0442\u0438**: \u041E\u043D \u0431\u044B\u043B
    \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D \u0441 \u0432\u044B\u0441\u0448\u0438\u043C\u0438
    \u043F\u043E\u0447\u0435\u0441\u0442\u044F\u043C\u0438 \u0432 \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u043C
    **\u041F\u0430\u043D\u0442\u0435\u043E\u043D\u0435**.  \u0418\u0434\u0435\u0438
    \u0438 \u043C\u0435\u0442\u043E\u0434\u044B \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430
    \u2014 \u043E\u0442 \u043E\u0431\u043E\u0431\u0449\u0451\u043D\u043D\u044B\u0445
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442 \u0432 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435
    \u0434\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0443\u043F\u043F
    \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0435 \u2014 \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0438 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u043D\u0430\u0443\u043A\u0438 \u0438 \u043D\u0430\u0448\u043B\u0438 \u0441\u0432\u043E\u0451
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0435\u043D\u0438\u0435 \u0432 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    \u041A\u043E\u0448\u0438, \u041F\u0443\u0430\u0441\u0441\u043E\u043D\u0430, \u0410\u0431\u0435\u043B\u044F
    \u0438 \u0413\u0430\u043B\u0443\u0430."
  shortBioEn: 
  interestingFactsRu: "\u0417\u0430 \u043D\u0430\u0443\u043A\u043E\u0439 \u0432\u0441\u0435\u0433\u0434\u0430
    \u0441\u0442\u043E\u044F\u0442 \u0436\u0438\u0432\u044B\u0435 \u043B\u044E\u0434\u0438
    \u0441\u043E \u0441\u0432\u043E\u0438\u043C\u0438 \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0430\u043C\u0438,
    \u0441\u043B\u0430\u0431\u043E\u0441\u0442\u044F\u043C\u0438 \u0438 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F\u043C\u0438. \u0416\u043E\u0437\u0435\u0444
    \u041B\u0443\u0438 \u041B\u0430\u0433\u0440\u0430\u043D\u0436 \u043D\u0435 \u0431\u044B\u043B
    \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435\u043C \u2014 \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C \u043F\u043E\u043B\u043D\u0430 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0441\u0442\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u0435\u043B\u0430\u044E\u0442 \u0435\u0433\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0438\u043C\u0435\u043D\u0435\u043C \u0432 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0430\u0445,
    \u0430 \u043E\u0447\u0435\u043D\u044C \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E\u0439
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C\u044E.  ### \U0001F4B0 \u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F
    \u0431\u0435\u0434\u043D\u043E\u0441\u0442\u0438: \xAB\u0415\u0441\u043B\u0438
    \u0431\u044B \u044F \u0431\u044B\u043B \u0431\u043E\u0433\u0430\u0442...\xBB 
    \u041F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u044B\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0430\u0444\u043E\u0440\u0438\u0437\u043C \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430
    \u0441\u0432\u044F\u0437\u0430\u043D \u0441 \u0435\u0433\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435\u043C.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446 \u0440\u0430\u0437\u043E\u0440\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0445 \u0441\u043F\u0435\u043A\u0443\u043B\u044F\u0446\u0438\u044F\u0445,
    \u0438 \u044D\u0442\u043E \u0441\u043E\u0431\u044B\u0442\u0438\u0435, \u043F\u043E
    \u043C\u043D\u0435\u043D\u0438\u044E \u0441\u0430\u043C\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E,
    \u0441\u0442\u0430\u043B\u043E \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0431\u043B\u0430\u0433\u043E\u043C.
    \u041E\u043D \u0447\u0430\u0441\u0442\u043E \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u043B:
    **\xAB\u0415\u0441\u043B\u0438 \u0431\u044B \u044F \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435, \u044F, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u043D\u0435 \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B \u0431\u044B \u0441\u0435\u0431\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435\xBB**. \u0420\u0430\u0437\u043E\u0440\u0435\u043D\u0438\u0435
    \u0441\u0435\u043C\u044C\u0438, \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043E\u0431\u044B\u0447\u043D\u043E
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439,
    \u0432 \u0435\u0433\u043E \u0441\u043B\u0443\u0447\u0430\u0435 \u0441\u0442\u0430\u043B\u043E
    \u043C\u043E\u0449\u043D\u0435\u0439\u0448\u0438\u043C \u043C\u043E\u0442\u0438\u0432\u0430\u0442\u043E\u0440\u043E\u043C
    \u043D\u0430 \u043F\u0443\u0442\u0438 \u043A \u043D\u0430\u0443\u043A\u0435. 
    ### \U0001F3B5 \u041C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u043E\u0435
    \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0435\u043D\u0438\u0435  \u0423 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430
    \u0431\u044B\u043B\u0430 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u0430\u044F
    \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0430, \u043F\u043E\u043C\u043E\u0433\u0430\u0432\u0448\u0430\u044F
    \u0435\u043C\u0443 \u0432 \u0440\u0430\u0431\u043E\u0442\u0435. \u041E\u043D
    \u0431\u044B\u043B \u0431\u043E\u043B\u044C\u0448\u0438\u043C \u043B\u044E\u0431\u0438\u0442\u0435\u043B\u0435\u043C
    \u043C\u0443\u0437\u044B\u043A\u0438 \u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0435\u0451 \u043A\u0430\u043A \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442
    \u0434\u043B\u044F \u043A\u043E\u043D\u0446\u0435\u043D\u0442\u0440\u0430\u0446\u0438\u0438.
    \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438 \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B\u0438,
    \u0447\u0442\u043E \u043E\u043D \u043C\u043E\u0433 \u0441\u0438\u0434\u0435\u0442\u044C
    \u0432 \u043A\u0440\u0435\u0441\u043B\u0435 \u0438 \u0441\u043B\u0443\u0448\u0430\u0442\u044C
    \u043C\u0443\u0437\u044B\u043A\u0443, \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0433\u0440\u0443\u0436\u0430\u044F\u0441\u044C \u0432 \u0441\u0432\u043E\u0438
    \u043C\u044B\u0441\u043B\u0438. \u041E\u043D \u0433\u043E\u0432\u043E\u0440\u0438\u043B,
    \u0447\u0442\u043E **\xAB\u043F\u043E\u0441\u043B\u0435 \u0442\u0440\u0435\u0442\u044C\u0435\u0439
    \u043D\u043E\u0442\u044B \u044F \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435
    \u0441\u043B\u044B\u0448\u0443\u2026 \u0438 \u0432\u0441\u0451, \u0447\u0442\u043E
    \u044F \u0437\u043D\u0430\u044E \u043F\u043E\u0442\u043E\u043C, \u2014 \u044D\u0442\u043E
    \u0442\u043E, \u0447\u0442\u043E \u044F \u0440\u0435\u0448\u0438\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0437\u0430\u0434\u0430\u0447\u0443\xBB**. \u041C\u0443\u0437\u044B\u043A\u0430
    \u0441\u043B\u0443\u0436\u0438\u043B\u0430 \u0435\u043C\u0443 \u0441\u0432\u043E\u0435\u043E\u0431\u0440\u0430\u0437\u043D\u044B\u043C
    \xAB\u0431\u0435\u043B\u044B\u043C \u0448\u0443\u043C\u043E\u043C\xBB, \u043E\u0442\u0441\u0435\u043A\u0430\u044E\u0449\u0438\u043C
    \u0432\u043D\u0435\u0448\u043D\u0438\u0435 \u0440\u0430\u0437\u0434\u0440\u0430\u0436\u0438\u0442\u0435\u043B\u0438
    \u0438 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0438\u043C \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0438\u0442\u044C\u0441\u044F
    \u043D\u0430 \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F\u0445. 
    ### \U0001F5E3\uFE0F \u0421\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0430\u043D\u0442\u0438\u043F\u0430\u0442\u0438\u044F \u043A \u0441\u043F\u043E\u0440\u0430\u043C 
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436 \u043E\u0431\u043B\u0430\u0434\u0430\u043B
    \u043A\u0440\u0430\u0439\u043D\u0435 \u043C\u0438\u0440\u043E\u043B\u044E\u0431\u0438\u0432\u044B\u043C
    \u0438 \u0434\u0435\u043B\u0438\u043A\u0430\u0442\u043D\u044B\u043C \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C,
    \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u0440\u0435\u0434\u043A\u043E\u0441\u0442\u044C\u044E
    \u0432 \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0441\u0440\u0435\u0434\u0435,
    \u043F\u043E\u043B\u043D\u043E\u0439 \u0430\u043C\u0431\u0438\u0446\u0438\u0439
    \u0438 \u0441\u043F\u043E\u0440\u043E\u0432.  *   **\xAB\u042F \u043D\u0435 \u0437\u043D\u0430\u044E\xBB**:
    \u0415\u0433\u043E \u043B\u044E\u0431\u0438\u043C\u043E\u0439 \u0444\u0440\u0430\u0437\u043E\u0439
    \u0432 \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u044F\u0445 \u0431\u044B\u043B\u043E
    \u043F\u0440\u043E\u0441\u0442\u043E\u0435 **\xAB\u042F \u043D\u0435 \u0437\u043D\u0430\u044E\xBB**
    (Je ne sais pas). \u041E\u043D \u043D\u0435 \u043B\u044E\u0431\u0438\u043B \u0441\u043F\u043E\u0440\u0438\u0442\u044C
    \u0438 \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u043B \u0438\u0437\u0431\u0435\u0433\u0430\u0442\u044C
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u043E\u0432, \u0447\u0442\u043E
    \u0440\u0435\u0437\u043A\u043E \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u043E
    \u0441 \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435\u043C \u043C\u043D\u043E\u0433\u0438\u0445
    \u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E \u041F\u044C\u0435\u0440\u0430-\u0421\u0438\u043C\u043E\u043D\u0430
    \u041B\u0430\u043F\u043B\u0430\u0441\u0430. *   **\u0418\u0440\u043E\u043D\u0438\u044F
    \u043D\u0430\u0434 \u0442\u0438\u0442\u0443\u043B\u0430\u043C\u0438**: \u0414\u0430\u0436\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D
    \u0441\u0434\u0435\u043B\u0430\u043B \u0435\u0433\u043E \u0441\u0435\u043D\u0430\u0442\u043E\u0440\u043E\u043C
    \u0438 \u0433\u0440\u0430\u0444\u043E\u043C, \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F \u0438\u0440\u043E\u043D\u0438\u0447\u043D\u044B\u043C
    \u043F\u043E \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044E \u043A \u0432\u043D\u0435\u0448\u043D\u0438\u043C
    \u0430\u0442\u0440\u0438\u0431\u0443\u0442\u0430\u043C \u0432\u043B\u0430\u0441\u0442\u0438.
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435 \u043D\u0430
    \u043E\u0431\u0435\u0434 \u043E\u0442 \u043A\u043E\u043B\u043B\u0435\u0433\u0438-\u0441\u0435\u043D\u0430\u0442\u043E\u0440\u0430,
    \u043E\u043D \u0441 \u0443\u043B\u044B\u0431\u043A\u043E\u0439 \u0441\u043F\u0440\u043E\u0441\u0438\u043B:
    **\xAB\u041D\u0443\u0436\u043D\u043E \u043B\u0438 \u0431\u0443\u0434\u0435\u0442
    \u043D\u0430\u0434\u0435\u0442\u044C \u0441\u0435\u043D\u0430\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443?\xBB**, \u0447\u0435\u043C \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u043D\u0443\u043B
    \u0441\u0432\u043E\u044E \u0438\u0440\u043E\u043D\u0438\u044E \u043D\u0430\u0434
    \u0441\u0432\u0435\u0442\u0441\u043A\u0438\u043C\u0438 \u0443\u0441\u043B\u043E\u0432\u043D\u043E\u0441\u0442\u044F\u043C\u0438. 
    ### \U0001F3DB\uFE0F \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441
    \u0432\u043B\u0430\u0441\u0442\u044C\u044E: \u043E\u0442 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438
    \u0434\u043E \u0438\u043C\u043F\u0435\u0440\u0438\u0438  \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u043F\u0435\u0440\u0435\u0436\u0438\u043B \u0431\u0443\u0440\u043D\u044B\u0435
    \u0432\u0440\u0435\u043C\u0435\u043D\u0430 \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438 \u0438 \u0441\u043C\u0435\u043D\u0443
    \u0440\u0435\u0436\u0438\u043C\u043E\u0432, \u0438 \u0435\u0433\u043E \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0432\u043B\u0430\u0441\u0442\u044C\u044E \u043F\u043E\u043B\u043D\u044B
    \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u0432.  *   **\u0418\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435
    \u0438\u0437 \u043F\u0440\u0430\u0432\u0438\u043B**: \u0412\u043E \u0432\u0440\u0435\u043C\u044F
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438 \u0431\u044B\u043B \u043F\u0440\u0438\u043D\u044F\u0442
    \u0434\u0435\u043A\u0440\u0435\u0442 \u043E\u0431 \u0438\u0437\u0433\u043D\u0430\u043D\u0438\u0438
    \u0438\u0437 \u0424\u0440\u0430\u043D\u0446\u0438\u0438 \u0432\u0441\u0435\u0445
    \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u0446\u0435\u0432, \u043E\u0434\u043D\u0430\u043A\u043E
    \u0434\u043B\u044F \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430, \u0440\u043E\u0436\u0434\u0435\u043D\u043D\u043E\u0433\u043E
    \u0432 \u0422\u0443\u0440\u0438\u043D\u0435, \u0431\u044B\u043B\u043E \u0441\u0434\u0435\u043B\u0430\u043D\u043E
    \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435 \u2014 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0435
    \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u043E \u0435\u0433\u043E \u0432 \u041F\u0430\u0440\u0438\u0436\u0435.
    *   **\u0421\u043C\u0435\u0440\u0442\u044C \u041B\u0430\u0432\u0443\u0430\u0437\u044C\u0435**:
    \u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F \u0444\u0440\u0430\u0437\u0430
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430 \u0431\u044B\u043B\u0430 \u0441\u043A\u0430\u0437\u0430\u043D\u0430
    \u043F\u043E\u0441\u043B\u0435 \u043A\u0430\u0437\u043D\u0438 \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u0445\u0438\u043C\u0438\u043A\u0430 \u0410\u043D\u0442\u0443\u0430\u043D\u0430
    \u041B\u0430\u0432\u0443\u0430\u0437\u044C\u0435. \u0423\u0437\u043D\u0430\u0432
    \u043E\u0431 \u044D\u0442\u043E\u043C, \u041B\u0430\u0433\u0440\u0430\u043D\u0436
    \u0432\u043E\u0441\u043A\u043B\u0438\u043A\u043D\u0443\u043B: **\xAB\u0418\u043C
    \u043F\u043E\u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u043E\u0441\u044C
    \u043B\u0438\u0448\u044C \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u0438\u0435,
    \u0447\u0442\u043E\u0431\u044B \u043E\u0442\u0440\u0443\u0431\u0438\u0442\u044C
    \u044D\u0442\u0443 \u0433\u043E\u043B\u043E\u0432\u0443, \u043D\u043E \u0438
    \u0441\u0442\u0430 \u043B\u0435\u0442 \u043D\u0435 \u0445\u0432\u0430\u0442\u0438\u0442,
    \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0441\u0442\u0438
    \u0435\u0449\u0451 \u043E\u0434\u043D\u0443 \u0442\u0430\u043A\u0443\u044E \u0436\u0435\xBB**.
    *   **\xAB\u041F\u0438\u0440\u0430\u043C\u0438\u0434\u0430 \u043D\u0430\u0443\u043A\xBB**:
    \u041F\u0440\u0438\u0448\u0435\u0434\u0448\u0438\u0439 \u043A \u0432\u043B\u0430\u0441\u0442\u0438
    \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D \u0411\u043E\u043D\u0430\u043F\u0430\u0440\u0442
    \u0431\u043E\u0433\u043E\u0442\u0432\u043E\u0440\u0438\u043B \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430
    \u0438 \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0435\u0433\u043E **\xAB\u0432\u044B\u0441\u043E\u043A\u043E\u0439
    \u043F\u0438\u0440\u0430\u043C\u0438\u0434\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A\xBB**. \u0418\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440
    \u043B\u044E\u0431\u0438\u043B \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u0442\u044C
    \u0441 \u043D\u0438\u043C \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435
    \u0432\u043E\u043F\u0440\u043E\u0441\u044B \u0438 \u043E\u0441\u044B\u043F\u0430\u043B
    \u0435\u0433\u043E \u043F\u043E\u0447\u0435\u0441\u0442\u044F\u043C\u0438.  ###
    \U0001F9E0 \u0425\u0440\u0443\u043F\u043A\u043E\u0441\u0442\u044C \u0433\u0435\u043D\u0438\u044F:
    \u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u044F \u0438 \u043F\u0435\u0440\u0435\u0443\u0442\u043E\u043C\u043B\u0435\u043D\u0438\u0435 
    \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430
    \u0434\u0430\u0432\u0430\u043B\u0430\u0441\u044C \u0435\u043C\u0443 \u0446\u0435\u043D\u043E\u0439
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0433\u043E \u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u0438\u044F.
    \u0423\u0436\u0435 \u043A 25 \u0433\u043E\u0434\u0430\u043C \u043E\u043D \u0431\u044B\u043B
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043F\u0435\u0440\u0435\u0443\u0442\u043E\u043C\u043B\u0435\u043D,
    \u0447\u0442\u043E \u0432\u0440\u0430\u0447\u0438 \u0432 1761 \u0433\u043E\u0434\u0443
    \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0434\u0438\u043B\u0438
    \u0435\u0433\u043E: \u0435\u0441\u043B\u0438 \u043E\u043D \u043D\u0435 \u0438\u0437\u043C\u0435\u043D\u0438\u0442
    \u0441\u0432\u043E\u0439 \u0440\u0430\u0431\u043E\u0447\u0438\u0439 \u0433\u0440\u0430\u0444\u0438\u043A,
    \u043E\u043D\u0438 \u043D\u0435 \u043E\u0442\u0432\u0435\u0447\u0430\u044E\u0442
    \u0437\u0430 \u0435\u0433\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435. 
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u043F\u0440\u0438\u0441\u043B\u0443\u0448\u0430\u043B\u0441\u044F
    \u043A \u0441\u043E\u0432\u0435\u0442\u0430\u043C, \u043D\u043E \u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u044F
    \u0438 \u0430\u043F\u0430\u0442\u0438\u044F \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0436\u0438\u0437\u043D\u0438.
    \u0412 \u043F\u0438\u0441\u044C\u043C\u0435 \u0441\u0432\u043E\u0435\u043C\u0443
    \u043A\u043E\u043B\u043B\u0435\u0433\u0435 \u0414'\u0410\u043B\u0430\u043C\u0431\u0435\u0440\u0443
    \u0432 1776 \u0433\u043E\u0434\u0443 (\u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    40 \u043B\u0435\u0442) \u043E\u043D \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B\u0441\u044F:
    *\xAB\u042F \u043D\u0430\u0447\u0438\u043D\u0430\u044E \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C,
    \u043A\u0430\u043A \u0432\u043E \u043C\u043D\u0435 \u043D\u0430\u0440\u0430\u0441\u0442\u0430\u0435\u0442
