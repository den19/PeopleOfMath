  achievementsRu: "\u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434\u0430 \u0420\u0438\u043C\u0430\u043D\u0430,
    \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0435\u0433\u043E
    \u043A\u043E\u0440\u043E\u0442\u043A\u0443\u044E \u0436\u0438\u0437\u043D\u044C
    (\u0432\u0441\u0435\u0433\u043E \u043E\u043A\u043E\u043B\u043E \u0434\u0435\u0441\u044F\u0442\u0438
    \u043B\u0435\u0442 \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u044B),
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u043E \u043E\u0431\u043B\u0438\u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0415\u0433\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434\u044B, \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u043E
    \u043D\u043E\u0432\u044B\u0435 \u0434\u043B\u044F XIX \u0432\u0435\u043A\u0430,
    \u0441\u0442\u0430\u043B\u0438 \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C
    \u043A\u0430\u043C\u043D\u0435\u043C \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0434\u043B\u044F \u043C\u043D\u043E\u0433\u0438\u0445 \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432
    \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u043D\u043E \u0438 \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438. \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439, \u043A\u0430\u0436\u0434\u0430\u044F
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442
    \u0440\u0430\u0431\u043E\u0442\u044B, \u0441\u0442\u0430\u0432\u0448\u0438\u0435
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F \u0446\u0435\u043B\u044B\u0445
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439. 
    ### \U0001F9EE \u0420\u0438\u043C\u0430\u043D\u043E\u0432\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:
    \u041D\u043E\u0432\u0430\u044F \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430 \u042D\u0442\u043E,
    \u0431\u0435\u0437\u0443\u0441\u043B\u043E\u0432\u043D\u043E, \u0441\u0430\u043C\u043E\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435 \u0438 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0420\u0438\u043C\u0430\u043D\u0430,
    \u0437\u0430\u043B\u043E\u0436\u0438\u0432\u0448\u0435\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0434\u043B\u044F \u043E\u0431\u0449\u0435\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430.  *   **\u0418\u043D\u0430\u0443\u0433\u0443\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u0430\u044F
    \u043B\u0435\u043A\u0446\u0438\u044F (1854 \u0433.)**: \u0412 \u0441\u0432\u043E\u0435\u0439
    \u043F\u0440\u043E\u0431\u043D\u043E\u0439 \u043B\u0435\u043A\u0446\u0438\u0438
    **\xAB\u041E \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430\u0445, \u043B\u0435\u0436\u0430\u0449\u0438\u0445
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB**
    (\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430 \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E
    \u0432 1868 \u0433.) , \u0420\u0438\u043C\u0430\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E \u043D\u043E\u0432\u044B\u0439
    \u0432\u0437\u0433\u043B\u044F\u0434 \u043D\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E.
    \u041E\u043D \u043E\u0431\u043E\u0431\u0449\u0438\u043B \u0438\u0434\u0435\u0438
    \u0413\u0430\u0443\u0441\u0441\u0430 \u043E \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0435\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439
    \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u043B\u044C\u043D\u043E\u0439 \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438
    (\u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u044F). *  
    **\u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u044F**:
    \u041E\u043D \u0432\u0432\u0435\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F **\u0440\u0438\u043C\u0430\u043D\u043E\u0432\u043E\u0439
    \u043C\u0435\u0442\u0440\u0438\u043A\u0438** (\u0441\u043F\u043E\u0441\u043E\u0431\u0430
    \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0439
    \u043C\u0435\u0436\u0434\u0443 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E
    \u0431\u043B\u0438\u0437\u043A\u0438\u043C\u0438 \u0442\u043E\u0447\u043A\u0430\u043C\u0438)
    \u0438 **\u0442\u0435\u043D\u0437\u043E\u0440\u0430 \u043A\u0440\u0438\u0432\u0438\u0437\u043D\u044B**.
    \u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u0415\u0432\u043A\u043B\u0438\u0434\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043B\u0438\u0448\u044C \u0447\u0430\u0441\u0442\u043D\u044B\u043C
    \u0441\u043B\u0443\u0447\u0430\u0435\u043C \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438\u0437 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0445 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432.
    *   **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435**: \u042D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430 \xAB\u0441\u0432\u0435\u0440\u0433\u043B\u0430
    \u0441 \u0442\u0440\u043E\u043D\u0430\xBB \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u0443
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u043A\u0430\u043A \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0435 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043C\u0438\u0440\u0430.
    \u0420\u0438\u043C\u0430\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430
    \u0434\u043E\u043B\u0436\u043D\u044B \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442\u044C\u0441\u044F
    \u044D\u043C\u043F\u0438\u0440\u0438\u0447\u0435\u0441\u043A\u0438, \u0447\u0442\u043E
    \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u043B\u043E
    \u0438\u0434\u0435\u0438 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430
    \u043E \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u043C\u0435\u0440\u043D\u043E\u043C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435-\u0432\u0440\u0435\u043C\u0435\u043D\u0438. 
    ### \U0001F4D0 \u041A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0438 \u0420\u0438\u043C\u0430\u043D\u043E\u0432\u044B
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438 \u0415\u0433\u043E
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0430\u044F \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F
    (1851 \u0433.) **\xAB\u041E\u0441\u043D\u043E\u0432\u044B \u043E\u0431\u0449\u0435\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u043E\u0434\u043D\u043E\u0439 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E\u0439
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439\xBB** \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B\u0430
    \u043F\u0435\u0440\u0435\u0432\u043E\u0440\u043E\u0442 \u0432 \u044D\u0442\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438.  *   **\u0420\u0438\u043C\u0430\u043D\u043E\u0432\u044B
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438**: \u0414\u043B\u044F
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F \u043C\u043D\u043E\u0433\u043E\u0437\u043D\u0430\u0447\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u043E\u0433\u043E \u043A\u043E\u0440\u043D\u044F
    \u0438\u043B\u0438 \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0430) \u0420\u0438\u043C\u0430\u043D
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044E \u2014 **\u0440\u0438\u043C\u0430\u043D\u043E\u0432\u0443
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C**. \u041D\u0430
    \u0442\u0430\u043A\u043E\u0439 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    \u043C\u043D\u043E\u0433\u043E\u0437\u043D\u0430\u0447\u043D\u0430\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u044F
    \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E\u0439.
    *   **\u0422\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F \u0438 \u0440\u043E\u0434**:
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0442\u0430\u043A\u0438\u0435
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438 \u043C\u043E\u0436\u043D\u043E
    \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u0446\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u0430 \u2014 **\u0440\u043E\u0434\u0430**
    (\u0447\u0438\u0441\u043B\u0430 \xAB\u0440\u0443\u0447\u0435\u043A\xBB), \u0447\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0439 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. *   **\u0414\u0440\u0443\u0433\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B**: \u0412 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043E\u043D \u0442\u0430\u043A\u0436\u0435 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E **\u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439** (1857 \u0433.), \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u0442\u0430\u043B\u0430 \u0432\u0430\u0436\u043D\u044B\u043C \u0448\u0430\u0433\u043E\u043C
    \u0432 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u0445 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439
    , \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B **\u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u0420\u0438\u043C\u0430\u043D\u0430 \u043E\u0431 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0438**. 
    ### \U0001F4CA \u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B
    \u0438 \u0414\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u044F
    \u0420\u0438\u043C\u0430\u043D\u0430 \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0420\u0438\u043C\u0430\u043D\u0430 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B (1859 \u0433.) \u2014 **\xAB\u041E \u0447\u0438\u0441\u043B\u0435
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B, \u043D\u0435
    \u043F\u0440\u0435\u0432\u044B\u0448\u0430\u044E\u0449\u0438\u0445 \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u0439
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u044B\xBB** \u2014 \u0441\u0442\u0430\u043B\u0430
    \u043E\u0442\u043F\u0440\u0430\u0432\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u043E\u0439
    \u0434\u043B\u044F \u0446\u0435\u043B\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u2014 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B.  *   **\u0414\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u044F
    \u0420\u0438\u043C\u0430\u043D\u0430**: \u0420\u0438\u043C\u0430\u043D \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0438\u043B
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435 \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0438
    (\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439 \u0435\u0449\u0435 \u042D\u0439\u043B\u0435\u0440\u0443)
    \u043D\u0430 \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B. *   **\u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u0420\u0438\u043C\u0430\u043D\u0430**: \u0412 \u044D\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    \u043E\u043D \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    **\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443 \u0420\u0438\u043C\u0430\u043D\u0430**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0432\u0441\u0435 \u043D\u0435\u0442\u0440\u0438\u0432\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u043D\u0443\u043B\u0438 \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u0438
    \u043B\u0435\u0436\u0430\u0442 \u043D\u0430 \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439
    \u043F\u0440\u044F\u043C\u043E\u0439 `Re(s) = 1/2`. *   **\u0412\u043B\u0438\u044F\u043D\u0438\u0435**:
    \u042D\u0442\u0430 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430 \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440 \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0432\u0430\u0436\u043D\u044B\u0445
    \u043D\u0435\u0440\u0435\u0448\u0435\u043D\u043D\u044B\u0445 \u043F\u0440\u043E\u0431\u043B\u0435\u043C
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u0415\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043F\u0440\u043E\u043B\u0438\u043B\u043E \u0431\u044B \u0441\u0432\u0435\u0442
    \u043D\u0430 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B \u0438
    \u043E\u0442\u043A\u0440\u044B\u043B\u043E \u0431\u044B \u043D\u043E\u0432\u044B\u0435
    \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u044B \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u0437\u0430 \u0447\u0442\u043E \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u043E\u043C
    \u041A\u043B\u044D\u044F \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0430
    \u043F\u0440\u0435\u043C\u0438\u044F \u0432 1 \u043C\u0438\u043B\u043B\u0438\u043E\u043D
    \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432.  ### \u2699\uFE0F \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0438 \u0434\u0440\u0443\u0433\u0438\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0412\u043B\u0438\u044F\u043D\u0438\u0435
    \u0420\u0438\u043C\u0430\u043D\u0430 \u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0442\u0430\u043A\u0436\u0435 \u043E\u0433\u0440\u043E\u043C\u043D\u043E. 
    *   **\u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B \u0420\u0438\u043C\u0430\u043D\u0430**:
    \u0412 \u0441\u0432\u043E\u0435\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 \u043F\u043E
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0440\u044F\u0434\u0430\u043C (\u0433\u0430\u0431\u0438\u043B\u0438\u0442\u0430\u0446\u0438\u043E\u043D\u043D\u0430\u044F
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F 1854 \u0433.)
    \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u0442\u0440\u043E\u0433\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F,
    \u0432\u0432\u0435\u0434\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0432\u0441\u0435\u043C \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430\u043C
    **\u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B \u0420\u0438\u043C\u0430\u043D\u0430**.
    *   **\u0420\u044F\u0434\u044B \u0424\u0443\u0440\u044C\u0435**: \u041E\u043D
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0444\u0443\u043D\u043A\u0446\u0438\u044F,
    \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u0443\u0435\u043C\u0430\u044F
    \u043F\u043E \u0420\u0438\u043C\u0430\u043D\u0443, \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u0440\u044F\u0434\u043E\u043C \u0424\u0443\u0440\u044C\u0435, \u0438 \u043F\u0440\u0438\u0432\u0435\u043B
    \u043F\u0440\u0438\u043C\u0435\u0440 \u0444\u0443\u043D\u043A\u0446\u0438\u0438,
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0439 \u043F\u043E\u0447\u0442\u0438
    \u043D\u0438\u0433\u0434\u0435, \u043D\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043C\u043E\u0439
    \u0442\u0430\u043A\u0438\u043C \u0440\u044F\u0434\u043E\u043C, \u0447\u0442\u043E
    \u0441\u0442\u0438\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B\u043E
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432. *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u0438\u0437\u0438\u043A\u0430**: \u0420\u0438\u043C\u0430\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430\u043C\u0438: \u0438\u0437\u0443\u0447\u0430\u043B
    \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u0435
    \u043F\u043B\u043E\u0441\u043A\u0438\u0445 \u0437\u0432\u0443\u043A\u043E\u0432\u044B\u0445
    \u0432\u043E\u043B\u043D \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0439 \u0430\u043C\u043F\u043B\u0438\u0442\u0443\u0434\u044B
    (\u0432\u043E\u043B\u043D\u044B \u0420\u0438\u043C\u0430\u043D\u0430), \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435
    \u0436\u0438\u0434\u043A\u043E\u0433\u043E \u044D\u043B\u043B\u0438\u043F\u0441\u043E\u0438\u0434\u0430,
    \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0438 \u043C\u0430\u0433\u043D\u0435\u0442\u0438\u0437\u043C. \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u043B\u0435\u043A\u0446\u0438\u0438
    \u043F\u043E \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u0438, \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u0443
    \u0438 \u043C\u0430\u0433\u043D\u0435\u0442\u0438\u0437\u043C\u0443, \u0431\u044B\u043B\u0438
    \u0438\u0437\u0434\u0430\u043D\u044B \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E. 
    ### \U0001F4DC \u041F\u043E\u043B\u043D\u044B\u0439 \u043F\u0435\u0440\u0435\u0447\u0435\u043D\u044C
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u0442\u0440\u0443\u0434\u043E\u0432
    \u0420\u0438\u043C\u0430\u043D\u0430 \u0414\u043B\u044F \u043F\u043E\u043B\u043D\u043E\u0442\u044B
    \u043A\u0430\u0440\u0442\u0438\u043D\u044B \u043F\u0440\u0438\u0432\u0435\u0434\u0443
    \u0441\u043F\u0438\u0441\u043E\u043A \u0435\u0433\u043E \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442 : 1.  **Grundlagen f\xFCr eine allgemeine Theorie
    der Functionen einer ver\xE4nderlichen complexen Gr\xF6sse** (1851) \u2014 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0430\u044F
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F \u043E \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u044B\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044F\u0445. 2. 
    **Ueber die Gesetze der Vertheilung von Spannungselectricit\xE4t...** (1854)
    \u2014 \u043E \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u0430.
    3.  **Zur Theorie der Nobili'schen Farbenringe** (1855) \u2014 \u043E \u0444\u0438\u0437\u0438\u043A\u0435
    \u0446\u0432\u0435\u0442\u043D\u044B\u0445 \u043A\u043E\u043B\u0435\u0446. 4. 
    **Beitr\xE4ge zur Theorie der durch die Gauss'sche Reihe darstellbaren Functionen**
    (1857) \u2014 \u043E \u0433\u0438\u043F\u0435\u0440\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u0445. 5.  **Theorie der Abel'schen
    Functionen** (1857) \u2014 \u0442\u0435\u043E\u0440\u0438\u044F \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439. 6.  **Ueber die Anzahl der Primzahlen
    unter einer gegebenen Gr\xF6sse** (1859) \u2014 \u0433\u043B\u0430\u0432\u043D\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B \u0438 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u0420\u0438\u043C\u0430\u043D\u0430. 7.  **Ueber die Fortpflanzung ebener Luftwellen
    von endlicher Schwingungsweite** (1860) \u2014 \u043E \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u0438
    \u0437\u0432\u0443\u043A\u043E\u0432\u044B\u0445 \u0432\u043E\u043B\u043D. 8. 
    **Ein Beitrag zu den Untersuchungen \xFCber die Bewegung eines fl\xFCssigen gleichartigen
    Ellipsoides** (1860) \u2014 \u043E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438
    \u044D\u043B\u043B\u0438\u043F\u0441\u043E\u0438\u0434\u0430. 9.  **Ueber das
    Verschwinden der Theta-Functionen** (1866) \u2014 \u043E \u0442\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u044F\u0445. 
    \u0420\u0430\u0431\u043E\u0442\u044B, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E, \u0432\u043A\u043B\u044E\u0447\u0430\u044E\u0442
    \u0435\u0433\u043E \u0438\u043D\u0430\u0443\u0433\u0443\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u0443\u044E
    \u043B\u0435\u043A\u0446\u0438\u044E \u043F\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u0433\u0430\u0431\u0438\u043B\u0438\u0442\u0430\u0446\u0438\u043E\u043D\u043D\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u043F\u043E
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0440\u044F\u0434\u0430\u043C \u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u043E\u0432 \u043F\u043E \u0444\u0438\u0437\u0438\u043A\u0435,
    \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435
    \u0438 \u0434\u0440\u0443\u0433\u0438\u043C \u0442\u0435\u043C\u0430\u043C. 
    \u041A\u043E\u0440\u043E\u0442\u043A\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0420\u0438\u043C\u0430\u043D\u0430 \u0431\u044B\u043B\u0430 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u043E\u0439. \u0421\u043E\u0437\u0434\u0430\u043D\u043D\u044B\u0435
    \u0438\u043C \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438 \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0430\u0441\u0448\u0438\u0440\u0438\u043B\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0439,
    \u043D\u043E \u0438 \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438 \u0441\u0430\u043C\u043E
    \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0435 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430,
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0438 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u0438,
    \u043E\u043A\u0430\u0437\u0430\u0432 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u0434\u0430\u043B\u0435\u043A\u043E \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438."
  achievementsEn: 
  personalLifeRu: "\u0411\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434\u0430
    \u0420\u0438\u043C\u0430\u043D\u0430 \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043E\u0434\u0430\u0440\u0451\u043D\u043D\u043E\u0433\u043E, \u043D\u043E \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u043A\u0440\u0430\u0439\u043D\u0435 \u0437\u0430\u0441\u0442\u0435\u043D\u0447\u0438\u0432\u043E\u0433\u043E
    \u0438 \u043D\u0435 \u0441\u0430\u043C\u043E\u0433\u043E \u043A\u0440\u0435\u043F\u043A\u043E\u0433\u043E
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0437\u0430 \u0441\u0432\u043E\u044E \u043A\u043E\u0440\u043E\u0442\u043A\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443.
    \u041E\u043D \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D
    \u043A \u0441\u0435\u043C\u044C\u0435 \u0438 \u0443\u0432\u0430\u0436\u0430\u043B
    \u043C\u043D\u0435\u043D\u0438\u0435 \u043E\u0442\u0446\u0430, \u0447\u0442\u043E
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u043E \u0435\u0433\u043E
    \u043F\u0443\u0442\u044C \u0432 \u043D\u0430\u0443\u043A\u0435.  ### \U0001F4D6
    \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u044E\u043D\u043E\u0441\u0442\u044C
    (1826\u20131846)  \u0413\u0435\u043E\u0440\u0433 \u0424\u0440\u0438\u0434\u0440\u0438\u0445
    \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434 \u0420\u0438\u043C\u0430\u043D
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **17 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F
    1826 \u0433\u043E\u0434\u0430** \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435
    \u0411\u0440\u0435\u0437\u0435\u043B\u0435\u043D\u0446 (\u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u0442\u0432\u043E
    \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440) \u0432 \u0441\u0435\u043C\u044C\u0435
    \u0431\u0435\u0434\u043D\u043E\u0433\u043E \u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u043F\u0430\u0441\u0442\u043E\u0440\u0430. \u041E\u043D \u0431\u044B\u043B \u0432\u0442\u043E\u0440\u044B\u043C
    \u0438\u0437 \u0448\u0435\u0441\u0442\u0438 \u0434\u0435\u0442\u0435\u0439. 
    \u0415\u0433\u043E \u0440\u0430\u043D\u043D\u0435\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B\u043E \u0434\u043E\u043C\u0430
    \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u043E\u0442\u0446\u0430. \u0421\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C
    \u0440\u0430\u043D\u043E: \u0432 \u0448\u043A\u043E\u043B\u0435, \u043A\u0443\u0434\u0430
    \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 14 \u043B\u0435\u0442,
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F \u0437\u0430\u043C\u0435\u0447\u0430\u043B\u0438
    \u0435\u0433\u043E \u0442\u0430\u043B\u0430\u043D\u0442. \u041E\u0434\u0438\u043D
    \u0438\u0437 \u043D\u0438\u0445, \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440
    \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0438 \u0432 \u041B\u044E\u043D\u0435\u0431\u0443\u0440\u0433\u0435
    \u041A\u043E\u043D\u0441\u0442\u0430\u043D\u0442\u0438\u043D \u0428\u043C\u0430\u043B\u044C\u0444\u0443\u0441,
    \u0434\u0430\u0432\u0430\u043B \u043C\u0430\u043B\u044C\u0447\u0438\u043D\u0443
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u043A\u043D\u0438\u0433\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0420\u0438\u043C\u0430\u043D, \u043F\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435,
    \u043E\u0441\u0432\u0430\u0438\u0432\u0430\u043B \u0438 \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u043B
    \u0432\u0441\u0435\u0433\u043E \u0437\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0434\u043D\u0435\u0439. \u041E\u0434\u043D\u0430\u043A\u043E \u0441\u0430\u043C
    \u0420\u0438\u043C\u0430\u043D \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
    \u0431\u044B\u043B \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u043D\u043D\u043E
    \u0437\u0430\u0441\u0442\u0435\u043D\u0447\u0438\u0432\u044B\u043C \u0438 \u0440\u043E\u0431\u043A\u0438\u043C,
    \u0441\u0442\u0440\u0430\u0434\u0430\u043B \u043E\u0442 \u0431\u043E\u044F\u0437\u043D\u0438
    \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u044B\u0445 \u0432\u044B\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0439
    \u0438 \u043D\u0435\u0440\u0432\u043D\u044B\u0445 \u0441\u0440\u044B\u0432\u043E\u0432. 
    \u0412 1846 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    19 \u043B\u0435\u0442, \u0420\u0438\u043C\u0430\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u0447\u0442\u043E\u0431\u044B
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C **\u0444\u0438\u043B\u043E\u043B\u043E\u0433\u0438\u044E
    \u0438 \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044E**, \u0436\u0435\u043B\u0430\u044F
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u044C \u043F\u043E
    \u0441\u0442\u043E\u043F\u0430\u043C \u043E\u0442\u0446\u0430 \u0438 \u0441\u0442\u0430\u0442\u044C
    \u043F\u0430\u0441\u0442\u043E\u0440\u043E\u043C. \u041F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0434\u0430\u043D\u043D\u044B\u043C, \u043E\u043D \u0442\u0430\u043A\u0436\u0435
    \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0438\u043B \u043A \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438.  ### \U0001F393 \u0423\u0447\u0451\u0431\u0430
    \u0438 \u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u0441 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u0430\u043C\u0438
    (1846\u20131851)  \u0412 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435
    \u0420\u0438\u043C\u0430\u043D \u043D\u0435 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0438 \u043F\u043E\u0441\u0435\u0449\u0430\u043B
    \u043B\u0435\u043A\u0446\u0438\u0438. \u0412\u043E\u043F\u0440\u0435\u043A\u0438
    \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0451\u043D\u043D\u043E\u0439
    \u043B\u0435\u0433\u0435\u043D\u0434\u0435, \u0438\u043C\u0435\u043D\u043D\u043E
    \u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044C \u0428\u043C\u0430\u043B\u044C\u0444\u0443\u0441,
    \u0430 \u043D\u0435 \u0413\u0430\u0443\u0441\u0441, \u0441\u044B\u0433\u0440\u0430\u043B
    \u0440\u0435\u0448\u0430\u044E\u0449\u0443\u044E \u0440\u043E\u043B\u044C \u0432
    \u0435\u0433\u043E \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0435 \u043D\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442. \u041F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043E\u0442\u0446\u0430,
    \u0420\u0438\u043C\u0430\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044E,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C
    \u0441\u0435\u0431\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. 
    \u0412 1847 \u0433\u043E\u0434\u0443 \u0420\u0438\u043C\u0430\u043D \u043F\u0435\u0440\u0435\u0432\u0451\u043B\u0441\u044F
    \u0432 **\u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F
    \u0431\u044B\u043B \u0432\u0435\u0434\u0443\u0449\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0446\u0435\u043D\u0442\u0440\u043E\u043C. \u0422\u0430\u043C \u043E\u043D \u0443\u0447\u0438\u043B\u0441\u044F
    \u0443 \u0442\u0430\u043A\u0438\u0445 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u043A\u0430\u043A
    **\u0413\u0443\u0441\u0442\u0430\u0432 \u0414\u0438\u0440\u0438\u0445\u043B\u0435**,
    **\u041A\u0430\u0440\u043B \u0413\u0443\u0441\u0442\u0430\u0432 \u042F\u043A\u043E\u0431\u0438**
    \u0438 **\u0413\u043E\u0442\u0445\u043E\u043B\u044C\u0434 \u042D\u0439\u0437\u0435\u043D\u0448\u0442\u0435\u0439\u043D**.
    \u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0441\u0438\u043B\u044C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0435\u0433\u043E \u043F\u043E\u0434\u0445\u043E\u0434
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u043E\u043A\u0430\u0437\u0430\u043B
    **\u0414\u0438\u0440\u0438\u0445\u043B\u0435**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u043B\u0430\u0432\u0438\u043B\u0441\u044F \u0441\u0442\u0440\u0435\u043C\u043B\u0435\u043D\u0438\u0435\u043C
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u043E\u0435
    \u0438 \u044F\u0441\u043D\u043E\u0435 \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u0435
    \u0441\u043B\u043E\u0436\u043D\u044B\u043C \u0432\u0435\u0449\u0430\u043C, \u0438\u0437\u0431\u0435\u0433\u0430\u044F
    \u0433\u0440\u043E\u043C\u043E\u0437\u0434\u043A\u0438\u0445 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439.
    \u0412 \u0411\u0435\u0440\u043B\u0438\u043D\u0435 \u043E\u043D \u0442\u0430\u043A\u0436\u0435
    \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u043B\u0441\u044F \u0432 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435
    \u043D\u043E\u0432\u0435\u0439\u0448\u0435\u0439 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u044B, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0440\u0430\u0431\u043E\u0442 \u041A\u043E\u0448\u0438.  \u0412 1849 \u0433\u043E\u0434\u0443
    \u0420\u0438\u043C\u0430\u043D \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D. \u0417\u0434\u0435\u0441\u044C
    \u043E\u043D \u0441\u0431\u043B\u0438\u0437\u0438\u043B\u0441\u044F \u0441 \u0444\u0438\u0437\u0438\u043A\u043E\u043C
    **\u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u043E\u043C \u0412\u0435\u0431\u0435\u0440\u043E\u043C**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B
    \u0432 \u043D\u0451\u043C \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439 \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435 \u0438 \u043F\u043E\u0437\u0436\u0435 \u0441\u0442\u0430\u043B
    \u0435\u0433\u043E \u0431\u043B\u0438\u0437\u043A\u0438\u043C \u0434\u0440\u0443\u0433\u043E\u043C
    \u0438 \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u043C. \u041F\u0440\u0438\u043C\u0435\u0440\u043D\u043E
    \u0432 \u044D\u0442\u043E \u0436\u0435 \u0432\u0440\u0435\u043C\u044F \u043E\u043D
    \u043F\u043E\u0434\u0440\u0443\u0436\u0438\u043B\u0441\u044F \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    **\u0420\u0438\u0445\u0430\u0440\u0434\u043E\u043C \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u043E\u043C**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0437\u0436\u0435 \u0441\u0442\u0430\u043D\u0435\u0442
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u043E\u043C \u0438
    \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u043C
    \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u043E\u0432.  **16 \u0434\u0435\u043A\u0430\u0431\u0440\u044F
    1851 \u0433\u043E\u0434\u0430** \u0420\u0438\u043C\u0430\u043D \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    **\xAB\u041E\u0441\u043D\u043E\u0432\u044B \u043E\u0431\u0449\u0435\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u043E\u0434\u043D\u043E\u0439 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E\u0439
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439\xBB** \u043F\u043E\u0434
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C \u0413\u0430\u0443\u0441\u0441\u0430.
    \u0412 \u044D\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 \u043E\u043D
    \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0432\u0432\u0451\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    **\u0440\u0438\u043C\u0430\u043D\u043E\u0432\u043E\u0439 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438**,
    \u0447\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u043E \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u0438\u0435 \u043D\u0430
    \u0413\u0430\u0443\u0441\u0441\u0430, \u0432\u044B\u0441\u043E\u043A\u043E \u043E\u0446\u0435\u043D\u0438\u0432\u0448\u0435\u0433\u043E
    \u0442\u0430\u043B\u0430\u043D\u0442 \u0441\u0432\u043E\u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0430. 
    ### \U0001F9D1\u200D\U0001F3EB \u0420\u0430\u0431\u043E\u0442\u0430, \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    (1854\u20131866)  \u0427\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u043C\u0435\u0441\u0442\u043E \u043F\u0440\u0438\u0432\u0430\u0442-\u0434\u043E\u0446\u0435\u043D\u0442\u0430,
    \u0420\u0438\u043C\u0430\u043D\u0443 \u043F\u0440\u0435\u0434\u0441\u0442\u043E\u044F\u043B\u043E
    \u043F\u0440\u043E\u0439\u0442\u0438 \u043F\u0440\u043E\u0446\u0435\u0434\u0443\u0440\u0443
    \u0445\u0430\u0431\u0438\u043B\u0438\u0442\u0430\u0446\u0438\u0438, \u0432\u043A\u043B\u044E\u0447\u0430\u044E\u0449\u0443\u044E
    \u043F\u0440\u043E\u0431\u043D\u0443\u044E \u043B\u0435\u043A\u0446\u0438\u044E.
    \u041E\u043D \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u043B \u0442\u0440\u0438
    \u0442\u0435\u043C\u044B, \u043D\u043E \u0413\u0430\u0443\u0441\u0441 \u0432\u044B\u0431\u0440\u0430\u043B
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0441\u0430\u043C\u0443\u044E \u0441\u043B\u043E\u0436\u043D\u0443\u044E
    \u2014 **\xAB\u041E \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430\u0445, \u043B\u0435\u0436\u0430\u0449\u0438\u0445
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB**.
    \u041B\u0435\u043A\u0446\u0438\u044F, \u0441\u043E\u0441\u0442\u043E\u044F\u0432\u0448\u0430\u044F\u0441\u044F
    **10 \u0438\u044E\u043D\u044F 1854 \u0433\u043E\u0434\u0430**, \u0441\u0442\u0430\u043B\u0430
    \u0441\u0435\u043D\u0441\u0430\u0446\u0438\u0435\u0439. \u041F\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430, \u0413\u0430\u0443\u0441\u0441
    \u0431\u044B\u043B \u043F\u043E\u0440\u0430\u0436\u0451\u043D \u0433\u043B\u0443\u0431\u0438\u043D\u043E\u0439
    \u0438 \u043D\u043E\u0432\u0438\u0437\u043D\u043E\u0439 \u0438\u0434\u0435\u0439
    \u0420\u0438\u043C\u0430\u043D\u0430. \u041E\u0434\u043D\u0430\u043A\u043E, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0442\u0440\u0438\u0443\u043C\u0444, \u0420\u0438\u043C\u0430\u043D\u0430
    \u043D\u0435 \u0443\u0442\u0432\u0435\u0440\u0434\u0438\u043B\u0438 \u043D\u0430
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430. \u041E\u043D \u043D\u0430\u0447\u0430\u043B
    \u0441\u0432\u043E\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u0430\u0440\u044C\u0435\u0440\u0443 \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u043F\u0440\u0438\u0432\u0430\u0442-\u0434\u043E\u0446\u0435\u043D\u0442\u0430
    \u0441 \u043C\u0438\u0437\u0435\u0440\u043D\u044B\u043C \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u044C\u0435\u043C,
    \u0447\u0438\u0442\u0430\u044F \u043B\u0435\u043A\u0446\u0438\u0438 \u043F\u043E
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C.  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0435 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435,
    \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C.
    \u0412 1857 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u0438, \u043D\u0430\u043A\u043E\u043D\u0435\u0446, \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C **\u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430** \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430.  \u0412
    **1859 \u0433\u043E\u0434\u0443**, \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0441\u0432\u043E\u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044F
    \u0414\u0438\u0440\u0438\u0445\u043B\u0435, \u0420\u0438\u043C\u0430\u043D \u0437\u0430\u043D\u044F\u043B
    \u0435\u0433\u043E \u043C\u0435\u0441\u0442\u043E, \u0441\u0442\u0430\u0432 **\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C** \u0438 \u0433\u043B\u0430\u0432\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435.
    \u0412 \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A \u0441\u0432\u043E\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    **\xAB\u041E \u0447\u0438\u0441\u043B\u0435 \u043F\u0440\u043E\u0441\u0442\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B, \u043D\u0435 \u043F\u0440\u0435\u0432\u044B\u0448\u0430\u044E\u0449\u0438\u0445
    \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u0439 \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u044B\xBB**,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u0420\u0438\u043C\u0430\u043D\u0430**. **\u041A\u0430\u0440\u043B \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441**,
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438\u0437 \u0411\u0435\u0440\u043B\u0438\u043D\u0430,
    \u0432\u044B\u0441\u043E\u043A\u043E \u043E\u0446\u0435\u043D\u0438\u043B \u044D\u0442\u0443
    \u0440\u0430\u0431\u043E\u0442\u0443, \u0447\u0442\u043E \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E
    \u0438\u0437\u0431\u0440\u0430\u043D\u0438\u044E \u0420\u0438\u043C\u0430\u043D\u0430
    \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0438 \u0447\u043B\u0435\u043D\u043E\u043C
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u0438 \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430. 
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u043D\u0430\u0434 \u0442\u0435\u043E\u0440\u0435\u043C\u0430\u043C\u0438
    \u0438 \u043C\u0435\u0442\u043E\u0434\u0430\u043C\u0438 \u0431\u044B\u043B\u0430
    \u0442\u0435\u0441\u043D\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441
    \u043E\u0431\u0449\u0435\u043D\u0438\u0435\u043C \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438
    \u0443\u0447\u0451\u043D\u044B\u043C\u0438. \u0412 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435
    \u043E\u043D \u0442\u0435\u0441\u043D\u043E \u043E\u0431\u0449\u0430\u043B\u0441\u044F
    \u0441 **\u0420\u0438\u0445\u0430\u0440\u0434\u043E\u043C \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u043E\u043C**,
    \u0438 \u0438\u0445 \u0434\u0440\u0443\u0436\u0431\u0430 \u043E\u043A\u0430\u0437\u0430\u043B\u0430
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0412 1858 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u043B \u0441\u0432\u043E\u0438
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0434\u0435\u0438 \u0441 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u043C\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438, \u0442\u0430\u043A\u0438\u043C\u0438
    \u043A\u0430\u043A **\u042D\u043D\u0440\u0438\u043A\u043E \u0411\u0435\u0442\u0442\u0438**,
    \u0447\u0442\u043E \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E
    \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044E
    \u0435\u0433\u043E \u0438\u0434\u0435\u0439 \u0432 \u0415\u0432\u0440\u043E\u043F\u0435. 
    ### \U0001F494 \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C,
    \u0431\u043E\u043B\u0435\u0437\u043D\u044C \u0438 \u0441\u043C\u0435\u0440\u0442\u044C 
    **3 \u0438\u044E\u043D\u044F 1862 \u0433\u043E\u0434\u0430** \u0420\u0438\u043C\u0430\u043D
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u042D\u043B\u044C\u0437\u0435
    \u041A\u043E\u0445**, \u043F\u043E\u0434\u0440\u0443\u0433\u0435 \u0441\u0432\u043E\u0435\u0439
    \u043F\u043E\u043A\u043E\u0439\u043D\u043E\u0439 \u0441\u0435\u0441\u0442\u0440\u044B.
    \u0412\u0441\u043A\u043E\u0440\u0435 \u043F\u043E\u0441\u043B\u0435 \u0441\u0432\u0430\u0434\u044C\u0431\u044B,
    \u043E\u0441\u0435\u043D\u044C\u044E 1862 \u0433\u043E\u0434\u0430, \u043E\u043D
    \u0441\u0438\u043B\u044C\u043D\u043E \u043F\u0440\u043E\u0441\u0442\u044B\u043B,
    \u0438 \u044D\u0442\u043E \u0443\u0441\u043A\u043E\u0440\u0438\u043B\u043E \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0451\u0437\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u043E\u043D, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0431\u043E\u043B\u0435\u043B
    \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430. \u0422\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0451\u0437
    \u0443\u0436\u0435 \u0443\u043D\u0451\u0441 \u0436\u0438\u0437\u043D\u0438 \u0435\u0433\u043E
    \u043C\u0430\u0442\u0435\u0440\u0438 \u0438 \u0434\u0432\u0443\u0445 \u0441\u0435\u0441\u0442\u0451\u0440. 
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0447\u0435\u0442\u044B\u0440\u0435
    \u0433\u043E\u0434\u0430 \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438
    \u0420\u0438\u043C\u0430\u043D \u043F\u0440\u043E\u0432\u0451\u043B \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C
    \u0432 \u0418\u0442\u0430\u043B\u0438\u0438, \u043D\u0430\u0434\u0435\u044F\u0441\u044C,
    \u0447\u0442\u043E \u0431\u043E\u043B\u0435\u0435 \u043C\u044F\u0433\u043A\u0438\u0439
    \u043A\u043B\u0438\u043C\u0430\u0442 \u043F\u043E\u043C\u043E\u0436\u0435\u0442
    \u0435\u043C\u0443 \u0441\u043F\u0440\u0430\u0432\u0438\u0442\u044C\u0441\u044F
    \u0441 \u0431\u043E\u043B\u0435\u0437\u043D\u044C\u044E. \u0412 \u043D\u0430\u0447\u0430\u043B\u0435
    \u0410\u0432\u0441\u0442\u0440\u043E-\u043F\u0440\u0443\u0441\u0441\u043A\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B (1866) \u043E\u043D, \u043A\u0430\u043A \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0438\u043D
    \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440\u0430, \u0431\u044B\u043B \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u0431\u0435\u0436\u0430\u0442\u044C \u0438\u0437 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0430
    \u0438 \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0443\u0435\u0445\u0430\u043B \u0432 \u0418\u0442\u0430\u043B\u0438\u044E. 
    **20 \u0438\u044E\u043B\u044F 1866 \u0433\u043E\u0434\u0430**, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    39 \u043B\u0435\u0442, \u0420\u0438\u043C\u0430\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u043E\u0442 \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0451\u0437\u0430
    \u0432 \u0421\u0435\u043B\u0430\u0441\u043A\u0435 \u043D\u0430 \u0431\u0435\u0440\u0435\u0433\u0443
    \u043E\u0437\u0435\u0440\u0430 \u041B\u0430\u0433\u043E-\u041C\u0430\u0434\u0436\u043E\u0440\u0435
    \u0432 \u0418\u0442\u0430\u043B\u0438\u0438. \u0420\u044F\u0434\u043E\u043C \u0441
    \u043D\u0438\u043C \u0431\u044B\u043B\u0438 \u0436\u0435\u043D\u0430 \u042D\u043B\u044C\u0437\u0430
    \u0438 \u0438\u0445 \u0442\u0440\u0451\u0445\u043B\u0435\u0442\u043D\u044F\u044F
    \u0434\u043E\u0447\u044C \u0418\u0434\u0430. \u0415\u0433\u043E \u0434\u0440\u0443\u0433
    \u0420\u0438\u0445\u0430\u0440\u0434 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u043A\u0440\u0430\u0441\u043E\u0447\u043D\u043E \u043E\u043F\u0438\u0441\u0430\u043B
    \u0435\u0433\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0434\u043D\u0438:
    \u0437\u0430 \u0434\u0435\u043D\u044C \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    \u043E\u043D, \u043E\u0442\u0434\u044B\u0445\u0430\u044F \u0432 \u0442\u0435\u043D\u0438
    \u0444\u0438\u0433\u043E\u0432\u043E\u0433\u043E \u0434\u0435\u0440\u0435\u0432\u0430,
    \u0432\u0441\u0451 \u0435\u0449\u0451 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043D\u0430\u0434 \u043D\u0435\u0437\u0430\u043A\u043E\u043D\u0447\u0435\u043D\u043D\u043E\u0439
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C\u044E. \u041E\u043D \u0443\u0448\u0451\u043B
    \u043C\u0438\u0440\u043D\u043E, \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u0432
    \u0436\u0435\u043D\u0443 \u043F\u0435\u0440\u0435\u0434\u0430\u0442\u044C \u043F\u0440\u0438\u0432\u0435\u0442
    \u0432\u0441\u0435\u043C \u0434\u043E\u043C\u0430\u0448\u043D\u0438\u043C \u0438
    \u043F\u043E\u0446\u0435\u043B\u043E\u0432\u0430\u0442\u044C \u0438\u0445 \u0434\u043E\u0447\u044C. 
    \u041F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D \u043E\u043D \u043F\u0440\u0438
    \u0446\u0435\u0440\u043A\u0432\u0438 \u0432 \u0411\u0438\u0433\u0430\u043D\u0446\u043E\u043B\u043E.
    \u041D\u0430 \u0435\u0433\u043E \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u0438\u0438
    \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u0430 \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u044F:
    \xAB\u041B\u044E\u0431\u044F\u0449\u0438\u043C \u0411\u043E\u0433\u0430 \u0432\u0441\u0435
    \u0441\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442 \u043A\u043E
    \u0431\u043B\u0430\u0433\u0443\xBB. \u041C\u043E\u0433\u0438\u043B\u0430 \u0431\u044B\u043B\u0430
    \u043F\u043E\u0437\u0436\u0435 \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u0430
    \u043F\u0440\u0438 \u043F\u0435\u0440\u0435\u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u043A\u0435
    \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0430, \u043D\u043E \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u043D\u0430\u044F
    \u043F\u043B\u0438\u0442\u0430 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C.
    \u041F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    \u0435\u0433\u043E \u0432\u0434\u043E\u0432\u0430 \u042D\u043B\u044C\u0437\u0430
    \u0438 \u0434\u043E\u0447\u044C \u0418\u0434\u0430 \u0432\u0435\u0440\u043D\u0443\u043B\u0438\u0441\u044C
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D. \u0427\u0430\u0441\u0442\u044C
    \u0435\u0433\u043E \u043D\u0435\u0438\u0437\u0434\u0430\u043D\u043D\u044B\u0445
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0435\u0439, \u043A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u0431\u044B\u043B\u0430 \u0443\u0442\u0435\u0440\u044F\u043D\u0430."
  personalLifeEn: 
  shortBioRu: "\u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434 \u0420\u0438\u043C\u0430\u043D
    (\u043F\u043E\u043B\u043D\u043E\u0435 \u0438\u043C\u044F \u2014 **\u0413\u0435\u043E\u0440\u0433
    \u0424\u0440\u0438\u0434\u0440\u0438\u0445 \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434
    \u0420\u0438\u043C\u0430\u043D**) \u2014 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u044B
    \u0441\u0440\u0430\u0437\u0443 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0444\u0438\u0437\u0438\u043A\u0438.
    \u0415\u0433\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u043D\u0435\u043F\u043E\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043F\u0440\u0435\u0435\u043C\u043D\u0438\u043A\u043E\u043C \u0413\u0430\u0443\u0441\u0441\u0430
    \u0438 \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 XIX \u0432\u0435\u043A\u0430. 
    ### \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u044E\u043D\u043E\u0441\u0442\u044C:
    \u043F\u0443\u0442\u044C \u043E\u0442 \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u0438
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435  \u0420\u0438\u043C\u0430\u043D
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **17 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F
    1826 \u0433\u043E\u0434\u0430** \u0432 \u0431\u0435\u0434\u043D\u043E\u0439 \u0441\u0435\u043C\u044C\u0435
    \u043B\u044E\u0442\u0435\u0440\u0430\u043D\u0441\u043A\u043E\u0433\u043E \u043F\u0430\u0441\u0442\u043E\u0440\u0430
    \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435 \u0411\u0440\u0435\u0437\u0435\u043B\u0435\u043D\u0446,
    \u0413\u0430\u043D\u043D\u043E\u0432\u0435\u0440. \u041E\u043D \u0431\u044B\u043B
    \u0432\u0442\u043E\u0440\u044B\u043C \u0438\u0437 \u0448\u0435\u0441\u0442\u0438
    \u0434\u0435\u0442\u0435\u0439. \u0415\u0433\u043E \u043C\u0430\u0442\u044C,
    \u0428\u0430\u0440\u043B\u043E\u0442\u0442\u0430 \u042D\u0431\u0435\u043B\u043B\u044C,
    \u0443\u043C\u0435\u0440\u043B\u0430 \u043E\u0442 \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0451\u0437\u0430,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u0431\u044B\u043B \u0435\u0449\u0451
    \u043F\u043E\u0434\u0440\u043E\u0441\u0442\u043A\u043E\u043C; \u044D\u0442\u0430
    \u0436\u0435 \u0431\u043E\u043B\u0435\u0437\u043D\u044C \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0443\u043D\u0435\u0441\u043B\u0430 \u0436\u0438\u0437\u043D\u0438 \u0434\u0432\u0443\u0445
    \u0435\u0433\u043E \u0441\u0435\u0441\u0442\u0451\u0440 \u0438 \u0435\u0433\u043E
    \u0441\u0430\u043C\u043E\u0433\u043E.  \u0421\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C
    \u0443 \u043D\u0435\u0433\u043E \u0440\u0430\u043D\u043E. \u041E\u0434\u0438\u043D
    \u0438\u0437 \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0445 \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439,
    \u0437\u0430\u043C\u0435\u0442\u0438\u0432 \u0442\u0430\u043B\u0430\u043D\u0442
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430, \u0434\u0430\u0432\u0430\u043B
    \u0435\u043C\u0443 \u043A\u043D\u0438\u0433\u0438 \u043F\u043E \u0432\u044B\u0441\u0448\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0432 \u0442\u043E\u043C
    \u0447\u0438\u0441\u043B\u0435 \u0442\u0440\u0443\u0434\u044B \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0420\u0438\u043C\u0430\u043D, \u043A\u0430\u043A
    \u0433\u043E\u0432\u043E\u0440\u044F\u0442, \u043E\u0441\u0432\u043E\u0438\u043B
    \u0437\u0430 \u043D\u0435\u0434\u0435\u043B\u044E. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u044D\u0442\u043E, \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0432 1846
    \u0433\u043E\u0434\u0443, \u0447\u0442\u043E\u0431\u044B \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    **\u0444\u0438\u043B\u043E\u043B\u043E\u0433\u0438\u044E \u0438 \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044E**,
    \u0436\u0435\u043B\u0430\u044F \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u044C
    \u043F\u043E \u0441\u0442\u043E\u043F\u0430\u043C \u043E\u0442\u0446\u0430. 
    \u041E\u0434\u043D\u0430\u043A\u043E \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0420\u0438\u043C\u0430\u043D \u043D\u0430\u0447\u0430\u043B \u043F\u043E\u0441\u0435\u0449\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u0438 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0447\u0438\u0442\u0430\u043B **\u041A\u0430\u0440\u043B
    \u0424\u0440\u0438\u0434\u0440\u0438\u0445 \u0413\u0430\u0443\u0441\u0441**.
    \u041F\u043E\u0434 \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C \u0413\u0430\u0443\u0441\u0441\u0430
    \u043E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0442\u0435\u043E\u043B\u043E\u0433\u0438\u044E
    \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u043E\u0442\u0446\u0430 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C \u0441\u0435\u0431\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.  ### \u0413\u043E\u0434\u044B
    \u0443\u0447\u0435\u043D\u0438\u044F \u0438 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432 
    \u0412 1847 \u0433\u043E\u0434\u0443 \u0420\u0438\u043C\u0430\u043D \u043F\u0435\u0440\u0435\u0432\u0451\u043B\u0441\u044F
    \u0432 **\u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u043B \u0432 \u0442\u043E
    \u0432\u0440\u0435\u043C\u044F \u0432\u0435\u0434\u0443\u0449\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438.
    \u0422\u0430\u043C \u043E\u043D \u0441\u043B\u0443\u0448\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432:
    **\u0414\u0438\u0440\u0438\u0445\u043B\u0435, \u042F\u043A\u043E\u0431\u0438
    \u0438 \u0428\u0442\u0435\u0439\u043D\u0435\u0440\u0430**. \u0414\u0438\u0440\u0438\u0445\u043B\u0435
    \u043E\u043A\u0430\u0437\u0430\u043B \u043D\u0430 \u043D\u0435\u0433\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0441\u0438\u043B\u044C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435,
    \u043F\u0440\u0438\u0432\u0438\u0432 \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B \u0438
    \u0430\u043D\u0430\u043B\u0438\u0437\u0443.  \u0412 1849 \u0433\u043E\u0434\u0443
    \u0420\u0438\u043C\u0430\u043D \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D, \u0433\u0434\u0435
    \u0441\u0431\u043B\u0438\u0437\u0438\u043B\u0441\u044F \u0441 \u0444\u0438\u0437\u0438\u043A\u043E\u043C
    **\u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u043E\u043C \u0412\u0435\u0431\u0435\u0440\u043E\u043C**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B
    \u0432 \u043D\u0451\u043C \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439 \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435. \u0412 \u044D\u0442\u043E\u043C \u0436\u0435
    \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0438 \u043F\u043E\u0434\u0440\u0443\u0436\u0438\u043B\u0441\u044F \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0420\u0438\u0445\u0430\u0440\u0434\u043E\u043C \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0437\u0436\u0435 \u0441\u0442\u0430\u043B
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u043E\u043C \u0438
    \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u043C \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u043E\u0432. 
    ### \u0414\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0430\u044F \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F
    \u0438 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u044B\u0445
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439  \u0412
    **1851 \u0433\u043E\u0434\u0443** \u0420\u0438\u043C\u0430\u043D \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    **\xAB\u041E\u0441\u043D\u043E\u0432\u044B \u043E\u0431\u0449\u0435\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u043E\u0434\u043D\u043E\u0439 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E\u0439
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439\xBB**. \u0415\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C
    \u0431\u044B\u043B \u0413\u0430\u0443\u0441\u0441, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u044B\u0441\u043E\u043A\u043E \u043E\u0446\u0435\u043D\u0438\u043B \u0440\u0430\u0431\u043E\u0442\u0443.
    \u0412 \u044D\u0442\u043E\u0439 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438
    \u0420\u0438\u043C\u0430\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u043D\u043E\u0432\u043E\u0433\u043E \u043F\u043E\u0434\u0445\u043E\u0434\u0430
    \u043A \u0442\u0435\u043E\u0440\u0438\u0438 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439, \u0432\u0432\u0435\u0434\u044F \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    **\u0440\u0438\u043C\u0430\u043D\u043E\u0432\u043E\u0439 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438**
    \u2014 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u044A\u0435\u043A\u0442\u0430, \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0435\u0433\u043E
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u043C\u043D\u043E\u0433\u043E\u0437\u043D\u0430\u0447\u043D\u044B\u0435
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438 \u043A\u0430\u043A \u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u044B\u0435
    \u043D\u0430 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438. 
    ### \u041F\u0440\u043E\u0431\u043D\u0430\u044F \u043B\u0435\u043A\u0446\u0438\u044F:
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438  \u0427\u0442\u043E\u0431\u044B
    \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u0438\u0432\u0430\u0442-\u0434\u043E\u0446\u0435\u043D\u0442\u0430,
    \u0420\u0438\u043C\u0430\u043D\u0443 \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
    \u0431\u044B\u043B\u043E \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u044C
    \u043F\u0440\u043E\u0431\u043D\u0443\u044E \u043B\u0435\u043A\u0446\u0438\u044E.
    \u041E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u043D\u0430
    \u0432\u044B\u0431\u043E\u0440 \u0442\u0440\u0438 \u0442\u0435\u043C\u044B, \u0438
    \u0413\u0430\u0443\u0441\u0441, \u043A \u0443\u0434\u0438\u0432\u043B\u0435\u043D\u0438\u044E
    \u0420\u0438\u043C\u0430\u043D\u0430, \u0432\u044B\u0431\u0440\u0430\u043B \u0442\u0435\u043C\u0443
    **\xAB\u041E \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430\u0445, \u043B\u0435\u0436\u0430\u0449\u0438\u0445
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB**.
    \u041B\u0435\u043A\u0446\u0438\u044F \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0430\u0441\u044C
    **10 \u0438\u044E\u043D\u044F 1854 \u0433\u043E\u0434\u0430**. \u041F\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430, \u0413\u0430\u0443\u0441\u0441,
    \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u0432\u0448\u0438\u0439
    \u043D\u0430 \u043D\u0435\u0439, \u0431\u044B\u043B \u043F\u043E\u0440\u0430\u0436\u0451\u043D
    \u0433\u043B\u0443\u0431\u0438\u043D\u043E\u0439 \u0438 \u043D\u043E\u0432\u0438\u0437\u043D\u043E\u0439
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0445 \u0438\u0434\u0435\u0439. 
    \u0412 \u044D\u0442\u043E\u043C \u0434\u043E\u043A\u043B\u0430\u0434\u0435 \u0420\u0438\u043C\u0430\u043D
    \u043E\u0431\u043E\u0431\u0449\u0438\u043B \u0433\u0430\u0443\u0441\u0441\u043E\u0432\u0443
    \u0442\u0435\u043E\u0440\u0438\u044E \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0435\u0439
    \u043D\u0430 \u043C\u043D\u043E\u0433\u043E\u043C\u0435\u0440\u043D\u044B\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430, \u0432\u0432\u0435\u0434\u044F
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F **\u0440\u0438\u043C\u0430\u043D\u043E\u0432\u0430
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u044F**, **\u0440\u0438\u043C\u0430\u043D\u043E\u0432\u043E\u0439
    \u043C\u0435\u0442\u0440\u0438\u043A\u0438** \u0438 **\u0442\u0435\u043D\u0437\u043E\u0440\u0430
    \u043A\u0440\u0438\u0432\u0438\u0437\u043D\u044B**. \u041E\u043D \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u043B,
    \u0447\u0442\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430 \u043C\u043E\u0436\u0435\u0442
    \u043D\u0435 \u0431\u044B\u0442\u044C \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439,
    \u0438 \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0432\u043E\u043F\u0440\u043E\u0441
    \u043E \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043F\u0440\u0438\u0447\u0438\u043D\u0430\u0445
    \u0435\u0433\u043E \u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432, \u0447\u0442\u043E \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u043B\u043E
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 **\u043E\u0431\u0449\u0435\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430**.  ### \u041D\u0430\u0443\u0447\u043D\u044B\u0439
    \u043F\u0443\u0442\u044C \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    *   **1854 \u0433\u043E\u0434**: \u0420\u0438\u043C\u0430\u043D \u0441\u0442\u0430\u043B
    **\u043F\u0440\u0438\u0432\u0430\u0442-\u0434\u043E\u0446\u0435\u043D\u0442\u043E\u043C**
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435. *  
    **1857 \u0433\u043E\u0434**: \u041F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    **\u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430**. *   **1859 \u0433\u043E\u0434**:
    \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u0414\u0438\u0440\u0438\u0445\u043B\u0435
    \u0437\u0430\u043D\u044F\u043B \u0435\u0433\u043E \u043C\u0435\u0441\u0442\u043E,
    \u0441\u0442\u0430\u0432 **\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C** \u0438 \u0433\u043B\u0430\u0432\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435. 
    \u0412 \u044D\u0442\u043E \u0436\u0435 \u0432\u0440\u0435\u043C\u044F \u043E\u043D
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    **\xAB\u041E \u0447\u0438\u0441\u043B\u0435 \u043F\u0440\u043E\u0441\u0442\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B, \u043D\u0435 \u043F\u0440\u0435\u0432\u044B\u0448\u0430\u044E\u0449\u0438\u0445
    \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u0439 \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u044B\xBB**
    , \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    **\u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u044E**
    \u0438 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u0420\u0438\u043C\u0430\u043D\u0430** \u043E \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u0435\u0451 \u043D\u0443\u043B\u0435\u0439, \u043E\u0441\u0442\u0430\u044E\u0449\u0443\u044E\u0441\u044F
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u043D\u0435\u0440\u0435\u0448\u0451\u043D\u043D\u044B\u0445 \u043F\u0440\u043E\u0431\u043B\u0435\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  \u0415\u0433\u043E
    \u0437\u0430\u0441\u043B\u0443\u0433\u0438 \u0431\u044B\u043B\u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u044B
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E\u043C:
    \u043E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C
    \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u0439 (1859), \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439 \u043D\u0430\u0443\u043A \u0438
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 (1860).  ### \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B  \u0412 1862 \u0433\u043E\u0434\u0443 \u0420\u0438\u043C\u0430\u043D
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u042D\u043B\u044C\u0437\u0435
    \u041A\u043E\u0445**. \u0412\u0441\u043A\u043E\u0440\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0441\u0432\u0430\u0434\u044C\u0431\u044B \u043E\u043D \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u043E
    \u0437\u0430\u0431\u043E\u043B\u0435\u043B \u043F\u043B\u0435\u0432\u0440\u0438\u0442\u043E\u043C,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u043D\u0430\u0447\u0430\u043B\u043E\u043C
    \u0435\u0433\u043E \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0431\u043E\u0440\u044C\u0431\u044B \u0441 \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0451\u0437\u043E\u043C.
    \u041D\u0430\u0434\u0435\u044F\u0441\u044C \u043F\u043E\u043F\u0440\u0430\u0432\u0438\u0442\u044C
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435, \u043E\u043D \u0441 \u0436\u0435\u043D\u043E\u0439
    \u0438 \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u0418\u0434\u043E\u0439 \u0443\u0435\u0445\u0430\u043B
    \u0432 \u0418\u0442\u0430\u043B\u0438\u044E.  \u0420\u0438\u043C\u0430\u043D
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u043E\u0442 \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0451\u0437\u0430
    **20 \u0438\u044E\u043B\u044F 1866 \u0433\u043E\u0434\u0430** \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    39 \u043B\u0435\u0442 \u0432 \u043C\u0435\u0441\u0442\u0435\u0447\u043A\u0435
    \u0421\u0435\u043B\u0430\u0441\u043A\u0430 \u043D\u0430 \u0431\u0435\u0440\u0435\u0433\u0443
    \u043E\u0437\u0435\u0440\u0430 \u041B\u0430\u0433\u043E-\u041C\u0430\u0434\u0436\u043E\u0440\u0435
    \u0432 \u0418\u0442\u0430\u043B\u0438\u0438. \u0415\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u0430
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0437\u0436\u0435 \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u0430
    \u043F\u0440\u0438 \u043F\u0435\u0440\u0435\u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u043A\u0435
    \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0430, \u043D\u043E \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u043D\u0430\u044F
    \u043F\u043B\u0438\u0442\u0430 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C. 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043A\u043E\u0440\u043E\u0442\u043A\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u0438 \u0432\u0441\u0435\u0433\u043E \u0434\u0435\u0441\u044F\u0442\u044C
    \u043B\u0435\u0442 \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B, \u0420\u0438\u043C\u0430\u043D \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443, \u0430 \u0435\u0433\u043E
    \u0438\u0434\u0435\u0438 \u0441\u0442\u0430\u043B\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0425\u043E\u0442\u044F \u0436\u0438\u0437\u043D\u044C \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434\u0430
    \u0420\u0438\u043C\u0430\u043D\u0430 \u0431\u044B\u043B\u0430 \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u0430
    \u0431\u0435\u0434\u043D\u043E\u0441\u0442\u044C\u044E, \u0431\u043E\u043B\u0435\u0437\u043D\u044F\u043C\u0438
    \u0438 \u0447\u0435\u0440\u0435\u0434\u043E\u0439 \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u0445
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0439, \u043E\u043D\u0430 \u043F\u043E\u043B\u043D\u0430
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u044F\u0440\u043A\u043E \u0432\u044B\u0441\u0432\u0435\u0447\u0438\u0432\u0430\u044E\u0442
    \u0438 \u0435\u0433\u043E \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0433\u0435\u043D\u0438\u0439, \u0438 \u0441\u043B\u043E\u0436\u043D\u044B\u0439,
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u044B\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440. \u0414\u0430\u0432\u0430\u0439\u0442\u0435
    \u0440\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0438\u043C \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435 \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438. 
    ### \U0001F92F \u0424\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u0430\u044F
    \u043F\u0430\u043C\u044F\u0442\u044C \u0438 \"900 \u0441\u0442\u0440\u0430\u043D\u0438\u0446
    \u0437\u0430 6 \u0434\u043D\u0435\u0439\" \u041F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0430\u043D\u0435\u043A\u0434\u043E\u0442 \u0438\u0437 \u0436\u0438\u0437\u043D\u0438
    \u0420\u0438\u043C\u0430\u043D\u0430 \u0441\u0432\u044F\u0437\u0430\u043D \u0441
    \u0435\u0433\u043E \u0443\u0447\u0435\u0431\u043E\u0439 \u0432 \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0438.
    \u0415\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044F \u0431\u044B\u0441\u0442\u0440\u043E
    \u043F\u043E\u043D\u044F\u043B\u0438, \u0447\u0442\u043E \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u0430\u044F
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430 \u0434\u043B\u044F \u043D\u0435\u0433\u043E
    \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u043F\u0440\u043E\u0441\u0442\u0430,
    \u0438 \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u043B\u0438 \u0435\u0433\u043E
    \u043E\u0442 \u0437\u0430\u043D\u044F\u0442\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439.
    \u0427\u0442\u043E\u0431\u044B \u043C\u0430\u043B\u044C\u0447\u0438\u043A \u043D\u0435
    \u0441\u043A\u0443\u0447\u0430\u043B, \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440
    \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0438 \u043E\u0434\u043E\u043B\u0436\u0438\u043B
    \u0435\u043C\u0443 \u043A\u0430\u043F\u0438\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430
    \xAB\u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B\xBB \u2014
    \u043A\u043D\u0438\u0433\u0443 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0432 \u0442\u0435 \u0433\u043E\u0434\u044B \u043C\u043E\u0433\u043B\u0438 \u043E\u0441\u0438\u043B\u0438\u0442\u044C
    \u043B\u0438\u0448\u044C \u0435\u0434\u0438\u043D\u0438\u0446\u044B \u0432 \u043C\u0438\u0440\u0435.
    \u041A\u0430\u043A\u043E\u0432\u043E \u0436\u0435 \u0431\u044B\u043B\u043E \u0443\u0434\u0438\u0432\u043B\u0435\u043D\u0438\u0435
    \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u0430, \u043A\u043E\u0433\u0434\u0430
    \u0447\u0435\u0440\u0435\u0437 **\u0448\u0435\u0441\u0442\u044C \u0434\u043D\u0435\u0439**
    \u0420\u0438\u043C\u0430\u043D \u0432\u0435\u0440\u043D\u0443\u043B \u043A\u043D\u0438\u0433\u0443.
    \u041D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441, \u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043E\u043D \u0443\u0441\u043F\u0435\u043B \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u044C,
    \u044E\u043D\u044B\u0439 \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E
    \u043E\u0442\u0432\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u043F\u0440\u043E\u0447\u0435\u043B
    \u0432\u0441\u044E \u043A\u043D\u0438\u0433\u0443 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u2014 \u0438, \u043A\u0430\u043A \u0432\u044B\u044F\u0441\u043D\u0438\u043B\u043E\u0441\u044C
    \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438, \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0443\u0441\u0432\u043E\u0438\u043B \u0435\u0435 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435.
    \u0412 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E
    \u043E\u043D \"\u043F\u043E\u0433\u043B\u043E\u0449\u0430\u043B \u043F\u043E
    900 \u0441\u0442\u0440\u0430\u043D\u0438\u0446 \u0432 \u043D\u0435\u0434\u0435\u043B\u044E\",
    \u0447\u0442\u043E, \u0443\u0447\u0438\u0442\u044B\u0432\u0430\u044F \u043E\u0431\u044A\u0435\u043C
    \u0440\u0430\u0431\u043E\u0442\u044B \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430,
    \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442 \u0432\u043F\u043E\u043B\u043D\u0435
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E.  ### \U0001F3AD \u0420\u043E\u0431\u043A\u0438\u0439
    \u0433\u0435\u043D\u0438\u0439 \u0438 \"\u0418\u0441\u043A\u0440\u044B \u0432\u043D\u0443\u0442\u0440\u0438
    \u0445\u0438\u0431\u0430\u0440\u043A\u0438\" \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0439 \u0443\u043C,
    \u0420\u0438\u043C\u0430\u043D \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u043A\u0440\u0430\u0439\u043D\u0435 \u0437\u0430\u0441\u0442\u0435\u043D\u0447\u0438\u0432\u044B\u043C
    \u0438 \u0434\u0430\u0436\u0435 \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u043D\u043D\u043E
    \u0440\u043E\u0431\u043A\u0438\u043C. \u041E\u043D \u0442\u0430\u043A \u0441\u0438\u043B\u044C\u043D\u043E
    \u0431\u043E\u044F\u043B\u0441\u044F \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u044B\u0445
    \u0432\u044B\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0439, \u0447\u0442\u043E
    \u044D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u043F\u0440\u0438\u0447\u0438\u043D, \u043F\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043E\u043D \u0432 \u0438\u0442\u043E\u0433\u0435 \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u043A\u0430\u0440\u044C\u0435\u0440\u044B \u043F\u0430\u0441\u0442\u043E\u0440\u0430,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u043B
    \u0435\u0433\u043E \u043E\u0442\u0435\u0446. \u0415\u0433\u043E \u0437\u0430\u0441\u0442\u0435\u043D\u0447\u0438\u0432\u043E\u0441\u0442\u044C
    \u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0430\u0441\u044C \u043D\u0430
    \u0432\u0441\u0435\u0439 \u0436\u0438\u0437\u043D\u0438: \u043E\u043D \u0438\u0437\u0431\u0435\u0433\u0430\u043B
    \u0441\u0432\u0435\u0442\u0441\u043A\u0438\u0445 \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u043E\u0432
    \u0438 \u0441\u0438\u043B\u044C\u043D\u043E \u0442\u043E\u0441\u043A\u043E\u0432\u0430\u043B
    \u043F\u043E \u0434\u043E\u043C\u0443, \u0435\u0441\u043B\u0438 \u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F
    \u0432\u0434\u0430\u043B\u0438 \u043E\u0442 \u0441\u0435\u043C\u044C\u0438. 
    \u041D\u043E \u044D\u0442\u0430 \u0432\u043D\u0435\u0448\u043D\u044F\u044F \u0440\u043E\u0431\u043E\u0441\u0442\u044C
    \u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u0430
    \u0441 \u0434\u0435\u0440\u0437\u043E\u0441\u0442\u044C\u044E \u0438 \u0441\u043C\u0435\u043B\u043E\u0441\u0442\u044C\u044E
    \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u043C\u044B\u0441\u043B\u0438.
    \u0410\u0432\u0442\u043E\u0440 \u043A\u043D\u0438\u0433\u0438 \u043E \u0420\u0438\u043C\u0430\u043D\u0435
    \u0414\u0436\u043E\u043D \u0414\u0435\u0440\u0431\u0438\u0448\u0438\u0440 \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u0442
    \u044F\u0440\u043A\u0443\u044E \u0430\u043D\u0430\u043B\u043E\u0433\u0438\u044E:
    \u0432\u043D\u0435\u0448\u043D\u0435 \u0420\u0438\u043C\u0430\u043D \u0431\u044B\u043B
    \u043F\u043E\u0434\u043E\u0431\u0435\u043D \u0443\u0431\u043E\u0433\u043E\u0439
    \u0445\u0438\u0436\u0438\u043D\u0435, \u043D\u043E \u0441\u0442\u043E\u0438\u043B\u043E
    \u043F\u0435\u0440\u0435\u0441\u0442\u0443\u043F\u0438\u0442\u044C \u043F\u043E\u0440\u043E\u0433,
    \u043A\u0430\u043A \u0432\u043D\u0443\u0442\u0440\u0438 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u043B\u043E\u0441\u044C
    \u0441\u0438\u044F\u043D\u0438\u0435, \u044F\u0440\u0447\u0435 \u0441\u043E\u043B\u043D\u0446\u0430.
    \u041E\u043D \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \"\u0431\u0435\u0441\u0441\u0442\u0440\u0430\u0448\u043D\u044B\u0439 \u0440\u0430\u0437\u043C\u0430\u0445
    \u0438 \u044D\u043D\u0435\u0440\u0433\u0438\u044E\", \u0440\u0435\u0448\u0430\u044F
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u0435\u0440\u0435\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u043B\u0438
    \u0443\u0441\u0442\u043E\u044F\u0432\u0448\u0438\u0435\u0441\u044F \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u043E \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435. 
    ### \U0001F393 \u0422\u0440\u0438\u0443\u043C\u0444, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u043B\u0443\u0448\u0430\u043B\u0438 \u0435\u0434\u0438\u043D\u0438\u0446\u044B
    \u0412 1854 \u0433\u043E\u0434\u0443 \u0420\u0438\u043C\u0430\u043D \u0433\u043E\u0442\u043E\u0432\u0438\u043B\u0441\u044F
    \u043A \u043F\u0440\u043E\u0431\u043D\u043E\u0439 \u043B\u0435\u043A\u0446\u0438\u0438,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u043C\u0435\u0441\u0442\u043E \u043F\u0440\u0438\u0432\u0430\u0442-\u0434\u043E\u0446\u0435\u043D\u0442\u0430.
    \u0415\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044C, \u0432\u0435\u043B\u0438\u043A\u0438\u0439
    \u041A\u0430\u0440\u043B \u0424\u0440\u0438\u0434\u0440\u0438\u0445 \u0413\u0430\u0443\u0441\u0441,
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u0432\u044B\u0431\u0440\u0430\u043B
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0443\u044E
    \u0442\u0435\u043C\u0443 \u2014 \xAB\u041E \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430\u0445,
    \u043B\u0435\u0436\u0430\u0449\u0438\u0445 \u0432 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0438
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB, \u0442\u0430\u043A
    \u043A\u0430\u043A \u0435\u043C\u0443 \u0441\u0430\u043C\u043E\u043C\u0443 \u0431\u044B\u043B\u043E
    \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u043E, \u0447\u0442\u043E \u0441\u043A\u0430\u0436\u0435\u0442
    \u043C\u043E\u043B\u043E\u0434\u043E\u0439 \u0443\u0447\u0435\u043D\u044B\u0439.
    \u041B\u0435\u043A\u0446\u0438\u044F \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0430\u0441\u044C
    10 \u0438\u044E\u043D\u044F 1854 \u0433\u043E\u0434\u0430 \u0438 \u0441\u0442\u0430\u043B\u0430
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C \u0442\u0440\u0438\u0443\u043C\u0444\u043E\u043C,
    \u0437\u0430\u043B\u043E\u0436\u0438\u0432 \u043E\u0441\u043D\u043E\u0432\u044B
    \u043D\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u043F\u043E \u0438\u0440\u043E\u043D\u0438\u0438
    \u0441\u0443\u0434\u044C\u0431\u044B, \u043E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u043E\u0439
    \u0438 \u0441\u043B\u043E\u0436\u043D\u043E\u0439, \u0447\u0442\u043E \u0438\u0437
    \u0432\u0441\u0435\u0439 \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u0438
    \u0435\u0435 \u043F\u043E-\u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u043C\u0443
    \u043F\u043E\u043D\u044F\u043B, \u043A\u0430\u0436\u0435\u0442\u0441\u044F, \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0430\u043C \u0413\u0430\u0443\u0441\u0441, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u0440\u0438\u0448\u0435\u043B \u0432 \u0432\u043E\u0441\u0442\u043E\u0440\u0433. 
    \u041A\u0443\u0440\u044C\u0435\u0437\u043D\u043E \u0438 \u0442\u043E, \u0447\u0442\u043E
    \u043D\u0430 \u0441\u0432\u043E\u044E \u0441\u0430\u043C\u0443\u044E \u043F\u0435\u0440\u0432\u0443\u044E
    \u043B\u0435\u043A\u0446\u0438\u044E \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044F
    \u0433\u043E\u0434\u043E\u043C \u0440\u0430\u043D\u0435\u0435 \u0420\u0438\u043C\u0430\u043D
    \u0441 \u0440\u0430\u0434\u043E\u0441\u0442\u044C\u044E \u0441\u043E\u043E\u0431\u0449\u0430\u043B
    \u043E \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E \u0431\u043E\u043B\u044C\u0448\u043E\u043C
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0435 \u0441\u043B\u0443\u0448\u0430\u0442\u0435\u043B\u0435\u0439
    \u2014 \u0430 \u0438\u043C\u0435\u043D\u043D\u043E, **\u0432\u043E\u0441\u044C\u043C\u0438
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430\u0445**.  ### \U0001F48D \u0421\u0435\u043C\u0435\u0439\u043D\u044B\u0435
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438 \u0438 \u043D\u0435\u0434\u043E\u043B\u0433\u043E\u0435
    \u0441\u0447\u0430\u0441\u0442\u044C\u0435 \u0416\u0438\u0437\u043D\u044C \u0420\u0438\u043C\u0430\u043D\u0430
    \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u0433\u043E\u0440\u0435\u043C. \u041E\u043D \u0440\u0430\u043D\u043E \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u043C\u0430\u0442\u044C, \u0430 \u0437\u0430\u0442\u0435\u043C, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    29 \u043B\u0435\u0442, \u043E\u0442\u0446\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0431\u043E\u0433\u043E\u0442\u0432\u043E\u0440\u0438\u043B. \u0417\u0430 \u0434\u0435\u0441\u044F\u0442\u044C
    \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u043E\u0442\u0446\u0430 \u043E\u0434\u0438\u043D \u0437\u0430 \u0434\u0440\u0443\u0433\u0438\u043C
    \u0443\u043C\u0435\u0440\u043B\u0438 \u0447\u0435\u0442\u0432\u0435\u0440\u043E
    \u0438\u0437 \u043F\u044F\u0442\u0438 \u0435\u0433\u043E \u0431\u0440\u0430\u0442\u044C\u0435\u0432
    \u0438 \u0441\u0435\u0441\u0442\u0435\u0440. \u042D\u0442\u0438 \u0443\u0434\u0430\u0440\u044B
    \u0441\u0443\u0434\u044C\u0431\u044B \u043F\u043E\u0432\u0435\u0440\u0433\u0430\u043B\u0438
    \u0435\u0433\u043E \u0432 \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u044E
    (\u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438
    \u043E\u0431 \u0438\u043F\u043E\u0445\u043E\u043D\u0434\u0440\u0438\u0438), \u0441\u043F\u0430\u0441\u0430\u044F\u0441\u044C
    \u043E\u0442 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u0441 \u0433\u043E\u043B\u043E\u0432\u043E\u0439
    \u0443\u0445\u043E\u0434\u0438\u043B \u0432 \u0440\u0430\u0431\u043E\u0442\u0443. 
    \u0422\u0435\u043C \u043D\u0435 \u043C\u0435\u043D\u0435\u0435, \u0432 1862 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u042D\u043B\u044C\u0437\u0435
    \u041A\u043E\u0445, \u043F\u043E\u0434\u0440\u0443\u0433\u0435 \u0441\u0432\u043E\u0435\u0439
    \u0441\u0435\u0441\u0442\u0440\u044B. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E \u0441\u0447\u0430\u0441\u0442\u044C\u0435
    \u043F\u0440\u043E\u0434\u043B\u0438\u043B\u043E\u0441\u044C \u043D\u0435\u0434\u043E\u043B\u0433\u043E
    \u2014 \u0432\u0441\u0435\u0433\u043E \u0442\u0440\u0438 \u0433\u043E\u0434\u0430
    \u0434\u043E \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438, \u2014
    \u044D\u0442\u043E\u0442 \u0431\u0440\u0430\u043A \u0441\u0442\u0430\u043B \u0434\u043B\u044F
    \u043D\u0435\u0433\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C
    \u0443\u0442\u0435\u0448\u0435\u043D\u0438\u0435\u043C. \u0414\u0440\u0443\u0433
    \u0420\u0438\u043C\u0430\u043D\u0430, \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434,
    \u043F\u0438\u0441\u0430\u043B, \u0447\u0442\u043E \u043E\u043D\u0430 \u0431\u044B\u043B\u0430
    \"\u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0430
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C \u0441 \u043D\u0438\u043C
    \u0433\u0440\u044F\u0434\u0443\u0449\u0438\u0435 \u0433\u043E\u0434\u044B \u0431\u043E\u043B\u0438
    \u0438 \u0443\u043A\u0440\u0430\u0441\u0438\u0442\u044C \u0438\u0445 \u0441\u0432\u043E\u0435\u0439
    \u043D\u0435\u0443\u0442\u043E\u043C\u0438\u043C\u043E\u0439 \u043B\u044E\u0431\u043E\u0432\u044C\u044E\". 
    ### \U0001F9EC \"\u0415\u0441\u043B\u0438 \u0431\u044B \u043E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u043E\u043C!\" \u0423 \u0420\u0438\u043C\u0430\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0434\u043E\u0447\u044C, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043D\u0430\u0437\u0432\u0430\u043B\u0438 \u0418\u0434\u043E\u0439, \u0432 \u0447\u0435\u0441\u0442\u044C
    \u0435\u0433\u043E \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0432\u044B\u0436\u0438\u0432\u0448\u0435\u0439 \u0441\u0435\u0441\u0442\u0440\u044B.
    \u0414\u0435\u0432\u043E\u0447\u043A\u0430 \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0430\u043B\u0430\u043D\u0442 \u043E\u0442\u0446\u0430. \u0412 \u043F\u0438\u0441\u044C\u043C\u0435
    \u043A \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0443 \u0435\u0433\u043E
    \u0432\u0434\u043E\u0432\u0430 \u042D\u043B\u044C\u0437\u0430 \u0441 \u0433\u043E\u0440\u0434\u043E\u0441\u0442\u044C\u044E
    \u043F\u0438\u0441\u0430\u043B\u0430, \u0447\u0442\u043E 11-\u043B\u0435\u0442\u043D\u044F\u044F
    \u0418\u0434\u0430 \u043E\u0431\u043E\u0436\u0430\u0435\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0438 \u0447\u0430\u0441\u0442\u043E, \u0438\u0437 \u0447\u0438\u0441\u0442\u043E\u0433\u043E
    \u0443\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u044F, \u0440\u0435\u0448\u0430\u0435\u0442
    \u043D\u0430 30 \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u0432 \u0431\u043E\u043B\u044C\u0448\u0435,
    \u0447\u0435\u043C \u0437\u0430\u0434\u0430\u044E\u0442 \u043D\u0430 \u0434\u043E\u043C.
    \u041E\u043D\u0430 \u043E\u043F\u0435\u0440\u0435\u0436\u0430\u043B\u0430 \u0432
    \u0443\u0447\u0435\u0431\u0435 \u0434\u0435\u0432\u043E\u0447\u0435\u043A \u0438\u0437
    \u0441\u0442\u0430\u0440\u0448\u0438\u0445 \u043A\u043B\u0430\u0441\u0441\u043E\u0432.
    \u0417\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u043B\u043E\u0441\u044C
    \u043F\u0438\u0441\u044C\u043C\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043D\u043E\u0439
    \u0434\u043B\u044F \u0442\u043E\u0439 \u044D\u043F\u043E\u0445\u0438 \u0444\u0440\u0430\u0437\u043E\u0439:
    \xAB\u0415\u0441\u043B\u0438 \u0431\u044B \u043E\u043D\u0430 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0431\u044B\u043B\u0430 \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u043E\u043C!\xBB.
    \u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E, \u043A\u0430\u043A
    \u043E\u0442\u043C\u0435\u0447\u0430\u0435\u0442 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C,
    \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u0435
    \u0434\u0435\u0432\u0443\u0448\u043A\u0438 \u0440\u0435\u0434\u043A\u043E \u043F\u043E\u043B\u0443\u0447\u0430\u043B\u0438
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0440\u0435\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u0439 \u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B. 
    ### \U0001F48E \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u043C\u0438\u043D\u0443\u0442\u044B
    \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u043E\u0439 \u0423\u043C\u0438\u0440\u0430\u044F
    \u043E\u0442 \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437\u0430
    \u0432 \u0418\u0442\u0430\u043B\u0438\u0438, \u0420\u0438\u043C\u0430\u043D \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u043B
    \u044F\u0441\u043D\u043E\u0441\u0442\u044C \u0443\u043C\u0430 \u0434\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0433\u043E
    \u0434\u043D\u044F. \u0414\u0440\u0443\u0433\u043E\u0439 \u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0430,
    \u0412\u0435\u0431\u0435\u0440, \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B,
    \u0447\u0442\u043E \u0437\u0430 \u0434\u0435\u043D\u044C \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438,
    19 \u0438\u044E\u043B\u044F 1866 \u0433\u043E\u0434\u0430, \u0420\u0438\u043C\u0430\u043D
    \u043B\u0435\u0436\u0430\u043B \u043F\u043E\u0434 \u0444\u0438\u0433\u043E\u0432\u044B\u043C
    \u0434\u0435\u0440\u0435\u0432\u043E\u043C, \u043D\u0430\u0441\u043B\u0430\u0436\u0434\u0430\u044F\u0441\u044C
    \u0432\u0438\u0434\u043E\u043C \u043D\u0430 \u043E\u0437\u0435\u0440\u043E \u041B\u0430\u0433\u043E-\u041C\u0430\u0434\u0436\u043E\u0440\u0435,
    \u0438... \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u0430\u0434 \u0441\u0432\u043E\u0435\u0439
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0439 \u043D\u0435\u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E\u0439
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C\u044E \u043F\u043E \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435
    \u0443\u0445\u0430."
