  achievementsRu: "\u0413\u0435\u0440\u043C\u0430\u043D \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0437\u0430\u043C\u0435\u0442\u043D\u044B\u0439
    \u0441\u043B\u0435\u0434 \u0432 \u043D\u0430\u0443\u043A\u0435, \u0440\u0430\u0431\u043E\u0442\u0430\u044F
    \u0432 \u0434\u0432\u0443\u0445, \u043D\u0430 \u043F\u0435\u0440\u0432\u044B\u0439
    \u0432\u0437\u0433\u043B\u044F\u0434, \u0434\u0430\u043B\u0435\u043A\u0438\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445: \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u043D\u043E\u0432\u044B\u0439 \u0440\u0430\u0437\u0434\u0435\u043B \u0447\u0438\u0441\u0442\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u2014 **\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u0447\u0438\u0441\u0435\u043B**, \u0430 \u0437\u0430\u0442\u0435\u043C \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432 \u0432 \u0444\u0438\u0437\u0438\u043A\u0435,
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u0432 **\u0447\u0435\u0442\u044B\u0440\u0435\u0445\u043C\u0435\u0440\u043D\u043E\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E-\u0432\u0440\u0435\u043C\u044F**,
    \u0441\u0442\u0430\u0432\u0448\u0435\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u044F\u0437\u044B\u043A\u043E\u043C \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438. 
    ### \U0001F9EE \u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B:
    \u043D\u043E\u0432\u044B\u0439 \u044F\u0437\u044B\u043A \u0434\u043B\u044F \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B  \u0414\u043E \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0442\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B\u0438\u0441\u044C \u0432 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E.
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E, \u043F\u043E\u043A\u0430\u0437\u0430\u0432,
    \u0447\u0442\u043E \u043C\u043D\u043E\u0433\u0438\u0435 \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u043C\u043E\u0436\u043D\u043E \u043F\u0435\u0440\u0435\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043D\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435, \u0433\u0434\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u0431\u043E\u043B\u0435\u0435
    \u043E\u0447\u0435\u0432\u0438\u0434\u043D\u044B\u043C. \u042D\u0442\u043E\u0442
    \u043F\u043E\u0434\u0445\u043E\u0434 \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B
    **\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439 \u0447\u0438\u0441\u0435\u043B**. 
    *   **\u0420\u0430\u043D\u043D\u0438\u0439 \u0442\u0440\u0438\u0443\u043C\u0444
    (1883):** \u0415\u0449\u0451 \u0432 17 \u043B\u0435\u0442, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C, \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u0440\u0435\u0448\u0438\u043B
    \u0441\u043B\u043E\u0436\u043D\u0443\u044E \u0437\u0430\u0434\u0430\u0447\u0443
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0438
    \u0446\u0435\u043B\u043E\u0433\u043E \u0447\u0438\u0441\u043B\u0430 \u0432 \u0432\u0438\u0434\u0435
    \u0441\u0443\u043C\u043C\u044B \u043F\u044F\u0442\u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u0431\u044B\u043B\u0430
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u0430,
    \u0447\u0442\u043E \u043E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0434\u0430\u043B \u0440\u0435\u0448\u0435\u043D\u0438\u0435, \u0430 \u0441\u043E\u0437\u0434\u0430\u043B
    \u043E\u0431\u0448\u0438\u0440\u043D\u0443\u044E \u043E\u0431\u0449\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0445
    \u0444\u043E\u0440\u043C, \u0437\u0430 \u0447\u0442\u043E \u0443\u0434\u043E\u0441\u0442\u043E\u0438\u043B\u0441\u044F
    \u043F\u0440\u0435\u043C\u0438\u0438 \u0413\u0440\u0430\u043D-\u043F\u0440\u0438.
    \u042D\u0442\u043E\u0442 \u0443\u0441\u043F\u0435\u0445 \u043F\u0440\u0435\u0434\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B
    \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u0439
    \u043F\u0443\u0442\u044C. *   **\u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 (1896):** \u041A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u0435\u0439
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u044D\u0442\u043E\u043C
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0438 \u0441\u0442\u0430\u043B\u0430
    \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u044F **\xAB\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B\xBB (Geometrie der Zahlen)**. \u0412 \u044D\u0442\u043E\u043C
    \u0442\u0440\u0443\u0434\u0435 \u0431\u044B\u043B\u0438 \u0437\u0430\u043B\u043E\u0436\u0435\u043D\u044B
    \u043E\u0441\u043D\u043E\u0432\u044B \u043D\u043E\u0432\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043D\u0430\u0445\u043E\u0434\u044F\u0449\u0435\u0439\u0441\u044F
    \u043D\u0430 \u0441\u0442\u044B\u043A\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B. *  
    **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E \u0432\u044B\u043F\u0443\u043A\u043B\u043E\u043C \u0442\u0435\u043B\u0435:**
    \u042D\u0442\u043E \u0441\u0435\u0440\u0434\u0446\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B. \u0412 \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u043D\u043E\u043C
    \u0432\u0438\u0434\u0435 \u0434\u043B\u044F \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438
    \u043E\u043D\u0430 \u0433\u043B\u0430\u0441\u0438\u0442: \u0435\u0441\u043B\u0438
    \u0432\u0437\u044F\u0442\u044C \u0432\u044B\u043F\u0443\u043A\u043B\u0443\u044E
    \u0444\u0438\u0433\u0443\u0440\u0443, \u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u0447\u043D\u0443\u044E
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0446\u0435\u043D\u0442\u0440\u0430,
    \u043F\u043B\u043E\u0449\u0430\u0434\u044C \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043D\u0435 \u043C\u0435\u043D\u044C\u0448\u0435 4, \u0438 \u043F\u043E\u043C\u0435\u0441\u0442\u0438\u0442\u044C
    \u0435\u0451 \u0446\u0435\u043D\u0442\u0440 \u0432 \u043B\u044E\u0431\u043E\u0439
    \u0443\u0437\u0435\u043B \u0446\u0435\u043B\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u043E\u0439
    \u0440\u0435\u0448\u0435\u0442\u043A\u0438, \u0442\u043E \u0432\u043D\u0443\u0442\u0440\u0438
    \u0438\u043B\u0438 \u043D\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0435 \u0444\u0438\u0433\u0443\u0440\u044B
    \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E \u043D\u0430\u0439\u0434\u0435\u0442\u0441\u044F
    \u0435\u0449\u0451 \u043E\u0434\u043D\u0430 \u0442\u043E\u0447\u043A\u0430 \u044D\u0442\u043E\u0439
    \u0440\u0435\u0448\u0435\u0442\u043A\u0438.     *   \u042D\u0442\u0430, \u043D\u0430
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0432\u0437\u0433\u043B\u044F\u0434, \u043F\u0440\u043E\u0441\u0442\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u0434\u0435\u044F \u0441\u0442\u0430\u043B\u0430 \u043C\u043E\u0449\u043D\u044B\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0442\u0435\u043E\u0440\u0435\u043C \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0441 \u0435\u0451 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043C\u043E\u0436\u043D\u043E \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    **\u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430**
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u043B\u044E\u0431\u043E\u0435
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0435 \u0447\u0438\u0441\u043B\u043E
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043C\u043E \u0432 \u0432\u0438\u0434\u0435
    \u0441\u0443\u043C\u043C\u044B \u0447\u0435\u0442\u044B\u0440\u0435\u0445 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432,
    \u0438\u043B\u0438 \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 **\u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B\u0445
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u0439**.     *  
    \u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    \u0432 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430\u0445
    \u043B\u044E\u0431\u043E\u0439 \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438
    `n`: \u0434\u043B\u044F \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0433\u043E
    \u043D\u0430\u043B\u0438\u0447\u0438\u044F \u0442\u043E\u0447\u043A\u0438 \u0440\u0435\u0448\u0435\u0442\u043A\u0438
    \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F \u043E\u0431\u044A\u0435\u043C
    \u043D\u0435 \u043C\u0435\u043D\u0435\u0435 `2^n`.  ### \u23F3 \u041F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E-\u0432\u0440\u0435\u043C\u044F:
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F \u0432 \u0444\u0438\u0437\u0438\u043A\u0435 
    \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u0443\u0432\u043B\u0435\u043A\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u043E\u0439, \u0438 \u044D\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u0435\u0433\u043E \u043A \u0441\u0430\u043C\u043E\u043C\u0443 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u043C\u0443
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044E.  *   **\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u043D\u0442\u0435\u0440\u043F\u0440\u0435\u0442\u0430\u0446\u0438\u044F
    \u0421\u0422\u041E (1907-1908):** \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u043E\u0441\u043E\u0437\u043D\u0430\u043B, \u0447\u0442\u043E \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
    \u043D\u0435\u043E\u0431\u044B\u0447\u0430\u0439\u043D\u043E \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u043E\u0439,
    \u0435\u0441\u043B\u0438 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C
    \u0435\u0451 \u043D\u0435 \u0432 \u0442\u0440\u0435\u0445\u043C\u0435\u0440\u043D\u043E\u043C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435 \u0441
    \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E\u0439 \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043E\u0441\u044C\u044E, \u0430 \u0432 \u0435\u0434\u0438\u043D\u043E\u043C
    **\u0447\u0435\u0442\u044B\u0440\u0435\u0445\u043C\u0435\u0440\u043D\u043E\u043C
    \u043C\u0438\u0440\u0435**. *   **\u041F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E:** \u0412
    \u044D\u0442\u043E\u043C \u043C\u0438\u0440\u0435 \u043A\u0430\u0436\u0434\u0430\u044F
    \u0442\u043E\u0447\u043A\u0430 (\u0441\u043E\u0431\u044B\u0442\u0438\u0435) \u0437\u0430\u0434\u0430\u0435\u0442\u0441\u044F
    \u0447\u0435\u0442\u044B\u0440\u044C\u043C\u044F \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u0430\u043C\u0438:
    \u0442\u0440\u0435\u043C\u044F \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    (`x`, `y`, `z`) \u0438 \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    (`ct`), \u0433\u0434\u0435 `c` \u2014 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C
    \u0441\u0432\u0435\u0442\u0430. \u042D\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F **\u043F\u043B\u043E\u0441\u043A\u0438\u043C**
    \u0438 \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442 **\u043F\u0441\u0435\u0432\u0434\u043E\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u043C\u0435\u0442\u0440\u0438\u043A\u043E\u0439**. *   **\xAB\u041F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u0441\u0430\u043C\u043E \u043F\u043E \u0441\u0435\u0431\u0435 \u0438 \u0432\u0440\u0435\u043C\u044F
    \u0441\u0430\u043C\u043E \u043F\u043E \u0441\u0435\u0431\u0435 \u0434\u043E\u043B\u0436\u043D\u044B
    \u043E\u0431\u0440\u0430\u0442\u0438\u0442\u044C\u0441\u044F \u0432 \u0444\u0438\u043A\u0446\u0438\u0438...\xBB:**
    \u042D\u0442\u0430 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u0444\u0440\u0430\u0437\u0430 \u0438\u0437 \u0435\u0433\u043E \u0434\u043E\u043A\u043B\u0430\u0434\u0430
    \xAB\u041F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u0438 \u0432\u0440\u0435\u043C\u044F\xBB (1908) \u043E\u0442\u0440\u0430\u0436\u0430\u0435\u0442
    \u0441\u0443\u0442\u044C \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F. \u0412\u043C\u0435\u0441\u0442\u043E
    \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0442\u044C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0438 \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435 \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043A\u0438
    \u043A\u0430\u043A \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u044B\u0435,
    \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0435\u0434\u0438\u043D\u044B\u0439
    **\u0438\u043D\u0442\u0435\u0440\u0432\u0430\u043B** `ds\xB2 = c\xB2dt\xB2 -
    dx\xB2 - dy\xB2 - dz\xB2`, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043D\u044B\u043C (\u043D\u0435\u0438\u0437\u043C\u0435\u043D\u043D\u044B\u043C)
    \u0434\u043B\u044F \u0432\u0441\u0435\u0445 \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u0435\u043B\u0435\u0439.
    \u042D\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u044B\u0440\u0430\u0436\u0430\u0435\u0442 \u0442\u043E\u0442 \u0444\u0430\u043A\u0442,
    \u0447\u0442\u043E \u0432\u0440\u0435\u043C\u044F \u0442\u0435\u0447\u0435\u0442
    \u043F\u043E-\u0440\u0430\u0437\u043D\u043E\u043C\u0443 \u0432 \u0440\u0430\u0437\u043D\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0445 \u043E\u0442\u0441\u0447\u0435\u0442\u0430,
    \u0430 \u0434\u043B\u0438\u043D\u0430 \u0442\u0435\u043B \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
    \u043F\u0440\u0438 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438.  ### \U0001F4DC
    \u0414\u0440\u0443\u0433\u0438\u0435 \u0437\u043D\u0430\u0447\u0438\u043C\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B  \u041F\u043E\u043C\u0438\u043C\u043E \u0434\u0432\u0443\u0445
    \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439,
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0438 \u0432 \u0434\u0440\u0443\u0433\u0438\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445: *   \u0412\u043D\u0435\u0441
    \u0432\u0430\u0436\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434 \u0432 **\u0442\u0435\u043E\u0440\u0438\u044E
    \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u0438\u043A\u043E\u0432
    \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0432\u044B\u043F\u0443\u043A\u043B\u044B\u0445
    \u0442\u0435\u043B**. *   \u0418\u043C\u0435\u0435\u0442 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043F\u043E **\u0433\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435**
    \u0438 **\u0442\u0435\u043E\u0440\u0438\u0438 \u043A\u0430\u043F\u0438\u043B\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u0438**.
    *   \u041F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E
    \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u043C\u0435\u0440\u043D\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0443 **\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u041C\u0430\u043A\u0441\u0432\u0435\u043B\u043B\u0430**.  \u0412\u043A\u043B\u0430\u0434
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u043A\u0430\u043B\u0435\u043D
    \u0442\u0435\u043C, \u0447\u0442\u043E \u043E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0440\u0435\u0448\u0438\u043B \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438, \u0430 \u0441\u043E\u0437\u0434\u0430\u043B
    \u0446\u0435\u043B\u044B\u0435 \u043D\u043E\u0432\u044B\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u044F\u0437\u044B\u043A\u0438 \u0438 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B
    \u2014 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0447\u0438\u0441\u0435\u043B
    \u0434\u043B\u044F \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438
    \u0438 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E-\u0432\u0440\u0435\u043C\u044F
    \u0434\u043B\u044F \u0444\u0438\u0437\u0438\u043A\u0438. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B,
    \u0441\u043E\u0431\u0440\u0430\u043D\u043D\u044B\u0435 \u0438 \u0438\u0437\u0434\u0430\u043D\u043D\u044B\u0435
    \u0434\u0440\u0443\u0433\u043E\u043C \u0414\u0430\u0432\u0438\u0434\u043E\u043C
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C , \u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u043D\u0430\u0443\u043A\u0443 XX \u0432\u0435\u043A\u0430."
  achievementsEn: 
  personalLifeRu: "\u0413\u0435\u0440\u043C\u0430\u043D \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u043F\u0440\u043E\u0436\u0438\u043B \u044F\u0440\u043A\u0443\u044E, \u043D\u043E
    \u043D\u0435\u0434\u043E\u043B\u0433\u0443\u044E \u0436\u0438\u0437\u043D\u044C,
    \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u0443\u044E \u043D\u0430\u0443\u043A\u043E\u0439
    \u0438 \u0442\u0435\u0441\u043D\u043E\u0439 \u0434\u0440\u0443\u0436\u0431\u043E\u0439.
    \u0415\u0433\u043E \u043F\u0443\u0442\u044C \u043E\u0442 \u0432\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434\u0430
    \u0438\u0437 \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439 \u0438\u043C\u043F\u0435\u0440\u0438\u0438
    \u0434\u043E \u043E\u0434\u043D\u043E\u0433\u043E \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u0431\u044B\u043B \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0438 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u043E\u0431\u043E\u0440\u0432\u0430\u043B\u0441\u044F
    \u043D\u0430 \u0432\u0437\u043B\u0435\u0442\u0435.  ### \U0001F476 \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0441\u0435\u043C\u044C\u044F  \u0413\u0435\u0440\u043C\u0430\u043D \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **22 \u0438\u044E\u043D\u044F 1864
    \u0433\u043E\u0434\u0430** \u0432 \u043C\u0435\u0441\u0442\u0435\u0447\u043A\u0435
    **\u0410\u043B\u0435\u043A\u0441\u043E\u0442\u044B** (\u043D\u044B\u043D\u0435
    \u0447\u0430\u0441\u0442\u044C \u041A\u0430\u0443\u043D\u0430\u0441\u0430, \u041B\u0438\u0442\u0432\u0430),
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0442\u043E\u0433\u0434\u0430 \u0432\u0445\u043E\u0434\u0438\u043B\u043E
    \u0432 \u0441\u043E\u0441\u0442\u0430\u0432 \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439
    \u0438\u043C\u043F\u0435\u0440\u0438\u0438. \u041E\u043D \u0431\u044B\u043B \u0442\u0440\u0435\u0442\u044C\u0438\u043C
    \u0441\u044B\u043D\u043E\u043C \u0432 \u0437\u0430\u0436\u0438\u0442\u043E\u0447\u043D\u043E\u0439
    \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0439 \u043A\u0443\u043F\u0435\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0435\u043C\u044C\u0435.  - **\u041E\u0442\u0435\u0446:** \u041B\u0435\u0432\u0438\u043D
    (\u041B\u0435\u0439\u0431) \u0411\u043E\u0440\u0443\u0445\u043E\u0432\u0438\u0447
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439, \u043A\u0443\u043F\u0435\u0446
    \u043F\u0435\u0440\u0432\u043E\u0439 \u0433\u0438\u043B\u044C\u0434\u0438\u0438.
    \u041D\u0430 \u0435\u0433\u043E \u043F\u043E\u0436\u0435\u0440\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0430
    \u0425\u043E\u0440\u0430\u043B\u044C\u043D\u0430\u044F \u0441\u0438\u043D\u0430\u0433\u043E\u0433\u0430
    \u0432 \u041A\u043E\u0432\u043D\u043E (\u043D\u044B\u043D\u0435 \u041A\u0430\u0443\u043D\u0430\u0441).
    - **\u041C\u0430\u0442\u044C:** \u0420\u0430\u0445\u0438\u043B\u044C \u0418\u0441\u0430\u0430\u043A\u043E\u0432\u043D\u0430
    \u0422\u043E\u0439\u0431\u043C\u0430\u043D. - **\u0411\u0440\u0430\u0442\u044C\u044F
    \u0438 \u0441\u0435\u0441\u0442\u0440\u0430:** \u0421\u0442\u0430\u0440\u0448\u0438\u0439
    \u0431\u0440\u0430\u0442 **\u041C\u0430\u043A\u0441** \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B
    \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u0439 \u0431\u0438\u0437\u043D\u0435\u0441
    \u0438 \u0441\u0442\u0430\u043B \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u043C
    \u043A\u043E\u043D\u0441\u0443\u043B\u043E\u043C \u0432 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0435.
    \u0412\u0442\u043E\u0440\u043E\u0439 \u0431\u0440\u0430\u0442, **\u041E\u0441\u043A\u0430\u0440**
    (1858\u20131931), \u0441\u0442\u0430\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u0432\u0440\u0430\u0447\u043E\u043C-\u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0434\u0438\u0430\u0431\u0435\u0442\u0430. \u0422\u0430\u043A\u0436\u0435 \u0443
    \u0413\u0435\u0440\u043C\u0430\u043D\u0430 \u0431\u044B\u043B\u0438 \u0441\u0442\u0430\u0440\u0448\u0430\u044F
    \u0441\u0435\u0441\u0442\u0440\u0430 \u0424\u0430\u043D\u043D\u0438 \u0438 \u043C\u043B\u0430\u0434\u0448\u0438\u0439
    \u0431\u0440\u0430\u0442 \u0422\u0443\u0432\u044C\u044F (\u0422\u043E\u0431\u0438). 
    \u0412 1872 \u0433\u043E\u0434\u0443, \u0441\u043F\u0430\u0441\u0430\u044F\u0441\u044C
    \u043E\u0442 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0445 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u0438\u0445
    \u043F\u043E\u0433\u0440\u043E\u043C\u043E\u0432 \u0432 \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439
    \u0438\u043C\u043F\u0435\u0440\u0438\u0438, \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433, \u0433\u0434\u0435
    \u043E\u0442\u0435\u0446 \u0437\u0430\u043D\u044F\u043B\u0441\u044F \u044D\u043A\u0441\u043F\u043E\u0440\u0442\u043E\u043C
    \u043A\u043E\u0432\u0440\u043E\u0432 \u0438 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0437\u0430\u0432\u043E\u0434\u043D\u044B\u0445 \u0438\u0433\u0440\u0443\u0448\u0435\u043A. 
    ### \U0001F4DA \u0413\u043E\u0434\u044B \u0443\u0447\u0435\u0431\u044B \u0438
    \u043F\u0435\u0440\u0432\u044B\u0435 \u0442\u0440\u0438\u0443\u043C\u0444\u044B 
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
    \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438. \u0412 \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0438
    \u043E\u043D \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0438\u0437\u0443\u0447\u0430\u043B \u0442\u0440\u0443\u0434\u044B \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430,
    \u0414\u0438\u0440\u0438\u0445\u043B\u0435 \u0438 \u0413\u0430\u0443\u0441\u0441\u0430.
    \u0412 1879 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u044E \u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 **\u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442**.  \u0412
    \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0435 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E
    \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E, \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0432\u0448\u0435\u0435
    \u0432\u0441\u044E \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C: \u043E\u043D \u043F\u043E\u0434\u0440\u0443\u0436\u0438\u043B\u0441\u044F
    \u0441 \u0441\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A\u043E\u043C **\u0414\u0430\u0432\u0438\u0434\u043E\u043C
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C**. \u0412\u043C\u0435\u0441\u0442\u0435
    \u0441 \u0410\u0434\u043E\u043B\u044C\u0444\u043E\u043C \u0413\u0443\u0440\u0432\u0438\u0446\u0435\u043C
    \u043E\u043D\u0438 \u0443\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u043B\u0438
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435 \u0434\u043E\u043B\u0433\u0438\u0435
    \xAB\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0438\xBB, \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u044F
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B.
    \u041F\u043E\u0437\u0436\u0435 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u0433\u0434\u0435 \u0441\u043B\u0443\u0448\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438
    \u0442\u0430\u043A\u0438\u0445 \u043A\u043E\u0440\u0438\u0444\u0435\u0435\u0432,
    \u043A\u0430\u043A \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440 \u0438 \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441. 
    \u0412 1881 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    **17 \u043B\u0435\u0442**, \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B \u0441\u0432\u043E\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0445
    \u0444\u043E\u0440\u043C \u043D\u0430 \u043A\u043E\u043D\u043A\u0443\u0440\u0441
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A. \u0412\u043E\u043F\u0440\u0435\u043A\u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u0430\u043C,
    \u0441\u0442\u0430\u0442\u044C\u044F \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u0430
    \u043D\u0430 \u043D\u0435\u043C\u0435\u0446\u043A\u043E\u043C \u044F\u0437\u044B\u043A\u0435,
    \u043D\u043E \u044D\u0442\u043E \u043D\u0435 \u043F\u043E\u043C\u0435\u0448\u0430\u043B\u043E
    \u0435\u0439 \u0432 1883 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    **\u0413\u0440\u0430\u043D-\u043F\u0440\u0438 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043D\u0430\u0443\u043A\u0430\u043C (Grand Prix des Sciences Math\xE9matiques)**.
    \u0412 1885 \u0433\u043E\u0434\u0443 \u043E\u043D \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u0432 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0435, \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0432
    \u0441\u0432\u043E\u0438 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. 
    ### \U0001F468\u200D\U0001F3EB \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u043F\u0443\u0442\u044C  \u041F\u043E\u0441\u043B\u0435 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0431\u044B\u043B\u0430 \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439: 
    *   **1887\u20131894:** \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0432 **\u0411\u043E\u043D\u043D\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435**
    (\u0441 1892 \u2014 \u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u0439,
    \u0441 1894 \u2014 \u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u0439
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440). *   **1894\u20131896:**
    \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u0432 **\u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435**. *  
    **1896\u20131902:** \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u0432
    \u0426\u044E\u0440\u0438\u0445\u0441\u043A\u043E\u043C \u043F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u043A\u0443\u043C\u0435
    (\u043D\u044B\u043D\u0435 ETH Zurich). \u0417\u0434\u0435\u0441\u044C \u043E\u043D
    \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439
    **\u0410\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u043F\u043E \u0438\u0440\u043E\u043D\u0438\u0438
    \u0441\u0443\u0434\u044C\u0431\u044B, \u043D\u0435 \u0432\u044B\u0437\u044B\u0432\u0430\u043B
    \u0443 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E \u0434\u043E\u0432\u0435\u0440\u0438\u044F
    \u043A\u0430\u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438
    \u0447\u0430\u0441\u0442\u043E \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0430\u043B
    \u0435\u0433\u043E \u043B\u0435\u043A\u0446\u0438\u0438. *   **\u0421 1902 \u0433\u043E\u0434\u0430
    \u0438 \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0436\u0438\u0437\u043D\u0438:**
    \u041F\u043E \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u044E
    \u0441\u0432\u043E\u0435\u0433\u043E \u0434\u0440\u0443\u0433\u0430 \u0414\u0430\u0432\u0438\u0434\u0430
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u0437\u0430\u043D\u044F\u043B
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u0443\u044E
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u043A\u0430\u0444\u0435\u0434\u0440\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432 **\u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435** \u2014
    \u0432\u0435\u0434\u0443\u0449\u0435\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 \u043C\u0438\u0440\u0430 \u0442\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438.  ### \U0001F91D \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438 
    \u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u0444\u0438\u0433\u0443\u0440\u043E\u0439
    \u0432 \u043B\u0438\u0447\u043D\u043E\u0439 \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0431\u044B\u043B **\u0414\u0430\u0432\u0438\u0434 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442**.
    \u0418\u0445 \u0434\u0440\u0443\u0436\u0431\u0430, \u043D\u0430\u0447\u0430\u0432\u0448\u0430\u044F\u0441\u044F
    \u0432 \u0441\u0442\u0443\u0434\u0435\u043D\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B, \u0431\u044B\u043B\u0430 \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u0440\u043E\u0447\u043D\u043E\u0439. \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0435\u0433\u043E \xAB\u0441\u0432\u043E\u0438\u043C
    \u043B\u0443\u0447\u0448\u0438\u043C, \u0441\u0430\u043C\u044B\u043C \u043D\u0430\u0434\u0435\u0436\u043D\u044B\u043C
    \u0434\u0440\u0443\u0433\u043E\u043C\xBB. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u043D\u0430\u0441\u0442\u043E\u044F\u043B
    \u043D\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438 \u043A\u0430\u0444\u0435\u0434\u0440\u044B
    \u0434\u043B\u044F \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435. \u041F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442 \u0438\u0437\u0434\u0430\u043B
    \u043F\u043E\u043B\u043D\u043E\u0435 \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435
    \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u043E\u0432.  \u0412 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u0442\u0435\u0441\u043D\u043E
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0430\u043B \u0441 **\u0424\u0435\u043B\u0438\u043A\u0441\u043E\u043C
    \u041A\u043B\u0435\u0439\u043D\u043E\u043C** \u0438 **\u041A\u0430\u0440\u043B\u043E\u043C
    \u0420\u0443\u043D\u0433\u0435**. \u042D\u0442\u0438 \u0442\u0440\u043E\u0435,
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C,
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043B\u0438 \xAB\u043A\u0432\u0430\u0440\u0442\u0435\u0442\xBB
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u0447\u044C\u0438
    \u0435\u0436\u0435\u043D\u0435\u0434\u0435\u043B\u044C\u043D\u044B\u0435 \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0438
    \u0441\u0442\u0430\u043B\u0438 \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u043C\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u0435\u0441\u043B\u0438 \u041A\u043B\u0435\u0439\u043D
    \u0431\u044B\u043B \u0441\u043A\u043B\u043E\u043D\u0435\u043D \u043A \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u0438
    \u0438 \u043F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E,
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u0438 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u043B\u0438 \u0431\u043E\u043B\u0435\u0435
    \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u0443\u044E, \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0443\u044E
    \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0443. \u041E\u0434\u043D\u0430
    \u0438\u0437 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u0448\u0443\u0442\u043E\u043A
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E \u043D\u0430
    \u0437\u0430\u0441\u0435\u0434\u0430\u043D\u0438\u0438 \u041A\u043B\u0435\u0439\u043D\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u044B\u0442\u0430\u043B\u0441\u044F
    \u043E\u0431\u0441\u0443\u0434\u0438\u0442\u044C \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0443
    \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0445 \u0448\u043A\u043E\u043B, \u0431\u044B\u043B\u0430:
    \xAB\u041D\u0435 \u043A\u0430\u0436\u0435\u0442\u0441\u044F \u043B\u0438 \u0432\u0430\u043C,
    \u0433\u043E\u0441\u043F\u043E\u0434\u0438\u043D \u0442\u0430\u0439\u043D\u044B\u0439
    \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A, \u0447\u0442\u043E \u0441\u0440\u0435\u0434\u0438
    \u044D\u0442\u0438\u0445 \u0446\u0438\u0444\u0440 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E
    \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u0434\u043E\u043B\u044E \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0442
    \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u0447\u0438\u0441\u043B\u0430?\xBB. 
    \u0421\u0430\u043C \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0443\u0432\u043B\u0435\u0447\u0435\u043D
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u043E\u0439 \u0438, \u0445\u043E\u0442\u044F \u0438\u0437\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D \u043E\u0442\u043D\u0435\u0441\u0441\u044F
    \u043A \u0435\u0433\u043E \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u043C\u0435\u0440\u043D\u043E\u0439
    \u043C\u043E\u0434\u0435\u043B\u0438 \u0441\u043A\u0435\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438,
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u043E\u043A\u0430\u0437\u0430\u043B\u0430
    \u043A\u043B\u044E\u0447\u0435\u0432\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438. 
    ### \U0001F48D \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C 
    \u0412 1897 \u0433\u043E\u0434\u0443 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u0410\u0432\u0433\u0443\u0441\u0442\u0435
    \u0410\u0434\u043B\u0435\u0440** \u0432 \u0421\u0442\u0440\u0430\u0441\u0431\u0443\u0440\u0433\u0435.
    \u0423 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C \u0434\u0432\u0435
    \u0434\u043E\u0447\u0435\u0440\u0438: *   **\u041B\u0438\u043B\u0438** (1898\u20131983),
    \u0441\u0442\u0430\u0432\u0448\u0430\u044F \u0443\u0447\u0435\u043D\u044B\u043C-\u0431\u043E\u0442\u0430\u043D\u0438\u043A\u043E\u043C.
    *   **\u0420\u0443\u0442** (1902\u20132000).  ### \U0001F54A\uFE0F \u0421\u043C\u0435\u0440\u0442\u044C 
    12 \u044F\u043D\u0432\u0430\u0440\u044F 1909 \u0433\u043E\u0434\u0430, \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 44 \u043B\u0435\u0442, \u0432
    \u0440\u0430\u0441\u0446\u0432\u0435\u0442\u0435 \u0441\u0438\u043B \u0438 \u0441\u043B\u0430\u0432\u044B,
    \u0413\u0435\u0440\u043C\u0430\u043D \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u0441\u043A\u043E\u0440\u043E\u043F\u043E\u0441\u0442\u0438\u0436\u043D\u043E
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435
    \u043E\u0442 \u0440\u0430\u0437\u0440\u044B\u0432\u0430 \u0430\u043F\u043F\u0435\u043D\u0434\u0438\u043A\u0441\u0430
    (\u043F\u0435\u0440\u0438\u0442\u043E\u043D\u0438\u0442\u0430). \u0415\u0433\u043E
    \u0441\u043C\u0435\u0440\u0442\u044C \u0441\u0442\u0430\u043B\u0430 \u0442\u044F\u0436\u0435\u043B\u0435\u0439\u0448\u0438\u043C
    \u0443\u0434\u0430\u0440\u043E\u043C \u0434\u043B\u044F \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430
    \u0438 \u0432\u0441\u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430."
  personalLifeEn: 
  shortBioRu: "\u0413\u0435\u0440\u043C\u0430\u043D \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    (22 \u0438\u044E\u043D\u044F 1864 \u2014 12 \u044F\u043D\u0432\u0430\u0440\u044F
    1909) \u2014 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0438 \u0444\u0438\u0437\u0438\u043A, \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B
    \u0438 \u0447\u0435\u0442\u044B\u0440\u0451\u0445\u043C\u0435\u0440\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430-\u0432\u0440\u0435\u043C\u0435\u043D\u0438,
    \u0441\u0442\u0430\u0432\u0448\u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438. 
    ### \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0434\u0435\u0442\u0441\u0442\u0432\u043E  \u0413\u0435\u0440\u043C\u0430\u043D
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0439 \u043A\u0443\u043F\u0435\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0435\u043C\u044C\u0435 \u0432 \u043C\u0435\u0441\u0442\u0435\u0447\u043A\u0435
    \u0410\u043B\u0435\u043A\u0441\u043E\u0442\u044B \u0410\u0432\u0433\u0443\u0441\u0442\u043E\u0432\u0441\u043A\u043E\u0439
    \u0433\u0443\u0431\u0435\u0440\u043D\u0438\u0438 \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439
    \u0438\u043C\u043F\u0435\u0440\u0438\u0438 (\u043D\u044B\u043D\u0435 \u2014 \u0440\u0430\u0439\u043E\u043D
    \u041A\u0430\u0443\u043D\u0430\u0441\u0430 \u0432 \u041B\u0438\u0442\u0432\u0435).
    \u0415\u0433\u043E \u043E\u0442\u0446\u043E\u043C \u0431\u044B\u043B \u043A\u0443\u043F\u0435\u0446
    \u043F\u0435\u0440\u0432\u043E\u0439 \u0433\u0438\u043B\u044C\u0434\u0438\u0438
    \u041B\u0435\u0432\u0438\u043D (\u041B\u0435\u0439\u0431\u0430) \u0411\u043E\u0440\u0443\u0445\u043E\u0432\u0438\u0447
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439, \u043C\u0430\u0442\u0435\u0440\u044C\u044E
    \u2014 \u0420\u0430\u0445\u0438\u043B\u044C \u0418\u0441\u0430\u0430\u043A\u043E\u0432\u043D\u0430
    \u0422\u043E\u0439\u0431\u043C\u0430\u043D. \u0421\u0435\u043C\u044C\u044F \u0431\u044B\u043B\u0430
    \u0441\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0438 \u0443\u0432\u0430\u0436\u0430\u0435\u043C\u043E\u0439: \u043D\u0430 \u043F\u043E\u0436\u0435\u0440\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u043E\u0442\u0446\u0430 \u0432 \u041A\u043E\u0432\u043D\u043E \u0431\u044B\u043B\u0430
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0430 \u0425\u043E\u0440\u0430\u043B\u044C\u043D\u0430\u044F
    \u0441\u0438\u043D\u0430\u0433\u043E\u0433\u0430.  \u0413\u0435\u0440\u043C\u0430\u043D
    \u0431\u044B\u043B \u0442\u0440\u0435\u0442\u044C\u0438\u043C \u0441\u044B\u043D\u043E\u043C
    \u0432 \u0441\u0435\u043C\u044C\u0435. \u0415\u0433\u043E \u0441\u0442\u0430\u0440\u0448\u0438\u0435
    \u0431\u0440\u0430\u0442\u044C\u044F: - **\u041C\u0430\u043A\u0441 (\u041C\u0430\u0440\u043A\u0443\u0441)**
    \u2014 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0435
    \u0434\u0435\u043B\u043E, \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0442\u043E\u0440\u0433\u043E\u0432\u043B\u0435\u0439 \u0438 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0441\u043B\u0443\u0436\u0438\u043B \u043A\u043E\u043D\u0441\u0443\u043B\u043E\u043C
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438 \u0432 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0435.
    - **\u041E\u0441\u043A\u0430\u0440** \u2014 \u0441\u0442\u0430\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u0432\u0440\u0430\u0447\u043E\u043C, \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0434\u0438\u0430\u0431\u0435\u0442\u0430, \u0438 \u0434\u0435\u0434\u043E\u043C
    \u0430\u0441\u0442\u0440\u043E\u0444\u0438\u0437\u0438\u043A\u0430 \u0420\u0443\u0434\u043E\u043B\u044C\u0444\u0430
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E.  \u0412 1872
    \u0433\u043E\u0434\u0443, \u043E\u043F\u0430\u0441\u0430\u044F\u0441\u044C \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u0438\u0445
    \u043F\u043E\u0433\u0440\u043E\u043C\u043E\u0432 \u0432 \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439
    \u0438\u043C\u043F\u0435\u0440\u0438\u0438, \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433 (\u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044F),
    \u0433\u0434\u0435 \u043E\u0442\u0435\u0446 \u0437\u0430\u043D\u044F\u043B\u0441\u044F
    \u044D\u043A\u0441\u043F\u043E\u0440\u0442\u043E\u043C \u043A\u043E\u0432\u0440\u043E\u0432
    \u0438 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0437\u0430\u0432\u043E\u0434\u043D\u044B\u0445 \u0438\u0433\u0440\u0443\u0448\u0435\u043A.
    \u0417\u0434\u0435\u0441\u044C \u043F\u0440\u043E\u0448\u043B\u0438 \u0434\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u044E\u043D\u043E\u0441\u0442\u044C \u0413\u0435\u0440\u043C\u0430\u043D\u0430. 
    ### \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0438
    \u0440\u0430\u043D\u043D\u0438\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F 
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0430\u043B\u0430\u043D\u0442 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u0440\u0430\u043D\u043E.
    \u0415\u0449\u0451 \u0432 \u0433\u0438\u043C\u043D\u0430\u0437\u0438\u0438 \u043E\u043D
    \u0438\u0437\u0443\u0447\u0430\u043B \u0442\u0440\u0443\u0434\u044B \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430,
    \u0414\u0438\u0440\u0438\u0445\u043B\u0435 \u0438 \u0413\u0430\u0443\u0441\u0441\u0430.
    \u0412 1880 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    15 \u043B\u0435\u0442, \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u0433\u0434\u0435
    \u0435\u0433\u043E \u043E\u0434\u043D\u043E\u043A\u0443\u0440\u0441\u043D\u0438\u043A\u043E\u043C
    \u0438 \u0431\u043B\u0438\u0437\u043A\u0438\u043C \u0434\u0440\u0443\u0433\u043E\u043C
    \u0441\u0442\u0430\u043B \u0414\u0430\u0432\u0438\u0434 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442
    \u2014 \u0431\u0443\u0434\u0443\u0449\u0430\u044F \u043B\u0435\u0433\u0435\u043D\u0434\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0417\u0430\u0442\u0435\u043C
    \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u0441\u043B\u0443\u0448\u0430\u044F \u043B\u0435\u043A\u0446\u0438\u0438 \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440\u0430
    \u0438 \u0412\u0435\u0439\u0435\u0440\u0448\u0442\u0440\u0430\u0441\u0441\u0430. 
    \u041F\u043E\u0432\u043E\u0440\u043E\u0442\u043D\u044B\u043C \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C
    \u0432 \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0435 \u0441\u0442\u0430\u043B
    1881 \u0433\u043E\u0434. \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0430\u044F
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044F \u043D\u0430\u0443\u043A \u043E\u0431\u044A\u044F\u0432\u0438\u043B\u0430
    \u043A\u043E\u043D\u043A\u0443\u0440\u0441 \u043D\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0438
    \u0447\u0438\u0441\u043B\u0430 \u0432 \u0432\u0438\u0434\u0435 \u0441\u0443\u043C\u043C\u044B
    \u043F\u044F\u0442\u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432.
    18-\u043B\u0435\u0442\u043D\u0438\u0439 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439,
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0440\u0435\u0448\u0438\u043B
    \u0437\u0430\u0434\u0430\u0447\u0443, \u043D\u043E \u0438 \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B \u0446\u0435\u043B\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0445
    \u0444\u043E\u0440\u043C \u042D\u0439\u0437\u0435\u043D\u0448\u0442\u0435\u0439\u043D\u0430.
    \u0412 1883 \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u0413\u0440\u0430\u043D-\u043F\u0440\u0438 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043D\u0430\u0443\u043A\u0430\u043C (Grand Prix des Sciences Math\xE9matiques),
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0432 \u043D\u0430\u0433\u0440\u0430\u0434\u0443
    \u0441 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0413\u0435\u043D\u0440\u0438 \u0421\u043C\u0438\u0442\u043E\u043C. \u0412 1885
    \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0432 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0435 \u0437\u0430
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E, \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0432\u0448\u0443\u044E
    \u0435\u0433\u043E \u0442\u0440\u0438\u0443\u043C\u0444\u0430\u043B\u044C\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443.  ### \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430  \u041A\u0430\u0440\u044C\u0435\u0440\u0430
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E \u0431\u044B\u043B\u0430
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0439 \u0438 \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439:
    *   **1887\u20131894**: \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0411\u043E\u043D\u043D\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    (\u0441 1892 \u2014 \u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u0439,
    \u0441 1894 \u2014 \u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u0439
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440). *   **1894\u20131896**:
    \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u041A\u0451\u043D\u0438\u0433\u0441\u0431\u0435\u0440\u0433\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430. *  
    **1896\u20131902**: \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u0426\u044E\u0440\u0438\u0445\u0441\u043A\u043E\u0433\u043E
    \u043F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u043A\u0443\u043C\u0430
    (Eidgen\xF6ssische Polytechnikum). \u0412 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0435\u0433\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432
    \u0431\u044B\u043B **\u0410\u043B\u044C\u0431\u0435\u0440\u0442 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u043F\u043E \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F\u043C
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E, \u0447\u0430\u0441\u0442\u043E
    \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438
    \u0438 \u043D\u0435 \u0432\u044B\u0437\u044B\u0432\u0430\u043B \u0443 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0434\u043E\u0432\u0435\u0440\u0438\u044F \u043A\u0430\u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A.
    *   **1897**: \u0416\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u0410\u0432\u0433\u0443\u0441\u0442\u0435
    \u0410\u0434\u043B\u0435\u0440 \u0432 \u0421\u0442\u0440\u0430\u0441\u0431\u0443\u0440\u0433\u0435.
    \u0423 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C \u0434\u0432\u0435
    \u0434\u043E\u0447\u0435\u0440\u0438 \u2014 \u041B\u0438\u043B\u0438 (1898) \u0438
    \u0420\u0443\u0442 (1902). *   **1902\u20131909**: \u041F\u043E \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u044E
    \u0441\u0432\u043E\u0435\u0433\u043E \u0434\u0440\u0443\u0433\u0430 \u0414\u0430\u0432\u0438\u0434\u0430
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430 \u0437\u0430\u043D\u044F\u043B
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u0443\u044E
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u043A\u0430\u0444\u0435\u0434\u0440\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u2014
    \u0446\u0435\u043D\u0442\u0440\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438 \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. 
    ### \u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B
    \u0438 \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445: 
    1.  **\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B**:
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u0434\u0435\u0442\u0438\u0449\u0435
    \u0432 \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u0412 1896 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u044E \xAB\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B\xBB (Geometrie der Zahlen), \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u043B \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u0437\u0430\u0434\u0430\u0447 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B, \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A
    \u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u044F.
    \u0415\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    **\u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E \u0432\u044B\u043F\u0443\u043A\u043B\u043E\u043C \u0442\u0435\u043B\u0435**
    \u0441\u0442\u0430\u043B\u0430 \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C
    \u043A\u0430\u043C\u043D\u0435\u043C \u044D\u0442\u043E\u0439 \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u044B. 
    2.  **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u0438\u0437\u0438\u043A\u0430**: \u0412 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435,
    \u043F\u043E\u0434 \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430,
    \u043E\u043D \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0441\u044F
    \u0444\u0438\u0437\u0438\u043A\u043E\u0439, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043D\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u041B\u043E\u0440\u0435\u043D\u0446\u0430 \u0438 \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u043E\u0439. 
    3.  **\u041F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E-\u0432\u0440\u0435\u043C\u044F**:
    \u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435,
    \u043F\u0440\u043E\u0441\u043B\u0430\u0432\u0438\u0432\u0448\u0435\u0435 \u0438\u043C\u044F
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E. \u0412 1907\u20131908
    \u0433\u043E\u0434\u0430\u0445 \u043E\u043D \u043E\u0441\u043E\u0437\u043D\u0430\u043B,
    \u0447\u0442\u043E \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430 \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u044D\u043B\u0435\u0433\u0430\u043D\u0442\u043D\u043E
    \u043E\u043F\u0438\u0441\u0430\u043D\u0430 \u0432 \u0447\u0435\u0442\u044B\u0440\u0451\u0445\u043C\u0435\u0440\u043D\u043E\u043C
    \u043C\u0438\u0440\u0435, \u0433\u0434\u0435 \u0442\u0440\u0438 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u044F\u044E\u0442\u0441\u044F
    \u0441 \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C. \u041E\u043D \u0432\u0432\u0451\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\xAB\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E\xBB** \u2014
    \u0447\u0435\u0442\u044B\u0440\u0451\u0445\u043C\u0435\u0440\u043D\u043E\u0435
    \u043F\u0441\u0435\u0432\u0434\u043E\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E.  21
    \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F 1908 \u0433\u043E\u0434\u0430
    \u043D\u0430 80-\u043C \u0441\u044A\u0435\u0437\u0434\u0435 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0445
    \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u043E\u0438\u0441\u043F\u044B\u0442\u0430\u0442\u0435\u043B\u0435\u0439
    \u0438 \u0432\u0440\u0430\u0447\u0435\u0439 \u0432 \u041A\u0451\u043B\u044C\u043D\u0435
    \u043E\u043D \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441 \u0441\u0432\u043E\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u043B\u0435\u043A\u0446\u0438\u044E
    \xAB\u041F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u0438 \u0432\u0440\u0435\u043C\u044F\xBB (Raum und Zeit), \u0433\u0434\u0435
    \u043F\u0440\u043E\u0432\u043E\u0437\u0433\u043B\u0430\u0441\u0438\u043B: > **\xAB\u041E\u0442\u043D\u044B\u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E \u0441\u0430\u043C\u043E
    \u043F\u043E \u0441\u0435\u0431\u0435 \u0438 \u0432\u0440\u0435\u043C\u044F \u0441\u0430\u043C\u043E
    \u043F\u043E \u0441\u0435\u0431\u0435 \u0434\u043E\u043B\u0436\u043D\u044B \u043E\u0431\u0440\u0430\u0442\u0438\u0442\u044C\u0441\u044F
    \u0432 \u0444\u0438\u043A\u0446\u0438\u0438, \u0438 \u043B\u0438\u0448\u044C
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u0438\u0434 \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F
    \u043E\u0431\u043E\u0438\u0445 \u0434\u043E\u043B\u0436\u0435\u043D \u0435\u0449\u0451
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C\xBB**. 
    \u0418\u0437\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D
    \u0441\u043A\u0435\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043E\u0442\u043D\u0451\u0441\u0441\u044F
    \u043A \u044D\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438, \u043D\u0430\u0437\u0432\u0430\u0432
    \u0435\u0451 \u0438\u0437\u043B\u0438\u0448\u043D\u0435 \u0441\u043B\u043E\u0436\u043D\u043E\u0439,
    \u043D\u043E \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0438\u043C\u0435\u043D\u043D\u043E \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E \u0441\u0442\u0430\u043B\u043E
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0438
    \u043E\u0431\u0449\u0435\u0439 \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438. 
    ### \u0421\u043C\u0435\u0440\u0442\u044C \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u0412 \u0440\u0430\u0437\u0433\u0430\u0440 \u0441\u0432\u043E\u0435\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u044B,
    12 \u044F\u043D\u0432\u0430\u0440\u044F 1909 \u0433\u043E\u0434\u0430, \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u0441\u043A\u043E\u0440\u043E\u043F\u043E\u0441\u0442\u0438\u0436\u043D\u043E
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435
    \u043E\u0442 \u0440\u0430\u0437\u0440\u044B\u0432\u0430 \u0430\u043F\u043F\u0435\u043D\u0434\u0438\u043A\u0441\u0430
    (\u043F\u0435\u0440\u0438\u0442\u043E\u043D\u0438\u0442\u0430) \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    44 \u043B\u0435\u0442. \u0415\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u044C
    \u0441\u0442\u0430\u043B\u0430 \u0442\u044F\u0436\u0435\u043B\u044B\u043C \u0443\u0434\u0430\u0440\u043E\u043C
    \u0434\u043B\u044F \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u043C\u0438\u0440\u0430
    \u0438 \u0434\u043B\u044F \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430,
    \u043F\u043E\u0442\u0435\u0440\u044F\u0432\u0448\u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0433\u043E
    \u0431\u043B\u0438\u0437\u043A\u043E\u0433\u043E \u0434\u0440\u0443\u0433\u0430. 
    \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u0435\u0433\u043E
    \u0442\u0440\u0443\u0434\u044B \u0431\u044B\u043B\u0438 \u0441\u043E\u0431\u0440\u0430\u043D\u044B
    \u0438 \u0438\u0437\u0434\u0430\u043D\u044B \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C
    \u0432 \u0434\u0432\u0443\u0445 \u0442\u043E\u043C\u0430\u0445 (Gesammelte Abhandlungen,
    1911). \u0418\u043C\u044F \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0443\u0432\u0435\u043A\u043E\u0432\u0435\u0447\u0435\u043D\u043E \u0432 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u044F\u0445
    \u043A\u0440\u0430\u0442\u0435\u0440\u0430 \u043D\u0430 \u041B\u0443\u043D\u0435,
    \u0430\u0441\u0442\u0435\u0440\u043E\u0438\u0434\u0430, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0432 \u043C\u043D\u043E\u0433\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0442\u0435\u0440\u043C\u0438\u043D\u0430\u0445:
    **\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E,
    \u043D\u0435\u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u043E \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E,
    \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E**."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0413\u0435\u0440\u043C\u0430\u043D\u0430
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E \u043F\u043E\u043B\u043D\u0430
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0441\u043E\u0432\u043F\u0430\u0434\u0435\u043D\u0438\u0439, \u0438\u0440\u043E\u043D\u0438\u0438
    \u0438 \u044F\u0440\u043A\u0438\u0445 \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u0435\u0433\u043E \u043A\u0430\u043A \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0433\u043E,
    \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u043E\u0433\u043E \u0438 \u043D\u0435\u043C\u043D\u043E\u0433\u043E
    \u0432\u044B\u0441\u043E\u043A\u043E\u043C\u0435\u0440\u043D\u043E\u0433\u043E
    \u0443\u0447\u0451\u043D\u043E\u0433\u043E.  ### \U0001F9E0 \u0412\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434,
    \u043F\u043E\u0431\u0435\u0434\u0438\u0432\u0448\u0438\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u0432 
    \u0412 17 \u043B\u0435\u0442, \u0435\u0449\u0451 \u0431\u0443\u0434\u0443\u0447\u0438
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C, \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u0440\u0435\u0448\u0438\u043B \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0443\u044E
    \u0437\u0430\u0434\u0430\u0447\u0443 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A \u043E
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0438
    \u0447\u0438\u0441\u043B\u0430 \u0432 \u0432\u0438\u0434\u0435 \u0441\u0443\u043C\u043C\u044B
    \u043F\u044F\u0442\u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u0431\u044B\u043B\u0430
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439,
    \u0447\u0442\u043E \u0432\u044B\u0445\u043E\u0434\u0438\u043B\u0430 \u0434\u0430\u043B\u0435\u043A\u043E
    \u0437\u0430 \u0440\u0430\u043C\u043A\u0438 \u0432\u043E\u043F\u0440\u043E\u0441\u0430
    \u0438 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0430 \u043E\u0431\u0449\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0445
    \u0444\u043E\u0440\u043C. \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u043A \u0428\u0430\u0440\u043B\u044C
    \u042D\u0440\u043C\u0438\u0442, \u043E\u0434\u0438\u043D \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0442\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D, \u0447\u0442\u043E \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u044E\u043D\u043E\u043C\u0443 \u0433\u0435\u043D\u0438\u044E: *\xAB\u042F \u043F\u0440\u0435\u0438\u0441\u043F\u043E\u043B\u043D\u0435\u043D
    \u0443\u0434\u0438\u0432\u043B\u0435\u043D\u0438\u044F \u0438 \u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u044F
    \u043F\u0435\u0440\u0435\u0434 \u0412\u0430\u0448\u0438\u043C\u0438 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430\u043C\u0438
    \u0438 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430\u043C\u0438...
    \u0412\u044B \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0435 \u043F\u0435\u0440\u0435\u0434\u043E
    \u043C\u043D\u043E\u0439 \u043A\u0430\u043A \u0431\u044B \u0441\u043E\u0432\u0441\u0435\u043C
    \u043D\u043E\u0432\u044B\u0439 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0438\u0440\xBB*. 17-\u043B\u0435\u0442\u043D\u0438\u0439 \u044E\u043D\u043E\u0448\u0430
    \u0438\u0437 \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439 \u0438\u043C\u043F\u0435\u0440\u0438\u0438
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0413\u0440\u0430\u043D-\u043F\u0440\u0438
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u0438 \u043D\u0430\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043E\u0442 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u0430 \u041C\u0430\u0440\u0438
    \u042D\u043D\u043C\u043E\u043D\u0430 \u0416\u043E\u0440\u0434\u0430\u043D\u0430:
    *\xAB\u0420\u0430\u0431\u043E\u0442\u0430\u0439\u0442\u0435, \u043F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430,
    \u0447\u0442\u043E\u0431\u044B \u0441\u0442\u0430\u0442\u044C \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C\xBB*.  ###
    \U0001F468\u200D\U0001F393 \xAB\u041B\u0435\u043D\u0438\u0432\u044B\u0439 \u043F\u0451\u0441\xBB
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D  \u042D\u0442\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u0443\u0440\u044C\u0435\u0437 \u0432 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438.
    \u0412 1896\u20131902 \u0433\u043E\u0434\u0430\u0445 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B \u0432 \u0426\u044E\u0440\u0438\u0445\u0441\u043A\u043E\u043C
    \u043F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u043A\u0443\u043C\u0435,
    \u0438 \u0441\u0440\u0435\u0434\u0438 \u0435\u0433\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432
    \u0431\u044B\u043B **\u0410\u043B\u044C\u0431\u0435\u0440\u0442 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D**.
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u043D\u0435\u043B\u0435\u0441\u0442\u043D\u043E
    \u043E\u0442\u0437\u044B\u0432\u0430\u043B\u0441\u044F \u043E \u043D\u0435\u043C:
    *\xAB\u042D\u0442\u043E\u0442 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D,
    \u043E\u043D \u0432\u0435\u0447\u043D\u043E \u043F\u0440\u043E\u0433\u0443\u043B\u0438\u0432\u0430\u043B
    \u043C\u043E\u0438 \u043B\u0435\u043A\u0446\u0438\u0438... \u042F \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u0431\u044B \u043D\u0435 \u043F\u043E\u0432\u0435\u0440\u0438\u043B, \u0447\u0442\u043E
    \u043E\u043D \u043D\u0430 \u0442\u0430\u043A\u043E\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D\xBB*.
    \u041E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0431\u044B\u0432\u0448\u0435\u0433\u043E
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430 **\xAB\u043B\u0435\u043D\u0438\u0432\u044B\u043C
    \u043F\u0441\u043E\u043C\xBB (lazy dog)** \u0438 \u0433\u043E\u0432\u043E\u0440\u0438\u043B,
    \u0447\u0442\u043E \u0442\u043E\u0442 *\xAB\u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0443\u0442\u0440\u0443\u0436\u0434\u0430\u043B \u0441\u0435\u0431\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439\xBB*. \u041F\u043E
    \u0438\u0440\u043E\u043D\u0438\u0438 \u0441\u0443\u0434\u044C\u0431\u044B, \u0438\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u043E\u0433\u043E \xAB\u043D\u0435\u0440\u0430\u0434\u0438\u0432\u043E\u0433\u043E\xBB
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430 \u0441\u043F\u0443\u0441\u0442\u044F
    \u0432\u0441\u0435\u0433\u043E \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043B\u0435\u0442 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u0431\u0443\u0434\u0435\u0442 \u043F\u0440\u043E\u0441\u043B\u0430\u0432\u043B\u044F\u0442\u044C,
    \u0441\u043E\u0437\u0434\u0430\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0434\u043B\u044F \u0435\u0433\u043E
    \u0442\u0435\u043E\u0440\u0438\u0438. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0434\u0430\u0436\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    (\u0438, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0430\u043F\u043E\u043A\u0440\u0438\u0444\u0438\u0447\u0435\u0441\u043A\u0430\u044F)
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E \u0442\u043E\u043C, \u043A\u0430\u043A
    \u043D\u0430 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0435 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u0434\u0430\u043B \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0443 \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0435\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435, \u0447\u0442\u043E\u0431\u044B
    \u0435\u0433\u043E \xAB\u043F\u0440\u043E\u0443\u0447\u0438\u0442\u044C\xBB,
    \u043D\u043E \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435
    \u0435\u0433\u043E \u0440\u0435\u0448\u0438\u043B.  ### \u26C8 \u0428\u0443\u0442\u043A\u0430
    \u043D\u0430\u0434 \u0433\u0440\u043E\u0437\u043E\u0439 \u0438 \xAB\u043F\u0440\u043E\u0431\u043B\u0435\u043C\u043E\u0439
    \u0447\u0435\u0442\u044B\u0440\u0435\u0445 \u043A\u0440\u0430\u0441\u043E\u043A\xBB 
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u0431\u044B\u043B
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0438\u043C
    \u043E\u0441\u0442\u0440\u044B\u043C \u0443\u043C\u043E\u043C \u0438 \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C
    \u044E\u043C\u043E\u0440\u0430. \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u043E\u043D
    \u0437\u0430\u044F\u0432\u0438\u043B \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430\u043C,
    \u0447\u0442\u043E \u043D\u0430\u0434\u0435\u0435\u0442\u0441\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **\u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443
    \u0447\u0435\u0442\u044B\u0440\u0435\u0445 \u043A\u0440\u0430\u0441\u043E\u043A**
    (\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E \u043B\u0438 4-\u0445
    \u0446\u0432\u0435\u0442\u043E\u0432, \u0447\u0442\u043E\u0431\u044B \u0440\u0430\u0441\u043A\u0440\u0430\u0441\u0438\u0442\u044C
    \u043B\u044E\u0431\u0443\u044E \u043A\u0430\u0440\u0442\u0443). \u0427\u0435\u0440\u0435\u0437
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043D\u0435\u0434\u0435\u043B\u044C
    \u0431\u0435\u0437\u0443\u0441\u043F\u0435\u0448\u043D\u044B\u0445 \u043F\u043E\u043F\u044B\u0442\u043E\u043A,
    \u0432\u043E\u0439\u0434\u044F \u0432 \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u044E
    \u043F\u043E\u0434 \u0440\u0430\u0441\u043A\u0430\u0442\u044B \u0441\u0438\u043B\u044C\u043D\u043E\u0439
    \u0433\u0440\u043E\u0437\u044B, \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441:
    *\xAB\u041D\u0435\u0431\u043E \u0433\u043D\u0435\u0432\u0430\u0435\u0442\u0441\u044F
    \u043D\u0430 \u043C\u043E\u044E \u0434\u0435\u0440\u0437\u043E\u0441\u0442\u044C:
    \u043C\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0447\u0435\u0442\u044B\u0440\u0435\u0445
    \u0446\u0432\u0435\u0442\u043E\u0432 \u0442\u043E\u0436\u0435 \u043D\u0435\u0432\u0435\u0440\u043D\u043E\xBB*.
    \u041B\u0438\u0448\u044C \u043F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0433\u043E
    \u043E\u043D \u0443\u043B\u044B\u0431\u043D\u0443\u043B\u0441\u044F \u0438 \u043D\u0430\u0447\u0430\u043B
    \u043B\u0435\u043A\u0446\u0438\u044E.  ### \U0001F52C \u0412\u043A\u043B\u0430\u0434
    \u0431\u0440\u0430\u0442\u0430-\u043C\u0435\u0434\u0438\u043A\u0430  \u0412 \u0442\u0435\u043D\u0438
    \u0413\u0435\u0440\u043C\u0430\u043D\u0430 \u0447\u0430\u0441\u0442\u043E \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F
    \u0435\u0433\u043E \u0441\u0442\u0430\u0440\u0448\u0438\u0439 \u0431\u0440\u0430\u0442
    **\u041E\u0441\u043A\u0430\u0440 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439**,
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0432\u0440\u0430\u0447.
    \u0418\u043C\u0435\u043D\u043D\u043E \u041E\u0441\u043A\u0430\u0440 \u0432 1889
    \u0433\u043E\u0434\u0443 \u043F\u0440\u043E\u0432\u0435\u043B \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442
    \u043F\u043E \u0443\u0434\u0430\u043B\u0435\u043D\u0438\u044E \u043F\u043E\u0434\u0436\u0435\u043B\u0443\u0434\u043E\u0447\u043D\u043E\u0439
    \u0436\u0435\u043B\u0435\u0437\u044B \u0443 \u0441\u043E\u0431\u0430\u043A\u0438,
    \u0432 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435 \u0447\u0435\u0433\u043E
    \u0443 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0433\u043E \u0440\u0430\u0437\u0432\u0438\u043B\u0441\u044F
    \u0441\u0430\u0445\u0430\u0440\u043D\u044B\u0439 \u0434\u0438\u0430\u0431\u0435\u0442.
    \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043B\u043E
    \u0441\u0432\u044F\u0437\u044C \u043C\u0435\u0436\u0434\u0443 \u043F\u043E\u0434\u0436\u0435\u043B\u0443\u0434\u043E\u0447\u043D\u043E\u0439
    \u0436\u0435\u043B\u0435\u0437\u043E\u0439 \u0438 \u0434\u0438\u0430\u0431\u0435\u0442\u043E\u043C
    \u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u0443
    \u0434\u043B\u044F \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0438\u043D\u0441\u0443\u043B\u0438\u043D\u0430. \u0421\u044B\u043D \u041E\u0441\u043A\u0430\u0440\u0430
    \u0438 \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u043A \u0413\u0435\u0440\u043C\u0430\u043D\u0430,
    **\u0420\u0443\u0434\u043E\u043B\u044C\u0444 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439**,
    \u0441\u0442\u0430\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u0430\u0441\u0442\u0440\u043E\u0444\u0438\u0437\u0438\u043A\u043E\u043C.  ###
    \U0001FAA6 \u041F\u0440\u0438\u0436\u0438\u0437\u043D\u0435\u043D\u043D\u0430\u044F
    \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u0430\u044F \u0432\u0441\u0442\u0440\u0435\u0447\u0430? 
    \u0415\u0441\u0442\u044C \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0439 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043A\u0430\u0437\u0443\u0441, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0439
    \u0441 \u043A\u0438\u043D\u043E\u0432\u0435\u0440\u0441\u0438\u0435\u0439 \u0436\u0438\u0437\u043D\u0438
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430. \u0412 \u043E\u0434\u043D\u043E\u043C
    \u0438\u0437 \u0444\u0438\u043B\u044C\u043C\u043E\u0432 \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u0438
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u0432\u0441\u0442\u0440\u0435\u0447\u0443
    \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u0430 \u0441 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u043C
    \u043D\u0430 \u0417\u0430\u043B\u044C\u0446\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u043C
    \u0441\u044A\u0435\u0437\u0434\u0435 \u0432 **\u0441\u0435\u043D\u0442\u044F\u0431\u0440\u0435
    1909 \u0433\u043E\u0434\u0430**, \u0433\u0434\u0435 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442 \u0441\u0432\u043E\u0435\u0433\u043E
    \xAB\u043B\u0435\u043D\u0438\u0432\u043E\u0433\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430\xBB.
    \u041F\u0440\u043E\u0431\u043B\u0435\u043C\u0430 \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E
    \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u0439 \u0413\u0435\u0440\u043C\u0430\u043D
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439 \u0441\u043A\u043E\u0440\u043E\u043F\u043E\u0441\u0442\u0438\u0436\u043D\u043E
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u043E\u0442 \u0430\u043F\u043F\u0435\u043D\u0434\u0438\u0446\u0438\u0442\u0430
    \u0432 **\u044F\u043D\u0432\u0430\u0440\u0435 1909 \u0433\u043E\u0434\u0430**.
    \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0432
    \u0444\u0438\u043B\u044C\u043C\u0435 \u0441 \xAB\u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u043C\xBB \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u043B
    \u0435\u0433\u043E \u043F\u0440\u0438\u0437\u0440\u0430\u043A \u2014 \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u0438
    \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C \u0432 \u0436\u0435\u0440\u0442\u0432\u0443
    \u0445\u0443\u0434\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C\u0443
    \u0437\u0430\u043C\u044B\u0441\u043B\u0443.  ### \u26A1\uFE0F \u0415\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u0430\u044F \u0444\u0440\u0430\u0437\u0430, \u0441\u0442\u0430\u0432\u0448\u0430\u044F
    \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u043E\u043C  21
    \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F 1908 \u0433\u043E\u0434\u0430
    \u0432 \u041A\u0451\u043B\u044C\u043D\u0435 \u041C\u0438\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0439
    \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441 \u0441\u0432\u043E\u044E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
