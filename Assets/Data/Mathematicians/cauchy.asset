  achievementsRu: "\u0420\u0430\u0431\u043E\u0442\u044B \u041A\u043E\u0448\u0438
    \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E \u043F\u0435\u0440\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437, \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0432
    \u0435\u0433\u043E \u0438\u0437 \u043D\u0430\u0431\u043E\u0440\u0430 \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u043E
    \u043F\u043E\u043D\u044F\u0442\u043D\u044B\u0445 \u043F\u0440\u0430\u0432\u0438\u043B
    \u0432 \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u043D\u0430\u0443\u043A\u0443.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u0435\u043D,
    \u0447\u0442\u043E \u043C\u043D\u043E\u0433\u0438\u0435 \u0438\u0437 \u0435\u0433\u043E
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432 \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0442
    \u043E\u0441\u043D\u043E\u0432\u0443 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F \u0438 \u043D\u0430\u0443\u043A\u0438.
    \u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439 \u043E\u0431\u0437\u043E\u0440
    \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439. 
    ### \U0001F9EE \u041F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 (1820-\u0435 \u0433\u043E\u0434\u044B) 
    \u0412 \u043D\u0430\u0447\u0430\u043B\u0435 XIX \u0432\u0435\u043A\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437, \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u044B\u0439
    \u041D\u044C\u044E\u0442\u043E\u043D\u043E\u043C \u0438 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0435\u043C,
    \u0431\u044B\u043B \u043C\u043E\u0433\u0443\u0447\u0438\u043C, \u043D\u043E \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u0448\u0430\u0442\u043A\u0438\u043C \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C.
    \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u044F
    \u2014 \u043F\u0440\u0435\u0434\u0435\u043B, \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u044C,
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u0430\u044F \u2014 \u043D\u0435
    \u0438\u043C\u0435\u043B\u0438 \u0441\u0442\u0440\u043E\u0433\u0438\u0445 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0439.
    \u041A\u043E\u0448\u0438 \u0432\u0437\u044F\u043B \u043D\u0430 \u0441\u0435\u0431\u044F
    \u0441\u043C\u0435\u043B\u043E\u0441\u0442\u044C \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C
    \u044D\u0442\u043E. \u0412 \u0441\u0432\u043E\u0435\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \u0442\u0440\u0438\u043B\u043E\u0433\u0438\u0438 \u2014 **\xAB\u041A\u0443\u0440\u0441
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430\xBB** (1821), **\xAB\u0420\u0435\u0437\u044E\u043C\u0435
    \u043B\u0435\u043A\u0446\u0438\u0439 \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E\xBB** (1823) \u0438
    **\xAB\u041B\u0435\u043A\u0446\u0438\u0438 \u043E \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F\u0445
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u043A \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB**
    (1826\u20131828) \u2014 \u043E\u043D \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0435\u0440\u0435\u0441\u0442\u0440\u043E\u0438\u043B \u0432\u0435\u0441\u044C
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u044F
    **\u043F\u0440\u0435\u0434\u0435\u043B\u0430**.  *   **\u0421\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C
    \u0447\u0435\u0440\u0435\u0437 \u043F\u0440\u0435\u0434\u0435\u043B:** \u041A\u043E\u0448\u0438
    \u0432\u0432\u0435\u043B \u043F\u043E\u0447\u0442\u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u043F\u0440\u0435\u0434\u0435\u043B\u0430,
    \u0430 \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u0433\u043E \u2014 \u0441\u0442\u0440\u043E\u0433\u0438\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F **\u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438**, **\u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u043E\u0439**
    \u0438 **\u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430** (\u043A\u0430\u043A
    \u043F\u0440\u0435\u0434\u0435\u043B\u0430 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0441\u0443\u043C\u043C). *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0440\u044F\u0434\u043E\u0432:**
    \u041E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043F\u0440\u043E\u0447\u043D\u044B\u0435
    \u043E\u0441\u043D\u043E\u0432\u044B \u0442\u0435\u043E\u0440\u0438\u0438 \u0441\u0445\u043E\u0434\u044F\u0449\u0438\u0445\u0441\u044F
    \u0440\u044F\u0434\u043E\u0432, \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u0432
    \u0447\u0435\u0442\u043A\u0438\u0435 \u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0438
    \u0438\u0445 \u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438. \u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    **\u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u044B\u0439 \u043F\u0440\u0438\u0437\u043D\u0430\u043A
    \u041A\u043E\u0448\u0438** \u0438 \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    **\u0440\u0430\u0434\u0438\u0443\u0441\u0430 \u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438**
    \u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E\u0433\u043E \u0440\u044F\u0434\u0430
    \u2014 \u0435\u0433\u043E \u0437\u0430\u0441\u043B\u0443\u0433\u0430. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u0447\u043D\u043E\u043C
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0438:** \u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0411\u043E\u043B\u044C\u0446\u0430\u043D\u043E\u2013\u041A\u043E\u0448\u0438
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u0430\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F, \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u044E\u0449\u0430\u044F
    \u0434\u0432\u0430 \u0440\u0430\u0437\u043D\u044B\u0445 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F,
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0442 \u0438 \u043B\u044E\u0431\u043E\u0435
    \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u0447\u043D\u043E\u0435,
    \u0441\u0442\u0430\u043B\u0430 \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u043A\u0430\u043C\u043D\u0435\u0439 \u0430\u043D\u0430\u043B\u0438\u0437\u0430. 
    ### \U0001F310 \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E  \u0415\u0441\u043B\u0438
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u041A\u043E\u0448\u0438 \u0431\u044B\u043B
    \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u0442\u043E\u0440\u043E\u043C, \u0442\u043E
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u043E\u043D \u0441\u0442\u0430\u043B
    \u043F\u043E\u0434\u043B\u0438\u043D\u043D\u044B\u043C \u0442\u0432\u043E\u0440\u0446\u043E\u043C.
    \u0415\u0433\u043E \u043C\u0435\u043C\u0443\u0430\u0440 \u043E\u0431 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0445
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430\u0445 (1814) \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u0443 \u0434\u043B\u044F \u0446\u0435\u043B\u043E\u0439
    \u043D\u043E\u0432\u043E\u0439 \u0432\u0435\u0442\u0432\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    *   **\u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B \u041A\u043E\u0448\u0438:**
    \u041E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438 \u0432 \u0432\u0438\u0434\u0435 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430
    \u043F\u043E \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u043C\u0443 \u043A\u043E\u043D\u0442\u0443\u0440\u0443
    (**\u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B \u041A\u043E\u0448\u0438**),
    \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0442\u044C
    \u0444\u0443\u043D\u043A\u0446\u0438\u044E \u043F\u043E \u0435\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F\u043C
    \u043D\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0432\u044B\u0447\u0435\u0442\u043E\u0432:**
    \u041A\u043E\u0448\u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043C\u043E\u0449\u043D\u044B\u0439 \u0430\u043F\u043F\u0430\u0440\u0430\u0442
    **\u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u044B\u0447\u0435\u0442\u043E\u0432**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u043C \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u0432
    \u0432 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E\u0439 \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438.
    *   **\u0423\u0441\u043B\u043E\u0432\u0438\u044F \u041A\u043E\u0448\u0438-\u0420\u0438\u043C\u0430\u043D\u0430:**
    \u041E\u043D \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043B
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0434\u043E\u043B\u0436\u043D\u044B \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u044F\u0442\u044C
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0438 \u043C\u043D\u0438\u043C\u0430\u044F \u0447\u0430\u0441\u0442\u0438 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E-\u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0440\u0443\u0435\u043C\u043E\u0439
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438. \u0425\u043E\u0442\u044F \u044D\u0442\u0438
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F \u0431\u044B\u043B\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B
    \u0438 \u0440\u0430\u043D\u0435\u0435, \u0438\u043C\u0435\u043D\u043D\u043E \u041A\u043E\u0448\u0438
    \u043F\u0440\u0438\u0434\u0430\u043B \u0438\u043C \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435, \u0438 \u0441\u0435\u0439\u0447\u0430\u0441
    \u043E\u043D\u0438 \u043D\u043E\u0441\u044F\u0442 \u0435\u0433\u043E \u0438\u043C\u044F. 
    ### \u2699\uFE0F \u0412\u043A\u043B\u0430\u0434 \u0432 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u0438\u0437\u0438\u043A\u0443  \u041A\u043E\u0448\u0438 \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u043B\u0441\u044F
    \"\u0447\u0438\u0441\u0442\u043E\u0439\" \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439;
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u0438\u043C\u0435\u043B\u0438
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0434\u043B\u044F \u0444\u0438\u0437\u0438\u043A\u0438 \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438. 
    *   **\u0417\u0430\u0434\u0430\u0447\u0430 \u041A\u043E\u0448\u0438:** \u0412
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 (\u043E\u0431\u044B\u043A\u043D\u043E\u0432\u0435\u043D\u043D\u044B\u0445
    \u0438 \u0441 \u0447\u0430\u0441\u0442\u043D\u044B\u043C\u0438 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u043C\u0438)
    \u0435\u0433\u043E \u0438\u043C\u044F \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0441\u0432\u044F\u0437\u0430\u043D\u043E \u0441 **\u0437\u0430\u0434\u0430\u0447\u0435\u0439
    \u041A\u043E\u0448\u0438** \u2014 \u043F\u043E\u0438\u0441\u043A\u043E\u043C
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F, \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u044F\u044E\u0449\u0435\u0433\u043E
    \u0437\u0430\u0434\u0430\u043D\u043D\u044B\u043C \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u043C. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u0434\u043B\u044F \u044D\u0442\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0438. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0443\u043F\u0440\u0443\u0433\u043E\u0441\u0442\u0438:** \u0412 1822 \u0433\u043E\u0434\u0443
    \u041A\u043E\u0448\u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    **\u0442\u0435\u043E\u0440\u0438\u0438 \u0443\u043F\u0440\u0443\u0433\u043E\u0441\u0442\u0438**.
    \u041E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0440\u043E\u0440\u044B\u0432,
    \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u044F \u0442\u0435\u043B\u043E
    \u043A\u0430\u043A \u0441\u043F\u043B\u043E\u0448\u043D\u0443\u044E \u0441\u0440\u0435\u0434\u0443
    \u0438 \u0432\u0432\u043E\u0434\u044F \u043F\u043E\u043D\u044F\u0442\u0438\u044F
    **\u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u0438\u044F** \u0438 **\u0434\u0435\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0438**
    \u0432 \u043A\u0430\u0436\u0434\u043E\u0439 \u0435\u0433\u043E \u0442\u043E\u0447\u043A\u0435,
    \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C
    \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. *   **\u0413\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0430
    \u0438 \u043E\u043F\u0442\u0438\u043A\u0430:** \u0412 1816 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0413\u0440\u0430\u043D-\u043F\u0440\u0438
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u0437\u0430 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043F\u043E \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044E
    \u0432\u043E\u043B\u043D. \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0432\u043D\u0435\u0441
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u043E\u043F\u0442\u0438\u043A\u0438, \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u044F
    \u0441\u0432\u0435\u0442 \u043A\u0430\u043A \u0432\u043E\u043B\u043D\u044B \u0432
    \u0443\u043F\u0440\u0443\u0433\u043E\u0439 \u0441\u0440\u0435\u0434\u0435 (\u044D\u0444\u0438\u0440\u0435). 
    ### \U0001F4D0 \u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F, \u0430\u043B\u0433\u0435\u0431\u0440\u0430
    \u0438 \u0442\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B  \u0415\u0433\u043E
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u043B\u0438
    \u043F\u043E\u0447\u0442\u0438 \u0432\u0441\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.  *   **\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:**
    \u0412 1813 \u0433\u043E\u0434\u0443, \u0435\u0449\u0435 \u0431\u0443\u0434\u0443\u0447\u0438
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C, \u043E\u043D \u0440\u0435\u0448\u0438\u043B
    \u0437\u0430\u0434\u0430\u0447\u0443 \u043E \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u0438\u043A\u0430\u0445,
    \u0434\u043E\u043A\u0430\u0437\u0430\u0432, \u0447\u0442\u043E \u0443\u0433\u043B\u044B
    \u0432\u044B\u043F\u0443\u043A\u043B\u043E\u0433\u043E \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u0438\u043A\u0430
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u044E\u0442\u0441\u044F \u0435\u0433\u043E
    \u0433\u0440\u0430\u043D\u044F\u043C\u0438, \u0438 \u043E\u0431\u043E\u0431\u0449\u0438\u0432
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0443\u044E \u0444\u043E\u0440\u043C\u0443\u043B\u0443
    \u042D\u0439\u043B\u0435\u0440\u0430 \u0434\u043B\u044F \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u0438\u043A\u043E\u0432.
    *   **\u0410\u043B\u0433\u0435\u0431\u0440\u0430 \u0438 \u0442\u0435\u043E\u0440\u0438\u044F
    \u0433\u0440\u0443\u043F\u043F:** \u041E\u043D \u0432\u043D\u0435\u0441 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0442\u0435\u043E\u0440\u0438\u044E **\u043F\u043E\u0434\u0441\u0442\u0430\u043D\u043E\u0432\u043E\u043A**
    (\u0442\u0435\u043E\u0440\u0438\u044E \u0433\u0440\u0443\u043F\u043F), \u0434\u043E\u043A\u0430\u0437\u0430\u0432
    \u0432\u0430\u0436\u043D\u0443\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443:
    \u0435\u0441\u043B\u0438 \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D
    \u043E\u0442 *n* \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0442 \u0431\u043E\u043B\u0435\u0435
    \u0434\u0432\u0443\u0445 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439 \u043F\u0440\u0438
    \u0432\u0441\u0435\u0445 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0430\u0445
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445, \u0442\u043E \u0447\u0438\u0441\u043B\u043E
    \u044D\u0442\u0438\u0445 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439 \u043D\u0435
    \u043C\u0435\u043D\u044C\u0448\u0435, \u0447\u0435\u043C \u043D\u0430\u0438\u0431\u043E\u043B\u044C\u0448\u0438\u0439
    \u043F\u0440\u043E\u0441\u0442\u043E\u0439 \u0434\u0435\u043B\u0438\u0442\u0435\u043B\u044C
    \u0447\u0438\u0441\u043B\u0430 *n*. \u0422\u0430\u043A\u0436\u0435 \u043E\u043D
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0434\u043B\u044F
    \u043B\u044E\u0431\u043E\u0433\u043E \u043F\u0440\u043E\u0441\u0442\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 *p*, \u0434\u0435\u043B\u044F\u0449\u0435\u0433\u043E
    \u043F\u043E\u0440\u044F\u0434\u043E\u043A \u0433\u0440\u0443\u043F\u043F\u044B,
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u044D\u043B\u0435\u043C\u0435\u043D\u0442
    \u043F\u043E\u0440\u044F\u0434\u043A\u0430 *p* (\u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u041A\u043E\u0448\u0438 \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0443\u043F\u043F).
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B:**
    \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u0440\u0430\u0431\u043E\u0442,
    \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 \u0440\u0435\u0448\u0438\u043B
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443 \u0424\u0435\u0440\u043C\u0430
    \u043E \u043C\u043D\u043E\u0433\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u043B\u0430\u0445.  ### \U0001F4D6 \u0411\u0435\u0441\u043F\u0440\u0435\u0446\u0435\u0434\u0435\u043D\u0442\u043D\u0430\u044F
    \u043F\u043B\u043E\u0434\u043E\u0432\u0438\u0442\u043E\u0441\u0442\u044C  \u041A\u043E\u0448\u0438
    \u0431\u044B\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u043C \u0443\u0447\u0435\u043D\u044B\u043C.
    \u041E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043F\u043E\u0441\u043B\u0435
    \u0441\u0435\u0431\u044F \u0431\u043E\u043B\u0435\u0435 **780 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442**. \u041F\u043E \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0443
    \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0439 \u0435\u0433\u043E
    \u043F\u0440\u0435\u0432\u043E\u0441\u0445\u043E\u0434\u044F\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
    \u041B\u0435\u043E\u043D\u0430\u0440\u0434 \u042D\u0439\u043B\u0435\u0440 \u0438
    \u0410\u0440\u0442\u0443\u0440 \u041A\u044D\u043B\u0438. \u0415\u0433\u043E \u043F\u043E\u043B\u043D\u043E\u0435
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435 \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439
    \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 **27 \u0442\u043E\u043C\u043E\u0432**
    , \u0438 \u0435\u0433\u043E \u0438\u043C\u044F, \u043F\u043E \u043F\u0440\u0430\u0432\u0443,
    \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u043E \u043D\u0430 \u042D\u0439\u0444\u0435\u043B\u0435\u0432\u043E\u0439
    \u0431\u0430\u0448\u043D\u0435 \u0432 \u0441\u043F\u0438\u0441\u043A\u0435 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0443\u0447\u0435\u043D\u044B\u0445 \u0424\u0440\u0430\u043D\u0446\u0438\u0438."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u041E\u0433\u044E\u0441\u0442\u0435\u043D\u0430 \u041B\u0443\u0438 \u041A\u043E\u0448\u0438
    \u0431\u044B\u043B\u0430 \u043D\u0435\u0440\u0430\u0437\u0440\u044B\u0432\u043D\u043E
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441 \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u043E\u0439, \u043D\u043E \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u043B\u0430\u0441\u044C
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C\u0438 \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u043C\u0438
    \u0438 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u043C\u0438
    \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u044F\u043C\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0438
    \u043D\u0430 \u0432\u0441\u0435 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466
    \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B, \u0441\u0435\u043C\u044C\u044F
    \u0438 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0435  \u041A\u043E\u0448\u0438
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 21 \u0430\u0432\u0433\u0443\u0441\u0442\u0430
    1789 \u0433\u043E\u0434\u0430 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435, \u0432
    \u0441\u0435\u043C\u044C\u0435 \u0432\u044B\u0441\u043E\u043A\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u0430-\u043C\u043E\u043D\u0430\u0440\u0445\u0438\u0441\u0442\u0430
    \u041B\u0443\u0438-\u0424\u0440\u0430\u043D\u0441\u0443\u0430 \u041A\u043E\u0448\u0438
    \u0438 \u041C\u0430\u0440\u0438-\u041C\u0430\u0434\u043B\u0435\u043D \u0414\u0435\u044D\u0441\u0442\u0440.
    \u041E\u043D \u0431\u044B\u043B \u0441\u0442\u0430\u0440\u0448\u0438\u043C \u0438\u0437
    \u0447\u0435\u0442\u044B\u0440\u0435\u0445 \u0441\u044B\u043D\u043E\u0432\u0435\u0439
    \u0438 \u0434\u0432\u0443\u0445 \u0434\u043E\u0447\u0435\u0440\u0435\u0439 \u0432
    \u0441\u0435\u043C\u044C\u0435. \u0414\u0432\u043E\u0435 \u0435\u0433\u043E \u0431\u0440\u0430\u0442\u044C\u0435\u0432
    \u0442\u0430\u043A\u0436\u0435 \u0441\u0442\u0430\u043B\u0438 \u0437\u0430\u043C\u0435\u0442\u043D\u044B\u043C\u0438
    \u0444\u0438\u0433\u0443\u0440\u0430\u043C\u0438: \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440
    \u0441\u0434\u0435\u043B\u0430\u043B \u0443\u0441\u043F\u0435\u0448\u043D\u0443\u044E
    \u043A\u0430\u0440\u044C\u0435\u0440\u0443 \u0432 \u0441\u0443\u0434\u0435\u0431\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435, \u0430 \u042D\u0436\u0435\u043D \u0441\u0442\u0430\u043B
    \u043F\u0443\u0431\u043B\u0438\u0446\u0438\u0441\u0442\u043E\u043C \u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u043C
    \u043F\u0440\u0430\u0432\u0430.  \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u041A\u043E\u0448\u0438
    \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C \u043D\u0430 \u0442\u044F\u0436\u0435\u043B\u044B\u0435
    \u0432\u0440\u0435\u043C\u0435\u043D\u0430 \u0412\u0435\u043B\u0438\u043A\u043E\u0439
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438.
    \u0421\u0435\u043C\u044C\u044F, \u0441\u043F\u0430\u0441\u0430\u044F\u0441\u044C
    \u043E\u0442 \u0442\u0435\u0440\u0440\u043E\u0440\u0430, \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u043F\u0440\u0438\u0433\u043E\u0440\u043E\u0434 \u0410\u0440\u043A\u0451\u0439,
    \u0433\u0434\u0435 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u0432\u043E\u0435
    \u043F\u0435\u0440\u0432\u043E\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u043E\u0442 \u043E\u0442\u0446\u0430. \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C,
    \u043F\u043E \u0441\u043E\u0441\u0435\u0434\u0441\u0442\u0432\u0443 \u0441 \u043D\u0438\u043C\u0438,
    \u0436\u0438\u043B\u0438 \u0442\u0430\u043A\u0438\u0435 \u0432\u0435\u043B\u0438\u043A\u0438\u0435
    \u0443\u0447\u0435\u043D\u044B\u0435, \u043A\u0430\u043A \u041B\u0430\u043F\u043B\u0430\u0441
    \u0438 \u0411\u0435\u0440\u0442\u043E\u043B\u043B\u0435. \u0421 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0435\u043C \u0441\u0435\u043C\u044C\u044F
    \u041A\u043E\u0448\u0438 \u0431\u044B\u043B\u0430 \u0431\u043B\u0438\u0437\u043A\u043E
    \u0437\u043D\u0430\u043A\u043E\u043C\u0430. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435 \u043F\u0440\u0435\u0434\u0430\u043D\u0438\u0435,
    \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u041B\u0430\u0433\u0440\u0430\u043D\u0436,
    \u0440\u0430\u0437\u0433\u043B\u044F\u0434\u0435\u0432 \u0432 \u044E\u043D\u043E\u043C
    \u041E\u0433\u044E\u0441\u0442\u0435\u043D\u0435 \u043D\u0435\u0434\u044E\u0436\u0438\u043D\u043D\u044B\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438, \u043F\u043E\u0441\u043E\u0432\u0435\u0442\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u043E\u0442\u0446\u0443 \u043D\u0435 \u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0442\u044C
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430 \u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043A\u043D\u0438\u0433\u0430\u043C\u0438 \u0434\u043E 17 \u043B\u0435\u0442,
    \u0447\u0442\u043E\u0431\u044B \u0442\u043E\u0442 \u043C\u043E\u0433 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0445\u043E\u0440\u043E\u0448\u0435\u0435 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435. \u042D\u0442\u043E
    \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u0435 \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
    \u043F\u0440\u0435\u0434\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u043E
    \u0435\u0433\u043E \u0431\u0443\u0434\u0443\u0449\u0435\u0435.  ### \U0001F48D
    \u0411\u0440\u0430\u043A \u0438 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0434\u043E\u0447\u0435\u0440\u0435\u0439  \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    28 \u043B\u0435\u0442 \u041A\u043E\u0448\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u043E \u044D\u0442\u043E\u0433\u043E \u0436\u0438\u043B \u0441 \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u044F\u043C\u0438,
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F. \u0415\u0433\u043E \u0438\u0437\u0431\u0440\u0430\u043D\u043D\u0438\u0446\u0435\u0439
    \u0441\u0442\u0430\u043B\u0430 **\u0410\u043B\u043E\u0438\u0437\u0430 \u0434\u0435
    \u0411\u044E\u0440**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u044B\u043B\u0430
    \u043C\u043B\u0430\u0434\u0448\u0435 \u043D\u0435\u0433\u043E \u043D\u0430 \u043F\u044F\u0442\u044C
    \u043B\u0435\u0442. \u0418\u0445 \u0431\u0440\u0430\u043A\u043E\u0441\u043E\u0447\u0435\u0442\u0430\u043D\u0438\u0435
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u043E\u0441\u044C 4 \u0430\u043F\u0440\u0435\u043B\u044F
    1818 \u0433\u043E\u0434\u0430 \u0432 \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439
    \u0446\u0435\u0440\u043A\u0432\u0438 \u0421\u0435\u043D-\u0421\u044E\u043B\u044C\u043F\u0438\u0441,
    \u0438 \u0446\u0435\u0440\u0435\u043C\u043E\u043D\u0438\u044F \u043F\u0440\u043E\u0448\u043B\u0430
    \u0441 \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u0442\u043E\u0440\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u043E\u0431\u0440\u044F\u0434\u0443.  \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u0441\u0435\u043C\u044C\u044F \u0410\u043B\u043E\u0438\u0437\u044B
    \u0438\u043C\u0435\u043B\u0430 \u043D\u0435\u043F\u043E\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435 \u043A \u0435\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u0435:
    \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u0446\u0435\u0439
    \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u0432\u044B\u043F\u0443\u0441\u0442\u0438\u043B
    \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E \u0435\u0433\u043E
    \u0442\u0440\u0443\u0434\u043E\u0432. \u0412 \u044D\u0442\u043E\u043C \u0431\u0440\u0430\u043A\u0435
    \u0443 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C \u0434\u0432\u0435
    \u0434\u043E\u0447\u0435\u0440\u0438:  *   **\u041C\u0430\u0440\u0438 \u0424\u0440\u0430\u043D\u0441\u0443\u0430\u0437\u0430
    \u0410\u043B\u0438\u0441\u0438\u044F** (\u0440\u043E\u0434. 1819) *   **\u041C\u0430\u0440\u0438
    \u041C\u0430\u0442\u0438\u043B\u044C\u0434\u0430** (\u0440\u043E\u0434. 1823) 
    \u0412\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u043E\u0431\u0435
    \u0434\u043E\u0447\u0435\u0440\u0438 \u0432\u044B\u0448\u043B\u0438 \u0437\u0430\u043C\u0443\u0436
    \u0437\u0430 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u0435\u043B\u0435\u0439
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439 \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u0438\u0438. 
    ### \U0001F64F \u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440, \u0432\u0435\u0440\u0430
    \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F  \u041B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u041A\u043E\u0448\u0438 \u0431\u044B\u043B\u0430 \u0441\u0442\u043E\u043B\u044C
    \u0436\u0435 \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439,
    \u0441\u043A\u043E\u043B\u044C \u0438 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0439.
    \u0415\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438 \u0435\u0433\u043E \u043A\u0430\u043A
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u0441 \u043E\u0447\u0435\u043D\u044C
    \u0441\u043B\u043E\u0436\u043D\u044B\u043C \u0438 \u043D\u0435\u0443\u0441\u0442\u0443\u043F\u0447\u0438\u0432\u044B\u043C
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C. \u041E\u043D \u0431\u044B\u043B
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0435\u0439
    \u043D\u0435\u043F\u043E\u043A\u043E\u043B\u0435\u0431\u0438\u043C\u043E\u0439,
    \u0434\u0430\u0436\u0435 \u0430\u0433\u0440\u0435\u0441\u0441\u0438\u0432\u043D\u043E\u0439
    \u043F\u0440\u0438\u0432\u0435\u0440\u0436\u0435\u043D\u043D\u043E\u0441\u0442\u044C\u044E
    \u0441\u0432\u043E\u0438\u043C \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u043C
    \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0432\u0437\u0433\u043B\u044F\u0434\u0430\u043C. \u041A\u043E\u0448\u0438 \u0431\u044B\u043B
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0432\u0435\u0440\u0443\u044E\u0449\u0438\u043C
    \u043A\u0430\u0442\u043E\u043B\u0438\u043A\u043E\u043C \u0438 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u043C\u043E\u043D\u0430\u0440\u0445\u0438\u0441\u0442\u043E\u043C-\u043B\u0435\u0433\u0438\u0442\u0438\u043C\u0438\u0441\u0442\u043E\u043C,
    \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u043B\u043E \u0435\u0433\u043E \u0431\u0435\u0441\u043A\u043E\u043C\u043F\u0440\u043E\u043C\u0438\u0441\u0441\u043D\u044B\u043C
    \u0432 \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u0445 \u0441\u043E\u0432\u0435\u0441\u0442\u0438. 
    \u0418\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u0438 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F
    \u0441\u0442\u0430\u043B\u0438 \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439
    \u0435\u0433\u043E \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0435\u0433\u043E
    \u0438\u0437\u0433\u043D\u0430\u043D\u0438\u044F. \u041F\u043E\u0441\u043B\u0435
    \u0418\u044E\u043B\u044C\u0441\u043A\u043E\u0439 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438
    1830 \u0433\u043E\u0434\u0430 \u041A\u043E\u0448\u0438, \u043A\u0430\u043A \u0432\u0435\u0440\u043D\u044B\u0439
    \u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043A \u0441\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u044F \u041A\u0430\u0440\u043B\u0430 X, \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043F\u0440\u0438\u0441\u044F\u0433\u0430\u0442\u044C \u043D\u0430 \u0432\u0435\u0440\u043D\u043E\u0441\u0442\u044C
    \u043D\u043E\u0432\u043E\u043C\u0443 \u043C\u043E\u043D\u0430\u0440\u0445\u0443,
    \u041B\u0443\u0438-\u0424\u0438\u043B\u0438\u043F\u043F\u0443, \u0438 \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u0432\u0441\u0435 \u0441\u0432\u043E\u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u0438\u0435
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438 \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438.
    \u041E\u043D \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0435\u043B \u0434\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u0443\u044E
    \u044D\u043C\u0438\u0433\u0440\u0430\u0446\u0438\u044E, \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0432\u0448\u0438\u0441\u044C
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u0441\u0435\u043C\u044C\u0435\u0439
    \u0411\u0443\u0440\u0431\u043E\u043D\u043E\u0432. \u0416\u0438\u043B \u0432 \u0422\u0443\u0440\u0438\u043D\u0435
    \u0438 \u041F\u0440\u0430\u0433\u0435, \u0433\u0434\u0435 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u0431\u044B\u043B \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u0442\u0435\u043B\u0435\u043C
    \u0432\u043D\u0443\u043A\u0430 \u041A\u0430\u0440\u043B\u0430 X, \u0433\u0435\u0440\u0446\u043E\u0433\u0430
    \u0411\u043E\u0440\u0434\u043E\u0441\u043A\u043E\u0433\u043E, \u0437\u0430 \u0447\u0442\u043E
    \u0438\u0437\u0433\u043D\u0430\u043D\u043D\u044B\u0439 \u043A\u043E\u0440\u043E\u043B\u044C
    \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u043B \u0435\u043C\u0443 \u0442\u0438\u0442\u0443\u043B
    \u0431\u0430\u0440\u043E\u043D\u0430.  \u0422\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u041A\u0430\u0440\u043B\u0430 X \u0432
    1836 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u043C\u043E\u0433 \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F
    \u0432 \u041F\u0430\u0440\u0438\u0436 \u0432 1838 \u0433\u043E\u0434\u0443, \u043D\u043E
    \u0434\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F
    \u043E\u0442 \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0435\u0439 \u0438\u0437-\u0437\u0430
    \u043D\u0435\u043F\u0440\u0438\u044F\u0437\u043D\u0438 \u043A \u043D\u043E\u0432\u043E\u043C\u0443
    \u0440\u0435\u0436\u0438\u043C\u0443, \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u044F
    \u043B\u0438\u0448\u044C \u0432 \u0438\u0435\u0437\u0443\u0438\u0442\u0441\u043A\u043E\u043C
    \u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0435. \u041F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u0443\u044E
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0432 \u0421\u043E\u0440\u0431\u043E\u043D\u043D\u0435
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043B\u0438\u0448\u044C
    \u043F\u043E\u0441\u043B\u0435 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438
    1848 \u0433\u043E\u0434\u0430, \u0438 \u0434\u0430\u0436\u0435 \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D
    III \u0432 1852 \u0433\u043E\u0434\u0443 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0435\u0433\u043E \u043D\u0430 \u044D\u0442\u043E\u043C \u043F\u043E\u0441\u0442\u0443,
    \u043D\u0435 \u0442\u0440\u0435\u0431\u0443\u044F \u043F\u0440\u0438\u0441\u044F\u0433\u0438. 
    \u041E\u0433\u044E\u0441\u0442\u0435\u043D \u041B\u0443\u0438 \u041A\u043E\u0448\u0438
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 23 \u043C\u0430\u044F
    1857 \u0433\u043E\u0434\u0430 \u0432 \u043C\u0435\u0441\u0442\u0435\u0447\u043A\u0435
    \u0421\u043E (\u043F\u043E\u0434 \u041F\u0430\u0440\u0438\u0436\u0435\u043C).
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u044F\u0440\u043A\u0438\u0439
    \u043F\u0440\u0438\u043C\u0435\u0440 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u0434\u043B\u044F \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0435\u0433\u043E
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F, \u0441\u0435\u043C\u044C\u044F
    \u0438 \u0441\u043B\u0443\u0436\u0435\u043D\u0438\u0435 \u043D\u0430\u0443\u043A\u0435
    \u0431\u044B\u043B\u0438 \u043D\u0435\u0440\u0430\u0437\u0440\u044B\u0432\u043D\u044B."
  personalLifeEn: 
  shortBioRu: "\u041E\u0433\u044E\u0441\u0442\u0435\u043D \u041B\u0443\u0438 \u041A\u043E\u0448\u0438
    (1789\u20131857) \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438,
    \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430. \u041E\u043D \u0431\u044B\u043B \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C, \u043D\u043E \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0441\u043B\u043E\u0436\u043D\u043E\u0439 \u0441\u0443\u0434\u044C\u0431\u044B,
    \u0447\u044C\u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F
    \u043D\u0435 \u0440\u0430\u0437 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0438\u0441\u044C
    \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439 \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u043E\u0432
    \u0441 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E\u043C.  \u041D\u0438\u0436\u0435
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430 \u0435\u0433\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u0438 \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435. 
    ### \U0001F4DC \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u044E\u043D\u043E\u0441\u0442\u044C
    (1789\u20131807)  *   **\u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435:**
    \u041E\u0433\u044E\u0441\u0442\u0435\u043D \u041B\u0443\u0438 \u041A\u043E\u0448\u0438
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0432 \u041F\u0430\u0440\u0438\u0436\u0435
    21 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1789 \u0433\u043E\u0434\u0430,
    \u0440\u043E\u0432\u043D\u043E \u0447\u0435\u0440\u0435\u0437 \u043C\u0435\u0441\u044F\u0446
    \u043F\u043E\u0441\u043B\u0435 \u0432\u0437\u044F\u0442\u0438\u044F \u0411\u0430\u0441\u0442\u0438\u043B\u0438\u0438,
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u0432\u044B\u0441\u043E\u043A\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u0430-\u043C\u043E\u043D\u0430\u0440\u0445\u0438\u0441\u0442\u0430
    \u0438 \u0440\u0435\u0432\u043D\u043E\u0441\u0442\u043D\u043E\u0433\u043E \u043A\u0430\u0442\u043E\u043B\u0438\u043A\u0430.
    \u0420\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0432\u0448\u0438\u0439
    \u0437\u0430 \u043D\u0435\u0439 \u0442\u0435\u0440\u0440\u043E\u0440 \u0432\u044B\u043D\u0443\u0434\u0438\u043B\u0438
    \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u044E \u0431\u0435\u0436\u0430\u0442\u044C
    \u0432 \u043F\u0440\u0438\u0433\u043E\u0440\u043E\u0434 \u0410\u0440\u043A\u0451\u0439,
    \u0433\u0434\u0435 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439 \u041A\u043E\u0448\u0438
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0435\u0440\u0432\u044B\u0435
    \u0443\u0440\u043E\u043A\u0438 \u043E\u0442 \u043E\u0442\u0446\u0430. *   **\u0417\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E
    \u0441 \u0432\u0435\u043B\u0438\u043A\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438:**
    \u0416\u0438\u0437\u043D\u044C \u0432 \u0410\u0440\u043A\u0451\u0435 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430
    \u041A\u043E\u0448\u0438 \u0431\u0435\u0441\u0446\u0435\u043D\u043D\u043E\u0435
    \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E. \u041F\u043E \u0441\u043E\u0441\u0435\u0434\u0441\u0442\u0432\u0443
    \u0441 \u0441\u0435\u043C\u044C\u0435\u0439 \u0436\u0438\u043B\u0438 \u0442\u0430\u043A\u0438\u0435
    \u0441\u0432\u0435\u0442\u0438\u043B\u0430 \u043D\u0430\u0443\u043A\u0438, \u043A\u0430\u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u041F\u044C\u0435\u0440-\u0421\u0438\u043C\u043E\u043D
    \u041B\u0430\u043F\u043B\u0430\u0441 \u0438 \u0445\u0438\u043C\u0438\u043A \u041A\u043B\u043E\u0434-\u041B\u0443\u0438
    \u0411\u0435\u0440\u0442\u043E\u043B\u043B\u0435. \u0411\u043E\u043B\u0435\u0435
    \u0442\u043E\u0433\u043E, \u0435\u0433\u043E \u043E\u0442\u0435\u0446 \u0431\u044B\u043B
    \u0437\u043D\u0430\u043A\u043E\u043C \u0441 \u0434\u0440\u0443\u0433\u0438\u043C
    \u0432\u0435\u043B\u0438\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0416\u043E\u0437\u0435\u0444\u043E\u043C-\u041B\u0443\u0438 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0435\u043C.
    \u041B\u0435\u0433\u0435\u043D\u0434\u0430 \u0433\u043B\u0430\u0441\u0438\u0442,
    \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u041B\u0430\u0433\u0440\u0430\u043D\u0436,
    \u0437\u0430\u043C\u0435\u0442\u0438\u0432 \u043D\u0435\u0434\u044E\u0436\u0438\u043D\u043D\u044B\u0435
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430,
    \u043F\u043E\u0441\u043E\u0432\u0435\u0442\u043E\u0432\u0430\u043B \u043E\u0442\u0446\u0443
    \u043D\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C \u0435\u043C\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043D\u0438\u0433\u0438 \u0434\u043E 17 \u043B\u0435\u0442, \u0447\u0442\u043E\u0431\u044B
    \u0442\u043E\u0442 \u043C\u043E\u0433 \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435. *   **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:**
    \u041F\u043E\u0441\u043B\u0435 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F
    \u0432 \u041F\u0430\u0440\u0438\u0436 \u041A\u043E\u0448\u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u0443\u044E \u0448\u043A\u043E\u043B\u0443
    \u041F\u0430\u043D\u0442\u0435\u043E\u043D\u0430, \u0433\u0434\u0435 \u0441 \u043E\u0442\u043B\u0438\u0447\u0438\u0435\u043C
    \u0438\u0437\u0443\u0447\u0430\u043B \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u044F\u0437\u044B\u043A\u0438. \u0412 1805 \u0433\u043E\u0434\u0443, \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 16 \u043B\u0435\u0442, \u043E\u043D
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E
    \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443, \u0430 \u0437\u0430\u0442\u0435\u043C \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0432 \u0428\u043A\u043E\u043B\u0435
    \u043C\u043E\u0441\u0442\u043E\u0432 \u0438 \u0434\u043E\u0440\u043E\u0433 (1807). 
    ### \U0001F477 \u0418\u043D\u0436\u0435\u043D\u0435\u0440 \u0438 \u043F\u0443\u0442\u044C
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 (1810\u20131821) 
    *   **\u041A\u0430\u0440\u044C\u0435\u0440\u0430 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430:**
    \u041F\u043E \u043E\u043A\u043E\u043D\u0447\u0430\u043D\u0438\u0438 \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u044F
    \u0432 1810 \u0433\u043E\u0434\u0443 \u041A\u043E\u0448\u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0432\u043E\u0435\u043D\u043D\u043E\u0433\u043E
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430 \u0432 \u043F\u043E\u0440\u0442\u043E\u0432\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u0435 \u0428\u0435\u0440\u0431\u0443\u0440. \u041E\u043D
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u0430\u0434 \u0443\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0438\u044F\u043C\u0438
    \u0438 \u043F\u043E\u0440\u0442\u043E\u0432\u044B\u043C\u0438 \u0441\u043E\u043E\u0440\u0443\u0436\u0435\u043D\u0438\u044F\u043C\u0438
    \u0434\u043B\u044F \u0432\u0442\u043E\u0440\u0436\u0435\u043D\u0438\u044F \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D\u0430
    \u0432 \u0410\u043D\u0433\u043B\u0438\u044E. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0438\u043D\u0442\u0435\u043D\u0441\u0438\u0432\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443, \u043E\u043D \u043D\u0435 \u043F\u0440\u0435\u043A\u0440\u0430\u0449\u0430\u043B
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u0432 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0435 \u0432\u0440\u0435\u043C\u044F.
    *   **\u041D\u0430\u0447\u0430\u043B\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B:** \u0412 \u044D\u0442\u043E\u0442
    \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D \u0440\u0435\u0448\u0438\u043B
    \u0437\u0430\u0434\u0430\u0447\u0443, \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u043D\u0443\u044E
    \u0435\u043C\u0443 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0435\u043C, \u043E
    \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0438 \u043C\u0435\u0436\u0434\u0443
    \u0433\u0440\u0430\u043D\u044F\u043C\u0438, \u0440\u0435\u0431\u0440\u0430\u043C\u0438
    \u0438 \u0432\u0435\u0440\u0448\u0438\u043D\u0430\u043C\u0438 \u0432\u044B\u043F\u0443\u043A\u043B\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u0438\u043A\u043E\u0432,
    \u0447\u0442\u043E \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u043E \u0435\u043C\u0443
    \u043F\u0435\u0440\u0432\u0443\u044E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C.
    \u0412 1813 \u0433\u043E\u0434\u0443, \u043F\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u043D\u0438\u044E
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430 \u0438 \u041B\u0430\u043F\u043B\u0430\u0441\u0430,
    \u043E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u0443\u044E
    \u0441\u043B\u0443\u0436\u0431\u0443 \u0438 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u041F\u0430\u0440\u0438\u0436, \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C
    \u0441\u0435\u0431\u044F \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043D\u0430\u0443\u043A\u0435. *   **\u041F\u0435\u0440\u0432\u044B\u0435 \u0442\u0440\u0438\u0443\u043C\u0444\u044B:**
    \u0412 1814 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u043C\u0435\u043C\u0443\u0430\u0440
    \u043E\u0431 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0445
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430\u0445, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E. \u0412 1816
    \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0413\u0440\u0430\u043D-\u043F\u0440\u0438 \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A \u0437\u0430
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043F\u043E \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044E
    \u0432\u043E\u043B\u043D, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0432
    \u0433\u0438\u0434\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435.
    \u0412 \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0431\u044B\u043B \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D \u0447\u043B\u0435\u043D\u043E\u043C
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A, \u0437\u0430\u043D\u044F\u0432 \u043C\u0435\u0441\u0442\u043E
    \u043E\u043F\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0413\u0430\u0441\u043F\u0430\u0440\u0430 \u041C\u043E\u043D\u0436\u0430.  ###
    \U0001F468\u200D\U0001F3EB \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0438 \u043D\u043E\u0432\u0430\u0442\u043E\u0440 \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    (1816\u20131830)  \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u0441\u0430\u043C\u043E\u0435
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u043E\u0435 \u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u0432 \u0436\u0438\u0437\u043D\u0438 \u041A\u043E\u0448\u0438.
    \u041E\u043D \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u0438\u0435
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438 \u0432 \u0442\u0440\u0435\u0445
    \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u0443\u0447\u0435\u0431\u043D\u044B\u0445
    \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u044F\u0445 \u041F\u0430\u0440\u0438\u0436\u0430:
    \u0421\u043E\u0440\u0431\u043E\u043D\u043D\u0435, \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 \u0438 \u041A\u043E\u043B\u043B\u0435\u0436 \u0434\u0435
    \u0424\u0440\u0430\u043D\u0441.  \u0418\u043C\u0435\u043D\u043D\u043E \u0432
    \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0438
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435:
    *   \u041E\u043D \u043D\u0430\u0447\u0430\u043B \u0447\u0438\u0442\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u0438, \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u0441\u0442\u0440\u043E\u0433\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u043D\u0430 \u043F\u043E\u043D\u044F\u0442\u0438\u0438 **\u043F\u0440\u0435\u0434\u0435\u043B\u0430**.
    *   \u0412 1821 \u0433\u043E\u0434\u0443 \u0432\u044B\u0448\u0435\u043B \u0435\u0433\u043E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 **\xAB\u041A\u0443\u0440\u0441
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430\xBB (Cours d'analyse)**, \u0437\u0430
    \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u0438
    \xAB\u0420\u0435\u0437\u044E\u043C\u0435 \u0443\u0440\u043E\u043A\u043E\u0432
    \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E\xBB (1823) \u0438
    \xAB\u041F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    \u043A \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB (1826\u20131828).
    \u0412 \u044D\u0442\u0438\u0445 \u0440\u0430\u0431\u043E\u0442\u0430\u0445 \u043E\u043D
    \u0432\u0432\u0435\u043B \u0441\u0442\u0440\u043E\u0433\u0438\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    **\u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438**, **\u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430**
    \u043A\u0430\u043A \u043F\u0440\u0435\u0434\u0435\u043B\u0430 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0441\u0443\u043C\u043C \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E **\u0441\u0445\u043E\u0434\u044F\u0449\u0438\u0445\u0441\u044F
    \u0440\u044F\u0434\u043E\u0432**. *   \u041E\u043D \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432 \u043E\u0434\u0438\u043D\u043E\u0447\u043A\u0443 \u0441\u043E\u0437\u0434\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E **\u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u043E\u0433\u043E \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E**,
    \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430
    \u041A\u043E\u0448\u0438**, \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    **\u0442\u0435\u043E\u0440\u0438\u044E \u0432\u044B\u0447\u0435\u0442\u043E\u0432**.
    *   \u0412 \u0442\u0435\u043E\u0440\u0438\u0438 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u043E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **\u0437\u0430\u0434\u0430\u0447\u0443
    \u041A\u043E\u0448\u0438**. *   \u0412 1822 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    **\u0442\u0435\u043E\u0440\u0438\u0438 \u0443\u043F\u0440\u0443\u0433\u043E\u0441\u0442\u0438**,
    \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u044F \u0442\u0435\u043B\u043E
    \u043A\u0430\u043A \u0441\u043F\u043B\u043E\u0448\u043D\u0443\u044E \u0441\u0440\u0435\u0434\u0443
    \u0438 \u0432\u0432\u0435\u0434\u044F \u043F\u043E\u043D\u044F\u0442\u0438\u044F
    \u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u0438\u0439 \u0438 \u0434\u0435\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u0439
    \u0432 \u043A\u0430\u0436\u0434\u043E\u0439 \u0435\u0433\u043E \u0442\u043E\u0447\u043A\u0435. 
    ### \U0001F6B6 \u0418\u0437\u0433\u043D\u0430\u043D\u0438\u0435 \u0438 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    (1830\u20131857)  *   **\u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u0441
    \u0432\u043B\u0430\u0441\u0442\u044C\u044E:** \u0412 1830 \u0433\u043E\u0434\u0443
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430
    \u0418\u044E\u043B\u044C\u0441\u043A\u0430\u044F \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F,
    \u0441\u0432\u0435\u0440\u0433\u043D\u0443\u0432\u0448\u0430\u044F \u043A\u043E\u0440\u043E\u043B\u044F
    \u041A\u0430\u0440\u043B\u0430 X. \u041A\u043E\u0448\u0438, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C \u043B\u0435\u0433\u0438\u0442\u0438\u043C\u0438\u0441\u0442\u043E\u043C
    (\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043A\u043E\u043C \u0441\u0442\u0430\u0440\u0448\u0435\u0439
    \u0432\u0435\u0442\u0432\u0438 \u0411\u0443\u0440\u0431\u043E\u043D\u043E\u0432),
    \u043D\u0430\u043E\u0442\u0440\u0435\u0437 \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043F\u0440\u0438\u0441\u044F\u0433\u0430\u0442\u044C \u043D\u0430 \u0432\u0435\u0440\u043D\u043E\u0441\u0442\u044C
    \u043D\u043E\u0432\u043E\u043C\u0443 \u043A\u043E\u0440\u043E\u043B\u044E \u041B\u0443\u0438-\u0424\u0438\u043B\u0438\u043F\u043F\u0443
    \u0438 \u043F\u043E\u0442\u0435\u0440\u044F\u043B \u0432\u0441\u0435 \u0441\u0432\u043E\u0438
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438. *   **\u0414\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u043E\u0435
    \u0438\u0437\u0433\u043D\u0430\u043D\u0438\u0435:** \u041E\u043D \u0443\u0435\u0445\u0430\u043B
    \u0438\u0437 \u0424\u0440\u0430\u043D\u0446\u0438\u0438. \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u043E\u043D \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B
    \u0432 \u0422\u0443\u0440\u0438\u043D\u0435 (\u0418\u0442\u0430\u043B\u0438\u044F),
    \u0430 \u0437\u0430\u0442\u0435\u043C, \u043F\u043E \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u044E
    \u0441\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u044F
    \u041A\u0430\u0440\u043B\u0430 X, \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u041F\u0440\u0430\u0433\u0443, \u0447\u0442\u043E\u0431\u044B \u0441\u0442\u0430\u0442\u044C
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C \u0438 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u0442\u0435\u043B\u0435\u043C
    \u0435\u0433\u043E \u0432\u043D\u0443\u043A\u0430, \u0433\u0435\u0440\u0446\u043E\u0433\u0430
    \u0411\u043E\u0440\u0434\u043E\u0441\u043A\u043E\u0433\u043E. \u0417\u0430 \u044D\u0442\u0443
    \u0441\u043B\u0443\u0436\u0431\u0443 \u0438\u0437\u0433\u043D\u0430\u043D\u043D\u044B\u0439
    \u043A\u043E\u0440\u043E\u043B\u044C \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u043B
    \u0435\u043C\u0443 \u0442\u0438\u0442\u0443\u043B \u0431\u0430\u0440\u043E\u043D\u0430.
    \u0412 1834 \u0433\u043E\u0434\u0443 \u043A \u043D\u0435\u043C\u0443 \u043F\u0440\u0438\u0441\u043E\u0435\u0434\u0438\u043D\u0438\u043B\u0430\u0441\u044C
    \u0435\u0433\u043E \u0436\u0435\u043D\u0430. *   **\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435:**
    \u0412 1838 \u0433\u043E\u0434\u0443 \u043E\u043D \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u041F\u0430\u0440\u0438\u0436. \u041F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443
    \u043E\u0442 \u043D\u0435\u0433\u043E \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435
    \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u0438 \u043F\u0440\u0438\u0441\u044F\u0433\u0438,
    \u043E\u043D \u0441\u043C\u043E\u0433 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u0441\u0432\u043E\u0435 \u0447\u043B\u0435\u043D\u0441\u0442\u0432\u043E \u0432
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A, \u043D\u043E
    \u043D\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u043E\u0439
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438. \u041B\u0438\u0448\u044C
    \u043F\u043E\u0441\u043B\u0435 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438
    1848 \u0433\u043E\u0434\u0430, \u043A\u043E\u0433\u0434\u0430 \u043F\u0440\u0438\u0441\u044F\u0433\u0430
    \u0431\u044B\u043B\u0430 \u043E\u0442\u043C\u0435\u043D\u0435\u043D\u0430, \u043E\u043D
    \u0432\u043D\u043E\u0432\u044C \u0437\u0430\u043D\u044F\u043B \u043A\u0430\u0444\u0435\u0434\u0440\u0443
    \u0432 \u0421\u043E\u0440\u0431\u043E\u043D\u043D\u0435. \u0414\u0430\u0436\u0435
    \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D III \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0435\u0433\u043E \u043D\u0430 \u044D\u0442\u043E\u043C \u043F\u043E\u0441\u0442\u0443
    \u0432 1852 \u0433\u043E\u0434\u0443, \u043D\u0435 \u0442\u0440\u0435\u0431\u0443\u044F
    \u043F\u0440\u0438\u0441\u044F\u0433\u0438.  ### \U0001F4D6 \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0438 \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  *   **\u0421\u0435\u043C\u044C\u044F:**
    \u0412 1818 \u0433\u043E\u0434\u0443 \u041A\u043E\u0448\u0438 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0410\u043B\u043E\u0438\u0437\u0435 \u0434\u0435 \u0411\u044E\u0440,
    \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u0446\u0435 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u044F. \u0423 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C
    \u0434\u0432\u0435 \u0434\u043E\u0447\u0435\u0440\u0438. *   **\u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440:**
    \u0415\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u0447\u0430\u0441\u0442\u043E
    \u0441\u0447\u0438\u0442\u0430\u043B\u0438 \u0435\u0433\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0442\u044F\u0436\u0435\u043B\u044B\u043C \u0432 \u043E\u0431\u0449\u0435\u043D\u0438\u0438,
    \u0441\u0430\u043C\u043E\u0443\u0432\u0435\u0440\u0435\u043D\u043D\u044B\u043C
    \u0438 \u0430\u0433\u0440\u0435\u0441\u0441\u0438\u0432\u043D\u044B\u043C \u0432
    \u0441\u0432\u043E\u0438\u0445 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0445
    \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0432\u0437\u0433\u043B\u044F\u0434\u0430\u0445. \u042D\u0442\u0430 \u043D\u0435\u043F\u0440\u0438\u043C\u0438\u0440\u0438\u043C\u043E\u0441\u0442\u044C
    \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0430
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438 \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B.
    *   **\u0413\u0438\u0433\u0430\u043D\u0442\u0441\u043A\u0438\u0439 \u0432\u043A\u043B\u0430\u0434:**
    \u041A\u043E\u0448\u0438 \u0431\u044B\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u043B\u043E\u0434\u043E\u0432\u0438\u0442\u044B\u043C \u0443\u0447\u0435\u043D\u044B\u043C.
    \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043E\u043A\u043E\u043B\u043E
    **800 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0440\u0430\u0431\u043E\u0442**
    \u0438 \u043F\u044F\u0442\u044C \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u044B\u0445
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u0432. \u0415\u0433\u043E \u043F\u043E\u043B\u043D\u043E\u0435
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435 \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439
    \u0441\u043E\u0441\u0442\u043E\u0438\u0442 \u0438\u0437 **27 \u0442\u043E\u043C\u043E\u0432**.
    *   **\u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435:** \u041E\u043D
    \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430,
    \u043F\u043E\u0447\u0435\u0442\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A (\u0441
    1851 \u0433.) \u0438 \u043C\u043D\u043E\u0433\u0438\u0445 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439 \u0415\u0432\u0440\u043E\u043F\u044B.
    \u0415\u0433\u043E \u0438\u043C\u044F \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u043E
    \u043D\u0430 \u042D\u0439\u0444\u0435\u043B\u0435\u0432\u043E\u0439 \u0431\u0430\u0448\u043D\u0435
    \u0432 \u0441\u043F\u0438\u0441\u043A\u0435 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0443\u0447\u0435\u043D\u044B\u0445 \u0424\u0440\u0430\u043D\u0446\u0438\u0438.
    *   **\u0421\u043C\u0435\u0440\u0442\u044C:** \u041E\u0433\u044E\u0441\u0442\u0435\u043D
    \u041B\u0443\u0438 \u041A\u043E\u0448\u0438 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    23 \u043C\u0430\u044F 1857 \u0433\u043E\u0434\u0430 \u0432 \u043C\u0435\u0441\u0442\u0435\u0447\u043A\u0435
    \u0421\u043E (\u043F\u043E\u0434 \u041F\u0430\u0440\u0438\u0436\u0435\u043C).
    \u041F\u043E \u043F\u0440\u0435\u0434\u0430\u043D\u0438\u044E, \u0435\u0433\u043E
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u043C\u0438 \u0441\u043B\u043E\u0432\u0430\u043C\u0438
    \u0432 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u0431\u044B\u043B\u0438:
    \xAB\u042F \u043E\u0431\u044A\u044F\u0441\u043D\u044E \u044D\u0442\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0435
    \u0432 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C \u043C\u0435\u043C\u0443\u0430\u0440\u0435\xBB."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u041A\u043E\u0448\u0438 \u043F\u043E\u043B\u043D\u0430
    \u043B\u044E\u0431\u043E\u043F\u044B\u0442\u043D\u044B\u0445 \u044D\u043F\u0438\u0437\u043E\u0434\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0440\u0438\u0441\u0443\u044E\u0442
    \u0435\u0433\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043A\u0430\u043A
    \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E,
    \u043D\u043E \u0438 \u043A\u0430\u043A \u043E\u0447\u0435\u043D\u044C \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430. \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435 \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438,
    \u0441\u043E\u0431\u0440\u0430\u043D\u043D\u044B\u0435 \u0432\u043E\u0435\u0434\u0438\u043D\u043E. 
    ### \U0001F9E0 \u041F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u043E
    \u0438 \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0439 \u043F\u0443\u0442\u044C 
    *   **\u041F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u0435
    \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430:** \u041A\u043E\u0433\u0434\u0430
    \u041A\u043E\u0448\u0438 \u0431\u044B\u043B \u0435\u0449\u0435 \u0440\u0435\u0431\u0435\u043D\u043A\u043E\u043C,
    \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0416\u043E\u0437\u0435\u0444-\u041B\u0443\u0438 \u041B\u0430\u0433\u0440\u0430\u043D\u0436,
    \u0431\u043B\u0438\u0437\u043A\u0438\u0439 \u0434\u0440\u0443\u0433 \u0441\u0435\u043C\u044C\u0438,
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043B \u0435\u0433\u043E
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C. \u041E\u043D
    \u0434\u0430\u0436\u0435 \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0434\u0438\u043B
    \u043E\u0442\u0446\u0430 \u041A\u043E\u0448\u0438, \u0447\u0442\u043E\u0431\u044B
    \u0442\u043E\u0442 \u043D\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u043D\u0438\u0433 \u0434\u043E 17 \u043B\u0435\u0442, \u0447\u0442\u043E\u0431\u044B
    \u0442\u043E\u0442 \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0445\u043E\u0440\u043E\u0448\u0435\u0435 \u0433\u0443\u043C\u0430\u043D\u0438\u0442\u0430\u0440\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435. *   **\u041A\u0430\u0440\u044C\u0435\u0440\u043D\u044B\u0439
    \u0441\u0442\u0430\u0440\u0442:** \u0412 16 \u043B\u0435\u0442 \u041A\u043E\u0448\u0438
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443, \u0437\u0430\u043D\u044F\u0432 \u0432\u0442\u043E\u0440\u043E\u0435
    \u043C\u0435\u0441\u0442\u043E \u0441\u0440\u0435\u0434\u0438 \u043F\u043E\u0447\u0442\u0438
    300 \u0430\u0431\u0438\u0442\u0443\u0440\u0438\u0435\u043D\u0442\u043E\u0432.
    \u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043E\u043D \u0432\u044B\u0431\u0440\u0430\u043B
    \u043A\u0430\u0440\u044C\u0435\u0440\u0443 \u0432\u043E\u0435\u043D\u043D\u043E\u0433\u043E
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430 \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043D\u0430\u0434 \u0443\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0438\u044F\u043C\u0438
    \u043F\u043E\u0440\u0442\u0430 \u0432 \u0428\u0435\u0440\u0431\u0443\u0440\u0435
    \u0432\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0430 \u041D\u0430\u043F\u043E\u043B\u0435\u043E\u043D\u0430. 
    ### \u270D\uFE0F \u041F\u043B\u043E\u0434\u043E\u0432\u0438\u0442\u043E\u0441\u0442\u044C
    \u0438 \"\u0446\u0430\u0440\u0441\u043A\u0438\u0439\" \u043F\u0443\u0442\u044C 
    *   **\u041A\u043E\u0448\u0438 \u2014 \u0411\u0430\u043B\u044C\u0437\u0430\u043A
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435:** \u041A\u043E\u0448\u0438
    \u0431\u044B\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u0435\u043D. \u041F\u043E
    \u043E\u0431\u044A\u0435\u043C\u0443 \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E
    \u0435\u0433\u043E \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u044E\u0442
    \u0441 \u041E\u043D\u043E\u0440\u0435 \u0434\u0435 \u0411\u0430\u043B\u044C\u0437\u0430\u043A\u043E\u043C,
    \u043D\u0430\u043F\u0438\u0441\u0430\u0432\u0448\u0438\u043C 90 \u0442\u043E\u043C\u043E\u0432
    \xAB\u0427\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u043E\u043C\u0435\u0434\u0438\u0438\xBB. \u041A\u043E\u0448\u0438 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F \u0431\u043E\u043B\u0435\u0435
    800 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0440\u0430\u0431\u043E\u0442
    \u0438 \u043F\u044F\u0442\u044C \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u0432.
    \u0415\u0433\u043E \u043F\u043E\u043B\u043D\u043E\u0435 \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    27 \u0442\u043E\u043C\u043E\u0432. *   **\u0426\u0430\u0440\u0441\u043A\u0438\u0439
    \u043F\u0443\u0442\u044C \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435:**
    \u041A\u043E\u0448\u0438 \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u0447\u0435\u0439 \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0439 \u043F\u0443\u0442\u044C
    \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u043B\u0441\u044F \u0441 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u0438\u043C\u0438
    \u043E\u0441\u043E\u0431\u0430\u043C\u0438. \u041E\u043D \u0431\u044B\u043B \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u0442\u0435\u043B\u0435\u043C
    \u0432\u043D\u0443\u043A\u0430 \u0441\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u044F \u041A\u0430\u0440\u043B\u0430 X \u0432
    \u041F\u0440\u0430\u0433\u0435, \u0437\u0430 \u0447\u0442\u043E \u0438\u0437\u0433\u043D\u0430\u043D\u043D\u044B\u0439
    \u043A\u043E\u0440\u043E\u043B\u044C \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u043B
    \u0435\u043C\u0443 \u0442\u0438\u0442\u0443\u043B \u0431\u0430\u0440\u043E\u043D\u0430.
    *   **\xAB\u0412 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C \u043C\u0435\u043C\u0443\u0430\u0440\u0435\u2026\xBB:**
    \u0415\u0433\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u043C\u0438
    \u0441\u043B\u043E\u0432\u0430\u043C\u0438 \u0432 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u0431\u044B\u043B\u0438: \xAB\u042F \u043E\u0431\u044A\u044F\u0441\u043D\u044E
    \u044D\u0442\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0435\u0435 \u0432
    \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C \u043C\u0435\u043C\u0443\u0430\u0440\u0435\xBB. 
    ### \u2696\uFE0F \u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440, \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u0430
    \u0438 \u0447\u0443\u0434\u0430\u0447\u0435\u0441\u0442\u0432\u0430  *   **\u041F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u043C\u043E\u043D\u0430\u0440\u0445\u0438\u0441\u0442:** \u041A\u043E\u0448\u0438
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u043C\u043E\u043D\u0430\u0440\u0445\u0438\u0441\u0442\u043E\u043C, \u043D\u043E
    \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0432\u0435\u0440\u0443\u044E\u0449\u0438\u043C
    \u043A\u0430\u0442\u043E\u043B\u0438\u043A\u043E\u043C. \u0412 1830 \u0433\u043E\u0434\u0443,
    \u043F\u043E\u0441\u043B\u0435 \u0418\u044E\u043B\u044C\u0441\u043A\u043E\u0439
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438, \u043E\u043D \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0435\u043B
    \u043F\u043E\u0442\u0435\u0440\u044F\u0442\u044C \u0432\u0441\u0435 \u0441\u0432\u043E\u0438
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438 \u0438 \u0443\u0435\u0445\u0430\u0442\u044C
    \u0432 \u0434\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u043E\u0435
    \u0438\u0437\u0433\u043D\u0430\u043D\u0438\u0435, \u043B\u0438\u0448\u044C \u0431\u044B
    \u043D\u0435 \u043F\u0440\u0438\u0441\u044F\u0433\u0430\u0442\u044C \u043D\u0430
    \u0432\u0435\u0440\u043D\u043E\u0441\u0442\u044C \u043D\u043E\u0432\u043E\u043C\u0443
    \u043A\u043E\u0440\u043E\u043B\u044E \u041B\u0443\u0438-\u0424\u0438\u043B\u0438\u043F\u043F\u0443.
    *   **\u041F\u043E\u043C\u043E\u0449\u044C \u0432\u0440\u0430\u0433\u0443:**
    \u041A\u043E\u0448\u0438 \u0438 \u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0430
    \u041E\u0441\u0442\u0440\u043E\u0433\u0440\u0430\u0434\u0441\u043A\u0438\u0439
    \u0438\u0441\u043F\u043E\u0432\u0435\u0434\u043E\u0432\u0430\u043B\u0438 \u0434\u0438\u0430\u043C\u0435\u0442\u0440\u0430\u043B\u044C\u043D\u043E
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u044B\u0435
    \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0432\u0437\u0433\u043B\u044F\u0434\u044B.
    \u0422\u0435\u043C \u043D\u0435 \u043C\u0435\u043D\u0435\u0435, \u043A\u043E\u0433\u0434\u0430
    \u041E\u0441\u0442\u0440\u043E\u0433\u0440\u0430\u0434\u0441\u043A\u0438\u0439
    \u043F\u043E\u043F\u0430\u043B \u0432 \u0434\u043E\u043B\u0433\u043E\u0432\u0443\u044E
    \u0442\u044E\u0440\u044C\u043C\u0443 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435,
    \u041A\u043E\u0448\u0438 \u043E\u0434\u043E\u0431\u0440\u0438\u043B \u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443, \u0430 \u0437\u0430\u0442\u0435\u043C \u0438
    \u0432\u044B\u043A\u0443\u043F\u0438\u043B \u0443\u0447\u0435\u043D\u043E\u0433\u043E
    \u0438\u0437 \u0442\u044E\u0440\u044C\u043C\u044B. *   **\u0421\u043B\u043E\u0436\u043D\u044B\u0439
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C:**
    \u0421\u0442\u0443\u0434\u0435\u043D\u0442\u044B \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u0441\u0447\u0438\u0442\u0430\u043B\u0438 \u0435\u0433\u043E \u0442\u044F\u0436\u0435\u043B\u044B\u043C
    \u0432 \u043E\u0431\u0449\u0435\u043D\u0438\u0438. \u041E\u043D \u0431\u044B\u043B
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0435\u0439
    \u043D\u0435\u043F\u0440\u0438\u043C\u0438\u0440\u0438\u043C\u043E\u0441\u0442\u044C\u044E
    \u0432 \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u0445 \u0440\u0435\u043B\u0438\u0433\u0438\u0438
    \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u0438, \u0447\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u043B\u043E
    \u0435\u043C\u0443 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0432\u0440\u0430\u0433\u043E\u0432
    \u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043A\u0440\u0443\u0433\u0430\u0445. 
    ### \U0001F3AD \u041A\u0443\u0440\u044C\u0435\u0437\u044B \u0438 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E\u0441\u0442\u0438 
    *   **\u0418\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u044B\u0435 \u0448\u0443\u0442\u043A\u0438:**
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u0440\u0430\u0431\u043E\u0442\u044B
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C \u041A\u043E\u0448\u0438
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0440\u0435\u043C\u043E\u043D\u0442\u043E\u043C
    \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0445 \u043A\u0430\u043D\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0439.
    \u0415\u0433\u043E \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u043D\u0438\u043A,
    \u044E\u043D\u044B\u0439 \u0433\u0435\u0440\u0446\u043E\u0433 \u0411\u043E\u0440\u0434\u043E\u0441\u043A\u0438\u0439,
    \u0441 \u0434\u0435\u0442\u0441\u043A\u043E\u0439 \u0437\u043B\u043E\u0441\u0442\u044C\u044E
    \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u043B \u0435\u043C\u0443 \u043E\u0431
    \u044D\u0442\u043E\u043C, \u0433\u043E\u0432\u043E\u0440\u044F, \u0447\u0442\u043E
    \u041A\u043E\u0448\u0438 \u043D\u0430\u0447\u0430\u043B \u0441\u0432\u043E\u044E
    \u043A\u0430\u0440\u044C\u0435\u0440\u0443 \u0432 \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0445
    \u0441\u0442\u043E\u0447\u043D\u044B\u0445 \u0442\u0440\u0443\u0431\u0430\u0445.
    *   **\u0412\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435:**
    \u0418\u043C\u044F \u041A\u043E\u0448\u0438 \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u043E
    \u043D\u0430 \u042D\u0439\u0444\u0435\u043B\u0435\u0432\u043E\u0439 \u0431\u0430\u0448\u043D\u0435
    \u0432 \u0441\u043F\u0438\u0441\u043A\u0435 72 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0443\u0447\u0435\u043D\u044B\u0445 \u0424\u0440\u0430\u043D\u0446\u0438\u0438.
    *   **\u0412\u0441\u0435\u0433\u043E \u0447\u0435\u0442\u044B\u0440\u0435 \u043A\u043D\u0438\u0433\u0438:**
    \u0423\u0435\u0437\u0436\u0430\u044F \u043D\u0430 \u043F\u0435\u0440\u0432\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 \u0428\u0435\u0440\u0431\u0443\u0440,
    \u043C\u043E\u043B\u043E\u0434\u043E\u0439 \u0438\u043D\u0436\u0435\u043D\u0435\u0440
    \u041A\u043E\u0448\u0438 \u0432\u0437\u044F\u043B \u0441 \u0441\u043E\u0431\u043E\u0439
    \u0432\u0441\u0435\u0433\u043E \u0447\u0435\u0442\u044B\u0440\u0435 \u043A\u043D\u0438\u0433\u0438:
    \u0441\u0431\u043E\u0440\u043D\u0438\u043A \u0441\u0442\u0438\u0445\u043E\u0432
    \u0412\u0435\u0440\u0433\u0438\u043B\u0438\u044F, \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0439
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442 \xAB\u041F\u043E\u0434\u0440\u0430\u0436\u0430\u043D\u0438\u0435
    \u0425\u0440\u0438\u0441\u0442\u0443\xBB, \xAB\u041D\u0435\u0431\u0435\u0441\u043D\u0443\u044E
