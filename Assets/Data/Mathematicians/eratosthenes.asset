  achievementsRu: "\u041A\u043E\u043D\u0435\u0447\u043D\u043E. \u0415\u0441\u043B\u0438
    \u043E\u0442\u0431\u0440\u043E\u0441\u0438\u0442\u044C \u043A\u0440\u0430\u0442\u043A\u0438\u0439
    \u043E\u0431\u0437\u043E\u0440 \u0438 \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u0442\u044C\u0441\u044F
    \u0432 \u0434\u0435\u0442\u0430\u043B\u0438, \u0442\u043E \u043E\u043A\u0430\u0436\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u0431\u044B\u043B
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \xAB\u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u043E\u043C\xBB,
    \u0430 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432 \u043A\u0430\u0436\u0434\u043E\u043C \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u043C
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u043B
    \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u043C\u0435\u0442\u043E\u0434\u043E\u043B\u043E\u0433\u0438\u044E.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u0432 \u043D\u0430\u0443\u043A\u0443
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u0441\u043F\u0438\u0441\u043E\u043A \u0444\u0430\u043A\u0442\u043E\u0432,
    \u0430 \u0441\u043F\u0438\u0441\u043E\u043A **\u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E
    \u043D\u043E\u0432\u044B\u0445 \u0441\u043F\u043E\u0441\u043E\u0431\u043E\u0432
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F**, \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438
    \u043C\u044B \u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C\u0441\u044F \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440.  \u041D\u0438\u0436\u0435 \u044F \u0440\u0430\u0437\u0431\u0438\u043B
    \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043D\u0435 \u043F\u043E \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0430\u043C,
    \u0430 \u043F\u043E **\u0441\u0443\u0442\u0438 \u0440\u0435\u0448\u0435\u043D\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447**, \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u0433\u043B\u0443\u0431\u0438\u043D\u0443 \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u044F. 
    ### 1. \u0413\u0435\u043E\u0434\u0435\u0437\u0438\u044F \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F:
    \u0418\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0435 \u043D\u0435\u0432\u0438\u0434\u0438\u043C\u043E\u0433\u043E
    (\u042D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0444\u0438\u0437\u0438\u043A\u0430)  \u0421\u0430\u043C\u043E\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u2014 \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0435
    \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u0438 \u0417\u0435\u043C\u043B\u0438
    \u2014 \u043D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0432\u0435\u0440\u0448\u0438\u043D\u043E\u0439 \u0435\u0433\u043E \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u043E\u0433\u043E
    \u043C\u0435\u0442\u043E\u0434\u0430. \u0417\u0434\u0435\u0441\u044C \u0432\u0430\u0436\u043D\u043E
    \u043D\u0435 \u0447\u0438\u0441\u043B\u043E (\u043F\u0443\u0441\u0442\u044C \u0434\u0430\u0436\u0435
    \u0438 \u0442\u043E\u0447\u043D\u043E\u0435), \u0430 **\u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B**. 
    *   **\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043C\u043E\u0434\u0435\u043B\u044C:** \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u0438\u0441\u0445\u043E\u0434\u0438\u043B \u0438\u0437 \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442\u0430,
    \u0447\u0442\u043E \u0421\u043E\u043B\u043D\u0446\u0435 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0434\u0430\u043B\u0435\u043A\u043E,
    \u0447\u0442\u043E \u0435\u0433\u043E \u043B\u0443\u0447\u0438 \u043F\u0440\u0438\u0445\u043E\u0434\u044F\u0442
    \u043D\u0430 \u0417\u0435\u043C\u043B\u044E \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u043F\u0443\u0447\u043A\u0430\u043C\u0438. \u042D\u0442\u043E \u0431\u044B\u043B\u043E
    \u0441\u043C\u0435\u043B\u043E\u0435 \u0434\u043E\u043F\u0443\u0449\u0435\u043D\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0432 \u0442\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u0430
    \u0440\u0430\u0437\u0434\u0435\u043B\u044F\u043B\u0438 \u043D\u0435 \u0432\u0441\u0435.
    *   **\u0418\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0439:**
    \u041E\u043D \u043D\u0435 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u043F\u0440\u0438\u0431\u043E\u0440\u043E\u0432.
    \u0415\u0433\u043E \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C
    \u0441\u0442\u0430\u043B **\u0441\u043A\u0430\u0444\u0438\u0441** (\u0447\u0430\u0448\u0435\u043E\u0431\u0440\u0430\u0437\u043D\u044B\u0435
    \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0435 \u0447\u0430\u0441\u044B).
    \u0412 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438 \u043E\u043D
    \u0437\u0430\u043C\u0435\u0440\u0438\u043B \u0443\u0433\u043E\u043B \u043C\u0435\u0436\u0434\u0443
    \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u043C \u0448\u0435\u0441\u0442\u043E\u043C
    (\u0433\u043D\u043E\u043C\u043E\u043D\u043E\u043C) \u0438 \u0442\u0435\u043D\u044C\u044E.
    \u0423\u0433\u043E\u043B \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B 1/50
    \u0447\u0430\u0441\u0442\u044C \u043A\u0440\u0443\u0433\u0430. *   **\u041A\u043B\u044E\u0447\u0435\u0432\u043E\u0435
    \u043D\u043E\u0443-\u0445\u0430\u0443:** \u041E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    **\u0440\u0430\u0437\u043D\u043E\u0441\u0442\u044C \u0448\u0438\u0440\u043E\u0442**,
    \u0430 \u043D\u0435 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u043F\u043E \u043A\u0430\u0440\u0442\u0435. \u041E\u043D \u0437\u043D\u0430\u043B,
    \u0447\u0442\u043E \u0432 \u0421\u0438\u0435\u043D\u0435 (\u0410\u0441\u0443\u0430\u043D)
    \u0432 \u0434\u0435\u043D\u044C \u0441\u043E\u043B\u043D\u0446\u0435\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    \u0421\u043E\u043B\u043D\u0446\u0435 \u0441\u0442\u043E\u0438\u0442 \u0432 \u0437\u0435\u043D\u0438\u0442\u0435
    (\u043E\u0441\u0432\u0435\u0449\u0430\u0435\u0442 \u0434\u043D\u043E \u043A\u043E\u043B\u043E\u0434\u0446\u0435\u0432).
    \u042D\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E, \u0447\u0442\u043E
    \u0421\u0438\u0435\u043D\u0430 \u043B\u0435\u0436\u0438\u0442 \u0442\u043E\u0447\u043D\u043E
    \u043D\u0430 \u043B\u0438\u043D\u0438\u0438 \u0442\u0440\u043E\u043F\u0438\u043A\u0430.
    \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u043C\u0435\u0436\u0434\u0443 \u0433\u043E\u0440\u043E\u0434\u0430\u043C\u0438
    \u2014 \u044D\u0442\u043E \u0434\u0443\u0433\u0430 \u043C\u0435\u0440\u0438\u0434\u0438\u0430\u043D\u0430
    \u0432 7,2 \u0433\u0440\u0430\u0434\u0443\u0441\u0430. *   **\u041F\u043E\u043F\u0440\u0430\u0432\u043A\u0430
    \u043D\u0430 \u0440\u0435\u0430\u043B\u0438\u0438:** \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u0443\u0441\u043B\u043E\u0436\u043D\u0438\u043B \u0440\u0430\u0441\u0447\u0435\u0442.
    \u041E\u043D \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u044F
    \u0438 \u0421\u0438\u0435\u043D\u0430 **\u043D\u0435 \u043B\u0435\u0436\u0430\u0442
    \u043D\u0430 \u043E\u0434\u043D\u043E\u043C \u043C\u0435\u0440\u0438\u0434\u0438\u0430\u043D\u0435**
    (\u0440\u0430\u0437\u043D\u0438\u0446\u0430 \u0432 \u0434\u043E\u043B\u0433\u043E\u0442\u0435
    \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u043E\u043A\u043E\u043B\u043E
    3\xB0). \u041F\u043E\u044D\u0442\u043E\u043C\u0443 \u043E\u043D \u043D\u0435
    \u0441\u0442\u0430\u043B \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438
    \u0443\u043C\u043D\u043E\u0436\u0430\u0442\u044C 5000 \u0441\u0442\u0430\u0434\u0438\u0435\u0432
    \u043D\u0430 50. \u041E\u043D \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u0441\u043F\u0440\u043E\u0435\u0446\u0438\u0440\u043E\u0432\u0430\u043B
    \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u043C\u0435\u0436\u0434\u0443
    \u0433\u043E\u0440\u043E\u0434\u0430\u043C\u0438 \u043D\u0430 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0441\u0435\u0432\u0435\u0440-\u044E\u0433, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0441\u043A\u043E\u0440\u0440\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435, \u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E\u0442\u043E\u043C \u043C\u043D\u043E\u0436\u0438\u043B. \u042D\u0442\u043E
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043E \u0435\u0433\u043E \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u043C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0438.  ---  ### 2. \u041A\u0430\u0440\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u044F:
    \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u043D\u043E\u0439
    \u0441\u0435\u0442\u043A\u0438 (\u0421\u0438\u0441\u0442\u0435\u043C\u043D\u044B\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434)  \u0414\u043E \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430
    \u043A\u0430\u0440\u0442\u044B \u0431\u044B\u043B\u0438 \u043F\u043E\u0445\u043E\u0436\u0438
    \u043D\u0430 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u044B\u0435
    \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0430\u0446\u0438\u0438: \u0431\u0435\u0440\u0435\u0433\u0430
    \u0440\u0438\u0441\u043E\u0432\u0430\u043B\u0438 \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u043B\u044C\u043D\u043E,
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u0443\u044F\u0441\u044C
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F\u043C\u0438 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432.
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u043F\u0435\u0440\u0432\u044B\u043C
    \u0441\u043A\u0430\u0437\u0430\u043B: *\xAB\u041A\u0430\u0440\u0442\u0430 \u0434\u043E\u043B\u0436\u043D\u0430
    \u0441\u0442\u0440\u043E\u0438\u0442\u044C\u0441\u044F \u043F\u043E \u0437\u0430\u043A\u043E\u043D\u0430\u043C
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB*.  *   **\u0412\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u043A\u043B\u0438\u043C\u0430\u0442\u043E\u0432 (\u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u0435\u0439):**
    \u041E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0430\u0440\u0438\u0441\u043E\u0432\u0430\u043B
    \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043B\u0438\u043D\u0438\u0438. \u041E\u043D \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043B
    \u0438\u0445 \u043A \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u044F\u0432\u043B\u0435\u043D\u0438\u044F\u043C. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043E\u043D \u043F\u0440\u043E\u0432\u0435\u043B \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u0438
    \u0447\u0435\u0440\u0435\u0437 \u043C\u0435\u0441\u0442\u0430, \u0433\u0434\u0435
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0441\u0430\u043C\u043E\u0433\u043E \u0434\u043B\u0438\u043D\u043D\u043E\u0433\u043E
    \u0434\u043D\u044F \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    13, 14, 15 \u0438 16 \u0447\u0430\u0441\u043E\u0432. \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u043E
    \u043B\u044E\u0431\u043E\u043C\u0443 \u043C\u043E\u0440\u0435\u043F\u043B\u0430\u0432\u0430\u0442\u0435\u043B\u044E,
    \u0437\u043D\u0430\u044F \u0448\u0438\u0440\u043E\u0442\u0443, \u043F\u043E\u043D\u0438\u043C\u0430\u0442\u044C
    \u043A\u043B\u0438\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F. *   **\u041F\u044F\u0442\u044C \u0437\u043E\u043D:**
    \u041E\u043D \u043F\u0435\u0440\u0432\u044B\u043C \u0447\u0435\u0442\u043A\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u043B \u0417\u0435\u043C\u043B\u044E
    \u043D\u0430 **\u0436\u0430\u0440\u043A\u0438\u0439, \u0434\u0432\u0430 \u0443\u043C\u0435\u0440\u0435\u043D\u043D\u044B\u0445
    \u0438 \u0434\u0432\u0430 \u0445\u043E\u043B\u043E\u0434\u043D\u044B\u0445 \u043F\u043E\u044F\u0441\u0430**,
    \u043E\u0441\u043D\u043E\u0432\u044B\u0432\u0430\u044F\u0441\u044C \u043D\u0430
    \u0443\u0433\u043B\u0435 \u043F\u0430\u0434\u0435\u043D\u0438\u044F \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0445
    \u043B\u0443\u0447\u0435\u0439. \u041E\u043D \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043B, \u043F\u043E\u0447\u0435\u043C\u0443
    \u0432 \u0436\u0430\u0440\u043A\u043E\u043C \u043F\u043E\u044F\u0441\u0435 (\u043C\u0435\u0436\u0434\u0443
    \u0442\u0440\u043E\u043F\u0438\u043A\u0430\u043C\u0438) \u043B\u044E\u0434\u0438
    \u043E\u0431\u0433\u043E\u0440\u0430\u044E\u0442, \u0430 \u0432 \u0445\u043E\u043B\u043E\u0434\u043D\u044B\u0445
    (\u0437\u0430 \u043F\u043E\u043B\u044F\u0440\u043D\u044B\u043C\u0438 \u043A\u0440\u0443\u0433\u0430\u043C\u0438)
    \u2014 \u043F\u043E\u043B\u044F\u0440\u043D\u0430\u044F \u043D\u043E\u0447\u044C.
    *   **\u041C\u0435\u0440\u0438\u0434\u0438\u0430\u043D\u044B:** \u041E\u043D
    \u0432\u044B\u0431\u0440\u0430\u043B \u043D\u0443\u043B\u0435\u0432\u043E\u0439
    \u043C\u0435\u0440\u0438\u0434\u0438\u0430\u043D, \u043F\u0440\u043E\u0445\u043E\u0434\u044F\u0449\u0438\u0439
    \u0447\u0435\u0440\u0435\u0437 \u043E\u0441\u0442\u0440\u043E\u0432 \u0420\u043E\u0434\u043E\u0441
    (\u0432\u0430\u0436\u043D\u044B\u0439 \u043D\u0430\u0432\u0438\u0433\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439
    \u0443\u0437\u0435\u043B), \u0438 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0438\u0437\u043C\u0435\u0440\u044F\u0442\u044C \u0434\u043E\u043B\u0433\u043E\u0442\u0443,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u0440\u0430\u0437\u043D\u0438\u0446\u0443
    \u0432\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0445
    \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u0439 (\u0445\u043E\u0442\u044F \u0434\u043B\u044F
    \u0442\u043E\u0447\u043D\u044B\u0445 \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0439
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u044D\u0442\u043E
    \u0431\u044B\u043B\u043E \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438
    \u0441\u043B\u043E\u0436\u043D\u043E, \u0438\u0434\u0435\u044F \u0441\u0442\u0430\u043B\u0430
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C \u0431\u0443\u0434\u0443\u0449\u0435\u0439
    \u0445\u0440\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0438).  ---  ###
    3. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430: \u041E\u0442
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u0438 \u043A \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0443
    (\u0418\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0438)  \u0417\u0434\u0435\u0441\u044C
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0432 \u0442\u043E\u043C,
    \u043A\u0430\u043A \u043C\u044B \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u043C
    \u0441 \u0447\u0438\u0441\u043B\u0430\u043C\u0438.  *   **\xAB\u0420\u0435\u0448\u0435\u0442\u043E
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430\xBB (\u0422\u0435\u043E\u0440\u0438\u044F
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432):** \u042D\u0442\u043E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u043F\u043E\u0441\u043E\u0431
    \u043D\u0430\u0439\u0442\u0438 \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u0447\u0438\u0441\u043B\u0430.
    \u042D\u0442\u043E **\u043F\u0435\u0440\u0432\u044B\u0439 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0430 \u0437\u0430\u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C \xAB\u043E\u0442\u0441\u0435\u0432\u0430\xBB**
    (sieve algorithm). \u0412 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0435
    \u044D\u0442\u043E\u0442 \u043F\u0440\u0438\u043D\u0446\u0438\u043F (\u043F\u0435\u0440\u0435\u0431\u043E\u0440
    \u0441 \u0443\u0434\u0430\u043B\u0435\u043D\u0438\u0435\u043C \u043B\u0438\u0448\u043D\u0435\u0433\u043E)
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440.     *   *\u0422\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0434\u0435\u0442\u0430\u043B\u044C:* \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u0434\u043E\u0448\u0435\u043B \u0432 \u0441\u0432\u043E\u0438\u0445 \u0442\u0430\u0431\u043B\u0438\u0446\u0430\u0445
    \u043D\u0435 \u0434\u043E 100 \u0438\u043B\u0438 1000, \u0430 \u0434\u043E **100
    000**. \u042D\u0442\u043E \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u044B\u0439
    \u043E\u0431\u044A\u0435\u043C \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439
    \u0434\u043B\u044F \u0440\u0443\u0447\u043D\u043E\u0433\u043E \u0442\u0440\u0443\u0434\u0430.
    \u0412\u0430\u0436\u043D\u043E, \u0447\u0442\u043E \u043E\u043D \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0430\u0448\u0435\u043B \u0447\u0438\u0441\u043B\u0430,
    \u0430 \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0434\u043B\u044F
    \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438 \u0447\u0438\u0441\u043B\u0430
    `N` \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u0443 \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u0434\u0435\u043B\u0438\u0442\u044C \u0435\u0433\u043E \u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u0447\u0438\u0441\u043B\u0430,
    \u043D\u0435 \u043F\u0440\u0435\u0432\u043E\u0441\u0445\u043E\u0434\u044F\u0449\u0438\u0435
    \u221AN. \u042D\u0442\u043E \u0440\u0435\u0437\u043A\u043E \u0441\u043E\u043A\u0440\u0430\u0449\u0430\u043B\u043E
    \u0442\u0440\u0443\u0434\u043E\u0437\u0430\u0442\u0440\u0430\u0442\u044B \u0438
    \u0431\u044B\u043B\u043E \u043F\u0435\u0440\u0432\u044B\u043C \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435\u043C
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B \u043A \u043E\u043F\u0442\u0438\u043C\u0438\u0437\u0430\u0446\u0438\u0438
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439.  *   **\u041C\u0435\u0437\u043E\u043B\u044F\u0431\u0438\u0439
    (\u0420\u0435\u0448\u0435\u043D\u0438\u0435 \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439):** \u0417\u0430\u0434\u0430\u0447\u0430
    \u043E\u0431 \u0443\u0434\u0432\u043E\u0435\u043D\u0438\u0438 \u043A\u0443\u0431\u0430
    \u0437\u0432\u0443\u0447\u0438\u0442 \u043A\u0430\u043A `x\xB3 = 2a\xB3`. \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u0441\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043B
    \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u043F\u0440\u0438\u0431\u043E\u0440
    \u0438\u0437 \u0442\u0440\u0435\u0445 \u043F\u043E\u0434\u0432\u0438\u0436\u043D\u044B\u0445
    \u043F\u0440\u044F\u043C\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u0445
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432,
    \u0434\u0432\u0438\u0433\u0430\u044E\u0449\u0438\u0445\u0441\u044F \u043F\u043E
    \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u043C \u043F\u0430\u0437\u0430\u043C.
    \u042D\u0442\u043E\u0442 \u043F\u0440\u0438\u0431\u043E\u0440 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B
    \u043D\u0430\u0439\u0442\u0438 \u0434\u0432\u0435 \u0441\u0440\u0435\u0434\u043D\u0438\u0435
    \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u043C\u0435\u0436\u0434\u0443 \u043E\u0442\u0440\u0435\u0437\u043A\u0430\u043C\u0438.
    \u041F\u043E \u0441\u0443\u0442\u0438, \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    **\u0430\u043D\u0430\u043B\u043E\u0433\u043E\u0432\u044B\u0439 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440**,
    \u0440\u0435\u0448\u0430\u044E\u0449\u0438\u0439 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u0442\u0440\u0435\u0442\u044C\u0435\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u0441\u043F\u043E\u0441\u043E\u0431\u043E\u043C.
    \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437
    \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043B\u0438\u043D\u0435\u0435\u043A \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u0442\u043E\u0440\u043E\u0432. 
    ---  ### 4. \u0425\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044F: \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043E\u0441\u0438 (\u0418\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u043A\u0430)  \u0414\u043E \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430
    \u0434\u0430\u0442\u0438\u0440\u043E\u0432\u043A\u0430 \u0441\u043E\u0431\u044B\u0442\u0438\u0439
    \u0431\u044B\u043B\u0430 \u0445\u0430\u043E\u0442\u0438\u0447\u043D\u043E\u0439:
    \xAB\u0432 \u0433\u043E\u0434 \u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0442\u0430\u043A\u043E\u0433\u043E-\u0442\u043E \u0446\u0430\u0440\u044F\xBB
    \u0438\u043B\u0438 \xAB\u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0442\u0430\u043A\u043E\u0439-\u0442\u043E
    \u041E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u044B\xBB. \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u0441\u043E\u0437\u0434\u0430\u043B **\u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u0443\u044E
    \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044E**.  *   **\u041E\u043B\u0438\u043C\u043F\u0438\u0439\u0441\u043A\u0430\u044F
    \u044D\u0440\u0430:** \u041E\u043D \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B
    **\xAB\u041E\u043B\u0438\u043C\u043F\u0438\u0439\u0441\u043A\u0438\u0435 \u043F\u043E\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u0438\xBB**
    \u2014 \u0441\u043F\u0438\u0441\u043E\u043A, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0441\u0438\u043D\u0445\u0440\u043E\u043D\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0432\u0441\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435 \u0435\u043C\u0443
    \u0441\u043E\u0431\u044B\u0442\u0438\u044F (\u043E\u0442 \u0422\u0440\u043E\u044F\u043D\u0441\u043A\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u0434\u043E \u043F\u043E\u0445\u043E\u0434\u043E\u0432
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0430) \u0441 \u0433\u043E\u0434\u0430\u043C\u0438
    \u041E\u043B\u0438\u043C\u043F\u0438\u0430\u0434. *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0430 \u043C\u0438\u0444\u043E\u0432:**
    \u041E\u043D \u043D\u0435 \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B
    \u043C\u0438\u0444\u044B \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E.
    \u041E\u043D \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043F\u0435\u0440\u0435\u0432\u0435\u0441\u0442\u0438
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u0435 \u0434\u0430\u0442\u044B
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u0438\u0435
    \u0422\u0440\u043E\u0438) \u0432 \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0434\u0430\u0442\u044B,
    \u0432\u044B\u0447\u0438\u0442\u0430\u044F \xAB\u0441\u0440\u0435\u0434\u043D\u044E\u044E
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0436\u0438\u0437\u043D\u0438 \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0439\xBB
    (\u043E\u043D \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B \u0435\u0451 \u0437\u0430
    40 \u043B\u0435\u0442) \u0438\u0437 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0434\u0430\u0442 \u043F\u043E\u0437\u0434\u043D\u0435\u0439 \u0438\u0441\u0442\u043E\u0440\u0438\u0438.
    \u0422\u0430\u043A \u043E\u043D \u0432\u044B\u0432\u0435\u043B \u0434\u0430\u0442\u0443
    \u043F\u0430\u0434\u0435\u043D\u0438\u044F \u0422\u0440\u043E\u0438 \u2014 **1184
    \u0433\u043E\u0434 \u0434\u043E \u043D. \u044D.** \u0423\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043D\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
    \u0430\u0440\u0445\u0435\u043E\u043B\u043E\u0433\u0438 (\u0428\u043B\u0438\u043C\u0430\u043D
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0435) \u0434\u0430\u0442\u0438\u0440\u0443\u044E\u0442
    \u0422\u0440\u043E\u044E VIIa \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E
    1190\u20131180 \u0433\u043E\u0434\u0430\u043C\u0438 \u0434\u043E \u043D. \u044D.
    \u041E\u0448\u0438\u0431\u043A\u0430 \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430
    \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430 \u043C\u0435\u043D\u044C\u0448\u0435
    \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F!  ---  ###
    5. \u0424\u0438\u043B\u043E\u043B\u043E\u0433\u0438\u044F \u0438 \u043A\u0440\u0438\u0442\u0438\u043A\u0430
    \u0442\u0435\u043A\u0441\u0442\u0430 (\u0413\u0443\u043C\u0430\u043D\u0438\u0442\u0430\u0440\u043D\u044B\u0435
    \u043D\u0430\u0443\u043A\u0438)  \u041D\u0430 \u043F\u043E\u0441\u0442\u0443
    \u0433\u043B\u0430\u0432\u044B \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0438 \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B \u0441\u0435\u0431\u044F \u043A\u0430\u043A
    \u0441\u0442\u0440\u043E\u0433\u0438\u0439 \u043A\u0440\u0438\u0442\u0438\u043A. 
    *   **\u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F \u043F\u0440\u043E\u0442\u0438\u0432
    \u043F\u043E\u044D\u0437\u0438\u0438:** \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u0441\u0432\u043E\u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044F
    \u041A\u0430\u043B\u043B\u0438\u043C\u0430\u0445\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0438\u0441\u043A\u0430\u043B \u043A\u0440\u0430\u0441\u043E\u0442\u0443, \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u0437\u0430\u044F\u0432\u043B\u044F\u043B, \u0447\u0442\u043E *\xAB\u043F\u043E\u044D\u0442
    \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u0442\u044C \u043F\u0440\u0435\u0436\u0434\u0435
    \u0432\u0441\u0435\u0433\u043E \u0437\u043D\u0430\u044E\u0449\u0438\u043C\xBB*.
    \u041E\u043D \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B \u0413\u043E\u043C\u0435\u0440\u0430
    \u0437\u0430 \u0442\u043E, \u0447\u0442\u043E \u0442\u043E\u0442 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0435 \u043F\u0440\u0438\u0440\u043E\u0434\u043D\u044B\u0435
    \u044F\u0432\u043B\u0435\u043D\u0438\u044F. *   **\u0410\u0442\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043A\u043E\u043C\u0435\u0434\u0438\u044F:** \u041E\u043D \u0438\u0437\u0434\u0430\u043B
    \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0438\u0437\u0434\u0430\u043D\u0438\u0435 \u0430\u0442\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u043E\u043C\u0435\u0434\u0438\u043E\u0433\u0440\u0430\u0444\u043E\u0432
    (\u0410\u0440\u0438\u0441\u0442\u043E\u0444\u0430\u043D\u0430 \u0438 \u0434\u0440.),
    \u0440\u0430\u0441\u0441\u0442\u0430\u0432\u0438\u0432 \u0437\u043D\u0430\u043A\u0438
    \u0443\u0434\u0430\u0440\u0435\u043D\u0438\u0439 \u0438 \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0432
    \u0442\u0435\u043A\u0441\u0442 \u043D\u0430 \u0441\u0442\u0440\u043E\u043A\u0438.
    \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u0439 \u043E\u043F\u044B\u0442
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    (\u043D\u0435 \u0441\u0446\u0435\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E)
    \u0442\u0435\u043A\u0441\u0442\u0430. *   **\xAB\u041E \u0434\u0440\u0435\u0432\u043D\u0435\u0439
    \u043A\u043E\u043C\u0435\u0434\u0438\u0438\xBB:** \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442 \u0432 12 \u043A\u043D\u0438\u0433\u0430\u0445,
    \u0433\u0434\u0435 \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B, \u0447\u0442\u043E
    \u043A\u043E\u043C\u0435\u0434\u0438\u0438 \u043C\u0435\u043D\u044F\u043B\u0438\u0441\u044C
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0441\u0442\u0440\u043E\u0435\u043C \u0410\u0444\u0438\u043D. \u042D\u0442\u043E
    \u0431\u044B\u043B\u043E \u0437\u0430\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    **\u0441\u043E\u0446\u0438\u043E\u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u043A\u0438**
    \u2014 \u0438\u0434\u0435\u0438, \u0447\u0442\u043E \u044F\u0437\u044B\u043A
    \u0438 \u0436\u0430\u043D\u0440 \u0437\u0430\u0432\u0438\u0441\u044F\u0442 \u043E\u0442
    \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043A\u043E\u043D\u0442\u0435\u043A\u0441\u0442\u0430. 
    ---  ### 6. \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F: \u041A\u0430\u043B\u0438\u0431\u0440\u043E\u0432\u043A\u0430
    \u043D\u0435\u0431\u0430  *   **\u041A\u0430\u0442\u0430\u0441\u0442\u0435\u0440\u0438\u0437\u043C\u044B
    (\u03A0\u03B5\u03C1\u03AF \u03BA\u03B1\u03C4\u03B1\u03C3\u03C4\u03B5\u03C1\u03B9\u03C3\u03BC\u1FF6\u03BD):**
    \u042D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u0431\u043E\u0440\u043D\u0438\u043A
    \u043C\u0438\u0444\u043E\u0432 \u043E \u0441\u043E\u0437\u0432\u0435\u0437\u0434\u0438\u044F\u0445.
    \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u0432\u043A\u043B\u044E\u0447\u0430\u043B\u0430
    \u0432 \u0441\u0435\u0431\u044F **\u0437\u0432\u0435\u0437\u0434\u043D\u044B\u0439
    \u043A\u0430\u0442\u0430\u043B\u043E\u0433**, \u0433\u0434\u0435 \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0437\u0432\u0435\u0437\u0434 \u0438 \u0438\u0445 \u044F\u0440\u043A\u043E\u0441\u0442\u044C.
    \u0425\u043E\u0442\u044F \u0434\u043E \u043D\u0430\u0441 \u0434\u043E\u0448\u0435\u043B
    \u043B\u0438\u0448\u044C \u043C\u0438\u0444\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0435\u0441\u043A\u0430\u0437 \u0413\u0438\u0433\u0438\u043D\u0430,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u0447\u0442\u043E \u0432 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u0435
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u0434\u0430\u0432\u0430\u043B
    **\u044D\u043A\u0432\u0430\u0442\u043E\u0440\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B** \u0437\u0432\u0435\u0437\u0434
    \u0438 \u043E\u0442\u043C\u0435\u0447\u0430\u043B \u0438\u0445 \u0446\u0432\u0435\u0442
    (\u043A\u0440\u0430\u0441\u043D\u044B\u0435, \u0436\u0435\u043B\u0442\u044B\u0435,
    \u0431\u0435\u043B\u044B\u0435). *   **\u0422\u0440\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0433\u043E\u0434:** \u041E\u043D \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0433\u043E\u0434\u0430 \u0432 **365 \u0434\u043D\u0435\u0439 \u0438 6 \u0447\u0430\u0441\u043E\u0432**
    (\u0442\u043E\u0447\u043D\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u2014 365 \u0434\u043D\u0435\u0439 5 \u0447\u0430\u0441\u043E\u0432 48 \u043C\u0438\u043D\u0443\u0442).
    \u0418 \u0445\u043E\u0442\u044F \u043E\u043D \u043E\u0448\u0438\u0431\u0441\u044F
    \u043D\u0430 12 \u043C\u0438\u043D\u0443\u0442, \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C **\u0432\u0438\u0441\u043E\u043A\u043E\u0441\u043D\u044B\u0439
    \u0434\u0435\u043D\u044C** (\u043A\u0430\u0436\u0434\u044B\u0435 4 \u0433\u043E\u0434\u0430),
    \u0447\u0435\u043C \u043D\u0430 100 \u043B\u0435\u0442 \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B
    \u044E\u043B\u0438\u0430\u043D\u0441\u043A\u0438\u0439 \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044C. 
    ### \u0418\u0442\u043E\u0433: \u0427\u0442\u043E \u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B
    \u0441 \u043D\u0430\u0443\u043A\u043E\u0439?  \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B **\u043F\u0435\u0440\u0435\u0445\u043E\u0434
    \u043E\u0442 \u043D\u0430\u043A\u043E\u043F\u043B\u0435\u043D\u0438\u044F \u0444\u0430\u043A\u0442\u043E\u0432
    (\u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0435 \u0441\u043E\u0437\u0435\u0440\u0446\u0430\u043D\u0438\u0435)
    \u043A \u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u043C\u043E\u0434\u0435\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E
    (\u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u0430\u044F \u043D\u0430\u0443\u043A\u0430)**.
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043C\u043E\u0436\u043D\u043E
    \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u044C \u0442\u043E, \u0447\u0442\u043E
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u043F\u043E\u0442\u0440\u043E\u0433\u0430\u0442\u044C,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u0438 \u043B\u043E\u0433\u0438\u043A\u0443.  \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u2014 \u043D\u0435
    \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0435 \u0446\u0438\u0444\u0440\u044B
    (\u043E\u043D\u0438 \u0431\u044B\u043B\u0438 \u043F\u0440\u0438\u0431\u043B\u0438\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u044B),
    \u0430 **\u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u0430\u044F
    \u043F\u043E\u0437\u043D\u0430\u0432\u0430\u0435\u043C\u0430**. \u041E\u043D
    \u0432\u0432\u0435\u043B \u043F\u0440\u0438\u043D\u0446\u0438\u043F, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    **\u0432\u0435\u0440\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0435\u0439**:
    \u0435\u0441\u043B\u0438 \u0442\u0432\u043E\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043C\u043E\u0434\u0435\u043B\u044C \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u0443\u0433\u043E\u043B \u0442\u0435\u043D\u0438 \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438
    \u0438 \u0434\u043B\u0438\u043D\u0443 \u0434\u043D\u044F \u0432 \u0421\u0438\u0435\u043D\u0435,
    \u0437\u043D\u0430\u0447\u0438\u0442, \u043C\u043E\u0434\u0435\u043B\u044C \u0432\u0435\u0440\u043D\u0430,
    \u0438 \u0417\u0435\u043C\u043B\u044F \u2014 \u0448\u0430\u0440. \u0418\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u043E\u0442 \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0441\u0434\u0435\u043B\u0430\u043B
    \u0435\u0433\u043E \xAB\u043E\u0442\u0446\u043E\u043C\xBB \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0438, \u043D\u043E \u0438 \u0432\u0441\u0435\u0433\u043E
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u043E\u0437\u043D\u0430\u043D\u0438\u044F."
  achievementsEn: 
  personalLifeRu: "\u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442
    \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439,
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0441\u044C \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u0445\u0443\u0436\u0435. \u041E\u043D\u0430
    \u043D\u0435 \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u0433\u0440\u043E\u043C\u043A\u0438\u043C\u0438 \u0440\u043E\u043C\u0430\u043D\u0430\u043C\u0438
    \u0438\u043B\u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0438\u043D\u0442\u0440\u0438\u0433\u0430\u043C\u0438, \u043D\u043E \u0432 \u043D\u0435\u0439
    \u0435\u0441\u0442\u044C \u0441\u0432\u043E\u0438 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u043E\u043C\u0435\u043D\u0442\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u0440\u0438\u043E\u0442\u043A\u0440\u044B\u0432\u0430\u044E\u0442 \u0437\u0430\u0432\u0435\u0441\u0443
    \u043D\u0430\u0434 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C
    \u044D\u0442\u043E\u0433\u043E \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E.  ### \U0001F3DB\uFE0F \u0421\u0435\u043C\u044C\u044F
    \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435 
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u043E\u043A\u043E\u043B\u043E **276 \u0433\u043E\u0434\u0430 \u0434\u043E \u043D.
    \u044D.** \u0432 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0439 \u043A\u043E\u043B\u043E\u043D\u0438\u0438
    **\u041A\u0438\u0440\u0435\u043D\u0430** (\u043D\u0430 \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u0438
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u041B\u0438\u0432\u0438\u0438).
    \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u0447\u0442\u043E \u0435\u0433\u043E
    \u043E\u0442\u0446\u0430 \u0437\u0432\u0430\u043B\u0438 **\u0410\u0433\u043B\u0430\u043E\u0441**.
    \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u043C, \u0435\u0433\u043E
    \u0441\u0435\u043C\u044C\u044F \u043D\u0435 \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u043B\u0430
    \u043A \u0437\u043D\u0430\u0442\u043D\u043E\u043C\u0443 \u0440\u043E\u0434\u0443,
    \u043E \u0447\u0435\u043C \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u0440\u0435\u0434\u043A\u043E\u0441\u0442\u044C
    \u0438\u0445 \u0438\u043C\u0435\u043D. \u041E\u0434\u043D\u0430\u043A\u043E \u0434\u0440\u0443\u0433\u0438\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0438
    \u0441\u0447\u0438\u0442\u0430\u044E\u0442, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0438\u043C\u044F, \u043E\u0437\u043D\u0430\u0447\u0430\u044E\u0449\u0435\u0435
    \"\u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u0430\u044F \u0441\u0438\u043B\u0430\",
    \u043C\u043E\u0436\u0435\u0442 \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u043D\u0430 \u0431\u043B\u0430\u0433\u043E\u0440\u043E\u0434\u043D\u043E\u0435
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435,
    \u043A\u0430\u043A \u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0441 \u0440\u0430\u043D\u043D\u0438\u0445 \u043B\u0435\u0442.  \u0411\u0443\u0434\u0443\u0449\u0438\u0439
    \u0443\u0447\u0435\u043D\u044B\u0439 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0435\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435: \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438 \u0443
    \u0441\u0432\u043E\u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E
    \u0437\u0435\u043C\u043B\u044F\u043A\u0430, \u043F\u043E\u044D\u0442\u0430 \u0438
    \u043A\u0440\u0438\u0442\u0438\u043A\u0430 \u041A\u0430\u043B\u043B\u0438\u043C\u0430\u0445\u0430,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0432 \u0410\u0444\u0438\u043D\u0430\u0445,
    \u0433\u0434\u0435 \u043E\u043D \u043F\u043E\u0441\u0435\u0449\u0430\u043B \u0437\u0430\u043D\u044F\u0442\u0438\u044F
    \u0432 \u043F\u043B\u0430\u0442\u043E\u043D\u043E\u0432\u0441\u043A\u043E\u0439
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438. \u0412\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043E\u043D \u0442\u0430\u043A \u043F\u0440\u043E\u043D\u0438\u043A\u0441\u044F
    \u0438\u0434\u0435\u044F\u043C\u0438 \u041F\u043B\u0430\u0442\u043E\u043D\u0430,
    \u0447\u0442\u043E \u0441 \u0433\u043E\u0440\u0434\u043E\u0441\u0442\u044C\u044E
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0441\u0435\u0431\u044F \"\u043F\u043B\u0430\u0442\u043E\u043D\u0438\u043A\u043E\u043C\". 
    ### \U0001F4DA \u0416\u0438\u0437\u043D\u044C, \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0430\u044F
    \u0437\u043D\u0430\u043D\u0438\u044F\u043C  \u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u043C
    \u0441\u043E\u0431\u044B\u0442\u0438\u0435\u043C \u0432 \u0436\u0438\u0437\u043D\u0438
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430 \u0441\u0442\u0430\u043B\u043E
    \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435 \u043E\u043A\u043E\u043B\u043E
    **245 \u0433\u043E\u0434\u0430 \u0434\u043E \u043D. \u044D.** \u043E\u0442 \u0435\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u043E\u0433\u043E
    \u0446\u0430\u0440\u044F \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F III
    \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u0442\u044C \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0443\u044E
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0443. \u041E\u043D \u043F\u0440\u0438\u043D\u044F\u043B
    \u044D\u0442\u043E \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u044E,
    \u0433\u0434\u0435 \u043F\u0440\u043E\u0432\u0435\u043B \u0432\u0441\u044E \u043E\u0441\u0442\u0430\u0432\u0448\u0443\u044E\u0441\u044F
    \u0436\u0438\u0437\u043D\u044C.  \u041D\u0430 \u043F\u043E\u0441\u0442\u0443
    \u0433\u043B\u0430\u0432\u044B \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0438
    \u043E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u043B
    \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u043C \u043A\u043D\u0438\u0436\u043D\u044B\u043C
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435\u043C \u0434\u0440\u0435\u0432\u043D\u043E\u0441\u0442\u0438,
    \u043D\u043E \u0438 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u043B \u043E\u0431\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u0438
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u0430 \u0434\u043B\u044F
    \u0434\u0435\u0442\u0435\u0439 \u043C\u043E\u043D\u0430\u0440\u0445\u0430. \u041E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432
    \u0431\u044B\u043B **\u0431\u0443\u0434\u0443\u0449\u0438\u0439 \u0446\u0430\u0440\u044C
    \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439 IV \u0424\u0438\u043B\u043E\u043F\u0430\u0442\u043E\u0440**
    \u0438 \u0435\u0433\u043E \u0441\u0435\u0441\u0442\u0440\u0430 \u0410\u0440\u0441\u0438\u043D\u043E\u044F.
    \u042D\u0442\u043E \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u043E \u0432\u044B\u0441\u043E\u043A\u043E\u043C \u0434\u043E\u0432\u0435\u0440\u0438\u0438
    \u0441\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u044B \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u0435\u0439
    \u0415\u0433\u0438\u043F\u0442\u0430. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430
    \u0432 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0435 \u0431\u044B\u043B\u0430
    \u043F\u043E-\u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u043C\u0443 \u0432\u0441\u0435\u043F\u043E\u0433\u043B\u043E\u0449\u0430\u044E\u0449\u0435\u0439:
    \u043E\u043D \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u043F\u0440\u0438\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435\u043C
    \u0438 \u043A\u043E\u043F\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043A\u043D\u0438\u0433, \u0441\u0442\u0440\u0435\u043C\u044F\u0441\u044C \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435 \u043B\u0443\u0447\u0448\u0438\u043C
    \u0432 \u043C\u0438\u0440\u0435.  ### \U0001F91D \u0414\u0440\u0443\u0436\u0431\u0430
    \u0441 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u043E\u043C  \u041E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0445 \u044F\u0440\u043A\u0438\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430, \u0434\u043E\u0448\u0435\u0434\u0448\u0438\u0445
    \u0434\u043E \u043D\u0430\u0441, \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0435\u0433\u043E **\u0434\u0440\u0443\u0436\u0431\u0430 \u0438 \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0441 \u0432\u0435\u043B\u0438\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u0435\u043C
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u043E\u043C**. \u041E\u043D\u0438
    \u043E\u0431\u043C\u0435\u043D\u0438\u0432\u0430\u043B\u0438\u0441\u044C \u0438\u0434\u0435\u044F\u043C\u0438
    \u0438 \u0442\u0440\u0443\u0434\u0430\u043C\u0438. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0443 \u0441\u0432\u043E\u0439
    \u0432\u0430\u0436\u043D\u044B\u0439 \u0442\u0440\u0430\u043A\u0442\u0430\u0442
    \xAB\u041C\u0435\u0442\u043E\u0434 \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0435\u043E\u0440\u0435\u043C\xBB \u0438 \u043F\u043E\u0441\u044B\u043B\u0430\u043B
    \u0435\u043C\u0443 \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438,
    \u0442\u0430\u043A\u0438\u0435 \u043A\u0430\u043A \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \xAB\u0417\u0430\u0434\u0430\u0447\u0430 \u043E \u0431\u044B\u043A\u0430\u0445\xBB.
    \u042D\u0442\u0430 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442,
    \u0447\u0442\u043E \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u0431\u044B\u043B
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439
    \u044D\u043B\u0438\u0442\u044B \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. 
    ### \U0001F948 \u041F\u0440\u043E\u0437\u0432\u0438\u0449\u0430 \xAB\u0411\u0435\u0442\u0430\xBB
    \u0438 \xAB\u041F\u0435\u043D\u0442\u0430\u0442\u043B\xBB  \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0439
    \u0432\u0437\u0433\u043B\u044F\u0434 \u043D\u0430 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0434\u0430\u044E\u0442 \u0435\u0433\u043E
    \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0430. \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438,
    \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u044F \u0435\u0433\u043E \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u044D\u0440\u0443\u0434\u0438\u0446\u0438\u044E, \u0434\u0430\u043B\u0438 \u0435\u043C\u0443
    \u0434\u0432\u0430 \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0430 :  *   **\xAB\u041F\u0435\u043D\u0442\u0430\u0442\u043B\xBB
    (\u03A0\u03AD\u03BD\u03C4\u03B1\u03B8\u03BB\u03BF\u03C2)** \u2014 \u043F\u044F\u0442\u0438\u0431\u043E\u0440\u0435\u0446.
    \u042D\u0442\u043E \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435 \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u0438\u0432\u0430\u043B\u043E
    \u0435\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C \u0431\u043B\u0438\u0441\u0442\u0430\u0442\u044C
    \u0432\u043E \u043C\u043D\u043E\u0433\u0438\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445
    \u0437\u043D\u0430\u043D\u0438\u0439. *   **\xAB\u0411\u0435\u0442\u0430\xBB
    (\u0392\u1FC6\u03C4\u03B1)** \u2014 \u0432\u0442\u043E\u0440\u0430\u044F \u0431\u0443\u043A\u0432\u0430
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0430\u043B\u0444\u0430\u0432\u0438\u0442\u0430.
    \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E \u044D\u0442\u043E
    \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u043D\u0435 \u043B\u0438\u0448\u0435\u043D\u043D\u043E\u0435 \u043B\u0435\u0433\u043A\u043E\u0439
    \u0438\u0440\u043E\u043D\u0438\u0438, \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u043E
    \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u043C \u0432\u043E
    \u0432\u0441\u0435\u043C, \u0432 \u043A\u0430\u0436\u0434\u043E\u0439 \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E\u0439
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0435 \u043E\u043D \u0432\u0441\u0435
    \u0436\u0435 \u0443\u0441\u0442\u0443\u043F\u0430\u043B \u043F\u0435\u0440\u0432\u0435\u043D\u0441\u0442\u0432\u043E
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043D\u044B\u043C \"\u0430\u043B\u044C\u0444\u0430\u043C\",
    \u0432\u0440\u043E\u0434\u0435 \u0442\u043E\u0433\u043E \u0436\u0435 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. \u0422\u0435\u043C
    \u043D\u0435 \u043C\u0435\u043D\u0435\u0435, \u043D\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u0435\u0433\u043E \u043F\u0440\u043E\u0441\u0442\u043E \xAB\u0432\u0442\u043E\u0440\u044B\u043C\xBB
    \u0431\u044B\u043B\u043E \u0431\u044B \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u043D\u043E.  ### \U0001F305 \u0421\u0442\u0430\u0440\u043E\u0441\u0442\u044C
    \u0438 \u0434\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u044B\u0439
    \u0443\u0445\u043E\u0434 \u0438\u0437 \u0436\u0438\u0437\u043D\u0438  \u0421\u0430\u043C\u0430\u044F
    \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u0430\u044F \u0438 \u0445\u043E\u0440\u043E\u0448\u043E
    \u0437\u0430\u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u0434\u0435\u0442\u0430\u043B\u044C \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u2014 \u044D\u0442\u043E \u0435\u0435 \u0444\u0438\u043D\u0430\u043B.
    \u0412 \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0438 \u0443 \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430
    **\u0432\u043E\u0441\u043F\u0430\u043B\u0438\u043B\u0438\u0441\u044C \u0433\u043B\u0430\u0437\u0430,
    \u0447\u0442\u043E \u0432 \u0438\u0442\u043E\u0433\u0435 \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u043A \u043F\u043E\u043B\u043D\u043E\u0439 \u0441\u043B\u0435\u043F\u043E\u0442\u0435**.
    \u0414\u043B\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u0432\u0441\u044F
    \u0436\u0438\u0437\u043D\u044C \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u0447\u0442\u0435\u043D\u0438\u044E \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0435\u0439,
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E \u0437\u0432\u0435\u0437\u0434
    \u0438 \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044E \u0437\u0430
    \u043F\u0440\u0438\u0440\u043E\u0434\u043E\u0439, \u043F\u043E\u0442\u0435\u0440\u044F
    \u0437\u0440\u0435\u043D\u0438\u044F \u0441\u0442\u0430\u043B\u0430 \u043D\u0435\u0432\u044B\u043D\u043E\u0441\u0438\u043C\u044B\u043C
    \u0443\u0434\u0430\u0440\u043E\u043C.  \u041D\u0435 \u0436\u0435\u043B\u0430\u044F
    \u043C\u0438\u0440\u0438\u0442\u044C\u0441\u044F \u0441 \u0431\u0435\u0441\u043F\u043E\u043C\u043E\u0449\u043D\u043E\u0441\u0442\u044C\u044E
    \u0438 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C\u044E
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F \u043B\u044E\u0431\u0438\u043C\u044B\u043C
    \u0434\u0435\u043B\u043E\u043C, \u0432 **194 \u0433\u043E\u0434\u0443 \u0434\u043E
    \u043D. \u044D.**, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u043E\u043A\u043E\u043B\u043E
    82 \u043B\u0435\u0442, \u043E\u043D **\u0434\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u043E
    \u0443\u043C\u043E\u0440\u0438\u043B \u0441\u0435\u0431\u044F \u0433\u043E\u043B\u043E\u0434\u043E\u043C**.
    \u042D\u0442\u043E\u0442 \u043F\u043E\u0441\u0442\u0443\u043F\u043E\u043A \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443\u0435\u0442
    \u043E \u0435\u0433\u043E \u0441\u0438\u043B\u044C\u043D\u043E\u043C \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0435
    \u0438 \u043F\u0440\u0435\u0434\u0430\u043D\u043D\u043E\u0441\u0442\u0438 \u0441\u0432\u043E\u0435\u0439
    \u0441\u0442\u0440\u0430\u0441\u0442\u0438 \u2014 \u0437\u043D\u0430\u043D\u0438\u044E. 
    \u0427\u0442\u043E \u043A\u0430\u0441\u0430\u0435\u0442\u0441\u044F \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0433\u043E
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F, \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442
    \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F, \u0447\u0442\u043E \u043E\u043D
    \u0442\u0430\u043A \u0438 **\u043D\u0435 \u0436\u0435\u043D\u0438\u043B\u0441\u044F**,
    \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0442\u044F \u043D\u0430\u0443\u043A\u0443
    \u0438 \u043F\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0438
    \u043C\u0438\u0440\u0430 \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438. 
    \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u0441\u0435\u0446\u0435\u043B\u043E
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B \u0441\u0435\u0431\u044F \u0441\u043B\u0443\u0436\u0435\u043D\u0438\u044E
    \u0437\u043D\u0430\u043D\u0438\u044F\u043C, \u0434\u043E\u0441\u0442\u0438\u0433
    \u0432 \u044D\u0442\u043E\u043C \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u0432\u044B\u0441\u043E\u0442, \u0431\u044B\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u043D
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438, \u043D\u043E \u0432 \u0438\u0442\u043E\u0433\u0435
    \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F \u0441 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u043B\u0430 \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439
    \u0435\u0433\u043E \u0434\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u043E\u0439
    \u0441\u043C\u0435\u0440\u0442\u0438."
  personalLifeEn: 
  shortBioRu: "\u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u041A\u0438\u0440\u0435\u043D\u0441\u043A\u0438\u0439
    \u2014 \u044D\u0442\u043E \u043E\u0434\u0438\u043D \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0443\u0447\u0451\u043D\u044B\u0445 \u0410\u043D\u0442\u0438\u0447\u043D\u043E\u0441\u0442\u0438,
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u0447\u044C\u0438 \u043F\u043E\u0437\u043D\u0430\u043D\u0438\u044F
    \u0431\u044B\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0431\u0448\u0438\u0440\u043D\u044B, \u0447\u0442\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u043F\u0440\u043E\u0437\u0432\u0430\u043B\u0438 \u0435\u0433\u043E **\u041F\u0435\u043D\u0442\u0430\u0442\u043B\u043E\u043C**
    (\u041C\u043D\u043E\u0433\u043E\u0431\u043E\u0440\u0446\u0435\u043C), \u0430
    \u043F\u043E\u0437\u0434\u043D\u0438\u0435 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0438
    \u2014 \xAB\u043E\u0442\u0446\u043E\u043C \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0438\xBB.
    \u041E\u043D \u0431\u044B\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C, \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u043E\u043C,
    \u0444\u0438\u043B\u043E\u043B\u043E\u0433\u043E\u043C \u0438 \u043F\u043E\u044D\u0442\u043E\u043C,
    \u0438 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E
    \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E \u0431\u0435\u0437\u0433\u0440\u0430\u043D\u0438\u0447\u043D\u043E\u0439
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0439 \u043B\u044E\u0431\u043E\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438. 
    ### \U0001F4DC \u0416\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0439 \u043F\u0443\u0442\u044C:
    \u043E\u0442 \u041A\u0438\u0440\u0435\u043D\u044B \u0434\u043E \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438 
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u043E\u043A\u043E\u043B\u043E **276 \u0433\u043E\u0434\u0430 \u0434\u043E \u043D.
    \u044D.** \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 **\u041A\u0438\u0440\u0435\u043D\u0430**
    (\u043D\u0430 \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u041B\u0438\u0432\u0438\u0438) \u0432 \u0441\u0435\u043C\u044C\u0435 \u043D\u0435\u043A\u043E\u0435\u0433\u043E
    \u0410\u0433\u043B\u0430\u043E\u0441\u0430. \u041D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u043E\u043D
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438,
    \u0433\u0434\u0435 \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0431\u044B\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043F\u043E\u044D\u0442 \u0438 \u0443\u0447\u0451\u043D\u044B\u0439 **\u041A\u0430\u043B\u043B\u0438\u043C\u0430\u0445**,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0444\u0438\u043B\u043E\u0441\u043E\u0444
    \u041B\u0438\u0437\u043D\u0438\u0439. \u041D\u0435 \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u0438\u0432\u0448\u0438\u0441\u044C
    \u044D\u0442\u0438\u043C, \u044E\u043D\u044B\u0439 \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432 **\u0410\u0444\u0438\u043D\u044B**
    \u2014 \u0446\u0435\u043D\u0442\u0440 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438 \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    \u0422\u0430\u043C \u043E\u043D \u0441\u0431\u043B\u0438\u0437\u0438\u043B\u0441\u044F
    \u0441 \u043F\u043B\u0430\u0442\u043E\u043D\u043E\u0432\u0441\u043A\u043E\u0439
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0435\u0439 \u0438 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0441 \u0433\u043E\u0440\u0434\u043E\u0441\u0442\u044C\u044E \u043D\u0430\u0437\u044B\u0432\u0430\u043B
    \u0441\u0435\u0431\u044F \u043F\u043B\u0430\u0442\u043E\u043D\u0438\u043A\u043E\u043C. 
    \u041E\u043A\u043E\u043B\u043E **245 \u0433\u043E\u0434\u0430 \u0434\u043E \u043D.
    \u044D.** \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u043A\u0440\u0443\u0442\u043E
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430\u0441\u044C. \u0426\u0430\u0440\u044C
    \u0415\u0433\u0438\u043F\u0442\u0430 **\u041F\u0442\u043E\u043B\u0435\u043C\u0435\u0439
    III \u042D\u0432\u0435\u0440\u0433\u0435\u0442** \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430 \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u044E,
    \u0447\u0442\u043E\u0431\u044B \u0442\u043E\u0442 \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u043B
    **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u0443\u044E
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0443** \u2014 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0435\u0435
    \u043A\u043D\u0438\u0433\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0449\u0435
    \u0414\u0440\u0435\u0432\u043D\u0435\u0433\u043E \u043C\u0438\u0440\u0430. \u041D\u0430
    \u044D\u0442\u043E\u043C \u043F\u043E\u0441\u0442\u0443 \u043E\u043D \u0441\u043C\u0435\u043D\u0438\u043B
    \u043F\u043E\u044D\u0442\u0430 \u0410\u043F\u043E\u043B\u043B\u043E\u043D\u0438\u044F
    \u0420\u043E\u0434\u043E\u0441\u0441\u043A\u043E\u0433\u043E. \u0421\u0442\u0430\u0432
    \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0430\u0440\u0435\u043C,
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u0441\u0435\u0431\u044F \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u044E
    \u0444\u043E\u043D\u0434\u043E\u0432: \u043F\u043E \u0435\u0433\u043E \u0443\u043A\u0430\u0437\u0430\u043D\u0438\u044E
    \u0441 \u043A\u043E\u0440\u0430\u0431\u043B\u0435\u0439, \u043F\u0440\u0438\u0431\u044B\u0432\u0430\u044E\u0449\u0438\u0445
    \u0432 \u043F\u043E\u0440\u0442, \u0438\u0437\u044B\u043C\u0430\u043B\u0438 \u0432\u0441\u0435
    \u043A\u043D\u0438\u0433\u0438 \u0434\u043B\u044F \u043A\u043E\u043F\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F,
    \u0430 \u0441\u0430\u043C \u043E\u043D \u043F\u0440\u0438\u043E\u0431\u0440\u0435\u0442\u0430\u043B
    \u043F\u043E\u0434\u043B\u0438\u043D\u043D\u044B\u0435 \u0442\u0435\u043A\u0441\u0442\u044B
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0439 \u042D\u0441\u0445\u0438\u043B\u0430,
    \u0421\u043E\u0444\u043E\u043A\u043B\u0430 \u0438 \u0415\u0432\u0440\u0438\u043F\u0438\u0434\u0430.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435\u043C \u0434\u0435\u0442\u0435\u0439
    \u043C\u043E\u043D\u0430\u0440\u0445\u0430, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E \u041F\u0442\u043E\u043B\u0435\u043C\u0435\u044F
    IV.  \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u0443\u0447\u0451\u043D\u043E\u0433\u043E \u0431\u044B\u043B\u0438
    \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u044B \u0441\u043B\u0435\u043F\u043E\u0442\u043E\u0439,
    \u0438\u0437-\u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D
    \u043D\u0435 \u043C\u043E\u0433 \u043D\u0438 \u0447\u0438\u0442\u0430\u0442\u044C,
    \u043D\u0438 \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u044C \u0437\u0430
    \u043F\u0440\u0438\u0440\u043E\u0434\u043E\u0439. \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432\u0448\u0438\u043C\u0441\u044F
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C,
    \u0432 **194 \u0433\u043E\u0434\u0443 \u0434\u043E \u043D. \u044D.**, \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u043E\u043A\u043E\u043B\u043E
    82 \u043B\u0435\u0442, \u043E\u043D \u0434\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u043E
    \u0443\u043C\u043E\u0440\u0438\u043B \u0441\u0435\u0431\u044F \u0433\u043E\u043B\u043E\u0434\u043E\u043C. 
    ### \U0001F52C \u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F  \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0441\u0442\u043E\u043C.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u043B\u0438
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u0441\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435 \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F
    \u043D\u0430\u0443\u043A\u0438.  #### \U0001F30D \u0413\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u0438 \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0435 \u0417\u0435\u043C\u043B\u0438
    \u042D\u0442\u043E \u0433\u043B\u0430\u0432\u043D\u0430\u044F \u0437\u0430\u0441\u043B\u0443\u0433\u0430
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430. \u041E\u043D \u043F\u0435\u0440\u0432\u044B\u043C
    \u0432\u0432\u0435\u043B \u0432 \u043E\u0431\u0438\u0445\u043E\u0434 \u0442\u0435\u0440\u043C\u0438\u043D
    **\xAB\u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u044F\xBB** \u0438 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u0435\u0451 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u043A\u0430\u043A \u043D\u0430\u0443\u043A\u0438.  \u0421\u0430\u043C\u044B\u043C
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C
    \u0441\u0442\u0430\u043B\u043E **\u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0435
    \u0434\u043B\u0438\u043D\u044B \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u0438
    \u0417\u0435\u043C\u043B\u0438**. \u041E\u043D \u0437\u043D\u0430\u043B, \u0447\u0442\u043E
    \u0432 \u0434\u0435\u043D\u044C \u043B\u0435\u0442\u043D\u0435\u0433\u043E \u0441\u043E\u043B\u043D\u0446\u0435\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    \u0432 \u043F\u043E\u043B\u0434\u0435\u043D\u044C \u0432 \u0433\u043E\u0440\u043E\u0434\u0435
    \u0421\u0438\u0435\u043D\u0430 (\u043D\u044B\u043D\u0435 \u0410\u0441\u0443\u0430\u043D)
    \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0435 \u043B\u0443\u0447\u0438
    \u043F\u0430\u0434\u0430\u044E\u0442 \u043E\u0442\u0432\u0435\u0441\u043D\u043E
    \u0438 \u043E\u0441\u0432\u0435\u0449\u0430\u044E\u0442 \u0434\u043D\u043E \u0441\u0430\u043C\u044B\u0445
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445 \u043A\u043E\u043B\u043E\u0434\u0446\u0435\u0432.
    \u0412 \u0442\u043E \u0436\u0435 \u0432\u0440\u0435\u043C\u044F \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438,
    \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043D\u043E\u0439
    \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E \u043D\u0430 \u043E\u0434\u043D\u043E\u043C
    \u043C\u0435\u0440\u0438\u0434\u0438\u0430\u043D\u0435, \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0435
    \u0447\u0430\u0441\u044B \u043E\u0442\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u044E\u0442
    \u0442\u0435\u043D\u044C. \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u0438\u0437\u043C\u0435\u0440\u0438\u043B \u044D\u0442\u0443 \u0442\u0435\u043D\u044C
    \u0438 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B, \u0447\u0442\u043E
    \u0443\u0433\u043E\u043B \u043F\u0430\u0434\u0435\u043D\u0438\u044F \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0445
    \u043B\u0443\u0447\u0435\u0439 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    **7\xB012'**, \u0447\u0442\u043E \u0440\u043E\u0432\u043D\u043E \u0432 50 \u0440\u0430\u0437
    \u043C\u0435\u043D\u044C\u0448\u0435 \u043F\u043E\u043B\u043D\u043E\u0439 \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u0438
    \u0432 360\xB0.  \u041F\u0440\u0438\u043D\u044F\u0432 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u043C\u0435\u0436\u0434\u0443 \u0421\u0438\u0435\u043D\u043E\u0439 \u0438 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0435\u0439
    \u0437\u0430 **5000 \u0441\u0442\u0430\u0434\u0438\u0435\u0432** (\u043F\u043E
    \u0434\u0430\u043D\u043D\u044B\u043C \u0435\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0438\u0445
    \u0437\u0435\u043C\u043B\u0435\u043C\u0435\u0440\u043E\u0432), \u043E\u043D \u043B\u0435\u0433\u043A\u043E
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u044C
    \u0417\u0435\u043C\u043B\u0438: 5000 * 50 = **250 000 \u0441\u0442\u0430\u0434\u0438\u0435\u0432**.
    \u0422\u043E\u0447\u043D\u043E\u0441\u0442\u044C \u044D\u0442\u043E\u0433\u043E
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430 \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440 \u0432\u044B\u0437\u044B\u0432\u0430\u0435\u0442 \u0441\u043F\u043E\u0440\u044B,
    \u0442\u0430\u043A \u043A\u0430\u043A \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u043A\u0430\u043A\u0438\u043C \u0438\u043C\u0435\u043D\u043D\u043E \u0441\u0442\u0430\u0434\u0438\u0435\u043C
    \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F \u0443\u0447\u0451\u043D\u044B\u0439.
    \u0415\u0441\u043B\u0438 \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0435\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0438\u0439 \u0441\u0442\u0430\u0434\u0438\u0439
    (\u043E\u043A. 157,5 \u043C), \u0435\u0433\u043E \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u0431\u044B\u043B \u0431\u044B \u0431\u043B\u0438\u0437\u043E\u043A \u043A \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C\u0443
    (\u043E\u043A. 39 690 \u043A\u043C), \u0435\u0441\u043B\u0438 \u0436\u0435 \u0430\u0442\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    (\u043E\u043A. 178 \u043C), \u0442\u043E \u043F\u043E\u0433\u0440\u0435\u0448\u043D\u043E\u0441\u0442\u044C
    \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430 \u0431\u044B \u043E\u043A\u043E\u043B\u043E
    16%. \u0412 \u043B\u044E\u0431\u043E\u043C \u0441\u043B\u0443\u0447\u0430\u0435,
    \u044D\u0442\u043E \u0431\u044B\u043B \u043F\u0440\u043E\u0440\u044B\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B \u0448\u0430\u0440\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u043E\u0441\u0442\u044C
    \u0417\u0435\u043C\u043B\u0438.  \u0412 \u0441\u0432\u043E\u0451\u043C \u0442\u0440\u0451\u0445\u0442\u043E\u043C\u043D\u043E\u043C
    \u0442\u0440\u0443\u0434\u0435 **\xAB\u0413\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u043A\u0430\xBB**
    \u043E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u043F\u0438\u0441\u0430\u043B
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043C\u0438\u0440, \u043D\u043E
    \u0438 \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u0435\u0433\u043E \u043A\u0430\u0440\u0442\u0443, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442
    \u2014 **\u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u0438 \u0438 \u043C\u0435\u0440\u0438\u0434\u0438\u0430\u043D\u044B**. 
    #### \U0001F4D0 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0438 \"\u0420\u0435\u0448\u0435\u0442\u043E \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430\"
    \u0412 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F
    \u0434\u0432\u0430 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0445\u0441\u044F
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F.  \u0412\u043E-\u043F\u0435\u0440\u0432\u044B\u0445,
    \u044D\u0442\u043E **\xAB\u0440\u0435\u0448\u0435\u0442\u043E \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430\xBB**
    \u2014 \u0434\u0440\u0435\u0432\u043D\u0435\u0439\u0448\u0438\u0439 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    \u0434\u043B\u044F \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0432\u0441\u0435\u0445 \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B,
    \u043D\u0435 \u043F\u0440\u0435\u0432\u043E\u0441\u0445\u043E\u0434\u044F\u0449\u0438\u0445
    \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u0433\u043E \u043F\u0440\u0435\u0434\u0435\u043B\u0430.
    \u0412\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0430 \u0443\u0447\u0451\u043D\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438
    \u043D\u0430 \u0432\u043E\u0441\u043A\u043E\u0432\u044B\u0445 \u0442\u0430\u0431\u043B\u0438\u0447\u043A\u0430\u0445,
    \u0430 \u0441\u043E\u0441\u0442\u0430\u0432\u043D\u044B\u0435 \u0447\u0438\u0441\u043B\u0430
    \xAB\u0432\u044B\u043A\u0430\u043B\u044B\u0432\u0430\u043B\u0438\xBB, \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u044F
    \u043D\u0435\u0442\u0440\u043E\u043D\u0443\u0442\u044B\u043C\u0438 \u043F\u0440\u043E\u0441\u0442\u044B\u0435,
    \u043A\u0430\u043A \u0432 \u0440\u0435\u0448\u0435\u0442\u0435.  \u0412\u043E-\u0432\u0442\u043E\u0440\u044B\u0445,
    \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \u0434\u0435\u043B\u0438\u0439\u0441\u043A\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0438
    \u043E\u0431 **\u0443\u0434\u0432\u043E\u0435\u043D\u0438\u0438 \u043A\u0443\u0431\u0430**,
    \u0441\u043E\u0437\u0434\u0430\u0432 \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u043F\u0440\u0438\u0431\u043E\u0440
    \u2014 **\u043C\u0435\u0437\u043E\u043B\u044F\u0431\u0438\u0439**. \u041E\u0434\u043D\u0430\u043A\u043E
    \u044D\u0442\u043E\u0442 \u043F\u043E\u0434\u0445\u043E\u0434 \u043F\u043E\u0434\u0432\u0435\u0440\u0433\u0441\u044F
    \u043A\u0440\u0438\u0442\u0438\u043A\u0435, \u0442\u0430\u043A \u043A\u0430\u043A
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u044B
    \u0441\u0447\u0438\u0442\u0430\u043B\u0438 \u043D\u0435\u0434\u043E\u0441\u0442\u043E\u0439\u043D\u044B\u043C
    \u0440\u0435\u0448\u0430\u0442\u044C \u0447\u0438\u0441\u0442\u044B\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432.  #### \U0001F52D
    \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F \u0438 \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044F
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0443 \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442
    \u0440\u0430\u0431\u043E\u0442\u0430 **\xAB\u041A\u0430\u0442\u0430\u0441\u0442\u0435\u0440\u0438\u0437\u043C\u044B\xBB**
    \u2014 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435 44 \u0441\u043E\u0437\u0432\u0435\u0437\u0434\u0438\u0439
    \u0441 \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445
    \u0441 \u043D\u0438\u043C\u0438 \u043C\u0438\u0444\u043E\u0432. \u041E\u043D
    \u0442\u0430\u043A\u0436\u0435 \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E
    \u0442\u043E\u0447\u043D\u043E \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B
    **\u043D\u0430\u043A\u043B\u043E\u043D \u044D\u043A\u043B\u0438\u043F\u0442\u0438\u043A\u0438**
    (\u0443\u0433\u043E\u043B \u0437\u0435\u043C\u043D\u043E\u0439 \u043E\u0441\u0438)
    \u0438 \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0441\u043F\u0438\u0441\u043E\u043A
    \u043F\u043E\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u0435\u0439 \u041E\u043B\u0438\u043C\u043F\u0438\u0439\u0441\u043A\u0438\u0445
    \u0438\u0433\u0440, \u0441\u0442\u0430\u0432, \u0442\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, **\u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u0438**. 
    ### \U0001F48E \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0438 \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0430 
    \u0417\u0430 \u0441\u0432\u043E\u044E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u0432\u0430 \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0430. \u041E\u0434\u043D\u043E
    \u0438\u0437 \u043D\u0438\u0445 \u2014 **\xAB\u041F\u0435\u043D\u0442\u0430\u0442\u043B\xBB**,
    \u0442\u043E \u0435\u0441\u0442\u044C \u043F\u044F\u0442\u0438\u0431\u043E\u0440\u0435\u0446,
    \u0432 \u0437\u043D\u0430\u043A \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F
    \u0435\u0433\u043E \u0442\u0430\u043B\u0430\u043D\u0442\u043E\u0432 \u0432 \u0440\u0430\u0437\u043D\u044B\u0445
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0430\u0445. \u0414\u0440\u0443\u0433\u043E\u0435
    \u2014 **\xAB\u0411\u0435\u0442\u0430\xBB** (\u0432\u0442\u043E\u0440\u0430\u044F
    \u0431\u0443\u043A\u0432\u0430 \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043B\u0444\u0430\u0432\u0438\u0442\u0430). \u041E\u043D\u043E \u0438\u043C\u0435\u043B\u043E
    \u0434\u0432\u043E\u0439\u043D\u043E\u0439 \u0441\u043C\u044B\u0441\u043B: \u0441
    \u043E\u0434\u043D\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B, \u0435\u0433\u043E
    \u043C\u043E\u0433\u043B\u0438 \u0442\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0442\u044C,
    \u0441\u0447\u0438\u0442\u0430\u044F \xAB\u0432\u0442\u043E\u0440\u044B\u043C
    \u041F\u043B\u0430\u0442\u043E\u043D\u043E\u043C\xBB, \u0441 \u0434\u0440\u0443\u0433\u043E\u0439
    \u2014 \u043D\u0430\u043C\u0435\u043A\u0430\u044F \u043D\u0430 \u0442\u043E,
    \u0447\u0442\u043E, \u0431\u0443\u0434\u0443\u0447\u0438 \u0433\u0435\u043D\u0438\u0435\u043C
    \u0432\u043E \u0432\u0441\u0451\u043C, \u0432 \u043A\u0430\u0436\u0434\u043E\u0439
    \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043E\u043D \u043D\u0435\u043C\u043D\u043E\u0433\u043E \u0443\u0441\u0442\u0443\u043F\u0430\u043B
    \u043F\u0435\u0440\u0432\u044B\u043C \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u0430\u043C
    (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0443). 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E
    \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E \u0435\u0433\u043E
    \u0442\u0440\u0443\u0434\u043E\u0432 \u0443\u0442\u0435\u0440\u044F\u043D\u044B
    \u0438 \u0434\u043E\u0448\u043B\u0438 \u0434\u043E \u043D\u0430\u0441 \u043B\u0438\u0448\u044C
    \u0432 \u043E\u0442\u0440\u044B\u0432\u043A\u0430\u0445 \u0438 \u043F\u0435\u0440\u0435\u0441\u043A\u0430\u0437\u0430\u0445
    \u0434\u0440\u0443\u0433\u0438\u0445 \u0430\u0432\u0442\u043E\u0440\u043E\u0432,
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430
    \u043D\u0430 \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u043D\u0430\u0443\u043A\u0443
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E. \u0415\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u044B
    \u0431\u044B\u043B\u0438 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B
    \u043F\u043E \u0441\u0432\u043E\u0435\u0439 \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u0435
    \u0438 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438, \u0430 \u0438\u043C\u044F
    \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438. \u0412 \u0435\u0433\u043E
    \u0447\u0435\u0441\u0442\u044C \u043D\u0430\u0437\u0432\u0430\u043D\u044B \u043A\u0440\u0430\u0442\u0435\u0440
    \u043D\u0430 \u041B\u0443\u043D\u0435, \u043F\u043E\u0434\u0432\u043E\u0434\u043D\u0430\u044F
    \u0433\u043E\u0440\u0430 \u0432 \u0421\u0440\u0435\u0434\u0438\u0437\u0435\u043C\u043D\u043E\u043C
    \u043C\u043E\u0440\u0435 \u0438 \u0434\u0430\u0436\u0435 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u043F\u0435\u0440\u0438\u043E\u0434\u043E\u0432 \u0433\u0435\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u041B\u0443\u043D\u044B."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0438 \u0440\u0430\u0431\u043E\u0442\u0430
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430 \u043F\u043E\u043B\u043D\u044B
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u043D\u044E\u0430\u043D\u0441\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432\u044B\u0445\u043E\u0434\u044F\u0442
    \u0434\u0430\u043B\u0435\u043A\u043E \u0437\u0430 \u0440\u0430\u043C\u043A\u0438
    \u0441\u0443\u0445\u043E\u0433\u043E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u0435\u0440\u0435\u0441\u043A\u0430\u0437\u0430. \u041C\u043D\u043E\u0433\u0438\u0435
    \u0438\u0437 \u044D\u0442\u0438\u0445 \u0444\u0430\u043A\u0442\u043E\u0432 \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u044E\u0442
    \u0435\u0433\u043E \u043A\u0430\u043A \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u043E\u0433\u043E,
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u043E\u0433\u043E \u0438 \u0434\u0430\u0436\u0435
    \u043D\u0435\u043C\u043D\u043E\u0433\u043E \u044F\u0437\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430.  \u0412\u043E\u0442 \u0441\u0430\u043C\u0430\u044F
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u043F\u043E\u0434\u0431\u043E\u0440\u043A\u0430
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432, \u043F\u0440\u043E\u043B\u0438\u0432\u0430\u044E\u0449\u0438\u0445
    \u0441\u0432\u0435\u0442 \u043D\u0430 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043C\u0435\u0442\u043E\u0434\u044B \xAB\u043E\u0442\u0446\u0430 \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0438\xBB. 
    ### 1. \u0424\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u044F:
    \xAB\u041A\u043E\u043B\u043E\u0434\u0435\u0446\xBB \u0438 \xAB\u0412\u0435\u0440\u0431\u043B\u044E\u0434\xBB
    \u043A\u0430\u043A \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043F\u0440\u0438\u0431\u043E\u0440\u044B  *   **\u041D\u0435 \u043A\u043E\u043B\u043E\u0434\u0435\u0446,
    \u0430 \xAB\u0432\u0435\u0440\u0431\u043B\u044E\u0436\u0438\u0439\xBB \u0440\u0430\u0441\u0447\u0435\u0442:**
    \u0412 \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0445 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0430\u0445
    \u0447\u0430\u0441\u0442\u043E \u043F\u0438\u0448\u0443\u0442, \u0447\u0442\u043E
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043A\u043E\u043B\u043E\u0434\u0435\u0446 \u0432 \u0421\u0438\u0435\u043D\u0435,
    \u0433\u0434\u0435 \u0421\u043E\u043B\u043D\u0446\u0435 \u043E\u0441\u0432\u0435\u0449\u0430\u043B\u043E
    \u0434\u043D\u043E. \u041D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435,
    \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0434\u0440\u0443\u0433\u043E\u0439, \u0431\u043E\u043B\u0435\u0435 \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u044B\u0439
    \u043C\u0435\u0442\u043E\u0434. \u0421\u0438\u0435\u043D\u0430 \u043B\u0435\u0436\u0430\u043B\u0430
    \u043D\u0430 \u043F\u0443\u0442\u0438 \u043A\u0430\u0440\u0430\u0432\u0430\u043D\u043E\u0432,
    \u0438 \u043C\u0435\u0441\u0442\u043D\u044B\u0435 \u0436\u0438\u0442\u0435\u043B\u0438
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B\u0438, \u0447\u0442\u043E \u0432 \u043F\u043E\u043B\u0434\u0435\u043D\u044C
    \u043B\u0435\u0442\u043D\u0435\u0433\u043E \u0441\u043E\u043B\u043D\u0446\u0435\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0435 \u0448\u0435\u0441\u0442\u044B
    \u043D\u0435 \u043E\u0442\u0431\u0440\u0430\u0441\u044B\u0432\u0430\u044E\u0442
    \u0442\u0435\u043D\u0438. \u041D\u043E \u043A\u0430\u043A \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u044C
    \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u043C\u0435\u0436\u0434\u0443
    \u0433\u043E\u0440\u043E\u0434\u0430\u043C\u0438 \u0431\u0435\u0437 \u043A\u0430\u0440\u0442?    
    *   \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D **\u043D\u0435 \u0435\u0437\u0434\u0438\u043B
    \u0438\u0437 \u0433\u043E\u0440\u043E\u0434\u0430 \u0432 \u0433\u043E\u0440\u043E\u0434**.
    \u041E\u043D \u043D\u0430\u043D\u044F\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    **\u0431\u0435\u043C\u0430\u0442\u0438\u0441\u0442\u043E\u0432** \u2014 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u043E\u0431\u0443\u0447\u0435\u043D\u043D\u044B\u0445 \u0440\u0430\u0431\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u0447\u0438\u0442\u0430\u043B\u0438
    \u0448\u0430\u0433\u0438. \u041D\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u2014 \u043E\u043D \u0441\u043A\u043E\u0440\u0440\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438\u0445 \u0434\u0430\u043D\u043D\u044B\u0435. \u0411\u0435\u043C\u0430\u0442\u0438\u0441\u0442\u044B
    \u0448\u043B\u0438 \u043D\u0435 \u043F\u043E \u043F\u0440\u044F\u043C\u043E\u0439,
    \u0430 \u043F\u043E \u0438\u0437\u0432\u0438\u043B\u0438\u0441\u0442\u043E\u0439
    \u0434\u043E\u0440\u043E\u0433\u0435 \u0432\u0434\u043E\u043B\u044C \u041D\u0438\u043B\u0430.
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u0437\u043D\u0430\u043B,
    \u0447\u0442\u043E \u043F\u0443\u0442\u044C \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u0435\u0442
    \u0438\u0437\u0433\u0438\u0431\u044B \u0440\u0435\u043A\u0438, \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u044B\u043F\u0440\u044F\u043C\u0438\u043B \u044D\u0442\u0443 \u043A\u0440\u0438\u0432\u0443\u044E,
    \u043E\u0441\u043D\u043E\u0432\u044B\u0432\u0430\u044F\u0441\u044C \u043D\u0430
    \u0441\u0440\u0435\u0434\u043D\u0435\u0439 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438
    \u0432\u0435\u0440\u0431\u043B\u044E\u0436\u044C\u0438\u0445 \u043A\u0430\u0440\u0430\u0432\u0430\u043D\u043E\u0432
    (\u043E\u043A\u043E\u043B\u043E 100 \u0441\u0442\u0430\u0434\u0438\u0435\u0432
    \u0432 \u0434\u0435\u043D\u044C). \u0422\u0430\u043A \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0432\u043E\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    5000 \u0441\u0442\u0430\u0434\u0438\u0435\u0432.  *   **\u041E\u0448\u0438\u0431\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u043F\u0430\u0441\u043B\u0430
    \u041A\u043E\u043B\u0443\u043C\u0431\u0430:** \u0422\u043E\u0442 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D (\u043E\u043A\u043E\u043B\u043E
    250 000 \u0441\u0442\u0430\u0434\u0438\u0435\u0432), \u0431\u044B\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0431\u043B\u0438\u0437\u043E\u043A \u043A \u0438\u0441\u0442\u0438\u043D\u0435
    (\u0432\u0441\u0435\u0433\u043E \u043D\u0430 ~2% \u0432\u044B\u0448\u0435, \u0435\u0441\u043B\u0438
    \u0441\u0447\u0438\u0442\u0430\u0442\u044C \u0432 \u0435\u0433\u0438\u043F\u0435\u0442\u0441\u043A\u0438\u0445
    \u0441\u0442\u0430\u0434\u0438\u044F\u0445). \u041E\u0434\u043D\u0430\u043A\u043E
    \u0432 \u0421\u0440\u0435\u0434\u043D\u0435\u0432\u0435\u043A\u043E\u0432\u044C\u0435
    \u0438 \u0432 \u044D\u043F\u043E\u0445\u0443 \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0443\u0447\u0435\u043D\u044B\u0435 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u043C\u0438,
    \u0441\u0438\u043B\u044C\u043D\u043E \u0437\u0430\u043D\u0438\u0436\u0435\u043D\u043D\u044B\u043C\u0438
    \u0440\u0430\u0441\u0447\u0435\u0442\u0430\u043C\u0438 \u041F\u043E\u0441\u0438\u0434\u043E\u043D\u0438\u044F
    (\u043E\u043A\u043E\u043B\u043E 29 000 \u043A\u043C). \u0418\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u0438 **\u043E\u0448\u0438\u0431\u043E\u0447\u043D\u044B\u0435**
    \u0434\u0430\u043D\u043D\u044B\u0435 \u0443\u0431\u0435\u0434\u0438\u043B\u0438
    \u0425\u0440\u0438\u0441\u0442\u043E\u0444\u043E\u0440\u0430 \u041A\u043E\u043B\u0443\u043C\u0431\u0430,
    \u0447\u0442\u043E \u043F\u043B\u044B\u0442\u044C \u043D\u0430 \u0437\u0430\u043F\u0430\u0434
    \u0434\u043E \u0410\u0437\u0438\u0438 \u0440\u0443\u043A\u043E\u0439 \u043F\u043E\u0434\u0430\u0442\u044C.
    \u0415\u0441\u043B\u0438 \u0431\u044B \u041A\u043E\u043B\u0443\u043C\u0431 \u0437\u043D\u0430\u043B
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u0443\u044E \u0446\u0438\u0444\u0440\u0443
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430, \u043E\u043D \u0431\u044B
    \u0438\u0441\u043F\u0443\u0433\u0430\u043B\u0441\u044F \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F
    \u0438, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u043D\u0435 \u043E\u0442\u043F\u043B\u044B\u043B
    \u0431\u044B.  ---  ### 2. \u0411\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u0447\u043D\u0430\u044F
    \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u0430: \xAB\u041A\u043E\u0440\u0430\u0431\u0435\u043B\u044C\u043D\u044B\u0439\xBB
    \u043D\u0430\u043B\u043E\u0433  \u0411\u0443\u0434\u0443\u0447\u0438 \u0433\u043B\u0430\u0432\u043E\u0439
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0438, \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B \u0441\u0435\u0431\u044F \u043A\u0430\u043A
    \u043E\u0434\u0435\u0440\u0436\u0438\u043C\u044B\u0439 \u043A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u043E\u043D\u0435\u0440
    \u0437\u043D\u0430\u043D\u0438\u0439.  *   **\u041A\u043E\u043D\u0444\u0438\u0441\u043A\u0430\u0446\u0438\u044F
    \u043D\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0435:** \u041E\u043D \u0438\u0437\u0434\u0430\u043B
    \u0443\u043A\u0430\u0437, \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u0432\u0441\u0435 \u043A\u043E\u0440\u0430\u0431\u043B\u0438, \u043F\u0440\u0438\u0431\u044B\u0432\u0430\u044E\u0449\u0438\u0435
    \u0432 \u043F\u043E\u0440\u0442 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0438,
    \u043F\u043E\u0434\u043B\u0435\u0436\u0430\u043B\u0438 **\u043E\u0431\u044B\u0441\u043A\u0443
    \u043D\u0430 \u043D\u0430\u043B\u0438\u0447\u0438\u0435 \u043A\u043D\u0438\u0433**.
    \u0415\u0441\u043B\u0438 \u043D\u0430 \u0431\u043E\u0440\u0442\u0443 \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0441\u044F
    \u0441\u0432\u0438\u0442\u043E\u043A, \u0435\u0433\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043A\u043E\u043F\u0438\u0440\u043E\u0432\u0430\u043B\u0438, \u0430 *\u043A\u043E\u043D\u0444\u0438\u0441\u043A\u043E\u0432\u0430\u043B\u0438*
    \u0432 \u043F\u043E\u043B\u044C\u0437\u0443 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0438.
    \u0412\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0443 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u043B\u0438
    \u043A\u043E\u043F\u0438\u044E, \u0441\u0434\u0435\u043B\u0430\u043D\u043D\u0443\u044E
    \u043C\u0435\u0441\u0442\u043D\u044B\u043C\u0438 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u0447\u0438\u043A\u0430\u043C\u0438,
    \u0430 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u0432 \u043A\u043D\u0438\u0433\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0449\u0435.
    *   **\u0413\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0433\u0440\u0430\u0431\u0435\u0436 \u0440\u0430\u0434\u0438 \u043D\u0430\u0443\u043A\u0438:**
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u0438\u0437 \u0410\u0444\u0438\u043D
    \u0432 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u044E \u043F\u0440\u0438\u0432\u0435\u0437\u043B\u0438
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0430\u0440\u0445\u0438\u0432 \u0434\u0440\u0435\u0432\u043D\u0435\u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0439 (\u042D\u0441\u0445\u0438\u043B\u0430,
    \u0421\u043E\u0444\u043E\u043A\u043B\u0430, \u0415\u0432\u0440\u0438\u043F\u0438\u0434\u0430)
    \u0434\u043B\u044F \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \xAB\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u043B\u0435\u043D\u0438\u044F\xBB.
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u0437\u0430\u043F\u043B\u0430\u0442\u0438\u043B
    \u0430\u0444\u0438\u043D\u044F\u043D\u0430\u043C \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u0434\u0435\u043D\u0435\u0436\u043D\u044B\u0439 \u0437\u0430\u043B\u043E\u0433
    \u0437\u0430 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u0430\u0442\u044C \u0442\u0435\u043A\u0441\u0442\u044B,
    \u043D\u043E \u043F\u043E\u0442\u043E\u043C \u0437\u0430\u044F\u0432\u0438\u043B,
    \u0447\u0442\u043E \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044B
    \u0441\u0435\u0431\u0435, \u0430 \u0437\u0430\u043B\u043E\u0433 (\u0432\u0437\u0430\u043C\u0435\u043D
    \u043F\u043E\u0442\u0435\u0440\u0438) \u043E\u043D \u043E\u0442\u0434\u0430\u0435\u0442
    \u0430\u0444\u0438\u043D\u044F\u043D\u0430\u043C. \u042D\u0442\u043E \u0431\u044B\u043B
    \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u044C\u043D\u044B\u0439, \u043D\u043E
    \u043E\u0447\u0435\u043D\u044C \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0439
    \u043C\u0435\u0442\u043E\u0434 \u043F\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u044F
    \u0444\u043E\u043D\u0434\u043E\u0432.  ---  ### 3. \u0425\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044F:
    \u0421\u043C\u0435\u0445 \u043D\u0430\u0434 \u0437\u0432\u0435\u0437\u0434\u0430\u043C\u0438 
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u043C,
    \u043A\u0442\u043E \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0432\u044B\u0441\u043C\u0435\u044F\u0442\u044C
    \u0430\u0441\u0442\u0440\u043E\u043B\u043E\u0433\u043E\u0432 \u0438 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u044B\u0435
    \u0441\u0443\u0435\u0432\u0435\u0440\u0438\u044F \u043E \xAB\u043F\u0430\u0434\u0430\u044E\u0449\u0438\u0445
    \u0437\u0432\u0435\u0437\u0434\u0430\u0445\xBB.  *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \xAB\u0421\u043E\u0431\u0430\u0447\u044C\u0435\u0433\u043E \u0438\u0441\u043F\u0443\u0433\u0430\xBB:**
    \u0412 \u0441\u0432\u043E\u0435\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 \u043E\u043D
    \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u043D\u043E \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B,
    \u0447\u0442\u043E \u043F\u0430\u0434\u0430\u044E\u0449\u0438\u0435 \u0437\u0432\u0435\u0437\u0434\u044B
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u0435\u0434\u0437\u043D\u0430\u043C\u0435\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438 \u043D\u0435 \u0434\u0443\u0448\u0438 \u043B\u044E\u0434\u0435\u0439.
    \u041E\u043D \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u043B,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0442\u0432\u0435\u0440\u0434\u044B\u0435
    \u0447\u0430\u0441\u0442\u0438\u0446\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0433\u043E\u0440\u0430\u044E\u0442 \u0432 \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0435.
    \u0412 \u0448\u0443\u0442\u043A\u0443 \u043E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B
    \u0438\u0445 \xAB\u043A\u0430\u043B\u043E\u043C \u041A\u043E\u0441\u043C\u043E\u0441\u0430\xBB.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B,
    \u0447\u0442\u043E \u0435\u0441\u043B\u0438 \u0437\u0432\u0435\u0437\u0434\u0430
    \xAB\u043F\u0430\u0434\u0430\u0435\u0442\xBB, \u0442\u043E \u043D\u0430 \u0441\u0430\u043C\u043E\u043C
    \u0434\u0435\u043B\u0435 \u043E\u043D\u0430 \u043F\u0440\u043E\u043B\u0435\u0442\u0430\u0435\u0442
    \u043C\u0438\u043C\u043E \u043D\u0430\u0441 \u043D\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439
    \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438, \u0438 \u0432\u0438\u0437\u0443\u0430\u043B\u044C\u043D\u043E
    \u044D\u0442\u043E \u043F\u043E\u0445\u043E\u0436\u0435 \u043D\u0430 \u0442\u043E,
    \u043A\u0430\u043A \u0435\u0441\u043B\u0438 \u0431\u044B \u0432\u044B \u0431\u0440\u043E\u0441\u0438\u043B\u0438
    \u043A\u0430\u043C\u0435\u043D\u044C \u0441 \u0432\u044B\u0441\u043E\u043A\u043E\u0439
    \u0431\u0430\u0448\u043D\u0438.  ---  ### 4. \u041E\u0448\u0438\u0431\u043A\u0430
    \u0432 \u043A\u0430\u0440\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438: \u0421\u043F\u043E\u0440
    \u0441 \u0413\u043E\u043C\u0435\u0440\u043E\u043C  \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D
    \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0438\u043C
    \u0441\u043A\u0435\u043F\u0442\u0438\u0446\u0438\u0437\u043C\u043E\u043C \u043A
    \u043F\u043E\u044D\u0442\u0430\u043C, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u043A \u0413\u043E\u043C\u0435\u0440\u0443.  *   **\u041A\u0440\u0438\u0442\u0438\u043A\u0430
    \xAB\u041E\u0434\u0438\u0441\u0441\u0435\u0438\xBB:** \u041E\u043D \u044F\u0437\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0437\u0430\u043C\u0435\u0447\u0430\u043B, \u0447\u0442\u043E \u0435\u0441\u043B\u0438
    \u0431\u044B \u0413\u043E\u043C\u0435\u0440 \u0431\u044B\u043B \u043F\u0440\u0430\u0432,
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044F \u043F\u043B\u0430\u0432\u0430\u043D\u0438\u044F
    \u041E\u0434\u0438\u0441\u0441\u0435\u044F, \u0442\u043E \u0442\u043E\u0442 \u043F\u0440\u043E\u043F\u043B\u044B\u043B
    \u0431\u044B \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u044F, \u0441\u0440\u0430\u0432\u043D\u0438\u043C\u044B\u0435
    \u0441 \u043A\u0440\u0443\u0433\u043E\u0441\u0432\u0435\u0442\u043D\u044B\u043C
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435\u043C, \u043F\u0440\u0438\u0447\u0435\u043C
    \u0432 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u0445 \u043E\u0434\u043D\u043E\u0433\u043E
    \u0421\u0440\u0435\u0434\u0438\u0437\u0435\u043C\u043D\u043E\u0433\u043E \u043C\u043E\u0440\u044F.
    *   **\xAB\u041E\u0434\u0438\u0441\u0441\u0435\u044F \u2014 \u044D\u0442\u043E
    \u043D\u0435 \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u044F\xBB:** \u041A\u043E\u0433\u0434\u0430
    \u043A\u0440\u0438\u0442\u0438\u043A\u0438 \u043E\u0431\u0432\u0438\u043D\u044F\u043B\u0438
    \u0435\u0433\u043E \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u0435\u0433\u043E
    \u043A\u0430\u0440\u0442\u0430 \u0415\u0432\u0440\u043E\u043F\u044B \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \xAB\u0441\u0436\u0430\u0442\u0430\xBB \u0438 \u043B\u0438\u0448\u0435\u043D\u0430
    \u043F\u043E\u044D\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043A\u0440\u0430\u0441\u043E\u0442\u044B,
    \u043E\u043D \u043E\u0442\u0432\u0435\u0447\u0430\u043B: *\xAB\u0413\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u0442\u044C \u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E\u0439,
    \u0430 \u043D\u0435 \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439.
    \u041A\u0430\u0440\u0442\u0430 \u2014 \u044D\u0442\u043E \u043D\u0435 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0430,
    \u0430 \u0447\u0435\u0440\u0442\u0435\u0436\xBB*.  ---  ### 5. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u044E\u043C\u043E\u0440: \u041A\u0430\u043A \u043E\u043D \xAB\u043B\u043E\u0432\u0438\u043B\xBB
    \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u0447\u0438\u0441\u043B\u0430  \u0420\u0435\u0448\u0435\u0442\u043E
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0441\u0430\u043C\u044B\u0439 \u0434\u0440\u0435\u0432\u043D\u0438\u0439 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C,
    \u043D\u043E \u0435\u0433\u043E \u043D\u0430\u0437\u0432\u0430\u043B\u0438 **\xAB\u0420\u0435\u0448\u0435\u0442\u043E\u043C\xBB**
    \u043D\u0435 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E.  *   **\u0422\u0435\u0445\u043D\u0438\u043A\u0430
    \u0438\u0441\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u044F:** \u041E\u043D
    \u0431\u0440\u0430\u043B \u043F\u0430\u043F\u0438\u0440\u0443\u0441, \u043F\u0438\u0441\u0430\u043B
    \u043D\u0430 \u043D\u0435\u043C \u0447\u0438\u0441\u043B\u0430 \u043E\u0442 1
    \u0434\u043E 100 000, \u0430 \u0437\u0430\u0442\u0435\u043C \u0431\u0440\u0430\u043B
    \u043E\u0441\u0442\u0440\u0443\u044E \u043F\u0430\u043B\u043E\u0447\u043A\u0443
    \u0438 **\u0432\u044B\u043A\u0430\u043B\u044B\u0432\u0430\u043B** (\u0432\u044B\u0440\u0435\u0437\u0430\u043B)
    \u0432\u0441\u0435 \u0441\u043E\u0441\u0442\u0430\u0432\u043D\u044B\u0435 \u0447\u0438\u0441\u043B\u0430.
    \u041F\u0430\u043F\u0438\u0440\u0443\u0441 \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u043B\u0441\u044F
    \u0432 \u043F\u043E\u0434\u043E\u0431\u0438\u0435 \u0434\u0443\u0440\u0448\u043B\u0430\u0433\u0430.
    \u0412 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u043E\u043C
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u043C \u0442\u0435\u043A\u0441\u0442\u0435
    \u043E\u043D \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u043B \u044D\u0442\u043E\u0442
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441 \u0441 \u043F\u0440\u043E\u0441\u0435\u0438\u0432\u0430\u043D\u0438\u0435\u043C
    \u043C\u0443\u043A\u0438 \u0447\u0435\u0440\u0435\u0437 \u0441\u0438\u0442\u043E,
    \u0433\u0434\u0435 \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u0447\u0438\u0441\u043B\u0430
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0438\u0441\u044C \xAB\u043D\u0430
    \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438\xBB, \u0430
    \u0434\u044B\u0440\u043A\u0438 \u0431\u044B\u043B\u0438 \u043D\u0430 \u043C\u0435\u0441\u0442\u0435
    \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B.  --- 
    ### 6. \u0414\u0440\u0443\u0436\u0431\u0430 \u0441 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u043E\u043C:
    \u0428\u043F\u0438\u043E\u043D\u0441\u043A\u0438\u0435 \u0438\u0433\u0440\u044B 
    \u041C\u0435\u0436\u0434\u0443 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0438\u0435\u0439
    (\u0433\u0434\u0435 \u0436\u0438\u043B \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D)
    \u0438 \u0421\u0438\u0440\u0430\u043A\u0443\u0437\u0430\u043C\u0438 (\u0433\u0434\u0435
    \u0436\u0438\u043B \u0410\u0440\u0445\u0438\u043C\u0435\u0434) \u0448\u043B\u0430
    \u0430\u043A\u0442\u0438\u0432\u043D\u0430\u044F \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430. 
    *   **\xAB\u0417\u0430\u0434\u0430\u0447\u0430 \u043E \u0431\u044B\u043A\u0430\u0445\xBB:**
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0443 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0437\u0430\u0434\u0430\u0447\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u0441 \u0432\u043E\u0441\u0435\u043C\u044C\u044E \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C\u0438
    (\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435 \u043A\u0430\u043A \xAB\u0417\u0430\u0434\u0430\u0447\u0430
    \u043E \u0431\u044B\u043A\u0430\u0445\xBB). \u042D\u0442\u043E \u0431\u044B\u043B\u0430
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u043E\u043B\u043E\u0432\u043E\u043B\u043E\u043C\u043A\u0430. \u0410\u0440\u0445\u0438\u043C\u0435\u0434
    \u0433\u043E\u0440\u0434\u0438\u043B\u0441\u044F \u0442\u0435\u043C, \u0447\u0442\u043E
    \u0441\u043E\u0437\u0434\u0430\u043B \u0437\u0430\u0434\u0430\u0447\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442 \u043A\u0430\u043A \u043F\u0440\u043E\u0441\u0442\u0430\u044F,
    \u043D\u043E \u043D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435
    \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C\u0438 \u0447\u0438\u0441\u043B\u0430\u043C\u0438
    (\u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0438\u043C\u0435\u0435\u0442 206
    545 \u0446\u0438\u0444\u0440). \u041E\u043D \u0431\u0440\u043E\u0441\u0438\u043B
    \u0432\u044B\u0437\u043E\u0432 \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0443,
    \u0437\u043D\u0430\u044F, \u0447\u0442\u043E \u0442\u043E\u0442 \u043B\u044E\u0431\u0438\u0442
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F.
    *   **\u041C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435:** \u0412 \u043E\u0442\u0432\u0435\u0442
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u043D\u0435 \u0441\u0442\u0430\u043B
    \u043C\u0443\u0447\u0438\u0442\u044C\u0441\u044F \u0441 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C\u0438,
    \u0430 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0440\u0438\u0441\u043B\u0430\u043B
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0443 \u0447\u0435\u0440\u0442\u0435\u0436
    \u0441\u0432\u043E\u0435\u0433\u043E **\u043C\u0435\u0437\u043E\u043B\u044F\u0431\u0438\u044F**.
    \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B: *\xAB\u041B\u043E\u0432\u0438,
    \u0410\u0440\u0445\u0438\u043C\u0435\u0434, \u044D\u0442\u043E \u043B\u0435\u0433\u0447\u0435,
    \u0447\u0435\u043C \u0434\u0443\u043C\u0430\u0442\u044C \u0433\u043E\u043B\u043E\u0432\u043E\u0439
    \u2014 \u043F\u0440\u043E\u0441\u0442\u043E \u0434\u0432\u0438\u0433\u0430\u0439
    \u043F\u043B\u0430\u043D\u043A\u0438\xBB*.  ---  ### 7. \u041B\u0438\u0447\u043D\u044B\u0439
    \u0442\u0440\u0430\u0433\u0438\u0437\u043C \u0438 \xAB\u0414\u0438\u0435\u0442\u0430\xBB 
    \u0414\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u044B\u0439 \u0443\u0445\u043E\u0434
    \u0438\u0437 \u0436\u0438\u0437\u043D\u0438 \u0438\u0437-\u0437\u0430 \u0441\u043B\u0435\u043F\u043E\u0442\u044B
    \u2014 \u044D\u0442\u043E \u0444\u0430\u043A\u0442, \u043D\u043E \u0443 \u043D\u0435\u0433\u043E
    \u0435\u0441\u0442\u044C \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0434\u0435\u0442\u0430\u043B\u044C.  *   **\u0423\u0447\u0435\u043D\u044B\u0439
    \u0434\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0433\u043E \u0432\u0437\u0434\u043E\u0445\u0430:**
    \u0418\u0441\u0442\u043E\u0440\u0438\u043A \u041F\u043B\u0443\u0442\u0430\u0440\u0445
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442, \u0447\u0442\u043E \u043F\u0435\u0440\u0435\u0434
    \u0442\u0435\u043C \u043A\u0430\u043A \u043D\u0430\u0447\u0430\u0442\u044C \u0433\u043E\u043B\u043E\u0434\u043E\u0432\u043A\u0443,
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u0437\u0430\u043A\u0430\u0437\u0430\u043B
    \u0441\u0435\u0431\u0435 \u0443 \u0440\u0430\u0431\u043E\u0432 \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u0442\u044C
    \u0432\u0441\u043B\u0443\u0445 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439,
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u0435\u043C\u0443
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442 \u043E \u043A\u043E\u043C\u0435\u0442\u043D\u044B\u0445
    \u043E\u0440\u0431\u0438\u0442\u0430\u0445. \u041A\u043E\u0433\u0434\u0430 \u043A\u043D\u0438\u0433\u0443
    \u0434\u043E\u0447\u0438\u0442\u0430\u043B\u0438, \u043E\u043D \u0441\u043A\u0430\u0437\u0430\u043B:
    *\xAB\u0422\u0435\u043F\u0435\u0440\u044C \u044F \u0437\u043D\u0430\u044E \u0432\u0441\u0435,
    \u0447\u0442\u043E \u043D\u0443\u0436\u043D\u043E \u0437\u043D\u0430\u0442\u044C
    \u043E \u043D\u0435\u0431\u0435, \u043D\u043E \u0431\u043E\u043B\u044C\u0448\u0435
    \u043D\u0435 \u0443\u0432\u0438\u0436\u0443 \u0435\u0433\u043E\xBB* \u2014 \u0438
    \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u043E\u0442 \u0435\u0434\u044B.
    *   **\u0421\u043F\u043E\u0440 \u043E \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435:**
    \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0440\u0430\u0437\u043D\u043E\u0433\u043B\u0430\u0441\u0438\u0435
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0433\u043E\u0434\u0430
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438. \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438 \u0433\u043E\u0432\u043E\u0440\u044F\u0442,
    \u0447\u0442\u043E \u043E\u043D \u0443\u043C\u0435\u0440 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    80 \u043B\u0435\u0442, \u0434\u0440\u0443\u0433\u0438\u0435 \u2014 \u0432 82
    \u0433\u043E\u0434\u0430. \u0417\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0447\u0442\u043E \u044D\u0442\u0430 \u043F\u0443\u0442\u0430\u043D\u0438\u0446\u0430
    \u0432\u043E\u0437\u043D\u0438\u043A\u043B\u0430 \u0438\u0437-\u0437\u0430 \u0442\u043E\u0433\u043E,
    \u0447\u0442\u043E \u043E\u043D \u0441\u0430\u043C \u0436\u0435 \u0437\u0430\u043F\u0443\u0442\u0430\u043B
    \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u0438, \u0432\u0432\u0435\u0434\u044F
    \u043D\u043E\u0432\u0443\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u043E\u043B\u0438\u043C\u043F\u0438\u0439\u0441\u043A\u043E\u0433\u043E
    \u043B\u0435\u0442\u043E\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F,
    \u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043F\u043E\u0442\u043E\u043C
    \u043D\u0435 \u043C\u043E\u0433\u043B\u0438 \u0441\u043E\u0439\u0442\u0438\u0441\u044C
    \u043D\u0430 \u0442\u043E\u0447\u043D\u043E\u0439 \u0434\u0430\u0442\u0435 \u0435\u0433\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439 \u0441\u043C\u0435\u0440\u0442\u0438. 
    ---  ### 8. \u041F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u0435 \xAB\u043A\u0443\u0440\u044C\u0435\u0437\u044B\xBB:
    \u041B\u0443\u043D\u043D\u044B\u0439 \u043A\u0440\u0430\u0442\u0435\u0440 \u0438
    \u043C\u043E\u0440\u0441\u043A\u0430\u044F \u0433\u043E\u0440\u0430  \u0412 \u0447\u0435\u0441\u0442\u044C
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430 \u043D\u0430\u0437\u0432\u0430\u043D\u044B
    \u043E\u0431\u044A\u0435\u043A\u0442\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u043D \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0432\u0438\u0434\u0435\u043B. 
    *   **\u041A\u0440\u0430\u0442\u0435\u0440 \u043D\u0430 \u041B\u0443\u043D\u0435:**
    \u0423\u0434\u0430\u0440\u043D\u044B\u0439 \u043A\u0440\u0430\u0442\u0435\u0440
    \u0434\u0438\u0430\u043C\u0435\u0442\u0440\u043E\u043C \u043E\u043A\u043E\u043B\u043E
    60 \u043A\u043C \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u0432
    \u0432\u0438\u0434\u0438\u043C\u043E\u0439 \u0447\u0430\u0441\u0442\u0438 \u041B\u0443\u043D\u044B.
    \u0415\u0433\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u0443 \u043D\u0435\u0433\u043E
    \u043E\u0447\u0435\u043D\u044C \u043A\u0440\u0443\u0442\u044B\u0435 \u0441\u0442\u0435\u043D\u043A\u0438
    \u0438 \u043C\u043E\u043B\u043E\u0434\u043E\u0439 \u0432\u043E\u0437\u0440\u0430\u0441\u0442
    (\u0432 \u0433\u0435\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0441\u043C\u044B\u0441\u043B\u0435 \u2014 \u043E\u043A\u043E\u043B\u043E 1,1
    \u043C\u043B\u0440\u0434 \u043B\u0435\u0442). \u041B\u0443\u043D\u043D\u044B\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434, \u043A\u043E\u0433\u0434\u0430 \u043E\u043D
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043B\u0441\u044F, \u0442\u0430\u043A
    \u0438 \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u2014 **\xAB\u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u043E\u0432\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434\xBB**. \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u044B
    \u0432\u044B\u0431\u0440\u0430\u043B\u0438 \u0438\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u043E \u0438\u043C\u044F, \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D \u043F\u0435\u0440\u0432\u044B\u043C
    \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u0417\u0435\u043C\u043B\u0438 \u043D\u0430
    \u044D\u0440\u044B (\u043F\u0435\u0440\u0438\u043E\u0434\u044B). *   **\u0413\u043E\u0440\u0430
    \u042D\u0440\u0430\u0442\u043E\u0441\u0444\u0435\u043D\u0430:** \u0412 \u0421\u0440\u0435\u0434\u0438\u0437\u0435\u043C\u043D\u043E\u043C
    \u043C\u043E\u0440\u0435, \u043A \u044E\u0433\u0443 \u043E\u0442 \u041A\u0440\u0438\u0442\u0430,
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u043F\u043E\u0434\u0432\u043E\u0434\u043D\u0430\u044F
    \u0433\u043E\u0440\u0430, \u0432\u0435\u0440\u0448\u0438\u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043D\u0435 \u0434\u043E\u0445\u043E\u0434\u0438\u0442 \u0434\u043E \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    \u0432\u043E\u0434\u044B \u043E\u043A\u043E\u043B\u043E 700 \u043C\u0435\u0442\u0440\u043E\u0432.
    \u0415\u0451 \u043D\u0430\u0437\u0432\u0430\u043B\u0438 \u0432 \u0435\u0433\u043E
    \u0447\u0435\u0441\u0442\u044C, \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E
    \u043E\u043D \u043F\u0435\u0440\u0432\u044B\u043C \u043D\u0430\u043D\u0435\u0441
    \u043D\u0430 \u043A\u0430\u0440\u0442\u0443 \u044D\u0442\u0443 \u0437\u043E\u043D\u0443
    \u0438 \u043E\u0442\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u0437\u0434\u0435\u0441\u044C
    \u043C\u043E\u0440\u0435 \u0438\u043C\u0435\u0435\u0442 \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0439
    \u0441\u0438\u043D\u0438\u0439 \u043E\u0442\u0442\u0435\u043D\u043E\u043A (\u0438\u0437-\u0437\u0430
    \u043F\u043E\u0434\u0432\u043E\u0434\u043D\u043E\u0433\u043E \u0442\u0435\u0447\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043E\u0431\u0445\u043E\u0434\u0438\u0442
    \u0433\u043E\u0440\u0443)."
