  achievementsRu: "\u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439
    \u043E\u0431\u0437\u043E\u0440 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439
    \u0413\u0440\u0438\u0433\u043E\u0440\u0438\u044F \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0430
    \u0438 \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434\u0430 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443. 
    ### **1. \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u043E \u0434\u0443\u0448\u0435
    (1994)**  \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0435\u0433\u043E
    \u043F\u0435\u0440\u0432\u043E\u0439 \u043A\u0440\u0443\u043F\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u043E\u0439, \u043F\u0440\u0438\u043D\u0435\u0441\u0448\u0435\u0439
    \u0435\u043C\u0443 \u043C\u0438\u0440\u043E\u0432\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0443\u0433\u0430\u0445. \u0412 \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0435\u0441\u0442\u044C
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \xAB\u0434\u0443\u0448\u0438\xBB \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u044F
    \u2014 \u0435\u0433\u043E \u0441\u0432\u043E\u0435\u043E\u0431\u0440\u0430\u0437\u043D\u043E\u0433\u043E
    \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u043E\u0433\u043E \xAB\u0441\u043A\u0435\u043B\u0435\u0442\u0430\xBB.
    \u0412 1972 \u0433\u043E\u0434\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0414\u0436\u0435\u0444\u0444 \u0427\u0438\u0433\u0435\u0440 \u0438 \u0414\u0435\u0442\u043B\u0435\u0444
    \u0413\u0440\u043E\u043C\u043E\u043B \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443 \u043E \u0434\u0443\u0448\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B\u0430:
    \u0435\u0441\u043B\u0438 \u0432 \u043A\u0430\u0436\u0434\u043E\u0439 \u0442\u043E\u0447\u043A\u0435
    \u043F\u043E\u043B\u043D\u043E\u0433\u043E \u043D\u0435\u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u043E\u0433\u043E
    \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u0430 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u044F
    \u0441 \u043D\u0435\u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043A\u0440\u0438\u0432\u0438\u0437\u043D\u043E\u0439 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435, \u0433\u0434\u0435
    \u043A\u0440\u0438\u0432\u0438\u0437\u043D\u0430 \u0441\u0442\u0440\u043E\u0433\u043E
    \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u0430, \u0442\u043E
    \u0435\u0433\u043E \xAB\u0434\u0443\u0448\u0430\xBB \u0432\u044B\u0440\u043E\u0436\u0434\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0442\u043E\u0447\u043A\u0443, \u0430 \u0441\u0430\u043C\u043E \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0435
    \u0443\u0441\u0442\u0440\u043E\u0435\u043D\u043E \u043A\u0430\u043A \u043E\u0431\u044B\u0447\u043D\u043E\u0435
    \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E. 
    **\u0412\u043A\u043B\u0430\u0434 \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0430:** 
    *   **\u041A\u0440\u0430\u0442\u043A\u043E\u0441\u0442\u044C \u0438 \u0438\u0437\u044F\u0449\u0435\u0441\u0442\u0432\u043E:**
    \u0412 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u0430\u043A \u0434\u0440\u0443\u0433\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043F\u0438\u0441\u0430\u043B\u0438
    \u043E\u0431\u044A\u0451\u043C\u043D\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u044B,
    \u043F\u044B\u0442\u0430\u044F\u0441\u044C \u0440\u0435\u0448\u0438\u0442\u044C
    \u044D\u0442\u0443 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443, \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E,
    \u0437\u0430\u043D\u044F\u0432\u0448\u0435\u0435 \u0432\u0441\u0435\u0433\u043E
    **\u0447\u0435\u0442\u044B\u0440\u0435 \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u044B**.
    *   **\u041D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434:** \u041E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0442\u0435\u0445\u043D\u0438\u043A\u0443 \u0440\u0435\u0442\u0440\u0430\u043A\u0446\u0438\u0438
    \u0428\u0430\u0440\u0430\u0444\u0443\u0442\u0434\u0438\u043D\u043E\u0432\u0430,
    \u043F\u043E\u043A\u0430\u0437\u0430\u0432, \u0447\u0442\u043E \u043E\u043D\u0430
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0441\u0443\u0431\u043C\u0435\u0440\u0441\u0438\u0435\u0439,
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0432
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B
    \xAB\u0434\u0443\u0448\u0430\xBB \u043E\u0431\u044F\u0437\u0430\u043D\u0430 \u0431\u044B\u0442\u044C
    \u0442\u043E\u0447\u043A\u043E\u0439. *   **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435:**
    \u042D\u0442\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u043E
    \u0435\u0433\u043E \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0430\u043B\u0430\u043D\u0442 \u0432\u0438\u0434\u0435\u0442\u044C \u0441\u0443\u0442\u044C
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0438 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C
    \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E \u043F\u0440\u043E\u0441\u0442\u043E\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0442\u0430\u043C, \u0433\u0434\u0435
    \u0434\u0440\u0443\u0433\u0438\u0435 \u0432\u0438\u0434\u0435\u043B\u0438 \u043B\u0438\u0448\u044C
    \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u0438. 
    ### **2. \u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435:
    \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    (2002\u20132003)**  \u042D\u0442\u043E \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043C\u0438\u0440\u043E\u0432\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443. \u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435, \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u0432 1904 \u0433\u043E\u0434\u0443, \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    \u2014 \u043D\u0430\u0443\u043A\u0438 \u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\u0445
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432, \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u044E\u0449\u0438\u0445\u0441\u044F
    \u043F\u0440\u0438 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0445
    \u0434\u0435\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F\u0445. \u041E\u043D\u0430
    \u0437\u0432\u0443\u0447\u0438\u0442 \u0442\u0430\u043A: *\u0432\u0441\u044F\u043A\u043E\u0435
    \u043E\u0434\u043D\u043E\u0441\u0432\u044F\u0437\u043D\u043E\u0435 \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u043E\u0435
    \u0442\u0440\u0451\u0445\u043C\u0435\u0440\u043D\u043E\u0435 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0435
    \u0431\u0435\u0437 \u043A\u0440\u0430\u044F \u0433\u043E\u043C\u0435\u043E\u043C\u043E\u0440\u0444\u043D\u043E
    \u0442\u0440\u0451\u0445\u043C\u0435\u0440\u043D\u043E\u0439 \u0441\u0444\u0435\u0440\u0435*. 
    \u041F\u0440\u043E\u0441\u0442\u044B\u043C\u0438 \u0441\u043B\u043E\u0432\u0430\u043C\u0438:
    \u0435\u0441\u043B\u0438 \u0432\u0437\u044F\u0442\u044C \u043B\u044E\u0431\u043E\u0439
    \u0442\u0440\u0451\u0445\u043C\u0435\u0440\u043D\u044B\u0439 \u043E\u0431\u044A\u0435\u043A\u0442,
    \u0443 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043D\u0435\u0442 \u0434\u044B\u0440,
    \u0438 \u043B\u044E\u0431\u0443\u044E \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u0443\u044E
    \u043F\u0435\u0442\u043B\u044E \u043D\u0430 \u043D\u0451\u043C \u043C\u043E\u0436\u043D\u043E
    \u0441\u0442\u044F\u043D\u0443\u0442\u044C \u0432 \u0442\u043E\u0447\u043A\u0443,
    \u0442\u043E \u044D\u0442\u043E\u0442 \u043E\u0431\u044A\u0435\u043A\u0442 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u044D\u043A\u0432\u0438\u0432\u0430\u043B\u0435\u043D\u0442\u0435\u043D \u0442\u0440\u0451\u0445\u043C\u0435\u0440\u043D\u043E\u0439
    \u0441\u0444\u0435\u0440\u0435. \u042D\u0442\u0430 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u0431\u044B\u043B\u0430 \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0435\u043C\u0438
    \xAB\u0437\u0430\u0434\u0430\u0447 \u0442\u044B\u0441\u044F\u0447\u0435\u043B\u0435\u0442\u0438\u044F\xBB,
    \u0437\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u041A\u043B\u044D\u044F \u043D\u0430\u0437\u043D\u0430\u0447\u0438\u043B
    \u043F\u0440\u0435\u043C\u0438\u044E \u0432 **1 \u043C\u0438\u043B\u043B\u0438\u043E\u043D
    \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432**.  **\u0412\u043A\u043B\u0430\u0434
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0430:**  *   **\u0420\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u0430 \u043F\u043E\u0442\u043E\u043A\u0430 \u0420\u0438\u0447\u0447\u0438:**
    \u0418\u0441\u0445\u043E\u0434\u043D\u0443\u044E \u0438\u0434\u0435\u044E \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0420\u0438\u0447\u0430\u0440\u0434
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u0432 1981 \u0433\u043E\u0434\u0443.
    \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u043F\u043E\u0442\u043E\u043A\u0430 \u0420\u0438\u0447\u0447\u0438 \u2014 \u043F\u0440\u043E\u0446\u0435\u0441\u0441,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \xAB\u0441\u0433\u043B\u0430\u0436\u0438\u0432\u0430\u0435\u0442\xBB
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u044F,
    \u043F\u043E\u0434\u043E\u0431\u043D\u043E \u0442\u043E\u043C\u0443, \u043A\u0430\u043A
    \u0442\u0435\u043F\u043B\u043E \u0432\u044B\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u0435\u0442
    \u0442\u0435\u043C\u043F\u0435\u0440\u0430\u0442\u0443\u0440\u0443 \u0432 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0442\u0435\u043B\u0435. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u043D\u0430\u0434\u0435\u044F\u043B\u0441\u044F, \u0447\u0442\u043E \u044D\u0442\u043E\u0442
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0442
    \u043B\u044E\u0431\u043E\u0435 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0435
    \u0432 \u0441\u0444\u0435\u0440\u0443, \u043D\u043E \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F
    \u0441 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u043E\u0439 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \xAB\u0441\u0438\u043D\u0433\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u0435\u0439\xBB
    \u2014 \u043E\u0441\u043E\u0431\u044B\u0445 \u0442\u043E\u0447\u0435\u043A, \u0433\u0434\u0435
    \u043A\u0440\u0438\u0432\u0438\u0437\u043D\u0430 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0439, \u0438 \u043F\u0440\u043E\u0446\u0435\u0441\u0441
    \u043E\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442\u0441\u044F.
    *   **\u041C\u0435\u0442\u043E\u0434 \xAB\u0445\u0438\u0440\u0443\u0440\u0433\u0438\u0438\xBB:**
    \u0413\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0430
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C \u0432 \u0442\u043E\u043C,
    \u0447\u0442\u043E \u043E\u043D \u043D\u0430\u0448\u0451\u043B \u0441\u043F\u043E\u0441\u043E\u0431
    \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u044D\u0442\u0438 \u0441\u0438\u043D\u0433\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u0438.
    \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0442\u0435\u0445\u043D\u0438\u043A\u0443
    **\xAB\u043F\u043E\u0442\u043E\u043A\u0430 \u0420\u0438\u0447\u0447\u0438 \u0441
    \u0445\u0438\u0440\u0443\u0440\u0433\u0438\u0435\u0439\xBB**: \u043F\u0440\u0438
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u0438 \u043A \u0441\u0438\u043D\u0433\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u0438
    \u043E\u043D \u043E\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u043B
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441, \xAB\u0432\u044B\u0440\u0435\u0437\u0430\u043B\xBB
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u043D\u0443\u044E \u043E\u0431\u043B\u0430\u0441\u0442\u044C
    (\u0441\u0438\u043D\u0433\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u044C)
    \u0438 \u0430\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u043E \xAB\u0441\u0448\u0438\u0432\u0430\u043B\xBB
    \u043A\u0440\u0430\u044F, \u043F\u043E\u0441\u043B\u0435 \u0447\u0435\u0433\u043E
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u044D\u0432\u043E\u043B\u044E\u0446\u0438\u044E.
    *   **\u041D\u043E\u0432\u044B\u0435 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B:** \u0414\u043B\u044F
    \u0441\u0442\u0440\u043E\u0433\u043E\u0433\u043E \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u0441\u0432\u043E\u0435\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u0430 \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u0432\u0432\u0451\u043B \u043D\u043E\u0432\u044B\u0435 \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438,
    \u0442\u0430\u043A\u0438\u0435 \u043A\u0430\u043A **\xAB\u044D\u043D\u0442\u0440\u043E\u043F\u0438\u044F
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0430\xBB** \u0438 **\u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B
    F**. \u042D\u0442\u0438 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
    \u0447\u0442\u043E \u043F\u0440\u043E\u0446\u0435\u0441\u0441 \u043D\u0435 \u043C\u043E\u0436\u0435\u0442
    \u0434\u043B\u0438\u0442\u044C\u0441\u044F \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E
    \u0438 \u0432 \u0438\u0442\u043E\u0433\u0435 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0435
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F \u0432
    \u0442\u0440\u0451\u0445\u043C\u0435\u0440\u043D\u0443\u044E \u0441\u0444\u0435\u0440\u0443.
    *   **\u0424\u043E\u0440\u043C\u0430 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438:**
    \u041E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u043D\u0435 \u0432
    \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u043C \u0440\u0435\u0446\u0435\u043D\u0437\u0438\u0440\u0443\u0435\u043C\u043E\u043C
    \u0436\u0443\u0440\u043D\u0430\u043B\u0435, \u0430 \u0432 \u0432\u0438\u0434\u0435
    \u0442\u0440\u0451\u0445 \u043F\u0440\u0435\u043F\u0440\u0438\u043D\u0442\u043E\u0432
    \u043D\u0430 \u0441\u0430\u0439\u0442\u0435 **arXiv.org** \u0432 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0441 \u043D\u043E\u044F\u0431\u0440\u044F 2002 \u043F\u043E \u0438\u044E\u043B\u044C
    2003 \u0433\u043E\u0434\u0430. \u0422\u0435\u043A\u0441\u0442 \u0431\u044B\u043B
    \u043A\u0440\u0430\u0439\u043D\u0435 \u0441\u0436\u0430\u0442\u044B\u043C \u0438
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B \u043B\u0438\u0448\u044C \u043E\u0431\u0449\u0443\u044E
    \u0441\u0445\u0435\u043C\u0443 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430,
    \u0447\u0442\u043E \u0432\u044B\u0437\u0432\u0430\u043B\u043E \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u044C
    \u0432 \u0435\u0433\u043E \u0442\u0449\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0435 \u043C\u0438\u0440\u043E\u0432\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E\u043C.  ### **\u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0438 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B** 
    *   **\u041F\u0440\u043E\u0432\u0435\u0440\u043A\u0430 \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435:**
    \u041A 2006 \u0433\u043E\u0434\u0443 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u044B\u0445 \u0433\u0440\u0443\u043F\u043F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u043B\u0438
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0430, \u043D\u0435 \u043D\u0430\u0439\u0434\u044F
    \u0432 \u043D\u0451\u043C \u043E\u0448\u0438\u0431\u043E\u043A, \u0438 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u043B\u0438
    \u0435\u0433\u043E \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u043E\u0441\u0442\u044C.
    *   **\u041D\u0430\u0443\u0447\u043D\u044B\u0439 \u043F\u0440\u043E\u0440\u044B\u0432
    \u0433\u043E\u0434\u0430:** \u0412 2006 \u0433\u043E\u0434\u0443 \u0436\u0443\u0440\u043D\u0430\u043B
    **Science** \u043D\u0430\u0437\u0432\u0430\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u043D\u0430\u0443\u0447\u043D\u044B\u043C
    \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u043C \u0433\u043E\u0434\u0430. \u042D\u0442\u043E
    \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439,
    \u043A\u043E\u0433\u0434\u0430 \u0442\u0430\u043A\u0430\u044F \u043D\u0430\u0433\u0440\u0430\u0434\u0430
    \u0431\u044B\u043B\u0430 \u043F\u0440\u0438\u0441\u0443\u0436\u0434\u0435\u043D\u0430
    \u0437\u0430 \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    *   **\u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0430\u044F \u043F\u0440\u0435\u043C\u0438\u044F
    (2006):** \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0443 \u0431\u044B\u043B\u0430
    \u043F\u0440\u0438\u0441\u0443\u0436\u0434\u0435\u043D\u0430 \u0432\u044B\u0441\u0448\u0430\u044F
    \u043D\u0430\u0433\u0440\u0430\u0434\u0430 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u2014 \u043C\u0435\u0434\u0430\u043B\u044C \u0424\u0438\u043B\u0434\u0441\u0430,
    \u043D\u043E \u043E\u043D \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0435\u0451 \u043F\u0440\u0438\u043D\u044F\u0442\u044C. *   **\u041F\u0440\u0435\u043C\u0438\u044F
    \u0442\u044B\u0441\u044F\u0447\u0435\u043B\u0435\u0442\u0438\u044F (2010):**
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u041A\u043B\u044D\u044F \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u043F\u0440\u0438\u0441\u0443\u0434\u0438\u043B \u0435\u043C\u0443 \u043F\u0440\u0435\u043C\u0438\u044E
    \u0432 1 \u043C\u0438\u043B\u043B\u0438\u043E\u043D \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432
    \u0437\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B
    \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435. \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0438 \u043E\u0442 \u044D\u0442\u043E\u0439
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B, \u0437\u0430\u044F\u0432\u0438\u0432,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u0432 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043D\u0435 \u0431\u043E\u043B\u044C\u0448\u0435, \u0447\u0435\u043C \u0432\u043A\u043B\u0430\u0434
    \u0420\u0438\u0447\u0430\u0440\u0434\u0430 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430. 
    **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435:** \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0441\u0442\u0430\u043B\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435\u043C \u0441\u0442\u043E\u043B\u0435\u0442\u043D\u0435\u0439
    \u0437\u0430\u0434\u0430\u0447\u0438. \u041E\u043D\u043E **\u0437\u0430\u043A\u0440\u044B\u043B\u043E
    \u0446\u0435\u043B\u0443\u044E \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438**,
    \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u0443\u044E \u0441 \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0435\u0439
    \u0442\u0440\u0451\u0445\u043C\u0435\u0440\u043D\u044B\u0445 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439,
    \u0438 \u043E\u0442\u043A\u0440\u044B\u043B\u043E \u043D\u043E\u0432\u044B\u0435
    \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u044B \u0434\u043B\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u043C\u0435\u0442\u043E\u0434\u0430 \u043F\u043E\u0442\u043E\u043A\u0430 \u0420\u0438\u0447\u0447\u0438
    \u0432 \u0441\u043C\u0435\u0436\u043D\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445."
  achievementsEn: 
  personalLifeRu: "\u041F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0441\u0442\u0435\u0439
    \u043E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438 \u0413\u0440\u0438\u0433\u043E\u0440\u0438\u044F
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0430 \u043E\u0447\u0435\u043D\u044C
    \u043C\u0430\u043B\u043E, \u0438 \u0432\u0441\u0435 \u043E\u043D\u0438 \u0432\u0437\u044F\u0442\u044B
    \u0438\u0437 \u043A\u043E\u0441\u0432\u0435\u043D\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u0432
    \u2014 \u0440\u0435\u0434\u043A\u0438\u0445 \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u0439
    \u0441\u043E\u0441\u0435\u0434\u0435\u0439 \u0438 \u043F\u0440\u043E\u0434\u0430\u0432\u0446\u043E\u0432,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0441\u043B\u0443\u0445\u043E\u0432. \u0421\u0430\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u043F\u043E\u0447\u0442\u0438
    \u043D\u0435 \u043E\u0431\u0449\u0430\u0435\u0442\u0441\u044F \u0441 \u0432\u043D\u0435\u0448\u043D\u0438\u043C
    \u043C\u0438\u0440\u043E\u043C \u0438 \u043D\u0435 \u0434\u0430\u0435\u0442 \u0438\u043D\u0442\u0435\u0440\u0432\u044C\u044E.
    \u0412\u043E\u0442 \u0447\u0442\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E. 
    ### \u0421\u0435\u043C\u044C\u044F \u0438 \u0431\u043B\u0438\u0437\u043A\u0438\u0435 
    \u0413\u0440\u0438\u0433\u043E\u0440\u0438\u0439 \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u043D\u0435 \u0436\u0435\u043D\u0430\u0442 \u0438 \u043D\u0435 \u0438\u043C\u0435\u0435\u0442
    \u0434\u0435\u0442\u0435\u0439. \u0412\u0441\u044E \u0441\u0432\u043E\u044E \u0441\u043E\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u043E\u043D \u043F\u0440\u043E\u0436\u0438\u0432\u0430\u0435\u0442
    \u0441\u043E \u0441\u0432\u043E\u0435\u0439 \u043C\u0430\u0442\u0435\u0440\u044C\u044E,
    \u041B\u044E\u0431\u043E\u0432\u044C\u044E \u041B\u0435\u0439\u0431\u043E\u0432\u043D\u043E\u0439
    \u0428\u0442\u0435\u0439\u043D\u0433\u043E\u043B\u044C\u0446, \u043A\u043E\u0442\u043E\u0440\u0430\u044F,
    \u043F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0434\u0430\u043D\u043D\u044B\u043C,
    \u0441\u0435\u0439\u0447\u0430\u0441 \u0441\u0442\u0430\u0440\u0448\u0435 90
    \u043B\u0435\u0442 \u0438 \u043D\u0443\u0436\u0434\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0443\u0445\u043E\u0434\u0435.  *   **\u041E\u0442\u0435\u0446, \u042F\u043A\u043E\u0432
    \u041D\u0430\u0443\u043C\u043E\u0432\u0438\u0447**, \u0431\u044B\u043B \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C-\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u043A\u043E\u043C.
    \u0412 1993 \u0433\u043E\u0434\u0443 \u043E\u043D \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u0432 \u0418\u0437\u0440\u0430\u0438\u043B\u044C \u0438 \u043F\u043E\u0440\u0432\u0430\u043B
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0441\u0435\u043C\u044C\u0435\u0439,
    \u0447\u0442\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u0447\u0438\u0442\u0430\u044E\u0442
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439 \u043B\u0438\u0447\u043D\u043E\u0439
    \u0442\u0440\u0430\u0432\u043C\u043E\u0439 \u0434\u043B\u044F \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0430.
    \u041F\u043E\u0437\u0436\u0435 \u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u043E\u0442 \u0440\u0430\u043A\u0430. *   **\u041C\u0430\u0442\u044C, \u041B\u044E\u0431\u043E\u0432\u044C
    \u041B\u0435\u0439\u0431\u043E\u0432\u043D\u0430**, \u2014 \u0431\u044B\u0432\u0448\u0430\u044F
    \u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u0438\u0432\u0438\u043B\u0430
    \u0441\u044B\u043D\u0443 \u043B\u044E\u0431\u043E\u0432\u044C \u043A \u0442\u043E\u0447\u043D\u044B\u043C
    \u043D\u0430\u0443\u043A\u0430\u043C \u0438 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0443\u0437\u044B\u043A\u0435. \u041F\u043E \u0441\u043B\u043E\u0432\u0430\u043C
    \u0441\u043E\u0441\u0435\u0434\u0435\u0439, \u0413\u0440\u0438\u0433\u043E\u0440\u0438\u0439
    \u0437\u0430\u0431\u043E\u0442\u0438\u0442\u0441\u044F \u043E \u043D\u0435\u0439
    \u0438 \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u043E\u0442 \u043F\u043E\u043C\u043E\u0449\u0438 \u0441\u043E\u0446\u0441\u043B\u0443\u0436\u0431.
    *   **\u0421\u0435\u0441\u0442\u0440\u0430, \u0415\u043B\u0435\u043D\u0430**,
    \u0442\u0430\u043A\u0436\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C. \u041E\u043D\u0430
    \u043E\u043A\u043E\u043D\u0447\u0438\u043B\u0430 \u0421\u0430\u043D\u043A\u0442-\u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u0437\u0430\u0449\u0438\u0442\u0438\u043B\u0430
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u0432 \u0418\u0437\u0440\u0430\u0438\u043B\u0435,
    \u0430 \u0441 2007 \u0433\u043E\u0434\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0438\u0441\u0442\u043E\u043C
    \u0432 \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C\u0435. \u0421\u0432\u044F\u0437\u044C
    \u0441 \u0431\u0440\u0430\u0442\u043E\u043C, \u0441\u043A\u043E\u0440\u0435\u0435
    \u0432\u0441\u0435\u0433\u043E, \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u0440\u0435\u0434\u043A\u043E.  ### \u041E\u0431\u0440\u0430\u0437 \u0436\u0438\u0437\u043D\u0438
    \u0438 \u0431\u044B\u0442 \u0441\u0435\u0433\u043E\u0434\u043D\u044F  \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u0432\u0435\u0434\u0435\u0442 \u0430\u0441\u043A\u0435\u0442\u0438\u0447\u043D\u044B\u0439
    \u043E\u0431\u0440\u0430\u0437 \u0436\u0438\u0437\u043D\u0438, \u0433\u0440\u0430\u043D\u0438\u0447\u0430\u0449\u0438\u0439
    \u0441 \u0437\u0430\u0442\u0432\u043E\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E\u043C.
    \u041E\u043D \u0436\u0438\u0432\u0435\u0442 \u0432 \u043E\u0431\u044B\u0447\u043D\u043E\u0439
    \u043F\u0430\u043D\u0435\u043B\u044C\u043D\u043E\u0439 \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435
    \u0432 \u0441\u043F\u0430\u043B\u044C\u043D\u043E\u043C \u0440\u0430\u0439\u043E\u043D\u0435
    \u0421\u0430\u043D\u043A\u0442-\u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0430
    \u2014 \u041A\u0443\u043F\u0447\u0438\u043D\u043E.  *   **\u041F\u0438\u0442\u0430\u043D\u0438\u0435
    \u0438 \u043F\u043E\u043A\u0443\u043F\u043A\u0438:** \u041E\u043D \u043F\u043E\u043A\u0443\u043F\u0430\u0435\u0442
    \u0441\u0430\u043C\u044B\u0435 \u0434\u0435\u0448\u0435\u0432\u044B\u0435 \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u044B:
    \u0432\u0435\u0440\u043C\u0438\u0448\u0435\u043B\u044C, \u0442\u0432\u043E\u0440\u043E\u0433,
    \u044F\u0431\u043B\u043E\u043A\u0438, \u043A\u0440\u0443\u043F\u044B \u0438 \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u044B.
    *   **\u041E\u0434\u0435\u0436\u0434\u0430:** \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u043E\u0434\u0435\u0432\u0430\u0435\u0442\u0441\u044F \u043A\u0440\u0430\u0439\u043D\u0435
    \u0441\u043A\u0440\u043E\u043C\u043D\u043E \u0438 \u043D\u0435 \u0441\u043B\u0435\u0434\u0438\u0442
    \u0437\u0430 \u0441\u0435\u0437\u043E\u043D\u0430\u043C\u0438. \u0421\u043E\u043E\u0431\u0449\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0434\u043E\u043D\u0430\u0448\u0438\u0432\u0430\u0435\u0442
    \u043E\u0434\u0435\u0436\u0434\u0443 \u0441\u0432\u043E\u0435\u0433\u043E \u043F\u043E\u043A\u043E\u0439\u043D\u043E\u0433\u043E
    \u043E\u0442\u0446\u0430, \u0430 \u0435\u0433\u043E \u0432\u0438\u0437\u0438\u0442\u043D\u0430\u044F
    \u043A\u0430\u0440\u0442\u043E\u0447\u043A\u0430 \u2014 \u0440\u0435\u0437\u0438\u043D\u043E\u0432\u044B\u0435
    \u0433\u0430\u043B\u043E\u0448\u0438 \u0438 \u043F\u043E\u0442\u0435\u0440\u0442\u044B\u0435
    \u0431\u0440\u044E\u043A\u0438. *   **\u041E\u0431\u0449\u0435\u043D\u0438\u0435:**
    \u041E\u043D \u0441\u0442\u043E\u0440\u043E\u043D\u0438\u0442\u0441\u044F \u043B\u044E\u0434\u0435\u0439,
    \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u044F\u0441\u044C
    \u043B\u0438\u0448\u044C \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u043C\u0438
    \u043F\u0440\u0438\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u044F\u043C\u0438
    \u0441 \u0441\u043E\u0441\u0435\u0434\u044F\u043C\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0437\u043D\u0430\u044E\u0442 \u0435\u0433\u043E \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430.
    \u0412 \u043C\u0430\u0433\u0430\u0437\u0438\u043D\u0430\u0445 \u0438 \u043D\u0430
    \u0443\u043B\u0438\u0446\u0435 \u043E\u043D \u043F\u0440\u043E\u0441\u0438\u0442
    \u0436\u0443\u0440\u043D\u0430\u043B\u0438\u0441\u0442\u043E\u0432 \u0438 \u043D\u0430\u0437\u043E\u0439\u043B\u0438\u0432\u044B\u0445
    \u043F\u0440\u043E\u0445\u043E\u0436\u0438\u0445 \u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0435\u0433\u043E \u0432 \u043F\u043E\u043A\u043E\u0435.  ### \u0421\u043B\u0443\u0445\u0438
    \u0438 \u0438\u0445 \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0436\u0435\u043D\u0438\u0435 
    \u0417\u0430\u0442\u0432\u043E\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0430 \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0441\u043B\u0443\u0445\u043E\u0432.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0432 \u0441\u043E\u0446\u0441\u0435\u0442\u044F\u0445
    \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u043B\u0430\u0441\u044C
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F \u043E \u0442\u043E\u043C,
    \u0447\u0442\u043E \u043E\u043D \xAB\u043F\u043E\u0433\u0438\u0431\u0430\u0435\u0442
    \u0432 \u043D\u0438\u0449\u0435\u0442\u0435\xBB. \u0417\u043D\u0430\u043A\u043E\u043C\u044B\u0435
    \u0438 \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u043D\u0438\u043A\u0438,
    \u043E\u0434\u043D\u0430\u043A\u043E, \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u0430\u044E\u0442
    \u044D\u0442\u043E, \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0432\u0441\u0435\u0433\u0434\u0430 \u0432\u0435\u043B
    \u0442\u0430\u043A\u043E\u0439 \u043E\u0431\u0440\u0430\u0437 \u0436\u0438\u0437\u043D\u0438,
    \u0430 \u0435\u0433\u043E \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u043E\u0435
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u043D\u0435 \u0441\u0442\u043E\u043B\u044C
    \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\u0438\u0447\u043D\u043E,
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0430\u043B \u0434\u0435\u043D\u044C\u0433\u0438
    \u0437\u0430 \u043B\u0435\u043A\u0446\u0438\u0438. \u0422\u0430\u043A\u0436\u0435
    \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u044B \u0441\u043B\u0443\u0445\u0438
    \u043E \u0435\u0433\u043E \u043F\u0435\u0440\u0435\u0435\u0437\u0434\u0435 \u0432
    \u0428\u0432\u0435\u0446\u0438\u044E."
  personalLifeEn: 
  shortBioRu: "\u0413\u0440\u0438\u0433\u043E\u0440\u0438\u0439 \u042F\u043A\u043E\u0432\u043B\u0435\u0432\u0438\u0447
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D \u2014 \u0440\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0434\u043E\u043A\u0430\u0437\u0430\u0432\u0448\u0438\u0439
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435,
    \u043E\u0434\u043D\u0443 \u0438\u0437 \u0441\u0435\u043C\u0438 \xAB\u0437\u0430\u0434\u0430\u0447
    \u0442\u044B\u0441\u044F\u0447\u0435\u043B\u0435\u0442\u0438\u044F\xBB. \u041E\u043D
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0432\u043E\u0438\u043C \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0432\u043A\u043B\u0430\u0434\u043E\u043C \u0432 \u043D\u0430\u0443\u043A\u0443,
    \u043D\u043E \u0438 \u043A\u0440\u0430\u0439\u043D\u0435 \u0430\u0441\u043A\u0435\u0442\u0438\u0447\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0436\u0438\u0437\u043D\u0438, \u0430
    \u0442\u0430\u043A\u0436\u0435 \u043E\u0442\u043A\u0430\u0437\u043E\u043C \u043E\u0442
    \u0432\u0441\u0435\u0445 \u043A\u0440\u0443\u043F\u043D\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0435\u043C\u0438\u0439 \u0438 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0434\u0435\u043D\u0435\u0436\u043D\u044B\u0445 \u0432\u043E\u0437\u043D\u0430\u0433\u0440\u0430\u0436\u0434\u0435\u043D\u0438\u0439. 
    ### **\u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0432\u0435\u0445\u0438
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438**  - **\u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u044E\u043D\u043E\u0441\u0442\u044C:** \u0413\u0440\u0438\u0433\u043E\u0440\u0438\u0439
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    13 \u0438\u044E\u043D\u044F 1966 \u0433\u043E\u0434\u0430 \u0432 \u041B\u0435\u043D\u0438\u043D\u0433\u0440\u0430\u0434\u0435
    \u0432 \u0438\u043D\u0442\u0435\u043B\u043B\u0438\u0433\u0435\u043D\u0442\u043D\u043E\u0439
    \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0439 \u0441\u0435\u043C\u044C\u0435.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446 \u0431\u044B\u043B \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C-\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u043A\u043E\u043C,
    \u043C\u0430\u0442\u044C \u2014 \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0421 \u0440\u0430\u043D\u043D\u0438\u0445
    \u043B\u0435\u0442 \u043C\u0430\u0442\u044C \u043F\u0440\u0438\u0432\u0438\u043B\u0430
    \u0435\u043C\u0443 \u043B\u044E\u0431\u043E\u0432\u044C \u043A \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0443\u0437\u044B\u043A\u0435, \u0430 \u043E\u0442\u0435\u0446 \u043F\u043E\u043E\u0449\u0440\u044F\u043B
    \u0437\u0430\u043D\u044F\u0442\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u0438 \u0448\u0430\u0445\u043C\u0430\u0442\u0430\u043C\u0438.  - **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:**
    \u0412 5-\u043C \u043A\u043B\u0430\u0441\u0441\u0435 \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u043D\u0430\u0447\u0430\u043B \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 \u043F\u0440\u0438 \u0414\u0432\u043E\u0440\u0446\u0435
    \u043F\u0438\u043E\u043D\u0435\u0440\u043E\u0432. \u041F\u043E\u0441\u043B\u0435
    8-\u0433\u043E \u043A\u043B\u0430\u0441\u0441\u0430 \u043E\u043D \u043F\u0435\u0440\u0435\u0448\u0435\u043B
    \u0432 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0443\u044E
    \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u2116 239. \u0412 1982 \u0433\u043E\u0434\u0443
    \u0432 \u0441\u043E\u0441\u0442\u0430\u0432\u0435 \u0441\u0431\u043E\u0440\u043D\u043E\u0439
    \u0421\u0421\u0421\u0420 \u043E\u043D \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u043B
    \u0437\u043E\u043B\u043E\u0442\u0443\u044E \u043C\u0435\u0434\u0430\u043B\u044C
    \u043D\u0430 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u043B\u0438\u043C\u043F\u0438\u0430\u0434\u0435 \u0432 \u0411\u0443\u0434\u0430\u043F\u0435\u0448\u0442\u0435,
    \u043F\u043E\u043B\u0443\u0447\u0438\u0432 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u0439
    \u0431\u0430\u043B\u043B \u0437\u0430 \u0431\u0435\u0437\u0443\u043A\u043E\u0440\u0438\u0437\u043D\u0435\u043D\u043D\u043E\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0432\u0441\u0435\u0445 \u0437\u0430\u0434\u0430\u0447.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0443\u044E
    \u0443\u0447\u0435\u0431\u0443, \u0448\u043A\u043E\u043B\u0443 \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u0431\u0435\u0437 \u0437\u043E\u043B\u043E\u0442\u043E\u0439
    \u043C\u0435\u0434\u0430\u043B\u0438 \u0438\u0437-\u0437\u0430 \u043D\u0435\u0441\u0434\u0430\u043D\u043D\u044B\u0445
    \u043D\u043E\u0440\u043C\u0430\u0442\u0438\u0432\u043E\u0432 \u0413\u0422\u041E
    \u043F\u043E \u0444\u0438\u0437\u043A\u0443\u043B\u044C\u0442\u0443\u0440\u0435. 
    - **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0438
    \u043D\u0430\u0447\u0430\u043B\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B:**
    \u0412 1982 \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B \u0437\u0430\u0447\u0438\u0441\u043B\u0435\u043D
    \u0431\u0435\u0437 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u043E\u0432 \u043D\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E-\u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442 \u041B\u0413\u0423, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u0441 \u043E\u0442\u043B\u0438\u0447\u0438\u0435\u043C.
    \u0417\u0430\u0442\u0435\u043C \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u0443\u0440\u0443 \u043F\u0440\u0438
    \u041B\u0435\u043D\u0438\u043D\u0433\u0440\u0430\u0434\u0441\u043A\u043E\u043C
    \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u0438 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 \u0438\u043C. \u0412.
    \u0410. \u0421\u0442\u0435\u043A\u043B\u043E\u0432\u0430 (\u041F\u041E\u041C\u0418).
    \u0412 1990 \u0433\u043E\u0434\u0443 \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u0430 \u0410.\u0414. \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u0432\u0430
    \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E, \u043F\u043E\u0441\u043B\u0435
    \u0447\u0435\u0433\u043E \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435
    \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0441\u0442\u0430\u0440\u0448\u0435\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u0430. 
    ### **\u041D\u0430\u0443\u0447\u043D\u0430\u044F \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435** 
    - **\u0420\u0430\u0431\u043E\u0442\u0430 \u0432 \u0421\u0428\u0410:** \u0412
    \u043D\u0430\u0447\u0430\u043B\u0435 1990-\u0445 \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 \u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\u0445
    \u0421\u0428\u0410: \u041D\u044C\u044E-\u0419\u043E\u0440\u043A\u0441\u043A\u043E\u043C,
    \u0421\u0442\u043E\u043D\u0438-\u0411\u0440\u0443\u043A \u0438 \u0411\u0435\u0440\u043A\u043B\u0438.
    \u0412 1994 \u0433\u043E\u0434\u0443 \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0442\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u0443\u044E
    \xAB\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443 \u043E \u0434\u0443\u0448\u0435\xBB
    \u0432 \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u044B\u043C
    \u0432\u0430\u0436\u043D\u044B\u043C \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C.
    \u0412 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F \u0441
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u0420\u0438\u0447\u0430\u0440\u0434\u043E\u043C
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u043E\u043C, \u0447\u044C\u0438
    \u0438\u0434\u0435\u0438 \u043E \u043F\u043E\u0442\u043E\u043A\u0435 \u0420\u0438\u0447\u0447\u0438
    \u043B\u0435\u0433\u043B\u0438 \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0435\u0433\u043E
    \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E \u043F\u0440\u043E\u0440\u044B\u0432\u0430.
    \u0412 1995 \u0433\u043E\u0434\u0443 \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u0432 \u0421\u0430\u043D\u043A\u0442-\u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433. 
    - **\u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435:**
    \u0421 \u043D\u043E\u044F\u0431\u0440\u044F 2002 \u043F\u043E \u0438\u044E\u043B\u044C
    2003 \u0433\u043E\u0434\u0430 \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0442\u0440\u0438
    \u0441\u0442\u0430\u0442\u044C\u0438 \u043D\u0430 \u0441\u0430\u0439\u0442\u0435
    arXiv.org, \u0433\u0434\u0435 \u0432 \u0441\u0436\u0430\u0442\u043E\u0439 \u0444\u043E\u0440\u043C\u0435
    \u0438\u0437\u043B\u043E\u0436\u0438\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435.
    \u042D\u0442\u0430 \u0437\u0430\u0434\u0430\u0447\u0430, \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435 \u0432
    1904 \u0433\u043E\u0434\u0443, \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u0432 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438.
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D \u0440\u0430\u0437\u0432\u0438\u043B
    \u043C\u0435\u0442\u043E\u0434 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    (\u0442\u0435\u043E\u0440\u0438\u044F \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430\u2014\u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0430),
    \u0447\u0442\u043E\u0431\u044B \u0440\u0435\u0448\u0438\u0442\u044C \u044D\u0442\u0443
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443. \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0431\u044B\u043B\u043E \u043F\u0440\u043E\u0432\u0435\u0440\u0435\u043D\u043E
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u043C\u0438 \u0433\u0440\u0443\u043F\u043F\u0430\u043C\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0438 \u043A
    2006 \u0433\u043E\u0434\u0443 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043E
    \u0432\u0435\u0440\u043D\u044B\u043C.  - **\u0423\u0445\u043E\u0434 \u0438\u0437
    \u043D\u0430\u0443\u043A\u0438:** \u0412 \u0434\u0435\u043A\u0430\u0431\u0440\u0435
    2005 \u0433\u043E\u0434\u0430, \u043F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E
    \u043A\u0430\u043A \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430
    \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C,
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D \u0443\u0432\u043E\u043B\u0438\u043B\u0441\u044F
    \u0438\u0437 \u041F\u041E\u041C\u0418 \u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043F\u0440\u0435\u043A\u0440\u0430\u0442\u0438\u043B
    \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u044B \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438,
    \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0432 \u044D\u0442\u043E \u043D\u0435\u0441\u043E\u0433\u043B\u0430\u0441\u0438\u0435\u043C
    \u0441 \u044D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438 \u043D\u043E\u0440\u043C\u0430\u043C\u0438
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435.  ### **\u041E\u0442\u043A\u0430\u0437\u044B
    \u043E\u0442 \u043F\u0440\u0435\u043C\u0438\u0439**  - **\u041F\u0440\u0435\u043C\u0438\u044F
    \u0415\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 (1996):** \u041E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u043D\u0435\u0451. - **\u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F (2006):** \u042D\u0442\u043E \u0432\u044B\u0441\u0448\u0430\u044F
    \u043D\u0430\u0433\u0440\u0430\u0434\u0430 \u0434\u043B\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0443
    \u043F\u0440\u0438\u0441\u0443\u0434\u0438\u043B\u0438 \u0437\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435.
    \u041E\u043D \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0435\u0451
    \u043F\u0440\u0438\u043D\u044F\u0442\u044C, \u0438 \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442
    \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u044E\u0437\u0430 \u043B\u0438\u0447\u043D\u043E \u043F\u0440\u0438\u0435\u0437\u0436\u0430\u043B
    \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433, \u0447\u0442\u043E\u0431\u044B
    \u0443\u0431\u0435\u0434\u0438\u0442\u044C \u0435\u0433\u043E, \u043D\u043E \u0431\u0435\u0437\u0443\u0441\u043F\u0435\u0448\u043D\u043E.
    - **\u041F\u0440\u0435\u043C\u0438\u044F \u0442\u044B\u0441\u044F\u0447\u0435\u043B\u0435\u0442\u0438\u044F
    (2010):** \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u041A\u043B\u044D\u044F \u043F\u0440\u0438\u0441\u0443\u0434\u0438\u043B
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0443 \u043F\u0440\u0435\u043C\u0438\u044E
    \u0432 1 \u043C\u0438\u043B\u043B\u0438\u043E\u043D \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432
    \u0437\u0430 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435.
    \u0412 \u0438\u044E\u043B\u0435 2010 \u0433\u043E\u0434\u0430 \u043E\u043D \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u043E\u0442 \u043D\u0430\u0433\u0440\u0430\u0434\u044B.
    \u0413\u043B\u0430\u0432\u043D\u043E\u0439 \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439
    \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B \u043D\u0435\u0441\u043E\u0433\u043B\u0430\u0441\u0438\u0435
    \u0441 \u0440\u0435\u0448\u0435\u043D\u0438\u044F\u043C\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430, \u0441\u0447\u0438\u0442\u0430\u044F,
    \u0447\u0442\u043E \u0432\u043A\u043B\u0430\u0434 \u0420\u0438\u0447\u0430\u0440\u0434\u0430
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430 \u0431\u044B\u043B
    \u043D\u0435 \u043C\u0435\u043D\u044C\u0448\u0438\u043C, \u0447\u0435\u043C \u0435\u0433\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439.  ### **\u041D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0435
    \u0432\u0440\u0435\u043C\u044F**  \u041F\u043E\u0441\u043B\u0435 \u0443\u0432\u043E\u043B\u044C\u043D\u0435\u043D\u0438\u044F
    \u0438\u0437 \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 \u0413\u0440\u0438\u0433\u043E\u0440\u0438\u0439
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D \u0432\u0435\u0434\u0435\u0442
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0439, \u043F\u043E\u0447\u0442\u0438
    \u0437\u0430\u0442\u0432\u043E\u0440\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043E\u0431\u0440\u0430\u0437 \u0436\u0438\u0437\u043D\u0438. \u041E\u043D \u0436\u0438\u0432\u0435\u0442
    \u0441 \u043C\u0430\u0442\u0435\u0440\u044C\u044E \u0432 \u043E\u0431\u044B\u0447\u043D\u043E\u0439
    \u043F\u0430\u043D\u0435\u043B\u044C\u043D\u043E\u0439 \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435
    \u0432 \u043F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u043C
    \u0440\u0430\u0439\u043E\u043D\u0435 \u041A\u0443\u043F\u0447\u0438\u043D\u043E.
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438\u0437\u0431\u0435\u0433\u0430\u0435\u0442
    \u043E\u0431\u0449\u0435\u043D\u0438\u044F \u0441 \u0436\u0443\u0440\u043D\u0430\u043B\u0438\u0441\u0442\u0430\u043C\u0438
    \u0438 \u0441\u043E\u0441\u0435\u0434\u044F\u043C\u0438, \u0432\u0435\u0434\u0435\u0442
    \u0430\u0441\u043A\u0435\u0442\u0438\u0447\u043D\u044B\u0439 \u0431\u044B\u0442.
    \u041F\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044E \u043D\u0430
    2011 \u0433\u043E\u0434, \u043E\u043D \u0442\u0430\u043A\u0436\u0435 \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u0441\u0442\u0430\u0442\u044C \u0447\u043B\u0435\u043D\u043E\u043C \u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A."
  shortBioEn: 
  interestingFactsRu: "\u041F\u043E\u043C\u0438\u043C\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0443\u043C\u0430, \u0413\u0440\u0438\u0433\u043E\u0440\u0438\u0439 \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u0441\u0432\u043E\u0438\u043C
    \u043A\u0440\u0430\u0439\u043D\u0435 \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u043C
    \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435\u043C, \u0430\u0441\u043A\u0435\u0442\u0438\u0437\u043C\u043E\u043C
    \u0438 \u043F\u043E\u043B\u043D\u044B\u043C \u0440\u0430\u0432\u043D\u043E\u0434\u0443\u0448\u0438\u0435\u043C
    \u043A \u043C\u0438\u0440\u0441\u043A\u043E\u0439 \u0441\u043B\u0430\u0432\u0435.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u043F\u043E\u043B\u043D\u0430
    \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u043E\u0432 \u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u043A\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043E \u0442\u043E\u043C, \u043A\u0430\u043A\u0438\u043C \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u0433\u0435\u043D\u0438\u0439.  ### \U0001F4DA \u041D\u0435\u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u0445 \u0437\u0430\u0441\u043B\u0443\u0433:
    \"\u041F\u0440\u043E\u0432\u0430\u043B\" \u043D\u0430 \u0444\u0438\u0437\u043A\u0443\u043B\u044C\u0442\u0443\u0440\u0435 
    \u041F\u043E\u0436\u0430\u043B\u0443\u0439, \u043E\u0434\u0438\u043D \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0430 \u2014 \u044D\u0442\u043E
    \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435 \u0437\u043E\u043B\u043E\u0442\u043E\u0439
    \u043C\u0435\u0434\u0430\u043B\u0438. \u041E\u043D \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u2116239 \u0441 \u043E\u0442\u043B\u0438\u0447\u043D\u044B\u043C\u0438
    \u043E\u0446\u0435\u043D\u043A\u0430\u043C\u0438 \u043F\u043E \u0432\u0441\u0435\u043C
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430\u043C, \u043D\u043E \u0442\u0430\u043A
    \u0438 \u043D\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0437\u0430\u0432\u0435\u0442\u043D\u0443\u044E
    \u043C\u0435\u0434\u0430\u043B\u044C. \u041F\u0440\u0438\u0447\u0438\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0434\u0430\u043B\u0435\u043A\u0430 \u043E\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438:
    \u043E\u043D \u043D\u0435 \u0441\u043C\u043E\u0433 \u0441\u0434\u0430\u0442\u044C
    \u043D\u043E\u0440\u043C\u0430\u0442\u0438\u0432\u044B \u043F\u043E \u0444\u0438\u0437\u043A\u0443\u043B\u044C\u0442\u0443\u0440\u0435.
    \u0414\u043B\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0437\u0436\u0435 \u043E\u0442\u043A\u0430\u0436\u0435\u0442\u0441\u044F
    \u043E\u0442 \u043F\u0440\u0435\u043C\u0438\u0438 \u0432 1 \u043C\u0438\u043B\u043B\u0438\u043E\u043D
    \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432, \u044D\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u043F\u0435\u0440\u0432\u044B\u043C, \u043D\u043E \u043D\u0435 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u043C
    \u043E\u0442\u043A\u0430\u0437\u043E\u043C \u043E\u0442 \"\u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0445\"
    \u043D\u0430\u0433\u0440\u0430\u0434.  ### \U0001F3BB \u0420\u0430\u0437\u043D\u043E\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u044F\u044F
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C 
    \u0425\u043E\u0442\u044F \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u0438 \u043F\u0440\u043E\u0441\u043B\u0430\u0432\u0438\u043B\u0441\u044F \u043A\u0430\u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435
    \u0438 \u044E\u043D\u043E\u0441\u0442\u0438 \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B
    \u0431\u044B\u043B\u0438 \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u0448\u0438\u0440\u0435.
    \u041E\u043D \u0445\u043E\u0440\u043E\u0448\u043E \u0438\u0433\u0440\u0430\u043B
    \u0432 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043D\u044B\u0439 \u0442\u0435\u043D\u043D\u0438\u0441,
    \u0430 \u0435\u0433\u043E \u043C\u0430\u0442\u044C, \u0438\u0433\u0440\u0430\u0432\u0448\u0430\u044F
    \u043D\u0430 \u0441\u043A\u0440\u0438\u043F\u043A\u0435, \u043F\u0440\u0438\u0432\u0438\u043B\u0430
    \u0435\u043C\u0443 \u043B\u044E\u0431\u043E\u0432\u044C \u043A \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0443\u0437\u044B\u043A\u0435. \u041F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F\u043C,
    \u043E\u043D \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u043A \u0433\u0435\u043E\u0433\u0440\u0430\u0444\u0438\u0438,
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u0438 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u043C\u0443
    \u044F\u0437\u044B\u043A\u0443, \u043F\u043E\u043F\u0440\u0430\u0432\u043B\u044F\u044F
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439 \u0441 \u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u0434\u0435\u043B\u0438\u043A\u0430\u0442\u043D\u043E\u0441\u0442\u044C\u044E.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E, \u0432\u043E\u043F\u0440\u0435\u043A\u0438
    \u0447\u0430\u0441\u0442\u043E\u043C\u0443 \u0437\u0430\u0431\u043B\u0443\u0436\u0434\u0435\u043D\u0438\u044E,
    \u0435\u0433\u043E \u043E\u0442\u0446\u043E\u043C \u0431\u044B\u043B \u043D\u0435
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0430\u0442\u043E\u0440
    \u043D\u0430\u0443\u043A\u0438 \u042F\u043A\u043E\u0432 \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D,
    \u0430 \u0438\u043D\u0436\u0435\u043D\u0435\u0440-\u044D\u043B\u0435\u043A\u0442\u0440\u0438\u043A
    \u042F\u043A\u043E\u0432 \u041D\u0430\u0443\u043C\u043E\u0432\u0438\u0447.  ###
    \U0001F35E \u0410\u0441\u043A\u0435\u0442\u0438\u0437\u043C \u0432 \u0431\u044B\u0442\u0443
    \u0438 \"\u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435\"
    \u043D\u0430\u0443\u043A\u0438  \u0412 \u043D\u0430\u0447\u0430\u043B\u0435 1990-\u0445,
    \u0440\u0430\u0431\u043E\u0442\u0430\u044F \u0432 \u0421\u0428\u0410, \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u043F\u043E\u0440\u0430\u0436\u0430\u043B \u043A\u043E\u043B\u043B\u0435\u0433
    \u0441\u0432\u043E\u0438\u043C \u0430\u0441\u043A\u0435\u0442\u0438\u0437\u043C\u043E\u043C.
    \u0412 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u0430\u043A \u043C\u043D\u043E\u0433\u0438\u0435
    \u043D\u0430\u0441\u043B\u0430\u0436\u0434\u0430\u043B\u0438\u0441\u044C \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u043C
    \"\u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0436\u0438\u0437\u043D\u0438\",
    \u0435\u0433\u043E \u043B\u044E\u0431\u0438\u043C\u043E\u0439 \u0435\u0434\u043E\u0439
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0438\u0441\u044C \u0441\u0430\u043C\u044B\u0435
    \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u044B:
    \u043C\u043E\u043B\u043E\u043A\u043E, \u0445\u043B\u0435\u0431 \u0438 \u0441\u044B\u0440.
    \u041E\u043D \u0445\u043E\u0434\u0438\u043B \u0432 \u043E\u0434\u043D\u043E\u043C
    \u0438 \u0442\u043E\u043C \u0436\u0435 \u0432\u0435\u043B\u044C\u0432\u0435\u0442\u043E\u0432\u043E\u043C
    \u043F\u0438\u0434\u0436\u0430\u043A\u0435 \u0438 \u0442\u0440\u0430\u0442\u0438\u043B
    \u0432\u0441\u0435 \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u043D\u044B\u0435
    \u0434\u0435\u043D\u044C\u0433\u0438 \u043D\u0435 \u043D\u0430 \u0431\u043B\u0430\u0433\u0430,
    \u0430 \u043D\u0430 \u0441\u0432\u043E\u0438 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F. 
    \u0421\u0430\u043C \u0444\u0430\u043A\u0442, \u0447\u0442\u043E \u043E\u043D
    \u043F\u0440\u043E\u0432\u0435\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435,
    \u043D\u0435 \u0438\u043C\u0435\u044F \u043D\u0438\u043A\u0430\u043A\u043E\u0433\u043E
    \u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F,
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u0435\u043D. \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u0436\u0438\u043B \u043D\u0430 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0441\u0431\u0435\u0440\u0435\u0436\u0435\u043D\u0438\u044F, \u043D\u0430\u043A\u043E\u043F\u043B\u0435\u043D\u043D\u044B\u0435
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0437\u0430\u0440\u0443\u0431\u0435\u0436\u043D\u044B\u0445
    \u0441\u0442\u0430\u0436\u0438\u0440\u043E\u0432\u043E\u043A. \u041F\u043E\u0437\u0436\u0435,
    \u0432 \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0432\u043E\u0438\u0445
    \u0441\u0442\u0430\u0442\u0435\u0439, \u043E\u043D \u0441 \u044E\u043C\u043E\u0440\u043E\u043C
    \u043E\u0442\u043C\u0435\u0442\u0438\u043B \u0432 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u043D\u043E\u0441\u0442\u044F\u0445,
    \u0447\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \"\u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E
    \u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043B\u0430\u0441\u044C\"
    \u0437\u0430 \u0441\u0447\u0435\u0442 \u043B\u0438\u0447\u043D\u044B\u0445 \u0441\u0431\u0435\u0440\u0435\u0436\u0435\u043D\u0438\u0439,
    \u0441\u044D\u043A\u043E\u043D\u043E\u043C\u043B\u0435\u043D\u043D\u044B\u0445
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043F\u043E\u0435\u0437\u0434\u043E\u043A
    \u0432 \u0421\u0428\u0410.  ### \U0001F4DC \u041F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u043E\u0442\u043A\u0430\u0437 \u043E\u0442 \"\u0431\u0443\u043C\u0430\u0436\u0435\u043A\"
    \u0438 \u0438\u043D\u0442\u0435\u0440\u0432\u044C\u044E  \u0418\u0441\u0442\u043E\u0440\u0438\u044F
    \u0441 \u043E\u0442\u043A\u0430\u0437\u043E\u043C \u043E\u0442 \u0440\u0435\u0437\u044E\u043C\u0435
    \u0441\u0442\u0430\u043B\u0430 \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C
    \u0435\u0433\u043E \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u041A\u043E\u0433\u0434\u0430 \u0432 \u0421\u0442\u044D\u043D\u0444\u043E\u0440\u0434\u0441\u043A\u043E\u043C
    \u0438\u043B\u0438 \u0413\u0430\u0440\u0432\u0430\u0440\u0434\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u0443
    \u043D\u0435\u0433\u043E \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B\u0438
    \u0430\u0432\u0442\u043E\u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E
    \u0438 \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043F\u0438\u0441\u044C\u043C\u0430, \u043E\u043D \u043E\u0442\u0432\u0435\u0442\u0438\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u0444\u0440\u0430\u0437\u043E\u0439:
    *\"\u0415\u0441\u043B\u0438 \u043E\u043D\u0438 \u0437\u043D\u0430\u044E\u0442
    \u043C\u043E\u0438 \u0440\u0430\u0431\u043E\u0442\u044B, \u0438\u043C \u043D\u0435
    \u043D\u0443\u0436\u043D\u043E \u043C\u043E\u0435 C.V. \u0415\u0441\u043B\u0438
    \u0438\u043C \u043D\u0443\u0436\u043D\u043E \u043C\u043E\u0435 C.V., \u0437\u043D\u0430\u0447\u0438\u0442,
    \u043E\u043D\u0438 \u043D\u0435 \u0437\u043D\u0430\u044E\u0442 \u043C\u043E\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442\"*. \u0412 \u0438\u0442\u043E\u0433\u0435 \u043E\u043D
    \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u043E\u0442 \u0432\u0441\u0435\u0445
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0439 \u0438 \u0443\u0435\u0445\u0430\u043B
    \u0432 \u0420\u043E\u0441\u0441\u0438\u044E.  \u0422\u0430\u043A\u0436\u0435
    \u043A\u0440\u0430\u0439\u043D\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u0430
    \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044F \u0441 \u0435\u0433\u043E \"\u0438\u043D\u0442\u0435\u0440\u0432\u044C\u044E\".
    \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u044D\u043A\u0441\u043F\u0435\u0440\u0442\u044B
    \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0438 \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u044F
    \u0432 \u043F\u043E\u0434\u043B\u0438\u043D\u043D\u043E\u0441\u0442\u0438 \u0442\u0435\u0445
    \u0440\u0435\u0434\u043A\u0438\u0445 \u0438\u043D\u0442\u0435\u0440\u0432\u044C\u044E,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0435\u043C\u0443 \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438,
    \u043D\u0430\u0445\u043E\u0434\u044F \u0432 \u043D\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0448\u0438\u0431\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439 \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u043D\u0435 \u043C\u043E\u0433 \u0431\u044B \u0434\u043E\u043F\u0443\u0441\u0442\u0438\u0442\u044C.
    \u0421\u0430\u043C \u043E\u043D \u044D\u0442\u0438 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438
    \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043B. 
    ### \U0001F300 \u0411\u043E\u0440\u044C\u0431\u0430 \u0437\u0430 \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442
    \u0438 \"\u0438\u0433\u043D\u043E\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435\"
    \u043A\u043E\u043B\u043B\u0435\u0433  \u0412\u044B\u043B\u043E\u0436\u0438\u0432
    \u0432 2002 \u0433\u043E\u0434\u0443 \u0441\u0432\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0432 \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442, \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D
    \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u043B\u0441\u044F \u043B\u0438\u0448\u044C
    \u043E\u0431\u0449\u0435\u0439 \u0441\u0445\u0435\u043C\u043E\u0439, \u043D\u0435
    \u0440\u0430\u0437\u0436\u0435\u0432\u044B\u0432\u0430\u044F \u0435\u0435 \u0434\u043E\u0441\u043A\u043E\u043D\u0430\u043B\u044C\u043D\u043E.
    \u041A\u043E\u0433\u0434\u0430 \u043A\u0438\u0442\u0430\u0439\u0441\u043A\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432\u043E \u0433\u043B\u0430\u0432\u0435
    \u0441 \u042F\u0443 \u0428\u0438\u043D\u0442\u0443\u043D\u043E\u043C \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B\u0438
    \u0431\u043E\u043B\u0435\u0435 \u043E\u0431\u044A\u0435\u043C\u043D\u0443\u044E
    \u0438 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0443\u044E \u0441\u0442\u0430\u0442\u044C\u044E,
    \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \"\u0440\u0430\u0437\u0436\u0435\u0432\u0430\u0432\"
    \u0435\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0438 \u043D\u0435 \u0443\u043F\u043E\u043C\u044F\u043D\u0443\u0432 \u0434\u043E\u043B\u0436\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u043F\u0440\u0438\u043E\u0440\u0438\u0442\u0435\u0442
    \u041F\u0435\u0440\u0435\u043B\u044C\u043C\u0430\u043D\u0430, \u043E\u043D \u043F\u0440\u043E\u043C\u043E\u043B\u0447\u0430\u043B.
    \u041D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441 \u0436\u0443\u0440\u043D\u0430\u043B\u0438\u0441\u0442\u043E\u0432
    \u043E \u043D\u0435\u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E\u0441\u0442\u0438
    \u043E\u043D \u043E\u0442\u0432\u0435\u0442\u0438\u043B \u0441 \u0433\u043E\u0440\u0435\u0447\u044C\u044E,
    \u0447\u0442\u043E \u0432 \u043D\u0430\u0443\u043A\u0435 \u0447\u0443\u0436\u0430\u043A\u0430\u043C\u0438
    \u0441\u0447\u0438\u0442\u0430\u044E\u0442 \u043D\u0435 \u043D\u0430\u0440\u0443\u0448\u0438\u0442\u0435\u043B\u0435\u0439
    \u044D\u0442\u0438\u043A\u0438, \u0430 \u0442\u0430\u043A\u0438\u0445, \u043A\u0430\u043A
    \u043E\u043D.  ### \U0001F3AC \"\u0423\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439\" \u0438 \u043C\u0438\u043B\u043B\u0438\u043E\u043D
    \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432  \u0421\u0430\u043C\u0430\u044F
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F \u0435\u0433\u043E
    \u0444\u0440\u0430\u0437\u0430, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u0430\u044F
    \u0441 \u043E\u0442\u043A\u0430\u0437\u043E\u043C \u043E\u0442 \u043F\u0440\u0435\u043C\u0438\u0438,
    \u2014 \u043E\u043D \u0441\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \u0437\u043D\u0430\u0435\u0442, \u043A\u0430\u043A \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0442\u044C
    \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439, \u0438 \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \"\u043D\u0435 \u0432\u0438\u0434\u0438\u0442 \u0441\u043C\u044B\u0441\u043B\u0430
    \u0431\u0435\u0436\u0430\u0442\u044C \u0437\u0430 \u043C\u0438\u043B\u043B\u0438\u043E\u043D\u043E\u043C\".
    \u0415\u0433\u043E \u043E\u0442\u043A\u0430\u0437 \u043E\u0442 1 \u043C\u0438\u043B\u043B\u0438\u043E\u043D\u0430
    \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 \u041A\u043B\u044D\u044F
    \u0431\u044B\u043B \u043C\u043E\u0442\u0438\u0432\u0438\u0440\u043E\u0432\u0430\u043D
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0435\u0441\u043E\u0433\u043B\u0430\u0441\u0438\u0435\u043C
    \u0441 \"\u043D\u0435\u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u044B\u043C\"
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435\u043C \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430,
    \u043D\u043E \u0438 \u0442\u0435\u043C, \u0447\u0442\u043E, \u043F\u043E \u0435\u0433\u043E
    \u043C\u043D\u0435\u043D\u0438\u044E, \u0432\u043A\u043B\u0430\u0434 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0420\u0438\u0447\u0430\u0440\u0434\u0430
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430 \u0432 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u043D\u0435 \u043C\u0435\u043D\u044C\u0448\u0435 \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E. 
    ### \u2728 \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438 \u043C\u0435\u0441\u0442\u043E
    \u0432 \u043F\u0430\u043D\u0442\u0435\u043E\u043D\u0435 \u0433\u0435\u043D\u0438\u0435\u0432 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0437\u0430\u0442\u0432\u043E\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E,
    \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0439 \u043F\u0440\u0438\u0437\u043D\u0430\u043D
    \u043D\u0430 \u043C\u0438\u0440\u043E\u0432\u043E\u043C \u0443\u0440\u043E\u0432\u043D\u0435.
    \u0412 2006 \u0433\u043E\u0434\u0443 \u0436\u0443\u0440\u043D\u0430\u043B **Science**
    \u043D\u0430\u0437\u0432\u0430\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u043C \u0433\u043E\u0434\u0430 , \u0430
    \u0431\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u0430\u044F \u0433\u0430\u0437\u0435\u0442\u0430
    The Daily Telegraph \u0432\u043A\u043B\u044E\u0447\u0438\u043B\u0430 \u0435\u0433\u043E
    \u0432 \u0441\u043F\u0438\u0441\u043E\u043A 100 \u043D\u044B\u043D\u0435 \u0436\u0438\u0432\u0443\u0449\u0438\u0445
    \u0433\u0435\u043D\u0438\u0435\u0432, \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0432
    \u043D\u0430 9-\u0435 \u043C\u0435\u0441\u0442\u043E (\u0432\u044B\u0448\u0435
    \u0413\u0430\u0440\u0440\u0438 \u041A\u0430\u0441\u043F\u0430\u0440\u043E\u0432\u0430
    \u0438 \u041C\u0438\u0445\u0430\u0438\u043B\u0430 \u041A\u0430\u043B\u0430\u0448\u043D\u0438\u043A\u043E\u0432\u0430).
    \u041E\u043D \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u0435\u043B\u0435\u043C
    \u0420\u043E\u0441\u0441\u0438\u0438 \u0432 \u044D\u0442\u043E\u043C \u0440\u0435\u0439\u0442\u0438\u043D\u0433\u0435. 
    ### \U0001F370 \u041D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0435
    \u0441\u043B\u0430\u0431\u043E\u0441\u0442\u0438  \u0423 \u0433\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0438\u0442\u0430\u043B\u0441\u044F
    \u0445\u043B\u0435\u0431\u043E\u043C \u0438 \u0441\u044B\u0440\u043E\u043C, \u0432\u0441\u0451
    \u0436\u0435 \u0431\u044B\u043B\u0430 \u043E\u0434\u043D\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u0441\u043B\u0430\u0431\u043E\u0441\u0442\u044C \u2014 \u043E\u043D \u043E\u0447\u0435\u043D\u044C
    \u043B\u044E\u0431\u0438\u043B \u043F\u0438\u0440\u043E\u0436\u043D\u044B\u0435-\u043A\u043E\u0440\u0437\u0438\u043D\u043E\u0447\u043A\u0438
    \u0441 \u043A\u0440\u0435\u043C\u043E\u043C. \u042D\u0442\u043E\u0442 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439
    \u0448\u0442\u0440\u0438\u0445 \u0434\u0435\u043B\u0430\u0435\u0442 \u0435\u0433\u043E
    \u043E\u0431\u0440\u0430\u0437 \u043D\u0435\u043C\u043D\u043E\u0433\u043E \u0431\u043E\u043B\u0435\u0435
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u043D\u044B\u043C \u0438 \u043E\u0442
    \u044D\u0442\u043E\u0433\u043E \u0435\u0449\u0435 \u0431\u043E\u043B\u0435\u0435
    \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u043D\u044B\u043C \u0441 \u0435\u0433\u043E
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0430\u0441\u043A\u0435\u0442\u0430-\u0437\u0430\u0442\u0432\u043E\u0440\u043D\u0438\u043A\u0430."
