    \u043B\u043E\u043A\u0430\u043B\u044C\u043D\u044B\u0445 \u043A\u043E\u043B\u044C\u0446\u0430\u0445,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u0442\u043E\u0440-\u0444\u0443\u043D\u043A\u0442\u043E\u0440\u044B.
