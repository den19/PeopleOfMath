    \u0447\u0430\u0441\u0442\u043D\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0421\u0435\u0440\u0440\u0430 (\u0434\u043B\u044F
    \u043F\u043E\u043B\u0443\u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u044B\u0445
