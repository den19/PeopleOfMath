    \u0440\u043E\u0434\u043E\u0432 \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u0445
    \u043F\u043E\u043B\u0435\u0439 \u0441 \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u043E\u0439 \u043A\u043B\u0430\u0441\u0441\u043E\u0432.
    \u041E\u043D\u0438 \u0441\u0432\u044F\u0437\u0430\u043B\u0438 \u0434\u0438\u0441\u043A\u0440\u0438\u043C\u0438\u043D\u0430\u043D\u0442\u044B
    \u043F\u043E\u043B\u0435\u0439 \u0441 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u043C\u0438
    \u043F\u0440\u043E\u0441\u0442\u044B\u043C\u0438 \u0434\u0435\u043B\u0438\u0442\u0435\u043B\u044F\u043C\u0438,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u0440\u0438\u0432\u044B\u0435 \u0441 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u043C
    \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435\u043C. \u042D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u043E\u0440\u043E\u0434\u0438\u043B\u0430
    \u0446\u0435\u043B\u0443\u044E \u0432\u0435\u0442\u0432\u044C \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    \u0432 \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B.  ---  ###
    \u0421\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0440\u0443\u0434\u044B \u0438 \"\u041A\u0440\u0430\u0441\u043D\u0430\u044F
    \u043A\u043D\u0438\u0433\u0430\" (1964) \u0412 1964 \u0433\u043E\u0434\u0443
    \u0421\u0435\u0440\u0440 \u043F\u0443\u0431\u043B\u0438\u043A\u0443\u0435\u0442
    \u043A\u043D\u0438\u0433\u0443 **\xABCohomologie Galoisienne\xBB** (\u041A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438
    \u0413\u0430\u043B\u0443\u0430), \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043D\u0435\u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \"\u041A\u0440\u0430\u0441\u043D\u043E\u0439 \u043A\u043D\u0438\u0433\u043E\u0439\"
    (\u0438\u0437-\u0437\u0430 \u043E\u0431\u043B\u043E\u0436\u043A\u0438).  *  
    \u0412 \u043D\u0435\u0439 \u043E\u043D \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0439
    \u043F\u0440\u043E\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445 \u0433\u0440\u0443\u043F\u043F
    \u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u0435\u0435 \u043A \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u0435 \u0413\u0430\u043B\u0443\u0430. *   \u041E\u043D
    \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435 *\u043A\u043B\u0430\u0441\u0441\u043E\u0432
    \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438* (cd) \u043F\u043E\u043B\u0435\u0439
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043F\u043E\u043B\u0435
    \\( \\mathbb{Q}_p \\) \u0438\u043C\u0435\u0435\u0442 \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C 2. \u042D\u0442\u043E
    \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B\u043E, \u043F\u043E\u0447\u0435\u043C\u0443
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u044B\u0435 \u0444\u043E\u0440\u043C\u044B
    \u043D\u0430\u0434 p-\u0430\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043F\u043E\u043B\u044F\u043C\u0438 \u0432\u0435\u0434\u0443\u0442 \u0441\u0435\u0431\u044F
    \"\u0445\u043E\u0440\u043E\u0448\u043E\".  **\u041A\u043D\u0438\u0433\u0430 \xABArbres,
    amalgames, SL\u2082\xBB (1977):** \u041D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434, \u0433\u0434\u0435 \u043E\u043D \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u0433\u0440\u0430\u0444\u043E\u0432 (\u0434\u0435\u0440\u0435\u0432\u044C\u0435\u0432)
    \u043A \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044E
    \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445 \u0433\u0440\u0443\u043F\u043F
    \\( SL_2 \\) \u043D\u0430\u0434 \u043A\u043E\u043B\u044C\u0446\u0430\u043C\u0438.
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435
    \u0433\u0440\u0443\u043F\u043F\u044B \u043D\u0430 \u0434\u0435\u0440\u0435\u0432\u0435
    (\u0434\u0435\u0440\u0435\u0432\u043E \u0421\u0435\u0440\u0440\u0430) \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u0442\u044C \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0443
    \u044D\u0442\u043E\u0439 \u0433\u0440\u0443\u043F\u043F\u044B \u043A\u0430\u043A
    \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0433\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u0441 \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u0435\u043C.
    \u042D\u0442\u043E \u0434\u0430\u043B\u043E \u043C\u043E\u0449\u043D\u044B\u0439
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442 \u0434\u043B\u044F
    \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0443\u043F\u043F.  ---  ###
    \u041C\u0435\u0442\u043E\u0434\u043E\u043B\u043E\u0433\u0438\u044F \u0421\u0435\u0440\u0440\u0430:
    \"\u041C\u0430\u043B\u044B\u0435 \u0442\u0435\u043E\u0440\u0435\u043C\u043D\u044B\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\"
    \u0413\u043B\u0430\u0432\u043D\u0430\u044F \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u043E\u0432 \u2014 \u043E\u043D **\u0438\u0437\u0431\u0435\u0433\u0430\u043B
    \u0433\u0440\u043E\u043C\u043E\u0437\u0434\u043A\u0438\u0445 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u0439**.
    \u0415\u0441\u043B\u0438 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u043F\u0438\u0441\u0430\u043B \u0442\u043E\u043C\u0430 (EGA \u043D\u0430\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u0435\u0442
    \u0442\u044B\u0441\u044F\u0447\u0438 \u0441\u0442\u0440\u0430\u043D\u0438\u0446),
    \u0442\u043E \u0421\u0435\u0440\u0440 \u043F\u0438\u0441\u0430\u043B \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0435,
    \u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u043E \u0441\u0436\u0430\u0442\u044B\u0435
    \u0437\u0430\u043C\u0435\u0442\u043A\u0438. \u0415\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u0442\u0435\u0445\u043D\u0438\u043A\u0430 \u2014 **\u043C\u0435\u0442\u043E\u0434
    \"\u0441\u043A\u0440\u0443\u0447\u0438\u0432\u0430\u043D\u0438\u044F\" (twisting)**
    \u2014 \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F \u0432
    \u0442\u043E\u043C, \u0447\u0442\u043E \u0434\u043B\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0441\u043B\u043E\u0436\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u043E\u043D \u0432\u044B\u0431\u0438\u0440\u0430\u0435\u0442 \u043F\u0440\u043E\u0441\u0442\u043E\u0439
    \u0447\u0430\u0441\u0442\u043D\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439
    (\u043E\u0431\u044B\u0447\u043D\u043E \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u0443\u044E
    \u043F\u0440\u044F\u043C\u0443\u044E \\( \\mathbb{P}^1 \\)), \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u0442\u0430\u043C, \u0430 \u0437\u0430\u0442\u0435\u043C \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0441\u043F\u0443\u0441\u043A\u0430 (descent)
    \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u0442 \u043D\u0430 \u043E\u0431\u0449\u0438\u0435
    \u0441\u0445\u0435\u043C\u044B.   ---  ### \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B (\u043F\u043E\u043B\u043D\u044B\u0439 \u0441\u043F\u0438\u0441\u043E\u043A
    \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0445):  1.  **1951** \u2014 *Homologie
    singuli\xE8re des espaces fibr\xE9s* (Topology). 2.  **1955** \u2014 *Faisceaux
    alg\xE9briques coh\xE9rents* (Algebraic Geometry, FAC). 3.  **1956** \u2014 *G\xE9om\xE9trie
    alg\xE9brique et g\xE9om\xE9trie analytique* (GAGA). 4.  **1958** \u2014 *Modules
    projectifs et espaces fibr\xE9s \xE0 fibre vectorielle* (\u0422\u0435\u043E\u0440\u0438\u044F
    \u043C\u043E\u0434\u0443\u043B\u0435\u0439). 5.  **1964** \u2014 *Cohomologie
    galoisienne* (\u0422\u0435\u043E\u0440\u0438\u044F \u0413\u0430\u043B\u0443\u0430
    \u0438 \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438). 6. 
    **1965** \u2014 *Alg\xE8bre locale, multiplicit\xE9s* (\u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u041F. \u0421\u0430\u043C\u0443\u044D\u043B\u0435\u043C). 7.  **1970**
    \u2014 *Cours d'arithm\xE9tique* (\u0423\u0447\u0435\u0431\u043D\u0438\u043A
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B,
    \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043D\u043D\u044B\u0439 \u043D\u0430
    \u0432\u0441\u0435 \u044F\u0437\u044B\u043A\u0438). 8.  **1973** \u2014 *Formes
    modulaires et repr\xE9sentations l-adiques* (\u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0414\u0435\u043B\u0438\u043D\u0435\u043C). 9.  **1975** \u2014 *Valeurs
    propres des op\xE9rateurs de Hecke modulo l* (\u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u0438). 10.
    **1988** \u2014 *Abelian l-adic representations and elliptic curves* (\u041A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0440\u0443\u0434 \u043F\u043E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F\u043C
    \u0413\u0430\u043B\u0443\u0430). 11. **1992** \u2014 *Topics in Galois Theory*
    (\u041B\u0435\u043A\u0446\u0438\u0438 \u0432 \u0413\u0430\u0440\u0432\u0430\u0440\u0434\u0435,
    \u0438\u0437\u0434\u0430\u043D\u044B \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E
    \u0434\u043B\u044F \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0439). 
    ---  ### \u0418\u0442\u043E\u0433\u043E\u0432\u043E\u0435 \u0440\u0435\u0437\u044E\u043C\u0435
    \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u0432\u043A\u043B\u0430\u0434\u0430
    \u0421\u0435\u0440\u0440 \u2014 **\"\u0437\u043E\u043B\u043E\u0442\u043E\u0439
    \u043C\u043E\u0441\u0442\"** \u043C\u0435\u0436\u0434\u0443 \u0447\u0438\u0441\u0442\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u043E\u0439, \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0435\u0439
    \u0438 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u043E\u0439. \u041E\u043D
    \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0441\u043E\u0437\u0434\u0430\u043B
    \u044F\u0437\u044B\u043A, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0433\u043E\u0432\u043E\u0440\u044F\u0442 \u0432\u0441\u0435 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u044B. \u0415\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F: 
    - \u0414\u0430\u0442\u044C \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0433\u043E\u043C\u043E\u0442\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0433\u0440\u0443\u043F\u043F. - \u0421\u0432\u044F\u0437\u0430\u0442\u044C
    \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438 \u0441 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043F\u0443\u0447\u043A\u0430\u043C\u0438. - \u041F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C
    \u0442\u0435\u043E\u0440\u0438\u044E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u0413\u0430\u043B\u0443\u0430, \u0431\u0435\u0437 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0424\u0435\u0440\u043C\u0430. -
    \u0412\u0432\u0435\u0441\u0442\u0438 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u044B
    \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u0438 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E
    \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0438\u0432\u044B\u0445 \u043D\u0430\u0434 \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u043C\u0438
    \u043F\u043E\u043B\u044F\u043C\u0438."
  achievementsEn: 
  personalLifeRu: "### \U0001F9EC \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0441\u0435\u043C\u044C\u044F  \u0416\u0430\u043D-\u041F\u044C\u0435\u0440
    \u0410\u043B\u044C\u0431\u0435\u0440 \u0410\u0445\u0438\u043B\u043B \u0421\u0435\u0440\u0440
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **15 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F
    1926 \u0433\u043E\u0434\u0430** \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 **\u0411\u0430\u0436
    (Bages) \u043D\u0430 \u044E\u0433\u0435 \u0424\u0440\u0430\u043D\u0446\u0438\u0438**,
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u0444\u0430\u0440\u043C\u0430\u0446\u0435\u0432\u0442\u043E\u0432.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u0416\u0430\u043D \u0421\u0435\u0440\u0440,
    \u0438 \u043C\u0430\u0442\u044C, \u0410\u0434\u0435\u043B\u044C \u0414\u0438\u0435\u0442,
    \u043E\u0431\u0430 \u0431\u044B\u043B\u0438 \u043F\u0440\u043E\u0432\u0438\u0437\u043E\u0440\u0430\u043C\u0438. 
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u043C\u0430\u0442\u044C
    \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0441\u0430\u043C\u0430 \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0430\u0441\u044C
    \u0442\u043E\u0447\u043D\u044B\u043C\u0438 \u043D\u0430\u0443\u043A\u0430\u043C\u0438:
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043A\u043E\u0439
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0430 \u0444\u0430\u0440\u043C\u0430\u0446\u0438\u0438
    \u0432 \u041C\u043E\u043D\u043F\u0435\u043B\u044C\u0435, \u043E\u043D\u0430 \u0440\u0430\u0434\u0438
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0430 \u043F\u0440\u043E\u0441\u043B\u0443\u0448\u0430\u043B\u0430
    \u043A\u0443\u0440\u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u0438 \u0441\u0434\u0430\u043B\u0430
    \u044D\u043A\u0437\u0430\u043C\u0435\u043D. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0435\u0435 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0438 (\u0430\u0432\u0442\u043E\u0440\u043E\u0432
    \u0424\u0430\u0431\u0440\u0438 \u0438 \u0424\u043E\u0433\u0442\u0430) \u044E\u043D\u044B\u0439
    \u0416\u0430\u043D-\u041F\u044C\u0435\u0440 \u043D\u0430\u0447\u0430\u043B \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u0432 14-15 \u043B\u0435\u0442, \u043E\u0441\u0432\u0430\u0438\u0432\u0430\u044F
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0435, \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044B
    \u0438 \u0440\u044F\u0434\u044B \u0432 \u0447\u0438\u0441\u0442\u043E \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u043C,
    \"\u044D\u0439\u043B\u0435\u0440\u043E\u0432\u0441\u043A\u043E\u043C\" \u0441\u0442\u0438\u043B\u0435,
    \u0431\u0435\u0437 \u0441\u0442\u0440\u043E\u0433\u0438\u0445 \u044D\u043F\u0441\u0438\u043B\u043E\u043D-\u0434\u0435\u043B\u044C\u0442\u0430-\u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0439. 
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439 \u043E\u043D
    \u0443\u0432\u043B\u0435\u043A\u0441\u044F \u0441 7-8 \u043B\u0435\u0442. \u0412
    \u043B\u0438\u0446\u0435\u0435 \u0432 \u041D\u0438\u043C\u0435 (Lyc\xE9e Alphonse-Daudet)
    \u0443 \u043D\u0435\u0433\u043E \u0431\u044B\u043B \u0441\u0442\u0440\u043E\u0433\u0438\u0439
    \u0438 \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u0439 \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u043F\u043E \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0443 \"\u0411\u043E\u0440\u043E\u0434\u0430\"
    (Le Barbu), \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u043B
    \u0421\u0435\u0440\u0440\u0430 \u043A \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u043A\u043E\u043D\u043A\u0443\u0440\u0441\u0443 Concours G\xE9n\xE9ral, \u0433\u0434\u0435
    \u0442\u043E\u0442 \u0437\u0430\u043D\u044F\u043B \u043F\u0435\u0440\u0432\u043E\u0435
    \u043C\u0435\u0441\u0442\u043E.  ### \U0001F393 \u0423\u0447\u0451\u0431\u0430,
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0438 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438 
    *   **1945\u20131948**: \u041F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u0435
    \u0438 \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435 \u0432 **\u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439
    \u0412\u044B\u0441\u0448\u0435\u0439 \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 (\xC9cole Normale Sup\xE9rieure)**. \u0412 19
    \u043B\u0435\u0442 \u043E\u043D \u0435\u0449\u0435 \u043D\u0435 \u0437\u043D\u0430\u043B,
    \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u0435\u0439,
    \u0438 \u0434\u0443\u043C\u0430\u043B \u0441\u0442\u0430\u0442\u044C \u0448\u043A\u043E\u043B\u044C\u043D\u044B\u043C
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C. \u041E\u0434\u043D\u0430\u043A\u043E,
    \u043F\u043E\u043F\u0430\u0432 \u0432 ENS, \u043E\u043D \u043F\u043E\u043D\u044F\u043B,
    \u0447\u0442\u043E \u0445\u043E\u0447\u0435\u0442 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\u043C\u0438.
    *   **1948\u20131954**: \u0420\u0430\u0431\u043E\u0442\u0430 \u0432 **\u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0424\u0440\u0430\u043D\u0446\u0438\u0438
    (CNRS)**. *   **1951**: \u0417\u0430\u0449\u0438\u0442\u0430 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u043E\u0439
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438 (Ph.D.) \u0432
    \u0421\u043E\u0440\u0431\u043E\u043D\u043D\u0435 (\u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442) \u043F\u043E
    \u0442\u0435\u043C\u0435 \u0441\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u041B\u0435\u0440\u0435\u2014\u0421\u0435\u0440\u0440\u0430. *   **1954\u20131956**:
    \u0420\u0430\u0431\u043E\u0442\u0430 \u0432 **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u041D\u0430\u043D\u0441\u0438**. *   **1956\u20131994**: \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u043A\u0430\u0444\u0435\u0434\u0440\u044B \u0430\u043B\u0433\u0435\u0431\u0440\u044B
    \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u043C
    **\u041A\u043E\u043B\u043B\u0435\u0436 \u0434\u0435 \u0424\u0440\u0430\u043D\u0441
    (Coll\xE8ge de France)**. \u041E\u043D \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B
    \u0441\u0432\u043E\u044E \u0438\u043D\u0430\u0443\u0433\u0443\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u0443\u044E
    \u043B\u0435\u043A\u0446\u0438\u044E \u043A\u0430\u043A \u0432\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u043C\u043E\u043C\u0435\u043D\u0442: \u0437\u0430 \u043C\u0435\u0441\u044F\u0446
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0432\u0441\u0435\u0433\u043E
    \u043F\u043E\u043B\u0441\u0442\u0440\u0430\u043D\u0438\u0446\u044B \u0438 \u0432
    \u0438\u0442\u043E\u0433\u0435 \u0438\u043C\u043F\u0440\u043E\u0432\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B.
    \u0412 1994 \u0433\u043E\u0434\u0443 \u0441\u0442\u0430\u043B \u043F\u043E\u0447\u0435\u0442\u043D\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C. *   \u0410\u043A\u0442\u0438\u0432\u043D\u043E
    \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u043B \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0435
    \u0432\u0438\u0437\u0438\u0442\u044B \u0432 **\u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u0438\u0439
    \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439**, **\u0413\u0430\u0440\u0432\u0430\u0440\u0434**,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0447\u0438\u0442\u0430\u043B \u043A\u0443\u0440\u0441\u044B
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\u0445
    \u043F\u043E \u0432\u0441\u0435\u043C\u0443 \u043C\u0438\u0440\u0443 \u2014 \u043E\u0442
    \u0410\u043B\u0436\u0438\u0440\u0430 \u0434\u043E \u0421\u0438\u043D\u0433\u0430\u043F\u0443\u0440\u0430
    \u0438 \u041C\u043E\u0441\u043A\u0432\u044B.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467
    \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C, \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F
    \u0438 \u0441\u0435\u043C\u044C\u044F  *   **\u0421\u0443\u043F\u0440\u0443\u0433\u0430**:
    **10 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1948 \u0433\u043E\u0434\u0430**
    \u0421\u0435\u0440\u0440 \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430
    **\u0416\u043E\u0437\u0438\u0430\u043D \u042D\u043B\u0451 (Josiane Heulot)**
    (1922\u20132004). \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0445\u0438\u043C\u0438\u043A\u043E\u043C-\u043E\u0440\u0433\u0430\u043D\u0438\u043A\u043E\u043C,
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430 \u0432 \u0412\u044B\u0441\u0448\u0435\u0439
    \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u0435
    \u0434\u043B\u044F \u0434\u0435\u0432\u0443\u0448\u0435\u043A \u0432 \u0421\u0435\u0432\u0440\u0435
    \u0438 \u0434\u0430\u0436\u0435 \u0431\u044B\u043B\u0430 \u0435\u0435 \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C.
    \u0421\u0430\u043C \u0421\u0435\u0440\u0440 \u0448\u0443\u0442\u0438\u043B, \u0447\u0442\u043E
    \u0432 \u044E\u043D\u043E\u0441\u0442\u0438 \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043B\u0441\u044F
    \u0432 \u0445\u0438\u043C\u0438\u0438 \u0438\u0437-\u0437\u0430 \u0435\u0435
    \"\u043F\u043E\u0447\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439\"
    \u043F\u0440\u0438\u0440\u043E\u0434\u044B, \u043D\u043E \u0432 \u0438\u0442\u043E\u0433\u0435
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u0445\u0438\u043C\u0438\u043A\u0435.
    *   **\u0414\u043E\u0447\u044C**: 29 \u043D\u043E\u044F\u0431\u0440\u044F 1949
    \u0433\u043E\u0434\u0430 \u0443 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C
    \u0434\u043E\u0447\u044C **\u041A\u043B\u043E\u0434\u0438\u043D \u041C\u043E\u043D\u0442\u0435\u0439
    (Claudine Monteil)**. \u041E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u043C
    \u0434\u0438\u043F\u043B\u043E\u043C\u0430\u0442\u043E\u043C, \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u0435\u043C
    \u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u043C. *   **\u041F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u043A**:
    \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A **\u0414\u0435\u043D\u0438
    \u0421\u0435\u0440\u0440** \u043F\u0440\u0438\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u0435\u043C\u0443 \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u043A\u043E\u043C.
    *   **\u0423\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F**: \u0421\u0435\u0440\u0440
    \u043B\u044E\u0431\u0438\u043B \u0430\u043A\u0442\u0438\u0432\u043D\u044B\u0439
    \u043E\u0442\u0434\u044B\u0445 \u2014 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0433\u043E\u0440\u043D\u044B\u043C\u0438 \u043B\u044B\u0436\u0430\u043C\u0438,
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043D\u044B\u043C \u0442\u0435\u043D\u043D\u0438\u0441\u043E\u043C
    \u0438 \u0441\u043A\u0430\u043B\u043E\u043B\u0430\u0437\u0430\u043D\u0438\u0435\u043C
    \u0432 \u0424\u043E\u043D\u0442\u0435\u043D\u0431\u043B\u043E.  ### \U0001F91D
    \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438
    \u0443\u0447\u0451\u043D\u044B\u043C\u0438  \u042D\u0442\u043E \u043E\u0434\u043D\u0430
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u044F\u0440\u043A\u0438\u0445 \u0441\u0442\u0440\u0430\u043D\u0438\u0446
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438. \u0421\u0435\u0440\u0440
    \u0432\u0440\u0430\u0449\u0430\u043B\u0441\u044F \u0432 \u044D\u043F\u0438\u0446\u0435\u043D\u0442\u0440\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438 XX \u0432\u0435\u043A\u0430.  *   **\u0410\u043D\u0440\u0438
    \u041A\u0430\u0440\u0442\u0430\u043D (\u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C)**:
    \u041A\u0430\u0440\u0442\u0430\u043D \u0431\u044B\u043B \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C,
    \u043D\u043E \u043E\u043D \u043D\u0435 \u0434\u0430\u0432\u0430\u043B \u0433\u043E\u0442\u043E\u0432\u044B\u0445
    \u0442\u0435\u043C \u0434\u043B\u044F \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    \u2014 \u0443\u0447\u0435\u043D\u0438\u043A\u0438 \u0434\u043E\u043B\u0436\u043D\u044B
    \u0431\u044B\u043B\u0438 \u043D\u0430\u0439\u0442\u0438 \u0438\u0445 \u0441\u0430\u043C\u0438.
    \u0412 1948\u20131949 \u0433\u043E\u0434\u0430\u0445 \u0421\u0435\u0440\u0440
    \u043F\u043E\u0441\u0435\u0449\u0430\u043B \u0441\u0435\u043C\u0438\u043D\u0430\u0440
    \u041A\u0430\u0440\u0442\u0430\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0448\u043A\u043E\u043B\u043E\u0439
    \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u0430. *   **\u0413\u0440\u0443\u043F\u043F\u0430
    \u0411\u0443\u0440\u0431\u0430\u043A\u0438 (Nicolas Bourbaki)**: \u0421\u0435\u0440\u0440
    \u0441\u0442\u0430\u043B \u0441\u0430\u043C\u044B\u043C \u043C\u043E\u043B\u043E\u0434\u044B\u043C
    \u0447\u043B\u0435\u043D\u043E\u043C \u044D\u0442\u043E\u0439 \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u044B \u043D\u0435\u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432. \u041E\u043D
    \u043F\u0440\u0438\u0441\u043E\u0435\u0434\u0438\u043D\u0438\u043B\u0441\u044F
    \u043A \u043D\u0435\u0439 \u0432 \u043A\u043E\u043D\u0446\u0435 1940-\u0445,
    \u043A\u043E\u0433\u0434\u0430 \u0442\u0430\u043C \u0443\u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438
    \u0410\u043D\u0440\u0438 \u041A\u0430\u0440\u0442\u0430\u043D, \u041A\u043B\u043E\u0434
    \u0428\u0435\u0432\u0430\u043B\u043B\u0435, \u0416\u0430\u043D \u0414\u044C\u0451\u0434\u043E\u043D\u043D\u0435
    \u0438 \u0410\u043D\u0434\u0440\u0435 \u0412\u0435\u0439\u043B\u044C. *   **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A (\u0434\u0440\u0443\u0433,
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430, \u043E\u043F\u043F\u043E\u043D\u0435\u043D\u0442)**:
    \u041F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u044B\u0435 \u0441\u043B\u043E\u0436\u043D\u044B\u0435
    \u0438 \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u0435
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F. \u041E\u043D\u0438 \u043F\u043E\u0434\u0440\u0443\u0436\u0438\u043B\u0438\u0441\u044C,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430\u043C\u0438.    
    *   **\u0421\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    (\u043A\u043E\u043D\u0435\u0446 1950-\u0445 \u2013 \u043D\u0430\u0447\u0430\u043B\u043E
    1960-\u0445)**: \u0412\u043C\u0435\u0441\u0442\u0435 \u043E\u043D\u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u044B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u0418\u0445 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430
    1955\u20131965 \u0433\u043E\u0434\u043E\u0432, \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u043C \u0442\u043E\u043C\u043E\u043C,
    \u2014 \u044D\u0442\u043E \u0436\u0438\u0432\u0430\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0421\u0435\u0440\u0440
    \u043F\u0438\u0441\u0430\u043B \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0443
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0435 \u043E\u0442\u0447\u0435\u0442\u044B
    \u0441 \u043A\u043E\u043D\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0439 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0438\u0437 \u0412\u0443\u0434\u0441-\u0425\u043E\u0443\u043B \u0432 1964 \u0433\u043E\u0434\u0443),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u043B\u0438
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430 \u043D\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u043E\u0442\u0438\u0432\u043E\u0432.    
    *   **\u0420\u0430\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435**: \u041A
    \u043A\u043E\u043D\u0446\u0443 1960-\u0445 \u0438\u0445 \u043F\u043E\u0434\u0445\u043E\u0434\u044B
    \u0440\u0430\u0437\u043E\u0448\u043B\u0438\u0441\u044C. \u0421\u0435\u0440\u0440
    \u0431\u044B\u043B \u0431\u043E\u043B\u0435\u0435 \u043F\u0440\u0430\u0433\u043C\u0430\u0442\u0438\u0447\u0435\u043D,
    \u043B\u044E\u0431\u0438\u043B \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0438 \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    (\"jolies choses\" \u2014 \"\u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0435
    \u0432\u0435\u0449\u0438\"), \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F
    \u043A\u0430\u043A \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435\u043C \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u044B\u0445
    \u043E\u0431\u0449\u0438\u0445 \u0442\u0435\u043E\u0440\u0438\u0439.     *  
    **\u0413\u043E\u0440\u044C\u043A\u0438\u0439 \u0444\u0438\u043D\u0430\u043B (1980-\u0435)**:
    \u041F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E \u043A\u0430\u043A \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u043F\u043E\u043A\u0438\u043D\u0443\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0438\u0440 \u0438 \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u044E
    \u0430\u0432\u0442\u043E\u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \"R\xE9coltes et Semailles\" (\"\u0423\u0440\u043E\u0436\u0430\u0439
    \u0438 \u043F\u043E\u0441\u0435\u0432\"), \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u0435\u0435 \u0431\u044B\u0432\u0448\u0438\u043C \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C.
    \u0421\u0435\u0440\u0440 \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0445, \u043A\u0442\u043E \u043E\u0442\u0432\u0435\u0442\u0438\u043B.
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A \u0443\u043F\u0440\u0435\u043A\u043D\u0443\u043B
    \u0421\u0435\u0440\u0440\u0430 \u0437\u0430 \u0442\u043E, \u0447\u0442\u043E
    \u0442\u043E\u0442 \"\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u0440\u0438\u044F\u0442\u043D\u044B\u0435 \u0432\u0435\u0449\u0438\" \u0438
    \"\u0441 \u0443\u0436\u0430\u0441\u043E\u043C \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0441\u044F
    \u043A \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E\u043C\u0443 \u0441\u0430\u043C\u043E\u0430\u043D\u0430\u043B\u0438\u0437\u0443\".
    \u0418\u0445 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430 \u0432 \u0442\u0435
    \u0433\u043E\u0434\u044B \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u043C
    \u043C\u043E\u0441\u0442\u0438\u043A\u043E\u043C \u043C\u0435\u0436\u0434\u0443
    \u0434\u0432\u0443\u043C\u044F \u0433\u0438\u0433\u0430\u043D\u0442\u0430\u043C\u0438.
    *   **\u0410\u043D\u0434\u0440\u0435 \u0412\u0435\u0439\u043B\u044C \u0438 \u041F\u044C\u0435\u0440
    \u0414\u0435\u043B\u0438\u043D\u044C**: \u0421\u0435\u0440\u0440 \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0430\u043B \u0441 \u0412\u0435\u0439\u043B\u0435\u043C,
    \u0430 \u043F\u043E\u0437\u0436\u0435 \u2014 \u0441 **\u041F\u044C\u0435\u0440\u043E\u043C
    \u0414\u0435\u043B\u0438\u043D\u0435\u043C**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437 \u0412\u0435\u0439\u043B\u044F, \u043E\u043F\u0438\u0440\u0430\u044F\u0441\u044C
    \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 \u043D\u0430 \u0438\u0434\u0435\u0438
    \u0421\u0435\u0440\u0440\u0430. \u041E\u043D \u0431\u044B\u043B \u0434\u043B\u044F
    \u043D\u0438\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u043C
    \u0438\u0434\u0435\u0439 \u0438 \u0441\u0442\u0440\u043E\u0433\u0438\u043C \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u043C. 
    \u0421\u0435\u0440\u0440 \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442
    \u043A \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u043E
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443.
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445,
    \u043E\u043D \u0431\u044B\u043B \u043B\u0438\u0448\u0435\u043D \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043D\u043E\u0431\u0438\u0437\u043C\u0430: \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043E\u043D \u0441 \u0443\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u0438\u0435\u043C
    \u0438 \u0443\u0434\u0438\u0432\u043B\u0435\u043D\u0438\u0435\u043C \u0440\u0435\u0430\u0433\u0438\u0440\u043E\u0432\u0430\u043B
    \u043D\u0430 \u0438\u0437\u044F\u0449\u043D\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0434\u0430\u0436\u0435 \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0439 \u043B\u0435\u043C\u043C\u044B,
    \u0435\u0441\u043B\u0438 \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043A\u0440\u0430\u0441\u0438\u0432\u043E\u0439."
  personalLifeEn: 
  shortBioRu: "### \u0416\u0430\u043D-\u041F\u044C\u0435\u0440 \u0421\u0435\u0440\u0440
    (\u0440. 1926) \u2014 \u0433\u0435\u043D\u0438\u0439 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438  **\u041E\u0431\u0449\u0438\u0435
    \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F:** *   **\u0414\u0430\u0442\u0430
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F:** 15 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F
    1926 \u0433\u043E\u0434\u0430. *   **\u041C\u0435\u0441\u0442\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F:**
    \u0411\u0430\u0436 (\u0434\u0435\u043F\u0430\u0440\u0442\u0430\u043C\u0435\u043D\u0442
    \u0412\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0435 \u041F\u0438\u0440\u0435\u043D\u0435\u0438),
    \u0424\u0440\u0430\u043D\u0446\u0438\u044F. *   **\u0413\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u043E:**
    \u0424\u0440\u0430\u043D\u0446\u0438\u044F. *   **\u0421\u0444\u0435\u0440\u0430
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438:** \u0410\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F, \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F, \u0442\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B, \u0442\u0435\u043E\u0440\u0438\u044F \u0433\u0440\u0443\u043F\u043F.
    *   **\u0421\u0442\u0430\u0442\u0443\u0441:** \u041E\u0434\u0438\u043D \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 XX \u0438
    XXI \u0432\u0435\u043A\u043E\u0432, \u043E\u0431\u043B\u0430\u0434\u0430\u0442\u0435\u043B\u044C
    \u0432\u0441\u0435\u0445 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u0435\u043C\u0438\u0439 (\u043A\u0440\u043E\u043C\u0435 \u043F\u0440\u0435\u043C\u0438\u0438
    \u0410\u0431\u0435\u043B\u044F, \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043F\u0435\u0440\u0432\u044B\u043C
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u0432 2003 \u0433\u043E\u0434\u0443). 
    ---  #### 1. \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    (1926\u20131945) \u0416\u0430\u043D-\u041F\u044C\u0435\u0440 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u0444\u0430\u0440\u043C\u0430\u0446\u0435\u0432\u0442\u043E\u0432.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u0416\u0430\u043D \u0421\u0435\u0440\u0440,
    \u0431\u044B\u043B \u0432\u0435\u0442\u0435\u0440\u0430\u043D\u043E\u043C \u041F\u0435\u0440\u0432\u043E\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u0432\u043E\u0439\u043D\u044B (\u043D\u0430\u0433\u0440\u0430\u0436\u0434\u0435\u043D
    \u0412\u043E\u0435\u043D\u043D\u044B\u043C \u043A\u0440\u0435\u0441\u0442\u043E\u043C),
    \u0447\u0442\u043E \u043E\u043A\u0430\u0437\u0430\u043B\u043E \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438 \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430.
    \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 14 \u043B\u0435\u0442
    (\u0432 1940 \u0433\u043E\u0434\u0443), \u043A\u043E\u0433\u0434\u0430 \u043D\u0430\u0446\u0438\u0441\u0442\u0441\u043A\u0430\u044F
    \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044F \u043E\u043A\u043A\u0443\u043F\u0438\u0440\u043E\u0432\u0430\u043B\u0430
    \u0424\u0440\u0430\u043D\u0446\u0438\u044E, \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u043D\u0430 \u044E\u0433 \u0432 \u041C\u043E\u043D\u043F\u0435\u043B\u044C\u0435,
    \u0447\u0442\u043E\u0431\u044B \u0438\u0437\u0431\u0435\u0436\u0430\u0442\u044C
    \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    (\u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u043E,
    \u0447\u0442\u043E \u043E\u043D\u0438 \u043D\u0435 \u0431\u044B\u043B\u0438 \u0435\u0432\u0440\u0435\u044F\u043C\u0438,
    \u0436\u0438\u0437\u043D\u044C \u0432 \u043E\u043A\u043A\u0443\u043F\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0437\u043E\u043D\u0435 \u0431\u044B\u043B\u0430 \u043E\u043F\u0430\u0441\u043D\u043E\u0439). 
    \u0412 \u041C\u043E\u043D\u043F\u0435\u043B\u044C\u0435 \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u043B\u0438\u0446\u0435\u0439, \u0433\u0434\u0435 \u0435\u0433\u043E
    \u0442\u0430\u043B\u0430\u043D\u0442 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B \u0443\u0447\u0438\u0442\u0435\u043B\u044C.
    \u0412 1944 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    17 \u043B\u0435\u0442, \u043E\u043D \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u041F\u0430\u0440\u0438\u0436, \u0447\u0442\u043E\u0431\u044B \u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C\u0441\u044F
    \u043A \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044E \u0432
    \u0441\u0430\u043C\u0443\u044E \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E
    \u044D\u043B\u0438\u0442\u043D\u0443\u044E \u0448\u043A\u043E\u043B\u0443 \u0424\u0440\u0430\u043D\u0446\u0438\u0438
    \u2014 **\u0412\u044B\u0441\u0448\u0443\u044E \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 (\xC9cole Normale Sup\xE9rieure)** \u043D\u0430
    \u0443\u043B\u0438\u0446\u0435 \u0423\u043B\u044C\u043C.  \u0412 1945 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0443\u0441\u043F\u0435\u0448\u043D\u043E \u0441\u0434\u0430\u0435\u0442
    \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u044B \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442
    \u043F\u0435\u0440\u0432\u043E\u0435 \u043C\u0435\u0441\u0442\u043E, \u043F\u043E\u0441\u0442\u0443\u043F\u0430\u044F
    \u0432 ENS.  #### 2. \u0420\u0430\u043D\u043D\u044F\u044F \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F (1945\u20131951)
    \u0412 \u0412\u044B\u0441\u0448\u0435\u0439 \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 \u0421\u0435\u0440\u0440 \u043F\u043E\u043F\u0430\u043B
    \u043F\u043E\u0434 \u0432\u043B\u0438\u044F\u043D\u0438\u0435 **\u0410\u043D\u0440\u0438
    \u041A\u0430\u0440\u0442\u0430\u043D\u0430** \u2014 \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438. \u041A\u0430\u0440\u0442\u0430\u043D
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0443\u044E
    \u043E\u0434\u0430\u0440\u0435\u043D\u043D\u043E\u0441\u0442\u044C \u0421\u0435\u0440\u0440\u0430
    \u0438 \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0441\u0442\u0430\u043B
    \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C. 
    \u0412 1948 \u0433\u043E\u0434\u0443 \u0421\u0435\u0440\u0440 \u0437\u0430\u0449\u0438\u0449\u0430\u0435\u0442
    \u0434\u0438\u043F\u043B\u043E\u043C\u043D\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443.
    \u0412 1949 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0443\u0431\u043B\u0438\u043A\u0443\u0435\u0442
    \u0441\u0432\u043E\u044E \u043F\u0435\u0440\u0432\u0443\u044E \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043E \u0441\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044F\u0445.
    \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 23 \u043B\u0435\u0442
    \u043E\u043D \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u043C
    \u0432 \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u043C
    \u0446\u0435\u043D\u0442\u0440\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0424\u0440\u0430\u043D\u0446\u0438\u0438
    (CNRS).  **\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u043F\u0440\u043E\u0440\u044B\u0432
    (1950):** \u0421\u0435\u0440\u0440 \u043F\u0438\u0448\u0435\u0442 \u0441\u0432\u043E\u044E
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u043D\u0430 \u0442\u0435\u043C\u0443 \u0433\u043E\u043C\u043E\u0442\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0433\u0440\u0443\u043F\u043F \u0441\u0444\u0435\u0440. \u041E\u043D \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0435\u0442
    \u0441\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0435 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0421\u0435\u0440\u0440\u0430 (\u043D\u044B\u043D\u0435 \u043D\u043E\u0441\u044F\u0449\u0438\u0435
    \u0435\u0433\u043E \u0438\u043C\u044F) \u0434\u043B\u044F \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0433\u043E\u043C\u043E\u0442\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0433\u0440\u0443\u043F\u043F. \u0414\u043E \u043D\u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043D\u0435 \u0437\u043D\u0430\u043B\u0438, \u043A\u0430\u043A \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u0442\u044C
    \u044D\u0442\u0438 \u0433\u0440\u0443\u043F\u043F\u044B \u0434\u0430\u0436\u0435
    \u0434\u043B\u044F \u043F\u0440\u043E\u0441\u0442\u0435\u0439\u0448\u0438\u0445
    \u0441\u0444\u0435\u0440, \u0430 \u0421\u0435\u0440\u0440 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434\u044B, \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0438\u0435
    \u044D\u0442\u043E \u0434\u0435\u043B\u0430\u0442\u044C. \u0412 1951 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C.  #### 3. \u041F\u0435\u0440\u0435\u0445\u043E\u0434
    \u043A \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 (1952\u20131955) \u041F\u043E\u0441\u043B\u0435
    \u0437\u0430\u0449\u0438\u0442\u044B \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438
    \u0421\u0435\u0440\u0440 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E
    \u043C\u0435\u043D\u044F\u0435\u0442 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435.
    \u041E\u043D \u0440\u0435\u0448\u0430\u0435\u0442 \u0437\u0430\u043D\u044F\u0442\u044C\u0441\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439 (\u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435\u043C
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432, \u0437\u0430\u0434\u0430\u043D\u043D\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u0430\u043C\u0438).  \u0412
    1955 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0443\u0431\u043B\u0438\u043A\u0443\u0435\u0442
    \u0441\u0432\u043E\u044E \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u0443\u044E
    \u0441\u0442\u0430\u0442\u044C\u044E **\xABFaisceaux alg\xE9briques coh\xE9rents\xBB**
    (\u0410\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043E\u0433\u0435\u0440\u0435\u043D\u0442\u043D\u044B\u0435 \u043F\u0443\u0447\u043A\u0438).
    \u0412 \u044D\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 \u043E\u043D
    \u0434\u0435\u043B\u0430\u0435\u0442 \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u044B\u0439
    \u043F\u0440\u043E\u0440\u044B\u0432: *   \u041E\u043D \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u0442
    \u043C\u0435\u0442\u043E\u0434\u044B \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u0443\u0447\u043A\u043E\u0432
    (\u0438\u0437 \u0430\u043D\u0430\u043B\u0438\u0437\u0430) \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E. *   \u041E\u043D \u0432\u0432\u043E\u0434\u0438\u0442
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0439
    \u043F\u0443\u0447\u043A\u043E\u0432 \u0434\u043B\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439. *  
    \u041E\u043D \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u0443\u0435\u0442
    \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0443\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443
    (\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0421\u0435\u0440\u0440\u0430 \u043E\u0431
    \u0430\u0444\u0444\u0438\u043D\u043D\u043E\u0441\u0442\u0438), \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0443\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442
    \u0442\u043E\u0447\u043D\u0443\u044E \u0441\u0432\u044F\u0437\u044C \u043C\u0435\u0436\u0434\u0443
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\u043C\u0438 \u043A\u043E\u043B\u044C\u0446\u0430
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432 \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\u043C\u0438 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430. 
    \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u043B\u0430
    \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0430
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u0441\u043A\u043E\u0440\u0435 \u043F\u0440\u0438\u0435\u0445\u0430\u043B
    \u0432 \u041F\u0430\u0440\u0438\u0436 \u0438 \u0432\u043C\u0435\u0441\u0442\u0435
    \u0441 \u0421\u0435\u0440\u0440\u043E\u043C \u0441\u043E\u0437\u0434\u0430\u043B
    \u043E\u0441\u043D\u043E\u0432\u0443 \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 (\u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435 \u0441\u0435\u043C\u0438\u043D\u0430\u0440\u044B
    \u0421\u0435\u0440\u0440\u0430-\u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430). 
    #### 4. \u0420\u0430\u0431\u043E\u0442\u0430 \u0441 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u043E\u043C
    \u0438 \u043E\u0442\u043A\u0430\u0437 \u043E\u0442 \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0430
    (1956\u20131969) \u0412 \u043A\u043E\u043D\u0446\u0435 1950-\u0445 \u0421\u0435\u0440\u0440
    \u0438 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A \u0441\u0442\u0430\u043D\u043E\u0432\u044F\u0442\u0441\u044F
    \u043D\u0435\u0440\u0430\u0437\u043B\u0443\u0447\u043D\u044B. \u041E\u043D\u0438
    \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442 \u043D\u0430\u0434 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435\u043C
    \u043E\u0441\u043D\u043E\u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0441\u0445\u0435\u043C
    (\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0442
    \u0440\u0435\u0448\u0430\u0442\u044C \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u0432 \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445 \u043F\u043E\u043B\u044F\u0445).
    \u041E\u0434\u043D\u0430\u043A\u043E \u043C\u0435\u0436\u0434\u0443 \u043D\u0438\u043C\u0438
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0440\u0430\u0437\u043B\u0438\u0447\u0438\u0435: *   **\u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A**
    \u0431\u044B\u043B \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u0438\u0441\u0442\u043E\u043C:
    \u043E\u043D \u0445\u043E\u0442\u0435\u043B \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C
    \u0441\u0430\u043C\u0443\u044E \u043E\u0431\u0449\u0443\u044E \u0442\u0435\u043E\u0440\u0438\u044E,
    \u0440\u0435\u0448\u0430\u044E\u0449\u0443\u044E \u0432\u0441\u0435 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
    \u0441\u0440\u0430\u0437\u0443, \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043D\u0430 \u0443\u0440\u043E\u0432\u043D\u0435 \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u044B\u0445
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u0439. *   **\u0421\u0435\u0440\u0440**
    \u0431\u044B\u043B \u0443\u043C\u0435\u0440\u0435\u043D\u043D\u044B\u043C: \u043E\u043D
    \u0432\u0435\u0440\u0438\u043B \u0432 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438, \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0435
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0438 \u043D\u0430\u0433\u043B\u044F\u0434\u043D\u044B\u0435
    \u043F\u0440\u0438\u043C\u0435\u0440\u044B.  \u041A \u043A\u043E\u043D\u0446\u0443
    1960-\u0445 \u0433\u043E\u0434\u043E\u0432 \u0438\u0445 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0443\u0442\u0438 \u0440\u0430\u0437\u043E\u0448\u043B\u0438\u0441\u044C.
    \u0421\u0435\u0440\u0440 \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u0443\u0447\u0430\u0441\u0442\u0438\u044F \u0432 \u043F\u0440\u043E\u0435\u043A\u0442\u0435
    Grothendieck's *EGA* (\u042D\u043B\u0435\u043C\u0435\u043D\u0442\u044B \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438), \u043F\u043E\u0441\u0447\u0438\u0442\u0430\u0432,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u043E\u0442\u043E\u0440\u0432\u0430\u043D\u043E \u043E\u0442 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u041E\u043D \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0442\u0435\u043E\u0440\u0438\u044E \u0447\u0438\u0441\u0435\u043B. 
    #### 5. \u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B \u0438
    \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u044B\u0435 \u0444\u043E\u0440\u043C\u044B
    (1970\u20131980-\u0435) \u0412 1970-\u0445 \u0421\u0435\u0440\u0440 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u0444\u0438\u0433\u0443\u0440 \u0432 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u041E\u043D \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442\u0441\u044F
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435\u043C \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0438\u0432\u044B\u0445 \u0438 \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u044B\u0445
    \u0444\u043E\u0440\u043C.  **\u0413\u043B\u0430\u0432\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u044D\u0442\u043E\u0433\u043E \u043F\u0435\u0440\u0438\u043E\u0434\u0430:**
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u0438
    (\u0432 \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u0441\u0442\u0432\u0435 \u0441
    \u041F\u044C\u0435\u0440\u043E\u043C \u0414\u0435\u043B\u0438\u043D\u0435\u043C):**
    \u041E\u043D\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B\u0438, \u0447\u0442\u043E
    \u0432\u0441\u0435 \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u044B\u0435
    \u0444\u043E\u0440\u043C\u044B \u043C\u043E\u0436\u043D\u043E \u0441\u0432\u044F\u0437\u0430\u0442\u044C
    \u0441 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F\u043C\u0438
    \u0413\u0430\u043B\u0443\u0430. \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0441\u0442\u0430\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0412\u0435\u043B\u0438\u043A\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u0424\u0435\u0440\u043C\u0430 \u042D\u043D\u0434\u0440\u044E \u0423\u0430\u0439\u043B\u0441\u043E\u043C
    (1994), \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0421\u0435\u0440\u0440\u0430
    \u0438 \u0414\u0435\u043B\u0438\u043D\u044F. *   **\u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u0421\u0435\u0440\u0440\u0430 \u043E \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u0438
    (1975):** \u041E\u043D \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u0432\u0441\u0435 \u0434\u0432\u0443\u043C\u0435\u0440\u043D\u044B\u0435
    \u043D\u0435\u0447\u0435\u0442\u043D\u044B\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0413\u0430\u043B\u0443\u0430 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u044F\u0442
    \u0438\u0437 \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u044B\u0445 \u0444\u043E\u0440\u043C.
    \u042D\u0442\u0430 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430 \u0431\u044B\u043B\u0430
    \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u0430
    \u0442\u043E\u043B\u044C\u043A\u043E \u0432 2000-\u0445 \u0433\u043E\u0434\u0430\u0445
    \u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043B\u0435\u0433\u043B\u0430
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0424\u0435\u0440\u043C\u0430.  ####
    6. \u041F\u0440\u0435\u043C\u0438\u0438 \u0438 \u043C\u0438\u0440\u043E\u0432\u043E\u0435
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0416\u0430\u043D-\u041F\u044C\u0435\u0440
    \u0421\u0435\u0440\u0440 \u2014 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438,
    \u043F\u043E\u043B\u0443\u0447\u0438\u0432\u0448\u0438\u0439 \u0442\u0440\u0438
    \u0441\u0430\u043C\u044B\u0435 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0435
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B (\u043D\u0435 \u0441\u0447\u0438\u0442\u0430\u044F
    \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439 \u043C\u0435\u0434\u0430\u043B\u0438):
    *   **\u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0430\u044F \u043C\u0435\u0434\u0430\u043B\u044C
    (1954)** \u2014 \u043D\u0430 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u043C
    \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0432 \u0410\u043C\u0441\u0442\u0435\u0440\u0434\u0430\u043C\u0435. \u041D\u0430
    \u043C\u043E\u043C\u0435\u043D\u0442 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F
    \u0435\u043C\u0443 \u0431\u044B\u043B\u043E 27 \u043B\u0435\u0442, \u043E\u043D
    \u0431\u044B\u043B \u0441\u0430\u043C\u044B\u043C \u043C\u043E\u043B\u043E\u0434\u044B\u043C
    \u043D\u0430 \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442 \u043B\u0430\u0443\u0440\u0435\u0430\u0442\u043E\u043C.
    *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0411\u0430\u043B\u044C\u0446\u0430\u043D\u0430
    (1985)** \u2014 \u0437\u0430 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. *   **\u041F\u0440\u0435\u043C\u0438\u044F
    \u0421\u0442\u0438\u043B\u0430 (1995)** \u2014 \u0437\u0430 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0412\u043E\u043B\u044C\u0444\u0430
    (2000)** \u2014 \u0437\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044E,
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0438 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0447\u0438\u0441\u0435\u043B. *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0410\u0431\u0435\u043B\u044F
    (2003)** \u2014 \u043E\u043D \u0441\u0442\u0430\u043B **\u043F\u0435\u0440\u0432\u044B\u043C**
    \u043B\u0430\u0443\u0440\u0435\u0430\u0442\u043E\u043C \u044D\u0442\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438 (\u043E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u0443\u0447\u0440\u0435\u0436\u0434\u0435\u043D\u0430 \u0432 2002 \u0433\u043E\u0434\u0443).
    \u041D\u0430\u0433\u0440\u0430\u0436\u0434\u0451\u043D \"\u0437\u0430 \u0435\u0433\u043E
    \u0440\u043E\u043B\u044C \u0432 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E \u043E\u0431\u043B\u0438\u043A\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\".  #### 7. \u041F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043F\u043E\u0437\u0438\u0446\u0438\u044F \u0438 \u043F\u0430\u0446\u0438\u0444\u0438\u0437\u043C
    \u0421\u0435\u0440\u0440 \u0432\u0441\u0435\u0433\u0434\u0430 \u0431\u044B\u043B
    \u0430\u043A\u0442\u0438\u0432\u043D\u044B\u043C \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0438\u043D\u043E\u043C.
    \u0412 1960-\u0445 \u0433\u043E\u0434\u0430\u0445 \u043E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B \u043F\u0440\u043E\u0442\u0438\u0432
    \u0432\u043E\u0439\u043D\u044B \u0432 \u0410\u043B\u0436\u0438\u0440\u0435 (\u043E\u043D
    \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \"\u041C\u0430\u043D\u0438\u0444\u0435\u0441\u0442 121\" \u2014 \u043F\u0440\u0438\u0437\u044B\u0432
    \u043A \u043D\u0435\u043F\u043E\u0432\u0438\u043D\u043E\u0432\u0435\u043D\u0438\u044E
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0430\u043B\u0436\u0438\u0440\u0441\u043A\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B). \u0412 1968 \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435
    \u0441\u0442\u0443\u0434\u0435\u043D\u0447\u0435\u0441\u043A\u0438\u0445 \u0432\u043E\u043B\u043D\u0435\u043D\u0438\u0439
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435, \u043E\u043D \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u043B
    \u0440\u0435\u0444\u043E\u0440\u043C\u044B \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u043E\u0432,
    \u0442\u0440\u0435\u0431\u0443\u044F \u0434\u0435\u043C\u043E\u043A\u0440\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u0438
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F.  #### 8.
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    (1980\u2013\u043D.\u0432.) \u0421 1980-\u0445 \u0433\u043E\u0434\u043E\u0432
    \u0421\u0435\u0440\u0440 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C\u0441\u044F.
    \u0415\u0433\u043E \u0441\u0442\u0438\u043B\u044C \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u044F
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u044D\u0442\u0430\u043B\u043E\u043D\u043D\u044B\u043C:
    \u043E\u043D \u043F\u0438\u0448\u0435\u0442 \u043A\u043E\u0440\u043E\u0442\u043A\u043E,
    \u044F\u0441\u043D\u043E, \u0438\u0437\u044F\u0449\u043D\u043E, \u0447\u0430\u0441\u0442\u043E
    \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u044F\u0441\u044C \u043E\u0442
    \u0433\u0440\u043E\u043C\u043E\u0437\u0434\u043A\u0438\u0445 \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439.
    \u0414\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 (\u0435\u043C\u0443 \u0443\u0436\u0435
    \u043F\u043E\u0434 100 \u043B\u0435\u0442) \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C \u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440\u0430\u0445 \u0432 \u041A\u043E\u043B\u043B\u0435\u0436
    \u0434\u0435 \u0424\u0440\u0430\u043D\u0441 (\u0433\u0434\u0435 \u043E\u043D
    \u0431\u044B\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0441 1956 \u043F\u043E 1994 \u0433\u043E\u0434) \u0438 \u0432\u0435\u0434\u0435\u0442
    \u0430\u043A\u0442\u0438\u0432\u043D\u0443\u044E \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443
    \u0441 \u043C\u043E\u043B\u043E\u0434\u044B\u043C\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438
    \u0441\u043E \u0432\u0441\u0435\u0433\u043E \u043C\u0438\u0440\u0430.  \u0412
    2012 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043A\u043D\u0438\u0433\u0443 \"Topics in Galois Theory\" (\u0422\u0435\u043C\u044B
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0413\u0430\u043B\u0443\u0430), \u0433\u0434\u0435
    \u043F\u043E\u0434\u0432\u0435\u043B \u0438\u0442\u043E\u0433\u0438 \u0441\u0432\u043E\u0438\u0445
    \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0438\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. 
    **\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C:** \u0416\u0435\u043D\u0430\u0442
    (\u0441 1952 \u0433\u043E\u0434\u0430) \u043D\u0430 \u0416\u043E\u0437\u0435\u0442\u0442
    \u0421\u0435\u0440\u0440, \u0443 \u043D\u0438\u0445 \u0435\u0441\u0442\u044C
    \u0442\u0440\u043E\u0435 \u0434\u0435\u0442\u0435\u0439. \u041E\u043D \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0441\u0432\u043E\u0438\u043C \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C
    \u044E\u043C\u043E\u0440\u0430 \u0438 \u043A\u0440\u0430\u0439\u043D\u0435\u0439
    \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u044C\u044E. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0441\u043B\u0430\u0432\u0443,
    \u043E\u043D \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F
    \u043A \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0430\u043D-\u041F\u044C\u0435\u0440 \u0421\u0435\u0440\u0440
    \u2014 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0433\u043B\u0443\u0431\u043E\u043A\u0430\u044F, \u043D\u043E \u0438 \u0432\u0435\u0441\u044C\u043C\u0430
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F.
    \u0417\u0430 \u0441\u0442\u0440\u043E\u0433\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u043B\u0430\u0432\u043E\u0439 \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0441 \u043E\u0442\u043B\u0438\u0447\u043D\u044B\u043C
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C \u044E\u043C\u043E\u0440\u0430,
    \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u043C\u0438
    \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0430\u043C\u0438 \u0438 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0434\u043B\u044F \u0433\u0435\u043D\u0438\u044F \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u043E\u0439.
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u044F\u0440\u043A\u0438\u0435
    \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0435 \u0444\u0430\u043A\u0442\u044B
    \u0438\u0437 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.  ### \U0001F4DD
    \u0414\u0435\u0442\u0441\u0442\u0432\u043E: \u043A\u0430\u043A \u0441\u0442\u0430\u0442\u044C
    \u0433\u0435\u043D\u0438\u0435\u043C, \u0441\u043F\u0430\u0441\u0430\u044F\u0441\u044C
    \u043E\u0442 \u0445\u0443\u043B\u0438\u0433\u0430\u043D\u043E\u0432  \u0421\u0432\u043E\u0439
    \u043F\u0443\u0442\u044C \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0421\u0435\u0440\u0440 \u043D\u0430\u0447\u0430\u043B \u043D\u0435 \u0441 \u043E\u0441\u043E\u0437\u043D\u0430\u043D\u043D\u043E\u0433\u043E
    \u043F\u0440\u0438\u0437\u0432\u0430\u043D\u0438\u044F, \u0430 \u0441 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438. 
    *   **\u0428\u043A\u043E\u043B\u044C\u043D\u044B\u0439 \"\u0440\u0435\u043F\u0435\u0442\u0438\u0442\u043E\u0440\"
    \u0434\u043B\u044F \u0441\u0442\u0430\u0440\u0448\u0438\u0445**: \u0412 \u043F\u0430\u043D\u0441\u0438\u043E\u043D\u0435
    \u0432 \u041D\u0438\u043C\u0435 \u0435\u0433\u043E, \u043C\u043B\u0430\u0434\u0448\u0435\u0433\u043E,
    \u043E\u0431\u0438\u0436\u0430\u043B\u0438 \u0441\u0442\u0430\u0440\u0448\u0438\u0435
    \u043C\u0430\u043B\u044C\u0447\u0438\u0448\u043A\u0438. \u0427\u0442\u043E\u0431\u044B
    \u0438\u0445 \u0443\u0442\u0438\u0445\u043E\u043C\u0438\u0440\u0438\u0442\u044C,
    \u0421\u0435\u0440\u0440 \u043D\u0430\u0447\u0430\u043B \u0434\u0435\u043B\u0430\u0442\u044C
    \u0437\u0430 \u043D\u0438\u0445 \u0434\u043E\u043C\u0430\u0448\u043D\u0438\u0435
    \u0437\u0430\u0434\u0430\u043D\u0438\u044F \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u041F\u043E\u0437\u0436\u0435 \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B
    \u044D\u0442\u043E \u043B\u0443\u0447\u0448\u0435\u0439 \u0442\u0440\u0435\u043D\u0438\u0440\u043E\u0432\u043A\u043E\u0439.
    *   **\u0423\u0440\u043E\u043A\u0438 \u043E\u0442 \u043C\u0430\u043C\u044B-\u0444\u0430\u0440\u043C\u0430\u0446\u0435\u0432\u0442\u0430**:
    \u0415\u0433\u043E \u043C\u0430\u0442\u044C, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043A\u043E\u0439 \u0444\u0430\u0440\u043C\u0430\u0446\u0435\u0432\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0430, \u0440\u0430\u0434\u0438
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0430 \u043F\u0440\u043E\u0441\u043B\u0443\u0448\u0430\u043B\u0430
    \u043A\u0443\u0440\u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430. \u0423\u0447\u0435\u0431\u043D\u0438\u043A\u0438,
    \u043F\u043E \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u043E\u043D\u0430 \u0443\u0447\u0438\u043B\u0430\u0441\u044C,
    \u043E\u043D\u0430 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430, \u0438
    \u0432 14-15 \u043B\u0435\u0442 \u0416\u0430\u043D-\u041F\u044C\u0435\u0440 \u043D\u0430\u0447\u0430\u043B
    \u0438\u0445 \u0438\u0437\u0443\u0447\u0430\u0442\u044C, \u043E\u0441\u0432\u043E\u0438\u0432
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u0435 \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044B
    \u0432 \"\u044D\u0439\u043B\u0435\u0440\u043E\u0432\u0441\u043A\u043E\u043C\"
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u043C \u0441\u0442\u0438\u043B\u0435
    (\u0431\u0435\u0437 \u0441\u0442\u0440\u043E\u0433\u0438\u0445 \u044D\u043F\u0441\u0438\u043B\u043E\u043D-\u0434\u0435\u043B\u044C\u0442\u0430-\u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0439).
    *   **\u041F\u0440\u043E\u0432\u0430\u043B \u043D\u0430 \u0444\u0438\u0437\u0438\u043A\u0435**:
    \u0412 1944 \u0433\u043E\u0434\u0443 \u043E\u043D \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u043C
    \u043A\u043E\u043D\u043A\u0443\u0440\u0441\u0435 \u043F\u043E \u0444\u0438\u0437\u0438\u043A\u0435.
    \u0417\u0430\u0434\u0430\u043D\u0438\u0435 \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u043E
    \u0437\u043D\u0430\u043D\u0438\u044F \u0437\u0430\u043A\u043E\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043E\u043D \u043D\u0435 \u0437\u043D\u0430\u043B. \u0420\u0435\u0448\u0438\u0432,
    \u0447\u0442\u043E \u0438\u0437 \u0432\u0441\u0435\u0445 \u0444\u043E\u0440\u043C\u0443\u043B
    \u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0442 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0434\u043D\u0430, \u043E\u043D 6 \u0447\u0430\u0441\u043E\u0432 \u0440\u0435\u0448\u0430\u043B
    \u0437\u0430\u0434\u0430\u0447\u0443 \u043D\u0430 \u0435\u0435 \u043E\u0441\u043D\u043E\u0432\u0435,
    \u0431\u044B\u043B \u0443\u0432\u0435\u0440\u0435\u043D \u0432 \u043F\u043E\u0431\u0435\u0434\u0435...
    \u043D\u043E \u0444\u043E\u0440\u043C\u0443\u043B\u0430 \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C
    \u043D\u0435\u0432\u0435\u0440\u043D\u043E\u0439, \u0438 \u043E\u043D \u043D\u0435
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043D\u0438\u0447\u0435\u0433\u043E. 
    ### \U0001F4A1 \u0420\u0430\u0431\u043E\u0447\u0438\u0439 \u043F\u0440\u043E\u0446\u0435\u0441\u0441:
    \u0433\u0440\u044F\u0437\u043D\u0430\u044F \u043F\u043E\u0441\u0443\u0434\u0430
    \u0438 \u043F\u043E\u043B\u0443\u043D\u043E\u0447\u043D\u044B\u0435 \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u044F 
    \u0421\u0435\u0440\u0440 \u043C\u044B\u0441\u043B\u0438\u0442 \u0441\u043E\u0432\u0441\u0435\u043C
    \u043D\u0435 \u0442\u0430\u043A, \u043A\u0430\u043A \u043E\u0431\u044B\u0447\u043D\u044B\u0435
    \u043B\u044E\u0434\u0438, \u0430 \u0435\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u044B
    \"\u0440\u0430\u0431\u043E\u0442\u044B\" \u043C\u043E\u0433\u0443\u0442 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C\u0441\u044F
    \u0432\u0435\u0441\u044C\u043C\u0430 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u043C\u0438. 
    *   **\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442
    \u2014 \u043A\u0443\u0445\u043E\u043D\u043D\u0430\u044F \u0440\u0430\u043A\u043E\u0432\u0438\u043D\u0430**:
    \u0421\u0435\u0440\u0440 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u043C\u044B\u0442\u044C\u0435 \u043F\u043E\u0441\u0443\u0434\u044B
    \u2014 \u044D\u0442\u043E \u043E\u0442\u043B\u0438\u0447\u043D\u043E\u0435 \u0432\u0440\u0435\u043C\u044F
    \u0434\u043B\u044F \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439
    \u043D\u0430\u0434 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0437\u0430\u0434\u0430\u0447\u0430\u043C\u0438. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u043E\u0432\u0430\u043B \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u0433\u043E\u0442\u043E\u0432\u043A\u043E\u0439, \u043A\u0430\u043A \"\u043B\u0435\u0433\u043A\u0438\u043C
    \u0438 \u043F\u043E\u0432\u0442\u043E\u0440\u044F\u044E\u0449\u0438\u043C\u0441\u044F\"
    \u0434\u0435\u043B\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0445\u043E\u0440\u043E\u0448\u043E
    \u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0430\u0435\u0442 \u043C\u043E\u0437\u0433
    \u0434\u043B\u044F \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u043C\u044B\u0441\u043B\u0435\u0439.
    *   **\u0420\u0430\u0431\u043E\u0442\u0430 \u0432 \u043F\u043E\u043B\u0443\u0441\u043D\u0435**:
    \u041E\u043D \u0447\u0430\u0441\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043F\u043E \u043D\u043E\u0447\u0430\u043C, \u0432 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0438
    \"\u043F\u043E\u043B\u0443\u0441\u043D\u0430\", \u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u043D\u0443\u0436\u043D\u043E \u043D\u0438\u0447\u0435\u0433\u043E
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C. \u042D\u0442\u043E,
    \u043F\u043E \u0435\u0433\u043E \u0441\u043B\u043E\u0432\u0430\u043C, \u0434\u0430\u0435\u0442
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u043B\u0443\u0447\u0448\u0435
    \u0441\u043A\u043E\u043D\u0446\u0435\u043D\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C\u0441\u044F
    \u0438 \u043B\u0435\u0433\u0447\u0435 \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0442\u044C\u0441\u044F
    \u043C\u0435\u0436\u0434\u0443 \u0442\u0435\u043C\u0430\u043C\u0438. *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0432 \u043A\u0438\u043D\u043E\u0442\u0435\u0430\u0442\u0440\u0435**: \u0412\u043E
    \u0432\u0440\u0435\u043C\u044F \u0441\u0435\u0430\u043D\u0441\u043E\u0432 \u0432
    \u043A\u0438\u043D\u043E, \u0432 \u043F\u0435\u0440\u0435\u0440\u044B\u0432\u0430\u0445
    \u043C\u0435\u0436\u0434\u0443 \u0440\u0435\u043A\u043B\u0430\u043C\u043D\u044B\u043C\u0438
    \u0440\u043E\u043B\u0438\u043A\u0430\u043C\u0438, \u0421\u0435\u0440\u0440 \u0437\u0430\u043A\u0440\u044B\u0432\u0430\u043B
    \u0433\u043B\u0430\u0437\u0430 \u0438 \u043F\u043E\u0433\u0440\u0443\u0436\u0430\u043B\u0441\u044F
    \u0432 \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F \u043E
    \u0441\u0432\u043E\u0438\u0445 \u0437\u0430\u0434\u0430\u0447\u0430\u0445.  ###
    \U0001F3AD \"\u0421\u0435\u0440\u0440 1, \u0413\u0430\u0431\u0435\u0440 0\":
    \u044E\u043C\u043E\u0440 \u0438 \u0434\u0443\u0445 \u0441\u043E\u043F\u0435\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0430 
    \u0421\u0435\u0440\u0440 \u2014 \u043D\u0435 \u0441\u0443\u0445\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A.
    \u041D\u0430 \u0441\u0432\u043E\u0438\u0445 \u043B\u0435\u043A\u0446\u0438\u044F\u0445
    \u0432 \u041A\u043E\u043B\u043B\u0435\u0436 \u0434\u0435 \u0424\u0440\u0430\u043D\u0441
    \u043E\u043D \u043B\u044E\u0431\u0438\u043B \u0437\u0430\u0442\u0435\u0432\u0430\u0442\u044C
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438\u0433\u0440\u044B \u0441\u043E \u0441\u0432\u043E\u0438\u043C\u0438 \u0441\u043B\u0443\u0448\u0430\u0442\u0435\u043B\u044F\u043C\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u0430\u043C\u0438 \u0431\u044B\u043B\u0438
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0438\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438. 
    *   **\u0421\u0447\u0435\u0442 \u043D\u0430 \u0434\u043E\u0441\u043A\u0435**:
    \u041D\u0430 \u0441\u0435\u043C\u0438\u043D\u0430\u0440\u0430\u0445 \u0421\u0435\u0440\u0440
    \u043C\u043E\u0433 \u0437\u0430\u043F\u0438\u0441\u0430\u0442\u044C \u043D\u0430
    \u0434\u043E\u0441\u043A\u0435 \"Serre 1, Gaber 0\", \u0435\u0441\u043B\u0438
    \u0435\u043C\u0443 \u0443\u0434\u0430\u0432\u0430\u043B\u043E\u0441\u044C \"\u043F\u043E\u0439\u043C\u0430\u0442\u044C\"
    \u0441\u0432\u043E\u0435\u0433\u043E \u043B\u044E\u0431\u0438\u043C\u043E\u0433\u043E
    \u043E\u043F\u043F\u043E\u043D\u0435\u043D\u0442\u0430 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0441\u043F\u043E\u0440\u0435. \u041E\u043D \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0435
    \u0440\u0430\u0434\u043E\u0432\u0430\u043B\u0441\u044F \u0442\u0430\u043A\u0438\u043C
    \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u043C \u043F\u043E\u0431\u0435\u0434\u0430\u043C.
    *   **\u0418\u043D\u0430\u0443\u0433\u0443\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u0430\u044F
    \u043B\u0435\u043A\u0446\u0438\u044F \u0431\u0435\u0437 \u0442\u0435\u043A\u0441\u0442\u0430**:
    \u041A\u043E\u0433\u0434\u0430 \u0432 1956 \u0433\u043E\u0434\u0443 \u0421\u0435\u0440\u0440
    \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u041A\u043E\u043B\u043B\u0435\u0436 \u0434\u0435 \u0424\u0440\u0430\u043D\u0441,
    \u043E\u043D \u0433\u043E\u0442\u043E\u0432\u0438\u043B \u0441\u0432\u043E\u044E
    \u043F\u0435\u0440\u0432\u0443\u044E \u043B\u0435\u043A\u0446\u0438\u044E \u0446\u0435\u043B\u044B\u0439
    \u043C\u0435\u0441\u044F\u0446, \u043D\u043E \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0432\u0441\u0435\u0433\u043E \u043F\u043E\u043B\u0441\u0442\u0440\u0430\u043D\u0438\u0446\u044B.
    \u0412 \u0438\u0442\u043E\u0433\u0435 \u043E\u043D \u0437\u0430\u0447\u0438\u0442\u0430\u043B
    \u044D\u0442\u043E\u0442 \u043E\u0442\u0440\u044B\u0432\u043E\u043A, \u0430 \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u2014 \u043F\u0440\u043E\u0438\u043C\u043F\u0440\u043E\u0432\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B.
    \u041F\u043E\u0437\u0436\u0435, \u043A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E
    \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B\u0438 \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u0442\u0435\u043A\u0441\u0442 \u0434\u043B\u044F \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438,
    \u043E\u043D \u043D\u0430\u0434\u0438\u043A\u0442\u043E\u0432\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u044E
    \u043D\u0430 \u043F\u043B\u0435\u043D\u043A\u0443, \u043D\u043E \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u044C
    \u0441\u043A\u0430\u0437\u0430\u043B\u0430, \u0447\u0442\u043E \u0437\u0430\u043F\u0438\u0441\u044C
    \u043D\u0435\u0440\u0430\u0437\u0431\u043E\u0440\u0447\u0438\u0432\u0430. \u0412
    \u0438\u0442\u043E\u0433\u0435 \u0435\u0433\u043E \u0438\u043D\u0430\u0443\u0433\u0443\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u0430\u044F
    \u043B\u0435\u043A\u0446\u0438\u044F \u0442\u0430\u043A \u0438 \u043D\u0435 \u0431\u044B\u043B\u0430
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430 \u2014
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u041A\u043E\u043B\u043B\u0435\u0436
    \u0434\u0435 \u0424\u0440\u0430\u043D\u0441.  ### \U0001F3C6 \u0420\u0435\u043A\u043E\u0440\u0434\u044B
    \u0438 \u043F\u043E\u0447\u0442\u0438 \"\u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0430\u044F\"
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F  *   **\u0421\u0430\u043C\u044B\u0439
    \u043C\u043E\u043B\u043E\u0434\u043E\u0439 \u0444\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0438\u0439
    \u043B\u0430\u0443\u0440\u0435\u0430\u0442**: \u0412 1954 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    27 \u043B\u0435\u0442, \u0438 \u044D\u0442\u043E\u0442 \u0440\u0435\u043A\u043E\u0440\u0434
    \u043D\u0435 \u043F\u043E\u0431\u0438\u0442 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440.
    *   **\u041F\u0435\u0440\u0432\u044B\u0439 \u043B\u0430\u0443\u0440\u0435\u0430\u0442
    \u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438**:
    \u0412 2003 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u0435\u0440\u0432\u044B\u043C
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D\u043D\u044B\u043C \u044D\u0442\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u0443\u0447\u0440\u0435\u0436\u0434\u0435\u043D\u0430
    \u043A\u0430\u043A \u0430\u043D\u0430\u043B\u043E\u0433 \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439.
    *   **\"\u041E\u0433\u0440\u0430\u0436\u0434\u0435\u043D\u0438\u0435\" \u043E\u0442
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430**:
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u0440\u0430\u0431\u043E\u0442\u044B
    \u042D\u043D\u0434\u0440\u044E \u0423\u0430\u0439\u043B\u0441\u0430 \u043D\u0430\u0434
    \u0412\u0435\u043B\u0438\u043A\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u043E\u0439
    \u0424\u0435\u0440\u043C\u0430, \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u043D\u0430\u043C\u0435\u0440\u0435\u043D\u043D\u043E
    \u043D\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0438 \u0435\u043C\u0443
    \u0447\u0435\u0440\u043D\u043E\u0432\u0438\u043A\u0438, \u043E\u043F\u0430\u0441\u0430\u044F\u0441\u044C,
    \u0447\u0442\u043E \u0421\u0435\u0440\u0440, \u0441 \u0435\u0433\u043E \u043C\u043E\u043B\u043D\u0438\u0435\u043D\u043E\u0441\u043D\u043E\u0439
    \u0440\u0435\u0430\u043A\u0446\u0438\u0435\u0439, \u0440\u0435\u0448\u0438\u0442
    \u0437\u0430\u0434\u0430\u0447\u0443 \u043F\u0435\u0440\u0432\u044B\u043C.  ###
    \U0001F607 \"\u041E\u0434\u043D\u043E\u0433\u043E \u0411\u043E\u0433\u0430 \u043F\u0440\u043E\u0441\u0438\u0442\u044C
    \u043D\u0435 \u0437\u0430 \u0447\u0442\u043E\": \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u0442\u0435\u0438\u0441\u0442 \u0438 \u0434\u0436\u0435\u043D\u0442\u043B\u044C\u043C\u0435\u043D 
    \u0421\u0435\u0440\u0440 \u2014 \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0442\u0432\u0435\u0440\u0434\u044B\u0445
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u0439. \u0411\u0443\u0434\u0443\u0447\u0438
    \u0432\u043D\u0443\u043A\u043E\u043C \u043F\u0430\u0441\u0442\u043E\u0440\u0430,
    \u043E\u043D \u0441\u0430\u043C \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u0430\u0442\u0435\u0438\u0441\u0442\u043E\u043C. \u041D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441
    \u043E \u0432\u0435\u0440\u0435 \u043E\u043D \u043E\u0442\u0432\u0435\u0447\u0430\u043B
    \u0441 \u043F\u0440\u0438\u0441\u0443\u0449\u0438\u043C \u0435\u043C\u0443 \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u0438\u0435\u043C:
    \"\u041D\u0435\u043B\u044C\u0437\u044F \u0443\u043F\u0440\u0435\u043A\u0430\u0442\u044C
    \u0411\u043E\u0433\u0430 \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u043E\u043D
    \u043D\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442, \u044D\u0442\u043E
    \u0431\u044B\u043B\u043E \u0431\u044B \u043C\u0435\u043B\u043E\u0447\u043D\u043E\".
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0441\u0442\u0430\u0442\u0443\u0441, \u043E\u043D \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F
    \u043A\u0440\u0430\u0439\u043D\u0435 \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u043C
    \u0438 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u043C \u0434\u043B\u044F
    \u043E\u0431\u0449\u0435\u043D\u0438\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438 \u043A\u0430\u043A \"\u0433\u043E\u0442\u043E\u0432\u043E\u0433\u043E
    \u0432\u0441\u0435\u0433\u0434\u0430 \u043E\u0431\u0441\u0443\u0434\u0438\u0442\u044C
    \u043B\u044E\u0431\u0443\u044E \u0438\u0434\u0435\u044E\"."
