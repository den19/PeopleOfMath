  achievementsRu: "\u0412\u043A\u043B\u0430\u0434 \u0416\u0430\u043D-\u041F\u044C\u0435\u0440\u0430
    \u0421\u0435\u0440\u0440\u0430 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0443\u043D\u0438\u043A\u0430\u043B\u0435\u043D \u0442\u0435\u043C, \u0447\u0442\u043E
    \u043E\u043D **\u0442\u0440\u0438\u0436\u0434\u044B \u043F\u0435\u0440\u0435\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0446\u0435\u043B\u044B\u0445
    \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438**
    \u0437\u0430 \u0441\u0432\u043E\u044E \u043A\u0430\u0440\u044C\u0435\u0440\u0443.
    \u0415\u0433\u043E \u0442\u0440\u0443\u0434\u044B \u0434\u0435\u043B\u044F\u0442\u0441\u044F
    \u043D\u0430 \u0442\u0440\u0438 \u0431\u043E\u043B\u044C\u0448\u0438\u0435 \u044D\u043F\u043E\u0445\u0438.
    \u041D\u0438\u0436\u0435 \u2014 \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0440\u0430\u0437\u0431\u043E\u0440 \u043A\u0430\u0436\u0434\u043E\u0433\u043E
    \u044D\u0442\u0430\u043F\u0430, \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u0442\u0435\u043E\u0440\u0435\u043C \u0438 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0445
    \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0439.  ---  ### \u042D\u043F\u043E\u0445\u0430
    1: \u0410\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F (1948\u20131953) \u042D\u0442\u043E
    \u0432\u0440\u0435\u043C\u044F, \u043A\u043E\u0433\u0434\u0430 \u0421\u0435\u0440\u0440
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u0433\u043E\u043C\u043E\u0442\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438.  **1. \u0421\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0421\u0435\u0440\u0440\u0430** \u0412 \u0441\u0432\u043E\u0435\u0439 \u0434\u0438\u043F\u043B\u043E\u043C\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 (1951) \u0421\u0435\u0440\u0440 \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u043E
    \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0438\u043B \u0441\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u041B\u0435\u0440\u0435. \u041E\u043D \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    **\u0441\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u0443\u044E \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0440\u0430\u0441\u0441\u043B\u043E\u0435\u043D\u0438\u044F (Serre spectral
    sequence)**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u0435\u0442
    \u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438 \u0431\u0430\u0437\u044B,
    \u0441\u043B\u043E\u044F \u0438 \u0442\u043E\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430 \u0440\u0430\u0441\u0441\u043B\u043E\u0435\u043D\u0438\u044F. 
    *\u0414\u0435\u0442\u0430\u043B\u044C:* \u0414\u043B\u044F \u043B\u044E\u0431\u043E\u0433\u043E
    \u0440\u0430\u0441\u0441\u043B\u043E\u0435\u043D\u0438\u044F \\( F \\to E \\to
    B \\) \u043E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \\( E^2_{p,q} = H_p(B, H_q(F)) \\Rightarrow H_{p+q}(E) \\). \u042D\u0442\u043E
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u0442\u044C
    \u0433\u043E\u043C\u043E\u0442\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u0440\u0443\u043F\u043F\u044B \u0441\u0444\u0435\u0440, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u043E \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u0438 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E
    \"\u0442\u0451\u043C\u043D\u044B\u043C \u043B\u0435\u0441\u043E\u043C\".  **2.
    \u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043A\u043B\u0430\u0441\u0441\u044B \u0421\u0435\u0440\u0440\u0430 (C-\u0442\u0435\u043E\u0440\u0438\u044F)**
    \u041E\u043D \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    **\u043A\u043B\u0430\u0441\u0441\u043E\u0432 \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445
    \u0433\u0440\u0443\u043F\u043F \u0421\u0435\u0440\u0440\u0430** (\u043A\u043B\u0430\u0441\u0441
    \\( \\mathcal{C} \\) \u0433\u0440\u0443\u043F\u043F, \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0439
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043F\u043E\u0434\u0433\u0440\u0443\u043F\u043F,
    \u0444\u0430\u043A\u0442\u043E\u0440\u043E\u0432 \u0438 \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u0439).
    \u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u044D\u0442\u043E, \u043E\u043D
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E: *   \u0413\u043E\u043C\u043E\u0442\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u0440\u0443\u043F\u043F\u044B \\( \\pi_i(S^n) \\) \u043A\u043E\u043D\u0435\u0447\u043D\u044B
    \u0434\u043B\u044F \u0432\u0441\u0435\u0445 \\( i > n \\), \u0437\u0430 \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435\u043C
    \u0441\u043B\u0443\u0447\u0430\u044F \\( i = 2n-1 \\), \u0433\u0434\u0435 \u043E\u043D\u0438
    \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043F\u043E\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u043E\u0439
    \u0430\u0431\u0435\u043B\u0435\u0432\u043E\u0439 \u0433\u0440\u0443\u043F\u043F\u043E\u0439
    \u0440\u0430\u043D\u0433\u0430 1. *   \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0440\u043E\u0440\u044B\u0432,
    \u0442\u0430\u043A \u043A\u0430\u043A \u0434\u043E \u0421\u0435\u0440\u0440\u0430
    \u043D\u0435 \u0437\u043D\u0430\u043B\u0438 \u0434\u0430\u0436\u0435 \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438
    \u044D\u0442\u0438\u0445 \u0433\u0440\u0443\u043F\u043F.  **3. \u0422\u0435\u043E\u0440\u0438\u044F
    \u0433\u043E\u043C\u043E\u0442\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0433\u0440\u0443\u043F\u043F \u0441 \u043B\u043E\u043A\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u0430\u043C\u0438**
    \u0421\u0435\u0440\u0440 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0442\u0435\u0445\u043D\u0438\u043A\u0443 **\\( \\mathcal{C} \\)-\u0438\u0437\u043E\u043C\u043E\u0440\u0444\u0438\u0437\u043C\u043E\u0432**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0430
    \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u0442\u044C \u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u0445
    \u043D\u0430\u043A\u0440\u044B\u0432\u0430\u044E\u0449\u0438\u0445. \u042D\u0442\u043E
    \u0434\u0430\u043B\u043E \u043C\u043E\u0449\u043D\u044B\u0439 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442
    \u0434\u043B\u044F \u0440\u0430\u0437\u043B\u0438\u0447\u0435\u043D\u0438\u044F
    \u0433\u043E\u043C\u043E\u0442\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u0438
    \u044D\u043A\u0432\u0438\u0432\u0430\u043B\u0435\u043D\u0442\u043D\u044B\u0445
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432.  **\u0413\u043B\u0430\u0432\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u044D\u0442\u043E\u0433\u043E \u043F\u0435\u0440\u0438\u043E\u0434\u0430:**
    \u0414\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F *\xABHomologie
    singuli\xE8re des espaces fibr\xE9s\xBB* (\u0410\u043D\u043D\u0430\u043B\u044B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, 1951) \u0438 \u0441\u0435\u0440\u0438\u044F
    \u0437\u0430\u043C\u0435\u0442\u043E\u043A \u0432 Comptes Rendus.  ---  ### \u042D\u043F\u043E\u0445\u0430
    2: \u041F\u0435\u0440\u0435\u0445\u043E\u0434 \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u2014 \u0442\u0435\u043E\u0440\u0438\u044F
    \u043F\u0443\u0447\u043A\u043E\u0432 (1954\u20131959) \u042D\u0442\u043E \u0441\u0430\u043C\u044B\u0439
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043F\u0435\u0440\u0435\u043B\u043E\u043C
    \u0432 \u043A\u0430\u0440\u044C\u0435\u0440\u0435 \u0421\u0435\u0440\u0440\u0430.
    \u041E\u043D \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u0442\u044C
    \u043A \u0430\u043B\u0433\u0435\u0431\u0440\u0435.  **1. Faisceaux Alg\xE9briques
    Coh\xE9rents (FAC) \u2014 1955 \u0433\u043E\u0434** \u042D\u0442\u043E \u0435\u0433\u043E
    **\u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0440\u043E\u0434\u0438\u043B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E. \u0412 \u044D\u0442\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 (\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0432 Annals of Mathematics) \u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B
    \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0435:  *   **\u0410\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0443\u0447\u043A\u0438:** \u041E\u043D \u043F\u0435\u0440\u0435\u043D\u0435\u0441
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u043F\u0443\u0447\u043A\u043E\u0432 \u041E\u043A\u0430-\u041A\u0430\u0440\u0442\u0430\u043D\u0430
    \u043D\u0430 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u044F \u043D\u0430\u0434
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u043C \u043F\u043E\u043B\u0435\u043C.
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0410 \u0438 \u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0411 (\u0434\u043B\u044F \u0430\u0444\u0444\u0438\u043D\u043D\u044B\u0445 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439):**     
    *   *\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0410:* \u0414\u043B\u044F \u043A\u043E\u0433\u0435\u0440\u0435\u043D\u0442\u043D\u043E\u0433\u043E
    \u043F\u0443\u0447\u043A\u0430 \\( \\mathcal{F} \\) \u043D\u0430 \u0430\u0444\u0444\u0438\u043D\u043D\u043E\u043C
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0438 \\(
    X \\) \u0435\u0433\u043E \u0433\u043B\u043E\u0431\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u0435\u0447\u0435\u043D\u0438\u044F \u043F\u043E\u0440\u043E\u0436\u0434\u0430\u044E\u0442
    \u0432\u0441\u0435 \u0440\u043E\u0441\u0442\u043A\u0438.     *   *\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0411:* \u0412\u0441\u0435 \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438
    \\( H^i(X, \\mathcal{F}) = 0 \\) \u0434\u043B\u044F \\( i > 0 \\). *   **\u0421\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0435:**
