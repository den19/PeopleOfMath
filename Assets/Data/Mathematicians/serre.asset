    \u0438\u0437 \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u043E\u0439 \u0444\u043E\u0440\u043C\u044B
    (\u0442.\u0435. \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u044B\u043C).
