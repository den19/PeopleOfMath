    \u043C\u0435\u0442\u043E\u0434\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438 \u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440.  ### \U0001F9E0 \u0418\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0437\u043C:
    \u043F\u0435\u0440\u0435\u0441\u043C\u043E\u0442\u0440 \u043E\u0441\u043D\u043E\u0432
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438  \u041F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u043E
    \u0441 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0435\u0439, \u043D\u0430\u0447\u0438\u043D\u0430\u044F
    \u0441 1904 \u0433\u043E\u0434\u0430, \u0411\u0440\u0430\u0443\u044D\u0440 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B
    \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u0443\u044E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0443\u044E
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0443\u044E
    \u043A\u0430\u043A \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0437\u043C.
    \u0415\u0451 \u0441\u0443\u0442\u044C \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0430\u0441\u044C
    \u0432 \u043F\u0435\u0440\u0435\u0441\u043C\u043E\u0442\u0440\u0435 \u0441\u0430\u043C\u0438\u0445
    \u043E\u0441\u043D\u043E\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435, \u043F\u043E \u0435\u0433\u043E \u043C\u043D\u0435\u043D\u0438\u044E,
    \u0431\u044B\u043B\u0438 \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u044B
    \u043D\u0430 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439,
    \u043D\u0435\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0435.  *   **\u041A\u0440\u0438\u0442\u0438\u043A\u0430
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0438\u0441\u043A\u043B\u044E\u0447\u0451\u043D\u043D\u043E\u0433\u043E
    \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E:** \u0411\u0440\u0430\u0443\u044D\u0440
    \u043F\u043E\u0434\u0432\u0435\u0440\u0433 \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u044E
    \u043D\u0435\u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u043D\u0443\u044E
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043C\u043E\u0441\u0442\u044C \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0437\u0430\u043A\u043E\u043D\u0430
    \u0438\u0441\u043A\u043B\u044E\u0447\u0451\u043D\u043D\u043E\u0433\u043E \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E
    (\u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435 \"\u0410
    \u0438\u043B\u0438 \u043D\u0435-\u0410\" \u0438\u0441\u0442\u0438\u043D\u043D\u043E
    \u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0433\u043E \u0432\u044B\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043D\u0438\u044F).
    \u0412 \u0441\u0442\u0430\u0442\u044C\u0435 1908 \u0433\u043E\u0434\u0430 \xAB\u041E
    \u043D\u0435\u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E\u0441\u0442\u0438
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u043E\u0432\xBB
    \u043E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u044D\u0442\u043E\u0442
    \u0437\u0430\u043A\u043E\u043D, \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u044B\u0439
    \u0434\u043B\u044F \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432,
    \u043D\u0435\u043F\u0440\u0430\u0432\u043E\u043C\u0435\u0440\u043D\u043E \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u0442\u0441\u044F
    \u043D\u0430 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C.
    \u0414\u043B\u044F \u043C\u043D\u043E\u0433\u0438\u0445 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0439
    \u043E \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445 \u043E\u0431\u044A\u0435\u043A\u0442\u0430\u0445
    \u043C\u044B \u043D\u0435 \u0437\u043D\u0430\u0435\u043C, \u0438\u0441\u0442\u0438\u043D\u043D\u044B
    \u043E\u043D\u0438 \u0438\u043B\u0438 \u043B\u043E\u0436\u043D\u044B, \u0438
    \u043D\u0435 \u0438\u043C\u0435\u0435\u043C \u043C\u0435\u0442\u043E\u0434\u0430,
    \u0447\u0442\u043E\u0431\u044B \u044D\u0442\u043E \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C. \u041F\u043E\u044D\u0442\u043E\u043C\u0443
    \u0441\u0447\u0438\u0442\u0430\u0442\u044C \u0438\u0445 \u043B\u0438\u0431\u043E
    \u0438\u0441\u0442\u0438\u043D\u043D\u044B\u043C\u0438, \u043B\u0438\u0431\u043E
    \u043B\u043E\u0436\u043D\u044B\u043C\u0438 \u2014 \u043D\u0435\u043E\u043F\u0440\u0430\u0432\u0434\u0430\u043D\u043D\u043E.
    \u041E\u043D \u0432\u0432\u0451\u043B \u043A\u043B\u0430\u0441\u0441 \u043A\u043E\u043D\u0442\u0440\u043F\u0440\u0438\u043C\u0435\u0440\u043E\u0432,
    \u0437\u0430\u0432\u0438\u0441\u044F\u0449\u0438\u0445 \u043E\u0442 \u0442\u0435\u043A\u0443\u0449\u0435\u0433\u043E
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0437\u043D\u0430\u043D\u0438\u044F, \u0430 \u043D\u0435 \u043E\u0442 \xAB\u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0435\u0439\xBB.
    *   **\u041A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:** \u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u0430\u044F
    \u0438\u0434\u0435\u044F \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0437\u043C\u0430
    \u2014 **\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u0437\u043D\u0430\u0447\u0438\u0442 \u0431\u044B\u0442\u044C \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u044B\u043C**.
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u043E\u0431\u044A\u0435\u043A\u0442\u0430 \u0434\u043E\u043B\u0436\u043D\u043E
    \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0442\u044C
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0435, \u0430 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0439
    \u043C\u0435\u0442\u043E\u0434 (\u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C)
    \u0435\u0433\u043E \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F.
    \"\u0427\u0438\u0441\u0442\u044B\u0435\" \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F,
    \u043E\u043F\u0438\u0440\u0430\u044E\u0449\u0438\u0435\u0441\u044F \u043D\u0430
    \u0437\u0430\u043A\u043E\u043D \u0438\u0441\u043A\u043B\u044E\u0447\u0451\u043D\u043D\u043E\u0433\u043E
    \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E \u0438\u043B\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043E\u0442 \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u043E\u0433\u043E, \u0431\u044B\u043B\u0438
    \u043E\u0442\u0432\u0435\u0440\u0433\u043D\u0443\u0442\u044B. \u0411\u0440\u0430\u0443\u044D\u0440
    \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u044F\u043B \u043F\u0435\u0440\u0432\u0443\u044E
    \u043F\u043E\u043F\u044B\u0442\u043A\u0443 \u043F\u0435\u0440\u0435\u0441\u0442\u0440\u043E\u0438\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u043D\u0430 \u044D\u0442\u0438\u0445 \u043D\u043E\u0432\u044B\u0445,
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u0445
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F\u0445. *   **\u041D\u043E\u0432\u0430\u044F
    \u043B\u043E\u0433\u0438\u043A\u0430:** \u0420\u0430\u0431\u043E\u0442\u044B
    \u0411\u0440\u0430\u0443\u044D\u0440\u0430 \u043F\u0440\u0438\u0432\u0435\u043B\u0438
    \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043D\u0435 \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u0437\u0430\u043A\u043E\u043D\u043E\u0432
    \u0438\u0441\u043A\u043B\u044E\u0447\u0451\u043D\u043D\u043E\u0433\u043E \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E
    \u0438 \u0441\u043D\u044F\u0442\u0438\u044F \u0434\u0432\u043E\u0439\u043D\u043E\u0433\u043E
    \u043E\u0442\u0440\u0438\u0446\u0430\u043D\u0438\u044F. \u0412 1930 \u0433\u043E\u0434\u0443
    \u0435\u0451 \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043B
    \u0443\u0447\u0435\u043D\u0438\u043A \u0411\u0440\u0430\u0443\u044D\u0440\u0430
    \u0410\u0440\u0435\u043D\u0434 \u0413\u0435\u0439\u0442\u0438\u043D\u0433. *  
    **\u0414\u0430\u043B\u044C\u043D\u043E\u0432\u0438\u0434\u043D\u044B\u0435 \u0438\u0434\u0435\u0438:**
    \u0411\u0440\u0430\u0443\u044D\u0440 \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B
    \u0438\u0434\u0435\u0438, \u043D\u0430\u043C\u043D\u043E\u0433\u043E \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0438\u0435
    \u0441\u0432\u043E\u0451 \u0432\u0440\u0435\u043C\u044F. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044E
    \xAB\u0431\u0435\u0437\u0437\u0430\u043A\u043E\u043D\u043D\u044B\u0445 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0435\u0439\xBB
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0435\u0439,
    \u0437\u0430\u0432\u0438\u0441\u044F\u0449\u0438\u0445 \u043E\u0442 \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0442\u0430\u043B\u0438 \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437\u0430\u043C\u0438
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 \u043C\u043E\u0434\u0435\u043B\u0435\u0439
    \u041A\u0440\u0438\u043F\u043A\u0435 \u0432 \u043B\u043E\u0433\u0438\u043A\u0435.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u043B
    \u043D\u0430 \u043D\u0435\u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u0443\u0435\u043C\u043E\u0441\u0442\u0438
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0437\u043D\u0430\u043D\u0438\u044F, \u0447\u0442\u043E \u043F\u0435\u0440\u0435\u043A\u043B\u0438\u043A\u0430\u0435\u0442\u0441\u044F
    \u0441 \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u043C\u0438
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430\u043C\u0438 \u041A\u0443\u0440\u0442\u0430
    \u0413\u0451\u0434\u0435\u043B\u044F.  \u0425\u043E\u0442\u044F \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0437\u043C
    \u043D\u0435 \u0441\u0442\u0430\u043B \u0433\u043E\u0441\u043F\u043E\u0434\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u043C
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C, \u0435\u0433\u043E
    \u0438\u0434\u0435\u0438 \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435. \u0412 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0410.\u041D. \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438 \u0440\u0435\u0430\u043B\u0438\u0437\u0443\u044E\u0442\u0441\u044F
    \u0432 \u043B\u043E\u0433\u0438\u043A\u0435 \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C. \u042D\u0442\u043E \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u043E
    \u043E\u0441\u043D\u043E\u0432\u0443 \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u041B\u0451\u0439\u0442\u0437\u0435\u043D\u0430 \u042D\u0433\u0431\u0435\u0440\u0442\u0430
    \u042F\u043D\u0430 \u0411\u0440\u0430\u0443\u044D\u0440\u0430 \u0431\u044B\u043B\u0430
    \u0441\u0442\u043E\u043B\u044C \u0436\u0435 \u0441\u043B\u043E\u0436\u043D\u043E\u0439,
    \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u043E\u0439
    \u0438 \u043F\u043E\u043B\u043D\u043E\u0439 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0439,
    \u043A\u0430\u043A \u0438 \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C. \u041E\u043D\u0430
    \u0432\u043A\u043B\u044E\u0447\u0430\u043B\u0430 \u0432 \u0441\u0435\u0431\u044F
    \u0431\u0440\u0430\u043A \u0441 \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439
    \u0441\u0442\u0430\u0440\u0448\u0435 \u0435\u0433\u043E, \u043D\u0430\u043F\u0440\u044F\u0436\u0451\u043D\u043D\u044B\u0435
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u043F\u0440\u0438\u0451\u043C\u043D\u043E\u0439
    \u0434\u043E\u0447\u0435\u0440\u044C\u044E, \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u0435
    \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0438 \u0438 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0433\u0438\u0431\u0435\u043B\u044C.  \u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437 \u043E \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438.  ### \U0001F48D \u0411\u0440\u0430\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0430\u0447\u0430\u043B\u0441\u044F \u0441 \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u043B\u0430\u043D\u0430  \u0411\u0440\u0430\u0443\u044D\u0440 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    31 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1904 \u0433\u043E\u0434\u0430 \u043D\u0430
    **\u0420\u0435\u0439\u043D\u0445\u0430\u0440\u0434\u0435 \u0411\u0435\u0440\u043D\u0430\u0440\u0434\u0438\u043D\u0435
    \u0424\u0440\u0435\u0434\u0435\u0440\u0438\u043A\u0435 \u042D\u043B\u0438\u0437\u0430\u0431\u0435\u0442
    (\u041B\u0438\u0437\u0435) \u0434\u0435 \u0425\u043E\u043B\u043B**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u0441\u0442\u0430\u0440\u0448\u0435 \u0435\u0433\u043E
    \u043D\u0430 11 \u043B\u0435\u0442 \u0438 \u0443\u0436\u0435 \u0438\u043C\u0435\u043B\u0430
    \u0434\u043E\u0447\u044C \u043E\u0442 \u043F\u0440\u0435\u0434\u044B\u0434\u0443\u0449\u0435\u0433\u043E
    \u0431\u0440\u0430\u043A\u0430.  \u0417\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E
    \u0441 \u041B\u0438\u0437\u043E\u0439 \u0431\u044B\u043B\u043E \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E
    \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u043C. \u0412 1902 \u0433\u043E\u0434\u0443
    \u0447\u0435\u0440\u0435\u0437 \u043E\u0431\u0449\u0443\u044E \u0437\u043D\u0430\u043A\u043E\u043C\u0443\u044E
    \u0411\u0440\u0430\u0443\u044D\u0440 \u0443\u0437\u043D\u0430\u043B \u043E \u043C\u043E\u043B\u043E\u0434\u043E\u0439
    \u0440\u0430\u0437\u0432\u0435\u0434\u0451\u043D\u043D\u043E\u0439 \u0436\u0435\u043D\u0449\u0438\u043D\u0435
    \u0441 \u0440\u0435\u0431\u0451\u043D\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0436\u0438\u043B\u0430 \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u043C\u0430\u0442\u0435\u0440\u044C\u044E
    \u0438 \u043F\u043E\u043C\u043E\u0433\u0430\u043B\u0430 \u0435\u0439 \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u0442\u044C
    \u0430\u043F\u0442\u0435\u043A\u043E\u0439. \u0427\u0442\u043E\u0431\u044B \u0443\u0432\u0438\u0434\u0435\u0442\u044C
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0430, \u0411\u0440\u0430\u0443\u044D\u0440,
    \u043F\u0440\u043E\u044F\u0432\u0438\u0432 \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u043C\u0435\u043B\u043E\u0441\u0442\u044C, \u0437\u0430\u0431\u0440\u0430\u043B\u0441\u044F
    \u043D\u0430 \u043A\u0440\u044B\u0448\u0443 \u0441\u043E\u0441\u0435\u0434\u043D\u0435\u0433\u043E
    \u0434\u043E\u043C\u0430, \u043E\u0442\u043A\u0443\u0434\u0430 \u043C\u043E\u0433
    \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u044C \u0437\u0430 \u041B\u0438\u0437\u043E\u0439.
    \u0418\u043D\u0441\u043F\u0435\u043A\u0446\u0438\u044F, \u0432\u0438\u0434\u0438\u043C\u043E,
    \u043F\u0440\u043E\u0448\u043B\u0430 \u0443\u0441\u043F\u0435\u0448\u043D\u043E,
    \u0438 \u0432\u0441\u043A\u043E\u0440\u0435 \u043E\u043D \u043D\u0430\u0447\u0430\u043B
    \u0437\u0430 \u043D\u0435\u0439 \u0443\u0445\u0430\u0436\u0438\u0432\u0430\u0442\u044C,
    \u043F\u0440\u0438\u043B\u043E\u0436\u0438\u0432 \u0432\u0441\u0435 \u0441\u0432\u043E\u0438
    \"\u0447\u0430\u0440\u044B \u0438 \u0441\u0438\u043B\u0443 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F\",
    \u0447\u0442\u043E\u0431\u044B \u0437\u0430\u0432\u043E\u0435\u0432\u0430\u0442\u044C
    \u0435\u0451 \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435. 
    \u0418\u0445 \u0431\u0440\u0430\u043A, \u0437\u0430\u043A\u043B\u044E\u0447\u0451\u043D\u043D\u044B\u0439
    \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0430 \u043C\u0435\u0441\u044F\u0446\u0430
    \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F
    \u0411\u0440\u0430\u0443\u044D\u0440\u043E\u043C \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u043E\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438, \u0431\u044B\u043B \u043F\u0440\u043E\u0441\u0442\u044B\u043C
    \u2014 \u0432\u0435\u043D\u0447\u0430\u043D\u0438\u0435 \u043F\u0440\u043E\u0448\u043B\u043E
    \u0432 \u043C\u044D\u0440\u0438\u0438 \u0410\u043C\u0441\u0442\u0435\u0440\u0434\u0430\u043C\u0430.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u043E, \u0447\u0442\u043E
    \u0443 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0434\u0440\u0443\u0437\u0435\u0439
    \u0431\u044B\u043B \u043D\u0435\u0433\u0430\u0442\u0438\u0432\u043D\u044B\u0439
    \u043D\u0430\u0441\u0442\u0440\u043E\u0439 \u0438\u0437-\u0437\u0430 \u0440\u0430\u0437\u043D\u0438\u0446\u044B
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 \u0438 \u043D\u0430\u043B\u0438\u0447\u0438\u044F
    \u0443 \u041B\u0438\u0437\u044B \u0440\u0435\u0431\u0451\u043D\u043A\u0430, \u0411\u0440\u0430\u0443\u044D\u0440
    \u0441\u0434\u0435\u043B\u0430\u043B \u0441\u0432\u043E\u0439 \u0432\u044B\u0431\u043E\u0440.
    \u0421\u0443\u043F\u0440\u0443\u0433\u0438 \u0432\u043C\u0435\u0441\u0442\u0435
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0438 \u0432 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u043A\u043E\u0442\u0442\u0435\u0434\u0436 \u0432 \u0411\u043B\u0430\u0440\u0438\u043A\u044E\u043C\u0435
    \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E \u043E\u0442 \u0410\u043C\u0441\u0442\u0435\u0440\u0434\u0430\u043C\u0430,
    \u0433\u0434\u0435 \u0438 \u043F\u0440\u043E\u0436\u0438\u043B\u0438 \u0434\u043E\u043B\u0433\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467
    \u041D\u0430\u043F\u0440\u044F\u0436\u0451\u043D\u043D\u044B\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u043F\u0440\u0438\u0451\u043C\u043D\u043E\u0439 \u0434\u043E\u0447\u0435\u0440\u044C\u044E 
    \u0423 \u041B\u0438\u0437\u044B \u0431\u044B\u043B\u0430 \u0434\u043E\u0447\u044C
    \u043E\u0442 \u043F\u0435\u0440\u0432\u043E\u0433\u043E \u0431\u0440\u0430\u043A\u0430,
    **\u0410\u043D\u043D\u0430 \u041B\u0443\u0438\u0437\u0430 \u042D\u043B\u0438\u0437\u0430\u0431\u0435\u0442
    \u041F\u0435\u0439\u043F\u0435\u0440\u0441**, \u0440\u043E\u0434\u0438\u0432\u0448\u0430\u044F\u0441\u044F
    \u0432 1893 \u0433\u043E\u0434\u0443. \u0421 \u0441\u0430\u043C\u043E\u0433\u043E
    \u043D\u0430\u0447\u0430\u043B\u0430 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u043C\u0435\u0436\u0434\u0443 \u0411\u0440\u0430\u0443\u044D\u0440\u043E\u043C
    \u0438 \u0435\u0433\u043E \u043F\u0440\u0438\u0451\u043C\u043D\u043E\u0439 \u0434\u043E\u0447\u0435\u0440\u044C\u044E
    \u043D\u0435 \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u043B\u0438\u0441\u044C.
    \u0423\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E
    \u043E\u043D \u043D\u0435 \u0431\u044B\u043B \u0432 \u0432\u043E\u0441\u0442\u043E\u0440\u0433\u0435
    \u043E\u0442 \u043D\u0435\u0451, \u0438 \u0438\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0438\u0441\u044C \u043D\u0430\u0442\u044F\u043D\u0443\u0442\u044B\u043C\u0438
    \u043D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438 \u043C\u043D\u043E\u0433\u0438\u0445
    \u043B\u0435\u0442.  \u041F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0447\u0442\u043E \u0443 \u0441\u0430\u043C\u043E\u0433\u043E \u0411\u0440\u0430\u0443\u044D\u0440\u0430
    \u0438 \u041B\u0438\u0437\u044B \u043D\u0435 \u0431\u044B\u043B\u043E \u043E\u0431\u0449\u0438\u0445
    \u0434\u0435\u0442\u0435\u0439.  ### \U0001F9D8\u200D\u2642\uFE0F \u042D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u0439
    \u043E\u0431\u0440\u0430\u0437 \u0436\u0438\u0437\u043D\u0438 \u0438 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F 
    \u0411\u0440\u0430\u0443\u044D\u0440 \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0441\u0432\u043E\u0438\u043C \u0430\u0441\u043A\u0435\u0442\u0438\u0447\u043D\u044B\u043C
    \u0438 \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0436\u0438\u0437\u043D\u0438. \u041E\u043D
    \u043F\u0440\u0438\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0441\u044F
    **\u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0441\u0442\u0432\u0430**
    \u0438 \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u043C\u0438
    \u043E\u0437\u0434\u043E\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0430\u043C\u0438: \u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435\u043C
    \u0431\u043E\u0441\u0438\u043A\u043E\u043C \u043F\u043E \u0440\u043E\u0441\u0435
    \u0438 \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u043C\u0438 \u0432\u0430\u043D\u043D\u0430\u043C\u0438. 
    \u041F\u043E\u043C\u0438\u043C\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E\u043C \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432.
    \u041E\u043D \u0431\u044B\u043B \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u044B\u043C
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u043C
    \u0438 \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u043B \u0432\u0440\u0430\u0449\u0430\u0442\u044C\u0441\u044F
    \u0432 \u0430\u0440\u0442\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0443\u0433\u0430\u0445, \u043E\u0431\u0449\u0430\u044F\u0441\u044C
    \u0441 \u043F\u043E\u044D\u0442\u0430\u043C\u0438, \u043C\u0443\u0437\u044B\u043A\u0430\u043D\u0442\u0430\u043C\u0438
    \u0438 \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0430\u043C\u0438. \u041E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0435\u0433\u043E \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0438\u0445
    \u0434\u0440\u0443\u0437\u0435\u0439 \u0431\u044B\u043B \u043F\u043E\u044D\u0442
    \u041A.\u0421. \u0410\u0434\u0430\u043C\u0430 \u0432\u0430\u043D \u0421\u0445\u0435\u043B\u0442\u0435\u043C\u0430,
    \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u043E\u043D \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B
    \u0434\u043E\u043B\u0433\u0443\u044E \u0434\u0440\u0443\u0436\u0431\u0443.  \u0411\u0440\u0430\u0443\u044D\u0440
    \u0442\u0430\u043A\u0436\u0435 \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438. \u0422\u0430\u043A, \u0441 1935 \u043F\u043E
    1941 \u0433\u043E\u0434 \u043E\u043D \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C
    \u043C\u0443\u043D\u0438\u0446\u0438\u043F\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0441\u043E\u0432\u0435\u0442\u0430 \u0411\u043B\u0430\u0440\u0438\u043A\u044E\u043C\u0430
    \u043E\u0442 \u043C\u0435\u0441\u0442\u043D\u043E\u0439 \u043F\u0430\u0440\u0442\u0438\u0438. 
    ### \U0001F54A\uFE0F \u0422\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0438\u0431\u0435\u043B\u044C \u0438 \u043F\u0430\u0440\u0430\u043D\u043E\u0439\u044F 
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u0411\u0440\u0430\u0443\u044D\u0440\u0430 \u0431\u044B\u043B\u0438
    \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u044B \u043D\u0430\u0440\u0430\u0441\u0442\u0430\u044E\u0449\u0435\u0439
    \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0435\u0439 \u0438 \u043F\u0430\u0440\u0430\u043D\u043E\u0439\u0435\u0439.
    \u041E\u043D \u0441\u0442\u0440\u0430\u0434\u0430\u043B \u043E\u0442 \"\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u043D\u0435\u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0445 \u0442\u0440\u0435\u0432\u043E\u0433
    \u0438 \u043F\u0430\u0440\u0430\u043D\u043E\u0438\u0434\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0441\u0442\u0440\u0430\u0445\u0430 \u0431\u0430\u043D\u043A\u0440\u043E\u0442\u0441\u0442\u0432\u0430,
    \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    \u0438 \u0431\u043E\u043B\u0435\u0437\u043D\u0435\u0439\".  \u0415\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0431\u043E\u0440\u0432\u0430\u043B\u0430\u0441\u044C 2 \u0434\u0435\u043A\u0430\u0431\u0440\u044F
    1966 \u0433\u043E\u0434\u0430 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    85 \u043B\u0435\u0442. \u041E\u043D \u043F\u043E\u0433\u0438\u0431 \u0432 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435
    \u043D\u0435\u0441\u0447\u0430\u0441\u0442\u043D\u043E\u0433\u043E \u0441\u043B\u0443\u0447\u0430\u044F,
    \u043F\u043E\u043F\u0430\u0432 \u043F\u043E\u0434 \u043C\u0430\u0448\u0438\u043D\u0443,
    \u043A\u043E\u0433\u0434\u0430 \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0438\u043B
    \u0443\u043B\u0438\u0446\u0443 \u043F\u0440\u044F\u043C\u043E \u043F\u0435\u0440\u0435\u0434
    \u0441\u0432\u043E\u0438\u043C \u0434\u043E\u043C\u043E\u043C \u0432 \u0411\u043B\u0430\u0440\u0438\u043A\u044E\u043C\u0435."
  personalLifeEn: 
  shortBioRu: "\u041B\u0451\u0439\u0442\u0437\u0435\u043D \u042D\u0433\u0431\u0435\u0440\u0442
    \u042F\u043D \u0411\u0440\u0430\u0443\u044D\u0440 (1881\u20131966) \u2014 \u0433\u043E\u043B\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444,
    \u0447\u044C\u0451 \u0438\u043C\u044F \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0432\u043F\u0438\u0441\u0430\u043D\u043E \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E
    \u043D\u0430\u0443\u043A\u0438 \u043A\u0430\u043A \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u044F
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    \u0438 \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0437\u043C\u0430.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0445 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439,
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0445 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445
    \u043F\u0440\u043E\u0437\u0440\u0435\u043D\u0438\u0439 \u0438 \u043E\u0436\u0435\u0441\u0442\u043E\u0447\u0451\u043D\u043D\u044B\u0445
    \u0441\u043F\u043E\u0440\u043E\u0432 \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438. 
    ### \U0001F4DC \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435 (1881\u20131904) 
    \u0411\u0440\u0430\u0443\u044D\u0440 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    27 \u0444\u0435\u0432\u0440\u0430\u043B\u044F 1881 \u0433\u043E\u0434\u0430 \u0432
    \u041E\u0432\u0435\u0440\u0448\u0438, \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E
    \u043E\u0442 \u0420\u043E\u0442\u0442\u0435\u0440\u0434\u0430\u043C\u0430. \u041E\u043D
    \u0431\u044B\u043B \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u044B\u043C \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C
    \u0438 \u0443\u0436\u0435 \u0432 14 \u043B\u0435\u0442 \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u043E\u043B\u043D\u043E\u0435 \u0441\u0440\u0435\u0434\u043D\u0435\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0432 \u0425\u043E\u043E\u0440\u043D\u0435.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0434\u043B\u044F \u043F\u043E\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0435\u043C\u0443
    \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u043B\u043E \u0437\u043D\u0430\u043D\u0438\u0439
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0438 \u043B\u0430\u0442\u044B\u043D\u0438,
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0435
    \u0434\u0432\u0430 \u0433\u043E\u0434\u0430 \u043E\u043D \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u0438\u0445 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E, \u043F\u043E\u0441\u043B\u0435
    \u0447\u0435\u0433\u043E \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u0425\u0430\u0440\u043B\u0435\u043C, \u0433\u0434\u0435 \u0432 1897 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441\u0434\u0430\u043B \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u044B \u0432 \u0410\u043C\u0441\u0442\u0435\u0440\u0434\u0430\u043C\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442.  \u0412 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0435\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0414\u0438\u0434\u0435\u0440\u0438\u043A \u041A\u043E\u0440\u0442\u0435\u0432\u0435\u0433,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u0441\u0442\u0440\u043E
    \u0440\u0430\u0437\u0433\u043B\u044F\u0434\u0435\u043B \u0432 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0435
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F \u0442\u0430\u043B\u0430\u043D\u0442.
    \u0411\u0440\u0430\u0443\u044D\u0440 \u0441 \u044D\u043D\u0442\u0443\u0437\u0438\u0430\u0437\u043C\u043E\u043C
    \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u043B\u0441\u044F \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u043D\u043E \u0435\u0433\u043E \u0442\u0430\u043A\u0436\u0435 \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435
    \u0432\u043E\u043F\u0440\u043E\u0441\u044B. \u0415\u0449\u0451 \u0432 \u0441\u0442\u0443\u0434\u0435\u043D\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043F\u0435\u0440\u0432\u044B\u0435 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0432 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0431\u044B\u043B\u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u044B
    \u0432 1904 \u0433\u043E\u0434\u0443 \u0432 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A.  ###
    \U0001F9ED \u041D\u0430\u0447\u0430\u043B\u043E \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u0443\u0442\u0438: \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F
    \u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    (1905\u20131912)  \u0412 1904 \u0433\u043E\u0434\u0443 \u0411\u0440\u0430\u0443\u044D\u0440
    \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u0438 \u0432 \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u041B\u0438\u0437\u0435 \u0434\u0435 \u0425\u043E\u043B\u043B,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u044B\u043B\u0430 \u0441\u0442\u0430\u0440\u0448\u0435
    \u0435\u0433\u043E \u043D\u0430 11 \u043B\u0435\u0442. \u0412 1905 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0439 \u0442\u0440\u0430\u043A\u0442\u0430\u0442
    **\xAB\u0416\u0438\u0437\u043D\u044C, \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E
    \u0438 \u043C\u0438\u0441\u0442\u0438\u043A\u0430\xBB (Leven, Kunst, en Mystiek)**,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0443\u0436\u0435 \u043F\u0440\u043E\u0441\u043B\u0435\u0436\u0438\u0432\u0430\u043B\u0438\u0441\u044C
    \u043A\u043E\u043D\u0442\u0443\u0440\u044B \u0435\u0433\u043E \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E
    \u043C\u0438\u0440\u043E\u0432\u043E\u0437\u0437\u0440\u0435\u043D\u0438\u044F.
    \u0412 \u044D\u0442\u043E\u043C \u0442\u0440\u0443\u0434\u0435 \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E\u0441\u044C
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043F\u0435\u0441\u0441\u0438\u043C\u0438\u0437\u043C\u0430
    \u0438 \u0438\u0434\u0435\u0439 \u0410\u0440\u0442\u0443\u0440\u0430 \u0428\u043E\u043F\u0435\u043D\u0433\u0430\u0443\u044D\u0440\u0430,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0445
    \u0443\u0447\u0435\u043D\u0438\u0439.  \u0412 1907 \u0433\u043E\u0434\u0443 \u0411\u0440\u0430\u0443\u044D\u0440
    \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E **\xAB\u041E\u0431
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB
    (Over de grondslagen der wiskunde)**, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u043D\u0430\u0447\u0430\u043B \u0430\u0442\u0430\u043A\u0443 \u043D\u0430 \u0443\u0441\u0442\u043E\u044F\u0432\u0448\u0438\u0435\u0441\u044F
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u043E\u0441\u043D\u043E\u0432\u044B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u041E\u043D \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043F\u043E\u0434 \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u0435 \u043D\u0435\u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u043D\u0443\u044E
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043C\u043E\u0441\u0442\u044C \u0437\u0430\u043A\u043E\u043D\u0430
    \u0438\u0441\u043A\u043B\u044E\u0447\u0451\u043D\u043D\u043E\u0433\u043E \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E
    \u043A \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u043C \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430\u043C,
    \u0447\u0442\u043E \u0438 \u0441\u0442\u0430\u043B\u043E \u0437\u0430\u0440\u043E\u0434\u044B\u0448\u0435\u043C
    \u0435\u0433\u043E \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0437\u043C\u0430.
    \u0412 1908 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B
    \u0432 \u0441\u0442\u0430\u0442\u044C\u0435 \xAB\u041E \u043D\u0435\u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E\u0441\u0442\u0438
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u043E\u0432\xBB,
    \u0437\u0430\u044F\u0432\u0438\u0432, \u0447\u0442\u043E \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043B\u043E\u0433\u0438\u043A\u0430, \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043C\u0430\u044F
    \u043A \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u043C \u0441\u043E\u0432\u043E\u043A\u0443\u043F\u043D\u043E\u0441\u0442\u044F\u043C,
    \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0435\u0440\u0435\u043D\u0435\u0441\u0435\u043D\u0430 \u043D\u0430 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C. 
    \u0421 1909 \u0433\u043E\u0434\u0430, \u0441\u0442\u0430\u0432 \u043F\u0440\u0438\u0432\u0430\u0442-\u0434\u043E\u0446\u0435\u043D\u0442\u043E\u043C
    \u0410\u043C\u0441\u0442\u0435\u0440\u0434\u0430\u043C\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430, \u043E\u043D
    \u043D\u0430\u0447\u0430\u043B \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u0430\u0440\u044C\u0435\u0440\u0443. \u0415\u0433\u043E \u0438\u043D\u0430\u0443\u0433\u0443\u0440\u0430\u0446\u0438\u043E\u043D\u043D\u0430\u044F
    \u043B\u0435\u043A\u0446\u0438\u044F \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u043F\u0440\u0438\u0440\u043E\u0434\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.
    \u0412 \u043A\u043E\u043D\u0446\u0435 1909 \u0433\u043E\u0434\u0430 \u043E\u043D
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0432\u0430\u0436\u043D\u0443\u044E
    \u043F\u043E\u0435\u0437\u0434\u043A\u0443 \u0432 \u041F\u0430\u0440\u0438\u0436,
    \u0433\u0434\u0435 \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B\u0441\u044F
    \u0441 \u0410\u043D\u0440\u0438 \u041F\u0443\u0430\u043D\u043A\u0430\u0440\u0435
    \u0438 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0432\u0435\u0434\u0443\u0449\u0438\u043C\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438, \u0447\u0442\u043E
    \u0441\u0442\u0438\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B\u043E
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0430\u0434 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0435\u0439. 
    ### \U0001F9EC \u0420\u0430\u0441\u0446\u0432\u0435\u0442 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 (1912\u20131920-\u0435
    \u0433\u043E\u0434\u044B)  \u041F\u0435\u0440\u0438\u043E\u0434 \u0441 1911 \u043F\u043E
    1913 \u0433\u043E\u0434 \u0441\u0442\u0430\u043B \u0434\u043B\u044F \u0411\u0440\u0430\u0443\u044D\u0440\u0430
    \xAB\u0437\u043E\u043B\u043E\u0442\u044B\u043C \u0432\u0435\u043A\u043E\u043C\xBB
    \u0432 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0442\u043E\u0433\u0434\u0430 \u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0441\u0430\u043C\u044B\u0435 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u044B
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    :  *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0439
    \u0442\u043E\u0447\u043A\u0435:** \u0412\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u0441\u0430\u043C\u043E\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435
    \u0435\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435.
    \u041E\u043D\u0430 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u043F\u0440\u0438 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u043C
    \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0438 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0433\u043E
    \u0448\u0430\u0440\u0430 \u0432 \u0441\u0435\u0431\u044F \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0445\u043E\u0442\u044F \u0431\u044B \u043E\u0434\u043D\u0430 \u0442\u043E\u0447\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F
    \u043D\u0430 \u043C\u0435\u0441\u0442\u0435. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u0441\u0430\u043C \u0411\u0440\u0430\u0443\u044D\u0440 \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B
    \u043F\u0440\u0438\u043C\u0435\u0440 \u0441\u043E \u0441\u0442\u0430\u043A\u0430\u043D\u043E\u043C
    \u0447\u0430\u044F: \u043F\u043E\u0441\u043B\u0435 \u043B\u044E\u0431\u043E\u0433\u043E
    \u043F\u0435\u0440\u0435\u043C\u0435\u0448\u0438\u0432\u0430\u043D\u0438\u044F
    \u043D\u0430 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0438 \u043D\u0430\u0439\u0434\u0451\u0442\u0441\u044F
    \u0442\u043E\u0447\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043D\u0435
    \u0441\u0434\u0432\u0438\u043D\u0435\u0442\u0441\u044F \u0441 \u043C\u0435\u0441\u0442\u0430.
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E\u0431 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043D\u043E\u0441\u0442\u0438
    \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438:** \u0411\u0440\u0430\u0443\u044D\u0440
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u043C \u2014 \u0442\u043E
    \u0435\u0441\u0442\u044C n-\u043C\u0435\u0440\u043D\u043E\u0435 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u043D\u0435\u043B\u044C\u0437\u044F \u0432\u0437\u0430\u0438\u043C\u043D\u043E
    \u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E \u0438 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E
    \u043E\u0442\u043E\u0431\u0440\u0430\u0437\u0438\u0442\u044C \u043D\u0430 m-\u043C\u0435\u0440\u043D\u043E\u0435
    \u043F\u0440\u0438 n \u2260 m. *   **\u041F\u043E\u043D\u044F\u0442\u0438\u0435
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F
    \u0438 \u0441\u0438\u043C\u043F\u043B\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0430\u043F\u043F\u0440\u043E\u043A\u0441\u0438\u043C\u0430\u0446\u0438\u0438:**
    \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u043E\u0434\u0445\u043E\u0434\u044B \u043A \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432. 
    \u0412 1912 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    31 \u0433\u043E\u0434\u0430, \u0411\u0440\u0430\u0443\u044D\u0440 \u0431\u044B\u043B
    \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A \u0438
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u0432 \u0410\u043C\u0441\u0442\u0435\u0440\u0434\u0430\u043C\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B \u0434\u043E \u0432\u044B\u0445\u043E\u0434\u0430
    \u043D\u0430 \u043F\u0435\u043D\u0441\u0438\u044E \u0432 1951 \u0433\u043E\u0434\u0443.
    \u0412 \u0442\u043E\u043C \u0436\u0435 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0432\u044B\u0441\u0442\u0443\u043F\u0438\u043B \u043D\u0430 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u043C
    \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0432 \u041A\u0435\u043C\u0431\u0440\u0438\u0434\u0436\u0435, \u0443\u043A\u0440\u0435\u043F\u0438\u0432
    \u0441\u0432\u043E\u044E \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u0443\u044E
    \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044E.  \u0412 1918\u20131923
    \u0433\u043E\u0434\u0430\u0445 \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C \u0440\u0430\u0431\u043E\u0442\u044B
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432,
    \u043C\u0435\u0440\u0435 \u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C,
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u043D\u044B\u0435
    \u0443\u0436\u0435 \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435 \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u0441\u043A\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438. \u041E\u043D \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0438\u043B
    \u043A \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u043E\u0439 \u0437\u0430\u0434\u0430\u0447\u0435
    \u043F\u0435\u0440\u0435\u0441\u0442\u0440\u043E\u0439\u043A\u0438 \u0432\u0441\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043D\u0430 \u043D\u043E\u0432\u044B\u0445
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F\u0445. \u042D\u0442\u0430
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0430 \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u043B\u0430
    \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435 \u0442\u0430\u043A\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u043A\u0430\u043A
    \u0413\u0435\u0440\u043C\u0430\u043D \u0412\u0435\u0439\u043B\u044C, \u043D\u043E
    \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B\u0430 \u043E\u0436\u0435\u0441\u0442\u043E\u0447\u0451\u043D\u043D\u043E\u0435
    \u0441\u043E\u043F\u0440\u043E\u0442\u0438\u0432\u043B\u0435\u043D\u0438\u0435
    \u0441\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u044B \u0414\u0430\u0432\u0438\u0434\u0430
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430, \u043B\u0438\u0434\u0435\u0440\u0430
    \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0441\u0442\u0441\u043A\u043E\u0433\u043E
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F. \u0418\u0445
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435 \u043A\u0430\u043A **\xAB\u0441\u043F\u043E\u0440
    \u0411\u0440\u0430\u0443\u044D\u0440\u0430 \u0438 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u0430\xBB**,
    \u0441\u0442\u0430\u043B\u043E \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u043C
    \u0441\u043E\u0431\u044B\u0442\u0438\u0435\u043C \u0432 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 1920-\u0445 \u0433\u043E\u0434\u043E\u0432. 
    ### \u2694\uFE0F \u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u0441 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C
    \u0438 \u043F\u043E\u0437\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B (1928\u20131966) 
    \u041A\u0443\u043B\u044C\u043C\u0438\u043D\u0430\u0446\u0438\u0435\u0439 \u0441\u043F\u043E\u0440\u0430
    \u0441\u0442\u0430\u043B \u0438\u043D\u0446\u0438\u0434\u0435\u043D\u0442 \u0432
    1928 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u0441\u0432\u043E\u0439
    \u0430\u0432\u0442\u043E\u0440\u0438\u0442\u0435\u0442, \u0434\u043E\u0431\u0438\u043B\u0441\u044F
    \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F \u0411\u0440\u0430\u0443\u044D\u0440\u0430
    \u0438\u0437 \u0440\u0435\u0434\u0430\u043A\u0446\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0441\u043E\u0432\u0435\u0442\u0430 \u0432\u0435\u0434\u0443\u0449\u0435\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0436\u0443\u0440\u043D\u0430\u043B\u0430 *Mathematische Annalen*.  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435, \u0411\u0440\u0430\u0443\u044D\u0440
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F \u043E\u0434\u0438\u043D\u043E\u043A
    \u0432 \u0441\u0432\u043E\u0438\u0445 \u0432\u0437\u0433\u043B\u044F\u0434\u0430\u0445.
    \u0415\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A \u0410\u0440\u0435\u043D\u0434
    \u0413\u0435\u0439\u0442\u0438\u043D\u0433 \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043B
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u0441\u043A\u0443\u044E
    \u043B\u043E\u0433\u0438\u043A\u0443 \u0432 1930 \u0433\u043E\u0434\u0443, \u043D\u043E
    \u0441\u0430\u043C \u0411\u0440\u0430\u0443\u044D\u0440 \u0441\u0447\u0438\u0442\u0430\u043B
    \u043B\u044E\u0431\u0443\u044E \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u044E
    \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u044E\u0449\u0435\u0439.
    \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0435 \u0433\u043E\u0434\u044B
    \u043E\u043D \u043F\u043E\u0447\u0442\u0438 \u043D\u0435 \u0447\u0438\u0442\u0430\u043B
    \u043B\u0435\u043A\u0446\u0438\u0439 \u043F\u043E \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438,
    \u0441\u0447\u0438\u0442\u0430\u044F \u0441\u0432\u043E\u0438 \u043F\u0440\u0435\u0436\u043D\u0438\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \xAB\u043B\u043E\u0436\u043D\u044B\u043C\u0438\xBB
    \u0441 \u0442\u043E\u0447\u043A\u0438 \u0437\u0440\u0435\u043D\u0438\u044F \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0437\u043C\u0430,
    \u0438 \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0438\u043B\u0441\u044F
    \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F\u0445 \u0441\u0432\u043E\u0435\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438.  \u041F\u0435\u0440\u0438\u043E\u0434
    \u0412\u0442\u043E\u0440\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u2014 \u0441\u0430\u043C\u0430\u044F \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u0430\u044F
    \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0430 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438.
    \u0421 \u043E\u0434\u043D\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B,
    \u043E\u043D \u0443\u043A\u0440\u044B\u0432\u0430\u043B \u0435\u0432\u0440\u0435\u0435\u0432
    \u0432 \u0441\u0432\u043E\u0451\u043C \u0434\u043E\u043C\u0435, \u0434\u0435\u0440\u0436\u0430\u043B
    \u0432 \u0448\u0442\u0430\u0442\u0435 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0433\u043E
    \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u0430 \u0425\u0430\u043D\u0441\u0430
    \u0424\u0440\u043E\u0439\u0434\u0435\u043D\u0442\u0430\u043B\u044F \u0438 \u043D\u0435
    \u043F\u043E\u0434\u0434\u0430\u0432\u0430\u043B\u0441\u044F \u043D\u0430 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043D\u0430\u0446\u0438\u0441\u0442\u043E\u0432. \u0421 \u0434\u0440\u0443\u0433\u043E\u0439
    \u0441\u0442\u043E\u0440\u043E\u043D\u044B, \u0432 1943 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u0441\u043E\u0432\u0435\u0442\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438\u043C \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430\u043C
    \u043F\u043E\u0434\u043F\u0438\u0441\u0430\u0442\u044C \u0434\u0435\u043A\u043B\u0430\u0440\u0430\u0446\u0438\u044E
    \u043B\u043E\u044F\u043B\u044C\u043D\u043E\u0441\u0442\u0438 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u043C
    \u043E\u043A\u043A\u0443\u043F\u0430\u043D\u0442\u0430\u043C, \u0447\u0442\u043E\u0431\u044B
    \u0438\u0437\u0431\u0435\u0436\u0430\u0442\u044C \u043F\u0440\u0438\u043D\u0443\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442. \u041F\u043E\u0441\u043B\u0435 \u0432\u043E\u0439\u043D\u044B
    \u044D\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C\u0443 \u043E\u0442\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044E
    \u043E\u0442 \u0440\u0430\u0431\u043E\u0442\u044B.  \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0436\u0438\u0437\u043D\u0438 \u0411\u0440\u0430\u0443\u044D\u0440
    \u043F\u0440\u043E\u0432\u0451\u043B \u0432 \u0411\u043B\u0430\u0440\u0438\u043A\u044E\u043C\u0435.
    \u041E\u043D \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u043E\u0433\u0438\u0431
    2 \u0434\u0435\u043A\u0430\u0431\u0440\u044F 1966 \u0433\u043E\u0434\u0430 \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 85 \u043B\u0435\u0442 \u0432
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435 \u043D\u0435\u0441\u0447\u0430\u0441\u0442\u043D\u043E\u0433\u043E
    \u0441\u043B\u0443\u0447\u0430\u044F, \u043F\u043E\u043F\u0430\u0432 \u043F\u043E\u0434
    \u043C\u0430\u0448\u0438\u043D\u0443.  ### \U0001F3C6 \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435  \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0411\u0440\u0430\u0443\u044D\u0440\u0430 \u043E\u0433\u0440\u043E\u043C\u043D\u043E.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    \u0441\u0442\u0430\u043B\u0438 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u044E\u0442\u0441\u044F \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440. \u0415\u0433\u043E \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0437\u043C,
    \u0445\u043E\u0442\u044F \u0438 \u043D\u0435 \u0441\u0442\u0430\u043B \u0433\u043E\u0441\u043F\u043E\u0434\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u043C
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C, \u043E\u043A\u0430\u0437\u0430\u043B
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043B\u043E\u0433\u0438\u043A\u0438,
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432
    \u0438 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u044B\u0445
    \u043D\u0430\u0443\u043A. \u0418\u0434\u0435\u044F \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u0441\u0442\u0430\u043B\u0430 \u043D\u0435\u043E\u0442\u044A\u0435\u043C\u043B\u0435\u043C\u043E\u0439
    \u0447\u0430\u0441\u0442\u044C\u044E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438.  - \u0412 \u0435\u0433\u043E \u0447\u0435\u0441\u0442\u044C
    \u041D\u0438\u0434\u0435\u0440\u043B\u0430\u043D\u0434\u0441\u043A\u043E\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E \u0443\u0447\u0440\u0435\u0434\u0438\u043B\u043E
    \u043C\u0435\u0434\u0430\u043B\u044C \u0411\u0440\u0430\u0443\u044D\u0440\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0432\u0440\u0443\u0447\u0430\u0435\u0442\u0441\u044F
    \u0440\u0430\u0437 \u0432 \u0442\u0440\u0438 \u0433\u043E\u0434\u0430 \u0437\u0430
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F.
    - \u0415\u0433\u043E \u0438\u043C\u044F \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u043E
    \u043D\u0430 \u043A\u0430\u0440\u0442\u0435 \u041B\u0443\u043D\u044B: \u0432
    1970 \u0433\u043E\u0434\u0443 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u0439
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u043E\u044E\u0437 \u043D\u0430\u0437\u0432\u0430\u043B \u0435\u0433\u043E
    \u0438\u043C\u0435\u043D\u0435\u043C \u043E\u0434\u0438\u043D \u0438\u0437 \u043A\u0440\u0430\u0442\u0435\u0440\u043E\u0432
    \u043D\u0430 \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u0435.
    - \u0412 1932 \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u0437\u0432\u0430\u043D\u0438\u044F \u0440\u044B\u0446\u0430\u0440\u044F \u043E\u0440\u0434\u0435\u043D\u0430
    \u041D\u0438\u0434\u0435\u0440\u043B\u0430\u043D\u0434\u0441\u043A\u043E\u0433\u043E
    \u043B\u044C\u0432\u0430."
  shortBioEn: 
  interestingFactsRu: "\u041B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u041B\u0451\u0439\u0442\u0437\u0435\u043D\u0430
    \u042D\u0433\u0431\u0435\u0440\u0442\u0430 \u042F\u043D\u0430 \u0411\u0440\u0430\u0443\u044D\u0440\u0430
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0436\u0435 \u043D\u0435\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u043E\u0439,
    \u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0438 \u0435\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0438\u0434\u0435\u0438. \u0417\u0430
    \u0441\u0443\u0445\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0441\u043A\u0440\u044B\u0432\u0430\u043B\u0441\u044F
    \u043C\u0438\u0441\u0442\u0438\u043A, \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u0439
    \u0447\u0443\u0434\u0430\u043A, \u0431\u043E\u0440\u0435\u0446 \u0437\u0430 \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E\u0441\u0442\u044C
    \u0438, \u043A\u0430\u043A \u043D\u0438 \u0441\u0442\u0440\u0430\u043D\u043D\u043E,
    \u043B\u044E\u0431\u0438\u043C\u0435\u0446 \u0436\u0435\u043D\u0449\u0438\u043D.
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0438\u0437 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438. 
    ### \u2728 \u0412\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434 \u0438
    \u044E\u043D\u044B\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444  \u0422\u0430\u043B\u0430\u043D\u0442
    \u0411\u0440\u0430\u0443\u044D\u0440\u0430 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u0440\u0430\u043D\u043E. \u0412 9 \u043B\u0435\u0442 \u043E\u043D \u0443\u0436\u0435
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0441\u0440\u0435\u0434\u043D\u044E\u044E
    \u0448\u043A\u043E\u043B\u0443, \u0430 \u0432 14 \u043B\u0435\u0442 \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u043E\u043B\u043D\u043E\u0435 \u0441\u0440\u0435\u0434\u043D\u0435\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u2014 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0434\u0430\u0436\u0435 \u043F\u043E\u043F\u0430\u043B\u043E
    \u0432 \u041A\u043D\u0438\u0433\u0443 \u0440\u0435\u043A\u043E\u0440\u0434\u043E\u0432
    \u0413\u0438\u043D\u043D\u0435\u0441\u0441\u0430. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0431\u044B\u043B\u0438 \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u044B \u043F\u043B\u043E\u0445\u0438\u043C
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435\u043C \u0438 \u043D\u0435\u0440\u0432\u043D\u044B\u043C\u0438
    \u0441\u0440\u044B\u0432\u0430\u043C\u0438, \u0447\u0442\u043E \u0437\u0430\u043C\u0435\u0434\u043B\u044F\u043B\u043E
    \u0435\u0433\u043E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441.  \u0412 23 \u0433\u043E\u0434\u0430,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0435\u0449\u0451 \u043D\u0438\u043A\u043E\u043C\u0443
    \u043D\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C,
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0432 \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0435
    \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u043A\u0443\u044E \u0444\u0440\u0430\u0437\u0443:
    \"\u0415\u0449\u0451 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043B\u0435\u0442
    \u043C\u043D\u0435 \u0441\u0443\u0436\u0434\u0435\u043D\u043E \u0431\u044B\u0442\u044C
    \u0432 \u0431\u0435\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u043D\u043E \u0437\u0430\u0442\u0435\u043C \u043C\u043E\u044F \u0432\u043B\u0430\u0441\u0442\u044C
    \u0431\u0443\u0434\u0435\u0442 \u043E\u0449\u0443\u0442\u0438\u043C\u0430\".
    \u041E\u043D \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u043F\u0440\u0430\u0432:
    \u043C\u0435\u043D\u0435\u0435 \u0447\u0435\u043C \u0447\u0435\u0440\u0435\u0437
    \u0434\u0435\u0441\u044F\u0442\u044C \u043B\u0435\u0442 \u0435\u0433\u043E \u0438\u043C\u044F
    \u0433\u0440\u0435\u043C\u0435\u043B\u043E \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043C\u0438\u0440\u0435.  \u0411\u0443\u0434\u0443\u0447\u0438 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C,
    \u0411\u0440\u0430\u0443\u044D\u0440 \u0443\u0432\u043B\u0451\u043A\u0441\u044F
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0435\u0439 \u0438 \u043C\u0438\u0441\u0442\u0438\u0446\u0438\u0437\u043C\u043E\u043C.
    \u0412 1905 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442 **\"\u0416\u0438\u0437\u043D\u044C,
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E \u0438 \u043C\u0438\u0441\u0442\u0438\u043A\u0430\"**,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u043E\u0441\u0443\u0436\u0434\u0430\u043B \u0434\u043E\u043C\u0438\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u043D\u0430\u0434 \u043F\u0440\u0438\u0440\u043E\u0434\u043E\u0439
    \u0438 \u043D\u0430\u0434 \u0441\u0432\u043E\u0438\u043C\u0438 \u0441\u043E\u0431\u0440\u0430\u0442\u044C\u044F\u043C\u0438
    \u043A\u0430\u043A \"\u0433\u0440\u0435\u0445\u043E\u0432\u043D\u043E\u0435\".
    \u0415\u0433\u043E \u0438\u0434\u0435\u0438 \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0438\u0441\u044C
    \u043F\u043E\u0434 \u0441\u0438\u043B\u044C\u043D\u044B\u043C \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C
    \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0445 \u0443\u0447\u0435\u043D\u0438\u0439
    (\u0431\u0443\u0434\u0434\u0438\u0437\u043C\u0430 \u0438 \u0434\u0430\u043E\u0441\u0438\u0437\u043C\u0430).
    \u0414\u0430\u0436\u0435 \u0432 \u0441\u0432\u043E\u0435\u0439 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438
    \u043E\u043D \u043D\u0430\u0445\u043E\u0434\u0438\u043B \u043C\u0435\u0441\u0442\u043E
    \u0434\u043B\u044F \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439
    \u043E \u0442\u043E\u043C, \u043A\u0430\u043A \"\u0435\u0432\u0440\u0435\u0438
    \u0433\u043E\u0441\u043F\u043E\u0434\u0441\u0442\u0432\u0443\u044E\u0442 \u043D\u0430\u0434
    \u0444\u0435\u0440\u043C\u0435\u0440\u0430\u043C\u0438 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\".  ### \U0001F9E9
    \u041C\u0438\u0441\u0442\u0438\u043A \u0438 \"\u0431\u043E\u0433\u0435\u043C\u0430\"
    \u0432 \u043E\u0434\u043D\u043E\u043C \u043B\u0438\u0446\u0435  \u0411\u0440\u0430\u0443\u044D\u0440
    \u043D\u0435 \u0432\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0441\u044F \u0432
    \u043E\u0431\u0440\u0430\u0437 \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u043D\u043E\u0433\u043E
    \u0443\u0447\u0451\u043D\u043E\u0433\u043E. \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B
    \u0441\u0435\u0431\u044F \u043C\u0438\u0441\u0442\u0438\u043A\u043E\u043C \u0438
    \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0432\u0438\u0434\u0435\u043B
    \u0432 \u044D\u0442\u043E\u043C \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u044F
    \u0441\u0432\u043E\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438. \u0415\u0433\u043E
    \u0434\u0440\u0443\u0433\u043E\u043C \u0438 \u0435\u0434\u0438\u043D\u043E\u043C\u044B\u0448\u043B\u0435\u043D\u043D\u0438\u043A\u043E\u043C
    \u0431\u044B\u043B \u043F\u043E\u044D\u0442-\u0441\u043E\u0446\u0438\u0430\u043B\u0438\u0441\u0442
    \u041A.\u0421. \u0410\u0434\u0430\u043C\u0430 \u0432\u0430\u043D \u0421\u0445\u0435\u043B\u0442\u0435\u043C\u0430. 
    \u0411\u043E\u043B\u044C\u0448\u0443\u044E \u0447\u0430\u0441\u0442\u044C \u0436\u0438\u0437\u043D\u0438
    \u0411\u0440\u0430\u0443\u044D\u0440 \u043F\u0440\u043E\u0432\u0451\u043B \u0432
    \u043A\u043E\u0442\u0442\u0435\u0434\u0436\u0435 \"\u0425\u0438\u0436\u0438\u043D\u0430\"
    (de Hut) \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435 \u0411\u043B\u0430\u0440\u0438\u043A\u044E\u043C,
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u043E\u043C \u043F\u043E
    \u043F\u0440\u043E\u0435\u043A\u0442\u0443 \u0434\u0440\u0443\u0433\u0430. \u042D\u0442\u043E\u0442
    \u0440\u0430\u0439\u043E\u043D \u0431\u044B\u043B \u0438\u0437\u043B\u044E\u0431\u043B\u0435\u043D\u043D\u044B\u043C
    \u043C\u0435\u0441\u0442\u043E\u043C \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u043E\u0432
    \u0438 \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441\u0438\u0432\u043D\u044B\u0445
    \u043C\u044B\u0441\u043B\u0438\u0442\u0435\u043B\u0435\u0439. \u0412\u043E\u043A\u0440\u0443\u0433
    \u043D\u0435\u0433\u043E \u0447\u0430\u0441\u0442\u043E \u0441\u043E\u0431\u0438\u0440\u0430\u043B\u0441\u044F
    \u043A\u0440\u0443\u0433 \u043F\u043E\u0447\u0438\u0442\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u0446,
    \u0438 \u043E\u043D \u0434\u0430\u0436\u0435 \u0445\u043E\u0434\u0438\u043B \u043F\u043E
    \u0434\u043E\u043C\u0443 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u0433\u043E\u043B\u044B\u043C, \u0447\u0442\u043E \u0435\u0433\u043E \u0441\u043F\u0443\u0442\u043D\u0438\u0446,
    \u043F\u043E-\u0432\u0438\u0434\u0438\u043C\u043E\u043C\u0443, \u043D\u0438\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043D\u0435 \u0441\u043C\u0443\u0449\u0430\u043B\u043E. \u0422\u0430\u043A\u0436\u0435
    \u043E\u043D \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F \u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435\u043C
    \u0431\u043E\u0441\u0438\u043A\u043E\u043C \u043F\u043E \u0440\u043E\u0441\u0435,
    \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u043C\u0438 \u0432\u0430\u043D\u043D\u0430\u043C\u0438
    \u0438 \u0431\u044B\u043B \u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0446\u0435\u043C. 
    \u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u043F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u0411\u0440\u0430\u0443\u044D\u0440 \u043F\u0440\u0438\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0441\u044F
    \u0432\u0435\u0441\u044C\u043C\u0430 \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u0442\u0438\u0432\u043D\u044B\u0445
    \u0432\u0437\u0433\u043B\u044F\u0434\u043E\u0432 \u043D\u0430 \u0440\u043E\u043B\u044C
    \u0436\u0435\u043D\u0449\u0438\u043D\u044B \u0432 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435,
    \u0441\u0447\u0438\u0442\u0430\u044F \u0438\u0445 \"\u0438\u0441\u043A\u0443\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0430\u043C\u0438\".
    \u041E\u0434\u043D\u0430\u043A\u043E \u043E\u043D \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u043D\u0430\u043D\u044F\u0432\u0448\u0438\u0445 \u0436\u0435\u043D\u0449\u0438\u043D\u0443-\u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u0430
    (\u041A\u043E\u0440 \u0419\u043E\u043D\u0433\u044C\u044F\u043D), \u0438 \u0441\u043E\u0441\u0442\u043E\u044F\u043B
    \u0432 \u0445\u043E\u0440\u043E\u0448\u0438\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u0445
    \u0441 \u0442\u0430\u043A\u0438\u043C\u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0438\u0441\u044F
    \u0443\u0447\u0451\u043D\u044B\u043C\u0438, \u043A\u0430\u043A \u042D\u043C\u043C\u0438
    \u041D\u0451\u0442\u0435\u0440 \u0438 \u041E\u043B\u044C\u0433\u0430 \u0422\u0430\u0443\u0441\u0441\u043A\u0438. 
    ### \u2615 \"\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\" \u0447\u0430\u0448\u043A\u0438
    \u043A\u043E\u0444\u0435 \u0438 \u043B\u044B\u0441\u043E\u0433\u043E \u043C\u044F\u0447\u0430 
    \u0414\u0432\u0430 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430 \u0411\u0440\u0430\u0443\u044D\u0440\u0430
    \u0447\u0430\u0441\u0442\u043E \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u0443\u044E\u0442\u0441\u044F
    \u043E\u0447\u0435\u043D\u044C \u043D\u0430\u0433\u043B\u044F\u0434\u043D\u044B\u043C\u0438
    \u043F\u0440\u0438\u043C\u0435\u0440\u0430\u043C\u0438:  1.  **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u0435**:
    \u041B\u0435\u0433\u0435\u043D\u0434\u0430 \u0433\u043B\u0430\u0441\u0438\u0442,
    \u0447\u0442\u043E \u0411\u0440\u0430\u0443\u044D\u0440 \u043F\u0440\u0438\u0448\u0451\u043B
    \u043A \u0441\u0432\u043E\u0435\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \u0442\u0435\u043E\u0440\u0435\u043C\u0435, \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u044F
    \u0437\u0430 \u0440\u0430\u0437\u043C\u0435\u0448\u0438\u0432\u0430\u043D\u0438\u0435\u043C
    \u0441\u0430\u0445\u0430\u0440\u0430 \u0432 \u0447\u0430\u0448\u043A\u0435 \u043A\u043E\u0444\u0435.
    \u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u043A\u0430\u043A \u0431\u044B \u0432\u044B \u043D\u0438
    \u043C\u0435\u0448\u0430\u043B\u0438 \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u044C
    \u0432 \u043A\u0440\u0443\u0436\u043A\u0435, \u0432\u0441\u0435\u0433\u0434\u0430
    \u043D\u0430\u0439\u0434\u0451\u0442\u0441\u044F \u0445\u043E\u0442\u044F \u0431\u044B
    \u043E\u0434\u043D\u0430 \u0447\u0430\u0441\u0442\u0438\u0446\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0432\u0435\u0440\u043D\u0451\u0442\u0441\u044F \u0432 \u0438\u0441\u0445\u043E\u0434\u043D\u0443\u044E
    \u0442\u043E\u0447\u043A\u0443. \u0414\u0440\u0443\u0433\u043E\u0439 \u043F\u0440\u0438\u043C\u0435\u0440:
    \u0435\u0441\u043B\u0438 \u0441\u043C\u044F\u0442\u044C \u043B\u0438\u0441\u0442
    \u0431\u0443\u043C\u0430\u0433\u0438 \u0438 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u044C
    \u0435\u0433\u043E \u043D\u0430 \u0442\u043E \u0436\u0435 \u043C\u0435\u0441\u0442\u043E,
    \u0442\u043E \u043A\u0430\u043A\u0430\u044F-\u0442\u043E \u0442\u043E\u0447\u043A\u0430
    \u0441\u043C\u044F\u0442\u043E\u0433\u043E \u043B\u0438\u0441\u0442\u0430 \u043E\u043A\u0430\u0436\u0435\u0442\u0441\u044F
    \u0442\u043E\u0447\u043D\u043E \u043D\u0430\u0434 \u0442\u043E\u0439 \u0436\u0435
    \u0442\u043E\u0447\u043A\u043E\u0439 \u0441\u0442\u043E\u043B\u0430, \u0447\u0442\u043E
    \u0438 \u0434\u043E \u0441\u043C\u044F\u0442\u0438\u044F. 2.  **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043F\u0440\u0438\u0447\u0451\u0441\u044B\u0432\u0430\u043D\u0438\u0438
    \u0435\u0436\u0430**: \u042D\u0442\u0430 \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0433\u043B\u0430\u0441\u0438\u0442, \u0447\u0442\u043E \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E
    \u0440\u0430\u0441\u0447\u0435\u0441\u0430\u0442\u044C \u0432\u043E\u043B\u043E\u0441\u044B
    \u043D\u0430 \u0448\u0430\u0440\u0435 \u0442\u0430\u043A, \u0447\u0442\u043E\u0431\u044B
    \u043D\u0435 \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C \u043D\u0438 \u043E\u0434\u043D\u043E\u0439
    \"\u043C\u0430\u043A\u0443\u0448\u043A\u0438\" (\u0432\u043E\u0440\u0441\u0438\u043D\u043A\u0438,
    \u0442\u043E\u0440\u0447\u0430\u0449\u0435\u0439 \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u043E).
    \u0418\u0437 \u044D\u0442\u043E\u0433\u043E \u0441\u043B\u0435\u0434\u0443\u0435\u0442
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u0432\u044B\u0432\u043E\u0434:
    \u043D\u0430 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
    \u0417\u0435\u043C\u043B\u0438 **\u0432\u0441\u0435\u0433\u0434\u0430 \u0435\u0441\u0442\u044C
    \u043C\u0435\u0441\u0442\u043E, \u0433\u0434\u0435 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E
    \u0431\u0435\u0437\u0432\u0435\u0442\u0440\u0435\u043D\u043D\u043E**.  ### \U0001F525
    \u0412\u0435\u043B\u0438\u043A\u0438\u0439 \u0441\u043F\u043E\u0440 \u0441 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C 
    \u0411\u0440\u0430\u0443\u044D\u0440 \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0441\u0432\u043E\u0435\u0439 \u0431\u0435\u0441\u043A\u043E\u043C\u043F\u0440\u043E\u043C\u0438\u0441\u0441\u043D\u043E\u0441\u0442\u044C\u044E
    \u0438 \"\u0444\u0430\u043D\u0430\u0442\u0438\u0447\u043D\u043E\u0439 \u0441\u0442\u0440\u0430\u0441\u0442\u044C\u044E
    \u043A \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E\u0441\u0442\u0438\",
    \u043A\u0430\u043A \u0432\u044B\u0440\u0430\u0437\u0438\u043B\u0441\u044F \u0435\u0433\u043E
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430 \u0411\u0438\u0431\u0435\u0440\u0431\u0430\u0445.
    \u0415\u0433\u043E \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u0441 \u0414\u0430\u0432\u0438\u0434\u043E\u043C
    \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C \u043F\u043E \u043F\u043E\u0432\u043E\u0434\u0443
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0441\u0442\u0430\u043B \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u043C.
    \u041F\u0438\u043A \u0441\u043F\u043E\u0440\u0430 \u043F\u0440\u0438\u0448\u0451\u043B\u0441\u044F
    \u043D\u0430 1928 \u0433\u043E\u0434, \u043A\u043E\u0433\u0434\u0430 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u0441\u0432\u043E\u0451
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435, \u0434\u043E\u0431\u0438\u043B\u0441\u044F
    \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F \u0411\u0440\u0430\u0443\u044D\u0440\u0430
    \u0438\u0437 \u0440\u0435\u0434\u0430\u043A\u0446\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0441\u043E\u0432\u0435\u0442\u0430 \u0441\u0430\u043C\u043E\u0433\u043E \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0436\u0443\u0440\u043D\u0430\u043B\u0430 \u043C\u0438\u0440\u0430 \u2014 *Mathematische
    Annalen*. \u042D\u0442\u043E \u043D\u0430\u043D\u0435\u0441\u043B\u043E \u0411\u0440\u0430\u0443\u044D\u0440\u0443
    \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0434\u0443\u0448\u0435\u0432\u043D\u0443\u044E
    \u0440\u0430\u043D\u0443, \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0433\u043E\u0440\u0435\u0447\u0438
    \u0438 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438. \u041E\u043D \u0436\u0430\u043B\u043E\u0432\u0430\u043B\u0441\u044F
    \u0434\u0440\u0443\u0433\u0443, \u0447\u0442\u043E \"\u0432\u0441\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438 \u0431\u044B\u043B\u0430 \u043E\u0442\u043D\u044F\u0442\u0430\". 
    ### \U0001F4DC \"\u0417\u0430\u043F\u0440\u0435\u0442\u043D\u044B\u0439 \u043F\u043B\u043E\u0434\"
    \u0438 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u043A\u043E\u043D\u0435\u0446 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0435\u0433\u043E
    \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u044B\u0435
    \u0438 \u0434\u0430\u0436\u0435 \u0440\u0435\u0430\u043A\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u043D\u0430 \u0436\u0435\u043D\u0449\u0438\u043D
    \u0438 \u0435\u0432\u0440\u0435\u0435\u0432, \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0412\u0442\u043E\u0440\u043E\u0439 \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u0411\u0440\u0430\u0443\u044D\u0440 \u0443\u043A\u0440\u044B\u0432\u0430\u043B
    \u0435\u0432\u0440\u0435\u0435\u0432 \u0432 \u0441\u0432\u043E\u0451\u043C \u0434\u043E\u043C\u0435
    \u0438 \u043D\u0430\u043D\u0438\u043C\u0430\u043B \u0438\u0445 \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u0432. \u0415\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u0438 \u043D\u0435\u043B\u0435\u043F\u043E \u043E\u0431\u043E\u0440\u0432\u0430\u043B\u0430\u0441\u044C
    2 \u0434\u0435\u043A\u0430\u0431\u0440\u044F 1966 \u0433\u043E\u0434\u0430. 85-\u043B\u0435\u0442\u043D\u0438\u0439
    \u0443\u0447\u0451\u043D\u044B\u0439, **\u0437\u0430\u043A\u0443\u0442\u0430\u043D\u043D\u044B\u0439
    \u0432 \u043B\u043E\u0448\u0430\u0434\u0438\u043D\u0443\u044E \u043F\u043E\u043F\u043E\u043D\u0443**,
    \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0438\u043B \u0443\u043B\u0438\u0446\u0443
    \u043F\u0440\u044F\u043C\u043E \u043F\u0435\u0440\u0435\u0434 \u0441\u0432\u043E\u0438\u043C
    \u0434\u043E\u043C\u043E\u043C \u0432 \u0411\u043B\u0430\u0440\u0438\u043A\u044E\u043C\u0435,
    \u043D\u0435 \u0433\u043B\u044F\u0434\u044F \u043F\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u0430\u043C,
    \u0438 \u0431\u044B\u043B \u0441\u0431\u0438\u0442 \u043C\u0430\u0448\u0438\u043D\u043E\u0439.
    \u042D\u0442\u043E \u0431\u044B\u043B \u0444\u0438\u043D\u0430\u043B, \u0434\u043E\u0441\u0442\u043E\u0439\u043D\u044B\u0439
    \u0432\u0441\u0435\u0439 \u0435\u0433\u043E \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u043E\u0439
    \u0438 \u043F\u043E\u043B\u043D\u043E\u0439 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0439
    \u0436\u0438\u0437\u043D\u0438."
