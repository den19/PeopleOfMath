  achievementsRu: "\u0412\u043A\u043B\u0430\u0434 \u041B\u0451\u0439\u0442\u0437\u0435\u043D\u0430
    \u042D\u0433\u0431\u0435\u0440\u0442\u0430 \u042F\u043D\u0430 \u0411\u0440\u0430\u0443\u044D\u0440\u0430
    \u0432 \u043D\u0430\u0443\u043A\u0443 \u0443\u043D\u0438\u043A\u0430\u043B\u0435\u043D
    \u0442\u0435\u043C, \u0447\u0442\u043E \u043E\u043D \u0431\u044B\u043B \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u043F\u0435\u0440\u0432\u043E\u043F\u0440\u043E\u0445\u043E\u0434\u0446\u0435\u043C
    \u0432 \u0434\u0432\u0443\u0445, \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C
    \u0431\u044B, \u0440\u0430\u0437\u043D\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445:
    \u043E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    \u0438 \u0441\u043E\u0437\u0434\u0430\u043B \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0435
    \u0442\u0435\u0447\u0435\u043D\u0438\u0435 \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u043E\u043D\u0438\u0437\u043C\u0430,
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u0432 \u0437\u0430\u043D\u043E\u0432\u043E
    \u043F\u0435\u0440\u0435\u0441\u0442\u0440\u043E\u0438\u0442\u044C \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432\u0441\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0415\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u043C\u043E\u0436\u043D\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C \u043D\u0430 \u0434\u0432\u0430
    \u043C\u043E\u0449\u043D\u044B\u0445 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F,
    \u043A\u0430\u0436\u0434\u043E\u0435 \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043F\u043E-\u0441\u0432\u043E\u0435\u043C\u0443 \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0438\u0440.  ### \U0001F9EC \u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    (1911\u20131913)  \u0412 \u043D\u0430\u0447\u0430\u043B\u0435 XX \u0432\u0435\u043A\u0430
    \u0411\u0440\u0430\u0443\u044D\u0440 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432 \u0432 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    (\u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0442\u043E\u0433\u0434\u0430 \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438
    *analysis situs*), \u0437\u0430\u043B\u043E\u0436\u0438\u0432 \u0435\u0451 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A\u043E-\u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u043E\u0441\u043D\u043E\u0432\u044B. \u0412 \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 (1911\u20131913) \u043E\u043D \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B
    \u0440\u044F\u0434 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u043D\u044F\u0442\u0438\u0439 \u0438 \u0442\u0435\u043E\u0440\u0435\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0438
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u0432\u043F\u0435\u0440\u0451\u0434.  \u0412\u043E\u0442 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u044D\u0442\u043E\u0433\u043E
    \u043F\u0435\u0440\u0438\u043E\u0434\u0430:  *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u0435:**
    \u0412\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0441\u0430\u043C\u043E\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435 \u0435\u0433\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435.
    \u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u043F\u0440\u0438 \u043B\u044E\u0431\u043E\u043C \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u043C
    \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0438 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0433\u043E
    \u0448\u0430\u0440\u0430 \u0432 \u0441\u0435\u0431\u044F \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0445\u043E\u0442\u044F \u0431\u044B \u043E\u0434\u043D\u0430 \u0442\u043E\u0447\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F
    \u043D\u0430 \u043C\u0435\u0441\u0442\u0435. \u042D\u0442\u0430 \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u043D\u0430\u0448\u043B\u0430 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0439 \u0434\u0430\u043B\u0435\u043A\u043E
    \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438,
    \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0432 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0435,
    \u0444\u0438\u0437\u0438\u043A\u0435 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E\u0431 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043D\u043E\u0441\u0442\u0438
    \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438:** \u0411\u0440\u0430\u0443\u044D\u0440
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u043C. \u042D\u0442\u043E
    \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442, \u0447\u0442\u043E n-\u043C\u0435\u0440\u043D\u043E\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E \u043D\u0435\u043B\u044C\u0437\u044F
    \u0432\u0437\u0430\u0438\u043C\u043D\u043E \u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E
    \u0438 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E \u043E\u0442\u043E\u0431\u0440\u0430\u0437\u0438\u0442\u044C
    \u043D\u0430 m-\u043C\u0435\u0440\u043D\u043E\u0435 \u043F\u0440\u0438 n \u2260
    m. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u043E\u0431 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043D\u043E\u0441\u0442\u0438
    \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0445 \u0442\u043E\u0447\u0435\u043A:**
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043F\u0440\u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0438 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0435
    \u0442\u043E\u0447\u043A\u0438 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u044F\u0442 \u0432\u043E \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0435
    \u0442\u043E\u0447\u043A\u0438, \u0447\u0442\u043E \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u043C \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C
    \u0434\u043B\u044F \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432. *   **\u041D\u043E\u0432\u044B\u0435
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F:** \u0411\u0440\u0430\u0443\u044D\u0440
    \u0432\u0432\u0451\u043B \u0432 \u043D\u0430\u0443\u043A\u0443 \u043F\u043E\u043D\u044F\u0442\u0438\u044F
    \u0441\u0438\u043C\u043F\u043B\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0430\u043F\u043F\u0440\u043E\u043A\u0441\u0438\u043C\u0430\u0446\u0438\u0438
    \u0438 \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0433\u043E
    \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F, \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0433\u043E\u043C\u043E\u0442\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0438
    \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439. \u042D\u0442\u0438
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B \u0441\u0442\u0430\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438. *   **n-\u043C\u0435\u0440\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u0416\u043E\u0440\u0434\u0430\u043D\u0430:**
    \u041E\u043D \u043E\u0431\u043E\u0431\u0449\u0438\u043B \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u0416\u043E\u0440\u0434\u0430\u043D\u0430
    \u043D\u0430 \u043C\u043D\u043E\u0433\u043E\u043C\u0435\u0440\u043D\u044B\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430, \u0434\u043E\u043A\u0430\u0437\u0430\u0432,
    \u0447\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u0430\u044F \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u0430\u044F
    (n-1)-\u043C\u0435\u0440\u043D\u0430\u044F \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u044C
    \u0434\u0435\u043B\u0438\u0442 n-\u043C\u0435\u0440\u043D\u043E\u0435 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u043D\u0430 \u0434\u0432\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. 
    \u042D\u0442\u0438 \u0440\u0430\u0431\u043E\u0442\u044B, \u043F\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044E
    \u043A\u043E\u043B\u043B\u0435\u0433, \u043E\u043A\u0430\u0437\u0430\u043B\u0438
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    \u0432 \u043F\u0435\u0440\u0438\u043E\u0434 \u043C\u0435\u0436\u0434\u0443 \u043C\u0438\u0440\u043E\u0432\u044B\u043C\u0438
