  id: witten
  wikiTitleRu: "Виттен, Эдвард"
  wikidataId: Q107419
  fullNameRu: "Виттен, Эдвард"
  fullNameEn: 
  birthDate: 
  deathDate: 
  countryKeys:
  - usa
  centuryKeys:
