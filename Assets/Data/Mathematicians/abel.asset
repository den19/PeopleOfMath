    \u0412 \u0442\u043E\u043C \u0436\u0435 1826 \u0433\u043E\u0434\u0443 \u0410\u0431\u0435\u043B\u044C
    \u043F\u0440\u0438\u0432\u0435\u043B \u043A\u043E\u043D\u0442\u0440\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u041A\u043E\u0448\u0438 \u043E \u0441\u0443\u043C\u043C\u0435
    \u0441\u0445\u043E\u0434\u044F\u0449\u0435\u0433\u043E\u0441\u044F \u0440\u044F\u0434\u0430
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439,
    \u043F\u043E\u043A\u0430\u0437\u0430\u0432 \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u044C
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F \u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0439
    \u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438.  ### \u23F3 1827\u20131828:
    \u0417\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u0435 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0442\u0440\u0443\u0434\u044B
    \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C \u0432 \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u044E
    \u0432 1827 \u0433\u043E\u0434\u0443, \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044C
    \u0442\u0435\u043E\u0440\u0438\u044E \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439. \u041E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u0440\u0430\u0431\u043E\u0442\u0443 \xABRecherches
    sur les Fonctions elliptiques\xBB, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u044B\u043C \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u043C
    \u0442\u0440\u0443\u0434\u043E\u043C \u043F\u043E \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C. \u041E\u043D \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B
    \u044D\u0442\u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u0438 \u043A\u0430\u043A
    \u043E\u0431\u0440\u0430\u0442\u043D\u044B\u0435 \u043A \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430\u043C \u0438 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0438\u043B
    \u0438\u0445 \u043D\u0430 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u0443\u044E
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C. \u0412 1828 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C
    \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438. 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0431\u0435\u0434\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0443\u0445\u0443\u0434\u0448\u0430\u044E\u0449\u0435\u0435\u0441\u044F
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435, \u043E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043D\u0430\u0443\u043A\u0435 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0431\u043E\u0433\u0430\u0442\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435,
    \u0447\u0442\u043E, \u043F\u043E \u0441\u043B\u043E\u0432\u0430\u043C \u0428\u0430\u0440\u043B\u044F
    \u042D\u0440\u043C\u0438\u0442\u0430, \xAB\u0438\u043C \u0431\u0443\u0434\u0435\u0442
    \u0447\u0435\u043C \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u0432 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0438\u0435 500 \u043B\u0435\u0442\xBB.
    \u0415\u0433\u043E \u0438\u043C\u044F \u0442\u0435\u043F\u0435\u0440\u044C \u043D\u043E\u0441\u044F\u0442
    \u0434\u0435\u0441\u044F\u0442\u043A\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432, \u043E\u0442 **\u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445
    \u0433\u0440\u0443\u043F\u043F** \u0438 **\u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u0432**
    \u0434\u043E **\u0442\u0435\u043E\u0440\u0435\u043C** \u0438 **\u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0439**
    ."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u041D\u0438\u043B\u044C\u0441\u0430 \u0425\u0435\u043D\u0440\u0438\u043A\u0430
    \u0410\u0431\u0435\u043B\u044F \u2014 \u044D\u0442\u043E \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043B\u044E\u0431\u0432\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0442\u0430\u043A \u0438 \u043D\u0435 \u0431\u044B\u043B\u0430 \u0440\u0435\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043D\u0430
    \u0438\u0437-\u0437\u0430 \u0431\u0435\u0434\u043D\u043E\u0441\u0442\u0438 \u0438
    \u0440\u0430\u043D\u043D\u0435\u0439 \u0441\u043C\u0435\u0440\u0442\u0438 \u0443\u0447\u0435\u043D\u043E\u0433\u043E.
    \u0412\u043E\u0442 \u0435\u0435 \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044F: 
    ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466 \u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u044E\u043D\u043E\u0441\u0442\u044C (1802-1821): \u0422\u044F\u0436\u0435\u043B\u0430\u044F
    \u0441\u0435\u043C\u0435\u0439\u043D\u0430\u044F \u043E\u0431\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0430 
    *   **1802 \u0433\u043E\u0434, 5 \u0430\u0432\u0433\u0443\u0441\u0442\u0430:**
    \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u041D\u0438\u043B\u044C\u0441\u0430
    \u0425\u0435\u043D\u0440\u0438\u043A\u0430 \u0432 \u0441\u0435\u043C\u044C\u0435
    \u043F\u0430\u0441\u0442\u043E\u0440\u0430 \u0421\u0451\u0440\u0435\u043D\u0430
    \u0413\u0435\u043E\u0440\u0433\u0430 \u0410\u0431\u0435\u043B\u044F \u043D\u0430
    \u043E\u0441\u0442\u0440\u043E\u0432\u0435 \u0424\u0438\u043D\u043D\u0451\u0439.
    *   **\u0414\u0435\u0442\u0441\u0442\u0432\u043E:** \u0421\u0435\u043C\u044C\u044F
    \u0431\u044B\u043B\u0430 \u043C\u043D\u043E\u0433\u043E\u0434\u0435\u0442\u043D\u043E\u0439
    (\u0410\u0431\u0435\u043B\u044C \u0431\u044B\u043B \u0432\u0442\u043E\u0440\u044B\u043C
    \u0438\u0437 \u0441\u0435\u043C\u0438 \u0434\u0435\u0442\u0435\u0439), \u0438
    \u0435\u0433\u043E \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438 \u043D\u0435
    \u0434\u0430\u0432\u0430\u043B\u0438 \u0435\u043C\u0443 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438. \u041E\u0442\u0435\u0446 \u0441\u0442\u0440\u0430\u0434\u0430\u043B
    \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u0438\u0437\u043C\u043E\u043C, \u0430
    \u043C\u0430\u0442\u044C \u0442\u0430\u043A\u0436\u0435 \u0438\u043C\u0435\u043B\u0430
    \u043F\u0440\u0438\u0441\u0442\u0440\u0430\u0441\u0442\u0438\u0435 \u043A \u0441\u043F\u0438\u0440\u0442\u043D\u043E\u043C\u0443.
    *   **1820 \u0433\u043E\u0434:** \u0421\u043C\u0435\u0440\u0442\u044C \u043E\u0442\u0446\u0430.
    \u041D\u0430 \u043F\u043B\u0435\u0447\u0438 18-\u043B\u0435\u0442\u043D\u0435\u0433\u043E
    \u041D\u0438\u043B\u044C\u0441\u0430 \u043B\u043E\u0436\u0438\u0442\u0441\u044F
    \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0437\u0430 \u0441\u0435\u043C\u044C\u044E \u0438\u0437 \u0448\u0435\u0441\u0442\u0438
    \u0434\u0435\u0442\u0435\u0439. \u0427\u0442\u043E\u0431\u044B \u043E\u0431\u043B\u0435\u0433\u0447\u0438\u0442\u044C
    \u0436\u0438\u0437\u043D\u044C \u043C\u0430\u0442\u0435\u0440\u0438, \u043E\u043D
    \u0437\u0430\u0431\u0438\u0440\u0430\u0435\u0442 \u043E\u0434\u043D\u043E\u0433\u043E
    \u0438\u0437 \u0431\u0440\u0430\u0442\u044C\u0435\u0432 \u043A \u0441\u0435\u0431\u0435
    \u043D\u0430 \u043F\u043E\u043F\u0435\u0447\u0435\u043D\u0438\u0435 \u0438 \u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0435\u0442
    \u0440\u0435\u043F\u0435\u0442\u0438\u0442\u043E\u0440\u0441\u0442\u0432\u043E\u043C. 
    ### \U0001F496 \u0412\u0441\u0442\u0440\u0435\u0447\u0430 \u0438 \u043E\u0431\u0440\u0443\u0447\u0435\u043D\u0438\u0435
    (1823\u20131824)  *   **1823 \u0433\u043E\u0434, \u043B\u0435\u0442\u043E:**
    \u0410\u0431\u0435\u043B\u044C \u0441\u043E\u0432\u0435\u0440\u0448\u0430\u0435\u0442
    \u043F\u043E\u0435\u0437\u0434\u043A\u0443 \u0432 \u041A\u043E\u043F\u0435\u043D\u0433\u0430\u0433\u0435\u043D
    \u0434\u043B\u044F \u0432\u0441\u0442\u0440\u0435\u0447\u0438 \u0441 \u0434\u0430\u0442\u0441\u043A\u0438\u043C\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438. \u041D\u0430
    \u043E\u0434\u043D\u043E\u043C \u0438\u0437 \u0431\u0430\u043B\u043E\u0432 \u043E\u043D
    \u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0442\u0441\u044F \u0441 **\u041A\u0440\u0438\u0441\u0442\u0438\u043D\u043E\u0439
    (\"\u041A\u0440\u0435\u043B\u043B\u0438\") \u041A\u0435\u043C\u043F**, 19-\u043B\u0435\u0442\u043D\u0435\u0439
    \u0434\u0435\u0432\u0443\u0448\u043A\u043E\u0439, \u043A\u043E\u0442\u043E\u0440\u0430\u044F,
    \u043A\u0430\u043A \u0438 \u043E\u043D \u0441\u0430\u043C\u0430, \u0431\u044B\u043B\u0430
    \u0431\u0435\u0434\u043D\u0430 \u0438 \u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043B\u0430
    \u043D\u0430 \u0436\u0438\u0437\u043D\u044C \u0440\u0435\u043F\u0435\u0442\u0438\u0442\u043E\u0440\u0441\u0442\u0432\u043E\u043C.
    *   **1824 \u0433\u043E\u0434, \u0420\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u043E:**
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0442\u044F\u0436\u0435\u043B\u043E\u0435
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u043E\u0435 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435,
    \u0410\u0431\u0435\u043B\u044C \u0438 \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430
    \u043F\u0440\u0430\u0437\u0434\u043D\u0443\u044E\u0442 \u0441\u0432\u043E\u044E
    \u043F\u043E\u043C\u043E\u043B\u0432\u043A\u0443. \u041E\u043D\u0438 \u0441\u0442\u0440\u043E\u044F\u0442
    \u043F\u043B\u0430\u043D\u044B \u043D\u0430 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C, \u043D\u043E \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E
    \u0410\u0431\u0435\u043B\u044E \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
    \u043D\u0430\u0439\u0442\u0438 \u0445\u043E\u0440\u043E\u0448\u043E \u043E\u043F\u043B\u0430\u0447\u0438\u0432\u0430\u0435\u043C\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443.  ### \U0001F6B6\u200D\u2642\uFE0F \u0420\u0430\u0437\u043B\u0443\u043A\u0430
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F \u0437\u0438\u043C\u0430
    (1825\u20131829)  *   **1825\u20131827:** \u041F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0443\u044F
    \u043F\u043E \u0415\u0432\u0440\u043E\u043F\u0435 \u0441 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438
    \u0446\u0435\u043B\u044F\u043C\u0438, \u0410\u0431\u0435\u043B\u044C \u043F\u043E\u0447\u0442\u0438
    \u0432\u0441\u0435 \u0432\u0440\u0435\u043C\u044F \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u0432 \u0440\u0430\u0437\u043B\u0443\u043A\u0435 \u0441\u043E \u0441\u0432\u043E\u0435\u0439
    \u043D\u0435\u0432\u0435\u0441\u0442\u043E\u0439. *   **\u041A\u043E\u043D\u0435\u0446
    1828 \u0433\u043E\u0434\u0430:** \u0421\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F \u0410\u0431\u0435\u043B\u044F
    \u0440\u0435\u0437\u043A\u043E \u0443\u0445\u0443\u0434\u0448\u0430\u0435\u0442\u0441\u044F.
    \u041E\u043D \u0440\u0435\u0448\u0430\u0435\u0442 \u043F\u0440\u043E\u0432\u0435\u0441\u0442\u0438
    \u0420\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u043E 1828 \u0433\u043E\u0434\u0430
    \u0441 \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u043E\u0439 \u0432\u043E \u0424\u0440\u043E\u043B\u0430\u043D\u0434\u0435,
    \u0433\u0434\u0435 \u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430
    \u0433\u0443\u0432\u0435\u0440\u043D\u0430\u043D\u0442\u043A\u043E\u0439 \u0432
    \u0441\u0435\u043C\u044C\u0435 \u0435\u0433\u043E \u0434\u0440\u0443\u0437\u0435\u0439.
    *   **1829 \u0433\u043E\u0434, 6 \u0430\u043F\u0440\u0435\u043B\u044F:** \u0412\u043E
    \u0432\u0440\u0435\u043C\u044F \u0432\u0438\u0437\u0438\u0442\u0430 \u043A \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0435
    \u0410\u0431\u0435\u043B\u044C \u0437\u0430\u0431\u043E\u043B\u0435\u0432\u0430\u0435\u0442
    \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437\u043E\u043C \u0438
    \u0443\u043C\u0438\u0440\u0430\u0435\u0442. \u0415\u043C\u0443 \u0431\u044B\u043B\u043E
    \u0432\u0441\u0435\u0433\u043E 26 \u043B\u0435\u0442 . \u0427\u0435\u0440\u0435\u0437
    \u043D\u0435\u0434\u0435\u043B\u044E \u0435\u0433\u043E \u0445\u043E\u0440\u043E\u043D\u044F\u0442
    \u043D\u0430 \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435 \u0432\u043E \u0424\u0440\u043E\u043B\u0430\u043D\u0434\u0435. 
    ### \U0001F494 \u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 
    *   **\u0422\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u0441\u043E\u0432\u043F\u0430\u0434\u0435\u043D\u0438\u0435:**
    \u041F\u0438\u0441\u044C\u043C\u043E \u043E\u0442 \u0434\u0440\u0443\u0433\u0430
    \u0410\u0432\u0433\u0443\u0441\u0442\u0430 \u041A\u0440\u0435\u043B\u043B\u0435
    \u0441 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u043E\u0439
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438 \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0435
    \u043F\u0440\u0438\u0448\u043B\u043E \u0432 \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u044E
    \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0430 \u0434\u043D\u044F \u043F\u043E\u0441\u043B\u0435
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438. *   **\u0421\u0443\u0434\u044C\u0431\u0430
    \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u044B:** \u041F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0410\u0431\u0435\u043B\u044F \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0435\u0433\u043E \u0434\u0440\u0443\u0437\u0435\u0439, \u0411\u0430\u043B\u0442\u0430\u0437\u0430\u0440
    \u041A\u0435\u0439\u043B\u044C\u0445\u0430\u0443, \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0435 \u043F\u0438\u0441\u044C\u043C\u043E
    \u0441 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C
    \u0440\u0443\u043A\u0438 \u0438 \u0441\u0435\u0440\u0434\u0446\u0430. \u041F\u0435\u0440\u0435\u0434
    \u0441\u043C\u0435\u0440\u0442\u044C\u044E \u0410\u0431\u0435\u043B\u044C \u043F\u0440\u043E\u0441\u0438\u043B
    \u0435\u0433\u043E \u043F\u043E\u0437\u0430\u0431\u043E\u0442\u0438\u0442\u044C\u0441\u044F
    \u043E \u043D\u0435\u0432\u0435\u0441\u0442\u0435, \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044F
    \u0435\u0451 \u043A\u0430\u043A \"\u043D\u0435 \u043A\u0440\u0430\u0441\u0430\u0432\u0438\u0446\u0443,
    \u0440\u044B\u0436\u0435\u0432\u043E\u043B\u043E\u0441\u0443\u044E \u0438 \u0432\u0435\u0441\u043D\u0443\u0448\u0447\u0430\u0442\u0443\u044E,
    \u043D\u043E \u0432\u0435\u043B\u0438\u043A\u043E\u043B\u0435\u043F\u043D\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430\". \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430
    \u043F\u0440\u0438\u043D\u044F\u043B\u0430 \u044D\u0442\u043E \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435."
  personalLifeEn: 
  shortBioRu: "\u041D\u0438\u043B\u044C\u0441 \u0425\u0435\u043D\u0440\u0438\u043A
    \u0410\u0431\u0435\u043B\u044C (1802\u20131829) \u2014 \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0447\u044C\u044F \u043A\u043E\u0440\u043E\u0442\u043A\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C, \u043F\u043E\u043B\u043D\u0430\u044F \u0431\u0435\u0434\u043D\u043E\u0441\u0442\u0438
    \u0438 \u043B\u0438\u0448\u0435\u043D\u0438\u0439, \u0441\u0442\u0430\u043B\u0430
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u0432 \u0442\u043E \u0436\u0435 \u0432\u0440\u0435\u043C\u044F \u044F\u0440\u043A\u0438\u0445
    \u0441\u0442\u0440\u0430\u043D\u0438\u0446 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430\u0443\u043A\u0438. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u044B
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044F
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438 \u0438 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439.  ### \U0001F4DC
    \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u044E\u043D\u043E\u0441\u0442\u044C
    (1802\u20131821)  *   **5 \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1802 \u0433\u043E\u0434\u0430**:
    \u0420\u043E\u0434\u0438\u043B\u0441\u044F \u043D\u0430 \u043E\u0441\u0442\u0440\u043E\u0432\u0435
    \u0424\u0438\u043D\u043D\u0451\u0439, \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u044F,
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u043F\u0430\u0441\u0442\u043E\u0440\u0430
    \u0421\u0451\u0440\u0435\u043D\u0430 \u0413\u0435\u043E\u0440\u0433\u0430 \u0410\u0431\u0435\u043B\u044F
    . \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0431\u044B\u043B\u043E \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u043E
    \u0431\u0435\u0434\u043D\u043E\u0441\u0442\u044C\u044E, \u0441\u043B\u0430\u0431\u044B\u043C
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435\u043C \u0438 \u0440\u0430\u0437\u0434\u043E\u0440\u0430\u043C\u0438
    \u0432 \u0441\u0435\u043C\u044C\u0435. *   **1815 \u0433\u043E\u0434**: \u041F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u043A\u0430\u0444\u0435\u0434\u0440\u0430\u043B\u044C\u043D\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u0432 \u0425\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0438\u0438
    (\u043D\u044B\u043D\u0435 \u041E\u0441\u043B\u043E). \u041F\u0435\u0440\u0432\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F \u0443\u0447\u0438\u043B\u0441\u044F \u043F\u043E\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E.
    *   **1817 \u0433\u043E\u0434**: \u0412 \u0448\u043A\u043E\u043B\u0435 \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u043D\u043E\u0432\u044B\u0439 \u0443\u0447\u0438\u0442\u0435\u043B\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    **\u0411\u0435\u0440\u0442 \u041C\u0438\u0445\u0430\u044D\u043B\u044C \u0425\u043E\u043B\u044C\u043C\u0431\u043E\u044D**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0440\u0430\u0437\u0433\u043B\u044F\u0434\u0435\u043B
    \u0432 \u044E\u043D\u043E\u043C \u041D\u0438\u043B\u044C\u0441\u0435 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0430\u043B\u0430\u043D\u0442 \u0438 \u0441\u0442\u0430\u043B \u0435\u0433\u043E
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C. \u0425\u043E\u043B\u044C\u043C\u0431\u043E\u044D
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B \u0410\u0431\u0435\u043B\u044F
    \u0441 \u0442\u0440\u0443\u0434\u0430\u043C\u0438 \u042D\u0439\u043B\u0435\u0440\u0430,
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430, \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430
    \u0438 \u0413\u0430\u0443\u0441\u0441\u0430. *   **1820 \u0433\u043E\u0434**:
    \u0423\u043C\u0438\u0440\u0430\u0435\u0442 \u043E\u0442\u0435\u0446 \u0410\u0431\u0435\u043B\u044F.
    \u0421\u0435\u043C\u044C\u044F \u0441 \u0448\u0435\u0441\u0442\u044C\u044E \u0434\u0435\u0442\u044C\u043C\u0438
    \u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u043D\u0430
    \u0433\u0440\u0430\u043D\u0438 \u043D\u0438\u0449\u0435\u0442\u044B, \u0430 \u0443
    \u0441\u0442\u0430\u0440\u0448\u0435\u0433\u043E \u0431\u0440\u0430\u0442\u0430
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u0434\u0443\u0448\u0435\u0432\u043D\u043E\u0435 \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E.
    \u0412\u0441\u044F \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u043B\u043E\u0436\u0438\u0442\u0441\u044F \u043D\u0430 18-\u043B\u0435\u0442\u043D\u0435\u0433\u043E
    \u041D\u0438\u043B\u044C\u0441\u0430.  ### \U0001F393 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    (1821\u20131824)  *   **1821 \u0433\u043E\u0434**: \u041F\u0440\u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0435
    \u0425\u043E\u043B\u044C\u043C\u0431\u043E\u044D \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438 \u041A\u0440\u0438\u0441\u0442\u043E\u0444\u0435\u0440\u0430
    \u0425\u0430\u043D\u0441\u0442\u0438\u043D\u0430 \u043F\u043E\u0441\u0442\u0443\u043F\u0430\u0435\u0442
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0425\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0438\u0438
    . \u0427\u0442\u043E\u0431\u044B \u043F\u043E\u043C\u043E\u0447\u044C \u0441\u0435\u043C\u044C\u0435,
    \u043E\u043D \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442 \u043F\u043E\u0434\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0442\u044C
    \u0440\u0435\u043F\u0435\u0442\u0438\u0442\u043E\u0440\u0441\u0442\u0432\u043E\u043C.
    *   **1822 \u0433\u043E\u0434**: \u041F\u043E\u043B\u0443\u0447\u0430\u0435\u0442
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \xAB\u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0430
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438\xBB. *   **\u0417\u0438\u043C\u0430
    1822\u20131823**: \u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0443 \u0441\u0432\u043E\u044E
    \u043F\u0435\u0440\u0432\u0443\u044E \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043F\u043E \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u0443\u0435\u043C\u043E\u0441\u0442\u0438
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. \u0420\u0443\u043A\u043E\u043F\u0438\u0441\u044C
    \u0431\u044B\u043B\u0430 \u0443\u0442\u0435\u0440\u044F\u043D\u0430, \u043D\u043E
    \u0437\u0430 \u043D\u0435\u0435 \u0410\u0431\u0435\u043B\u044E \u043D\u0430\u0437\u043D\u0430\u0447\u0438\u043B\u0438
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E. *   **1823 \u0433\u043E\u0434**:
    \u0421\u043E\u0432\u0435\u0440\u0448\u0430\u0435\u0442 \u043F\u043E\u0435\u0437\u0434\u043A\u0443
    \u0432 \u041A\u043E\u043F\u0435\u043D\u0433\u0430\u0433\u0435\u043D, \u0433\u0434\u0435
    \u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0442\u0441\u044F \u0441\u043E \u0441\u0432\u043E\u0435\u0439
    \u0431\u0443\u0434\u0443\u0449\u0435\u0439 \u043D\u0435\u0432\u0435\u0441\u0442\u043E\u0439,
    **\u041A\u0440\u0438\u0441\u0442\u0438\u043D\u043E\u0439 \u041A\u0435\u043C\u043F**
    . \u041F\u0443\u0431\u043B\u0438\u043A\u0443\u0435\u0442 \u0441\u0432\u043E\u0438
    \u043F\u0435\u0440\u0432\u044B\u0435 \u0441\u0442\u0430\u0442\u044C\u0438 \u0432
    \u043D\u043E\u0432\u043E\u043C \u043D\u0430\u0443\u0447\u043D\u043E\u043C \u0436\u0443\u0440\u043D\u0430\u043B\u0435.
    *   **1824 \u0433\u043E\u0434**: \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    21 \u0433\u043E\u0434\u0430 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0434\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442 **\u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u043E \u043D\u0435\u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0441\u0442\u0438
    \u043E\u0431\u0449\u0435\u0433\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u043F\u044F\u0442\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u0432
    \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0430\u0445**. \u0418\u0437\u0434\u0430\u0435\u0442
    \u0441\u0432\u043E\u044E \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0430 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435 \u0437\u0430 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0441\u0447\u0435\u0442, \u0441\u0442\u0440\u0435\u043C\u044F\u0441\u044C \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435. \u0412 \u0442\u043E\u043C
    \u0436\u0435 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442
    \u043E\u0431\u0440\u0443\u0447\u0430\u043B\u044C\u043D\u043E\u0435 \u043A\u043E\u043B\u044C\u0446\u043E
    \u043E\u0442 \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u044B.  ### \u2708\uFE0F
    \u041F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u043F\u043E
    \u0415\u0432\u0440\u043E\u043F\u0435 (1825\u20131827)  *   **\u0421\u0435\u043D\u0442\u044F\u0431\u0440\u044C
    1825 \u2013 \u0444\u0435\u0432\u0440\u0430\u043B\u044C 1826**: \u041F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E, \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0432 \u043F\u043E\u0435\u0437\u0434\u043A\u0443 \u043F\u043E \u0415\u0432\u0440\u043E\u043F\u0435.
    \u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u0435\u0434\u0435\u0442 \u0432 **\u0411\u0435\u0440\u043B\u0438\u043D**,
    \u0433\u0434\u0435 \u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0442\u0441\u044F
    \u0441 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C \u0438 \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u043C
    **\u0410\u0432\u0433\u0443\u0441\u0442\u043E\u043C \u041B\u0435\u043E\u043F\u043E\u043B\u044C\u0434\u043E\u043C
    \u041A\u0440\u0435\u043B\u043B\u0435**. \u042D\u0442\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430
    \u0441\u0442\u0430\u043B\u0430 \u0440\u0435\u0448\u0430\u044E\u0449\u0435\u0439:
    \u041A\u0440\u0435\u043B\u043B\u0435 \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \u0436\u0443\u0440\u043D\u0430\u043B \xABJournal f\xFCr die reine und angewandte
    Mathematik\xBB (\u0436\u0443\u0440\u043D\u0430\u043B \u041A\u0440\u0435\u043B\u043B\u0435),
    \u0432 \u043F\u0435\u0440\u0432\u043E\u043C \u0442\u043E\u043C\u0435 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0431\u044B\u043B\u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u044B
    \u0440\u0430\u0431\u043E\u0442\u044B \u0410\u0431\u0435\u043B\u044F. \u0417\u0434\u0435\u0441\u044C
    \u0436\u0435 \u043E\u043D \u043F\u0443\u0431\u043B\u0438\u043A\u0443\u0435\u0442
    \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u043D\u0443\u044E \u0432\u0435\u0440\u0441\u0438\u044E
    \u0441\u0432\u043E\u0435\u0439 \u0440\u0430\u0431\u043E\u0442\u044B \u043E\u0431
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u0445 \u043F\u044F\u0442\u043E\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438. *   **\u0424\u0435\u0432\u0440\u0430\u043B\u044C
    \u2013 \u0438\u044E\u043B\u044C 1826**: \u041F\u0435\u0440\u0435\u0435\u0437\u0436\u0430\u0435\u0442
    \u0432 **\u0418\u0442\u0430\u043B\u0438\u044E**, \u0433\u0434\u0435 \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u0442
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0435\u0441\u044F\u0446\u0435\u0432
    \u0432 \u0412\u0435\u043D\u0435\u0446\u0438\u0438. *   **\u0418\u044E\u043B\u044C
    \u2013 \u0434\u0435\u043A\u0430\u0431\u0440\u044C 1826**: \u041F\u0440\u0438\u0431\u044B\u0432\u0430\u0435\u0442
    \u0432 **\u041F\u0430\u0440\u0438\u0436**, \u0442\u043E\u0433\u0434\u0430\u0448\u043D\u0438\u0439
    \u0446\u0435\u043D\u0442\u0440 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u044B\u0441\u043B\u0438. \u0417\u043D\u0430\u043A\u043E\u043C\u0438\u0442\u0441\u044F
    \u0441 \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u043E\u043C \u0438 \u041A\u043E\u0448\u0438.
    \u041F\u0438\u0448\u0435\u0442 \u0441\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043C\u0435\u043C\u0443\u0430\u0440 \u043E\u0431 \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u0445, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438 \u0431\u044B\u043B
    \u0443\u0442\u0435\u0440\u044F\u043D \u0438 \u043D\u0430\u0439\u0434\u0435\u043D
    \u0443\u0436\u0435 \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E. \u0420\u0430\u0431\u043E\u0442\u0430
    \u043D\u0435 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430 \u0410\u0431\u0435\u043B\u044E
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F \u0432 \u041F\u0430\u0440\u0438\u0436\u0435,
    \u0438 \u043E\u043D \u043D\u0435 \u0441\u043C\u043E\u0433 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
    \u0442\u0430\u043C \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C.  ###
    \U0001F4C9 \u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0432 \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u044E \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B (1827\u20131829)  *   **\u041D\u0430\u0447\u0430\u043B\u043E
    1827 \u0433\u043E\u0434\u0430**: \u0421\u0440\u0435\u0434\u0441\u0442\u0432\u0430
    \u0437\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u044E\u0442\u0441\u044F,
    \u0410\u0431\u0435\u043B\u044C \u0433\u043E\u043B\u043E\u0434\u0430\u0435\u0442.
    \u041E\u043D \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F
    \u0447\u0435\u0440\u0435\u0437 \u0411\u0435\u0440\u043B\u0438\u043D \u0432 \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u044E.
    *   **1827\u20131828**: \u0416\u0438\u0432\u0435\u0442 \u0432 \u043A\u0440\u0430\u0439\u043D\u0435\u0439
    \u043D\u0438\u0449\u0435\u0442\u0435, \u043F\u043E\u0434\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u044F
    \u0447\u0430\u0441\u0442\u043D\u044B\u043C\u0438 \u0443\u0440\u043E\u043A\u0430\u043C\u0438
    \u0438 \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435\u043C
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0438 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u0435
    . \u0411\u043E\u043B\u044C\u0448\u0430\u044F \u0447\u0430\u0441\u0442\u044C \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0433\u043E
    \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u044C\u044F \u0443\u0445\u043E\u0434\u0438\u0442
    \u043D\u0430 \u0432\u044B\u043F\u043B\u0430\u0442\u0443 \u0434\u043E\u043B\u0433\u043E\u0432
    \u0441\u0435\u043C\u044C\u0438. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u044D\u0442\u043E, \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442
    \u0438\u043D\u0442\u0435\u043D\u0441\u0438\u0432\u043D\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u043D\u0430\u0434 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439. *   **1828 \u0433\u043E\u0434**:
    \u0418\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430
    \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438. *   **\u041E\u0441\u0435\u043D\u044C
    1828 \u0433\u043E\u0434\u0430**: \u0421\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F \u0440\u0435\u0437\u043A\u043E
    \u0443\u0445\u0443\u0434\u0448\u0430\u0435\u0442\u0441\u044F \u0438\u0437-\u0437\u0430
    \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437\u0430. *   **6 \u0430\u043F\u0440\u0435\u043B\u044F
    1829 \u0433\u043E\u0434\u0430**: \u0423\u043C\u0438\u0440\u0430\u0435\u0442 \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 26 \u043B\u0435\u0442 \u0432\u043E
    \u0424\u0440\u043E\u043B\u0430\u043D\u0434\u0435, \u0431\u043B\u0438\u0437 \u0410\u0440\u0435\u043D\u0434\u0430\u043B\u0430. 
    \u041F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435 \u043D\u0430
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u0432 \u0411\u0435\u0440\u043B\u0438\u043D, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u041A\u0440\u0435\u043B\u043B\u0435 \u0434\u043E\u0431\u0438\u0432\u0430\u043B\u0441\u044F
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E, \u043F\u0440\u0438\u0448\u043B\u043E
    \u0432 \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u044E \u0447\u0435\u0440\u0435\u0437
    \u0434\u0432\u0430 \u0434\u043D\u044F \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0410\u0431\u0435\u043B\u044F.  ### \U0001F3C6 \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    *   \u0412 1839 \u0433\u043E\u0434\u0443 \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u0425\u043E\u043B\u044C\u043C\u0431\u043E\u044D \u0438\u0437\u0434\u0430\u043B
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0435 \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439
    \u0410\u0431\u0435\u043B\u044F. *   \u0412 2002 \u0433\u043E\u0434\u0443, \u043A
    200-\u043B\u0435\u0442\u0438\u044E \u0441\u043E \u0434\u043D\u044F \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0410\u0431\u0435\u043B\u044F, \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438 \u0443\u0447\u0440\u0435\u0434\u0438\u043B\u043E
    **\u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E**
    \u2014 \u043E\u0434\u043D\u0443 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0441\u0432\u043E\u0435\u0433\u043E
    \u0440\u043E\u0434\u0430 \xAB\u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E\xBB \u0434\u043B\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.
    *   \u041F\u0430\u043C\u044F\u0442\u043D\u0438\u043A \u0410\u0431\u0435\u043B\u044E
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D \u0432 \u041E\u0441\u043B\u043E
    . \u0415\u0433\u043E \u043F\u043E\u0440\u0442\u0440\u0435\u0442 \u043F\u043E\u043C\u0435\u0449\u0430\u043B\u0441\u044F
    \u043D\u0430 \u0431\u0430\u043D\u043A\u043D\u043E\u0442\u0435 \u0432 500 \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u0438\u0445
    \u043A\u0440\u043E\u043D. *   \u0415\u0433\u043E \u0438\u043C\u0435\u043D\u0435\u043C
    \u043D\u0430\u0437\u0432\u0430\u043D\u044B \u043C\u043D\u043E\u0433\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0431\u044A\u0435\u043A\u0442\u044B: **\u0430\u0431\u0435\u043B\u0435\u0432\u0430
    \u0433\u0440\u0443\u043F\u043F\u0430**, **\u0430\u0431\u0435\u043B\u0435\u0432\u044B
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044B**, **\u0430\u0431\u0435\u043B\u0435\u0432\u043E
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0435**, **\u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0410\u0431\u0435\u043B\u044F \u2014 \u0420\u0443\u0444\u0444\u0438\u043D\u0438**
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0435."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u041D\u0438\u043B\u044C\u0441\u0430
    \u0425\u0435\u043D\u0440\u0438\u043A\u0430 \u0410\u0431\u0435\u043B\u044F, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0441\u0432\u043E\u044E \u043A\u043E\u0440\u043E\u0442\u043A\u0443\u044E
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C,
    \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u0441\u043E\u0431\u044B\u0442\u0438\u044F\u043C\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u044E\u0442
    \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0442\u0440\u0430\u0433\u0438\u0437\u043C \u0435\u0433\u043E \u0441\u0443\u0434\u044C\u0431\u044B.
    \u0412\u043E\u0442 \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438,
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0435
    \u0432 \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043F\u043E\u0440\u044F\u0434\u043A\u0435:  ### \U0001F4DC 1815\u20131820: \u041F\u0443\u0442\u044C
    \u0432 \u043D\u0430\u0443\u043A\u0443, \u043D\u0430\u0447\u0430\u0442\u044B\u0439
    \u043F\u043E \u043E\u0448\u0438\u0431\u043A\u0435  *   **\u041D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0439
    \u0432\u044B\u0431\u043E\u0440 \u0448\u043A\u043E\u043B\u044B**: \u0412 1815
    \u0433\u043E\u0434\u0443 13-\u043B\u0435\u0442\u043D\u0438\u0439 \u041D\u0438\u043B\u044C\u0441
    \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u043B \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C\u0441\u044F
    \u0432 \u043A\u0430\u0444\u0435\u0434\u0440\u0430\u043B\u044C\u043D\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 \u0432 \u0425\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0438\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0435\u0433\u043E \u0441\u0442\u0430\u0440\u0448\u0438\u0439
    \u0431\u0440\u0430\u0442 \u0425\u0430\u043D\u0441 \u041C\u0430\u0442\u0438\u0430\u0441
    \u0442\u0430\u043A \u0442\u044F\u0436\u0435\u043B\u043E \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u043B
    \u043F\u0440\u0435\u0434\u0441\u0442\u043E\u044F\u0449\u0443\u044E \u0440\u0430\u0437\u043B\u0443\u043A\u0443
    \u0441 \u0434\u043E\u043C\u043E\u043C, \u0447\u0442\u043E \u043E\u0442\u0435\u0446
    \u0440\u0435\u0448\u0438\u043B \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C
    \u0432\u043C\u0435\u0441\u0442\u043E \u043D\u0435\u0433\u043E \u041D\u0438\u043B\u044C\u0441\u0430.
    \u0422\u0430\u043A \u043D\u0430\u0447\u0430\u043B\u0441\u044F \u0435\u0433\u043E
    \u043F\u0443\u0442\u044C \u0432 \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u043C\u0438\u0440.
    *   **\u041F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044F**:
    \u0412 1819 \u0433\u043E\u0434\u0443 \u0435\u0433\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0411\u0435\u0440\u0442
    \u041C\u0438\u0445\u0430\u044D\u043B\u044C \u0425\u043E\u043B\u044C\u043C\u0431\u043E\u044D
    \u043F\u0438\u0441\u0430\u043B: *\xAB\u0421 \u043F\u0440\u0435\u0432\u043E\u0441\u0445\u043E\u0434\u043D\u0435\u0439\u0448\u0438\u043C
    \u0433\u0435\u043D\u0438\u0435\u043C \u043E\u043D \u0441\u043E\u0447\u0435\u0442\u0430\u0435\u0442
    \u043D\u0435\u043D\u0430\u0441\u044B\u0442\u043D\u044B\u0439 \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u0438 \u0442\u044F\u0433\u043E\u0442\u0435\u043D\u0438\u0435 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443, \u0435\u0441\u043B\u0438 \u043E\u043D
    \u0431\u0443\u0434\u0435\u0442 \u0436\u0438\u0442\u044C, \u043E\u043D, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u0441\u0442\u0430\u043D\u0435\u0442 \u0432\u0435\u043B\u0438\u043A\u0438\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C\xBB*. \u042D\u0442\u043E
    \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u043E \u0441\u0431\u044B\u043B\u043E\u0441\u044C,
    \u043D\u043E \u043E\u0433\u043E\u0432\u043E\u0440\u043A\u0430 \xAB\u0435\u0441\u043B\u0438
    \u043E\u043D \u0431\u0443\u0434\u0435\u0442 \u0436\u0438\u0442\u044C\xBB \u0441\u0442\u0430\u043B\u0430
    \u0440\u043E\u043A\u043E\u0432\u043E\u0439. *   **\u0411\u0440\u0435\u043C\u044F
    \u0433\u043B\u0430\u0432\u044B \u0441\u0435\u043C\u044C\u0438**: \u0412 1820
    \u0433\u043E\u0434\u0443 \u0443\u043C\u0438\u0440\u0430\u0435\u0442 \u043E\u0442\u0435\u0446
    \u0410\u0431\u0435\u043B\u044F, \u043E\u0441\u0442\u0430\u0432\u0438\u0432 \u0441\u0435\u043C\u044C\u044E
    \u0438\u0437 \u0448\u0435\u0441\u0442\u0438 \u0434\u0435\u0442\u0435\u0439 \u043D\u0430
    \u0433\u0440\u0430\u043D\u0438 \u043D\u0438\u0449\u0435\u0442\u044B. \u0412\u0434\u043E\u0431\u0430\u0432\u043E\u043A
    \u0443 \u0441\u0442\u0430\u0440\u0448\u0435\u0433\u043E \u0431\u0440\u0430\u0442\u0430
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u0434\u0443\u0448\u0435\u0432\u043D\u043E\u0435 \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E.
    \u0412\u0441\u044F \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0437\u0430 \u0441\u0435\u043C\u044C\u044E \u043B\u043E\u0436\u0438\u0442\u0441\u044F
    \u043D\u0430 18-\u043B\u0435\u0442\u043D\u0435\u0433\u043E \u041D\u0438\u043B\u044C\u0441\u0430. 
    ### \U0001F393 1821\u20131824: \u041F\u0435\u0440\u0432\u044B\u0439 \u043F\u0440\u043E\u0440\u044B\u0432
    \u0438 \u043B\u0438\u0447\u043D\u043E\u0435 \u0441\u0447\u0430\u0441\u0442\u044C\u0435 
    *   **\u0421\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044F \u043E\u0442 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u0432**:
    \u041F\u043E\u0441\u0442\u0443\u043F\u0438\u0432 \u0432 1821 \u0433\u043E\u0434\u0443
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0425\u0440\u0438\u0441\u0442\u0438\u0430\u043D\u0438\u0438,
    \u0410\u0431\u0435\u043B\u044C \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0431\u0435\u0434\u0435\u043D, \u0447\u0442\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430,
    \u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0432\u0448\u0438\u0441\u044C
    \u0441 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u043C\u0438, \u0441\u043B\u043E\u0436\u0438\u043B\u0438\u0441\u044C
    \u0438 \u0441\u0442\u0430\u043B\u0438 \u0432\u044B\u043F\u043B\u0430\u0447\u0438\u0432\u0430\u0442\u044C
    \u0435\u043C\u0443 \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E \u0438\u0437
    **\u043B\u0438\u0447\u043D\u044B\u0445 \u0441\u0440\u0435\u0434\u0441\u0442\u0432**,
    \xAB\u0434\u0430\u0431\u044B \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C
    \u0434\u043B\u044F \u043D\u0430\u0443\u043A\u0438 \u044D\u0442\u043E \u0440\u0435\u0434\u043A\u043E\u0435
    \u0434\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u0435\xBB. *   **\u042D\u043A\u043E\u043D\u043E\u043C\u0438\u044F
    \u043D\u0430 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435**:
    \u0421\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u043E \u043D\u0435\u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0441\u0442\u0438
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u043F\u044F\u0442\u043E\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u0432 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0430\u0445
    \u0410\u0431\u0435\u043B\u044C \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0432 1824 \u0433\u043E\u0434\u0443 \u0432 \u0432\u0438\u0434\u0435 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u0431\u0440\u043E\u0448\u044E\u0440\u044B \u043D\u0430 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435. \u0427\u0442\u043E\u0431\u044B \u0441\u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0442\u044C
    \u043D\u0430 \u043F\u0435\u0447\u0430\u0442\u0438, \u043E\u043D \u0441\u043E\u043A\u0440\u0430\u0442\u0438\u043B
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0434\u043E \u0448\u0435\u0441\u0442\u0438 \u0441\u0442\u0440\u0430\u043D\u0438\u0446,
    \u0438\u0437-\u0437\u0430 \u0447\u0435\u0433\u043E \u043E\u043D\u043E \u0441\u0442\u0430\u043B\u043E
    \u043E\u0447\u0435\u043D\u044C \u0442\u0440\u0443\u0434\u043D\u044B\u043C \u0434\u043B\u044F
    \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F. *   **\u0414\u0430\u0442\u0441\u043A\u0438\u0439
    \u0441\u043E\u0432\u0435\u0442**: \u0415\u0433\u043E \u043F\u0435\u0440\u0432\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043E\u0431 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u0445
    \u043F\u044F\u0442\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0438
    \u043D\u0430 \u0440\u0435\u0446\u0435\u043D\u0437\u0438\u044E \u0434\u0430\u0442\u0441\u043A\u043E\u043C\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0424\u0435\u0440\u0434\u0438\u043D\u0430\u043D\u0434\u0443
    \u0414\u0435\u0433\u0435\u043D\u0443. \u0422\u043E\u0442 \u043D\u0435 \u043D\u0430\u0448\u0435\u043B
    \u043E\u0448\u0438\u0431\u043E\u043A, \u043D\u043E \u0443\u0441\u043E\u043C\u043D\u0438\u043B\u0441\u044F,
    \u0447\u0442\u043E \u0441\u0442\u043E\u043B\u044C \u0441\u043B\u043E\u0436\u043D\u0443\u044E
    \u0437\u0430\u0434\u0430\u0447\u0443 \u0440\u0435\u0448\u0438\u043B \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442 \u0438\u0437 \u0434\u0430\u043B\u0435\u043A\u043E\u0439
    \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438. \u0414\u0435\u0433\u0435\u043D
    \u043F\u043E\u0441\u043E\u0432\u0435\u0442\u043E\u0432\u0430\u043B \u0410\u0431\u0435\u043B\u044E
    \u0437\u0430\u043D\u044F\u0442\u044C\u0441\u044F \u0431\u043E\u043B\u0435\u0435
    \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C\u044E \u2014 \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C\u0438. \u042D\u0442\u043E\u0442
    \u0441\u043E\u0432\u0435\u0442 \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u043A\u0438\u043C. *   **\u041F\u043E\u043C\u043E\u043B\u0432\u043A\u0430
    \u0441 \u0442\u0430\u043A\u043E\u0439 \u0436\u0435 \u0431\u0435\u0434\u043D\u043E\u0439
    \u043D\u0435\u0432\u0435\u0441\u0442\u043E\u0439**: \u0412\u043E \u0432\u0440\u0435\u043C\u044F
    \u043F\u043E\u0435\u0437\u0434\u043A\u0438 \u0432 \u041A\u043E\u043F\u0435\u043D\u0433\u0430\u0433\u0435\u043D
    \u0432 1823 \u0433\u043E\u0434\u0443 \u0410\u0431\u0435\u043B\u044C \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B
    \u0441\u0432\u043E\u044E \u043B\u044E\u0431\u043E\u0432\u044C \u2014 \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0443
    \u041A\u0435\u043C\u043F. \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430 \u0431\u044B\u043B\u0430
    \u0442\u0430\u043A \u0436\u0435 \u0431\u0435\u0434\u043D\u0430, \u043A\u0430\u043A
    \u0438 \u043E\u043D, \u0438 \u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043B\u0430
    \u043D\u0430 \u0436\u0438\u0437\u043D\u044C \u0440\u0435\u043F\u0435\u0442\u0438\u0442\u043E\u0440\u0441\u0442\u0432\u043E\u043C.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043D\u0438\u0449\u0435\u0442\u0443,
    \u0432 1824 \u0433\u043E\u0434\u0443 \u043E\u043D\u0438 \u043E\u0431\u0440\u0443\u0447\u0438\u043B\u0438\u0441\u044C. 
    ### \u2708\uFE0F 1825\u20131827: \u0415\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0435
    \u0442\u0443\u0440\u043D\u0435, \u043F\u043E\u043B\u043D\u043E\u0435 \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u0439 
    *   **\u041F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u0435 \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u0436\u0443\u0440\u043D\u0430\u043B\u0430**: \u0412 1825 \u0433\u043E\u0434\u0443
    \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0435 \u0410\u0431\u0435\u043B\u044C
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F \u0441
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C-\u043B\u044E\u0431\u0438\u0442\u0435\u043B\u0435\u043C
    \u0410\u0432\u0433\u0443\u0441\u0442\u043E\u043C \u041A\u0440\u0435\u043B\u043B\u0435,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043A\u0430\u043A \u0440\u0430\u0437
    \u0441\u043E\u0431\u0438\u0440\u0430\u043B\u0441\u044F \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u044C
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0436\u0443\u0440\u043D\u0430\u043B. \u0410\u0431\u0435\u043B\u044C \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u044B\u0445 \u0430\u0432\u0442\u043E\u0440\u043E\u0432,
    \u043D\u043E \u0438 \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \xAB\u0432\u0434\u043E\u0445\u043D\u0443\u043B \u0436\u0438\u0437\u043D\u044C\xBB
    \u0432 \u044D\u0442\u043E \u0438\u0437\u0434\u0430\u043D\u0438\u0435, \u043D\u0430\u043F\u0435\u0447\u0430\u0442\u0430\u0432
    \u0432 \u043D\u0435\u043C 7 \u0441\u0432\u043E\u0438\u0445 \u0440\u0430\u0431\u043E\u0442.
    \u0416\u0443\u0440\u043D\u0430\u043B \u041A\u0440\u0435\u043B\u043B\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0438 \u043F\u043E\u043D\u044B\u043D\u0435. *   **\u0420\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435**: \u0412 1826 \u0433\u043E\u0434\u0443
    \u0410\u0431\u0435\u043B\u044C \u043F\u0440\u0438\u0435\u0445\u0430\u043B \u0432
    \u041F\u0430\u0440\u0438\u0436 \u2014 \u0446\u0435\u043D\u0442\u0440 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430. \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0441\u0432\u043E\u0439 \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u043C\u0435\u043C\u0443\u0430\u0440
    \u043E\u0431 \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u0445
    \u0438 \u043F\u0435\u0440\u0435\u0434\u0430\u043B \u0435\u0433\u043E \u043D\u0430
    \u0440\u0435\u0446\u0435\u043D\u0437\u0438\u044E \u041E\u0433\u044E\u0441\u0442\u0435\u043D\u0443
    \u041A\u043E\u0448\u0438. \u041E\u0434\u043D\u0430\u043A\u043E \u041A\u043E\u0448\u0438,
    \u0437\u0430\u043D\u044F\u0442\u044B\u0439 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    \u0434\u0435\u043B\u0430\u043C\u0438, \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C. \u0410\u0431\u0435\u043B\u044C,
    \u043E\u0441\u043A\u043E\u0440\u0431\u043B\u0435\u043D\u043D\u044B\u0439 \u0438
    \u0440\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439,
    \u0443\u0435\u0445\u0430\u043B \u0438\u0437 \u041F\u0430\u0440\u0438\u0436\u0430
    \u043D\u0438 \u0441 \u0447\u0435\u043C. \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u0431\u044B\u043B \u043D\u0430\u0439\u0434\u0435\u043D
    \u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D \u043B\u0438\u0448\u044C
    \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E.  ### \u23F3 1827\u20131829:
    \u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0432 \u043D\u0438\u0449\u0435\u0442\u0443
    \u0438 \u0437\u0430\u043F\u043E\u0437\u0434\u0430\u043B\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    *   **\u0411\u043E\u0440\u044C\u0431\u0430 \u0437\u0430 \u0432\u044B\u0436\u0438\u0432\u0430\u043D\u0438\u0435**:
    \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C \u0432 \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u044E
    \u0432 1827 \u0433\u043E\u0434\u0443, \u0410\u0431\u0435\u043B\u044C \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0432 \u043E\u0442\u0447\u0430\u044F\u043D\u043D\u043E\u043C \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0438:
    \u043E\u043D \u0433\u043E\u043B\u043E\u0434\u0430\u043B, \u043F\u043E\u0434\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043B
    \u0447\u0430\u0441\u0442\u043D\u044B\u043C\u0438 \u0443\u0440\u043E\u043A\u0430\u043C\u0438,
    \u0430 \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u0447\u0430\u0441\u0442\u044C
    \u0441\u0432\u043E\u0435\u0433\u043E \u0441\u043A\u0443\u0434\u043D\u043E\u0433\u043E
    \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u044C\u044F \u043E\u0442\u0434\u0430\u0432\u0430\u043B
    \u043D\u0430 \u0432\u044B\u043F\u043B\u0430\u0442\u0443 \u0434\u043E\u043B\u0433\u043E\u0432
    \u0441\u0435\u043C\u044C\u0438. *   **\u041F\u043E\u043C\u043E\u0449\u044C \u043E\u0442
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0445 \u043A\u043E\u043B\u043B\u0435\u0433**:
    \u0422\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E,
    \u043A\u0430\u043A \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B\u0438 \u043F\u0438\u0441\u044C\u043C\u043E
    \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u043E\u043C\u0443 \u043A\u043E\u0440\u043E\u043B\u044E
    \u0441 \u043F\u0440\u043E\u0441\u044C\u0431\u043E\u0439 \u043F\u043E\u043C\u043E\u0447\u044C
    \u0433\u0435\u043D\u0438\u044E, \u0410\u0431\u0435\u043B\u044F \u0432\u0437\u044F\u043B\u0438
    \u043D\u0430 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044F
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0438 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u0435.
    *   **\u041F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435, \u043E\u043F\u043E\u0437\u0434\u0430\u0432\u0448\u0435\u0435
    \u043D\u0430 \u0434\u0432\u0430 \u0434\u043D\u044F**: \u0414\u0440\u0443\u0433
    \u0438 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A \u0410\u0431\u0435\u043B\u044F,
    \u0410\u0432\u0433\u0443\u0441\u0442 \u041A\u0440\u0435\u043B\u043B\u0435, \u0441\u0443\u043C\u0435\u043B
    \u0434\u043E\u0431\u0438\u0442\u044C\u0441\u044F \u0434\u043B\u044F \u043D\u0435\u0433\u043E
    \u043C\u0435\u0441\u0442\u0430 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435.
    \u041F\u0438\u0441\u044C\u043C\u043E \u0441 \u044D\u0442\u0438\u043C \u0440\u0430\u0434\u043E\u0441\u0442\u043D\u044B\u043C
    \u0438\u0437\u0432\u0435\u0441\u0442\u0438\u0435\u043C \u043F\u0440\u0438\u0448\u043B\u043E
    \u0432 \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u044E **\u0447\u0435\u0440\u0435\u0437
    \u0434\u0432\u0430 \u0434\u043D\u044F \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438**
    \u0410\u0431\u0435\u043B\u044F, 8 \u0430\u043F\u0440\u0435\u043B\u044F 1829 \u0433\u043E\u0434\u0430.
    \u041E\u043D \u0443\u043C\u0435\u0440 6 \u0430\u043F\u0440\u0435\u043B\u044F
    \u043E\u0442 \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437\u0430
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 26 \u043B\u0435\u0442.
    *   **\u041F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u0430\u044F \u0441\u043B\u0430\u0432\u0430**:
    \u0412 1830 \u0433\u043E\u0434\u0443, \u0443\u0436\u0435 \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E,
    \u0410\u0431\u0435\u043B\u044C \u0438 \u041A\u0430\u0440\u043B \u0413\u0443\u0441\u0442\u0430\u0432
    \u042F\u043A\u043E\u0431\u0438 \u0431\u044B\u043B\u0438 \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D\u044B
    \u0411\u043E\u043B\u044C\u0448\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u0437\u0430 \u0438\u0445 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043F\u043E \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C.  ### \U0001F3C6 \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    *   \u0415\u0433\u043E \u043F\u043E\u0440\u0442\u0440\u0435\u0442 \u0431\u044B\u043B
    \u043F\u043E\u043C\u0435\u0449\u0435\u043D \u043D\u0430 \u0431\u0430\u043D\u043A\u043D\u043E\u0442\u0443
    \u0432 500 \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u0438\u0445 \u043A\u0440\u043E\u043D
    (\u0432 1978\u20132002 \u0433\u043E\u0434\u0430\u0445). *   \u0412 \u0435\u0433\u043E
    \u0447\u0435\u0441\u0442\u044C \u043D\u0430\u0437\u0432\u0430\u043D \u043A\u0440\u0430\u0442\u0435\u0440
    \u043D\u0430 \u041B\u0443\u043D\u0435. *   \u0412 2002 \u0433\u043E\u0434\u0443
    \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438 \u0443\u0447\u0440\u0435\u0434\u0438\u043B\u043E
    **\u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E**
    \u2014 \u043E\u0434\u043D\u0443 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434 \u0432 \u043C\u0438\u0440\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0447\u0430\u0441\u0442\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u0430\u043D\u0430\u043B\u043E\u0433\u043E\u043C \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438 \u0434\u043B\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.
    *   \u0428\u0430\u0440\u043B\u044C \u042D\u0440\u043C\u0438\u0442 \u0441\u043A\u0430\u0437\u0430\u043B
    \u043E\u0431 \u0410\u0431\u0435\u043B\u0435: *\xAB\u041E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C \u0441\u0442\u043E\u043B\u044C
    \u0431\u043E\u0433\u0430\u0442\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435,
    \u0447\u0442\u043E \u0438\u043C \u0431\u0443\u0434\u0435\u0442 \u0447\u0435\u043C
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F \u0432 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0438\u0435
    500 \u043B\u0435\u0442\xBB*."
