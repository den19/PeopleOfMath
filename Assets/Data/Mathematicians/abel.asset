    \u043D\u0430\u0443\u043A\u0435 \u043E\u0433\u0440\u043E\u043C\u043D\u0443\u044E
    \u043F\u043E\u043B\u044C\u0437\u0443.  ### \U0001F1EB\U0001F1F7 1826: \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0439
    \u043C\u0435\u043C\u0443\u0430\u0440 \u0438 \u0443\u0442\u0435\u0440\u044F\u043D\u043D\u044B\u0439
    \u0448\u0435\u0434\u0435\u0432\u0440 \u041B\u0435\u0442\u043E\u043C 1826 \u0433\u043E\u0434\u0430
    \u0410\u0431\u0435\u043B\u044C \u043F\u0440\u0438\u0431\u044B\u043B \u0432 \u041F\u0430\u0440\u0438\u0436
    \u2014 \u0446\u0435\u043D\u0442\u0440 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u0438\u0440\u0430 \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    \u041E\u043D \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u043E\u043C \u0438 \u041A\u043E\u0448\u0438
    \u0438 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u043B \u0441\u0432\u043E\u0439
    \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434 \u2014 \u043C\u0435\u043C\u0443\u0430\u0440
    \u043E \u0442\u0440\u0430\u043D\u0441\u0446\u0435\u043D\u0434\u0435\u043D\u0442\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u0445, \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0438\u0439
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **\u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u0410\u0431\u0435\u043B\u044F** \u043E\u0431 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430\u0445
    \u043E\u0442 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C, \u043F\u043E\u0434\u0430\u043D\u043D\u0430\u044F
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0443\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E
    \u043D\u0430\u0443\u043A, \u0431\u044B\u043B\u0430 \u0443\u0442\u0435\u0440\u044F\u043D\u0430
    \u0441\u0430\u043C\u0438\u043C \u041A\u043E\u0448\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u0442\u043B\u043E\u0436\u0438\u043B \u0435\u0435 \u0432 \u0441\u0442\u043E\u0440\u043E\u043D\u0443.
    \u0420\u0430\u0431\u043E\u0442\u0430 \u0431\u044B\u043B\u0430 \u043D\u0430\u0439\u0434\u0435\u043D\u0430
