  achievementsRu: "\u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u041D\u0438\u043B\u044C\u0441\u0430
    \u0425\u0435\u043D\u0440\u0438\u043A\u0430 \u0410\u0431\u0435\u043B\u044F \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442
    \u0442\u0440\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438. \u0412\u043E-\u043F\u0435\u0440\u0432\u044B\u0445,
    \u044D\u0442\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B,
    \u043E\u0441\u0442\u0430\u0432\u0430\u0432\u0448\u0435\u0439\u0441\u044F \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0439
    \u0431\u043E\u043B\u0435\u0435 250 \u043B\u0435\u0442: \u043E\u043D \u0434\u0430\u043B
    \u043F\u0435\u0440\u0432\u043E\u0435 \u043F\u043E\u043B\u043D\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u043E\u0431\u0449\u0435\u0433\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u043F\u044F\u0442\u043E\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438 (\u0438 \u0432\u044B\u0448\u0435)
    \u0432 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0430\u0445, \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0443\u0432
    \u044D\u0442\u0438\u043C \u043C\u043D\u043E\u0433\u043E\u0432\u0435\u043A\u043E\u0432\u044B\u0435
    \u043F\u043E\u0438\u0441\u043A\u0438 \u043E\u0431\u0449\u0435\u0439 \u0444\u043E\u0440\u043C\u0443\u043B\u044B.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u0432 \u044D\u0442\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0441\u0442\u0430\u043B\u0430 \u043E\u0441\u043D\u043E\u0432\u043E\u0439
    \u0434\u043B\u044F \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0443\u043F\u043F
    \u0438 \u043D\u0435\u043F\u043E\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0430 \u043D\u0430 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0413\u0430\u043B\u0443\u0430. \u0412\u043E-\u0432\u0442\u043E\u0440\u044B\u0445,
    \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0440\u043E\u0440\u044B\u0432
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439, \u043F\u0435\u0440\u0432\u044B\u043C
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0432 \u0438\u0445 \u043A\u0430\u043A
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438, \u043E\u0431\u0440\u0430\u0442\u043D\u044B\u0435
    \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430\u043C, \u0438 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0438\u0432
    \u0438\u0445 \u043D\u0430 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u0443\u044E
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C; \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \u043E\u0431 \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u0430\u0445, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u0430\u043A \xAB\u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0439
    \u043C\u0435\u043C\u0443\u0430\u0440\xBB, \u0431\u044B\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u043D
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C
    \u0438 \u0438\u0437\u0434\u0430\u043D \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u043E.
    \u0412-\u0442\u0440\u0435\u0442\u044C\u0438\u0445, \u043E\u043D \u0432\u043D\u0451\u0441
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437, \u0441\u0442\u0440\u043E\u0433\u043E \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u0432
    \u0442\u0435\u043E\u0440\u0438\u044E \u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u0438
    \u0440\u044F\u0434\u043E\u0432 \u0438 \u0443\u043A\u0430\u0437\u0430\u0432 \u043D\u0430
    \u043E\u0448\u0438\u0431\u043A\u0438 \u0432 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    \u041A\u043E\u0448\u0438, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0441\u0442\u0430\u0432
    \u043F\u0438\u043E\u043D\u0435\u0440\u043E\u043C \u0432 \u0440\u0435\u0448\u0435\u043D\u0438\u0438
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u041D\u0438\u043B\u044C\u0441\u0430 \u0425\u0435\u043D\u0440\u0438\u043A\u0430
    \u0410\u0431\u0435\u043B\u044F \u0431\u044B\u043B\u0430 \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u0430
    \u0431\u0435\u0434\u043D\u043E\u0441\u0442\u044C\u044E \u0438 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439,
    \u043D\u043E \u0432 \u043D\u0435\u0439 \u043D\u0430\u0448\u043B\u043E\u0441\u044C
    \u043C\u0435\u0441\u0442\u043E \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439
    \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u0438.
    \u041E\u043D \u0432\u044B\u0440\u043E\u0441 \u0432 \u0441\u043B\u043E\u0436\u043D\u043E\u0439
    \u0441\u0435\u043C\u044C\u0435: \u0435\u0433\u043E \u043E\u0442\u0435\u0446,
    \u043F\u0430\u0441\u0442\u043E\u0440, \u0441\u0442\u0440\u0430\u0434\u0430\u043B
    \u043E\u0442 \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u0438\u0437\u043C\u0430,
    \u0430 \u043C\u0430\u0442\u044C, \u043F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C,
    \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B\u0430 \u0441\u043A\u043B\u043E\u043D\u043D\u0430
    \u043A \u043F\u044C\u044F\u043D\u0441\u0442\u0432\u0443, \u0438 \u0438\u0445
    \u0431\u0440\u0430\u043A \u0441\u043E\u043F\u0440\u043E\u0432\u043E\u0436\u0434\u0430\u043B\u0441\u044F
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u044B\u043C\u0438 \u0440\u0430\u0437\u0434\u043E\u0440\u0430\u043C\u0438.
    \u0412 1820 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u0410\u0431\u0435\u043B\u044E
    \u0431\u044B\u043B\u043E 18 \u043B\u0435\u0442, \u043E\u0442\u0435\u0446 \u0443\u043C\u0435\u0440,
    \u043E\u0441\u0442\u0430\u0432\u0438\u0432 \u0441\u0435\u043C\u044C\u044E \u0438\u0437
    \u0441\u0435\u043C\u0435\u0440\u044B\u0445 \u0434\u0435\u0442\u0435\u0439 \u043D\u0430
    \u0433\u0440\u0430\u043D\u0438 \u043D\u0438\u0449\u0435\u0442\u044B, \u0438 \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0437\u0430 \u0431\u043B\u0438\u0437\u043A\u0438\u0445, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0431\u0440\u0430\u0442\u0430 \u0441 \u0434\u0443\u0448\u0435\u0432\u043D\u044B\u043C
    \u0440\u0430\u0441\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u043E\u043C,
    \u043B\u0435\u0433\u043B\u0430 \u043D\u0430 \u0435\u0433\u043E \u043F\u043B\u0435\u0447\u0438.
    \u0412 1823 \u0433\u043E\u0434\u0443, \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u043F\u043E\u0435\u0437\u0434\u043A\u0438 \u0432 \u041A\u043E\u043F\u0435\u043D\u0433\u0430\u0433\u0435\u043D,
    \u0410\u0431\u0435\u043B\u044C \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B
    \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0443 (\u041A\u0440\u0435\u043B\u043B\u0438)
    \u041A\u0435\u043C\u043F, \u0431\u0435\u0434\u043D\u0443\u044E \u0434\u0435\u0432\u0443\u0448\u043A\u0443,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F, \u043A\u0430\u043A \u0438 \u043E\u043D,
    \u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043B\u0430 \u0440\u0435\u043F\u0435\u0442\u0438\u0442\u043E\u0440\u0441\u0442\u0432\u043E\u043C.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0441\u0442\u0435\u0441\u043D\u0435\u043D\u043D\u044B\u0435
    \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430,
    \u043E\u043D\u0438 \u043E\u0431\u0440\u0443\u0447\u0438\u043B\u0438\u0441\u044C
    \u043D\u0430 \u0420\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u043E 1824 \u0433\u043E\u0434\u0430
    \u0438 \u0441\u0442\u0440\u043E\u0438\u043B\u0438 \u043F\u043B\u0430\u043D\u044B
    \u043D\u0430 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0443\u044E \u0436\u0438\u0437\u043D\u044C,
    \u043E\u0434\u043D\u0430\u043A\u043E \u0438\u043C \u0442\u0430\u043A \u0438 \u043D\u0435
    \u0441\u0443\u0436\u0434\u0435\u043D\u043E \u0431\u044B\u043B\u043E \u043F\u043E\u0436\u0435\u043D\u0438\u0442\u044C\u0441\u044F.
    \u041C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B
    \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u0438 \u0410\u0431\u0435\u043B\u044F
    \u0434\u043E \u043A\u043E\u043D\u0446\u0430: \u043E\u043D \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E
    \u0431\u0435\u0434\u0441\u0442\u0432\u043E\u0432\u0430\u043B, \u043F\u043E\u0434\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043B
    \u0447\u0430\u0441\u0442\u043D\u044B\u043C\u0438 \u0443\u0440\u043E\u043A\u0430\u043C\u0438,
    \u0430 \u0431\xF3\u043B\u044C\u0448\u0430\u044F \u0447\u0430\u0441\u0442\u044C
    \u0435\u0433\u043E \u0441\u043A\u0443\u0434\u043D\u043E\u0433\u043E \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u044C\u044F
    \u0443\u0445\u043E\u0434\u0438\u043B\u0430 \u043D\u0430 \u043F\u043E\u043A\u0440\u044B\u0442\u0438\u0435
    \u0434\u043E\u043B\u0433\u043E\u0432 \u0441\u0435\u043C\u044C\u0438. \u041E\u0441\u043B\u0430\u0431\u043B\u0435\u043D\u043D\u044B\u0439
    \u043D\u0443\u0436\u0434\u043E\u0439, \u043E\u043D \u0437\u0430\u0440\u0430\u0437\u0438\u043B\u0441\u044F
    \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437\u043E\u043C \u0438
    \u0443\u043C\u0435\u0440 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    26 \u043B\u0435\u0442, \u0442\u0430\u043A \u0438 \u043D\u0435 \u0434\u043E\u0436\u0434\u0430\u0432\u0448\u0438\u0441\u044C
    \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u044F \u043D\u0430
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043F\u0440\u0438\u0448\u043B\u043E \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0430
    \u0434\u043D\u044F \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438."
  personalLifeEn: 
  shortBioRu: "\u041D\u0438\u043B\u044C\u0441 \u0425\u0435\u043D\u0440\u0438\u043A
    \u0410\u0431\u0435\u043B\u044C (1802\u20131829) \u2014 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F
    \u043D\u043E\u0440\u0432\u0435\u0436\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043A\u0440\u0430\u0439\u043D\u044E\u044E \u0431\u0435\u0434\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0442\u044F\u0436\u0435\u043B\u0443\u044E \u0431\u043E\u043B\u0435\u0437\u043D\u044C,
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0440\u043E\u0440\u044B\u0432
    \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445
    \u043D\u0430\u0443\u043A\u0438. \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u2014 \u043F\u0435\u0440\u0432\u043E\u0435
    \u043F\u043E\u043B\u043D\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u043E\u0431\u0449\u0435\u0433\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u043F\u044F\u0442\u043E\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u0432 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0430\u0445,
    \u0447\u0442\u043E \u0437\u0430\u043A\u0440\u044B\u043B\u043E \u0432\u043E\u043F\u0440\u043E\u0441,
    \u043E\u0441\u0442\u0430\u0432\u0430\u0432\u0448\u0438\u0439\u0441\u044F \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u043C
    \u0431\u043E\u043B\u0435\u0435 250 \u043B\u0435\u0442. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0442\u0435\u043E\u0440\u0438\u0438 \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u043C\u0435\u043C\u0443\u0430\u0440,
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0439
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438,
    \u0431\u044B\u043B\u0438 \u043F\u043E \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u0443
    \u043E\u0446\u0435\u043D\u0435\u043D\u044B \u043B\u0438\u0448\u044C \u043F\u043E\u0441\u043B\u0435
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u0442 \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437\u0430
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 26 \u043B\u0435\u0442.
    \u0412 2002 \u0433\u043E\u0434\u0443 \u0432 \u0435\u0433\u043E \u0447\u0435\u0441\u0442\u044C
    \u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u041D\u043E\u0440\u0432\u0435\u0433\u0438\u0438 \u0431\u044B\u043B\u0430 \u0443\u0447\u0440\u0435\u0436\u0434\u0435\u043D\u0430
    \u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u043F\u0440\u0435\u043C\u0438\u044F
    \u2014 \u043E\u0434\u043D\u0430 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434 \u0432 \u043C\u0438\u0440\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438."
