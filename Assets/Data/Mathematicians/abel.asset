  achievementsRu: "### \U0001F4DC 1823: \u041F\u0435\u0440\u0432\u044B\u0435 \u0448\u0430\u0433\u0438
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u042D\u0442\u043E\u0442
    \u0433\u043E\u0434 \u043E\u0437\u043D\u0430\u043C\u0435\u043D\u043E\u0432\u0430\u043B\u0441\u044F
    \u043D\u0430\u0447\u0430\u043B\u043E\u043C \u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439. \u041E\u043D
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0441\u0432\u043E\u044E
    \u043F\u0435\u0440\u0432\u0443\u044E \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443, \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0443\u044E
    \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u0443\u0435\u043C\u043E\u0441\u0442\u0438
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. \u0425\u043E\u0442\u044F
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C \u043D\u0435 \u0431\u044B\u043B\u0430
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u0430 \u0438
    \u043F\u043E\u0437\u0436\u0435 \u0437\u0430\u0442\u0435\u0440\u044F\u043B\u0430\u0441\u044C,
    \u043E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430 \u0432\u0430\u0436\u043D\u043E\u0439
    \u0432\u0435\u0445\u043E\u0439, \u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0410\u0431\u0435\u043B\u044C \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E. \u041F\u043E \u0441\u0443\u0442\u0438,
    \u043E\u043D \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u043F\u0435\u0440\u0432\u044B\u0445, \u043A\u0442\u043E \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u0440\u0435\u0448\u0438\u043B \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435.  ### \u2694\uFE0F 1824:
    \u0412\u0435\u043B\u0438\u043A\u0430\u044F \u043F\u043E\u0431\u0435\u0434\u0430
    \u043D\u0430\u0434 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435\u043C
    \u043F\u044F\u0442\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u0412
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 21 \u0433\u043E\u0434\u0430
    \u0410\u0431\u0435\u043B\u044C \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432 \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0435.
    \u041E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0437\u0430 \u0441\u0432\u043E\u0439 \u0441\u0447\u0435\u0442 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    **\u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u043D\u0435\u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0441\u0442\u0438
    \u043E\u0431\u0449\u0435\u0433\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u043F\u044F\u0442\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u0432
    \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0430\u0445**. \u042D\u0442\u043E
    \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E, \u0447\u0442\u043E \u043D\u0435
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u0435\u0434\u0438\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0449\u0435\u0439
    \u043B\u0438\u0448\u044C \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438 \u0438 \u0438\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435
    \u043A\u043E\u0440\u043D\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043C\u043E\u0433\u043B\u0430 \u0431\u044B \u0434\u0430\u0442\u044C \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0433\u043E \u0442\u0430\u043A\u043E\u0433\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u0441\u0432\u043E\u044E \u0440\u0430\u0431\u043E\u0442\u0443 \u041A\u0430\u0440\u043B\u0443
    \u0413\u0430\u0443\u0441\u0441\u0443, \u043D\u043E \u0442\u043E\u0442 \u043D\u0435
    \u043E\u0446\u0435\u043D\u0438\u043B \u0435\u0435 \u0432\u0430\u0436\u043D\u043E\u0441\u0442\u044C.
    \u041D\u0430 \u044D\u0442\u0443 \u0440\u0430\u0431\u043E\u0442\u0443 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043E\u043F\u0438\u0440\u0430\u043B\u0441\u044F \u042D\u0432\u0430\u0440\u0438\u0441\u0442
    \u0413\u0430\u043B\u0443\u0430, \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u044F
    \u0441\u0432\u043E\u044E \u0442\u0435\u043E\u0440\u0438\u044E.  ### \u270D\uFE0F
    1825\u20131826: \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 \u0438 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0436\u0443\u0440\u043D\u0430\u043B\u0430 \u041A\u0440\u0435\u043B\u043B\u0435
    \u041F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0443\u044F \u043F\u043E
    \u0415\u0432\u0440\u043E\u043F\u0435, \u0410\u0431\u0435\u043B\u044C \u043F\u0440\u043E\u0432\u0435\u043B
    \u0437\u0438\u043C\u0443 1825\u20131826 \u0433\u043E\u0434\u043E\u0432 \u0432
    \u0411\u0435\u0440\u043B\u0438\u043D\u0435. \u0422\u0430\u043C \u043E\u043D \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B
    \u0410\u0432\u0433\u0443\u0441\u0442\u0430 \u041A\u0440\u0435\u043B\u043B\u0435,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \xABJournal f\xFCr
    die reine und angewandte Mathematik\xBB (\u0416\u0443\u0440\u043D\u0430\u043B
    \u041A\u0440\u0435\u043B\u043B\u0435). \u0410\u0431\u0435\u043B\u044C \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445 \u0430\u0432\u0442\u043E\u0440\u043E\u0432
    \u0436\u0443\u0440\u043D\u0430\u043B\u0430, \u043D\u043E \u0438 \u043E\u043A\u0430\u0437\u0430\u043B
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0443
    \u044D\u0442\u043E\u043C\u0443 \u043D\u0430\u0447\u0438\u043D\u0430\u043D\u0438\u044E.
    \u0412 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B: *   **\u0420\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u043D\u0443\u044E
    \u0432\u0435\u0440\u0441\u0438\u044E \u0441\u0432\u043E\u0435\u0439 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u0431 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u0445**,
    \u0433\u0434\u0435 \u0431\u043E\u043B\u0435\u0435 \u0441\u0442\u0440\u043E\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u043D\u0435\u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0441\u0442\u044C
