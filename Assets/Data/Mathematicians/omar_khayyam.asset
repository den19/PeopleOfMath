    \u0432\u0440\u0435\u043C\u044F, \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u043C\u043E\u0436\u043D\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C \u043D\u0430 \u0442\u0440\u0438
    \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. 
    ### \U0001F4D0 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:
    \u0420\u0435\u0444\u043E\u0440\u043C\u0430\u0442\u043E\u0440 \u0430\u043B\u0433\u0435\u0431\u0440\u044B 
    \u041E\u043C\u0430\u0440 \u0425\u0430\u0439\u044F\u043C \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434,
    \xAB\u0422\u0440\u0430\u043A\u0442\u0430\u0442 \u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u0445
    \u0437\u0430\u0434\u0430\u0447 \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0438
    \u0430\u043B\u044C-\u043C\u0443\u043A\u0430\u0431\u0430\u043B\u044B\xBB (\u043E\u043A.
    1070 \u0433.), \u0441\u0442\u0430\u043B \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C
    \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u043C.  *   **\u041E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B**: \u0412 \u044D\u0442\u043E\u043C
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435 \u0425\u0430\u0439\u044F\u043C
    \u043F\u0435\u0440\u0432\u044B\u043C \u0434\u0430\u043B \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u0430\u043B\u0433\u0435\u0431\u0440\u044B
    \u043A\u0430\u043A \u043D\u0430\u0443\u043A\u0438 \u043E\u0431 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u0445,
    \u043E\u0442\u0434\u0435\u043B\u0438\u0432 \u0435\u0435 \u043E\u0442 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438.
    *   **\u041A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044F
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439**: \u041E\u043D \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043F\u043E\u043B\u043D\u0443\u044E \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u043D\u0430 25 \u0442\u0438\u043F\u043E\u0432,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0432\u0441\u0435 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0435
    \u0441\u043B\u0443\u0447\u0430\u0438 \u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0445,
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0445 \u0438 \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0441 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u0430\u043C\u0438.
    *   **\u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u2014 \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439**: \u0413\u043B\u0430\u0432\u043D\u044B\u043C
    \u043F\u0440\u043E\u0440\u044B\u0432\u043E\u043C \u0441\u0442\u0430\u043B\u043E
    \u0435\u0433\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 **\u0432\u0441\u0435\u0445 14 \u0442\u0438\u043F\u043E\u0432
    \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439**
    (\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0442\u0440\u0435\u0442\u044C\u0435\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438). \u0414\u043E \u043D\u0435\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043C\u043E\u0433\u043B\u0438
    \u0440\u0435\u0448\u0430\u0442\u044C \u043B\u0438\u0448\u044C \u0447\u0430\u0441\u0442\u043D\u044B\u0435
    \u0441\u043B\u0443\u0447\u0430\u0438. \u041C\u0435\u0442\u043E\u0434 \u0425\u0430\u0439\u044F\u043C\u0430
    \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0441\u044F \u0432 \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0438
    \u043A\u043E\u0440\u043D\u0435\u0439 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u043A\u0430\u043A \u0442\u043E\u0447\u0435\u043A \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u044F
    \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u0435\u0447\u0435\u043D\u0438\u0439
    \u2014 \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u0438, \u043F\u0430\u0440\u0430\u0431\u043E\u043B\u044B,
    \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u044B \u0438 \u044D\u043B\u043B\u0438\u043F\u0441\u0430.
    *   **\u041F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u0435
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438**: \u0415\u0433\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434, \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u044E\u0449\u0438\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u0440\u0438\u0432\u044B\u0435, \u0441\u0442\u0430\u043B \u043F\u0440\u044F\u043C\u044B\u043C
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u043C
    \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0441\u043F\u0443\u0441\u0442\u044F \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438 \u0420\u0435\u043D\u0435
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0438 \u041F\u044C\u0435\u0440 \u0424\u0435\u0440\u043C\u0430.
    *   **\u0420\u0430\u0431\u043E\u0442\u0430 \u043D\u0430\u0434 \xAB\u041D\u0430\u0447\u0430\u043B\u0430\u043C\u0438\xBB
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430**: \u0412 \u0441\u0432\u043E\u0435\u043C
    \xAB\u041A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0438 \u043A
    \u0442\u0440\u0443\u0434\u043D\u044B\u043C \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442\u0430\u043C
    \u043A\u043D\u0438\u0433\u0438 \u0415\u0432\u043A\u043B\u0438\u0434\u0430\xBB
    (1077 \u0433.) \u043E\u043D \u043F\u0440\u0435\u0434\u043F\u0440\u0438\u043D\u044F\u043B
    \u0441\u043C\u0435\u043B\u0443\u044E \u043F\u043E\u043F\u044B\u0442\u043A\u0443
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043F\u044F\u0442\u044B\u0439 \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u043E \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u044F\u043C\u044B\u0445, \u0447\u0442\u043E \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. 
    ### \u2600\uFE0F \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F:
    \u041A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044C, \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0438\u0439
    \u0432\u0440\u0435\u043C\u044F  \u0412 1074 \u0433\u043E\u0434\u0443 \u0425\u0430\u0439\u044F\u043C
    \u0431\u044B\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D \u0432
    \u0418\u0441\u0444\u0430\u0445\u0430\u043D \u0434\u043B\u044F \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u0430
    \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0435\u0439 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0435\u0439.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C
    \u0437\u0434\u0435\u0441\u044C \u0441\u0442\u0430\u043B\u0430 \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u043D\u0430\u044F
    \u0440\u0435\u0444\u043E\u0440\u043C\u0430.  *   **\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044F \xAB\u0414\u0436\u0430\u043B\u0430\u043B\u0438\xBB**:
    \u0412 1079 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B
    \u043D\u043E\u0432\u044B\u0439 \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0439
    \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044C, \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u044B\u0439
    \u0432 \u0447\u0435\u0441\u0442\u044C \u0441\u0443\u043B\u0442\u0430\u043D\u0430
    \u041C\u0430\u043B\u0438\u043A-\u0448\u0430\u0445\u0430. *   **\u041D\u0435\u043F\u0440\u0435\u0432\u0437\u043E\u0439\u0434\u0435\u043D\u043D\u0430\u044F
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C**: \u042D\u0442\u043E\u0442
    \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044C \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0442\u043E\u0447\u0435\u043D,
    \u0447\u0442\u043E \u043F\u0440\u0435\u0432\u043E\u0441\u0445\u043E\u0434\u0438\u043B
    \u043F\u043E \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438 \u0433\u0440\u0438\u0433\u043E\u0440\u0438\u0430\u043D\u0441\u043A\u0438\u0439
    \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044C, \u0432\u0432\u0435\u0434\u0435\u043D\u043D\u044B\u0439
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u043B\u0438\u0448\u044C \u0432 1582
    \u0433\u043E\u0434\u0443.     *   **\u0426\u0438\u043A\u043B**: 33 \u0433\u043E\u0434\u0430,
    8 \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u2014 \u0432\u0438\u0441\u043E\u043A\u043E\u0441\u043D\u044B\u0435
    (\u0432 4-\u0439, 8-\u0439, 12-\u0439, 16-\u0439, 20-\u0439, 24-\u0439, 28-\u0439
    \u0438 33-\u0439 \u0433\u043E\u0434\u044B).     *   **\u0422\u043E\u0447\u043D\u043E\u0441\u0442\u044C**:
    \u0413\u043E\u0434 \u043F\u043E \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044E
    \u0425\u0430\u0439\u044F\u043C\u0430 \u0434\u043B\u0438\u0442\u0441\u044F **365,2424242**
    \u0441\u0443\u0442\u043E\u043A, \u0447\u0442\u043E \u0432\u0441\u0435\u0433\u043E
    \u043D\u0430 **1,24 \u0441\u0435\u043A\u0443\u043D\u0434\u044B** \u043E\u0442\u043B\u0438\u0447\u0430\u0435\u0442\u0441\u044F
    \u043E\u0442 \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0442\u0440\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0433\u043E\u0434\u0430. *   **\u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B**: \u0417\u0430 \u0433\u043E\u0434\u044B
    \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438
    \u043E\u043D \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0435
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B \xAB\u0417\u0438\u0434\u0436 \u041C\u0430\u043B\u0438\u043A-\u0448\u0430\u0445\u0438\xBB
    \u0438 \u043A\u0430\u0442\u0430\u043B\u043E\u0433 \u0437\u0432\u0435\u0437\u0434,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C, \u043F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0434\u0430\u043D\u043D\u044B\u043C, \u043E\u043F\u0438\u0441\u0430\u043B \u043E\u043A\u043E\u043B\u043E
    100 \u0437\u0432\u0435\u0437\u0434.  ### \U0001F4DA \u0414\u0440\u0443\u0433\u0438\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B \u0438
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F  \u041F\u043E\u043C\u0438\u043C\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438,
    \u0425\u0430\u0439\u044F\u043C \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0442\u0440\u0443\u0434\u044B
    \u0432 \u0434\u0440\u0443\u0433\u0438\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445
    \u0438 \u0431\u044B\u043B \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u043C.  *   **\u0424\u0438\u0437\u0438\u043A\u0430**:
    \u041D\u0430\u043F\u0438\u0441\u0430\u043B \u0442\u0440\u0430\u043A\u0442\u0430\u0442
    \xAB\u0412\u0435\u0441\u044B \u043C\u0443\u0434\u0440\u043E\u0441\u0442\u0438,
    \u0438\u043B\u0438 \u0422\u0440\u0430\u043A\u0442\u0430\u0442 \u043E\u0431 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430
    \u0437\u043E\u043B\u043E\u0442\u0430 \u0438 \u0441\u0435\u0440\u0435\u0431\u0440\u0430
    \u0432 \u0441\u043F\u043B\u0430\u0432\u0430\u0445\xBB, \u043A\u043E\u0442\u043E\u0440\u044B\u0439,
    \u043F\u043E \u0441\u0443\u0442\u0438, \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0444\u0438\u0437\u0438\u043A\u043E-\u0445\u0438\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0443\u0434\u0435\u043B\u044C\u043D\u043E\u0433\u043E \u0432\u0435\u0441\u0430
    \u043C\u0435\u0442\u0430\u043B\u043B\u043E\u0432. *   **\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430**:
    \u0415\u0433\u043E \u0440\u0430\u043D\u043D\u044F\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \xAB\u0422\u0440\u0443\u0434\u043D\u044B\u0435 \u0432\u043E\u043F\u0440\u043E\u0441\u044B
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\xBB, \u043A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u043D\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0430\u0441\u044C,
    \u043D\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u0447\u0442\u043E
    \u0432 \u043D\u0435\u0439 \u043E\u043D \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434\u044B \u0438\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F
    \u043A\u043E\u0440\u043D\u0435\u0439, \u043F\u043E \u0441\u0443\u0442\u0438,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u0431\u0438\u043D\u043E\u043C
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u043D\u0430 700 \u043B\u0435\u0442
    \u0440\u0430\u043D\u044C\u0448\u0435 \u043D\u0435\u0433\u043E. *   **\u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F**:
    \u0411\u0443\u0434\u0443\u0447\u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0418\u0431\u043D \u0421\u0438\u043D\u044B (\u0410\u0432\u0438\u0446\u0435\u043D\u043D\u044B),
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445 \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u043E\u0432
    \u043D\u0430 \u0430\u0440\u0430\u0431\u0441\u043A\u043E\u043C \u0438 \u043F\u0435\u0440\u0441\u0438\u0434\u0441\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0430\u0445, \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u043B \u0432\u043E\u043F\u0440\u043E\u0441\u044B
    \u0431\u044B\u0442\u0438\u044F, \u0434\u0435\u0442\u0435\u0440\u043C\u0438\u043D\u0438\u0437\u043C\u0430
    \u0438 \u0432\u0435\u0447\u043D\u043E\u0441\u0442\u0438 \u043C\u0438\u0440\u0430.
    \u0415\u0433\u043E \xAB\u041D\u043E\u0443\u0440\u0443\u0437-\u043D\u0430\u043C\u0435\xBB
    \u2014 \u044D\u0442\u043E \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0435
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0435 \u043E \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u044F\u0445
    \u043F\u0440\u0430\u0437\u0434\u043D\u0438\u043A\u0430 \u0432\u0435\u0441\u043D\u044B
    \u041D\u0430\u0432\u0440\u0443\u0437.  ### \U0001F48E \u0418\u0442\u043E\u0433 
    \u041E\u043C\u0430\u0440 \u0425\u0430\u0439\u044F\u043C \u0431\u044B\u043B \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u0443\u0447\u0435\u043D\u044B\u043C-\u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0441\u0442\u043E\u043C.
    \u0415\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u0441\u0442\u0430\u043B\u0438 \u043C\u043E\u0441\u0442\u043E\u043C
    \u043C\u0435\u0436\u0434\u0443 \u0430\u043D\u0442\u0438\u0447\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439 \u0438 \u043D\u043E\u0432\u043E\u0439
    \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0439 \u043D\u0430\u0443\u043A\u043E\u0439,
    \u0430 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B, \u043F\u043E-\u043F\u0440\u0435\u0436\u043D\u0435\u043C\u0443
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u0432
    \u0418\u0440\u0430\u043D\u0435 \u0438 \u0410\u0444\u0433\u0430\u043D\u0438\u0441\u0442\u0430\u043D\u0435,
    \u044F\u0432\u043B\u044F\u044F\u0441\u044C \u0436\u0438\u0432\u044B\u043C \u043F\u0430\u043C\u044F\u0442\u043D\u0438\u043A\u043E\u043C
    \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u044E."
  achievementsEn: 
  personalLifeRu: "\u0416\u0438\u0437\u043D\u044C \u041E\u043C\u0430\u0440\u0430
    \u0425\u0430\u0439\u044F\u043C\u0430, \u0437\u0430\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u043D\u0430\u044F
    \u0432 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432\u0448\u0438\u0445\u0441\u044F
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445, \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0435\u0442
    \u043A\u0430\u043A \u043F\u0443\u0442\u044C \u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E, \u0446\u0435\u043B\u0438\u043A\u043E\u043C
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0432\u0448\u0435\u0433\u043E \u0441\u0435\u0431\u044F
    \u043D\u0430\u0443\u043A\u0435 \u0438 \u043E\u0441\u0442\u0430\u0432\u0438\u0432\u0448\u0435\u0433\u043E
    \u044F\u0440\u043A\u0438\u0439 \u0441\u043B\u0435\u0434 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438. \u0414\u0435\u0442\u0430\u043B\u0438
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438
    \u0431\u043E\u043B\u044C\u0448\u0435\u0439 \u0447\u0430\u0441\u0442\u044C\u044E
    \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C \u0437\u0430 \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0430\u043C\u0438
    \u0445\u0440\u043E\u043D\u0438\u043A, \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0435\u043D\u043D\u044B\u0445
    \u043D\u0430 \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u0445.  \u041D\u0438\u0436\u0435
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u044B \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0432\u0435\u0445\u0438 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438,
    \u0441\u043E\u0431\u0440\u0430\u043D\u043D\u044B\u0435 \u043F\u043E \u043A\u0440\u0443\u043F\u0438\u0446\u0430\u043C
    \u0438\u0437 \u0434\u043E\u0448\u0435\u0434\u0448\u0438\u0445 \u0434\u043E \u043D\u0430\u0441
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432. 
    ### \U0001F476 \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B  \u041E\u043C\u0430\u0440
    \u0425\u0430\u0439\u044F\u043C, \u043F\u043E\u043B\u043D\u043E\u0435 \u0438\u043C\u044F
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E **\u0413\u0438\u044F\u0441\u0430\u0434\u0434\u0438\u043D
    \u0410\u0431\u0443-\u043B\u044C-\u0424\u0430\u0442\u0445 \u041E\u043C\u0430\u0440
    \u0438\u0431\u043D \u0418\u0431\u0440\u0430\u0445\u0438\u043C \u041D\u0438\u0448\u0430\u043F\u0443\u0440\u0438**,
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **18 \u043C\u0430\u044F 1048 \u0433\u043E\u0434\u0430**
    \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u041D\u0438\u0448\u0430\u043F\u0443\u0440,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0442\u043E\u0433\u0434\u0430 \u0431\u044B\u043B
    \u043A\u0440\u0443\u043F\u043D\u044B\u043C \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u043D\u044B\u043C
    \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u0425\u043E\u0440\u0430\u0441\u0430\u043D\u0430
    (\u043D\u0430 \u0441\u0435\u0432\u0435\u0440\u043E-\u0432\u043E\u0441\u0442\u043E\u043A\u0435
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E \u0418\u0440\u0430\u043D\u0430).
    \u0415\u0433\u043E \u0441\u0435\u043C\u044C\u044F, \u0441\u0443\u0434\u044F \u043F\u043E
    \u0444\u0430\u043C\u0438\u043B\u0438\u0438 (\xAB\u0445\u0430\u0439\u044F\u043C\xBB
    \u2014 \u043F\u0430\u043B\u0430\u0442\u043E\u0447\u043D\u044B\u0445 \u0434\u0435\u043B
    \u043C\u0430\u0441\u0442\u0435\u0440), \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0430
    \u0438\u0437 \u0440\u0435\u043C\u0435\u0441\u043B\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u0438\u0437\u0433\u043E\u0442\u0430\u0432\u043B\u0438\u0432\u0430\u0432\u0448\u0438\u0445
    \u043F\u0430\u043B\u0430\u0442\u043A\u0438. \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u0447\u0442\u043E \u0443 \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u0430 \u043C\u043B\u0430\u0434\u0448\u0430\u044F
    \u0441\u0435\u0441\u0442\u0440\u0430 \u043F\u043E \u0438\u043C\u0435\u043D\u0438
    \u0410\u0438\u0448\u0430.  \u041E\u043D \u0440\u0430\u043D\u043E \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u043D\u0435\u0437\u0430\u0443\u0440\u044F\u0434\u043D\u044B\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438:
    \u0443\u0436\u0435 \u0432 8 \u043B\u0435\u0442 \u043E\u043D \u043D\u0430\u0447\u0430\u043B
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443, \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044E
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E. \u0412 12 \u043B\u0435\u0442
    \u041E\u043C\u0430\u0440 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432
    \u043C\u0435\u0434\u0440\u0435\u0441\u0435 \u041D\u0438\u0448\u0430\u043F\u0443\u0440\u0430,
    \u0433\u0434\u0435 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u043E\u0441\u0432\u043E\u0438\u043B
    \u043A\u0443\u0440\u0441 \u043C\u0443\u0441\u0443\u043B\u044C\u043C\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u0430\u0432\u0430 \u0438 \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u044B,
    \u043F\u043E\u043B\u0443\u0447\u0438\u0432 \u043A\u0432\u0430\u043B\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044E
    \u0432\u0440\u0430\u0447\u0430 (\u0445\u0430\u043A\u0438\u043C\u0430). \u041E\u0434\u043D\u0430\u043A\u043E
    \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u0430\u044F \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0430
    \u043C\u0430\u043B\u043E \u0435\u0433\u043E \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u0430\u043B\u0430,
    \u043E\u043D \u0432\u0441\u0435\u0446\u0435\u043B\u043E \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u0441\u0435\u0431\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E \u0442\u0440\u0443\u0434\u043E\u0432
    \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u0445 \u0438 \u0432\u043E\u0441\u0442\u043E\u0447\u043D\u044B\u0445
    \u0443\u0447\u0435\u043D\u044B\u0445, \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A
    \u0415\u0432\u043A\u043B\u0438\u0434 \u0438 \u0410\u0432\u0438\u0446\u0435\u043D\u043D\u0430
    (\u0418\u0431\u043D \u0421\u0438\u043D\u0430).  \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    16 \u043B\u0435\u0442 \u0436\u0438\u0437\u043D\u044C \u041E\u043C\u0430\u0440\u0430
    \u0440\u0435\u0437\u043A\u043E \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0430\u0441\u044C:
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u0438
    \u0443\u043C\u0435\u0440\u043B\u0438 \u0435\u0433\u043E \u043E\u0442\u0435\u0446
    \u0438 \u043C\u0430\u0442\u044C. \u041F\u0440\u043E\u0434\u0430\u0432 \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0439
    \u0434\u043E\u043C \u0438 \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u0443\u044E,
    \u043E\u043D \u043F\u043E\u043A\u0438\u043D\u0443\u043B \u041D\u0438\u0448\u0430\u043F\u0443\u0440
    \u0438 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432 \u0421\u0430\u043C\u0430\u0440\u043A\u0430\u043D\u0434,
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0446\u0435\u043D\u0442\u0440\u043E\u0432
    \u0412\u043E\u0441\u0442\u043E\u043A\u0430.  ### \U0001F9D1\u200D\U0001F393 \u041F\u0443\u0442\u044C
    \u043A \u0441\u043B\u0430\u0432\u0435: \u0423\u0447\u0451\u0431\u0430 \u0438
    \u0440\u0430\u0431\u043E\u0442\u0430  \u0412 \u0421\u0430\u043C\u0430\u0440\u043A\u0430\u043D\u0434\u0435
    \u0425\u0430\u0439\u044F\u043C \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B
    \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435 \u0432 \u043C\u0435\u0434\u0440\u0435\u0441\u0435,
    \u043D\u043E \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0441\u0442\u044C
    \u043D\u0430 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u044B\u0445 \u0434\u0438\u0441\u043F\u0443\u0442\u0430\u0445
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0440\u0430\u0437\u0438\u043B\u0430
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0441\u0440\u0430\u0437\u0443 \u0436\u0435 \u0432\u043E\u0437\u0432\u0435\u043B\u0438
    \u0432 \u0440\u0430\u043D\u0433 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u0430.
    \u041A\u0430\u043A \u0438 \u043C\u043D\u043E\u0433\u0438\u0435 \u0443\u0447\u0435\u043D\u044B\u0435
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u043E\u043D
    \u043D\u0435 \u0437\u0430\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0441\u044F
    \u043F\u043E\u0434\u043E\u043B\u0433\u0443 \u043D\u0430 \u043E\u0434\u043D\u043E\u043C
    \u043C\u0435\u0441\u0442\u0435. \u041E\u043A\u043E\u043B\u043E 1070 \u0433\u043E\u0434\u0430
    \u043E\u043D \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0411\u0443\u0445\u0430\u0440\u0443,
    \u0433\u0434\u0435 \u043E\u043A\u043E\u043B\u043E \u0434\u0435\u0441\u044F\u0442\u0438
    \u043B\u0435\u0442 \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u043C\u0435\u0441\u0442\u043D\u044B\u0445 \u043A\u043D\u0438\u0433\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u0438\u0449\u0430\u0445.
    \u042D\u0442\u043E\u0442 \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B
    \u0435\u043C\u0443 \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C \u0447\u0435\u0442\u044B\u0440\u0435
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0430.  ### \U0001F451 \u0417\u0432\u0451\u0437\u0434\u043D\u044B\u0439
    \u0447\u0430\u0441 \u0432 \u0418\u0441\u0444\u0430\u0445\u0430\u043D\u0435: \u041F\u0438\u043A
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u044B 
    \u0412 1074 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u0425\u0430\u0439\u044F\u043C\u0443
    \u0431\u044B\u043B\u043E \u043E\u043A\u043E\u043B\u043E 27 \u043B\u0435\u0442,
    \u0435\u0433\u043E \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B\u0438
    \u0432 \u0418\u0441\u0444\u0430\u0445\u0430\u043D \u2014 \u0441\u0442\u043E\u043B\u0438\u0446\u0443
    \u043C\u043E\u0433\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0421\u0435\u043B\u044C\u0434\u0436\u0443\u043A\u0441\u043A\u043E\u0439 \u0438\u043C\u043F\u0435\u0440\u0438\u0438.
    \u041F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435 \u0438\u0441\u0445\u043E\u0434\u0438\u043B\u043E
    \u043E\u0442 \u0441\u0443\u043B\u0442\u0430\u043D\u0430 \u041C\u0430\u043B\u0438\u043A-\u0448\u0430\u0445\u0430
    \u0438 \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u043E\u0433\u043E \u0432\u0438\u0437\u0438\u0440\u044F
    \u041D\u0438\u0437\u0430\u043C \u0430\u043B\u044C-\u041C\u0443\u043B\u044C\u043A\u0430.
    \u041F\u043E \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u043B\u0435\u0433\u0435\u043D\u0434,
    \u043E\u043D\u0438 \u0431\u044B\u043B\u0438 \u043E\u0434\u043D\u043E\u043A\u043B\u0430\u0441\u0441\u043D\u0438\u043A\u0430\u043C\u0438
    \u0425\u0430\u0439\u044F\u043C\u0430 \u0432 \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438. 
    \u0412 \u0418\u0441\u0444\u0430\u0445\u0430\u043D\u0435 \u0425\u0430\u0439\u044F\u043C
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044F \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0445 \u0432
    \u043C\u0438\u0440\u0435 \u0434\u0432\u043E\u0440\u0446\u043E\u0432\u044B\u0445
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0439 \u0438
    \u0441\u0442\u0430\u043B \u0434\u0443\u0445\u043E\u0432\u043D\u044B\u043C \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u0441\u0443\u043B\u0442\u0430\u043D\u0430. \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    (\u043E\u043A\u043E\u043B\u043E 20 \u043B\u0435\u0442) \u0441\u0442\u0430\u043B
    \u0432\u0435\u0440\u0448\u0438\u043D\u043E\u0439 \u0435\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u044B.
    \u0420\u0430\u0431\u043E\u0442\u0430\u044F \u0441 \u0433\u0440\u0443\u043F\u043F\u043E\u0439
    \u0443\u0447\u0435\u043D\u044B\u0445, \u043E\u043D:  - **\u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0439 \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044C**
    \xAB\u0414\u0436\u0430\u043B\u0430\u043B\u0438\xBB, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B\u043B \u0431\u043E\u043B\u0435\u0435 \u0442\u043E\u0447\u043D\u044B\u043C,
    \u0447\u0435\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439
    \u0435\u043C\u0443 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0439
    \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044C, \u0438 \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0432 \u0418\u0440\u0430\u043D\u0435 \u0438 \u0410\u0444\u0433\u0430\u043D\u0438\u0441\u0442\u0430\u043D\u0435.
    - **\u0421\u043E\u0441\u0442\u0430\u0432\u0438\u043B \xAB\u041C\u0430\u043B\u0438\u043A\u0448\u0430\u0445\u0441\u043A\u0438\u0435
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B\xBB**, \u0432\u043A\u043B\u044E\u0447\u0430\u0432\u0448\u0438\u0435
    \u043A\u0430\u0442\u0430\u043B\u043E\u0433 \u044F\u0440\u043A\u0438\u0445 \u0437\u0432\u0435\u0437\u0434.
    - **\u041D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0442\u0440\u0443\u0434 \xAB\u041A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0438
    \u043A \u0442\u0440\u0443\u0434\u043D\u044B\u043C \u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442\u0430\u043C
    \u043A\u043D\u0438\u0433\u0438 \u0415\u0432\u043A\u043B\u0438\u0434\u0430\xBB**
    (1077 \u0433.), \u0433\u0434\u0435 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u0445
    \u043B\u0438\u043D\u0438\u0439 \u0438 \u0443\u0447\u0435\u043D\u0438\u0435 \u043E
    \u0447\u0438\u0441\u043B\u0435, \u043F\u043E\u0434\u043E\u0439\u0434\u044F \u043A
    \u0438\u0434\u0435\u044F\u043C \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.  ### \U0001F465 \u0423\u0447\u0435\u043D\u0438\u043A\u0438,
    \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u0438 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F 
    \u041E\u0431 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u0445 \u0425\u0430\u0439\u044F\u043C\u0430
    \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043D\u0435\u043C\u043D\u043E\u0433\u043E.
    \u0412 \u0447\u0438\u0441\u043B\u0435 \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432
    \u0431\u044B\u043B\u0438 \u0442\u0430\u043A\u0438\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435
    \u0443\u0447\u0435\u043D\u044B\u0435, \u043A\u0430\u043A \u0430\u043B-\u0410\u0441\u0444\u0438\u0437\u0430\u0440\u0438
    \u0438 \u0430\u043B-\u0425\u0430\u0437\u0438\u043D\u0438. \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438,
    \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432 \u0430\u043B\u044C-\u0413\u0430\u0437\u0430\u043B\u0438,
    \u043E\u0431\u0440\u0430\u0449\u0430\u043B\u0438\u0441\u044C \u043A \u043D\u0435\u043C\u0443
    \u0437\u0430 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438 \u0440\u0430\u0437\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u044F\u043C\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u043F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C,
    \u0425\u0430\u0439\u044F\u043C \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0440\u0435\u0437\u043A\u0438\u043C \u0438 \u0436\u0435\u043B\u0447\u043D\u044B\u043C,
    \u0447\u0442\u043E, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0443\u0441\u043B\u043E\u0436\u043D\u044F\u043B\u043E
    \u0435\u0433\u043E \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441
    \u043E\u043A\u0440\u0443\u0436\u0430\u044E\u0449\u0438\u043C\u0438.  \u0415\u0433\u043E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0435 \u0432\u0437\u0433\u043B\u044F\u0434\u044B,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0441\u043A\u0435\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435 \u043A \u0440\u0435\u043B\u0438\u0433\u0438\u0438,
    \u0432\u044B\u0437\u044B\u0432\u0430\u043B\u0438 \u043D\u0435\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u043E
    \u043E\u0440\u0442\u043E\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0434\u0443\u0445\u043E\u0432\u0435\u043D\u0441\u0442\u0432\u0430, \u0438 \u0435\u0433\u043E
    \u043D\u0435 \u0440\u0430\u0437 \u043E\u0431\u0432\u0438\u043D\u044F\u043B\u0438
    \u0432 \u0431\u0435\u0437\u0431\u043E\u0436\u043D\u043E\u043C \u0432\u043E\u043B\u044C\u043D\u043E\u0434\u0443\u043C\u0441\u0442\u0432\u0435. 
    ### \U0001F51A \u0417\u0430\u043A\u0430\u0442: \u0418\u0437\u0433\u043D\u0430\u043D\u0438\u0435,
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0441\u043C\u0435\u0440\u0442\u044C  \u0411\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0439
    \u0438\u0441\u0444\u0430\u0445\u0430\u043D\u0441\u043A\u0438\u0439 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B\u0441\u044F \u0432 1092 \u0433\u043E\u0434\u0443
    \u0441\u043E \u0441\u043C\u0435\u0440\u0442\u044C\u044E \u0435\u0433\u043E \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u0435\u0439
    \u2014 \u0441\u0443\u043B\u0442\u0430\u043D\u0430 \u041C\u0430\u043B\u0438\u043A-\u0448\u0430\u0445\u0430
    \u0438 \u0432\u0438\u0437\u0438\u0440\u044F \u041D\u0438\u0437\u0430\u043C \u0430\u043B\u044C-\u041C\u0443\u043B\u044C\u043A\u0430.
    \u041D\u0430\u0447\u0430\u043B\u0441\u044F \u043F\u0435\u0440\u0438\u043E\u0434
    \u0441\u043C\u0443\u0442 \u0438 \u0431\u043E\u0440\u044C\u0431\u044B \u0437\u0430
    \u0432\u043B\u0430\u0441\u0442\u044C. \u0425\u0430\u0439\u044F\u043C \u0431\u044B\u043B
    \u043E\u0431\u0432\u0438\u043D\u0435\u043D \u0432 \u0432\u043E\u043B\u044C\u043D\u043E\u0434\u0443\u043C\u0441\u0442\u0432\u0435,
    \u043B\u0438\u0448\u0438\u043B\u0441\u044F \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0438
    \u0438 \u0431\u044B\u043B \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D \u043F\u043E\u043A\u0438\u043D\u0443\u0442\u044C
    \u0441\u0442\u043E\u043B\u0438\u0446\u0443.  \u041E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0432 \u041C\u0435\u043A\u043A\u0443, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u0432 \u0440\u043E\u0434\u043D\u043E\u0439
    \u041D\u0438\u0448\u0430\u043F\u0443\u0440. \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0436\u0438\u0437\u043D\u0438 \u043E\u043D \u043F\u0440\u043E\u0432\u0435\u043B
    \u0442\u0430\u043C, \u0432\u0435\u0434\u044F \u0443\u0435\u0434\u0438\u043D\u0435\u043D\u043D\u044B\u0439
    \u043E\u0431\u0440\u0430\u0437 \u0436\u0438\u0437\u043D\u0438, \u0437\u0430\u043D\u0438\u043C\u0430\u044F\u0441\u044C
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E
    \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438 \u0442\u0440\u0443\u0434\u0430\u043C\u0438.
    \u041F\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C,
    \u043E\u043D \u0436\u0438\u043B \u0431\u0435\u0434\u043D\u043E, \u0431\u0435\u0437
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0438, \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043A\u0430\u043A \u043E\u0442\u0448\u0435\u043B\u044C\u043D\u0438\u043A.  \u041E\u043C\u0430\u0440
    \u0425\u0430\u0439\u044F\u043C \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    **4 \u0434\u0435\u043A\u0430\u0431\u0440\u044F 1131 \u0433\u043E\u0434\u0430**
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 83 \u043B\u0435\u0442.
    \u0421\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C \u0442\u0440\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435 \u0435\u0433\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0445
    \u0447\u0430\u0441\u043E\u0432, \u043F\u0435\u0440\u0435\u0434\u0430\u043D\u043D\u043E\u0435
    \u0437\u044F\u0442\u0435\u043C \u043F\u043E\u044D\u0442\u0430. \u0412 \u0434\u0435\u043D\u044C
    \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u043D \u0447\u0438\u0442\u0430\u043B
    \xAB\u041A\u043D\u0438\u0433\u0443 \u0438\u0441\u0446\u0435\u043B\u0435\u043D\u0438\u044F\xBB
    \u0441\u0432\u043E\u0435\u0433\u043E \u043A\u0443\u043C\u0438\u0440\u0430 \u0410\u0432\u0438\u0446\u0435\u043D\u043D\u044B.
    \u0414\u043E\u0439\u0434\u044F \u0434\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0430
    \xAB\u0415\u0434\u0438\u043D\u043E\u0435 \u0432\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C\xBB,
    \u043E\u043D \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0441\u044F,
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0443
    \u0437\u0443\u0431\u043E\u0447\u0438\u0441\u0442\u043A\u043E\u0439, \u0437\u0430\u043A\u0440\u044B\u043B
    \u043A\u043D\u0438\u0433\u0443, \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0435 \u0438, \u043E\u0442\u043A\u0430\u0437\u0430\u0432\u0448\u0438\u0441\u044C
    \u043E\u0442 \u0435\u0434\u044B \u0438 \u043F\u0438\u0442\u044C\u044F, \u043F\u0440\u0435\u0434\u0430\u043B\u0441\u044F
    \u043C\u043E\u043B\u0438\u0442\u0432\u0435. \u0415\u0433\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u043C\u0438
    \u0441\u043B\u043E\u0432\u0430\u043C\u0438 \u0431\u044B\u043B\u043E \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u043A \u0411\u043E\u0433\u0443: \xAB\u041F\u043E \u043C\u0435\u0440\u0435 \u0441\u0432\u043E\u0438\u0445
    \u0441\u0438\u043B \u044F \u0441\u0442\u0430\u0440\u0430\u043B\u0441\u044F \u043F\u043E\u0437\u043D\u0430\u0442\u044C
    \u0422\u0435\u0431\u044F. \u041F\u0440\u043E\u0441\u0442\u0438 \u043C\u0435\u043D\u044F!
    \u041F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443 \u044F \u043F\u043E\u0437\u043D\u0430\u043B
    \u0422\u0435\u0431\u044F, \u043F\u043E\u0441\u0442\u043E\u043B\u044C\u043A\u0443
    \u044F \u043A \u0422\u0435\u0431\u0435 \u043F\u0440\u0438\u0431\u043B\u0438\u0437\u0438\u043B\u0441\u044F\xBB. 
    ### \U0001F494 \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C:
    \u0422\u0430\u0439\u043D\u044B \u0438 \u0434\u043E\u043C\u044B\u0441\u043B\u044B 
    \u0412\u043E\u043F\u0440\u043E\u0441 \u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0425\u0430\u0439\u044F\u043C\u0430 \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0433\u043B\u0430\u0432\u043D\u044B\u0445
    \u0437\u0430\u0433\u0430\u0434\u043E\u043A \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438.
    \u0418\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0438 \u0445\u0440\u0430\u043D\u044F\u0442
    \u043F\u043E\u0447\u0442\u0438 \u043F\u043E\u043B\u043D\u043E\u0435 \u043C\u043E\u043B\u0447\u0430\u043D\u0438\u0435
    \u043D\u0430 \u044D\u0442\u0443 \u0442\u0435\u043C\u0443.  *   **\u0416\u0435\u043D\u0430:**
    \u041D\u0435\u0442 \u043D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E \u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E\u0433\u043E
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0438\u043C\u044F \u0435\u0433\u043E
    \u0436\u0435\u043D\u044B. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442
    \u043B\u0438\u0448\u044C \u043F\u043E\u0437\u0434\u043D\u0438\u0435 \u0438 \u043D\u0435\u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u043D\u044B\u0435
    \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F,
    \u0447\u0442\u043E \u043E\u043D \u043C\u043E\u0433 \u0431\u044B\u0442\u044C \u0436\u0435\u043D\u0430\u0442
    \xAB\u043D\u0430 \u0436\u0435\u043D\u0449\u0438\u043D\u0435 \u0431\u043B\u0430\u0433\u043E\u0433\u043E
    \u043D\u0440\u0430\u0432\u0430\xBB \u0438\u0437 \u041D\u0438\u0448\u0430\u043F\u0443\u0440\u0430.
    *   **\u0414\u0435\u0442\u0438:** \u0418\u0441\u0442\u043E\u0440\u0438\u043A
    \u0418\u0431\u043D \u0430\u043B\u044C-\u041A\u0438\u0444\u0442\u0438 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0443 \u0425\u0430\u0439\u044F\u043C\u0430 \u0431\u044B\u043B
    \u0441\u044B\u043D, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0443\u043C\u0435\u0440
    \u0432 \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438, \u043D\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0441\u0442\u0435\u0439
    \u043E\u0431 \u044D\u0442\u043E\u043C \u043D\u0435\u0442. \u0412\u0441\u0435
    \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B \u043E \u0434\u043E\u0447\u0435\u0440\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043F\u043E\u0437\u0434\u043D\u0438\u0445
    \u043A\u043D\u0438\u0433\u0430\u0445, \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u044B\u043C \u0432\u044B\u043C\u044B\u0441\u043B\u043E\u043C.
    *   **\u041F\u0440\u0438\u0447\u0438\u043D\u044B:** \u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0438
    \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u044E\u0442 \u044D\u0442\u043E \u0441
    \u0442\u0435\u043C, \u0447\u0442\u043E \u0434\u043B\u044F \u0441\u0440\u0435\u0434\u043D\u0435\u0432\u0435\u043A\u043E\u0432\u044B\u0445
    \u0445\u0440\u043E\u043D\u0438\u0441\u0442\u043E\u0432 \u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u043D\u0435
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0430 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0430
    \u043F\u043E \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044E \u0441 \u0435\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430\u043C\u0438. \u0421\u0430\u043C \u0425\u0430\u0439\u044F\u043C,
    \u0441\u0443\u0434\u044F \u043F\u043E \u0435\u0433\u043E \u043F\u043E\u044D\u0437\u0438\u0438,
    \u0432\u0435\u043B \u043A\u043E\u0447\u0435\u0432\u043E\u0439 \u043E\u0431\u0440\u0430\u0437
    \u0436\u0438\u0437\u043D\u0438, \u0431\u044B\u043B \u043F\u043E\u0433\u0440\u0443\u0436\u0435\u043D
    \u0432 \u043D\u0430\u0443\u043A\u0443 \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E
    \u0438, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043D\u0435 \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F
    \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u0441\u0435\u043C\u044C\u0438.  \u041E\u043C\u0430\u0440 \u0425\u0430\u0439\u044F\u043C
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0435\u0442 \u043F\u0435\u0440\u0435\u0434
    \u043D\u0430\u043C\u0438 \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A,
    \u0434\u043B\u044F \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u0432 \u0436\u0438\u0437\u043D\u0438 \u0431\u044B\u043B\u043E \u0441\u043B\u0443\u0436\u0435\u043D\u0438\u0435
    \u043D\u0430\u0443\u043A\u0435 \u0438 \u0438\u0441\u0442\u0438\u043D\u0435, \u0430
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u044B\u0435 \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u043D\u0438\u044F
    \u0438 \u0431\u044B\u0442\u043E\u0432\u044B\u0435 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0441\u0442\u0438
    \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C \u0437\u0430 \u0440\u0430\u043C\u043A\u0430\u043C\u0438
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438."
  personalLifeEn: 
  shortBioRu: "\u041E\u043C\u0430\u0301\u0440 \u0425\u0430\u0439\u044F\u0301\u043C
    \u2014 \u0444\u0438\u0433\u0443\u0440\u0430, \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0430\u044F
    \u0441\u0432\u043E\u0451 \u0432\u0440\u0435\u043C\u044F. \u0414\u043B\u044F \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u0430
    \u043E\u043D \u2014 \u0430\u0432\u0442\u043E\u0440 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445
    \u0447\u0435\u0442\u0432\u0435\u0440\u043E\u0441\u0442\u0438\u0448\u0438\u0439,
    \u043D\u043E \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u043E\u043D \u0431\u044B\u043B
    \u043F\u0440\u0435\u0436\u0434\u0435 \u0432\u0441\u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0447\u0451\u043D\u044B\u043C: \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C. \u0415\u0433\u043E
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u2014 \u044D\u0442\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u044B\u0442\u0430\u043B\u0441\u044F
