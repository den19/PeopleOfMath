    \u0443\u043C\u0430.  ### \U0001F319 \u041A\u0440\u0430\u0442\u0435\u0440 \u043D\u0430
    \u041B\u0443\u043D\u0435 \u0438 \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043E\u0448\u0438\u0431\u043A\u0430  \u041A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u0441\u0432\u044F\u0437\u0430\u043D\u044B
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0441 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u043C\u0438, \u043D\u043E
    \u0438 \u0441 \u0442\u0435\u043C, \u043A\u0430\u043A \u0435\u0433\u043E \u0438\u043C\u044F
    \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u0438\u043C\u0430\u043B\u043E\u0441\u044C
    \u0432\u0435\u043A\u0430\u043C\u0438 \u0441\u043F\u0443\u0441\u0442\u044F.  *  
    **\u0418\u043C\u044F \u043D\u0430 \u041B\u0443\u043D\u0435**: \u0412 1970 \u0433\u043E\u0434\u0443
    \u0432 \u0447\u0435\u0441\u0442\u044C \u041E\u043C\u0430\u0440\u0430 \u0425\u0430\u0439\u044F\u043C\u0430
