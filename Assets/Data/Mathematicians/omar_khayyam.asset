    \u0432\u0435\u0434\u044C \u043E\u043D \u0442\u0430\u043A \u043C\u043D\u043E\u0433\u043E
    \u0441\u0434\u0435\u043B\u0430\u043B \u0434\u043B\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438.
    *   **\"\u0414\u0432\u0430 \u0440\u0430\u0437\u043D\u044B\u0445 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430\"**:
    \u0412 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0438
    \u0411\u0440\u043E\u043A\u0433\u0430\u0443\u0437\u0430 \u0438 \u0415\u0444\u0440\u043E\u043D\u0430,
    \u0438\u0437\u0434\u0430\u043D\u043D\u043E\u0439 \u0432 \u0434\u043E\u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u0420\u043E\u0441\u0441\u0438\u0438, \u0425\u0430\u0439\u044F\u043C\u0443-\u043F\u043E\u044D\u0442\u0443
