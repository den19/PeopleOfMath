    \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043D\u0430\u0443\u043A\u0438 \u0438 \u043E\u0441\u043C\u044B\u0441\u043B\u0438\u0442\u044C
    \u043C\u0435\u0441\u0442\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    \u0432 \u043D\u0435\u0439 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043F\u043E\u044D\u0437\u0438\u0438. 
    ### \U0001F4DC \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0432\u0435\u0445\u0438
    \u0436\u0438\u0437\u043D\u0438: \u043E\u0442 \u043F\u0430\u043B\u0430\u0442\u043E\u0447\u043D\u043E\u0439
    \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439 \u0434\u043E \u0434\u0432\u043E\u0440\u0446\u043E\u0432\u043E\u0439
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438  **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B** \u041E\u043C\u0430\u0440
    \u0425\u0430\u0439\u044F\u043C, \u043F\u043E\u043B\u043D\u043E\u0435 \u0438\u043C\u044F
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E **\u0413\u0438\u044F\u0441\u0430\u0434\u0434\u0438\u043D
    \u0410\u0431\u0443-\u043B\u044C-\u0424\u0430\u0442\u0445 \u041E\u043C\u0430\u0440
    \u0438\u0431\u043D \u0418\u0431\u0440\u0430\u0445\u0438\u043C \u041D\u0438\u0448\u0430\u043F\u0443\u0440\u0438**,
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F **18 \u043C\u0430\u044F 1048 \u0433\u043E\u0434\u0430**
    \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u041D\u0438\u0448\u0430\u043F\u0443\u0440
    (\u043E\u0431\u043B\u0430\u0441\u0442\u044C \u0425\u043E\u0440\u0430\u0441\u0430\u043D,
    \u043D\u0430 \u0441\u0435\u0432\u0435\u0440\u043E-\u0432\u043E\u0441\u0442\u043E\u043A\u0435
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E \u0418\u0440\u0430\u043D\u0430).
    \u0415\u0433\u043E \u0444\u0430\u043C\u0438\u043B\u0438\u044F, \u0425\u0430\u0439\u044F\u043C,
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442 \u043E\u0442 \u0441\u043B\u043E\u0432\u0430
    `\u0445\u0430\u0439\u043C\u0430` \u2014 \u043F\u0430\u043B\u0430\u0442\u043A\u0430,
    \u0438, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0430
    \u043D\u0430 \u0440\u0435\u043C\u0435\u0441\u043B\u043E \u0435\u0433\u043E \u043E\u0442\u0446\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u043B \u043C\u0430\u0441\u0442\u0435\u0440\u043E\u043C
    \u043F\u043E \u0438\u0437\u0433\u043E\u0442\u043E\u0432\u043B\u0435\u043D\u0438\u044E
    \u043F\u0430\u043B\u0430\u0442\u043E\u043A. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u044D\u0442\u043E, \u0441\u0435\u043C\u044C\u044F \u0431\u044B\u043B\u0430
    \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u0430,
    \u0447\u0442\u043E\u0431\u044B \u0434\u0430\u0442\u044C \u0441\u044B\u043D\u0443
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435. 
    \u0421 \u0440\u0430\u043D\u043D\u0438\u0445 \u043B\u0435\u0442 \u041E\u043C\u0430\u0440
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438 \u043A \u043D\u0430\u0443\u043A\u0430\u043C.
    \u041E\u043A\u043E\u043B\u043E 12 \u043B\u0435\u0442 \u043E\u043D \u043D\u0430\u0447\u0430\u043B
    \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435 \u0432 \u043C\u0435\u0434\u0440\u0435\u0441\u0435
    \u041D\u0438\u0448\u0430\u043F\u0443\u0440\u0430, \u0433\u0434\u0435 \u0438\u0437\u0443\u0447\u0430\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443, \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044E,
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E \u0438 \u043C\u0443\u0441\u0443\u043B\u044C\u043C\u0430\u043D\u0441\u043A\u043E\u0435
    \u043F\u0440\u0430\u0432\u043E. \u041F\u043E\u0437\u0436\u0435 \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B
