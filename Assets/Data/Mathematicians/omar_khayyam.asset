    \u041B\u0443\u043D\u044B. \u0412\u0435\u0441\u044C\u043C\u0430 \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u043D\u043E,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0438\u043C\u044F \u0443\u0432\u0435\u043A\u043E\u0432\u0435\u0447\u0438\u043B\u0438
