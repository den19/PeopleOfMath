    \u041E\u043D \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u044D\u0440\u0443\u0434\u0438\u0442\u043E\u043C, \u0430 \u0440\u0435\u0444\u043E\u0440\u043C\u0430\u0442\u043E\u0440\u043E\u043C,
    \u0447\u044C\u0438 \u0438\u0434\u0435\u0438 \u043D\u0430 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F
