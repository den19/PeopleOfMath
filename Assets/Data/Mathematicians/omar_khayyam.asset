    \u0438 \u043E\u043F\u0430\u043B\u044B \u0435\u0433\u043E \u0432\u0438\u0437\u0438\u0440\u044F.
    \u0425\u0430\u0439\u044F\u043C \u043F\u043E\u0442\u0435\u0440\u044F\u043B \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E,
    \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F \u0441 \u043D\u0435\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u043E\u0440\u0442\u043E\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0434\u0443\u0445\u043E\u0432\u0435\u043D\u0441\u0442\u0432\u0430 \u0438 \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u0431\u044B\u043B \u043F\u043E\u043A\u0438\u043D\u0443\u0442\u044C \u0418\u0441\u0444\u0430\u0445\u0430\u043D. 
    \u041E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0432 \u041C\u0435\u043A\u043A\u0443 (\u0445\u0430\u0434\u0436), \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u0432 \u0440\u043E\u0434\u043D\u043E\u0439
    \u041D\u0438\u0448\u0430\u043F\u0443\u0440, \u0433\u0434\u0435 \u043F\u0440\u043E\u0432\u0451\u043B
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438. \u0412 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434
    \u043E\u043D \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E,
    \u043F\u0438\u0441\u0430\u043B \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B
    \u0438, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    \u0440\u0443\u0431\u0430\u0438. \u041E\u043C\u0430\u0440 \u0425\u0430\u0439\u044F\u043C
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F **4 \u0434\u0435\u043A\u0430\u0431\u0440\u044F
    1131 \u0433\u043E\u0434\u0430** \u0432 \u041D\u0438\u0448\u0430\u043F\u0443\u0440\u0435
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 83 \u043B\u0435\u0442.
    \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u043B\u0435\u0433\u0435\u043D\u0434\u0430,
    \u0447\u0442\u043E \u043E\u043D \u0443\u043C\u0435\u0440, \u0447\u0438\u0442\u0430\u044F
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442 \u0410\u0432\u0438\u0446\u0435\u043D\u043D\u044B
    (\u0418\u0431\u043D \u0421\u0438\u043D\u044B), \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u043F\u043E\u0447\u0438\u0442\u0430\u043B. 
    ### \U0001F9E0 \u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435:
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C 
    \u0425\u0430\u0439\u044F\u043C-\u0443\u0447\u0451\u043D\u044B\u0439 \u0431\u044B\u043B
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D \u0435\u0449\u0451 \u043F\u0440\u0438
    \u0436\u0438\u0437\u043D\u0438, \u0435\u0433\u043E \u0442\u0438\u0442\u0443\u043B\u043E\u0432\u0430\u043B\u0438
    \xAB\u0426\u0430\u0440\u0451\u043C \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u0432
    \u0412\u043E\u0441\u0442\u043E\u043A\u0430 \u0438 \u0417\u0430\u043F\u0430\u0434\u0430\xBB
    \u0438 \xAB\u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0418\u0441\u0442\u0438\u043D\u044B\xBB.  *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:**
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434
    \u2014 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0435\u0442\u043E\u0434 \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u0435\u0447\u0435\u043D\u0438\u0439
    \u0438 \u0434\u0430\u043B \u0438\u0445 \u043F\u043E\u043B\u043D\u0443\u044E \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044E.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043D\u0430\u0434 \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u0445
    \u043B\u0438\u043D\u0438\u0439, \u0435\u0433\u043E \u0438\u0434\u0435\u0438 \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0438
    \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043D\u0435\u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0432 \u0415\u0432\u0440\u043E\u043F\u0435.
    *   **\u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F:** \u0415\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C
    \u0441\u0442\u0430\u043B \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044C
    \xAB\u0414\u0436\u0430\u043B\u0430\u043B\u0438\xBB, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0432 \u0418\u0440\u0430\u043D\u0435 \u0438 \u0410\u0444\u0433\u0430\u043D\u0438\u0441\u0442\u0430\u043D\u0435
    \u043A\u0430\u043A \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u043F\u0435\u0440\u0441\u0438\u0434\u0441\u043A\u0438\u0439 \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044C. 
    ### \u270D \xAB\u0420\u0443\u0431\u0430\u0439\u044F\u0442\xBB: \u0437\u0430\u0433\u0430\u0434\u043A\u0430
    \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u043F\u043E\u044D\u0442\u0430 
    \u0412\u0441\u0435\u043C\u0438\u0440\u043D\u0443\u044E \u0441\u043B\u0430\u0432\u0443,
    \u043F\u0440\u0438\u0448\u0435\u0434\u0448\u0443\u044E \u043A \u043D\u0435\u043C\u0443
    \u0441\u043F\u0443\u0441\u0442\u044F \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F,
    \u041E\u043C\u0430\u0440\u0443 \u0425\u0430\u0439\u044F\u043C\u0443 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0438
    \u0447\u0435\u0442\u0432\u0435\u0440\u043E\u0441\u0442\u0438\u0448\u0438\u044F
    \u2014 **\u0440\u0443\u0431\u0430\u0438**.  \u0413\u043B\u0430\u0432\u043D\u0430\u044F
    \u0437\u0430\u0433\u0430\u0434\u043A\u0430 \u0435\u0433\u043E \u043F\u043E\u044D\u0437\u0438\u0438
    \u2014 **\u0430\u0442\u0440\u0438\u0431\u0443\u0446\u0438\u044F**. \u0414\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u043E, \u0447\u0442\u043E \u0435\u043C\u0443
    \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u0442 \u0432\u0441\u0435\u0433\u043E
    **\u043E\u043A\u043E\u043B\u043E 66 \u0440\u0443\u0431\u0430\u0438** \u0438\u0437
    \u0434\u0440\u0435\u0432\u043D\u0435\u0439\u0448\u0438\u0445 \u0441\u043F\u0438\u0441\u043A\u043E\u0432.
    \u041E\u0431\u0449\u0435\u0435 \u0436\u0435 \u0447\u0438\u0441\u043B\u043E \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u043C\u044B\u0445
    \u0435\u043C\u0443 \u0441\u0442\u0438\u0445\u043E\u0432 \u0434\u043E\u0441\u0442\u0438\u0433\u0430\u0435\u0442
    5000. \u042D\u0442\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u043E \u0441 \u0442\u0435\u043C,
    \u0447\u0442\u043E \u0432\u043E\u043B\u044C\u043D\u043E\u0434\u0443\u043C\u043D\u0430\u044F
    \u043F\u043E\u044D\u0437\u0438\u044F \u0425\u0430\u0439\u044F\u043C\u0430 \u0431\u044B\u043B\u0430
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u0430, \u0438 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0430\u0432\u0442\u043E\u0440\u044B, \u0431\u043E\u044F\u0432\u0448\u0438\u0435\u0441\u044F
    \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439,
    \u043F\u0440\u0438\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438 \u0435\u043C\u0443
    \u0441\u0432\u043E\u0438 \u0441\u0442\u0438\u0445\u0438, \u0430 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u0447\u0438\u043A\u0438
    \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u043B\u0438 \u0438\u0445 \u0432 \u0441\u0431\u043E\u0440\u043D\u0438\u043A\u0438. 
    \u0422\u0435\u043C\u044B \u0435\u0433\u043E \u043F\u043E\u0434\u043B\u0438\u043D\u043D\u044B\u0445
    \u0447\u0435\u0442\u0432\u0435\u0440\u043E\u0441\u0442\u0438\u0448\u0438\u0439
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0441\u043E\u0437\u0432\u0443\u0447\u043D\u044B
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C\u0443 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0443:
    *   **\u0421\u043A\u0435\u043F\u0442\u0438\u0446\u0438\u0437\u043C \u0438 \u0431\u043E\u0433\u043E\u0431\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u043E:**
    \u041E\u043D \u0441\u043E\u043C\u043D\u0435\u0432\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E\u0441\u0442\u0438
    \u043C\u0438\u0440\u043E\u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430,
    \u043F\u043E\u0434\u0432\u0435\u0440\u0433\u0430\u0435\u0442 \u0441\u043E\u043C\u043D\u0435\u043D\u0438\u044E
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435 \u0434\u043E\u0433\u043C\u044B,
    \u0432\u044B\u0441\u043C\u0435\u0438\u0432\u0430\u0435\u0442 \u043B\u0438\u0446\u0435\u043C\u0435\u0440\u0438\u0435
    \u0434\u0443\u0445\u043E\u0432\u0435\u043D\u0441\u0442\u0432\u0430. *   **\u0411\u0440\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0431\u044B\u0442\u0438\u044F:** \u041C\u044B\u0441\u043B\u0438 \u043E \u043D\u0435\u043E\u0442\u0432\u0440\u0430\u0442\u0438\u043C\u043E\u0441\u0442\u0438
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0438 \u043D\u0435\u043F\u043E\u0441\u0442\u0438\u0436\u0438\u043C\u043E\u0441\u0442\u0438
    \u0441\u0443\u0434\u044C\u0431\u044B, \u043D\u043E\u0441\u0442\u0430\u043B\u044C\u0433\u0438\u044F
    \u043F\u043E \u0443\u0445\u043E\u0434\u044F\u0449\u0435\u0439 \u0436\u0438\u0437\u043D\u0438.
    *   **\u0413\u0435\u0434\u043E\u043D\u0438\u0437\u043C:** \u041F\u0440\u0438\u0437\u044B\u0432
    \u043D\u0430\u0441\u043B\u0430\u0436\u0434\u0430\u0442\u044C\u0441\u044F \u043A\u0430\u0436\u0434\u044B\u043C
    \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u0438\u0435\u043C, \u0446\u0435\u043D\u0438\u0442\u044C
    \u0440\u0430\u0434\u043E\u0441\u0442\u0438 \u0436\u0438\u0437\u043D\u0438 \u2014
    \u0432\u0438\u043D\u043E, \u043B\u044E\u0431\u043E\u0432\u044C, \u043A\u0440\u0430\u0441\u043E\u0442\u0443
    \u043F\u0440\u0438\u0440\u043E\u0434\u044B \u2014 \u0432\u043E\u043F\u0440\u0435\u043A\u0438
    \u043D\u0435\u0438\u0437\u0431\u0435\u0436\u043D\u043E\u0441\u0442\u0438 \u043A\u043E\u043D\u0446\u0430. 
    \u0421\u0442\u0438\u043B\u044C \u0425\u0430\u0439\u044F\u043C\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u043E
    \u043B\u0430\u043A\u043E\u043D\u0438\u0447\u0435\u043D \u0438 \u0442\u043E\u0447\u0435\u043D,
    \u043A\u0430\u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u043E\u0440\u043C\u0443\u043B\u0430, \u0437\u0430 \u0447\u0442\u043E \u0435\u0433\u043E
    \u0438 \u043F\u043E\u043B\u044E\u0431\u0438\u043B\u0438 \u043C\u0438\u043B\u043B\u0438\u043E\u043D\u044B
    \u0447\u0438\u0442\u0430\u0442\u0435\u043B\u0435\u0439 \u043F\u043E \u0432\u0441\u0435\u043C\u0443
    \u043C\u0438\u0440\u0443. \u0421\u0432\u043E\u0435\u0439 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u044C\u044E
    \u043D\u0430 \u0417\u0430\u043F\u0430\u0434\u0435 \u043E\u043D \u043E\u0431\u044F\u0437\u0430\u043D
    \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u043C\u0443 \u043F\u043E\u044D\u0442\u0443
    \u042D\u0434\u0432\u0430\u0440\u0434\u0443 \u0424\u0438\u0446\u0434\u0436\u0435\u0440\u0430\u043B\u044C\u0434\u0443,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432 1859 \u0433\u043E\u0434\u0443
    \u0432\u044B\u043F\u0443\u0441\u0442\u0438\u043B \u0441\u0432\u043E\u0439 \u0432\u043E\u043B\u044C\u043D\u044B\u0439,
    \u043D\u043E \u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u043E
    \u043F\u043E\u044D\u0442\u0438\u0447\u043D\u044B\u0439 \u043F\u0435\u0440\u0435\u0432\u043E\u0434
    \xAB\u0420\u0443\u0431\u0430\u0439\u044F\u0442\u0430\xBB.  \u0418\u0442\u0430\u043A,
    \u041E\u043C\u0430\u0440 \u0425\u0430\u0439\u044F\u043C \u2014 \u044D\u0442\u043E
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u044D\u0442, \u0430
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u0439
    \u0433\u0435\u043D\u0438\u0439, \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u0441\u043B\u0443\u0436\u0435\u043D\u0438\u044E \u0438\u0441\u0442\u0438\u043D\u0435.
    \u0415\u0433\u043E \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u2014 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u0441\u043F\u043B\u0430\u0432 \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F \u0438 \u043F\u043E\u044D\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0435\u043D\u0438\u044F, \u0441\u043A\u0432\u043E\u0437\u044C
    \u0432\u0435\u043A\u0430 \u043E\u0431\u0440\u0430\u0449\u0451\u043D\u043D\u044B\u0439
    \u043A \u043D\u0430\u043C."
  shortBioEn: 
  interestingFactsRu: "\u041B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u041E\u043C\u0430\u0440\u0430
    \u0425\u0430\u0439\u044F\u043C\u0430, \u0441\u043E\u0447\u0435\u0442\u0430\u0432\u0448\u0435\u0433\u043E
    \u0432 \u0441\u0435\u0431\u0435 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u0438 \u043F\u043E\u044D\u0442\u0430-\u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430,
    \u043F\u043E\u0434\u0430\u0440\u0438\u043B\u0430 \u043D\u0430\u043C \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u0439
    \u0438 \u0444\u0430\u043A\u0442\u043E\u0432. \u0412\u043E\u0442 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438 \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0445, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u0440\u0438\u043E\u0442\u043A\u0440\u044B\u0432\u0430\u044E\u0442 \u0437\u0430\u0432\u0435\u0441\u0443
    \u0442\u0430\u0439\u043D\u044B \u043D\u0430\u0434 \u044D\u0442\u0438\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C. 
    ### \U0001F92F \"\u0425\" \u0438 \"\u0411\u0438\u043D\u043E\u043C \u041D\u044C\u044E\u0442\u043E\u043D\u0430\":
    \u043A\u0430\u043A \u0425\u0430\u0439\u044F\u043C \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B
    \u0432\u0440\u0435\u043C\u044F  \u041E\u0434\u043D\u0438\u043C \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0442\u043E, \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u043E\u0437\u0440\u0435\u043D\u0438\u044F \u0425\u0430\u0439\u044F\u043C\u0430
    \u043D\u0430 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F \u043E\u0431\u043E\u0433\u043D\u0430\u043B\u0438
    \u0441\u0432\u043E\u0435 \u0432\u0440\u0435\u043C\u044F. \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C,
    \u0447\u0442\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F,
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u044B\u0435 \u0438\u043C,
    \u043F\u043E\u0437\u0436\u0435 \u043F\u0435\u0440\u0435\u043E\u0442\u043A\u0440\u044B\u043B\u0438
    \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0435 \u0443\u0447\u0435\u043D\u044B\u0435: 
    *   **\u0412\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \"\u0445\"**: \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E
    \u0438\u043C\u0435\u043D\u043D\u043E \u041E\u043C\u0430\u0440 \u0425\u0430\u0439\u044F\u043C
    \u043F\u0435\u0440\u0432\u044B\u043C \u0432\u0432\u0435\u043B \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u044B, \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0438\u0432
    \u0435\u0435 \u0431\u0443\u043A\u0432\u043E\u0439 \"\u0445\". \u042D\u0442\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435, \u0431\u0435\u0437 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043D\u0435\u043C\u044B\u0441\u043B\u0438\u043C\u0430 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430. *   **\u041F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u0435
    \u0431\u0438\u043D\u043E\u043C\u0430 \u041D\u044C\u044E\u0442\u043E\u043D\u0430**:
    \u0417\u0430\u0434\u043E\u043B\u0433\u043E \u0434\u043E \u0418\u0441\u0430\u0430\u043A\u0430
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u0425\u0430\u0439\u044F\u043C \u043E\u043F\u0438\u0441\u0430\u043B
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0431\u0438\u043D\u043E\u043C\u0430
    \u0434\u043B\u044F \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u0435\u0439. \u0421\u043F\u0443\u0441\u0442\u044F
    \u043F\u043E\u0447\u0442\u0438 600 \u043B\u0435\u0442 \u041D\u044C\u044E\u0442\u043E\u043D,
    \u043E\u0442\u043A\u0440\u044B\u0432\u0448\u0438\u0439 \u0435\u0435 \u0437\u0430\u043D\u043E\u0432\u043E,
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u043E \u0431\u0438\u043D\u043E\u043C\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u0430\u0445.
    \u041F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0447\u0442\u043E \u0432 \u043B\u0435\u0433\u0435\u043D\u0434\u0435 \u043E \u043F\u0430\u0434\u0430\u044E\u0449\u0435\u043C
    \u044F\u0431\u043B\u043E\u043A\u0435, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u044F\u043A\u043E\u0431\u044B \u043D\u0430\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0430
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u043D\u0430 \u043C\u044B\u0441\u043B\u044C
    \u043E \u0437\u0430\u043A\u043E\u043D\u0435 \u0442\u044F\u0433\u043E\u0442\u0435\u043D\u0438\u044F,
    \u043C\u043E\u0436\u043D\u043E \u0443\u0432\u0438\u0434\u0435\u0442\u044C \u043E\u0442\u0433\u043E\u043B\u043E\u0441\u043E\u043A
    \u0430\u043D\u0430\u043B\u043E\u0433\u0438\u0447\u043D\u043E\u0433\u043E \u043F\u0440\u0438\u043C\u0435\u0440\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B
    \u0432 \u0441\u0432\u043E\u0438\u0445 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
