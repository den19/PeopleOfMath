    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0430\u0431\u043E\u0440
    \u0442\u0435\u043E\u0440\u0435\u043C, \u0430 \u0446\u0435\u043B\u0430\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F,
    \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    **\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u2014 \u044D\u0442\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u0439
