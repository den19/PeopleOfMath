    \u0447\u0430\u0441\u0442\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043A\u0430\u043A \u041C\u0438\u0448\u0430 \u0413\u0440\u043E\u043C\u043E\u0432)
    \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0441\u0442\u0438,
    \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
