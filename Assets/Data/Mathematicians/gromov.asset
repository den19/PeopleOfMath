    \u041B\u0435\u043E\u043D\u0438\u0434\u043E\u0432\u0438\u0447\u0435 \u0432\u0435\u0441\u044C\u043C\u0430
    \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u044B. \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u0447\u0442\u043E \u0432 **1967 \u0433\u043E\u0434\u0443** \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 **\u041C\u0430\u0440\u0433\u0430\u0440\u0438\u0442\u0435 \u0413\u0440\u043E\u043C\u043E\u0432\u043E\u0439**
    (\u0434\u0435\u0432\u0438\u0447\u044C\u044F \u0444\u0430\u043C\u0438\u043B\u0438\u044F
    \u043D\u0435 \u0443\u043A\u0430\u0437\u0430\u043D\u0430). \u0411\u044B\u043B
    \u043B\u0438 \u044D\u0442\u043E\u0442 \u0431\u0440\u0430\u043A \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C,
    \u0435\u0441\u0442\u044C \u043B\u0438 \u0443 \u043D\u0435\u0433\u043E \u0434\u0435\u0442\u0438
    \u2014 \u0432 \u043D\u0430\u0439\u0434\u0435\u043D\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445
    \u044D\u0442\u0438 \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u043D\u0435
    \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u044E\u0442\u0441\u044F.  \u0412\u0441\u044F
    \u0435\u0433\u043E \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C,
    \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u043E \u044D\u0442\u0438\u043C \u0434\u0430\u043D\u043D\u044B\u043C,
    \u2014 \u044D\u0442\u043E \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430.
    \u041F\u043E\u0441\u043B\u0435 \u044D\u043C\u0438\u0433\u0440\u0430\u0446\u0438\u0438
    \u0438\u0437 \u0421\u0421\u0421\u0420 \u0432 1974 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B \u0441\u0435\u0431\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0438\u0432\u0448\u0438\u0441\u044C
