    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0412 2009 \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0447\u0430\u0441\u0442\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \xAB\u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0435\u0439
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435\xBB,
    \u0437\u0430 \u0441\u0432\u043E\u0439 \xAB\u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u0438\u0437\u0438\u0440\u0443\u044E\u0449\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E\xBB. 
    \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E.  ### \U0001F9EC \u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B, \u0441\u0435\u043C\u044C\u044F \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 
    \u041C\u0438\u0445\u0430\u0438\u043B \u041B\u0435\u043E\u043D\u0438\u0434\u043E\u0432\u0438\u0447
    \u0413\u0440\u043E\u043C\u043E\u0432 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    **23 \u0434\u0435\u043A\u0430\u0431\u0440\u044F 1943 \u0433\u043E\u0434\u0430**
    \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 **\u0411\u043E\u043A\u0441\u0438\u0442\u043E\u0433\u043E\u0440\u0441\u043A\u0435
    \u041B\u0435\u043D\u0438\u043D\u0433\u0440\u0430\u0434\u0441\u043A\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438**. \u0415\u0433\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C \u043D\u0430 \u0442\u044F\u0436\u0435\u043B\u043E\u0435
    \u0432\u043E\u0435\u043D\u043D\u043E\u0435 \u0432\u0440\u0435\u043C\u044F: \u0435\u0433\u043E
    \u043C\u0430\u0442\u044C, \u0432\u043E\u0435\u043D\u043D\u044B\u0439 \u0432\u0440\u0430\u0447
    \u041B\u0438\u044F \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u0432\u043D\u0430
    \u0420\u0430\u0431\u0438\u043D\u043E\u0432\u0438\u0447, \u0441\u043B\u0443\u0436\u0438\u043B\u0430
    \u043D\u0430 \u0412\u043E\u043B\u0445\u043E\u0432\u0441\u043A\u043E\u043C \u0444\u0440\u043E\u043D\u0442\u0435
    \u0438 \u0431\u044B\u043B\u0430 \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u0430
    \u043F\u043E\u043A\u0438\u043D\u0443\u0442\u044C \u043F\u0435\u0440\u0435\u0434\u043E\u0432\u0443\u044E,
    \u0447\u0442\u043E\u0431\u044B \u0440\u043E\u0434\u0438\u0442\u044C \u0441\u044B\u043D\u0430.
    \u041E\u0442\u0435\u0446, \u041B\u0435\u043E\u043D\u0438\u0434 \u0418\u043D\u043D\u043E\u043A\u0435\u043D\u0442\u044C\u0435\u0432\u0438\u0447
    \u0413\u0440\u043E\u043C\u043E\u0432, \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B
    \u0432\u043E\u0435\u043D\u043D\u044B\u043C \u0432\u0440\u0430\u0447\u043E\u043C-\u043F\u0430\u0442\u043E\u043B\u043E\u0433\u043E\u0430\u043D\u0430\u0442\u043E\u043C\u043E\u043C.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u043C\u0430\u0442\u044C
    \u041C\u0438\u0445\u0430\u0438\u043B\u0430 \u0413\u0440\u043E\u043C\u043E\u0432\u0430
    \u0431\u044B\u043B\u0430 \u0434\u0432\u043E\u044E\u0440\u043E\u0434\u043D\u043E\u0439
    \u0441\u0435\u0441\u0442\u0440\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E
    \u0448\u0430\u0445\u043C\u0430\u0442\u0438\u0441\u0442\u0430 \u041C\u0438\u0445\u0430\u0438\u043B\u0430
    \u0411\u043E\u0442\u0432\u0438\u043D\u043D\u0438\u043A\u0430.  \u0412 \u0434\u0435\u0442\u0441\u0442\u0432\u0435,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 9 \u043B\u0435\u0442,
    \u043C\u0430\u0442\u044C \u043F\u043E\u0434\u0430\u0440\u0438\u043B\u0430 \u0435\u043C\u0443
    \u043A\u043D\u0438\u0433\u0443 \u0413\u0430\u043D\u0441\u0430 \u0420\u0430\u0434\u0435\u043C\u0430\u0445\u0435\u0440\u0430
    \u0438 \u041E\u0442\u0442\u043E \u0422\u0435\u043F\u043B\u0438\u0446\u0430 \xAB\u042D\u0442\u044E\u0434\u044B
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435\xBB,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B\u0430
    \u0432 \u043D\u0435\u043C \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439 \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.  \u0421\u0432\u043E\u0438
    \u043F\u0435\u0440\u0432\u044B\u0435 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u043D\u0430\u043D\u0438\u044F \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0432 \u041B\u0435\u043D\u0438\u043D\u0433\u0440\u0430\u0434\u0435, \u0433\u0434\u0435
    \u0443\u0447\u0438\u043B\u0441\u044F \u0432 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    217-\u0439 \u0448\u043A\u043E\u043B\u0435 (\u0431\u044B\u0432\u0448\u0430\u044F
    \u041F\u0435\u0442\u0440\u0438\u0448\u0443\u043B\u0435). \u0417\u0430\u0442\u0435\u043C
    \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 **\u041B\u0435\u043D\u0438\u043D\u0433\u0440\u0430\u0434\u0441\u043A\u0438\u0439
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u0432 **1965 \u0433\u043E\u0434\u0443**.
    \u0422\u0430\u043C \u0436\u0435 \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B
    \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u043A\u0430\u0440\u044C\u0435\u0440\u0443
    \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0433\u043E\u0441\u044F \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0430
    **\u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440\u0430 \u0410\u0431\u0440\u0430\u043C\u043E\u0432\u0438\u0447\u0430
    \u0420\u043E\u0445\u043B\u0438\u043D\u0430**. \u0412 1969 \u0433\u043E\u0434\u0443
    \u0413\u0440\u043E\u043C\u043E\u0432 \u0437\u0430\u0449\u0438\u0442\u0438\u043B
    \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E,
    \u0430 \u0432 **1973 \u0433\u043E\u0434\u0443** \u2014 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u043F\u043E
    \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043D\u0430\u0443\u043A\u0430\u043C.  ### \U0001F680 \u041D\u0430\u0443\u0447\u043D\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430  **\u041D\u0430\u0447\u0430\u043B\u043E
    \u0432 \u0421\u0421\u0421\u0420 \u0438 \u044D\u043C\u0438\u0433\u0440\u0430\u0446\u0438\u044F**:
    \u0421 1967 \u0433\u043E\u0434\u0430 \u0413\u0440\u043E\u043C\u043E\u0432 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u041B\u0435\u043D\u0438\u043D\u0433\u0440\u0430\u0434\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u043C
    \u0438 \u0434\u043E\u0446\u0435\u043D\u0442\u043E\u043C, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0432 \u0434\u0440\u0443\u0433\u0438\u0445 \u043D\u0430\u0443\u0447\u043D\u043E-\u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0445
    \u0443\u0447\u0440\u0435\u0436\u0434\u0435\u043D\u0438\u044F\u0445. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u043D\u0435\u0441\u043E\u0433\u043B\u0430\u0441\u0438\u0435
    \u0441 \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439
    \u0438 \u0441\u0442\u0440\u0435\u043C\u043B\u0435\u043D\u0438\u0435 \u043A \u0441\u0432\u043E\u0431\u043E\u0434\u0435
    \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430 \u043F\u0440\u0438\u0432\u0435\u043B\u0438
    \u043A \u0440\u0435\u0448\u0435\u043D\u0438\u044E \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C.
    \u0412 1974 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441 \u0441\u0435\u043C\u044C\u0435\u0439
    \u043F\u043E\u043A\u0438\u043D\u0443\u043B \u0421\u0421\u0421\u0420 \u043F\u043E
    \u0438\u0437\u0440\u0430\u0438\u043B\u044C\u0441\u043A\u043E\u0439 \u0432\u0438\u0437\u0435
    \u0438 \u0447\u0435\u0440\u0435\u0437 \u0418\u0442\u0430\u043B\u0438\u044E \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u0421\u0428\u0410. \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043D\u044B\u043C \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C,
    \u043E\u0442\u043A\u0440\u044B\u0432\u0448\u0438\u043C \u0435\u043C\u0443 \u0434\u043E\u0441\u0442\u0443\u043F
    \u043A \u043C\u0438\u0440\u043E\u0432\u043E\u043C\u0443 \u043D\u0430\u0443\u0447\u043D\u043E\u043C\u0443
    \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0443.  **\u0417\u0430\u0440\u0443\u0431\u0435\u0436\u043D\u044B\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434**: *   **\u0421\u0428\u0410 (1974\u20131981):**
    \u0421\u0440\u0430\u0437\u0443 \u043F\u043E\u0441\u043B\u0435 \u043F\u0435\u0440\u0435\u0435\u0437\u0434\u0430
    \u0413\u0440\u043E\u043C\u043E\u0432 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043C\u0435\u0441\u0442\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0432 **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0448\u0442\u0430\u0442\u0430 \u041D\u044C\u044E-\u0419\u043E\u0440\u043A \u0432
    \u0421\u0442\u043E\u0443\u043D\u0438-\u0411\u0440\u0443\u043A**, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0431\u044B\u043B\u043E \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043D\u043E.
    *   **\u0424\u0440\u0430\u043D\u0446\u0438\u044F (\u0441 1981 \u0433\u043E\u0434\u0430):**
    \u0412 1981 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E. \u0412 1981\u20131982
    \u0433\u043E\u0434\u0430\u0445 \u043E\u043D \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B
    \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u041F\u0430\u0440\u0438\u0436\u0430 VI (\u043D\u044B\u043D\u0435 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u041F\u044C\u0435\u0440\u0430 \u0438 \u041C\u0430\u0440\u0438\u0438 \u041A\u044E\u0440\u0438).
    **\u0412 1982 \u0433\u043E\u0434\u0443** \u043E\u043D \u0441\u0442\u0430\u043B
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u044B\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0433\u043E **\u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430
    \u0432\u044B\u0441\u0448\u0438\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 (IH\xC9S)**
    \u0432 \u0411\u044E\u0440-\u0441\u044E\u0440-\u0418\u0432\u0435\u0442\u0442,
    \u0433\u0434\u0435 \u0437\u0430\u043D\u044F\u043B \u043F\u043E\u0436\u0438\u0437\u043D\u0435\u043D\u043D\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C. \u0412 **1992 \u0433\u043E\u0434\u0443**
    \u0413\u0440\u043E\u043C\u043E\u0432 \u043F\u0440\u0438\u043D\u044F\u043B \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0435
    \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u043E. *   **\u041F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u044C\u043D\u044B\u0435
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438:** \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0443 \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438,
    \u043E\u043D \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B
    \u0432 **\u041C\u044D\u0440\u0438\u043B\u0435\u043D\u0434\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435** (1991\u20131996)
    \u0438 \u0441 **1996 \u0433\u043E\u0434\u0430** \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0432 **\u041A\u0443\u0440\u0430\u043D\u0442\u043E\u0432\u0441\u043A\u043E\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A** \u043F\u0440\u0438 \u041D\u044C\u044E-\u0419\u043E\u0440\u043A\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435.  ###
    \U0001F52C \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F  \u041C\u0438\u0445\u0430\u0438\u043B
    \u0413\u0440\u043E\u043C\u043E\u0432 \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u043A\u0430\u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u043C\u043E\u0442\u0440\u0435\u043B \u043D\u0430 \u0441\u0442\u0430\u0440\u044B\u0435
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0441 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E
    \u043D\u043E\u0432\u043E\u0439, \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u0447\u043A\u0438 \u0437\u0440\u0435\u043D\u0438\u044F. \u0415\u0433\u043E
    \u0438\u0434\u0435\u0438 \u0441\u0442\u0430\u043B\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u0446\u0435\u043B\u044B\u0445 \u043D\u043E\u0432\u044B\u0445
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439.  *   **\\(h\\)-\u043F\u0440\u0438\u043D\u0446\u0438\u043F:**
    \u041E\u0434\u043D\u043E \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0440\u0430\u043D\u043D\u0438\u0445
    \u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439 \u0413\u0440\u043E\u043C\u043E\u0432\u0430
    \u2014 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0430 \u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0430\u0446\u0438\u044F
    \u0442\u0435\u043E\u0440\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C,
    \u043A\u043E\u0433\u0434\u0430 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0437\u0430\u0434\u0430\u0447\u0430 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C
    \u0440\u0435\u0448\u0435\u043D\u0430 \u043A\u0430\u043A \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E-\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F.
    \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u043E\u0439
    \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439
    \u043A\u043D\u0438\u0433\u0438 \xAB\u0414\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0447\u0430\u0441\u0442\u043D\u044B\u043C\u0438
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u0434\u043D\u044B\u043C\u0438\xBB.
    *   **\u0421\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:** \u0413\u0440\u043E\u043C\u043E\u0432
    \u043F\u043E \u043F\u0440\u0430\u0432\u0443 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0441\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438. \u041E\u043D \u0432\u0432\u0435\u043B
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\\(J\\)-\u0433\u043E\u043B\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445
    \u043A\u0440\u0438\u0432\u044B\u0445**, \u0447\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u043E
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0432 \u044D\u0442\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0438 \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E **\u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432
    \u0413\u0440\u043E\u043C\u043E\u0432\u0430\u2013\u0412\u0438\u0442\u0442\u0435\u043D\u0430**,
    \u0432\u0430\u0436\u043D\u044B\u0445 \u0434\u043B\u044F \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u043E\u043B\u044F. \u0415\u0433\u043E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F **\xAB\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043D\u0435\u0432\u044B\u0436\u0438\u043C\u0430\u043D\u0438\u0438\xBB
    (Nonsqueezing theorem)** \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0440\u0430\u0437\u043B\u0438\u0447\u0438\u0435 \u043C\u0435\u0436\u0434\u0443
    \u0441\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0438 \u043E\u0431\u044A\u0435\u043C\u043B\u044E\u0449\u0438\u043C\u0438 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F\u043C\u0438.
    *   **\u0420\u0438\u043C\u0430\u043D\u043E\u0432\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:**
    \u0413\u0440\u043E\u043C\u043E\u0432 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u043D\u043E\u0432\u044B\u0439 \u0432\u0437\u0433\u043B\u044F\u0434 \u043D\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0432 \u0446\u0435\u043B\u043E\u043C,
    \u0438\u0437\u0443\u0447\u0430\u044F \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0433\u043B\u0430\u0434\u043A\u0438\u0435, \u043D\u043E \u0438 \u0431\u043E\u043B\u0435\u0435
    \u043E\u0431\u0449\u0438\u0435 \u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430. \u0421\u0440\u0435\u0434\u0438
    \u0435\u0433\u043E \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432
    \u2014 **\u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u043E \u043F\u043E\u0447\u0442\u0438
    \u043F\u043B\u043E\u0441\u043A\u0438\u0445 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u044F\u0445**,
    **\u043D\u0435\u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u0430 \u0411\u0435\u0442\u0442\u0438**
    \u0438 **\u0441\u0445\u043E\u0434\u0438\u043C\u043E\u0441\u0442\u044C \u0413\u0440\u043E\u043C\u043E\u0432\u0430\u2013\u0425\u0430\u0443\u0441\u0434\u043E\u0440\u0444\u0430**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u043B\u0430 \u043C\u043E\u0449\u043D\u044B\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F \u043A\u043B\u0430\u0441\u0441\u043E\u0432
    \u0440\u0438\u043C\u0430\u043D\u043E\u0432\u044B\u0445 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439.
    *   **\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0433\u0440\u0443\u043F\u043F:** \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430 \xAB\u0413\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u0440\u0443\u043F\u043F\u044B\xBB (Gromov hyperbolic groups) \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0430
    \u043E\u0441\u043D\u043E\u0432\u044B \u0446\u0435\u043B\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u041E\u043D \u043F\u0435\u0440\u0435\u043D\u0435\u0441
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0434\u0435\u0438 (\u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u043A\u0440\u0438\u0432\u0438\u0437\u043D\u0443) \u043D\u0430 \u0434\u0438\u0441\u043A\u0440\u0435\u0442\u043D\u044B\u0435
    \u0433\u0440\u0443\u043F\u043F\u044B, \u0447\u0442\u043E \u0434\u0430\u043B\u043E
    \u043D\u043E\u0432\u044B\u0439 \u043C\u043E\u0449\u043D\u044B\u0439 \u044F\u0437\u044B\u043A
    \u0434\u043B\u044F \u0438\u0445 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **\u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u043E \u0433\u0440\u0443\u043F\u043F\u0430\u0445 \u043F\u043E\u043B\u0438\u043D\u043E\u043C\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0440\u043E\u0441\u0442\u0430**.  \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B \u0442\u0430\u043A\u0436\u0435
    \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u044B \u043A \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438
    \u0438 \u043D\u0435\u0439\u0440\u043E\u043D\u0430\u0443\u043A\u0430\u043C. \u041E\u043D
    \u0438\u0441\u0441\u043B\u0435\u0434\u0443\u0435\u0442 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u0435\u0442\u043E\u0434\u043E\u0432 \u0434\u043B\u044F \u043C\u043E\u0434\u0435\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440, \u044D\u0432\u043E\u043B\u044E\u0446\u0438\u0438
    \u0433\u0435\u043D\u043E\u043C\u043E\u0432 \u0438 \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F
    \u0440\u0430\u0431\u043E\u0442\u044B \u043C\u043E\u0437\u0433\u0430.  ### \U0001F3C6
    \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438 \u043D\u0430\u0433\u0440\u0430\u0434\u044B 
    \u0417\u0430 \u0441\u0432\u043E\u044E \u043A\u0430\u0440\u044C\u0435\u0440\u0443
    \u041C\u0438\u0445\u0430\u0438\u043B \u0413\u0440\u043E\u043C\u043E\u0432 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u0441\u0435
    \u0441\u0430\u043C\u044B\u0435 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0435
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0432 \u043C\u0438\u0440\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    **\u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043F\u0440\u0435\u043C\u0438\u0438**:
    *   **\u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u043F\u0440\u0435\u043C\u0438\u044F
    (2009)** \u2014 \xAB\u0437\u0430 \u0435\u0433\u043E \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u0438\u0437\u0438\u0440\u0443\u044E\u0449\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E\xBB.
    *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0412\u043E\u043B\u044C\u0444\u0430
    (1993)**. *   **\u041C\u0435\u0434\u0430\u043B\u044C \u041B\u043E\u0431\u0430\u0447\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    (1997)**. *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0411\u0430\u043B\u044C\u0446\u0430\u043D\u0430
    (1999)**. *   **\u041F\u0440\u0435\u043C\u0438\u044F \u041A\u0438\u043E\u0442\u043E
    (2002)**. *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0412\u0435\u0431\u043B\u0435\u043D\u0430
    \u043F\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 (1981)**.
    *   **\u041F\u0440\u0435\u043C\u0438\u044F \u041D\u0435\u043C\u043C\u0435\u0440\u0441\u0430
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 (2004)**. 
    **\u0427\u043B\u0435\u043D\u0441\u0442\u0432\u043E \u0432 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044F\u0445
    \u0438 \u0437\u0432\u0430\u043D\u0438\u044F**: *   \u0418\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0439
    \u0447\u043B\u0435\u043D **\u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A (\u0420\u0410\u041D)**
    (2011). *   \u0427\u043B\u0435\u043D **\u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u0424\u0440\u0430\u043D\u0446\u0438\u0438** (\u0441
    1997, \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0439 \u0447\u043B\u0435\u043D
    \u0441 1989). *   \u0418\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0439
    \u0447\u043B\u0435\u043D **\u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A \u0421\u0428\u0410**
    (1989). *   \u0418\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0439
    \u0447\u043B\u0435\u043D **\u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430**
    (2011). *   \u041F\u043E\u0447\u0451\u0442\u043D\u044B\u0439 \u0447\u043B\u0435\u043D
    \u043C\u043D\u043E\u0433\u0438\u0445 \u0434\u0440\u0443\u0433\u0438\u0445 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u043C\u0438\u0440\u0430.  \u041C\u0438\u0445\u0430\u0438\u043B \u0413\u0440\u043E\u043C\u043E\u0432
    \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0449\u0438\u043C \u0443\u0447\u0435\u043D\u044B\u043C
    \u0438 \u0441\u0435\u0433\u043E\u0434\u043D\u044F, \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044F
    \u0440\u0430\u0441\u0448\u0438\u0440\u044F\u0442\u044C \u0433\u0440\u0430\u043D\u0438\u0446\u044B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0435\u0435
    \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0439. \u0415\u0433\u043E
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439, \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0438 \u0447\u0430\u0441\u0442\u043E \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434 \u043A \u0440\u0435\u0448\u0435\u043D\u0438\u044E
    \u0437\u0430\u0434\u0430\u0447 \u0441\u043D\u0438\u0441\u043A\u0430\u043B \u0435\u043C\u0443
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u043A\u0430\u043A \u043E\u0434\u043D\u043E\u043C\u0443
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u0443\u043C\u043E\u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0441\u0442\u0438."
  shortBioEn: 
  interestingFactsRu: "\u041C\u0438\u0445\u0430\u0438\u043B \u0413\u0440\u043E\u043C\u043E\u0432
    \u2014 \u0444\u0438\u0433\u0443\u0440\u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u0430, \u043D\u043E \u0438 \u043E\u0447\u0435\u043D\u044C
    \u043A\u043E\u043B\u043E\u0440\u0438\u0442\u043D\u0430\u044F. \u0412\u043E\u0442
    \u0441\u0430\u043C\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u0438 \u0436\u0438\u0437\u043D\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0440\u0438\u0441\u0443\u044E\u0442 \u043F\u043E\u0440\u0442\u0440\u0435\u0442
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0433\u043E \u0433\u0435\u043D\u0438\u044F,
    \u0436\u0438\u0432\u0443\u0449\u0435\u0433\u043E \u0432 \u043C\u0438\u0440\u0435
    \u0438\u0434\u0435\u0439.  ### \U0001F476 \u0420\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u0435
    \u0441\u0432\u044F\u0437\u0438  *   **\u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0432 \u0432\u043E\u0435\u043D\u043D\u043E\u043C \u0433\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u0435:**
    \u0413\u0440\u043E\u043C\u043E\u0432 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    23 \u0434\u0435\u043A\u0430\u0431\u0440\u044F 1943 \u0433\u043E\u0434\u0430 \u0432
    \u0433\u043E\u0440\u043E\u0434\u0435 \u0411\u043E\u043A\u0441\u0438\u0442\u043E\u0433\u043E\u0440\u0441\u043A\u0435
    \u0432 \u0441\u0430\u043C\u044B\u0439 \u0440\u0430\u0437\u0433\u0430\u0440 \u0412\u0435\u043B\u0438\u043A\u043E\u0439
    \u041E\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B. \u0415\u0433\u043E \u043C\u0430\u0442\u044C \u0431\u044B\u043B\u0430
    \u0432\u043E\u0435\u043D\u043D\u044B\u043C \u0432\u0440\u0430\u0447\u043E\u043C
    \u0438 \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u0430 \u0431\u044B\u043B\u0430
    \u043F\u043E\u043A\u0438\u043D\u0443\u0442\u044C \u043F\u0435\u0440\u0435\u0434\u043E\u0432\u0443\u044E
    \u043D\u0430 \u0412\u043E\u043B\u0445\u043E\u0432\u0441\u043A\u043E\u043C \u0444\u0440\u043E\u043D\u0442\u0435,
    \u0447\u0442\u043E\u0431\u044B \u0440\u043E\u0434\u0438\u0442\u044C \u0441\u044B\u043D\u0430.
    \u041E\u0431\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0430 \u0431\u044B\u043B\u0430
    \u0441\u0443\u0440\u043E\u0432\u043E\u0439 \u2014 \u043E\u043D\u0430 \u0441\u043B\u0443\u0436\u0438\u043B\u0430
    \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A\u043E\u043C \u043F\u0430\u0442\u043E\u043B\u043E\u0433\u043E\u0430\u043D\u0430\u0442\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u0432 \u0433\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u0435.
    *   **\u0417\u043D\u0430\u043A\u043E\u043C\u0430\u044F \u0444\u0430\u043C\u0438\u043B\u0438\u044F:**
    \u0415\u0433\u043E \u043C\u0430\u0442\u044C, \u041B\u0438\u044F \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u0432\u043D\u0430
    \u0420\u0430\u0431\u0438\u043D\u043E\u0432\u0438\u0447, \u0431\u044B\u043B\u0430
    \u0434\u0432\u043E\u044E\u0440\u043E\u0434\u043D\u043E\u0439 \u0441\u0435\u0441\u0442\u0440\u043E\u0439
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u043E\u0433\u043E \u0447\u0435\u043C\u043F\u0438\u043E\u043D\u0430
    \u043C\u0438\u0440\u0430 \u043F\u043E \u0448\u0430\u0445\u043C\u0430\u0442\u0430\u043C
    **\u041C\u0438\u0445\u0430\u0438\u043B\u0430 \u0411\u043E\u0442\u0432\u0438\u043D\u043D\u0438\u043A\u0430**.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u0438
    \u0441\u0430\u043C \u0413\u0440\u043E\u043C\u043E\u0432, \u0438 \u0411\u043E\u0442\u0432\u0438\u043D\u043D\u0438\u043A
    \u043D\u043E\u0441\u044F\u0442 \u0438\u043C\u044F \u041C\u0438\u0445\u0430\u0438\u043B.
    *   **\u041A\u043D\u0438\u0433\u0430, \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0430\u044F
    \u0432\u0441\u0451:** \u041A\u043E\u0433\u0434\u0430 \u0431\u0443\u0434\u0443\u0449\u0435\u043C\u0443
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0431\u044B\u043B\u043E
    9 \u043B\u0435\u0442, \u043C\u0430\u0442\u044C \u043F\u043E\u0434\u0430\u0440\u0438\u043B\u0430
    \u0435\u043C\u0443 \u043A\u043D\u0438\u0433\u0443 \u0413\u0430\u043D\u0441\u0430
    \u0420\u0430\u0434\u0435\u043C\u0430\u0445\u0435\u0440\u0430 \u0438 \u041E\u0442\u0442\u043E
    \u0422\u0435\u043F\u043B\u0438\u0446\u0430 \xAB\u042D\u0442\u044E\u0434\u044B
    \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435\xBB.
    \u0418\u043C\u0435\u043D\u043D\u043E \u043E\u043D\u0430 \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B\u0430
    \u0432 \u043D\u0435\u043C \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439 \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0438 \u0432\u043E
    \u043C\u043D\u043E\u0433\u043E\u043C \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0430
    \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u0439
    \u043F\u0443\u0442\u044C.  ### \U0001F9E0 \u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0430 \u0438 \u043F\u0440\u0438\u0432\u044B\u0447\u0435\u043A 
    *   **\"\u041C\u0438\u0448\u0430\" \u0434\u043B\u044F \u0432\u0441\u0435\u0433\u043E
    \u043C\u0438\u0440\u0430:** \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u0438\u043C\u044F \xAB\u041C\u0438\u0445\u0430\u0438\u043B\xBB, \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u0438 \u0434\u0430\u0436\u0435 \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B \u0447\u0430\u0441\u0442\u043E
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u0435\u0433\u043E \u043F\u0440\u043E\u0441\u0442\u043E
    **\u041C\u0438\u0448\u0430** (Misha). \u041E\u043D \u0441\u0430\u043C \u0442\u0430\u043A
    \u0441\u0435\u0431\u044F \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442,
    \u0447\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u043E \u0435\u0433\u043E
    \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u0435 \u0438 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u0441\u0442\u0438.
    *   **\u041E\u0441\u043E\u0431\u044B\u0439 \u0441\u043F\u043E\u0441\u043E\u0431
    \u043D\u043E\u0441\u0438\u0442\u044C \u0447\u0430\u0441\u044B:** \u0412 \u043E\u0434\u043D\u043E\u043C
    \u0438\u0437 \u0438\u043D\u0442\u0435\u0440\u0432\u044C\u044E \u043E\u043D \u0437\u0430\u043C\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u043D\u043E\u0441\u0438\u0442 \u0447\u0430\u0441\u044B \u0446\u0438\u0444\u0435\u0440\u0431\u043B\u0430\u0442\u043E\u043C
    \u0432\u043D\u0438\u0437, \u043D\u0430 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0435\u0439
    \u0441\u0442\u043E\u0440\u043E\u043D\u0435 \u0437\u0430\u043F\u044F\u0441\u0442\u044C\u044F,
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u0435\u043C\u0443 \u0442\u0430\u043A
    **\u0443\u0434\u043E\u0431\u043D\u0435\u0435 \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
    \u043D\u0430 \u0432\u0440\u0435\u043C\u044F**. \u042D\u0442\u0430 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0430\u044F,
    \u043D\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043D\u0430\u044F
    \u0434\u0435\u0442\u0430\u043B\u044C \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u0438\u0432\u0430\u0435\u0442
    \u0435\u0433\u043E \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u044B\u0439
    \u0438 \u043D\u0435\u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434 \u043A \u043C\u0435\u043B\u043E\u0447\u0430\u043C.
    *   **\u0418\u0434\u0435\u0430\u043B\u044C\u043D\u0430\u044F \u0441\u0440\u0435\u0434\u0430
    \u0434\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B:** \u0413\u0440\u043E\u043C\u043E\u0432
    \u043B\u044E\u0431\u0438\u0442 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0432 \u043F\u043E\u043B\u043D\u043E\u0439 \u0442\u0438\u0448\u0438\u043D\u0435
    \u0438 \u0443\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u0438. \u041A\u043E\u0433\u0434\u0430
    \u0435\u0433\u043E \u0441\u043F\u0440\u043E\u0441\u0438\u043B\u0438, \u043D\u0443\u0436\u0435\u043D
    \u043B\u0438 \u0435\u043C\u0443 \u0434\u043B\u044F \u0440\u0430\u0431\u043E\u0442\u044B
    \u0440\u0430\u0439\u0441\u043A\u0438\u0439 \u0443\u0433\u043E\u043B\u043E\u043A
    \u0432\u043E \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u043C
    \u043F\u0440\u0438\u0433\u043E\u0440\u043E\u0434\u0435, \u043E\u043D \u043E\u0442\u0432\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u0434\u043B\u044F
    \u0437\u0430\u043D\u044F\u0442\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u2014 \u0447\u0442\u043E\u0431\u044B **\u043D\u0435 \u0431\u044B\u043B\u043E
    \u043D\u0438\u043A\u0430\u043A\u043E\u0439 \u0441\u0440\u0435\u0434\u044B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043E\u0442\u0432\u043B\u0435\u043A\u0430\u043B\u0430 \u0431\u044B \u043E\u0442
    \u0432\u043D\u0435\u0448\u043D\u0435\u0433\u043E \u043C\u0438\u0440\u0430**.
    *   **\xAB\u041D\u0435 \u0441\u0442\u0438\u0440\u0430\u0442\u044C!\xBB:** \u0412
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0447\u0435\u043C \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u0435
    \u0432 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u0432\u044B\u0441\u0448\u0438\u0445
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    (IH\xC9S) \u043D\u0430 \u0434\u043E\u0441\u043A\u0435 \u0432\u0441\u0435\u0433\u0434\u0430
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0434\u043F\u0438\u0441\u044C: **\xAB\u041D\u0435
    \u0441\u0442\u0438\u0440\u0430\u0442\u044C!\xBB** \u2014 \u043D\u0430 \u0442\u043E\u0442
    \u0441\u043B\u0443\u0447\u0430\u0439, \u0435\u0441\u043B\u0438 \u0443\u0431\u043E\u0440\u0449\u0438\u0446\u0430
    \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u0442
    \u0435\u0433\u043E \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F. 
    ### \U0001F4D0 \u041E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438 
    *   **\u0421\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u044C \u0432 \u043E\u0446\u0435\u043D\u043A\u0435
    \u0441\u0432\u043E\u0438\u0445 \u0437\u0430\u0441\u043B\u0443\u0433:** \u041A\u043E\u0433\u0434\u0430
    \u0436\u0443\u0440\u043D\u0430\u043B\u0438\u0441\u0442\u044B \u0441\u043F\u0440\u043E\u0441\u0438\u043B\u0438
    \u0435\u0433\u043E, \u0437\u0430 \u0447\u0442\u043E \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E,
    \u043E\u043D \u0441 \u0443\u043B\u044B\u0431\u043A\u043E\u0439 \u043E\u0442\u0432\u0435\u0442\u0438\u043B:
    *\"\u041E\u0442\u043A\u0443\u0434\u0430 \u044F \u0437\u043D\u0430\u044E?! \u041A\u043E\u043C\u0438\u0442\u0435\u0442
    \u0440\u0435\u0448\u0430\u043B. \u042F \u0441\u0430\u043C \u0443\u0434\u0438\u0432\u0438\u043B\u0441\u044F\"*.
    \u041D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441, \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F
    \u043B\u0438 \u043E\u043D \u043A \u043F\u0440\u0435\u043C\u0438\u044F\u043C,
    \u043E\u043D \u043E\u0442\u0432\u0435\u0442\u0438\u043B: *\"\u041F\u0440\u0438\u044F\u0442\u043D\u043E,
    \u043A\u043E\u0433\u0434\u0430 \u043F\u043E \u0433\u043E\u043B\u043E\u0432\u043A\u0435
    \u043F\u043E\u0433\u043B\u0430\u0434\u044F\u0442. \u041D\u043E \u044F \u043D\u0435
    \u043C\u043E\u0433\u0443 \u0441\u043A\u0430\u0437\u0430\u0442\u044C, \u0447\u0442\u043E
    \u044F \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F\"*. *   **\xAB\u041D\u0438\u043A\u0442\u043E
    \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0442\xBB:**
    \u0413\u0440\u043E\u043C\u043E\u0432 \u0441 \u043F\u0440\u0438\u0441\u0443\u0449\u0438\u043C
    \u0435\u043C\u0443 \u044E\u043C\u043E\u0440\u043E\u043C \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B,
    \u043A\u0430\u043A \u043F\u0440\u043E\u0445\u043E\u0434\u044F\u0442 \u0435\u0433\u043E
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0434\u043B\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432:
    *\"\u0427\u0438\u0441\u0442\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0442\u044C \u043E\u0447\u0435\u043D\u044C
    \u0442\u0440\u0443\u0434\u043D\u043E \u0434\u0430\u0436\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443.
    \u041D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u0435\u043A\u0446\u0438\u0438 \u043D\u0438\u043A\u0442\u043E \u043D\u0438\u0447\u0435\u0433\u043E
    \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0442. \u0418 \u044D\u0442\u043E
    \u2013 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u041D\u043E
    \u044D\u0442\u043E \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E. \u041F\u043E\u0442\u043E\u043C
    \u043F\u0440\u043E\u0440\u0435\u0437\u0430\u0435\u0442\u0441\u044F. \u0427\u0435\u0440\u0435\u0437
    \u0433\u043E\u0434. \u042D\u0442\u043E \u043E\u0447\u0435\u043D\u044C \u0442\u0440\u0443\u0434\u043D\u044B\u0439
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441\"*. *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043A\u0430\u043A \u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u0443\u0440\u0430:**
    \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u0435\u0442, \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C, \u0430 **\u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0435
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440**. \u0410 \u0438\u0442\u043E\u0433\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043D\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u043D\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430,
    \u0430 *\"\u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u0443\u0440\u043D\u043E\u0435
    \u0441\u043E\u043E\u0440\u0443\u0436\u0435\u043D\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043D\u0443\u0436\u043D\u043E \u043B\u0438\u0431\u043E \u043E\u0442\u043A\u043E\u043F\u0430\u0442\u044C,
    \u043B\u0438\u0431\u043E \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C\"*.
    \u041E\u043D \u0438\u0441\u043F\u044B\u0442\u044B\u0432\u0430\u0435\u0442 \u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u0435,
    \u043A\u043E\u0433\u0434\u0430 \u0437\u0430 \u0445\u0430\u043E\u0441\u043E\u043C
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u0432\u0430\u0435\u0442 *\"\u0437\u0430\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043D\u043D\u0443\u044E
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044E\"*. *   **\"\u042F
    \u0436\u0438\u0432\u0443 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435\":**
    \u041D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441, \u043B\u044E\u0431\u0438\u0442
    \u043B\u0438 \u043E\u043D \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u0413\u0440\u043E\u043C\u043E\u0432 \u043E\u0442\u0432\u0435\u0442\u0438\u043B:
    *\"\u0410 \u043A\u0430\u043A \u0436\u0435! \u0412\u043B\u044E\u0431\u043B\u0435\u043D.
    \u041D\u0435 \u0442\u043E \u0447\u0442\u043E \u043B\u044E\u0431\u043B\u044E \u2013
    \u0436\u0438\u0432\u0443 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435\"*.
    \u042D\u0442\u043E \u044F\u0440\u043A\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0437\u0443\u0435\u0442
    \u0435\u0433\u043E \u043F\u043E\u043B\u043D\u0443\u044E \u043F\u043E\u0433\u0440\u0443\u0436\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u0432 \u043D\u0430\u0443\u043A\u0443. *   **\u0421\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u0441 \u0433\u0435\u043D\u0438\u044F\u043C\u0438:** \u0412 \u043D\u0430\u0443\u0447\u043D\u043E\u043C
    \u043C\u0438\u0440\u0435 \u0438 \u043F\u0440\u0435\u0441\u0441\u0435 \u0435\u0433\u043E
    \u0447\u0430\u0441\u0442\u043E \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u044E\u0442
    \u0441 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D\u043E\u043C, \u041D\u044C\u044E\u0442\u043E\u043D\u043E\u043C
    \u0438 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E \u0434\u0430 \u0412\u0438\u043D\u0447\u0438,
    \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u0438\u0432\u0430\u044F \u0433\u043B\u0443\u0431\u0438\u043D\u0443
    \u0438 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0435\u0433\u043E \u0438\u0434\u0435\u0439.  ### \U0001F30D \u0416\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0435
    \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0438 \u044D\u043C\u0438\u0433\u0440\u0430\u0446\u0438\u044F  *   **\u042D\u043C\u0438\u0433\u0440\u0430\u0446\u0438\u044F
    \u0440\u0430\u0434\u0438 \u043D\u0430\u0443\u043A\u0438:** \u0413\u0440\u043E\u043C\u043E\u0432
    \u0437\u0430\u0434\u0443\u043C\u044B\u0432\u0430\u043B\u0441\u044F \u043E\u0431
    \u044D\u043C\u0438\u0433\u0440\u0430\u0446\u0438\u0438 \u0438\u0437 \u0421\u0421\u0421\u0420
    \u0441 14 \u043B\u0435\u0442 \u0438\u0437-\u0437\u0430 \u043D\u0435\u0441\u043E\u0433\u043B\u0430\u0441\u0438\u044F
    \u0441 \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439. \u0412 \u043D\u0430\u0447\u0430\u043B\u0435
    1970-\u0445 \u043E\u043D \u0434\u0430\u0436\u0435 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B
    \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C\u0441\u044F,
    \u0447\u0442\u043E\u0431\u044B \u0435\u0433\u043E \u0437\u0430\u044F\u0432\u043A\u0430
    \u043D\u0430 \u0432\u044B\u0435\u0437\u0434 \u0432 \u0418\u0437\u0440\u0430\u0438\u043B\u044C
    \u0431\u044B\u043B\u0430 \u0443\u0441\u043F\u0435\u0448\u043D\u0435\u0435. *  
    **\u041F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435 \u0438\u0437-\u0437\u0430
    \u0433\u0440\u0430\u043D\u0438\u0446\u044B:** \u0415\u043C\u0443 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B\u043E
    \u0437\u0430\u043A\u043E\u0434\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0435
    \u043F\u0438\u0441\u044C\u043C\u043E \u0441 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C
    \u043C\u0435\u0441\u0442\u0430 \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0421\u0442\u043E\u0443\u043D\u0438-\u0411\u0440\u0443\u043A \u0432 \u0421\u0428\u0410,
    \u0435\u0441\u043B\u0438 \u043E\u043D \u0441\u043C\u043E\u0436\u0435\u0442 \u0432\u044B\u0435\u0445\u0430\u0442\u044C.
    \u0412 1974 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043A\u0438\u043D\u0443\u043B
    \u0421\u0421\u0421\u0420 \u043F\u043E \u0438\u0437\u0440\u0430\u0438\u043B\u044C\u0441\u043A\u043E\u0439
    \u0432\u0438\u0437\u0435 \u0438 \u0447\u0435\u0440\u0435\u0437 \u0418\u0442\u0430\u043B\u0438\u044E
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0421\u0428\u0410. \u041F\u043E\u0437\u0436\u0435
    \u043E\u043D \u043F\u0435\u0440\u0435\u0431\u0440\u0430\u043B\u0441\u044F \u0432\u043E
    \u0424\u0440\u0430\u043D\u0446\u0438\u044E, \u0433\u0434\u0435 \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    \u043F\u043E \u0441\u0435\u0439 \u0434\u0435\u043D\u044C. *   **\u0414\u0432\u043E\u0439\u043D\u043E\u0435
    \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u043E:** \u0412
    1992 \u0433\u043E\u0434\u0443 \u0413\u0440\u043E\u043C\u043E\u0432 \u043F\u0440\u0438\u043D\u044F\u043B
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0435 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u0442\u0432\u043E,
    \u043D\u043E \u043F\u043E\u0437\u0436\u0435 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B
    \u0438 \u0440\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0435. \u0412 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445 \u0435\u0433\u043E
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0438\u043D\u043E\u043C
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438, \u0420\u043E\u0441\u0441\u0438\u0438
    \u0438 \u0434\u0430\u0436\u0435 \u0421\u0428\u0410.  ### \U0001F3C6 \u0420\u0435\u043A\u043E\u0440\u0434\u044B
    \u0438 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F  *   **\u0411\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0435
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B:** \u041E\u043D \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043B\u0430\u0443\u0440\u0435\u0430\u0442\u043E\u043C \u0431\u043E\u043B\u0435\u0435
    \u0434\u0435\u0441\u044F\u0442\u043A\u0430 \u0441\u0430\u043C\u044B\u0445 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0445
    \u043C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u044B\u0445
    \u043F\u0440\u0435\u043C\u0438\u0439, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E \u043F\u0440\u0435\u043C\u0438\u044E
    2009 \u0433\u043E\u0434\u0430 (\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u043E\u0433 \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439),
    \u043F\u0440\u0435\u043C\u0438\u044E \u0412\u043E\u043B\u044C\u0444\u0430, \u041A\u0438\u043E\u0442\u043E,
    \u0411\u0430\u043B\u044C\u0446\u0430\u043D\u0430 \u0438 \u043C\u043D\u043E\u0433\u0438\u0435
    \u0434\u0440\u0443\u0433\u0438\u0435. *   **\u041D\u0430\u0443\u0447\u043D\u044B\u0439
    \"\u041E\u0441\u043A\u0430\u0440\":** \u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E \u0438\u043D\u043E\u0433\u0434\u0430 \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \"\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u041E\u0441\u043A\u0430\u0440\u043E\u043C\" \u0438\u0437-\u0437\u0430 \u0435\u0451
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0441\u0442\u0438 \u0438
    \u0440\u0430\u0437\u043C\u0435\u0440\u0430 (\u0432 2009 \u0433\u043E\u0434\u0443
    \u043E\u043D\u0430 \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430 \u043F\u043E\u0447\u0442\u0438
    1 \u043C\u0438\u043B\u043B\u0438\u043E\u043D \u0434\u043E\u043B\u043B\u0430\u0440\u043E\u0432). 
    ### \U0001F9EC \u0417\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \"\u0432\u044B\u0445\u043E\u0434\u043A\u0438\" 
    *   **\u041A\u0430\u043A \u043E\u0442\u043B\u0438\u0447\u0438\u0442\u044C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    \u043E\u0442 \u0441\u043E\u0431\u0430\u043A\u0438:** \u0412 \u043E\u0434\u043D\u043E\u043C
    \u0438\u0437 \u0438\u043D\u0442\u0435\u0440\u0432\u044C\u044E \u0413\u0440\u043E\u043C\u043E\u0432
    \u0441 \u0443\u043B\u044B\u0431\u043A\u043E\u0439 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043E\u0434\u0438\u043D \u0438\u0437 \u0430\u0441\u043F\u0435\u043A\u0442\u043E\u0432
    \u0435\u0433\u043E \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u043E\u0434\u0435\u043B\u0435\u0439 \u043C\u043E\u0436\u0435\u0442 \u043F\u043E\u043C\u043E\u0447\u044C
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0430\u0448\u0438\u043D\u0435 \u043E\u0442\u043B\u0438\u0447\u0438\u0442\u044C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u043E\u0442 \u0441\u043E\u0431\u0430\u043A\u0438,
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E \u043E\u0442 \u043F\u043E\u0437\u044B.
    \u041D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441, \u0432 \u0447\u0435\u043C
    \u0436\u0435 \u0440\u0430\u0437\u043D\u0438\u0446\u0430, \u043E\u043D \u0441
    \u0438\u0440\u043E\u043D\u0438\u0435\u0439 \u0437\u0430\u043C\u0435\u0442\u0438\u043B:
    *\"\u0412\u043E\u0442 \u044F \u0441\u0438\u0436\u0443 \u0432 \u0442\u0430\u043A\u043E\u0439
    \u043F\u043E\u0437\u0435 \u2013 \u0447\u0435\u043C \u044F \u043D\u0435 \u0441\u043E\u0431\u0430\u043A\u0430?\"*.
    *   **\u041F\u0440\u0438\u043D\u0446\u0438\u043F \"\u0441\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0432\u0435\u0440\u0431\u043B\u044E\u0434\u0430\":** \u041E\u0434\u0438\u043D
    \u0438\u0437 \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432 \u0432 \u0441\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u2014 \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043D\u0435\u0432\u044B\u0436\u0438\u043C\u0430\u043D\u0438\u0438 \u2014
    \u0438\u043C\u0435\u0435\u0442 \u0437\u0430\u0431\u0430\u0432\u043D\u043E\u0435
    \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435 **\xAB\u043F\u0440\u0438\u043D\u0446\u0438\u043F
    \u0441\u0438\u043C\u043F\u043B\u0435\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0432\u0435\u0440\u0431\u043B\u044E\u0434\u0430\xBB**. \u0421\u0443\u0442\u044C
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u043E\u0431\u044A\u0435\u043A\u0442 (\u0432\u0435\u0440\u0431\u043B\u044E\u0434)
    \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u043F\u0440\u043E\u0442\u0438\u0441\u043D\u0443\u0442\u044C\u0441\u044F
    \u0447\u0435\u0440\u0435\u0437 \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0443\u044E
    \u0438\u0433\u043E\u043B\u044C\u043D\u0443\u044E \u0438\u0433\u043B\u0443. \u0417\u0430
    \u044D\u0442\u043E\u0439 \u0448\u0443\u0442\u043B\u0438\u0432\u043E\u0439 \u0430\u043D\u0430\u043B\u043E\u0433\u0438\u0435\u0439
    \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u0433\u043B\u0443\u0431\u043E\u0447\u0430\u0439\u0448\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442.  \u0412\u0441\u0435 \u044D\u0442\u0438
    \u0444\u0430\u043A\u0442\u044B \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442,
    \u0447\u0442\u043E \u041C\u0438\u0445\u0430\u0438\u043B \u0413\u0440\u043E\u043C\u043E\u0432
    \u2014 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u043D\u043E \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A
    \u0441 \u0431\u043E\u043B\u044C\u0448\u0438\u043C \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C
    \u044E\u043C\u043E\u0440\u0430, \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u0439
    \u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043F\u0440\u0435\u0434\u0430\u043D\u043D\u044B\u0439
    \u0441\u0432\u043E\u0435\u043C\u0443 \u0434\u0435\u043B\u0443."
