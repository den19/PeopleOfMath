    \u0433\u0440\u0443\u043F\u043F \u0434\u043E \u0444\u043E\u0440\u043C \u0433\u0435\u043D\u043E\u043C\u043E\u0432.
    \u0417\u0430 \u044D\u0442\u0438\u043C\u0438 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F\u043C\u0438
    \u0441\u0442\u043E\u044F\u0442 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0435
    \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0435 \u0438\u0434\u0435\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435, \u043F\u043E \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u044E
    \u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u043C\u0438\u0442\u0435\u0442\u0430,
    \"\u043F\u0440\u0438\u0432\u0435\u043B\u0438 \u043A \u043D\u043E\u0432\u044B\u043C
    \u0432\u0437\u0433\u043B\u044F\u0434\u0430\u043C \u043D\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u0441\u0444\u0435\u0440\u044B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\"."
  achievementsEn: 
  personalLifeRu: "\u0414\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0435 \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F
