    \u043C\u043E\u0437\u0433\u0430. \u041E\u043D \u043F\u044B\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0442\u0432\u0435\u0442\u0438\u0442\u044C \u043D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441\u044B:
    \u043A\u0430\u043A \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
