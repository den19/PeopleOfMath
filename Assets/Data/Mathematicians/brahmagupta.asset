    \u043F\u043E\u043C\u0438\u043C\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439:  *   **\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0441\u0435\u043C\u044C\u044F**: \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u043E\u043A\u043E\u043B\u043E 598
    \u0433\u043E\u0434\u0430  \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u0411\u0445\u0438\u043B\u043B\u0430\u043C\u0430\u043B\u0430
    (\u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439 \u0411\u0445\u0438\u043D\u043C\u0430\u043B
    \u0432 \u0448\u0442\u0430\u0442\u0435 \u0420\u0430\u0434\u0436\u0430\u0441\u0442\u0445\u0430\u043D).
    \u0415\u0433\u043E \u043E\u0442\u0446\u0430 \u0437\u0432\u0430\u043B\u0438 \u0414\u0436\u0438\u0448\u043D\u0443\u0433\u0443\u043F\u0442\u0430.
    *   **\u0420\u0435\u043B\u0438\u0433\u0438\u044F**: \u041E\u043D \u0431\u044B\u043B
    \u0438\u043D\u0434\u0443\u0438\u0441\u0442\u043E\u043C \u0438 \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0430\u043B
