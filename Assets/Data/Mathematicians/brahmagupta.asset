  achievementsRu: "\u0425\u043E\u0442\u044F \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E
    \u044F \u0443\u0436\u0435 \u043A\u043E\u0441\u043D\u0443\u043B\u0441\u044F \u044D\u0442\u043E\u0439
    \u0442\u0435\u043C\u044B \u0432 \u043F\u0440\u0435\u0434\u044B\u0434\u0443\u0449\u0435\u043C
    \u043E\u0442\u0432\u0435\u0442\u0435, \u0434\u0430\u0432\u0430\u0439\u0442\u0435
    \u0440\u0430\u0437\u0431\u0435\u0440\u0435\u043C **\u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0438 \u0432\u043A\u043B\u0430\u0434 \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B
    \u0432 \u043D\u0430\u0443\u043A\u0443** \u0441 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0433\u043B\u0443\u0431\u0438\u043D\u043E\u0439 \u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u043D\u043E\u0441\u0442\u044C\u044E.  
    \u0415\u0433\u043E \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0434\u043B\u044F
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u043D\u0430\u0443\u043A\u0438 \u0432\u044B\u0445\u043E\u0434\u0438\u0442
    \u0434\u0430\u043B\u0435\u043A\u043E \u0437\u0430 \u0440\u0430\u043C\u043A\u0438
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B. \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430
    \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 **\u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0438\u0437 \u043D\u0430\u0431\u043E\u0440\u0430
    \u0440\u0435\u0446\u0435\u043F\u0442\u043E\u0432 \u0434\u043B\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u0432
    \u0432 \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u0443\u044E
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0443**, \u043E\u043F\u0435\u0440\u0438\u0440\u0443\u044E\u0449\u0443\u044E
    \u043E\u0431\u0449\u0438\u043C\u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u0430\u043C\u0438. 
    \u041D\u0438\u0436\u0435 \u043F\u0440\u0438\u0432\u0435\u0434\u0435\u043D \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0440\u0430\u0437\u0431\u043E\u0440 \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434\u0430
    \u043F\u043E \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C \u043D\u0430\u0443\u043A\u0438. 
    ---  ### 1. \u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430 \u0438 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \xAB\u041F\u0440\u0430\u0432\u0438\u043B \u0437\u043D\u0430\u043A\u043E\u0432\xBB 
    \u042D\u0442\u043E \u0441\u0430\u043C\u043E\u0435 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B.
    \u0412 12-\u0439 \u0433\u043B\u0430\u0432\u0435 \xAB\u0411\u0440\u0430\u0445\u043C\u0430-\u0441\u043F\u0445\u0443\u0442\u0430-\u0441\u0438\u0434\u0434\u0445\u0430\u043D\u0442\u044B\xBB
    \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u0442\u0432\u0430 \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u0443\u0435\u0442
    \u0435\u0434\u0438\u043D\u044B\u0435 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u0434\u043B\u044F \u0432\u0441\u0435\u0445
    \u0432\u0438\u0434\u043E\u0432 \u0447\u0438\u0441\u0435\u043B:  *   **\u041D\u043E\u043B\u044C
    \u043A\u0430\u043A \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E**: \u041E\u043D \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B
    \u043D\u043E\u043B\u044C \u043D\u0435 \u043A\u0430\u043A \xAB\u043F\u0443\u0441\u0442\u043E\u0435
    \u043C\u0435\u0441\u0442\u043E\xBB \u0432 \u0437\u0430\u043F\u0438\u0441\u0438
    \u0447\u0438\u0441\u043B\u0430, \u0430 \u043A\u0430\u043A \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u0432\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u044F \u0447\u0438\u0441\u043B\u0430
    \u0438\u0437 \u0441\u0430\u043C\u043E\u0433\u043E \u0441\u0435\u0431\u044F (`x
    - x = 0`). \u041E\u043D \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430:
    `a + 0 = a`, `a - 0 = a`, \u0438, \u0447\u0442\u043E \u0441\u0430\u043C\u043E\u0435
    \u0432\u0430\u0436\u043D\u043E\u0435, `a \xD7 0 = 0`. *   **\u041E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430 (\xAB\u0414\u043E\u043B\u0433\u0438\xBB)**: \u041E\u043D
    \u0432\u0432\u0435\u043B \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430 \u0434\u043B\u044F \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    \u0434\u043E\u043B\u0433\u043E\u0432, \u0430 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u2014 \u0434\u043B\u044F \u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u0430. 
    *   **\u041F\u0440\u0430\u0432\u0438\u043B\u0430 \u0437\u043D\u0430\u043A\u043E\u0432
    (\u0421\u0443\u0442\u0440\u044B)**: \u041E\u043D \u0434\u0430\u043B \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u044F
    \u0438 \u0434\u0435\u043B\u0435\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043C\u044B \u0443\u0447\u0438\u043C \u0432 \u0448\u043A\u043E\u043B\u0435:    
    *   *\xAB\u041F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0434\u0432\u0443\u0445 \u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432 (\u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445)
    \u0435\u0441\u0442\u044C \u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u043E;
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0434\u0432\u0443\u0445
    \u0434\u043E\u043B\u0433\u043E\u0432 (\u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445)
    \u0435\u0441\u0442\u044C \u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u043E;
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u0430
    \u0438 \u0434\u043E\u043B\u0433\u0430 \u0435\u0441\u0442\u044C \u0434\u043E\u043B\u0433\xBB.*    
    *   \u0422\u043E \u0435\u0441\u0442\u044C: `(+) * (+) = (+)`, `(-) * (-) = (+)`,
    `(+) * (-) = (-)`. *   **\u041F\u0440\u043E\u0431\u043B\u0435\u043C\u0430 \u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043D\u0430 \u043D\u043E\u043B\u044C**: \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430
    \u043F\u0435\u0440\u0432\u044B\u043C \u043E\u0441\u043E\u0437\u043D\u0430\u043B
    \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u044D\u0442\u043E\u0439
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438. \u041E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B,
    \u0447\u0442\u043E `0 / 0 = 0` (\u0447\u0442\u043E \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E
    \u0441 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u0438
    \u0437\u0440\u0435\u043D\u0438\u044F, \u043D\u043E \u044D\u0442\u043E \u0431\u044B\u043B\u0430
    \u043F\u0435\u0440\u0432\u0430\u044F \u0437\u0430\u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u043F\u043E\u043F\u044B\u0442\u043A\u0430 \u0434\u0430\u0442\u044C \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u044D\u0442\u043E\u0439 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438). \u0427\u0442\u043E
    \u043A\u0430\u0441\u0430\u0435\u0442\u0441\u044F `a / 0` (\u0433\u0434\u0435
    a \u2260 0), \u043E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u044D\u0442\u043E
    \u0431\u0435\u0437 \u0447\u0435\u0442\u043A\u043E\u0433\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F,
    \u043B\u0438\u0448\u044C \u0443\u043A\u0430\u0437\u0430\u0432, \u0447\u0442\u043E
    \u0442\u0430\u043A\u0430\u044F \u0434\u0440\u043E\u0431\u044C \u043E\u0431\u043B\u0430\u0434\u0430\u0435\u0442
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E\u043C \u043D\u0435\u0438\u0437\u043C\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    (\u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u0432
    \u043F\u043E\u043D\u044F\u0442\u0438\u0435 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438). 
    ---  ### 2. \u0410\u043B\u0433\u0435\u0431\u0440\u0430 \u0438 \u0422\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B (\u0420\u0435\u0448\u0435\u043D\u0438\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u041F\u0435\u043B\u043B\u044F)  \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0440\u043E\u0440\u044B\u0432
    \u0432 \u0440\u0435\u0448\u0435\u043D\u0438\u0438 \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0432\u0442\u043E\u0440\u043E\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438.  *   **\u0423\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u041F\u0435\u043B\u043B\u044F**: \u041E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0441 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435\u043C
    \u0432\u0438\u0434\u0430 **Nx\xB2 + 1 = y\xB2** (\u0433\u0434\u0435 N \u2014
    \u043D\u0435 \u043A\u0432\u0430\u0434\u0440\u0430\u0442).  *   **\u041C\u0435\u0442\u043E\u0434
    \xAB\u0421\u0430\u043C\u043E\u0441\u043B\u043E\u0436\u0435\u043D\u0438\u044F\xBB
    (\u0411\u0445\u0430\u0432\u0430\u043D\u0430)**: \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C,
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0438\u0439, \u0438\u043C\u0435\u044F
    \u0434\u0432\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0442\u0430\u043A\u043E\u0433\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F, \u043A\u043E\u043C\u0431\u0438\u043D\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0438\u0445 \u0434\u043B\u044F \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F
    **\u043D\u043E\u0432\u043E\u0433\u043E, \u0431\u043E\u043B\u044C\u0448\u0435\u0433\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F**. \u042D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434
    (\u043F\u043E\u0437\u0436\u0435 \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u044B\u0439
    \u0442\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u043E\u043C \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B\u2014\u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438)
    \u0433\u043B\u0430\u0441\u0438\u0442:     \u0415\u0441\u043B\u0438 `x\u2081\xB2
    - N*y\u2081\xB2 = k\u2081` \u0438 `x\u2082\xB2 - N*y\u2082\xB2 = k\u2082`, \u0442\u043E
    `(x\u2081x\u2082 + N*y\u2081y\u2082)\xB2 - N*(x\u2081y\u2082 + x\u2082y\u2081)\xB2
    = k\u2081*k\u2082`.     \u042D\u0442\u043E\u0442 \u043C\u043E\u0449\u043D\u044B\u0439
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B
    \u0433\u0435\u043D\u0435\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u0439
    \u0438\u0437 \u043E\u0434\u043D\u043E\u0433\u043E. \u041F\u043E\u0437\u0436\u0435,
    \u0432 XII \u0432\u0435\u043A\u0435, \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430
    II \u0434\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u044D\u0442\u043E\u0442
    \u043C\u0435\u0442\u043E\u0434 \u0434\u043E \u043F\u043E\u043B\u043D\u043E\u0433\u043E
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0430 (\u0427\u0430\u043A\u0440\u0430\u0432\u0430\u043B\u0430),
    \u043D\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u0438\u043C\u0435\u043D\u043D\u043E \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430.
    \u0415\u0432\u0440\u043E\u043F\u0435\u0439\u0446\u044B \u0437\u0430\u043D\u043E\u0432\u043E
    \u043E\u0442\u043A\u0440\u044B\u043B\u0438 \u044D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434
    \u0442\u043E\u043B\u044C\u043A\u043E \u0432 XVII \u0432\u0435\u043A\u0435 (\u0424\u0435\u0440\u043C\u0430,
    \u0423\u043E\u043B\u043B\u0438\u0441, \u041B\u0430\u0433\u0440\u0430\u043D\u0436). 
    ---  ### 3. \u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F (\u0424\u043E\u0440\u043C\u0443\u043B\u0430
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B)  \u0412 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u0435\u043D: 
    *   **\u0424\u043E\u0440\u043C\u0443\u043B\u0430 \u0434\u043B\u044F \u043F\u043B\u043E\u0449\u0430\u0434\u0438
    \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430**:
    \u0414\u043B\u044F \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430
    \u0441\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u0430\u043C\u0438 **a, b, c,
    d**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043C\u043E\u0436\u043D\u043E
    \u0432\u043F\u0438\u0441\u0430\u0442\u044C \u0432 \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u044C
    (\u0446\u0438\u043A\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439), \u043F\u043B\u043E\u0449\u0430\u0434\u044C
    \u0432\u044B\u0447\u0438\u0441\u043B\u044F\u0435\u0442\u0441\u044F \u043A\u0430\u043A:    
    **S = \u221A[(s - a)(s - b)(s - c)(s - d)]**, \u0433\u0434\u0435 **s** \u2014
    \u043F\u043E\u043B\u0443\u043F\u0435\u0440\u0438\u043C\u0435\u0442\u0440.    
    \u042D\u0442\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u0435 \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u0413\u0435\u0440\u043E\u043D\u0430 \u0434\u043B\u044F \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430
    (\u0435\u0441\u043B\u0438 \u043F\u0440\u0438\u043D\u044F\u0442\u044C d=0, \u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u043F\u0440\u0435\u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F \u0432
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0413\u0435\u0440\u043E\u043D\u0430).
    \u0412\u0430\u0436\u043D\u043E, \u0447\u0442\u043E \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0434\u0430\u043B \u0444\u043E\u0440\u043C\u0443\u043B\u0443,
    \u043D\u043E \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u0430\u044F \u043F\u043B\u043E\u0449\u0430\u0434\u044C
    \u0441\u0440\u0435\u0434\u0438 \u0432\u0441\u0435\u0445 \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432
    \u0441 \u0437\u0430\u0434\u0430\u043D\u043D\u044B\u043C\u0438 \u0441\u0442\u043E\u0440\u043E\u043D\u0430\u043C\u0438
    \u0434\u043E\u0441\u0442\u0438\u0433\u0430\u0435\u0442\u0441\u044F \u0438\u043C\u0435\u043D\u043D\u043E
    \u0443 \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430.
    *   **\u0414\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u0438 \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E
    \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430**:
    \u041E\u043D \u043D\u0430\u0448\u0435\u043B \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u044F
    \u0434\u043B\u044F \u0434\u043B\u0438\u043D \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u0435\u0439
    \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430
    \u0447\u0435\u0440\u0435\u0437 \u0435\u0433\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u044B.
    *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430 \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B**:
    \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0432
    \u043B\u044E\u0431\u043E\u043C \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u043C
    \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0435,
    \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u0438 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043F\u0435\u0440\u043F\u0435\u043D\u0434\u0438\u043A\u0443\u043B\u044F\u0440\u043D\u044B,
    \u043F\u0440\u044F\u043C\u0430\u044F, \u043E\u043F\u0443\u0449\u0435\u043D\u043D\u0430\u044F
    \u0438\u0437 \u0442\u043E\u0447\u043A\u0438 \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u044F
    \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u0435\u0439 \u043F\u0435\u0440\u043F\u0435\u043D\u0434\u0438\u043A\u0443\u043B\u044F\u0440\u043D\u043E
    \u0441\u0442\u043E\u0440\u043E\u043D\u0435, \u0432\u0441\u0435\u0433\u0434\u0430
    \u0434\u0435\u043B\u0438\u0442 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0443\u044E
    \u0441\u0442\u043E\u0440\u043E\u043D\u0443 \u043F\u043E\u043F\u043E\u043B\u0430\u043C. 
    ---  ### 4. \u0412\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0438 \u0422\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u044F 
    \u0412 \u0441\u0432\u043E\u0438\u0445 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0430\u0445 \u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434\u044B \u0434\u043B\u044F \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u0440\u0430\u0441\u0447\u0435\u0442\u043E\u0432 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442:  *   **\u0418\u043D\u0442\u0435\u0440\u043F\u043E\u043B\u044F\u0446\u0438\u043E\u043D\u043D\u0430\u044F
    \u0444\u043E\u0440\u043C\u0443\u043B\u0430 (\u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B)**: \u0414\u043B\u044F
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439
    \u0441\u0438\u043D\u0443\u0441\u043E\u0432 \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u0447\u043D\u044B\u0445
    \u0443\u0433\u043B\u043E\u0432 (\u043A\u043E\u0433\u0434\u0430 \u0442\u0430\u0431\u043B\u0438\u0447\u043D\u044B\u0435
    \u0434\u0430\u043D\u043D\u044B\u0435 \u0431\u044B\u043B\u0438 \u0434\u0438\u0441\u043A\u0440\u0435\u0442\u043D\u044B),
    \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u0443\u044E \u0438\u043D\u0442\u0435\u0440\u043F\u043E\u043B\u044F\u0446\u0438\u044E.
    \u0415\u0433\u043E \u0444\u043E\u0440\u043C\u0443\u043B\u0430 \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0447\u0430\u0441\u0442\u043D\u044B\u043C
    \u0441\u043B\u0443\u0447\u0430\u0435\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0438\u043D\u0442\u0435\u0440\u043F\u043E\u043B\u044F\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B \u041D\u044C\u044E\u0442\u043E\u043D\u0430-\u0421\u0442\u0438\u0440\u043B\u0438\u043D\u0433\u0430
    (\u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443 \u0431\u043E\u043B\u0435\u0435 \u0447\u0435\u043C
    \u043D\u0430 1000 \u043B\u0435\u0442). *   **\u0424\u043E\u0440\u043C\u0443\u043B\u0430
    \u0434\u043B\u044F \u0440\u0430\u0434\u0438\u0443\u0441\u0430 \u043E\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0439
    \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u0438**: \u041E\u043D
    \u0432\u044B\u0432\u0435\u043B \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0434\u043B\u044F
    \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0440\u0430\u0434\u0438\u0443\u0441\u0430
    \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u0438, \u043E\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0439
    \u0432\u043E\u043A\u0440\u0443\u0433 \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430,
    \u0447\u0435\u0440\u0435\u0437 \u043F\u043B\u043E\u0449\u0430\u0434\u044C \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430
    (S) \u0438 \u0435\u0433\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u044B (a,
    b, c): **R = (abc) / (4S)**.  *   **\u041B\u0438\u043D\u0435\u0439\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F**: \u041E\u043D \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434\u044B \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0441\u0438\u0441\u0442\u0435\u043C \u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0441 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u043C\u0438
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C\u0438, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u043C\u0435\u0442\u043E\u0434\u044B, \u043E\u0447\u0435\u043D\u044C \u0431\u043B\u0438\u0437\u043A\u0438\u0435
    \u043A \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C\u0443
    \u043C\u0435\u0442\u043E\u0434\u0443 \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445.  ---  ###
    5. \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F (\u041F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u044B\u0439
    \u043D\u043E\u0432\u0430\u0442\u043E\u0440)  \u0415\u0433\u043E \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u044B (\u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \xAB\u041A\u0445\u0430\u043D\u0434\u0430\u043A\u0445\u0430\u0434\u044C\u044F\u043A\u0430\xBB)
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0438 \u0443\u0442\u043E\u0447\u043D\u0435\u043D\u043D\u044B\u0435
    \u043F\u0430\u0440\u0430\u043C\u0435\u0442\u0440\u044B \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0431\u044B\u043B\u0438 \u0442\u043E\u0447\u043D\u0435\u0435, \u0447\u0435\u043C
    \u0443 \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432: 
    *   **\u0414\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0433\u043E\u0434\u0430**: \u041E\u043D \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u043B
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0437\u0432\u0435\u0437\u0434\u043D\u043E\u0433\u043E \u0433\u043E\u0434\u0430
    \u043A\u0430\u043A **365 \u0434\u043D\u0435\u0439 6 \u0447\u0430\u0441\u043E\u0432
    5 \u043C\u0438\u043D\u0443\u0442 \u0438 19 \u0441\u0435\u043A\u0443\u043D\u0434**,
    \u0447\u0442\u043E \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0431\u043B\u0438\u0437\u043A\u043E \u043A \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C
    \u0434\u0430\u043D\u043D\u044B\u043C (\u043E\u0448\u0438\u0431\u043A\u0430 \u0432\u0441\u0435\u0433\u043E
    \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0438\u043D\u0443\u0442).
    *   **\u041F\u0430\u0440\u0430\u043B\u043B\u0430\u043A\u0441 \u041B\u0443\u043D\u044B**:
    \u0412 \u0441\u0432\u043E\u0435\u043C \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435
    \u043E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E
    \u041B\u0443\u043D\u0430 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u0431\u043B\u0438\u0436\u0435 \u043A \u0417\u0435\u043C\u043B\u0435, \u0447\u0435\u043C
    \u0421\u043E\u043B\u043D\u0446\u0435, \u0438 \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u043B
    \u044D\u0442\u043E \u0440\u0430\u0437\u043D\u0438\u0446\u0435\u0439 \u0432 \u0432\u0438\u0434\u0438\u043C\u043E\u043C
    \u043F\u0430\u0440\u0430\u043B\u043B\u0430\u043A\u0441\u0435 (\u043A\u0430\u0436\u0443\u0449\u0435\u043C\u0441\u044F
    \u0441\u043C\u0435\u0449\u0435\u043D\u0438\u0438 \u0441\u0432\u0435\u0442\u0438\u043B\u0430
    \u043F\u0440\u0438 \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u0438
    \u0441 \u0440\u0430\u0437\u043D\u044B\u0445 \u0442\u043E\u0447\u0435\u043A \u0417\u0435\u043C\u043B\u0438).
    *   **\u041A\u0440\u0438\u0442\u0438\u043A\u0430 \u0433\u0435\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0437\u043C\u0430
    (\u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u043E)**:
    \u041E\u043D \u0436\u0435\u0441\u0442\u043A\u043E \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B
    \u0410\u0440\u0438\u0430\u0431\u0445\u0430\u0442\u0443 \u0437\u0430 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F \u0417\u0435\u043C\u043B\u0438
    \u0432\u043E\u043A\u0440\u0443\u0433 \u0441\u0432\u043E\u0435\u0439 \u043E\u0441\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u043E\u0442\u0432\u0435\u0440\u0433\u0430\u044F
    \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435, \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430
    \u0432 \u0441\u0432\u043E\u0438\u0445 \u0440\u0430\u0441\u0447\u0435\u0442\u0430\u0445
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    **\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0442\u0430\u043A, \u043A\u0430\u043A
    \u0431\u0443\u0434\u0442\u043E \u0417\u0435\u043C\u043B\u044F \u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F**
    (\u0442\u0435\u043E\u0440\u0438\u044F \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435).
    \u041E\u043D \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u043B
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0434\u043B\u044F \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439,
    \u0441\u0430\u043C \u0442\u043E\u0433\u043E \u043D\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u044F
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438.  ---  ### 6. \u0412\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u043D\u0430\u0443\u043A\u0443
    (\u041C\u0435\u0442\u0430-\u0432\u043A\u043B\u0430\u0434)  \u0413\u043B\u0430\u0432\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B
    \u2014 \u044D\u0442\u043E \u0441\u043F\u043E\u0441\u043E\u0431 \u043F\u043E\u0434\u0430\u0447\u0438
    \u0437\u043D\u0430\u043D\u0438\u0439:  *   **\u041E\u0442\u043A\u0430\u0437 \u043E\u0442
    \u043C\u0438\u0441\u0442\u0438\u043A\u0438 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435**:
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043C\u043D\u043E\u0433\u0438\u0445
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u043E\u043D \u0436\u0435\u0441\u0442\u043A\u043E \u043E\u0442\u0434\u0435\u043B\u044F\u043B
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u043E\u0442 \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0439
    \u043E\u0431\u0440\u044F\u0434\u043D\u043E\u0441\u0442\u0438. \u041E\u043D \u0437\u0430\u044F\u0432\u043B\u044F\u043B,
    \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0434\u043E\u043B\u0436\u043D\u0430 \u0431\u044B\u0442\u044C \u043F\u043E\u043D\u044F\u0442\u043D\u0430
    \u043B\u044E\u0431\u043E\u043C\u0443, \u043A\u0442\u043E \u043E\u0441\u0432\u043E\u0438\u043B
    \u0435\u0435 \u043F\u0440\u0430\u0432\u0438\u043B\u0430, \u0432\u043D\u0435 \u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u0438
    \u043E\u0442 \u043A\u0430\u0441\u0442\u044B. *   **\u041F\u0435\u0440\u0435\u0434\u0430\u0447\u0430
    \u0437\u043D\u0430\u043D\u0438\u0439 \u0430\u0440\u0430\u0431\u0430\u043C**:
    \u0418\u043C\u0435\u043D\u043D\u043E \u0435\u0433\u043E \u0442\u0440\u0443\u0434
    \u0432 771 \u0433\u043E\u0434\u0443 \u0431\u044B\u043B \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043D
    \u0432 \u0411\u0430\u0433\u0434\u0430\u0434\u0435 \u043A\u0430\u043A \xAB\u0421\u0438\u043D\u0434\u0445\u0438\u043D\u0434\xBB.
    \u0427\u0435\u0440\u0435\u0437 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0435\u0432\u043E\u0434
    \u0430\u0440\u0430\u0431\u044B \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0438\u0441\u044C
    \u0441 **\u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439
    \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F, \u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u043D\u044B\u043C
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u043E\u043C \u0437\u0430\u043F\u0438\u0441\u0438
    \u0447\u0438\u0441\u0435\u043B (\u0441 \u043D\u0443\u043B\u0435\u043C) \u0438
    \u043F\u0440\u0430\u0432\u0438\u043B\u0430\u043C\u0438 \u0437\u043D\u0430\u043A\u043E\u0432**.
    \u0411\u0435\u0437 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0430 \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B
    \u043D\u0435 \u0431\u044B\u043B\u043E \u0431\u044B \u0442\u0440\u0443\u0434\u043E\u0432
    \u0430\u043B\u044C-\u0425\u043E\u0440\u0435\u0437\u043C\u0438, \u0430 \u0431\u0435\u0437
    \u0430\u043B\u044C-\u0425\u043E\u0440\u0435\u0437\u043C\u0438 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0439
    \u0420\u0435\u043D\u0435\u0441\u0441\u0430\u043D\u0441 \u043C\u043E\u0433 \u0431\u044B
    \u0437\u0430\u0434\u0435\u0440\u0436\u0430\u0442\u044C\u0441\u044F \u043D\u0430
    \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F.  ---  ### \u0420\u0435\u0437\u044E\u043C\u0438\u0440\u0443\u044E\u0449\u0430\u044F
    \u0442\u0430\u0431\u043B\u0438\u0446\u0430 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439  | \u041E\u0431\u043B\u0430\u0441\u0442\u044C
    | \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 | \u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0434\u043B\u044F \u043D\u0430\u0443\u043A\u0438 | | :--- | :--- | :--- | |
    **\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430** | \u041F\u0440\u0430\u0432\u0438\u043B\u0430
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439 \u0441 \u043D\u0443\u043B\u0435\u043C
    \u0438 \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0447\u0438\u0441\u043B\u0430\u043C\u0438. | \u0412\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u043E\u0439 \u0447\u0438\u0441\u043B\u043E\u0432\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B (Z). | | **\u0410\u043B\u0433\u0435\u0431\u0440\u0430**
    | \u0422\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u043E \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B
    \u0438 \u043C\u0435\u0442\u043E\u0434 \u0411\u0445\u0430\u0432\u0430\u043D\u0430.
    | \u041E\u0441\u043D\u043E\u0432\u0430 \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u041F\u0435\u043B\u043B\u044F;
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B. | | **\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F**
    | \u0424\u043E\u0440\u043C\u0443\u043B\u0430 \u043F\u043B\u043E\u0449\u0430\u0434\u0438
    \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430.
    | \u041E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u0435 \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u0413\u0435\u0440\u043E\u043D\u0430; \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u043D\u043E\u0432\u043E\u0433\u043E \u043A\u043B\u0430\u0441\u0441\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447. | | **\u0410\u043D\u0430\u043B\u0438\u0437**
    | \u041A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u0430\u044F \u0438\u043D\u0442\u0435\u0440\u043F\u043E\u043B\u044F\u0446\u0438\u044F
    \u0434\u043B\u044F \u0441\u0438\u043D\u0443\u0441\u043E\u0432. | \u041F\u0435\u0440\u0432\u044B\u0439
    \u0448\u0430\u0433 \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445
    \u043C\u0435\u0442\u043E\u0434\u043E\u0432 \u0430\u043D\u0430\u043B\u0438\u0437\u0430.
    | | **\u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F** | \u0423\u0442\u043E\u0447\u043D\u0435\u043D\u0438\u0435
    \u0434\u043B\u0438\u043D\u044B \u0433\u043E\u0434\u0430 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043F\u0430\u0440\u0430\u043B\u043B\u0430\u043A\u0441\u0430. | \u041F\u043E\u0432\u044B\u0448\u0435\u043D\u0438\u0435
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u0439
    \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u0439 \u0438 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442. |"
  achievementsEn: 
  personalLifeRu: "\u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u0435\u0441\u043B\u0438 \u0440\u0435\u0447\u044C \u0438\u0434\u0435\u0442 \u043E
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438, \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u0439
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C \u043A\u0440\u0430\u0439\u043D\u0435
    \u043C\u0430\u043B\u043E. \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043C\u043E\u0433\u0443\u0442
    \u0432\u043E\u0441\u0441\u043E\u0437\u0434\u0430\u0442\u044C \u043B\u0438\u0448\u044C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0443\u044E
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B,
    \u0430 \u0434\u0435\u0442\u0430\u043B\u0438 \u0435\u0433\u043E \u0447\u0430\u0441\u0442\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438, \u0441\u0435\u043C\u044C\u0438 \u0438 \u0431\u044B\u0442\u0430
    \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C\u0438.
    \u0412\u0441\u044F \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u0430\u044F \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F,
