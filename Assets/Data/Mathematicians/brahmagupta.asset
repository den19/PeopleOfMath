    \u0442\u043E \u0435\u0441\u0442\u044C \u043F\u043E\u0447\u0438\u0442\u0430\u043B
    \u0431\u043E\u0433\u0430 \u0428\u0438\u0432\u0443 \u043A\u0430\u043A \u0432\u0435\u0440\u0445\u043E\u0432\u043D\u043E\u0435
    \u0431\u043E\u0436\u0435\u0441\u0442\u0432\u043E. *   **\u041C\u0435\u0441\u0442\u043E
    \u0438 \u043E\u0431\u0440\u0430\u0437 \u0436\u0438\u0437\u043D\u0438**: \u0411\u043E\u043B\u044C\u0448\u0443\u044E
    \u0447\u0430\u0441\u0442\u044C \u0436\u0438\u0437\u043D\u0438 \u043E\u043D \u043F\u0440\u043E\u0432\u0435\u043B
    \u0432 \u0440\u043E\u0434\u043D\u043E\u043C \u0411\u0445\u0438\u043D\u043C\u0430\u043B\u0435,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0442\u043E\u0433\u0434\u0430 \u0431\u044B\u043B
    \u0441\u0442\u043E\u043B\u0438\u0446\u0435\u0439 \u0446\u0430\u0440\u0441\u0442\u0432\u0430
    \u0413\u0443\u0440\u0434\u0436\u0430\u0440\u0430. \u041F\u0440\u0435\u0434\u043F\u043E\u043B\u0430\u0433\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0436\u0438\u043B \u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0442\u0430\u043C \u043F\u0440\u0438 \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435
    \u0446\u0430\u0440\u044F \u0412\u044C\u044F\u0433\u0440\u0430\u043C\u0443\u043A\u0445\u0438.
    *   **\u041F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0441\u0442\u0430\u0442\u0443\u0441 \u0438 \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435**:
    \u041E\u043D \u0431\u044B\u043B \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438 \u0432
    \u0423\u0434\u0434\u0436\u0430\u0439\u043D\u0435, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u0431\u044B\u043B\u0430 \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0446\u0435\u043D\u0442\u0440\u043E\u043C
    \u0418\u043D\u0434\u0438\u0438. \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0441\u0432\u043E\u0435\u043C\u0443 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044E
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0443\u0432\u0430\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435 **\u0411\u0445\u0438\u043B\u043B\u0430\u043C\u0430\u043B\u0430\u0447\u0430\u0440\u044C\u044F**,
    \u0447\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442 \xAB\u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u0438\u0437 \u0411\u0445\u0438\u043B\u043B\u0430\u043C\u0430\u043B\u044B\xBB.
    *   **\u041F\u043E\u0437\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B \u0438
    \u0441\u043C\u0435\u0440\u0442\u044C**: \u041F\u043E\u0437\u0434\u043D\u0435\u0435
    \u043E\u043D \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0423\u0434\u0434\u0436\u0430\u0439\u043D,
    \u0433\u0434\u0435 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 67
    \u043B\u0435\u0442 \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u0439
    \u0432\u0442\u043E\u0440\u043E\u0439 \u043A\u0440\u0443\u043F\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \xAB\u041A\u0445\u0430\u043D\u0434\u0430\u043A\u0445\u0430\u0434\u044C\u044F\u043A\u0430\xBB.
    \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E \u043E\u043D
    \u0443\u043C\u0435\u0440 \u0432 \u0423\u0434\u0434\u0436\u0430\u0439\u043D\u0435
    \u043E\u043A\u043E\u043B\u043E 668 \u0433\u043E\u0434\u0430.  \u0422\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u043C\u044B \u0437\u043D\u0430\u0435\u043C,
    \u0433\u0434\u0435 \u0438 \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u0436\u0438\u043B,
    \u043A\u0435\u043C \u0431\u044B\u043B \u0435\u0433\u043E \u043E\u0442\u0435\u0446,
    \u043A\u0430\u043A\u043E\u0439 \u0440\u0435\u043B\u0438\u0433\u0438\u0438 \u043F\u0440\u0438\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0441\u044F
    \u0438 \u0433\u0434\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F \u043E \u0435\u0433\u043E
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438, \u0441\u0435\u043C\u044C\u0435,
    \u0432\u0437\u0430\u0438\u043C\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u0445
    \u0441 \u043B\u044E\u0434\u044C\u043C\u0438 \u0438\u043B\u0438 \u043F\u043E\u0432\u0441\u0435\u0434\u043D\u0435\u0432\u043D\u044B\u0445
    \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0430\u0445 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0443\u0435\u0442. \u0412\u0441\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435 \u043D\u0430\u043C \u0444\u0430\u043A\u0442\u044B
    \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043A \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u0435
    \u0438 \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u044E \u0443\u0447\u0435\u043D\u044B\u0445
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u043C\u0443
    \u043F\u043E \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u0430\u043C."
  personalLifeEn: 
  shortBioRu: "**\u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430** 
    \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0438 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u0432, \u0436\u0438\u0432\u0448\u0438\u0439
    \u0432 VII \u0432\u0435\u043A\u0435. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432 \u0438\u0441\u043B\u0430\u043C\u0441\u043A\u043E\u043C
    \u043C\u0438\u0440\u0435, \u0430 \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u0433\u043E
    \u2014 \u0438 \u0432 \u0415\u0432\u0440\u043E\u043F\u0435. \u041E\u043D \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u043A\u0430\u043A \u043F\u0435\u0440\u0432\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u0432\u0448\u0438\u0439
    \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0439 \u0441 \u043D\u0443\u043B\u0435\u043C
    \u0438 \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0447\u0438\u0441\u043B\u0430\u043C\u0438.  ### \U0001F4DC \u0416\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0439
    \u043F\u0443\u0442\u044C \u0438 \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u0441\u0440\u0435\u0434\u0430 
    *   **\u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435**:
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u043E\u043A\u043E\u043B\u043E 598 \u0433\u043E\u0434\u0430 (\u043F\u043E \u0435\u0433\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u0437\u0430\u043F\u0438\u0441\u044F\u043C)
    \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u0411\u0445\u0438\u043B\u043B\u0430\u043C\u0430\u043B\u0430
    (\u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0439 \u0411\u0445\u0438\u043D\u043C\u0430\u043B)
    \u0432 \u0448\u0442\u0430\u0442\u0435 \u0420\u0430\u0434\u0436\u0430\u0441\u0442\u0445\u0430\u043D,
    \u0421\u0435\u0432\u0435\u0440\u043E-\u0417\u0430\u043F\u0430\u0434\u043D\u0430\u044F
    \u0418\u043D\u0434\u0438\u044F. \u0415\u0433\u043E \u043E\u0442\u0446\u043E\u043C
    \u0431\u044B\u043B \u0414\u0436\u0438\u0448\u043D\u0443\u0433\u0443\u043F\u0442\u0430.
    *   **\u041C\u0435\u0441\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u044B**:
    \u0411\u043E\u043B\u044C\u0448\u0443\u044E \u0447\u0430\u0441\u0442\u044C \u0441\u0432\u043E\u0435\u0439
    \u043A\u0430\u0440\u044C\u0435\u0440\u044B \u043E\u043D \u0431\u044B\u043B \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0439 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438 \u0432
    \u0423\u0434\u0434\u0436\u0430\u0439\u043D\u0435 \u2014 \u0433\u043B\u0430\u0432\u043D\u043E\u043C
    \u043D\u0430\u0443\u0447\u043D\u043E\u043C \u0446\u0435\u043D\u0442\u0440\u0435
    \u0434\u0440\u0435\u0432\u043D\u0435\u0439 \u0418\u043D\u0434\u0438\u0438, \u0433\u0434\u0435
    \u0434\u043E \u043D\u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C
    \u0412\u0430\u0440\u0430\u0445\u0430\u043C\u0438\u0445\u0438\u0440\u0430. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u044D\u0442\u043E, \u0441\u0432\u043E\u0451 \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0435 \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0432 \u0440\u043E\u0434\u043D\u043E\u043C \u0411\u0445\u0438\u043D\u043C\u0430\u043B\u0435.
    *   **\u0425\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u044F \u0442\u0440\u0443\u0434\u043E\u0432**:
    \u0421\u0432\u043E\u0438 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0432 \u0437\u0440\u0435\u043B\u043E\u043C
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435:     *   \u0412 **628 \u0433\u043E\u0434\u0443**
    (\u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 30 \u043B\u0435\u0442)
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u0439
    \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434 \u2014 \xAB\u0411\u0440\u0430\u0445\u043C\u0430-\u0441\u043F\u0445\u0443\u0442\u0430-\u0441\u0438\u0434\u0434\u0445\u0430\u043D\u0442\u0430\xBB.    
    *   \u0412 **665 \u0433\u043E\u0434\u0443** (\u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    67 \u043B\u0435\u0442) \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0432\u0442\u043E\u0440\u0443\u044E
    \u0432\u0430\u0436\u043D\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443 \u2014
    \xAB\u041A\u0445\u0430\u043D\u0434\u0430\u043A\u0445\u0430\u0434\u044C\u044F\u043A\u0430\xBB. 
    ### \u270D\uFE0F \u0413\u043B\u0430\u0432\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B
    \u0438 \u0438\u0445 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  #### 1.
    \xAB\u0411\u0440\u0430\u0445\u043C\u0430-\u0441\u043F\u0445\u0443\u0442\u0430-\u0441\u0438\u0434\u0434\u0445\u0430\u043D\u0442\u0430\xBB
    (\xAB\u0423\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u043D\u043E\u0435
    \u0443\u0447\u0435\u043D\u0438\u0435 \u0411\u0440\u0430\u0445\u043C\u044B\xBB,
    628 \u0433.)  \u042D\u0442\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442, \u0441\u043E\u0441\u0442\u043E\u044F\u0449\u0438\u0439
    \u0438\u0437 25 \u0433\u043B\u0430\u0432, \u0431\u043E\u043B\u044C\u0448\u0430\u044F
    \u0447\u0430\u0441\u0442\u044C \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0441\u043B\u0430\u0432\u0443 \u0435\u043C\u0443
    \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0438 \u0434\u0432\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u043B\u0430\u0432\u044B (12-\u044F \u0438 18-\u044F), \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0442\u0430\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439
    \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0435\u0439
    \u0437\u043D\u0430\u043D\u0438\u0439 \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    :  *   **\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430**: \u0412\u043F\u0435\u0440\u0432\u044B\u0435
    \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u0431\u044B\u043B\u0438 \u0447\u0435\u0442\u043A\u043E
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u044B
    \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439
    \u0441 \u043D\u0443\u043B\u0435\u043C \u0438 \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0447\u0438\u0441\u043B\u0430\u043C\u0438 (\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B \"\u0434\u043E\u043B\u0433\u0430\u043C\u0438\",
    \u0430 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u2014 \"\u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u043C\"). \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043E\u043D \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B, \u0447\u0442\u043E
    `x - x = 0` \u0438 \u0447\u0442\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0434\u0432\u0443\u0445 \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u0435\u0441\u0442\u044C \u0447\u0438\u0441\u043B\u043E
    \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435.
    *   **\u0410\u043B\u0433\u0435\u0431\u0440\u0430**: \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434\u044B \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0438, \u0447\u0442\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432\u0430\u0436\u043D\u043E,
    \u0443\u0434\u0435\u043B\u0438\u043B \u0431\u043E\u043B\u044C\u0448\u043E\u0435
    \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435 \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u043C
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C \u0432\u0438\u0434\u0430
    `Nx\xB2 + 1 = y\xB2`. \u041F\u043E\u0437\u0436\u0435 \u044D\u0442\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u0431\u0443\u0434\u0435\u0442 \u043D\u0430\u0437\u0432\u0430\u043D\u043E \"\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435\u043C
    \u041F\u0435\u043B\u043B\u044F\", \u043D\u043E \u0438\u043C\u0435\u043D\u043D\u043E
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430 \u043D\u0430\u0448\u0435\u043B
    \u043E\u0431\u0449\u0438\u0439 \u043C\u0435\u0442\u043E\u0434 \u0434\u043B\u044F
    \u0435\u0433\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u044F. *   **\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F**:
    \u041E\u043D \u0434\u0430\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0434\u043B\u044F \u043F\u043B\u043E\u0449\u0430\u0434\u0438
    **\u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E (\u0446\u0438\u043A\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E)
    \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0435\u0433\u043E\u0434\u043D\u044F
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430 \u043A\u0430\u043A **\u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B**: `S = \u221A((s-a)(s-b)(s-c)(s-d))`,
    \u0433\u0434\u0435 `s` \u2014 \u043F\u043E\u043B\u0443\u043F\u0435\u0440\u0438\u043C\u0435\u0442\u0440.
    \u042D\u0442\u043E \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u0435 \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u0413\u0435\u0440\u043E\u043D\u0430 \u0434\u043B\u044F \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430. 
    #### 2. \xAB\u041A\u0445\u0430\u043D\u0434\u0430\u043A\u0445\u0430\u0434\u044C\u044F\u043A\u0430\xBB
    (\xAB\u041B\u0430\u043A\u043E\u043C\u044B\u0439 \u043A\u0443\u0441\u043E\u0447\u0435\u043A\xBB,
    665 \u0433.)  \u042D\u0442\u0430 \u043A\u043D\u0438\u0433\u0430 \u043D\u043E\u0441\u0438\u043B\u0430
    \u0431\u043E\u043B\u0435\u0435 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440 \u0438 \u0431\u044B\u043B\u0430
    \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0430
    \u0434\u043B\u044F \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432-\u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u0432.
    \u0412 \u043D\u0435\u0439 \u043E\u043D \u0443\u0442\u043E\u0447\u043D\u0438\u043B
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0440\u0430\u0441\u0447\u0435\u0442\u044B \u0438, \u0447\u0442\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0432\u0430\u0436\u043D\u043E, \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    **\u0438\u043D\u0442\u0435\u0440\u043F\u043E\u043B\u044F\u0446\u0438\u043E\u043D\u043D\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443** \u0434\u043B\u044F \u0431\u043E\u043B\u0435\u0435
    \u0442\u043E\u0447\u043D\u043E\u0433\u043E \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0441\u0438\u043D\u0443\u0441\u043E\u0432.  ### \U0001F30C \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B  \u0412 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430 \u0431\u044B\u043B
    \u0444\u0438\u0433\u0443\u0440\u043E\u0439 \u0441\u043B\u043E\u0436\u043D\u043E\u0439
    \u0438 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u043E\u0439: 
    *   **\u041D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u0442\u0432\u043E**: \u0412
    \u0441\u0432\u043E\u0438\u0445 \u0440\u0430\u0441\u0447\u0435\u0442\u0430\u0445
    \u043E\u043D \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B
    \u0438\u0434\u0435\u044E \u043E \u0442\u043E\u043C, \u0447\u0442\u043E **\u041B\u0443\u043D\u0430
    \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F \u0431\u043B\u0438\u0436\u0435
    \u043A \u0417\u0435\u043C\u043B\u0435, \u0447\u0435\u043C \u0421\u043E\u043B\u043D\u0446\u0435**.
    *   **\u041A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u0442\u0438\u0437\u043C**:
    \u0411\u0443\u0434\u0443\u0447\u0438 \u043E\u0440\u0442\u043E\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u044B\u043C
    \u0438\u043D\u0434\u0443\u0438\u0441\u0442\u043E\u043C, \u043E\u043D \u0440\u0435\u0437\u043A\u043E
    \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B \u0438\u0434\u0435\u0438
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0430
    **\u0410\u0440\u0438\u0430\u0431\u0445\u0430\u0442\u044B** \u043E \u0442\u043E\u043C,
    \u0447\u0442\u043E \u0417\u0435\u043C\u043B\u044F \u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F
    \u0432\u043E\u043A\u0440\u0443\u0433 \u0441\u0432\u043E\u0435\u0439 \u043E\u0441\u0438.
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430 \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u043B
    \u043D\u0430 \u043D\u0435\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u043E\u0441\u0442\u0438
    \u0417\u0435\u043C\u043B\u0438, \u0430 \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439
    \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0445 \u0438 \u043B\u0443\u043D\u043D\u044B\u0445
    \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u0439 \u0441\u0447\u0438\u0442\u0430\u043B
    \u0434\u0435\u043C\u043E\u043D\u0430 \u0420\u0430\u0445\u0443, \u043A\u0430\u043A
    \u044D\u0442\u043E \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B\u043E \u0438\u0437
    \u0432\u0435\u0434\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u0438. 
    ### \U0001F4D6 \u0420\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u0435
    \u0438\u0434\u0435\u0439  \u0420\u0430\u0431\u043E\u0442\u044B \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u043C\u0438\u0440. **\u0412
    771 \u0433\u043E\u0434\u0443**, \u0447\u0435\u0440\u0435\u0437 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438,
    \u043F\u043E \u043F\u0440\u0438\u043A\u0430\u0437\u0443 \u0431\u0430\u0433\u0434\u0430\u0434\u0441\u043A\u043E\u0433\u043E
    \u0445\u0430\u043B\u0438\u0444\u0430 \u0430\u043B\u044C-\u041C\u0430\u043D\u0441\u0443\u0440\u0430
    \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0442\u0440\u0443\u0434
    \u0431\u044B\u043B \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043D \u043D\u0430
    \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0439 \u044F\u0437\u044B\u043A \u043F\u043E\u0434
    \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435\u043C **\xAB\u0421\u0438\u043D\u0434\u0445\u0438\u043D\u0434\xBB**.
    \u042D\u0442\u043E\u0442 \u043F\u0435\u0440\u0435\u0432\u043E\u0434:  *   \u041F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B
    \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0439 \u043C\u0438\u0440 \u0441 \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u043E\u0439
    \u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439
    \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0438 \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u0438\u043C\u0438
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0430\u043C\u0438 \u0441\u0447\u0435\u0442\u0430.
    *   \u041E\u043A\u0430\u0437\u0430\u043B \u043F\u0440\u044F\u043C\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 **\u0430\u043B\u044C-\u0425\u043E\u0440\u0435\u0437\u043C\u0438**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0438\u0434\u0435\u0438 \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B
    \u0432 \u0441\u0432\u043E\u0438\u0445 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    \u043F\u043E \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438 \u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.  \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u043C \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0430\u043C,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0438 \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u0438\u043C,
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B
    \u0441\u0442\u0430\u043B\u043E \u0447\u0430\u0441\u0442\u044C\u044E \u043C\u0438\u0440\u043E\u0432\u043E\u0439
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0425\u043E\u0442\u044F \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u043D\u0435
    \u0438\u0437\u043E\u0431\u0438\u043B\u0443\u0435\u0442 \u0431\u044B\u0442\u043E\u0432\u044B\u043C\u0438
    \u0434\u0435\u0442\u0430\u043B\u044F\u043C\u0438, \u0436\u0438\u0437\u043D\u044C
    \u0438 \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u043A\u0430\u0440\u044C\u0435\u0440\u0430
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B \u043F\u043E\u043B\u043D\u044B
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445, \u0430
    \u043F\u043E\u0440\u043E\u0439 \u0438 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432. \u0412\u043E\u0442 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0437 \u043D\u0438\u0445, \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u044E\u0449\u0438\u0435
    \u0435\u0433\u043E \u043A\u0430\u043A \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u0443\u044E
    \u0438 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0432\u0443\u044E
    \u0444\u0438\u0433\u0443\u0440\u0443 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430\u0443\u043A\u0438.  ### \U0001F4DC \u041B\u0438\u0447\u043D\u043E\u0441\u0442\u044C,
    \u043F\u043E\u043B\u043D\u0430\u044F \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0439:
    \u0423\u0447\u0435\u043D\u044B\u0439 \u0438 \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432 
    \u041F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u044B\u0439 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0430\u0441\u043F\u0435\u043A\u0442 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B \u2014 \u044D\u0442\u043E
    \u0435\u0433\u043E \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0434\u0432\u043E\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C. 
    *   **\u041D\u0430\u0443\u0447\u043D\u044B\u0439 \u043D\u043E\u0432\u0430\u0442\u043E\u0440
    vs. \u0420\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0439 \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440**:
    \u0421 \u043E\u0434\u043D\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B,
    \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0440\u043E\u0440\u044B\u0432
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u0432
    \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439
    \u0441 \u043D\u0443\u043B\u0435\u043C \u0438 \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0447\u0438\u0441\u043B\u0430\u043C\u0438 \u0438 \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u0432 \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u0438. \u0421 \u0434\u0440\u0443\u0433\u043E\u0439
    \u0441\u0442\u043E\u0440\u043E\u043D\u044B, \u043E\u043D \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u0432\u0435\u0440\u0443\u044E\u0449\u0438\u043C \u0448\u0438\u0432\u0430\u0438\u0442\u043E\u043C
    \u0438 \u0432 \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u0445 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B \u043A\u0440\u0430\u0439\u043D\u0435
    \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u0442\u0438\u0432\u043D\u0443\u044E
    \u043F\u043E\u0437\u0438\u0446\u0438\u044E. *   **\u042F\u0440\u043E\u0441\u0442\u043D\u0430\u044F
    \u043A\u0440\u0438\u0442\u0438\u043A\u0430 \u0410\u0440\u0438\u0430\u0431\u0445\u0430\u0442\u044B**:
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u043E\u043F\u043F\u043E\u043D\u0435\u043D\u0442\u043E\u043C
    \u0431\u044B\u043B \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A
    \u0410\u0440\u0438\u0430\u0431\u0445\u0430\u0442\u0430. \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430
    \u0440\u0435\u0437\u043A\u043E \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B
    \u0438\u0434\u0435\u044E \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F \u0417\u0435\u043C\u043B\u0438,
    \u043D\u0430\u0437\u044B\u0432\u0430\u044F \u0442\u0435\u0445, \u043A\u0442\u043E
    \u0435\u0435 \u043F\u0440\u0438\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B\u0441\u044F,
    \"\u0438\u0437\u0433\u043E\u044F\u043C\u0438 \u0441\u0444\u0435\u0440\u044B\"
    (`gola-b\u0101hyena`), \u0442\u043E \u0435\u0441\u0442\u044C \u043B\u044E\u0434\u044C\u043C\u0438,
    \u0438\u0437\u0433\u043D\u0430\u043D\u043D\u044B\u043C\u0438 \u0438\u0437 \u043A\u0440\u0443\u0433\u0430
    \u0443\u0432\u0430\u0436\u0430\u0435\u043C\u044B\u0445 \u0443\u0447\u0435\u043D\u044B\u0445.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u043B
    \u043D\u0430 \u0442\u043E\u043C, \u0447\u0442\u043E \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0435
    \u0438 \u043B\u0443\u043D\u043D\u044B\u0435 \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u044F
    \u0432\u044B\u0437\u044B\u0432\u0430\u0435\u0442 \u0434\u0435\u043C\u043E\u043D
    \u0420\u0430\u0445\u0443, \u0430 \u043D\u0435 \u0442\u0435\u043D\u044C \u0417\u0435\u043C\u043B\u0438,
    \u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443 \u0442\u0430\u043A \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043E
    \u0432 \u0412\u0435\u0434\u0430\u0445. \u042D\u0442\u043E \u044F\u0440\u043A\u0438\u0439
    \u043F\u0440\u0438\u043C\u0435\u0440 \u0442\u043E\u0433\u043E, \u043A\u0430\u043A
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435 \u0434\u043E\u0433\u043C\u0430\u0442\u044B
    \u0431\u0440\u0430\u043B\u0438 \u0432\u0435\u0440\u0445 \u043D\u0430\u0434 \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F\u043C\u0438. *  
    **\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441 \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u044F**:
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043E\u0441\u0442\u0440\u0443\u044E
    \u043A\u0440\u0438\u0442\u0438\u043A\u0443 \u0432 \u0430\u0434\u0440\u0435\u0441
    \u0410\u0440\u0438\u0430\u0431\u0445\u0430\u0442\u044B \u0432 \u0440\u0430\u043D\u043D\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442\u0430\u0445, \u0432 \u0441\u0432\u043E\u0435\u043C
    \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0435\u043C \u0442\u0440\u0443\u0434\u0435
    \xAB\u041A\u0445\u0430\u043D\u0434\u0430\u043A\u0445\u0430\u0434\u044C\u044F\u043A\u0430\xBB
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430 \u043E\u0442\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u043E \u043D\u0435\u043C \u0441 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C
    \u043F\u043E\u0447\u0442\u0435\u043D\u0438\u0435\u043C, \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u044F
    \u0435\u0433\u043E \u0432\u0435\u043B\u0438\u0447\u0438\u0435.  ### \U0001F30C
    \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u044F: \u0413\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u044F
    \u0438 \u0444\u043E\u0440\u043C\u0430 \u0417\u0435\u043C\u043B\u0438  \u0412\u043E\u043F\u0440\u0435\u043A\u0438
    \u0441\u0432\u043E\u0438\u043C \u043A\u043E\u043D\u0441\u0435\u0440\u0432\u0430\u0442\u0438\u0432\u043D\u044B\u043C
    \u0432\u0437\u0433\u043B\u044F\u0434\u0430\u043C \u043D\u0430 \u0437\u0430\u0442\u043C\u0435\u043D\u0438\u044F,
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0430 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438 \u0441\u0432\u043E\u0435
    \u0432\u0440\u0435\u043C\u044F.  *   **\u0418\u043D\u0442\u0443\u0438\u0446\u0438\u044F
    \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u0438**: \u041E\u043D
    \u043F\u0435\u0440\u0432\u044B\u043C \u0438\u0437 \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u0438\u0445
    \u0443\u0447\u0435\u043D\u044B\u0445 \u043E\u043F\u0438\u0441\u0430\u043B \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u044E
    \u043A\u0430\u043A \u0441\u0438\u043B\u0443 \u043F\u0440\u0438\u0442\u044F\u0436\u0435\u043D\u0438\u044F,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u0442\u0435\u0440\u043C\u0438\u043D
    **\xAB\u0433\u0443\u0440\u0443\u0442\u0432\u0430\u043A\u0430\u0440\u0448\u0430\u043D\u0430\u043C\xBB**.
    \u0412 \u0441\u0432\u043E\u0435\u043C \u0442\u0440\u0443\u0434\u0435 \u043E\u043D
    \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u043B \u043F\u0430\u0434\u0435\u043D\u0438\u0435
    \u0442\u0435\u043B \u043D\u0430 \u0417\u0435\u043C\u043B\u044E \u0442\u0435\u043C,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0437\u0430\u043B\u043E\u0436\u0435\u043D\u043E
    \u0432 \u043F\u0440\u0438\u0440\u043E\u0434\u0435 \u0417\u0435\u043C\u043B\u0438
    \u2014 \u043F\u0440\u0438\u0442\u044F\u0433\u0438\u0432\u0430\u0442\u044C \u0432\u0435\u0449\u0438,
    \u043F\u043E\u0434\u043E\u0431\u043D\u043E \u0442\u043E\u043C\u0443, \u043A\u0430\u043A
    \u043F\u0440\u0438\u0440\u043E\u0434\u0430 \u0432\u043E\u0434\u044B \u2014 \u0442\u0435\u0447\u044C.
    *   **\u0428\u0430\u0440\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u0430\u044F
    \u0417\u0435\u043C\u043B\u044F**: \u041E\u043D \u0441\u043C\u0435\u043B\u043E
    \u0437\u0430\u044F\u0432\u043B\u044F\u043B, \u0447\u0442\u043E \u0417\u0435\u043C\u043B\u044F
    \u0438 \u043D\u0435\u0431\u043E \u0438\u043C\u0435\u044E\u0442 \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443, \u0438 \u0434\u0430\u0436\u0435 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u0417\u0435\u043C\u043B\u044F \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F.
    \u041D\u0430 \u043A\u0440\u0438\u0442\u0438\u043A\u0443, \u0447\u0442\u043E \u0441
    \u0448\u0430\u0440\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u043E\u0439 \u0417\u0435\u043C\u043B\u0438
    \u0434\u043E\u043B\u0436\u043D\u044B \u0431\u044B\u043B\u0438 \u0431\u044B \u043F\u0430\u0434\u0430\u0442\u044C
    \u043A\u0430\u043C\u043D\u0438 \u0438 \u0434\u0435\u0440\u0435\u0432\u044C\u044F,
    \u043E\u043D \u043E\u0442\u0432\u0435\u0447\u0430\u043B, \u0447\u0442\u043E \u0432\u0441\u0435
    \u0442\u044F\u0436\u0435\u043B\u044B\u0435 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B
    \u043F\u0440\u0438\u0442\u044F\u0433\u0438\u0432\u0430\u044E\u0442\u0441\u044F
    \u043A \u0446\u0435\u043D\u0442\u0440\u0443 \u0417\u0435\u043C\u043B\u0438, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \u043B\u044E\u0434\u0438 \u0441\u0442\u043E\u044F\u0442 \u043D\u0430 \u043D\u0435\u0439
    \u0441\u043E \u0432\u0441\u0435\u0445 \u0441\u0442\u043E\u0440\u043E\u043D. 
    ### \U0001F9EE \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043D\u043E\u0432\u0430\u0446\u0438\u0438: \u041D\u043E\u043B\u044C \u0438 \u043F\u043E\u044D\u0437\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B  \u0415\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u043F\u043E\u0440\u0430\u0436\u0430\u044E\u0442
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0432\u043E\u0435\u0439
    \u0433\u043B\u0443\u0431\u0438\u043D\u043E\u0439, \u043D\u043E \u0438 \u0444\u043E\u0440\u043C\u043E\u0439
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u044F.  *   **\u041D\u043E\u043B\u044C
    \u043A\u0430\u043A \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E**: \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430
    \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u043C, \u043A\u0442\u043E \u043D\u0430\u0447\u0430\u043B
    \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0442\u044C
    \u043D\u043E\u043B\u044C \u043D\u0435 \u043A\u0430\u043A \u0441\u0438\u043C\u0432\u043E\u043B
    \u043F\u0443\u0441\u0442\u043E\u0442\u044B, \u0430 \u043A\u0430\u043A \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E, \u0443\u0447\u0430\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0435
    \u0432 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F\u0445. \u041E\u043D
    \u0434\u0430\u043B \u0447\u0435\u0442\u043A\u0438\u0435 \u043F\u0440\u0430\u0432\u0438\u043B\u0430
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438 \u0441 \u043D\u0443\u043B\u0435\u043C,
    \u0445\u043E\u0442\u044F \u0438 \u043E\u0448\u0438\u0431\u0441\u044F, \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044F,
    \u0447\u0442\u043E `0/0 = 0`. *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0432 \u0441\u0442\u0438\u0445\u0430\u0445**: \u0421\u0432\u043E\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u044B \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u0430
    \u043F\u0438\u0441\u0430\u043B \u0432 \u0441\u0442\u0438\u0445\u043E\u0442\u0432\u043E\u0440\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u0435, \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u043E\u0431\u044B\u0447\u043D\u043E\u0439
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u043E\u0439 \u0432 \u0434\u0440\u0435\u0432\u043D\u0435\u0439
    \u0418\u043D\u0434\u0438\u0438. \u042D\u0442\u043E \u043F\u0440\u0438\u0434\u0430\u0432\u0430\u043B\u043E
    \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u0430\u043C \u043F\u043E\u044D\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0437\u0432\u0443\u0447\u0430\u043D\u0438\u0435, \u043D\u043E, \u043A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u043E\u043D \u043D\u0435 \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432
    \u0441\u0432\u043E\u0438\u0445 \u0442\u0435\u043E\u0440\u0435\u043C, \u0438\u0437\u043B\u0430\u0433\u0430\u044F
    \u043B\u0438\u0448\u044C \u0433\u043E\u0442\u043E\u0432\u044B\u0435 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
    \u0438 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u044B. *   **\u041A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u044F
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439**: \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u0442\u0430\u043A \u0432\u0435\u043B\u0438\u043A, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0438\u043C\u0435\u043D\u0435\u043C \u043D\u0430\u0437\u0432\u0430\u043D\u044B
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432: **\u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B** (\u0434\u043B\u044F
    \u043F\u043B\u043E\u0449\u0430\u0434\u0438 \u0432\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0433\u043E
    \u0447\u0435\u0442\u044B\u0440\u0435\u0445\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430),
    **\u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B**,
    **\u0442\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u043E \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B-\u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438**
    \u0438 \u0438\u043D\u0442\u0435\u0440\u043F\u043E\u043B\u044F\u0446\u0438\u043E\u043D\u043D\u0430\u044F
    \u0444\u043E\u0440\u043C\u0443\u043B\u0430.  ### \U0001F451 \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  *   **\u0422\u0438\u0442\u0443\u043B
    \"\u0413\u0435\u043C\u043C\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432\"**:
    \u041F\u043E\u0437\u0434\u043D\u0435\u0439\u0448\u0438\u0439 \u0432\u0435\u043B\u0438\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0411\u0445\u0430\u0441\u043A\u0430\u0440\u0430
    II \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u043E\u043C
    \u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B, \u0447\u0442\u043E
    \u0443\u0434\u043E\u0441\u0442\u043E\u0438\u043B \u0435\u0433\u043E \u0442\u0438\u0442\u0443\u043B\u0430
    **\xAB\u0413\u0430\u043D\u0438\u0442\u0430 \u0427\u0430\u043A\u0440\u0430 \u0427\u0443\u0434\u0430\u043C\u0430\u043D\u0438\xBB**
    \u2014 \"\u0414\u0440\u0430\u0433\u043E\u0446\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u043A\u0440\u0443\u0433\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432\".
    *   **\u0412\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0432\u0435\u0441\u044C
    \u043C\u0438\u0440**: \u0418\u043C\u0435\u043D\u043D\u043E \u0447\u0435\u0440\u0435\u0437
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u044B \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u043E\u0432
    \u043D\u0430 \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0439 \u044F\u0437\u044B\u043A
    (\u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \xAB\u0411\u0440\u0430\u0445\u043C\u0430-\u0441\u043F\u0445\u0443\u0442\u0430-\u0441\u0438\u0434\u0434\u0445\u0430\u043D\u0442\u044B\xBB)
    \u0438\u0441\u043B\u0430\u043C\u0441\u043A\u0438\u0439 \u043C\u0438\u0440 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u043E\u0439 \u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439 \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F.
    \u042D\u0442\u043E \u0437\u043D\u0430\u043D\u0438\u0435 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0447\u0435\u0440\u0435\u0437 \u0430\u0440\u0430\u0431\u043E\u0432 \u043F\u043E\u043F\u0430\u043B\u043E
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0443, \u043E\u043A\u0430\u0437\u0430\u0432
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0432\u0441\u0435\u0439
    \u043C\u0438\u0440\u043E\u0432\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    ### \U0001F4DD \u0417\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0438\u0442\u043E\u0433 \u0432 \u0442\u0430\u0431\u043B\u0438\u0446\u0435  |
    \u0410\u0441\u043F\u0435\u043A\u0442 | \u0417\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442 | | :--- | :--- | | **\u041B\u0438\u0447\u043D\u043E\u0441\u0442\u044C**
    | \u0421\u043E\u0435\u0434\u0438\u043D\u044F\u043B \u0432 \u0441\u0435\u0431\u0435
    \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0438\u0434\u0435\u0438. \u041A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B
    \u0410\u0440\u0438\u0430\u0431\u0445\u0430\u0442\u0443 \u0437\u0430 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044E,
    \u043D\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B \u0435\u0433\u043E
    \u0433\u0435\u043D\u0438\u0439 \u0432 \u043F\u043E\u0437\u0434\u043D\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442\u0430\u0445. | | **\u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F**
    | \u041F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u043B \u0442\u0435\u043E\u0440\u0438\u044E
    \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u0438, \u043D\u0430\u0437\u044B\u0432\u0430\u044F
    \u0435\u0435 \u0441\u0438\u043B\u043E\u0439 \u043F\u0440\u0438\u0442\u044F\u0436\u0435\u043D\u0438\u044F
    \u0417\u0435\u043C\u043B\u0438. \u0423\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u0417\u0435\u043C\u043B\u044F \u0448\u0430\u0440\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u0430.
    | | **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430** | \u0411\u044B\u043B
    \u043F\u0435\u0440\u0432\u044B\u043C, \u043A\u0442\u043E \u0434\u0430\u043B \u043F\u0440\u0430\u0432\u0438\u043B\u0430
    \u0434\u043B\u044F \u043D\u043E\u043B\u044F \u043A\u0430\u043A \u0447\u0438\u0441\u043B\u0430.
    \u0421\u0432\u043E\u0438 \u0442\u0440\u0443\u0434\u044B \u043F\u0438\u0441\u0430\u043B
    \u0432 \u0441\u0442\u0438\u0445\u043E\u0442\u0432\u043E\u0440\u043D\u043E\u0439
    \u0444\u043E\u0440\u043C\u0435 \u0438 \u043D\u0435 \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432.
    | | **\u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435** | \u0411\u044B\u043B
    \u043D\u0430\u0437\u0432\u0430\u043D \xAB\u0414\u0440\u0430\u0433\u043E\u0446\u0435\u043D\u043D\u043E\u0441\u0442\u044C\u044E
    \u043A\u0440\u0443\u0433\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432\xBB.
    \u0415\u0433\u043E \u0442\u0440\u0443\u0434\u044B \u0431\u044B\u043B\u0438 \u043F\u0435\u0440\u0435\u0432\u0435\u0434\u0435\u043D\u044B
