    \u0438 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0439 \u0432 \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u0445 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0442\u043E\u0440\u043E\u0432. 
