  achievementsRu: "\u0413\u0435\u0440\u0434 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0432\u043B\u0438\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0441\u0442\u0438,
    \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0438 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0447\u0438\u0441\u0435\u043B. \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0438 \u043C\u043E\u0449\u043D\u044B\u0445
    \u043D\u043E\u0432\u044B\u0445 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438
    \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u0442\u044C \u0434\u0430\u0432\u043D\u0438\u0435
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B, \u043E\u0442\u043A\u0440\u044B\u0432
    \u043D\u043E\u0432\u044B\u0435 \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u044B
    \u0434\u043B\u044F \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439.
    \u0417\u0430 \u044D\u0442\u0438 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u0432\u044B\u0441\u0448\u0438\u0445 \u043D\u0430\u0433\u0440\u0430\u0434 \u0432
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044E \u0410\u0431\u0435\u043B\u044F 2026 \u0433\u043E\u0434\u0430. 
    ### \U0001F9E9 \u0420\u0435\u0448\u0435\u043D\u0438\u0435 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B
    \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430 (\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u0430)  \u0421\u0430\u043C\u044B\u043C
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435\u043C
    \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u0430 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    **\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430**
    \u0432 1983 \u0433\u043E\u0434\u0443. \u042D\u0442\u0430 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430,
    \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u0442\u0430\u044F \u0432 1922 \u0433\u043E\u0434\u0443,
    \u0431\u043E\u043B\u0435\u0435 60 \u043B\u0435\u0442 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u043D\u0435\u0440\u0435\u0448\u0435\u043D\u043D\u044B\u0445 \u043F\u0440\u043E\u0431\u043B\u0435\u043C
    \u0432 \u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. 
    *   **\u0412 \u0447\u0435\u043C \u0441\u0443\u0442\u044C \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B**:
    \u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0434\u043B\u044F \u0433\u043B\u0430\u0434\u043A\u043E\u0439
    \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0439 \u043A\u0440\u0438\u0432\u043E\u0439
    \u0440\u043E\u0434\u0430 \u0431\u043E\u043B\u044C\u0448\u0435 \u0435\u0434\u0438\u043D\u0438\u0446\u044B,
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0439 \u043D\u0430\u0434
    \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u043C \u043F\u043E\u043B\u0435\u043C,
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u043B\u0438\u0448\u044C
    \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435 \u0447\u0438\u0441\u043B\u043E
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0442\u043E\u0447\u0435\u043A.
    \u041F\u0440\u043E\u0449\u0435 \u0433\u043E\u0432\u043E\u0440\u044F, \u0434\u043B\u044F
    \u0448\u0438\u0440\u043E\u043A\u043E\u0433\u043E \u043A\u043B\u0430\u0441\u0441\u0430
    \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u043B\u0438\u0448\u044C
    \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435 \u0447\u0438\u0441\u043B\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u0432 \u0432\u0438\u0434\u0435 \u0434\u0440\u043E\u0431\u0435\u0439
    (\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B).
    *   **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0434\u043B\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0424\u0435\u0440\u043C\u0430**: \u0427\u0442\u043E\u0431\u044B \u043F\u043E\u043D\u044F\u0442\u044C
    \u0432\u0430\u0436\u043D\u043E\u0441\u0442\u044C \u044D\u0442\u043E\u0433\u043E
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430, \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u0432\u0441\u043F\u043E\u043C\u043D\u0438\u0442\u044C \u0412\u0435\u043B\u0438\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u0424\u0435\u0440\u043C\u0430 (x\u207F
    + y\u207F = z\u207F). \u0414\u043B\u044F n \u2265 4 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u0424\u0435\u0440\u043C\u0430 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u0442
    \u043A\u0440\u0438\u0432\u0443\u044E \u0440\u043E\u0434\u0430 > 1. \u0418\u0437
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u0430
    \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E \u0441\u043B\u0435\u0434\u0443\u0435\u0442,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u043C\u043E\u0436\u0435\u0442 \u0438\u043C\u0435\u0442\u044C \u043B\u0438\u0448\u044C
    **\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435 \u0447\u0438\u0441\u043B\u043E**
    \u0446\u0435\u043B\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0445
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 (\u043F\u0440\u0438 n > 3). \u042D\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u0440\u0435\u0448\u0430\u044E\u0449\u0438\u043C
    \u0448\u0430\u0433\u043E\u043C \u043D\u0430 \u043F\u0443\u0442\u0438 \u043A \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u043C\u0443
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0424\u0435\u0440\u043C\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043F\u043E\u0437\u0436\u0435 \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B
    \u042D\u043D\u0434\u0440\u044E \u0423\u0430\u0439\u043B\u0441, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0432
    \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 \u0438 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B,
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u043D\u044B\u0435
    \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u043E\u043C. *   **\u041D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u0439
    \u043C\u0435\u0442\u043E\u0434**: \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430, \u043E\u043F\u0438\u0440\u0430\u044F\u0441\u044C
    \u043D\u0430 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u043D\u043E\u0432\u044B\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434. \u0412\u043C\u0435\u0441\u0442\u043E \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u0435\u0442\u043E\u0434\u043E\u0432 \u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B\u0445
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u0439 \u043E\u043D
    \u0440\u0435\u0448\u0438\u043B \u0434\u0432\u0435 \u0434\u0440\u0443\u0433\u0438\u0435
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u2014 **\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447\u0430** \u0438 **\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u0422\u0435\u0439\u0442\u0430** \u0434\u043B\u044F \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439 \u043D\u0430\u0434
    \u0447\u0438\u0441\u043B\u043E\u0432\u044B\u043C\u0438 \u043F\u043E\u043B\u044F\u043C\u0438.
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u044B\u0442\u0435\u043A\u0430\u0435\u0442 \u0438\u0437 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B
    \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447\u0430, \u0438 \u0437\u0430\u0442\u0435\u043C
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u044D\u0442\u0443 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044E\u044E. \u042D\u0442\u043E
    \u043F\u0440\u043E\u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u043E
    \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u0441\u0432\u044F\u0437\u044C
    \u043C\u0435\u0436\u0434\u0443 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439
    \u0438 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u043E\u0439.  ###
    \U0001F9ED \u0420\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0438 \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u044F:
    \u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430 \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430-\u041B\u0430\u043D\u0433\u0430 
    \u0420\u0430\u0431\u043E\u0442\u0430 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u0430
    \u043D\u0430 \u044D\u0442\u043E\u043C \u043D\u0435 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0430\u0441\u044C.
    \u0412\u0434\u043E\u0445\u043D\u043E\u0432\u0438\u0432\u0448\u0438\u0441\u044C
    \u043D\u043E\u0432\u044B\u043C \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430,
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u043C \u041F\u043E\u043B\u043E\u043C
    \u0412\u043E\u0439\u0442\u043E\u0439 \u0432 1991 \u0433\u043E\u0434\u0443, \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u0430\u0434\u0430\u043F\u0442\u0438\u0440\u043E\u0432\u0430\u043B \u0438 \u0440\u0430\u0437\u0432\u0438\u043B
    \u0435\u0433\u043E \u043C\u0435\u0442\u043E\u0434\u044B.  \u0412 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435
    \u0432 1991 \u0433\u043E\u0434\u0443 \u043E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    **\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443 \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430-\u041B\u0430\u043D\u0433\u0430**.
    \u042D\u0442\u043E \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u0431\u043E\u043B\u0435\u0435
    \u043E\u0431\u0449\u0435\u0435 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442
    \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0442\u043E\u0447\u0435\u043A
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0430 \u043A\u0440\u0438\u0432\u044B\u0445,
    \u0430 \u043D\u0430 \u043B\u044E\u0431\u044B\u0445 \u043F\u043E\u0434\u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u044F\u0445
    \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439
    (\u043C\u043D\u043E\u0433\u043E\u043C\u0435\u0440\u043D\u044B\u0445 \u0430\u043D\u0430\u043B\u043E\u0433\u043E\u0432
    \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0438\u0432\u044B\u0445).  ### \U0001F9EC \u0412\u043A\u043B\u0430\u0434
    \u0432 p-\u0430\u0434\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0442\u0435\u043E\u0440\u0438\u044E
    \u0425\u043E\u0434\u0436\u0430  \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u0432\u043D\u0435\u0441 \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0449\u0438\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 **p-\u0430\u0434\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u0425\u043E\u0434\u0436\u0430** \u2014
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0438\u0449\u0435\u0442 \u0430\u043D\u0430\u043B\u043E\u0433\u0438 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0425\u043E\u0434\u0436\u0430 (\u0441\u0432\u044F\u0437\u044B\u0432\u0430\u044E\u0449\u0435\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044E \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u0445 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439)
    \u0434\u043B\u044F \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439
    \u043D\u0430\u0434 p-\u0430\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043F\u043E\u043B\u044F\u043C\u0438.  *   \u041E\u043D \u0434\u0430\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0445 \u0433\u0438\u043F\u043E\u0442\u0435\u0437,
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0414\u0436\u043E\u043D\u043E\u043C \u0422\u0435\u0439\u0442\u043E\u043C \u0438
    \u0416\u0430\u043D-\u041C\u0430\u0440\u043A\u043E\u043C \u0424\u043E\u043D\u0442\u0435\u043D\u043E\u043C,
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0432 \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E
    \u0441\u0432\u044F\u0437\u044C \u043C\u0435\u0436\u0434\u0443 p-\u0430\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u044D\u0442\u0430\u043B\u044C\u043D\u044B\u043C \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u044F\u043C\u0438
    \u0438 \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u044F\u043C\u0438
    \u0434\u0435 \u0420\u0430\u043C\u0430. *   \u041E\u043D \u0432\u0432\u0435\u043B
    \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u0435 \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B, \u0442\u0430\u043A\u0438\u0435
    \u043A\u0430\u043A **\"\u043F\u043E\u0447\u0442\u0438 \u044D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u044F\"**, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0442\u0430\u043B\u0438 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u043C\u0438
    \u0434\u043B\u044F \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u0433\u043E
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F \u0432\u0441\u0435\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438.
    *   \u0415\u0433\u043E \u0438\u0434\u0435\u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u0443 \u0434\u043B\u044F **p-\u0430\u0434\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u044F \u0421\u0438\u043C\u043F\u0441\u043E\u043D\u0430**,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043D\u0435\u0430\u0431\u0435\u043B\u0435\u0432\u044B\u043C \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u0435\u043C
    p-\u0430\u0434\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0425\u043E\u0434\u0436\u0430 \u0438 \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u0435\u0442
    p-\u0430\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u044B \u0441 \u0440\u0430\u0441\u0441\u043B\u043E\u0435\u043D\u0438\u044F\u043C\u0438
    \u0425\u0438\u0433\u0433\u0441\u0430.  ### \U0001F6E0\uFE0F \u0418\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u0432\u0430\u0436\u043D\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B  \u041F\u043E\u043C\u0438\u043C\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0445 \u0433\u0438\u043F\u043E\u0442\u0435\u0437,
    \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441 \u0441\u043E\u0437\u0434\u0430\u043B
    \u0446\u0435\u043B\u044B\u0439 \u0440\u044F\u0434 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432 \u0438
    \u0442\u0435\u043E\u0440\u0438\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430\u043C\u0438 \u043F\u043E
    \u0432\u0441\u0435\u043C\u0443 \u043C\u0438\u0440\u0443:  *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0438
    \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u0430 (Product Theorem)**:
    \u0411\u044B\u043B \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D
    \u0434\u043B\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430-\u041B\u0430\u043D\u0433\u0430
    \u0438 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043C\u043E\u0449\u043D\u044B\u043C
    \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u0435\u043C \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u0420\u043E\u0442\u0430 \u043E \u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B\u0445
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u044F\u0445. \u041F\u043E\u0437\u0436\u0435,
    \u0432 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    \u0441 \u0413\u0438\u0441\u0431\u0435\u0440\u0442\u043E\u043C \u0412\u044E\u0441\u0442\u0445\u043E\u043B\u044C\u0446\u0435\u043C,
    \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u044D\u0442\u0443 \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u0434\u043B\u044F
    \u043D\u043E\u0432\u043E\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0420\u043E\u0442\u0430 \u0438 \u0435\u0435
    \u043C\u043D\u043E\u0433\u043E\u043C\u0435\u0440\u043D\u043E\u0433\u043E \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u044F
    \u2014 \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u043F\u043E\u0434\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430\u0445
    \u0428\u043C\u0438\u0434\u0442\u0430. *   **\u041A\u043E\u043C\u043F\u0430\u043A\u0442\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044F
    \u043C\u043E\u0434\u0443\u043B\u0435\u0439 \u0430\u0431\u0435\u043B\u0435\u0432\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439**: \u0412
    1990 \u0433\u043E\u0434\u0443 \u0432 \u0441\u0432\u043E\u0435\u0439 \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u0438,
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u043E\u0439 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0427\u0438\u043D-\u041B\u0438 \u0427\u0430\u0435\u043C, \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044E
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439 \u0417\u0438\u0433\u0435\u043B\u044F.
    \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u0441\u0442\u0430\u043B\u0430
    \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C \u043A\u0430\u043C\u043D\u0435\u043C
    \u0434\u043B\u044F \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u043E\u0434\u0435\u043B\u0435\u0439 \u0438 \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0439
    \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439 \u0428\u0438\u043C\u0443\u0440\u044B.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0432\u0435\u043A\u0442\u043E\u0440\u043D\u044B\u0445
    \u0440\u0430\u0441\u0441\u043B\u043E\u0435\u043D\u0438\u0439 \u043D\u0430 \u043A\u0440\u0438\u0432\u044B\u0445**:
    \u0412\u043D\u0435\u0441 \u0432\u0430\u0436\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u044D\u0442\u0443 \u043E\u0431\u043B\u0430\u0441\u0442\u044C, \u0432
    \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u0432
    \u0441\u0432\u043E\u0439 \u0432\u0430\u0440\u0438\u0430\u043D\u0442 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    **\u0444\u043E\u0440\u043C\u0443\u043B\u044B \u0412\u0435\u0440\u043B\u0438\u043D\u0434\u0435**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0438\u043C\u0435\u0435\u0442 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0435
    \u0441\u0432\u044F\u0437\u0438 \u0441 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0435\u0439 \u043F\u043E\u043B\u044F \u0438 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u0441\u0442\u0440\u0443\u043D.  ### \U0001F3C6 \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u0421\u043F\u0438\u0441\u043E\u043A \u043D\u0430\u0433\u0440\u0430\u0434 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u0430
    \u043B\u0443\u0447\u0448\u0435 \u0432\u0441\u0435\u0433\u043E \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
    \u043C\u0430\u0441\u0448\u0442\u0430\u0431 \u0435\u0433\u043E \u0432\u043B\u0438\u044F\u043D\u0438\u044F: 
    *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0410\u0431\u0435\u043B\u044F (2026)**
    \u2014 \u0437\u0430 \u0432\u043A\u043B\u0430\u0434 \u0432 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0438 \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437 \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430
    \u0438 \u041B\u0430\u043D\u0433\u0430. *   **\u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F (1986)** \u2014 \u0437\u0430 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430.
    *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0428\u0430\u043E (2015)** \u2014
    \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u0425\u0435\u043D\u0440\u0438\u043A\u043E\u043C
    \u0418\u0432\u0430\u043D\u0435\u0446\u0435\u043C. *   **\u041F\u0440\u0435\u043C\u0438\u044F
    \u0413\u043E\u0442\u0444\u0440\u0438\u0434\u0430 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u0430
    \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430 (1996)** \u2014 \u0432\u044B\u0441\u0448\u0430\u044F
    \u043D\u0430\u0433\u0440\u0430\u0434\u0430 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438
    \u0434\u043B\u044F \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439. 
    \u0413\u0435\u0440\u0434 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0435\u0448\u0438\u043B
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447; \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u044F\u0437\u044B\u043A \u0438 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0433\u043E\u0432\u043E\u0440\u0438\u0442
    \u0438 \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438 \u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u043B\u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E
    \u0438 \u0442\u0435\u043E\u0440\u0438\u044E \u0447\u0438\u0441\u0435\u043B \u0432
    \u0435\u0434\u0438\u043D\u0443\u044E \u043C\u043E\u0449\u043D\u0443\u044E \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0443,
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044E\u0449\u0443\u044E \u043F\u0440\u0438\u043D\u043E\u0441\u0438\u0442\u044C
    \u043D\u043E\u0432\u044B\u0435 \u043F\u043B\u043E\u0434\u044B."
  achievementsEn: 
  personalLifeRu: "\u0418\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F \u043E
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438 \u0438 \u0441\u0435\u043C\u044C\u0435
    \u0413\u0435\u0440\u0434\u0430 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u0430
    \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u0430, \u043E\u0434\u043D\u0430\u043A\u043E
    \u043E\u043D\u0430, \u043A\u0430\u043A \u0438 \u0443 \u043C\u043D\u043E\u0433\u0438\u0445
    \u043A\u0440\u0443\u043F\u043D\u044B\u0445 \u0443\u0447\u0435\u043D\u044B\u0445,
    \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E \u0441\u043A\u0443\u043F\u0430
    \u0438 \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0435\u043D\u0430
    \u0432\u043E\u043A\u0440\u0443\u0433 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u0444\u0430\u043A\u0442\u043E\u0432. 
    ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466 \u0421\u0435\u043C\u044C\u044F
    \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435 
    \u0413\u0435\u0440\u0434 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 28 \u0438\u044E\u043B\u044F 1954 \u0433\u043E\u0434\u0430
    \u0432 \u0440\u0430\u0439\u043E\u043D\u0435 \u0411\u044E\u0440 \u0433\u043E\u0440\u043E\u0434\u0430
    \u0413\u0435\u043B\u044C\u0437\u0435\u043D\u043A\u0438\u0440\u0445\u0435\u043D
    (\u0444\u0435\u0434\u0435\u0440\u0430\u043B\u044C\u043D\u0430\u044F \u0437\u0435\u043C\u043B\u044F
    \u0421\u0435\u0432\u0435\u0440\u043D\u044B\u0439 \u0420\u0435\u0439\u043D-\u0412\u0435\u0441\u0442\u0444\u0430\u043B\u0438\u044F).
    \u041E\u043D \u0432\u044B\u0440\u043E\u0441 \u0432 \u0441\u0435\u043C\u044C\u0435
    \u0443\u0447\u0435\u043D\u044B\u0445: \u0435\u0433\u043E \u043E\u0442\u0435\u0446
    \u0431\u044B\u043B \u0444\u0438\u0437\u0438\u043A\u043E\u043C, \u0430 \u043C\u0430\u0442\u044C
    \u2014 \u0445\u0438\u043C\u0438\u043A\u043E\u043C, \u0438 \u043E\u0431\u0430
    \u0438\u043C\u0435\u043B\u0438 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0438\u0435
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438. \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u044D\u0442\u0430 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0441\u0440\u0435\u0434\u0430 \u0441 \u0440\u0430\u043D\u043D\u0438\u0445 \u043B\u0435\u0442
    \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0430 \u043D\u0430 \u0435\u0433\u043E
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441 \u043A \u0442\u043E\u0447\u043D\u044B\u043C
    \u043D\u0430\u0443\u043A\u0430\u043C.  ### \u2764\uFE0F \u0411\u0440\u0430\u043A
    \u0438 \u0434\u0435\u0442\u0438  \u0416\u0438\u0437\u043D\u044C \u0443\u0447\u0435\u043D\u043E\u0433\u043E
    \u0431\u044B\u043B\u0430 \u0442\u0435\u0441\u043D\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u0430
    \u0441 \u0435\u0433\u043E \u0441\u0443\u043F\u0440\u0443\u0433\u043E\u0439, \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0410\u043D\u0433\u0435\u043B\u0438\u043A\u043E\u0439 \u0427\u0438\u043C\u043C\u0435\u043B\u044C
    (Angelika Tschimmel). \u041E\u043D\u0438 \u043F\u043E\u0436\u0435\u043D\u0438\u043B\u0438\u0441\u044C
    \u0432 1984 \u0433\u043E\u0434\u0443. \u0412 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u043C
    \u0433\u043E\u0434\u0443, \u0432 1985-\u043C, \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u043F\u0440\u0438\u043D\u044F\u043B \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u043E\u0442 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0438
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0441 \u0436\u0435\u043D\u043E\u0439
    \u0432 \u0421\u0428\u0410. \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C,
    \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435, \u0443 \u043F\u0430\u0440\u044B
    \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C \u0434\u0432\u0435 \u0434\u043E\u0447\u0435\u0440\u0438
    \u2014 \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430 \u0438 \u0423\u043B\u044C\u0440\u0438\u043A\u0435. 
    ### \u23F3 \u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044E \u0438 \u043F\u043E\u0442\u0435\u0440\u044F 
    \u0412 1994 \u0433\u043E\u0434\u0443 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u0441\u0435\u043C\u044C\u0435\u0439
    \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044E,
    \u0447\u0442\u043E\u0431\u044B \u0432\u043E\u0437\u0433\u043B\u0430\u0432\u0438\u0442\u044C
    \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u041E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u041C\u0430\u043A\u0441\u0430
    \u041F\u043B\u0430\u043D\u043A\u0430 \u0432 \u0411\u043E\u043D\u043D\u0435. 
    \u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E, \u0432 2011 \u0433\u043E\u0434\u0443
    \u0435\u0433\u043E \u0436\u0435\u043D\u0430 \u0410\u043D\u0433\u0435\u043B\u0438\u043A\u0430
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u0443\u0448\u043B\u0430
    \u0438\u0437 \u0436\u0438\u0437\u043D\u0438 \u0438\u0437-\u0437\u0430 \u0440\u0430\u043A\u0430.
    \u0421 \u0442\u0435\u0445 \u043F\u043E\u0440 \u043E\u043D \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0432\u0434\u043E\u0432\u0446\u043E\u043C.  \u0421\u0430\u043C \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u0432 \u043E\u0434\u043D\u043E\u043C \u0438\u0437 \u0438\u043D\u0442\u0435\u0440\u0432\u044C\u044E
    \u0441 \u044E\u043C\u043E\u0440\u043E\u043C \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u0436\u0438\u0437\u043D\u044C, \u0433\u043E\u0432\u043E\u0440\u044F,
    \u0447\u0442\u043E \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F
    \u043F\u0440\u0435\u043C\u0438\u0438 \u0435\u0433\u043E \u0441\u043B\u0430\u0432\u0430
    \u0431\u044B\u043B\u0430 \u043D\u0435\u0434\u043E\u043B\u0433\u043E\u0439 \u0438
    \u043E\u043D \u043C\u043E\u0433 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E
    \u0445\u043E\u0434\u0438\u0442\u044C \u043F\u043E \u043C\u0430\u0433\u0430\u0437\u0438\u043D\u0430\u043C,
    \u0430 \u0432 \u043E\u0442\u0432\u0435\u0442 \u043D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441
    \u043E \u0441\u0430\u043C\u043E\u043C \u0437\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u044E\u0449\u0435\u043C\u0441\u044F
    \u0434\u043D\u0435 \u0432 \u0436\u0438\u0437\u043D\u0438 \u0448\u0443\u0442\u0438\u043B,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0431\u044B\u043B \u0434\u0435\u043D\u044C
    \u0435\u0433\u043E \u0436\u0435\u043D\u0438\u0442\u044C\u0431\u044B, \u0438\u043D\u0430\u0447\u0435
    \u0431\u044B \u0435\u0433\u043E \u0436\u0435\u043D\u0430 \u043D\u0430 \u043D\u0435\u0433\u043E
    \u043E\u0431\u0438\u0434\u0435\u043B\u0430\u0441\u044C. \u042D\u0442\u0438 \u0441\u043B\u043E\u0432\u0430
    \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u0438\u0432\u0430\u044E\u0442 \u0432\u0430\u0436\u043D\u043E\u0441\u0442\u044C
    \u0441\u0435\u043C\u044C\u0438 \u0434\u043B\u044F \u043D\u0435\u0433\u043E."
  personalLifeEn: 
  shortBioRu: "\u0413\u0435\u0440\u0434 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    (Gerd Faltings) \u2014 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443. \u0412 2026 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u0441\u0442\u0430\u043B \u043F\u0435\u0440\u0432\u044B\u043C \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C, \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D\u043D\u044B\u043C
    \u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F
    \u0430\u043D\u0430\u043B\u043E\u0433\u043E\u043C \u041D\u043E\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    \u0420\u0430\u043D\u0435\u0435, \u0432 1986 \u0433\u043E\u0434\u0443, \u043E\u043D
    \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B \u043D\u0430\u0433\u0440\u0430\u0436\u0434\u0435\u043D
    \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0435\u0439,
    \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u0435\u0442 \u0435\u0433\u043E \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043D\u0435\u043C\u043D\u043E\u0433\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u043F\u043E\u043B\u0443\u0447\u0438\u0432\u0448\u0438\u0445 \u043E\u0431\u0435
    \u0432\u044B\u0441\u0448\u0438\u0435 \u043D\u0430\u0433\u0440\u0430\u0434\u044B
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. 
    \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u043D\u0430 \u0430\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445. 
    ### \U0001F4DC \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B  \u0413\u0435\u0440\u0434
    \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    **28 \u0438\u044E\u043B\u044F 1954 \u0433\u043E\u0434\u0430** \u0432 \u0440\u0430\u0439\u043E\u043D\u0435
    \u0411\u044E\u0440 \u0433\u043E\u0440\u043E\u0434\u0430 \u0413\u0435\u043B\u044C\u0437\u0435\u043D\u043A\u0438\u0440\u0445\u0435\u043D
    (\u0444\u0435\u0434\u0435\u0440\u0430\u043B\u044C\u043D\u0430\u044F \u0437\u0435\u043C\u043B\u044F
    \u0421\u0435\u0432\u0435\u0440\u043D\u044B\u0439 \u0420\u0435\u0439\u043D-\u0412\u0435\u0441\u0442\u0444\u0430\u043B\u0438\u044F,
    \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044F). \u041E\u043D \u0432\u044B\u0440\u043E\u0441
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u0443\u0447\u0435\u043D\u044B\u0445: \u0435\u0433\u043E
    \u043E\u0442\u0435\u0446 \u0431\u044B\u043B \u0444\u0438\u0437\u0438\u043A\u043E\u043C,
    \u0430 \u043C\u0430\u0442\u044C \u2014 \u0445\u0438\u043C\u0438\u043A\u043E\u043C,
    \u043E\u0431\u0430 \u0438\u043C\u0435\u043B\u0438 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0438\u0435
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438.  \u0418\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0443 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u0430
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u0434\u043E\u0432\u043E\u043B\u044C\u043D\u043E
    \u0440\u0430\u043D\u043E. \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u043E\u043A\u043E\u043B\u043E 12 \u043B\u0435\u0442 \u043E\u043D \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u0443\u0432\u043B\u0435\u043A\u0441\u044F \u0444\u0438\u0437\u0438\u043A\u043E\u0439,
    \u043D\u043E \u0437\u0430\u0442\u0435\u043C \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u043B\u0441\u044F
    \u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u043B\u0430 \u0435\u0433\u043E \u0441\u0432\u043E\u0435\u0439
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0439
    \u044F\u0441\u043D\u043E\u0441\u0442\u044C\u044E: *\xAB\u0432\u0435\u0449\u0438
    \u043B\u0438\u0431\u043E \u0438\u0441\u0442\u0438\u043D\u043D\u044B, \u043B\u0438\u0431\u043E
    \u043B\u043E\u0436\u043D\u044B, \u0438 \u044D\u0442\u043E \u043D\u0435 \u0432\u043E\u043F\u0440\u043E\u0441
    \u043C\u043D\u0435\u043D\u0438\u044F\xBB*.  \u041F\u043E\u0441\u043B\u0435 \u043E\u043A\u043E\u043D\u0447\u0430\u043D\u0438\u044F
    \u0448\u043A\u043E\u043B\u044B Max-Planck-Gymnasium \u0432 \u0413\u0435\u043B\u044C\u0437\u0435\u043D\u043A\u0438\u0440\u0445\u0435\u043D\u0435
    \u0432 1972 \u0433\u043E\u0434\u0443 , \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0412\u0435\u0441\u0442\u0444\u0430\u043B\u044C\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0438\u043C\u0435\u043D\u0438
    \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u0430 \u0432 \u041C\u044E\u043D\u0441\u0442\u0435\u0440\u0435,
    \u0433\u0434\u0435 \u0438\u0437\u0443\u0447\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0438 \u0444\u0438\u0437\u0438\u043A\u0443. \u0415\u0433\u043E \u0443\u0447\u0435\u0431\u0430
    \u0431\u044B\u043B\u0430 \u043F\u0440\u0435\u0440\u0432\u0430\u043D\u0430 \u043D\u0430
    18 \u043C\u0435\u0441\u044F\u0446\u0435\u0432 \u0438\u0437-\u0437\u0430 \u0441\u043B\u0443\u0436\u0431\u044B
    \u0432 \u0430\u0440\u043C\u0438\u0438.  ### \U0001F393 \u041D\u0430\u0443\u0447\u043D\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430: \u043E\u0442 \u041C\u044E\u043D\u0441\u0442\u0435\u0440\u0430
    \u0434\u043E \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0430  - **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u041C\u044E\u043D\u0441\u0442\u0435\u0440\u0430 (1972\u20131982)**: \u0412 1978
    \u0433\u043E\u0434\u0443 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435,
    \u043F\u043E\u043B\u0443\u0447\u0438\u0432 \u0434\u0438\u043F\u043B\u043E\u043C
    \u0438 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    (Ph.D.) \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u0425\u0430\u043D\u0441\u0430-\u0419\u043E\u0430\u0445\u0438\u043C\u0430
    \u041D\u0430\u0441\u0442\u043E\u043B\u044C\u0434\u0430. \u0415\u0433\u043E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0435. \u0421\u0440\u0430\u0437\u0443 \u043F\u043E\u0441\u043B\u0435
    \u0437\u0430\u0449\u0438\u0442\u044B \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u044E \u041D\u0435\u043C\u0435\u0446\u043A\u043E\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u043E-\u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 (DFG) \u0438 \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0433\u043E\u0434 \u0432 \u0413\u0430\u0440\u0432\u0430\u0440\u0434\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u0430.
    \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C \u0432 \u041C\u044E\u043D\u0441\u0442\u0435\u0440
    \u0432 1979 \u0433\u043E\u0434\u0443, \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0430\u0441\u0441\u0438\u0441\u0442\u0435\u043D\u0442\u043E\u043C \u0443 \u041D\u0430\u0441\u0442\u043E\u043B\u044C\u0434\u0430
    \u0438 \u0432 1981 \u0433\u043E\u0434\u0443 \u0443\u0441\u043F\u0435\u0448\u043D\u043E
    \u043F\u0440\u043E\u0448\u0435\u043B \u0445\u0430\u0431\u0438\u043B\u0438\u0442\u0430\u0446\u0438\u044E,
    \u0447\u0442\u043E \u0434\u0430\u043B\u043E \u0435\u043C\u0443 \u043F\u0440\u0430\u0432\u043E
    \u043D\u0430 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C. - **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u0412\u0443\u043F\u043F\u0435\u0440\u0442\u0430\u043B\u044F (1982\u20131984)**:
    \u0412 1982 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    28 \u043B\u0435\u0442, \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u0441\u0442\u0430\u043B \u043F\u043E\u043B\u043D\u044B\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0412\u0443\u043F\u043F\u0435\u0440\u0442\u0430\u043B\u044F,
    \u0441\u0442\u0430\u0432 \u0441\u0430\u043C\u044B\u043C \u043C\u043E\u043B\u043E\u0434\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438 \u043D\u0430 \u0442\u043E\u0442
    \u043C\u043E\u043C\u0435\u043D\u0442. \u0418\u043C\u0435\u043D\u043D\u043E \u0432
    \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434 \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u0441\u0432\u043E\u0435 \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435.
    - **\u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u0438\u0439
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 (1985\u20131994)**:
    \u0412 1985 \u0433\u043E\u0434\u0443 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u043F\u0440\u0438\u043D\u044F\u043B \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u043E\u0442 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0433\u043E
    \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 (\u0421\u0428\u0410),
    \u0433\u0434\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u043F\u043E\u0447\u0442\u0438 \u0434\u0435\u0441\u044F\u0442\u044C \u043B\u0435\u0442.
    \u0422\u0430\u043C \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0410\u043D\u0433\u0435\u043B\u0438\u043A\u0435
    \u0427\u0438\u043C\u043C\u0435\u043B\u044C (\u0443\u043C\u0435\u0440\u043B\u0430
    \u0432 2011 \u0433\u043E\u0434\u0443), \u0438 \u0443 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C
    \u0434\u0432\u0435 \u0434\u043E\u0447\u0435\u0440\u0438, \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430
    \u0438 \u0423\u043B\u044C\u0440\u0438\u043A\u0435.  ### \U0001F4A1 \u0413\u043B\u0430\u0432\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435: \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430 
    \u0412 1983 \u0433\u043E\u0434\u0443, \u0440\u0430\u0431\u043E\u0442\u0430\u044F
    \u0435\u0449\u0435 \u0432 \u0412\u0443\u043F\u043F\u0435\u0440\u0442\u0430\u043B\u0435,
    \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432, \u0434\u043E\u043A\u0430\u0437\u0430\u0432
    **\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443 \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430**.
    \u0410\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u041B\u0443\u0438\u0441 \u041C\u043E\u0440\u0434\u0435\u043B\u043B \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0435\u0435 \u0435\u0449\u0435 \u0432 1922 \u0433\u043E\u0434\u0443. \u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B\u0430, \u0447\u0442\u043E
    \u0434\u043B\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0440\u0438\u0432\u044B\u0445 \u0440\u043E\u0434\u0430 \u0431\u043E\u043B\u044C\u0448\u0435
    \u0435\u0434\u0438\u043D\u0438\u0446\u044B \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043B\u0438\u0448\u044C \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435 \u0447\u0438\u0441\u043B\u043E
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445 \u0442\u043E\u0447\u0435\u043A.
    \u041F\u0440\u043E\u0449\u0435 \u0433\u043E\u0432\u043E\u0440\u044F, \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0435
    \u0442\u0438\u043F\u044B \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u043C\u043E\u0433\u0443\u0442 \u0438\u043C\u0435\u0442\u044C \u043B\u0438\u0448\u044C
    \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435 \u0447\u0438\u0441\u043B\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u0439 \u0432 \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u043B\u0430\u0445 (\u0434\u0440\u043E\u0431\u044F\u0445). 
    \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u044D\u0442\u043E\u0439 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C \u043D\u0435\u0440\u0435\u0448\u0435\u043D\u043D\u043E\u0439
    \u0431\u043E\u043B\u0435\u0435 60 \u043B\u0435\u0442, \u0441\u0442\u0430\u043B\u043E
    \u0441\u0435\u043D\u0441\u0430\u0446\u0438\u0435\u0439 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043C\u0438\u0440\u0435. \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u043C\u0435\u0442\u043E\u0434\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0441\u043E\u0437\u0434\u0430\u043B\u0438 \u043D\u043E\u0432\u043E\u0435 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0432 \u043D\u0430\u0443\u043A\u0435, \u0441\u043E\u0435\u0434\u0438\u043D\u0438\u0432
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0438 \u0442\u0435\u043E\u0440\u0438\u044E
    \u0447\u0438\u0441\u0435\u043B. \u0412\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0430 \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430
    \u0441\u0442\u0430\u043B\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u043A\u0430\u043A **\u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u0430**.
    \u0421\u0430\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B\u0441\u044F,
    \u0447\u0442\u043E \u0438\u0437\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u043D\u0435 \u0431\u044B\u043B \u0443\u0432\u0435\u0440\u0435\u043D \u0432 \u0443\u0441\u043F\u0435\u0445\u0435
    \u0438 \u043D\u0430\u0434\u0435\u044F\u043B\u0441\u044F \u043B\u0438\u0448\u044C
    \u043D\u0430 \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u0447\u043D\u044B\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B.  ### \U0001F3C6
    \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438 \u043D\u0430\u0433\u0440\u0430\u0434\u044B 
    \u0417\u0430 \u0441\u0432\u043E\u0435 \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0435\u0441\u044F
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043D\u0430\u0433\u0440\u0430\u0434:  - **\u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F (1986)**: \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    32 \u043B\u0435\u0442 \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u0432\u044B\u0441\u0448\u0435\u0439 \u043D\u0430\u0433\u0440\u0430\u0434\u044B
    \u0434\u043B\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u043C\u043B\u0430\u0434\u0448\u0435 40 \u043B\u0435\u0442 \u043D\u0430 \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u043C
    \u043A\u043E\u043D\u0433\u0440\u0435\u0441\u0441\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.
    - **\u041F\u0440\u0435\u043C\u0438\u044F \u0413\u043E\u0442\u0444\u0440\u0438\u0434\u0430
    \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u0430 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    (1996)**: \u0412\u044B\u0441\u0448\u0430\u044F \u043D\u0430\u0433\u0440\u0430\u0434\u0430
    \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438 \u0434\u043B\u044F \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439,
    \u043F\u0440\u0438\u0441\u0443\u0436\u0434\u0430\u0435\u043C\u0430\u044F \u041D\u0435\u043C\u0435\u0446\u043A\u0438\u043C
    \u043D\u0430\u0443\u0447\u043D\u043E-\u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u043C
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E\u043C (DFG). - **\u041F\u0440\u0435\u043C\u0438\u044F
    \u0428\u0430\u043E (2015)**: \u041F\u043E\u043B\u0443\u0447\u0438\u043B \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0425\u0435\u043D\u0440\u0438\u043A\u043E\u043C \u0418\u0432\u0430\u043D\u0435\u0446\u0435\u043C
    \u0437\u0430 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B. - **\u041F\u0440\u0435\u043C\u0438\u044F \u0410\u0431\u0435\u043B\u044F
    (2026)**: \u0421\u0442\u0430\u043B \u043F\u0435\u0440\u0432\u044B\u043C \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D\u043D\u044B\u043C
    \u044D\u0442\u043E\u0439 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0435\u0439\u0448\u0435\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438 \xAB\u0437\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439, \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u044E\u0449\u0438\u0445
    \u0446\u0435\u043B\u044B\u0435 \u0447\u0438\u0441\u043B\u0430\xBB.  \u0422\u0430\u043A\u0436\u0435
    \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0447\u043B\u0435\u043D\u043E\u043C \u043C\u043D\u043E\u0433\u0438\u0445 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u043D\u0430\u0443\u043A, \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u041B\u0435\u043E\u043F\u043E\u043B\u044C\u0434\u0438\u043D\u0443
    (1992), \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0435 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E (2016) \u0438 \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A \u0421\u0428\u0410
    (2018). \u0415\u0433\u043E \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0432\u043A\u043B\u044E\u0447\u0430\u044E\u0442
    \u041E\u0444\u0438\u0446\u0435\u0440\u0441\u043A\u0438\u0439 \u043A\u0440\u0435\u0441\u0442
    (2009) \u0438 \u0411\u043E\u043B\u044C\u0448\u043E\u0439 \u043A\u0440\u0435\u0441\u0442
    \u0441\u043E \u0437\u0432\u0435\u0437\u0434\u043E\u0439 (2025) \u043E\u0440\u0434\u0435\u043D\u0430
    \xAB\u0417\u0430 \u0437\u0430\u0441\u043B\u0443\u0433\u0438 \u043F\u0435\u0440\u0435\u0434
    \u0424\u0435\u0434\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u043E\u0439 \u0420\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0439
    \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044F\xBB.  ### \U0001F3EB \u0420\u0430\u0431\u043E\u0442\u0430
    \u0432 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u041C\u0430\u043A\u0441\u0430
    \u041F\u043B\u0430\u043D\u043A\u0430 \u0438 \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C  \u0412
    1994 \u0433\u043E\u0434\u0443 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044E,
    \u0441\u0442\u0430\u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u043C,
    \u0430 \u0441 1995 \u0433\u043E\u0434\u0430 \u2014 \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u043E\u043C
    \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u041E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u041C\u0430\u043A\u0441\u0430
    \u041F\u043B\u0430\u043D\u043A\u0430 \u0432 \u0411\u043E\u043D\u043D\u0435. \u041E\u043D
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B \u044D\u0442\u043E\u0442 \u043F\u043E\u0441\u0442
    \u0434\u043E \u0432\u044B\u0445\u043E\u0434\u0430 \u043D\u0430 \u043F\u0435\u043D\u0441\u0438\u044E
    \u0432 2023 \u0433\u043E\u0434\u0443, \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u044F \u0432 \u0411\u043E\u043D\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435.  \u041D\u0430
    \u043F\u043E\u0441\u0442\u0443 \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u0430
    \u043E\u043D \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u043E\u0439, \u043A\u0443\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0441\u0432\u043E\u044E
    \u0430\u043A\u0442\u0438\u0432\u043D\u0443\u044E \u043D\u0430\u0443\u0447\u043D\u0443\u044E
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C. \u0415\u0433\u043E
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B
    \u0431\u044B\u043B\u0438 \u043E\u0447\u0435\u043D\u044C \u0448\u0438\u0440\u043E\u043A\u0438:
    \u043E\u0442 \u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438 p-\u0430\u0434\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0425\u043E\u0434\u0436\u0430 \u0434\u043E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u043A\u0442\u043E\u0440\u043D\u044B\u0445
    \u0440\u0430\u0441\u0441\u043B\u043E\u0435\u043D\u0438\u0439 \u043D\u0430 \u043A\u0440\u0438\u0432\u044B\u0445.
    \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C
    \u043C\u043D\u043E\u0433\u0438\u0445 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0421\u0438\u043D\u044A\u0438\u0442\u0438 \u041C\u043E\u0442\u0438\u0434\u0437\u0443\u043A\u0438. 
    \u0413\u0435\u0440\u0434 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442 \u0432\u043D\u043E\u0441\u0438\u0442\u044C
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043C\u0438\u0440\u043E\u0432\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443, \u043E\u0441\u0442\u0430\u0432\u0430\u044F\u0441\u044C
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445
    \u0444\u0438\u0433\u0443\u0440 \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435."
  shortBioEn: 
  interestingFactsRu: "\u0413\u0435\u0440\u0434 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u2014 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0432\u0435\u043B\u0438\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u043D\u043E \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A
    \u0441 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u043C\u0438 \u0432\u0437\u0433\u043B\u044F\u0434\u0430\u043C\u0438
    \u0438 \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0430\u043C\u0438. \u0417\u0430
    \u0441\u0442\u0440\u043E\u0433\u0438\u043C\u0438 \u0444\u043E\u0440\u043C\u0443\u043B\u0430\u043C\u0438
    \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C,
    \u043F\u043E\u043B\u043D\u0430\u044F \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0445
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043E\u0432, \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0434\u0430\u0436\u0435 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043E\u0437\u043E\u0440\u0441\u0442\u0432\u0430.  \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435 \u0444\u0430\u043A\u0442\u044B
    \u0438\u0437 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438 \u0438 \u043A\u0430\u0440\u044C\u0435\u0440\u044B,
    \u0441\u043E\u0431\u0440\u0430\u043D\u043D\u044B\u0435 \u0438\u0437 \u043D\u0435\u0434\u0430\u0432\u043D\u0438\u0445
    \u0438\u043D\u0442\u0435\u0440\u0432\u044C\u044E \u0438 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432.  ### \U0001F9D1\u200D\U0001F3EB
    \u0421\u0430\u043C\u044B\u0439 \u043C\u043E\u043B\u043E\u0434\u043E\u0439 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0438 \"\u0441\u043B\u0443\u0447\u0430\u0439\u043D\u0430\u044F\" \u0441\u043B\u0430\u0432\u0430 
    \u0412 1982 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    27 \u043B\u0435\u0442, \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u0441\u0442\u0430\u043B **\u0441\u0430\u043C\u044B\u043C \u043C\u043E\u043B\u043E\u0434\u044B\u043C
    \u043F\u043E\u043B\u043D\u044B\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438**.
    \u042D\u0442\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435
    \u0431\u044B\u043B\u043E \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u044F\u044E\u0449\u0438\u043C
    \u0441\u0430\u043C\u043E \u043F\u043E \u0441\u0435\u0431\u0435, \u043D\u043E
    \u0443\u0436\u0435 \u043D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
    \u0433\u043E\u0434 \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043D\u0435\u0447\u0442\u043E, \u0447\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B\u043E
    \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u043C
    \u043D\u0430 \u0432\u0435\u0441\u044C \u043C\u0438\u0440.  \u0421\u0430\u043C\u043E\u0435
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435, \u0447\u0442\u043E,
    \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0430\u044F \u043A \u0440\u0430\u0431\u043E\u0442\u0435
    \u043D\u0430\u0434 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u043E\u0439 \u041C\u043E\u0440\u0434\u0435\u043B\u043B\u0430,
    \u043E\u043D **\u043D\u0435 \u0441\u0442\u0430\u0432\u0438\u043B \u043F\u0435\u0440\u0435\u0434
    \u0441\u043E\u0431\u043E\u0439 \u0446\u0435\u043B\u044C \u0435\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C**.
    \u041E\u043D \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442, \u0447\u0442\u043E
    \u0434\u0440\u0443\u0433 \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044F, \u041B\u044E\u0441\u044C\u0435\u043D
    \u0428\u043F\u0438\u0440\u043E, \u043F\u043E\u0434\u0435\u043B\u0438\u043B\u0441\u044F
    \u0441 \u043D\u0438\u043C \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438
    \u0438\u0434\u0435\u044F\u043C\u0438. \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u043F\u043E\u0434\u0443\u043C\u0430\u043B: *\xAB\u042F, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0438 \u043D\u0435 \u0434\u043E\u043A\u0430\u0436\u0443 \u0435\u0435, \u043D\u043E
    \u0438\u0437 \u044D\u0442\u043E\u0433\u043E \u043C\u043E\u0436\u0435\u0442 \u0432\u044B\u0439\u0442\u0438
    \u0447\u0442\u043E-\u0442\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E\u0435\xBB*.
    \u041A\u043E\u0433\u0434\u0430 \u0435\u043C\u0443 \u044D\u0442\u043E \u0443\u0434\u0430\u043B\u043E\u0441\u044C,
    \u043E\u043D \u0441\u0430\u043C \u0431\u044B\u043B \u0443\u0434\u0438\u0432\u043B\u0435\u043D.
    \u041E\u043D \u0434\u0430\u0436\u0435 \u0448\u0443\u0442\u0438\u043B, \u0447\u0442\u043E
    \u0435\u043C\u0443 \u043F\u0440\u043E\u0441\u0442\u043E **\"\u043F\u043E\u0432\u0435\u0437\u043B\u043E\"**,
    \u0438 \u0447\u0442\u043E \u0441 \u0442\u0435\u0445 \u043F\u043E\u0440 \u043E\u043D
    **\"\u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u043F\u0435\u0440\u0432\u044B\u043C \u043A\u043B\u0430\u0441\u0441\u043E\u043C
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435\"**. \u041E\u043D
    \u0442\u0430\u043A\u0436\u0435 \u043E\u0442\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E
    \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043D\u0435 \u0432\u043E\u0441\u043F\u0440\u0438\u043D\u044F\u043B\u0438 \u0438\u0434\u0435\u0438
    \u0428\u043F\u0438\u0440\u043E \u0432\u0441\u0435\u0440\u044C\u0435\u0437, \u0447\u0442\u043E
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u043E \u044D\u0442\u043E \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0431\u0435\u0437
    \u043A\u043E\u043D\u043A\u0443\u0440\u0435\u043D\u0442\u043E\u0432 \u0434\u043B\u044F
    \u043D\u0435\u0433\u043E.  ### \U0001F4A1 \u0421\u043A\u0435\u043F\u0442\u0438\u043A-\u043E\u0434\u0438\u043D\u043E\u0447\u043A\u0430:
    \"\u042F \u043D\u0435 \u043B\u044E\u0431\u043B\u044E \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u043D\u0435 \u043E\u0431\u0434\u0443\u043C\u0430\u043B\" 
    \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u044F\u0440\u043A\u0438\u043C \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u0435\u043B\u0435\u043C
    **\u0438\u043D\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434\u0430** \u0432 \u043D\u0430\u0443\u043A\u0435.
    \u041E\u043D \u043F\u0440\u0438\u0437\u043D\u0430\u0435\u0442\u0441\u044F: *\xAB\u042F
    \u043D\u0435 \u043B\u044E\u0431\u043B\u044E \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u043D\u0435 \u043E\u0431\u0434\u0443\u043C\u0430\u043B
    \u0441\u0430\u043C\xBB*. \u0418\u0434\u0435\u0438 \u043F\u0440\u0438\u0445\u043E\u0434\u044F\u0442
    \u043A \u043D\u0435\u043C\u0443 \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043F\u0440\u043E\u0433\u0443\u043B\u043E\u043A
    \u0438\u043B\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u0441\u0430\u0434\u0443,
    \u043A\u043E\u0433\u0434\u0430 \u043C\u043E\u0437\u0433 \u043D\u0435 \u0437\u0430\u043D\u044F\u0442
    \u043D\u0438\u0447\u0435\u043C \u0434\u0440\u0443\u0433\u0438\u043C.  \u041E\u043D
    \u0441 \u044E\u043C\u043E\u0440\u043E\u043C \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0441\u044F
    \u043A \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C \u043C\u0435\u0442\u043E\u0434\u0430\u043C
    \u0440\u0430\u0431\u043E\u0442\u044B. \u041D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441
    \u043E \u0431\u0443\u0434\u0443\u0449\u0435\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0441 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043E\u0432 \u0438 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \"\u043F\u0440\u043E\u0432\u0435\u0440\u044F\u043B\u044C\u0449\u0438\u043A\u043E\u0432\"
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432,
    \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441 \u043E\u0442\u0432\u0435\u0442\u0438\u043B
    \u0441 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043D\u043E\u0439 \u043F\u0440\u044F\u043C\u043E\u0442\u043E\u0439:
    *\"\u041D\u0435\u0442, \u044D\u0442\u043E \u043D\u0435 \u0434\u043B\u044F \u043C\u0435\u043D\u044F...
    \u042F, \u043A\u0430\u043A \u0414\u0430\u0432\u0438\u0434 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442,
    \u043D\u0435 \u0445\u043E\u0447\u0443, \u0447\u0442\u043E\u0431\u044B \u043C\u043D\u0435
    \u043F\u043E\u0440\u0442\u0438\u043B\u0438 \u043C\u043E\u044E \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443\"*. \u041E\u043D
    \u0442\u0430\u043A\u0436\u0435 \u0441\u043A\u0435\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0441\u044F \u043A \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C\u0443
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443, \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u044F
    \u0435\u0433\u043E \u0441 **\"\u043F\u0443\u0441\u0442\u043E\u0439 \u0431\u043E\u043B\u0442\u043E\u0432\u043D\u0435\u0439\"**
    \u043D\u0430 \u0432\u0435\u0447\u0435\u0440\u0438\u043D\u043A\u0435 \u2014 \u043E\u043D
    \u0437\u0432\u0443\u0447\u0438\u0442 \u0443\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043D\u043E \u043B\u0438\u0448\u044C \u043F\u0435\u0440\u0435\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043D\u043D\u043E\u0435.  ### \U0001F575\uFE0F
    \u0420\u0435\u0434\u0430\u043A\u0442\u043E\u0440 \u042D\u043D\u0434\u0440\u044E
    \u0423\u0430\u0439\u043B\u0441\u0430 \u0438 \"\u0441\u043B\u043E\u0436\u043D\u044B\u0439\"
    \u0443\u0447\u0435\u043D\u0438\u043A  \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u0441\u044B\u0433\u0440\u0430\u043B \u0432\u0430\u0436\u043D\u0443\u044E, \u043D\u043E
    \u043C\u0430\u043B\u043E\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0443\u044E
    \u0440\u043E\u043B\u044C \u0432 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435
    \u0412\u0435\u043B\u0438\u043A\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u0424\u0435\u0440\u043C\u0430. \u041A\u043E\u0433\u0434\u0430 \u042D\u043D\u0434\u0440\u044E
    \u0423\u0430\u0439\u043B\u0441 \u043D\u0430\u0448\u0435\u043B \u0441\u043F\u043E\u0441\u043E\u0431
    \u0437\u0430\u043A\u0440\u044B\u0442\u044C \u043F\u0440\u043E\u0431\u0435\u043B
    \u0432 \u0441\u0432\u043E\u0435\u043C \u043F\u0435\u0440\u0432\u043E\u043C \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0435,
    \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B \u0447\u0435\u0440\u043D\u043E\u0432\u0438\u043A
    \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u0443 \u043D\u0430 \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0443.
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u043E\u043D\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0438
    \u0432 \u0422\u043E\u0441\u043A\u0430\u043D\u0435, \u043F\u043E\u043A\u0430 \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u043D\u0430\u0441\u043B\u0430\u0436\u0434\u0430\u043B\u0438\u0441\u044C \"\u0441\u043B\u0430\u0434\u043A\u043E\u0439
    \u0436\u0438\u0437\u043D\u044C\u044E\", \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u043F\u043E \u0432\u0435\u0447\u0435\u0440\u0430\u043C \u0447\u0438\u0442\u0430\u043B
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0423\u0430\u0439\u043B\u0441\u0430 \u0438
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u043B \u0435\u0435 \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043D\u043E\u0441\u0442\u044C,
    \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u0423\u0430\u0439\u043B\u0441\u0443
    \u043D\u0430\u043A\u043E\u043D\u0435\u0446 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442.  \u0412 \u0442\u043E
    \u0436\u0435 \u0432\u0440\u0435\u043C\u044F \u0435\u0433\u043E \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u043C \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C
    \u2014 \u044F\u043F\u043E\u043D\u0441\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    **\u0421\u0438\u043D\u044A\u0438\u0442\u0438 \u041C\u043E\u0442\u0438\u0434\u0437\u0443\u043A\u0438**
    \u2014 \u0441\u043B\u043E\u0436\u043D\u044B. \u041C\u043E\u0442\u0438\u0434\u0437\u0443\u043A\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0442\u043E\u0436\u0435 \u0443\u0447\u0438\u043B\u0441\u044F
    \u0443 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u0430 \u0432 \u041F\u0440\u0438\u043D\u0441\u0442\u043E\u043D\u0435
    , \u0432 2012 \u0433\u043E\u0434\u0443 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435,
    \u043D\u043E \u043A\u0440\u0430\u0439\u043D\u0435 \u0441\u043B\u043E\u0436\u043D\u043E\u0435
    \u0438 \u0441\u043F\u043E\u0440\u043D\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    ABC-\u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B. \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u043F\u0440\u044F\u043C\u043E \u0437\u0430\u044F\u0432\u0438\u043B: *\"\u041E\u043D
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0441\u043E\u0442\u0435\u043D \u0441\u0442\u0440\u0430\u043D\u0438\u0446, \u0438
    \u044F \u0438\u0445 \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u044E....
    \u041D\u043E \u043E\u043D \u043C\u043E\u0439 \u0443\u0447\u0435\u043D\u0438\u043A,
    \u0438 \u044F \u043D\u0435 \u0431\u0443\u0434\u0443 \u0435\u0433\u043E \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u0442\u044C\"*. 
    ### \U0001F3B5 \u0416\u0438\u0437\u043D\u044C \u0432\u043D\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 
    \u0412\u043E\u043F\u0440\u0435\u043A\u0438 \u043E\u0431\u0440\u0430\u0437\u0443
    \"\u0441\u0443\u0445\u043E\u0433\u043E\" \u0443\u0447\u0435\u043D\u043E\u0433\u043E,
    \u0443 \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441\u0430 \u0435\u0441\u0442\u044C
    \u0432\u043F\u043E\u043B\u043D\u0435 \u0437\u0435\u043C\u043D\u044B\u0435 \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F: 
    *   **\u0424\u0443\u0442\u0431\u043E\u043B**: \u041E\u043D \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u044B\u043C \u0431\u043E\u043B\u0435\u043B\u044C\u0449\u0438\u043A\u043E\u043C
    \u0444\u0443\u0442\u0431\u043E\u043B\u044C\u043D\u043E\u0433\u043E \u043A\u043B\u0443\u0431\u0430
    **\"\u0428\u0430\u043B\u044C\u043A\u0435-04\"** \u0438\u0437 \u0435\u0433\u043E
    \u0440\u043E\u0434\u043D\u043E\u0433\u043E \u0413\u0435\u043B\u044C\u0437\u0435\u043D\u043A\u0438\u0440\u0445\u0435\u043D\u0430.
    *   **\u041A\u0443\u043B\u044C\u0442\u0443\u0440\u0430**: \u041E\u043D \u0437\u043D\u0430\u0442\u043E\u043A
    \u043E\u043F\u0435\u0440\u044B \u0438 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0443\u0437\u044B\u043A\u0438, \u043B\u044E\u0431\u0438\u0442 \u0445\u043E\u0440\u043E\u0448\u0435\u0435
    \u0432\u0438\u043D\u043E \u0438 \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 \u0441\u0430\u0434\u0443. 
    ### \U0001F3C6 \u0421\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u044C \u0438
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435  \u0424\u0430\u043B\u044C\u0442\u0438\u043D\u0433\u0441
    \u2014 \u043E\u0431\u043B\u0430\u0434\u0430\u0442\u0435\u043B\u044C \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u0441\u0435\u0445 \u043C\u044B\u0441\u043B\u0438\u043C\u044B\u0445 \u043D\u0430\u0433\u0440\u0430\u0434,
    \u043D\u043E \u0435\u0433\u043E \u0441\u043B\u043E\u0432\u0430 \u043E \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u0438
    \u0410\u0431\u0435\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    \u0432 2026 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u043D\u044B \u0441\u0430\u043C\u043E\u0438\u0440\u043E\u043D\u0438\u0438.
    \u0423\u0437\u043D\u0430\u0432 \u043E \u043D\u0430\u0433\u0440\u0430\u0434\u0435,
    \u043E\u043D \u0441\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E **\u0441\u043E\u0432\u0441\u0435\u043C
    \u043D\u0435 \u043E\u0436\u0438\u0434\u0430\u043B \u044D\u0442\u043E\u0433\u043E**,
    \u0442\u0430\u043A \u043A\u0430\u043A \u0434\u0443\u043C\u0430\u043B, \u0447\u0442\u043E
    **\"\u0443\u0436\u0435 \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0441\u0442\u0430\u0440
    \u0434\u043B\u044F \u0442\u0430\u043A\u0438\u0445 \u043D\u0430\u0433\u0440\u0430\u0434\"**.
    \u0417\u0430\u0442\u0435\u043C \u043E\u043D \u043F\u043E\u0448\u0443\u0442\u0438\u043B,
    \u0447\u0442\u043E \u0442\u0435\u043F\u0435\u0440\u044C \u0435\u043C\u0443 **\u043D\u0443\u0436\u043D\u043E
    \u0430\u0440\u0435\u043D\u0434\u043E\u0432\u0430\u0442\u044C \u0441\u043C\u043E\u043A\u0438\u043D\u0433**
    \u0434\u043B\u044F \u0446\u0435\u0440\u0435\u043C\u043E\u043D\u0438\u0438."
