  achievementsRu: "\u0420\u0430\u0434, \u0447\u0442\u043E \u0432\u0430\u0441 \u0437\u0430\u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0430
    \u044D\u0442\u0430 \u0442\u0435\u043C\u0430. \u0415\u0441\u043B\u0438 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u0423\u0438\u043B\u044C\u044F\u043C\u0430 \u0420\u043E\u0443\u044D\u043D\u0430
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430 \u2014 \u044D\u0442\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0436\u0438\u0437\u043D\u0438 \u0433\u0435\u043D\u0438\u044F,
    \u0442\u043E \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E \u0442\u043E\u043C,
    \u043A\u0430\u043A \u043E\u0434\u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u0434\u0435\u044F \u043C\u043E\u0436\u0435\u0442 \u0438\u0437\u043C\u0435\u043D\u0438\u0442\u044C
    \u0432\u0441\u044E \u0444\u0438\u0437\u0438\u043A\u0443.  \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043D\u0430\u043C\u043D\u043E\u0433\u043E
    \u0431\u043E\u043B\u044C\u0448\u0435, \u0447\u0435\u043C \u043F\u0440\u043E\u0441\u0442\u043E
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0444\u043E\u0440\u043C\u0443\u043B.
    \u041E\u043D **\u0441\u043E\u0437\u0434\u0430\u043B \u043D\u043E\u0432\u044B\u0439
    \u044F\u0437\u044B\u043A**, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0444\u0438\u0437\u0438\u043A\u0438 XX \u0432\u0435\u043A\u0430 \u043E\u043F\u0438\u0441\u0430\u043B\u0438
    \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u044B\u0439 \u043C\u0438\u0440, \u0438
    **\u0438\u0437\u043E\u0431\u0440\u0451\u043B \u043D\u043E\u0432\u0443\u044E \u0430\u043B\u0433\u0435\u0431\u0440\u0443**,
    \u0431\u0435\u0437 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0441\u0435\u0433\u043E\u0434\u043D\u044F
    \u043D\u0435\u043C\u044B\u0441\u043B\u0438\u043C\u044B \u043D\u0438 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u0430\u044F
    \u0433\u0440\u0430\u0444\u0438\u043A\u0430, \u043D\u0438 \u043A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043D\u0430\u0432\u0438\u0433\u0430\u0446\u0438\u044F.  \u041D\u0438\u0436\u0435
    \u044F \u0440\u0430\u0437\u0431\u0438\u043B \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u043F\u043E \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C, \u0441 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0434\u0435\u0442\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0435\u0439.  --- 
    ### 1. \U0001F4D0 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u043E\u0432\u0430
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430 (\u0422\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u0438\u0437\u0438\u043A\u0430)  \u042D\u0442\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    \u0432 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443. \u0414\u043E \u043D\u0435\u0433\u043E \u0444\u0438\u0437\u0438\u043A\u0430
    \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0430\u0441\u044C \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u043E\u0439
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430 \u0438 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430,
    \u043D\u043E \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u0438\u043D\u043E\u0439
    \u0432\u0437\u0433\u043B\u044F\u0434.  *   **\u0412\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    (\u041F\u0440\u0438\u043D\u0446\u0438\u043F \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0433\u043E
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F):** \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043B\u044E\u0431\u0430\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0441\u0438\u0441\u0442\u0435\u043C\u0430
    \u0434\u0432\u0438\u0436\u0435\u0442\u0441\u044F \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0442\u0430\u043A, \u0430 \u043F\u043E \u0442\u0430\u043A\u043E\u043C\u0443
    \u043F\u0443\u0442\u0438, \u0447\u0442\u043E\u0431\u044B \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B
    \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u0438 \u043C\u0435\u0436\u0434\u0443
    \u043A\u0438\u043D\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0438
    \u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u044D\u043D\u0435\u0440\u0433\u0438\u0435\u0439 (\u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B **\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435\u043C**)
    \u0431\u044B\u043B \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u043C.
    \u042D\u0442\u043E \u043F\u0435\u0440\u0435\u0432\u0435\u043B\u043E \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443
    \u0438\u0437 \u0440\u0430\u0437\u0440\u044F\u0434\u0430 \xAB\u043F\u0440\u0438\u0447\u0438\u043D\u043D\u043E-\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0441\u0432\u044F\u0437\u0435\u0439\xBB \u0432 \u0440\u0430\u0437\u0440\u044F\u0434
    \xAB\u044D\u043A\u0441\u0442\u0440\u0435\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447\xBB \u0438 \u043E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u043C
    \u0434\u043B\u044F \u0432\u0441\u0435\u0445 \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432
    \u0444\u0438\u0437\u0438\u043A\u0438 (\u043E\u043F\u0442\u0438\u043A\u0430, \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0430,
    \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u0430\u044F \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430). 
    *   **\u041A\u0430\u043D\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430:**
    \u041E\u043D \u0437\u0430\u043C\u0435\u043D\u0438\u043B \u0433\u0440\u043E\u043C\u043E\u0437\u0434\u043A\u0438\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430
    \u0432\u0442\u043E\u0440\u043E\u0433\u043E \u043F\u043E\u0440\u044F\u0434\u043A\u0430
    \u043D\u0430 \u0438\u0437\u044F\u0449\u043D\u0443\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u0438\u0437 2n \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u043F\u0435\u0440\u0432\u043E\u0433\u043E
    \u043F\u043E\u0440\u044F\u0434\u043A\u0430. \u0412\u043C\u0435\u0441\u0442\u043E
    \u0441\u0438\u043B \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0444\u0443\u043D\u043A\u0446\u0438\u044E **\u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0438\u0430\u043D
    (H)**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    \u043F\u043E\u043B\u043D\u0443\u044E \u044D\u043D\u0435\u0440\u0433\u0438\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B. \u041A\u043B\u044E\u0447\u0435\u0432\u043E\u0435
    \u043D\u043E\u0432\u0448\u0435\u0441\u0442\u0432\u043E \u2014 \u043E\u043D \u0432\u0432\u0451\u043B
    **\u043E\u0431\u043E\u0431\u0449\u0451\u043D\u043D\u044B\u0435 \u0438\u043C\u043F\u0443\u043B\u044C\u0441\u044B**
    \u043A\u0430\u043A \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435, \u043D\u0430\u0440\u0430\u0432\u043D\u0435
    \u0441 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u0430\u043C\u0438.
    \u042D\u0442\u043E \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0441\u0434\u0435\u043B\u0430\u043B\u043E \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443
    \u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u0447\u043D\u043E\u0439 \u0438
    \u043E\u0442\u043A\u0440\u044B\u043B\u043E \u043F\u0443\u0442\u044C \u043A \u0441\u0442\u0430\u0442\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435.  *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0432\u043E\u0437\u043C\u0443\u0449\u0435\u043D\u0438\u0439:** \u0412 \u0440\u0430\u0431\u043E\u0442\u0435
    \xAB\u041E\u0431 \u043E\u0431\u0449\u0435\u043C \u043C\u0435\u0442\u043E\u0434\u0435
    \u0432 \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435\xBB (1834) \u043E\u043D
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u043C\u0435\u0442\u043E\u0434,
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0438\u0439 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u043F\u043B\u0430\u043D\u0435\u0442,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432\u043B\u0438\u044F\u044E\u0442
    \u0434\u0440\u0443\u0433\u0438\u0435 \u0442\u0435\u043B\u0430. \u042D\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u043D\u0435\u0431\u0435\u0441\u043D\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438.  > **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0434\u043B\u044F \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E:** \u041A\u043E\u0433\u0434\u0430
    \u0432 1920-\u0445 \u0433\u043E\u0434\u0430\u0445 \u043F\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C
    \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u0430\u044F \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430,
    \u042D\u0440\u0432\u0438\u043D \u0428\u0440\u0451\u0434\u0438\u043D\u0433\u0435\u0440
    \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E \u043E\u043F\u0438\u0440\u0430\u043B\u0441\u044F
    \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u044B \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430.
    \u0412\u043E\u043B\u043D\u043E\u0432\u043E\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u0428\u0440\u0451\u0434\u0438\u043D\u0433\u0435\u0440\u0430 \u2014 \u044D\u0442\u043E,
    \u043F\u043E \u0441\u0443\u0442\u0438, \xAB\u0437\u0430\u043A\u0432\u0430\u043D\u0442\u043E\u0432\u0430\u043D\u043D\u044B\u0439\xBB
    \u0433\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0438\u0430\u043D. \u0411\u0435\u0437
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    \u043D\u0435 \u0431\u044B\u043B\u043E \u0431\u044B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438 \u043C\u0438\u043A\u0440\u043E\u043C\u0438\u0440\u0430. 
    ---  ### 2. \U0001F300 \u041E\u043F\u0442\u0438\u043A\u0430 \u0438 \xAB\u041A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0440\u0435\u0444\u0440\u0430\u043A\u0446\u0438\u044F\xBB  \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0431\u044B\u043B \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A\u043E\u043C
    \u2014 \u043E\u043D \u0431\u044B\u043B \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u0435\u043C. 
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0441\u0438\u0441\u0442\u0435\u043C
    \u043B\u0443\u0447\u0435\u0439:** \u0412 1820-\u0445 \u043E\u043D \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    \u043E\u0431\u0449\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043C\u043E\u0434\u0435\u043B\u044C \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \u0441\u0432\u0435\u0442\u0430, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u0441\u0432\u043E\u044E \xAB\u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u0443\u043D\u043A\u0446\u0438\u044E\xBB (\u044D\u0442\u043E \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437
    \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E \u0433\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0438\u0430\u043D\u0430).
    *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u0435:** \u0412
    1832 \u0433\u043E\u0434\u0443, \u0430\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u0443\u044F
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0434\u043B\u044F \u0434\u0432\u0443\u0445\u043E\u0441\u043D\u044B\u0445
    \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u043E\u0432 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0430\u0440\u0430\u0433\u043E\u043D\u0438\u0442\u0430), \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u0432 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0445
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445 **\u0432\u043D\u0443\u0442\u0440\u0438
    \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u0430 \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u0435\u0442
    \u043D\u0435 \u043E\u0434\u0438\u043D \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0451\u043D\u043D\u044B\u0439
    \u043B\u0443\u0447, \u0430 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E**, \u043E\u0431\u0440\u0430\u0437\u0443\u044E\u0449\u0438\u0445
    \u043F\u043E\u043B\u044B\u0439 \u043A\u043E\u043D\u0443\u0441. *   **\u042D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435:**
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u043E, \u0447\u0442\u043E
    \u0444\u0438\u0437\u0438\u043A \u0425\u0430\u043C\u0444\u0440\u0438 \u041B\u043B\u043E\u0439\u0434
    \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442. **\u041F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u0435
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u043B\u043E\u0441\u044C**!
    \u042D\u0442\u043E \u0431\u044B\u043B \u0442\u0440\u0438\u0443\u043C\u0444 \u0447\u0438\u0441\u0442\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u043D\u0430\u0434
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u043E\u043C
    \u2014 \u043E\u0434\u043D\u043E \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u0441\u043E\u0431\u044B\u0442\u0438\u0439 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430\u0443\u043A\u0438, \u043A\u043E\u0433\u0434\u0430 \u044F\u0432\u043B\u0435\u043D\u0438\u0435
    \u0431\u044B\u043B\u043E \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u043E\u0442\u043A\u0440\u044B\u0442\u043E
    \u043D\u0430 \u043A\u043E\u043D\u0447\u0438\u043A\u0435 \u043F\u0435\u0440\u0430,
    \u0430 \u043B\u0438\u0448\u044C \u043F\u043E\u0442\u043E\u043C \u0443\u0432\u0438\u0434\u0435\u043D\u043E
    \u0432 \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u0438.  --- 
    ### 3. \U0001F52E \u041A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u044B
    \u0438 \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0412\u0435\u043A\u0442\u043E\u0440\u043D\u043E\u0433\u043E
    \u0418\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F  \u042D\u0442\u043E
    \u0441\u0430\u043C\u043E\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435
    \u0438 \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u044C\u043D\u043E\u0435 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0432\u044B\u0437\u0432\u0430\u043B\u043E \u0440\u0430\u0441\u043A\u043E\u043B
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043C\u0438\u0440\u0435 \u043D\u0430 50 \u043B\u0435\u0442.  *   **\u041F\u0440\u043E\u0431\u043B\u0435\u043C\u0430:**
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u0438\u0441\u043A\u0430\u043B
    \u0441\u043F\u043E\u0441\u043E\u0431 \u0443\u043C\u043D\u043E\u0436\u0430\u0442\u044C
    \u0442\u043E\u0447\u043A\u0438 \u0432 \u0442\u0440\u0451\u0445\u043C\u0435\u0440\u043D\u043E\u043C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435, \u043F\u043E\u0434\u043E\u0431\u043D\u043E
    \u0442\u043E\u043C\u0443, \u043A\u0430\u043A \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442
    \u043D\u0430 \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438 (\u043E\u043F\u0438\u0441\u044B\u0432\u0430\u044F
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u044B). \u041E\u043D \u0431\u0438\u043B\u0441\u044F
    \u043D\u0430\u0434 \u044D\u0442\u0438\u043C 10 \u043B\u0435\u0442 (\u0441 1833
    \u043F\u043E 1843), \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u0441\u0447\u0438\u0442\u0430\u043B,
    \u0447\u0442\u043E \u0447\u0438\u0441\u0435\u043B \u0434\u043E\u043B\u0436\u043D\u043E
    \u0431\u044B\u0442\u044C \u0442\u0440\u0438 (x, y, z). *   **\u041E\u0437\u0430\u0440\u0435\u043D\u0438\u0435
    (16 \u043E\u043A\u0442\u044F\u0431\u0440\u044F 1843):** \u041E\u043D \u043F\u043E\u043D\u044F\u043B,
    \u0447\u0442\u043E \u0443\u043C\u043D\u043E\u0436\u0430\u0442\u044C \u0442\u0440\u043E\u0439\u043A\u0438
    \u0447\u0438\u0441\u0435\u043B **\u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E**
    \u0431\u0435\u0437 \u043F\u043E\u0442\u0435\u0440\u0438 \u0441\u0432\u043E\u0439\u0441\u0442\u0432
    \u0434\u0435\u043B\u0435\u043D\u0438\u044F. \u041D\u0443\u0436\u043D\u043E \u0434\u043E\u0431\u0430\u0432\u0438\u0442\u044C
    \u0447\u0435\u0442\u0432\u0451\u0440\u0442\u043E\u0435 \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0435
    \u2014 \xAB\u0432\u0440\u0435\u043C\u044F\xBB \u0438\u043B\u0438 \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0447\u0430\u0441\u0442\u044C. \u0422\u0430\u043A \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C
    **\u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u044B** \u2014
    \u0447\u0438\u0441\u043B\u0430 \u0432\u0438\u0434\u0430 `q = a + bi + cj + dk`. 
    *   **\u0413\u043B\u0430\u0432\u043D\u0430\u044F \u0444\u043E\u0440\u043C\u0443\u043B\u0430:**
    `i\xB2 = j\xB2 = k\xB2 = ijk = -1`. \u042D\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u043B\u043E,
    \u0447\u0442\u043E `i \xD7 j = k`, \u043D\u043E `j \xD7 i = -k`. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    **\u0441\u043E\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E \u043E\u0442\u0431\u0440\u043E\u0441\u0438\u043B
    \u0437\u0430\u043A\u043E\u043D \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u0438**
    (\u043F\u043E\u0440\u044F\u0434\u043E\u043A \u043C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u0435\u0439
    \u0432\u0430\u0436\u0435\u043D). \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u043F\u0435\u0440\u0432\u044B\u043C \u0443\u0441\u043F\u0435\u0448\u043D\u044B\u043C
    \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u043C \u043D\u0435\u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  *   **\u0412\u0432\u0435\u0434\u0451\u043D\u043D\u0430\u044F
    \u0442\u0435\u0440\u043C\u0438\u043D\u043E\u043B\u043E\u0433\u0438\u044F:**    
    *   **\u0421\u043A\u0430\u043B\u044F\u0440** (\u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0447\u0430\u0441\u0442\u044C `a`).     *   **\u0412\u0435\u043A\u0442\u043E\u0440**
    (\u043C\u043D\u0438\u043C\u0430\u044F \u0447\u0430\u0441\u0442\u044C `bi + cj
    + dk`).     *   **\u0412\u0435\u043A\u0442\u043E\u0440\u043D\u044B\u0439 \u0430\u043D\u0430\u043B\u0438\u0437:**
    \u041E\u043D \u0438\u0437\u043E\u0431\u0440\u0451\u043B \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u044B \u0441\u0435\u0439\u0447\u0430\u0441
    \u0437\u043D\u0430\u0435\u043C \u043A\u0430\u043A **\u0432\u0435\u043A\u0442\u043E\u0440\u043D\u043E\u0435**
    \u0438 **\u0441\u043A\u0430\u043B\u044F\u0440\u043D\u043E\u0435** \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435
    \u0432\u0435\u043A\u0442\u043E\u0440\u043E\u0432.     *   **\u041E\u043F\u0435\u0440\u0430\u0442\u043E\u0440
    \u041D\u0430\u0431\u043B\u0430 (\u2207):** \u0421\u0438\u043C\u0432\u043E\u043B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043D \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B
    \u0434\u043B\u044F \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435,
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0432\u043E \u0432\u0441\u0435\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u0445
    \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0438
    \u041C\u0430\u043A\u0441\u0432\u0435\u043B\u043B\u0430.  *   **\u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0439:**     *   \u0425\u043E\u0442\u044F
    \u0432 \u0447\u0438\u0441\u0442\u043E\u0439 \u0444\u0438\u0437\u0438\u043A\u0435
    \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u044B \u0441\u0435\u0433\u043E\u0434\u043D\u044F
    \u0443\u0441\u0442\u0443\u043F\u0438\u043B\u0438 \u043C\u0435\u0441\u0442\u043E
    \u0432\u0435\u043A\u0442\u043E\u0440\u043D\u043E\u043C\u0443 \u0430\u043D\u0430\u043B\u0438\u0437\u0443
    \u0413\u0438\u0431\u0431\u0441\u0430, \u043E\u043D\u0438 **\u043D\u0435\u0437\u0430\u043C\u0435\u043D\u0438\u043C\u044B
    \u0432 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u043E\u0439
    \u0433\u0440\u0430\u0444\u0438\u043A\u0435** \u0438 \u0440\u043E\u0431\u043E\u0442\u043E\u0442\u0435\u0445\u043D\u0438\u043A\u0435.
    \u041E\u043D\u0438 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0442 \u0432\u0440\u0430\u0449\u0430\u0442\u044C
    3D-\u043E\u0431\u044A\u0435\u043A\u0442\u044B (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435\u0439 \u0432 \u0432\u0438\u0434\u0435\u043E\u0438\u0433\u0440\u0430\u0445
    \u0438\u043B\u0438 \u043A\u0430\u043C\u0435\u0440\u0443 \u0432 \u043A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u043E\u0440\u0430\u0431\u043B\u044F\u0445) \u0431\u0435\u0437 \u043E\u0448\u0438\u0431\u043E\u043A,
    \u0432\u044B\u0437\u044B\u0432\u0430\u0435\u043C\u044B\u0445 \xAB\u0448\u0430\u0440\u043D\u0438\u0440\u043D\u044B\u043C
    \u0437\u0430\u043C\u043A\u043E\u043C\xBB (Gimbal lock) \u043F\u0440\u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0438
    \u043E\u0431\u044B\u0447\u043D\u044B\u0445 \u0443\u0433\u043B\u043E\u0432 \u042D\u0439\u043B\u0435\u0440\u0430.
    \u0412\u0441\u044F \u0441\u0438\u0441\u0442\u0435\u043C\u0430 \u043D\u0430\u0432\u0438\u0433\u0430\u0446\u0438\u0438
    \u0438 \u0441\u0442\u0430\u0431\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u0438
    \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u043E\u0432 (\u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u041C\u041A\u0421) \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442
    \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u043D\u044B\u0435
    \u0440\u0430\u0441\u0447\u0451\u0442\u044B.  ---  ### 4. \U0001F4CA \u0422\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B \u0438 \u0410\u043B\u0433\u0435\u0431\u0440\u0430 
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u043B\u0441\u044F
    \u0444\u0438\u0437\u0438\u043A\u043E\u0439. \u041E\u043D \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B:  *   **\u0410\u043B\u0433\u0435\u0431\u0440\u0430
    \u043A\u0430\u043A \u043D\u0430\u0443\u043A\u0430 \u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438:**
    \u041E\u043D \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0434\u0430\u0442\u044C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0435 \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435
    \u0430\u043B\u0433\u0435\u0431\u0440\u0435, \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u044F
    \u0435\u0451 \u0441 \u0447\u0438\u0441\u0442\u043E\u0439 \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0435\u0439
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u043E\u043A\u0442\u0430\u0432:** \u041F\u043E\u0441\u043B\u0435 \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u043E\u0432
    \u043E\u043D \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u0430\u043B\u0433\u0435\u0431\u0440\u0443 \u0438\u0437 \u0432\u043E\u0441\u044C\u043C\u0438
    \u0447\u0438\u0441\u0435\u043B (\u043E\u043A\u0442\u0430\u0432\u044B), \u043D\u043E
    \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B, \u0447\u0442\u043E \u0432
    \u043D\u0435\u0439 \u0442\u0435\u0440\u044F\u0435\u0442\u0441\u044F \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C,
    \u043D\u043E \u0438 \u0430\u0441\u0441\u043E\u0446\u0438\u0430\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C
    (\u043F\u043E\u0440\u044F\u0434\u043E\u043A \u0441\u043A\u043E\u0431\u043E\u043A)
    \u2014 `(a\xD7b)\xD7c \u2260 a\xD7(b\xD7c)`. \u0425\u043E\u0442\u044F \u044D\u0442\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C
    \u043D\u0435\u0437\u0430\u0432\u0435\u0440\u0448\u0451\u043D\u043D\u043E\u0439,
    \u043E\u043D\u0430 \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442
    \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0433\u0438\u043F\u0435\u0440\u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u0438 \u0430\u043B\u0433\u0435\u0431\u0440 \u041B\u0438. 
    ---  ### 5. \U0001F30C \u0410\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044F
    \u0438 \xAB\u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u043E\u0432\u0430
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\xBB  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0442\u043E \u0447\u0442\u043E \u043E\u043D \u0431\u044B\u043B
    \xAB\u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C-\u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A\u043E\u043C\xBB
    (\u0438 \u043D\u0435 \u043E\u0447\u0435\u043D\u044C \u043B\u044E\u0431\u0438\u043B
    \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C \u0432 \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F),
    \u0438\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u043E\u0439 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u0441\u0442\u0443\u043F
    \u043A \u0440\u0435\u0441\u0443\u0440\u0441\u0430\u043C. \u0412 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u2014 \u043D\u0435 \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F,
    \u0430 **\u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0430**. \u0415\u0433\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F (\u043F\u043E\u0437\u0436\u0435 \u043D\u0430\u0437\u0432\u0430\u043D\u043D\u0430\u044F
    **\u0433\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u043E\u0432\u043E\u0439
    \u0444\u0443\u043D\u043A\u0446\u0438\u0435\u0439 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F**)
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u0430 \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u0442\u044C
    \u043E\u0440\u0431\u0438\u0442\u044B \u043F\u043B\u0430\u043D\u0435\u0442 \u043D\u0430
    \u043C\u043D\u043E\u0433\u043E \u043B\u0435\u0442 \u0432\u043F\u0435\u0440\u0451\u0434
    \u0441 \u0431\u0435\u0441\u043F\u0440\u0435\u0446\u0435\u0434\u0435\u043D\u0442\u043D\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E, \u0441\u0442\u0430\u0432
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F \u044D\u0444\u0435\u043C\u0435\u0440\u0438\u0434\u043D\u043E\u0439
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438.  ---  ### \U0001F4DD
    \u0418\u0442\u043E\u0433\u043E\u0432\u043E\u0435 \u0440\u0435\u0437\u044E\u043C\u0435
    \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434\u0430  \u0415\u0441\u043B\u0438
    \u0441\u0436\u0430\u0442\u044C \u0432\u0441\u0451 \u0432\u044B\u0448\u0435\u0441\u043A\u0430\u0437\u0430\u043D\u043D\u043E\u0435
    \u0432 \u0442\u0440\u0438 \u043F\u0443\u043D\u043A\u0442\u0430, \u0442\u043E
    \u043D\u0430\u0443\u0447\u043D\u044B\u0439 \u043F\u043E\u0440\u0442\u0440\u0435\u0442
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430 \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442
    \u0442\u0430\u043A:  1.  **\u0424\u0438\u0437\u0438\u043A-\u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A:**
    \u041F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443 \u0432 \u0441\u0442\u0440\u043E\u0439\u043D\u0443\u044E,
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u0443\u044E
    \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u0431\u0430\u0437\u0438\u0440\u0443\u044E\u0442\u0441\u044F
    \u0432\u0441\u0435 \u043F\u043E\u043B\u0435\u0432\u044B\u0435 \u0442\u0435\u043E\u0440\u0438\u0438.
    2.  **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A-\u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u0435\u0440:**
    \u041F\u0435\u0440\u0435\u043F\u0438\u0441\u0430\u043B \u043F\u0440\u0430\u0432\u0438\u043B\u0430
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B, \u043F\u043E\u0436\u0435\u0440\u0442\u0432\u043E\u0432\u0430\u0432
    \xAB\u043E\u0447\u0435\u0432\u0438\u0434\u043D\u044B\u043C\xBB \u0437\u0430\u043A\u043E\u043D\u043E\u043C
    `x*y = y*x` \u0440\u0430\u0434\u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u043D\u043E\u0432\u044B\u0445 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u0435.
    3.  **\u041F\u0440\u043E\u0432\u0438\u0434\u0435\u0446:** \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u0431\u044B\u043B\u0438 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0441\u043B\u043E\u0436\u043D\u044B \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u043D\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u0430 \u0441\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0434\u043B\u044F
    \u0444\u0438\u0437\u0438\u043A\u043E\u0432 \u0447\u0435\u0440\u0435\u0437 50\u201380
    \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438. 
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0440\u0435\u0448\u0438\u043B \u0437\u0430\u0434\u0430\u0447\u0438 \u2014 \u043E\u043D
    \u0434\u0430\u043B \u0443\u0447\u0451\u043D\u044B\u043C **\u043C\u0435\u0442\u043E\u0434**,
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0438\u0439 \u0440\u0435\u0448\u0430\u0442\u044C
    \u0437\u0430\u0434\u0430\u0447\u0438, \u043E \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u043D\u0438 \u0434\u0430\u0436\u0435 \u043D\u0435 \u0437\u043D\u0430\u043B\u0438."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0441\u044D\u0440\u0430 \u0423\u0438\u043B\u044C\u044F\u043C\u0430 \u0420\u043E\u0443\u044D\u043D\u0430
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430 \u2014 \u044D\u0442\u043E
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0438 \u043F\u0440\u043E\u043D\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F, \u0440\u0435\u0437\u043A\u043E \u043A\u043E\u043D\u0442\u0440\u0430\u0441\u0442\u0438\u0440\u0443\u044E\u0449\u0430\u044F
    \u0441 \u0432\u043E\u0437\u0432\u044B\u0448\u0435\u043D\u043D\u043E\u0439 \u0441\u0442\u0440\u043E\u0439\u043D\u043E\u0441\u0442\u044C\u044E
    \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u043E\u0440\u043C\u0443\u043B. \u0415\u0441\u043B\u0438 \u0432 \u043D\u0430\u0443\u043A\u0435
    \u043E\u043D \u0431\u044B\u043B \u043F\u0440\u043E\u0432\u0438\u0434\u0446\u0435\u043C,
    \u0432\u0438\u0434\u0435\u0432\u0448\u0438\u043C \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u044E
    \u0442\u0430\u043C, \u0433\u0434\u0435 \u0434\u0440\u0443\u0433\u0438\u0435 \u0432\u0438\u0434\u0435\u043B\u0438
    \u0445\u0430\u043E\u0441, \u0442\u043E \u0432 \u0431\u044B\u0442\u0443 \u0435\u0433\u043E
    \u0436\u0438\u0437\u043D\u044C \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0430
    \u0441\u043E\u0431\u043E\u0439 \u0446\u0435\u043F\u044C \u044D\u043C\u043E\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444, \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u0430
    \u0438 \u0441\u0430\u043C\u043E\u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u0438\u044F.  
    \u041D\u0438\u0436\u0435 \u044F \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E, \u043E\u043F\u0438\u0440\u0430\u044F\u0441\u044C
    \u043D\u0430 \u043F\u0438\u0441\u044C\u043C\u0430, \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0438
    \u0438 \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u044E \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u0443\u044E
    \u0434\u0440\u0430\u043C\u0443.  ---  ### 1. \U0001F622 \u042E\u043D\u043E\u0448\u0435\u0441\u043A\u0430\u044F
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F \u0438 \u043C\u0443\u0437\u0430
    (\u041A\u044D\u0442\u0440\u0438\u043D \u0414\u0438\u0441\u043D\u0435\u0439) 
    \u0421\u0430\u043C\u043E\u0439 \u0441\u0438\u043B\u044C\u043D\u043E\u0439 \u0438
    \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043B\u044E\u0431\u043E\u0432\u044C\u044E \u0432 \u0436\u0438\u0437\u043D\u0438
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430
    **\u041A\u044D\u0442\u0440\u0438\u043D \u0414\u0438\u0441\u043D\u0435\u0439**.
    \u041E\u043D \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 \u043D\u0435\u0439 \u0432 1820-\u0445 \u0433\u043E\u0434\u0430\u0445,
    \u043A\u043E\u0433\u0434\u0430 \u0435\u043C\u0443 \u0431\u044B\u043B\u043E \u043E\u043A\u043E\u043B\u043E
    20 \u043B\u0435\u0442. \u041A\u044D\u0442\u0440\u0438\u043D \u0431\u044B\u043B\u0430
    \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430
    \u0438, \u043F\u043E \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F\u043C,
    \u043E\u0431\u043B\u0430\u0434\u0430\u043B\u0430 \u0440\u0435\u0434\u043A\u043E\u0439
    \u043A\u0440\u0430\u0441\u043E\u0442\u043E\u0439 \u0438 \u043E\u0441\u0442\u0440\u044B\u043C
    \u0443\u043C\u043E\u043C.  \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0432\u043B\u044E\u0431\u0438\u043B\u0441\u044F \u0432 \u043D\u0435\u0451 \u0431\u0435\u0437\u043E\u0433\u043B\u044F\u0434\u043D\u043E.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0438\u0445 \u0431\u0440\u0430\u043A\u0443
    \u0432\u043E\u0441\u043F\u0440\u043E\u0442\u0438\u0432\u0438\u043B\u0430\u0441\u044C
    \u0441\u0435\u043C\u044C\u044F \u041A\u044D\u0442\u0440\u0438\u043D, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u043E\u0447\u043B\u0430 \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u043D\u044B\u043C \u0438
    \u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u044B\u043C \u0436\u0435\u043D\u0438\u0445\u043E\u043C
    (\u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0435\u0433\u043E
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0435 \u0431\u0443\u0434\u0443\u0449\u0435\u0435).  
    \u042D\u0442\u043E\u0442 \u0440\u0430\u0437\u0440\u044B\u0432 \u0441\u0442\u0430\u043B
    \u0434\u043B\u044F \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0440\u0430\u0432\u043C\u043E\u0439 \u043D\u0430 \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C.
    \u041E\u043D \u0431\u044B\u043B \u043D\u0430\u0442\u0443\u0440\u043E\u0439 \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u043E\u0439
    \u0438 \u0440\u0430\u043D\u0438\u043C\u043E\u0439; \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u043D\u0438\u044F
    \u0432\u044B\u043B\u0438\u043B\u0438\u0441\u044C \u0432 \u0442\u043E, \u0447\u0442\u043E
    \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u0438\u0441\u0430\u0442\u044C \u0441\u0442\u0438\u0445\u0438
    (\u043E\u043D \u0438\u0437\u0434\u0430\u043B \u0434\u0430\u0436\u0435 \u0441\u0431\u043E\u0440\u043D\u0438\u043A
    \u0441\u0442\u0438\u0445\u043E\u0442\u0432\u043E\u0440\u0435\u043D\u0438\u0439
    \u043D\u0430 \u0438\u0440\u043B\u0430\u043D\u0434\u0441\u043A\u043E\u043C \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u043E\u043C).
    \u041D\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u2014 \u044D\u0442\u0430
    \u0431\u0435\u0437\u043E\u0442\u0432\u0435\u0442\u043D\u0430\u044F \u043B\u044E\u0431\u043E\u0432\u044C
    **\u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u043F\u0440\u0438\u0443\u0447\u0438\u043B\u0430
    \u0435\u0433\u043E \u043A \u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u0432\u043D\u044B\u043C
    \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F\u043C**. \u0412
    \u0441\u0432\u043E\u0438\u0445 \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0430\u0445
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043E\u043D
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F
    \u043A \u043E\u0431\u0440\u0430\u0437\u0443 \u041A\u044D\u0442\u0440\u0438\u043D,
    \u0438\u0434\u0435\u0430\u043B\u0438\u0437\u0438\u0440\u0443\u0435\u0442 \u0435\u0451
    \u0438 \u043A\u043E\u0440\u0438\u0442 \u0441\u0435\u0431\u044F \u0437\u0430 \u043D\u0435\u0443\u0434\u0430\u0447\u0443.
    \u041C\u043D\u043E\u0433\u0438\u0435 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u044B
    \u0441\u0447\u0438\u0442\u0430\u044E\u0442, \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E
    \u0438\u0437-\u0437\u0430 \u044D\u0442\u043E\u0439 \u0434\u0443\u0448\u0435\u0432\u043D\u043E\u0439
    \u0431\u043E\u043B\u0438 \u043E\u043D \u0441 \u0433\u043E\u043B\u043E\u0432\u043E\u0439
    \u0443\u0448\u0451\u043B \u0432 \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0430\u0434
    \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u0430\u043C\u0438
    \u2014 \u044D\u0442\u043E \u0431\u044B\u043B \u0435\u0433\u043E \u0441\u043F\u043E\u0441\u043E\u0431
    \u0441\u043F\u0430\u0441\u0442\u0438\u0441\u044C \u043E\u0442 \u043C\u044B\u0441\u043B\u0435\u0439
    \u043E \u043D\u0435\u0439.  \u041A\u044D\u0442\u0440\u0438\u043D \u0414\u0438\u0441\u043D\u0435\u0439
    \u043F\u043E\u0437\u0436\u0435 \u0432\u044B\u0448\u043B\u0430 \u0437\u0430\u043C\u0443\u0436
    \u0437\u0430 \u0434\u0440\u0443\u0433\u043E\u0433\u043E, \u043D\u043E \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B \u043A \u043D\u0435\u0439 \u0442\u0451\u043F\u043B\u044B\u0435
    \u0447\u0443\u0432\u0441\u0442\u0432\u0430 \u0434\u043E \u043A\u043E\u043D\u0446\u0430
    \u0436\u0438\u0437\u043D\u0438 \u0438 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0432\u044B\u0437\u044B\u0432\u0430\u0435\u0442 \u0443 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E \u0449\u0435\u043C\u044F\u0449\u0435\u0439
    \u0433\u0440\u0443\u0441\u0442\u0438.  ---  ### 2. \U0001F494 \u041D\u0435\u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u0439
    \u0431\u0440\u0430\u043A \u0441 \u0425\u0435\u043B\u0435\u043D \u041C\u0430\u0440\u0438\u0435\u0439
    \u0411\u044D\u0439\u043B\u0438  \u0412 1833 \u0433\u043E\u0434\u0443, \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 28 \u043B\u0435\u0442, \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 **\u0425\u0435\u043B\u0435\u043D
    \u041C\u0430\u0440\u0438\u0438 \u0411\u044D\u0439\u043B\u0438**. \u042D\u0442\u043E
    \u0431\u044B\u043B \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0448\u0430\u0433, \u0441\u043E\u0432\u0435\u0440\u0448\u0451\u043D\u043D\u044B\u0439
    \u043E\u0442\u0447\u0430\u0441\u0442\u0438 \u043F\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u043D\u0438\u044E
    \u0441\u0435\u043C\u044C\u0438, \u0447\u0442\u043E\u0431\u044B \xAB\u043E\u0441\u0442\u0435\u043F\u0435\u043D\u0438\u0442\u044C\u0441\u044F\xBB
    \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0439 \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430. \u0425\u0435\u043B\u0435\u043D
    \u0431\u044B\u043B\u0430 \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430
    \u0438\u0437 \u0433\u0440\u0430\u0444\u0441\u0442\u0432\u0430 \u041C\u0438\u0442. 
    \u0423\u0432\u044B, \u0431\u0440\u0430\u043A \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\u043E\u0439 \u0441 \u0441\u0430\u043C\u043E\u0433\u043E
    \u043D\u0430\u0447\u0430\u043B\u0430. \u041E\u043D\u0438 \u0431\u044B\u043B\u0438
    \u043F\u043E\u043B\u043D\u044B\u043C\u0438 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u043E\u0441\u0442\u044F\u043C\u0438: 
    - **\u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D** \u2014 \u043C\u0435\u043B\u0430\u043D\u0445\u043E\u043B\u0438\u0447\u043D\u044B\u0439,
    \u043F\u043E\u0433\u0440\u0443\u0436\u0451\u043D\u043D\u044B\u0439 \u0432 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u0438
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043C\u043E\u0433 \u043D\u0435 \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u0442\u044C
    \u0447\u0430\u0441\u0430\u043C\u0438, \u043E\u0431\u0434\u0443\u043C\u044B\u0432\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443. - **\u0425\u0435\u043B\u0435\u043D**
    \u2014 \u043F\u0440\u043E\u0441\u0442\u0430\u044F, \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u0430\u044F
    \u0436\u0435\u043D\u0449\u0438\u043D\u0430, \u0434\u0430\u043B\u0451\u043A\u0430\u044F
    \u043E\u0442 \u043D\u0430\u0443\u043A\u0438, \u043D\u0443\u0436\u0434\u0430\u0432\u0448\u0430\u044F\u0441\u044F
    \u0432 \u043E\u0431\u044B\u0447\u043D\u043E\u043C \u0431\u044B\u0442\u043E\u0432\u043E\u043C
    \u0442\u0435\u043F\u043B\u0435 \u0438 \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0438. 
    \u0425\u0435\u043B\u0435\u043D \u043D\u0435 \u0432\u044B\u043D\u043E\u0441\u0438\u043B\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0441\u043A\u0443\u0447\u0430\u043B\u0430
    \u0432 \u0414\u0430\u043D\u0441\u0438\u043D\u043A\u0441\u043A\u043E\u0439 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438,
    \u0433\u0434\u0435 \u043E\u043D\u0438 \u0436\u0438\u043B\u0438. \u041E\u043D\u0430
    \u0441\u0447\u0438\u0442\u0430\u043B\u0430 \u043C\u0443\u0436\u0430 \u0447\u0443\u0434\u0430\u043A\u043E\u043C,
    \u0430 \u043E\u043D \u043D\u0435 \u043C\u043E\u0433 \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u044C
    \u0435\u0439 \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u044C \u0441\u0432\u043E\u0438\u0445
    \u0438\u0434\u0435\u0439. \u041C\u0435\u0436\u0434\u0443 \u043D\u0438\u043C\u0438
    \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E \u0432\u0441\u043F\u044B\u0445\u0438\u0432\u0430\u043B\u0438
    \u0441\u0441\u043E\u0440\u044B. \u0412\u0434\u043E\u0431\u0430\u0432\u043E\u043A
    \u0443 \u0425\u0435\u043B\u0435\u043D \u0431\u044B\u043B\u043E \u0441\u043B\u0430\u0431\u043E\u0435
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435, \u0438 \u043E\u043D\u0430 \u0447\u0430\u0441\u0442\u043E
    \u0431\u043E\u043B\u0435\u043B\u0430, \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u043B\u043E
    \u0435\u0451 \u0440\u0430\u0437\u0434\u0440\u0430\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439.  
    \u041E\u043D\u0438 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0438 \u043D\u0430
    \u0441\u0432\u0435\u0442 \u0442\u0440\u043E\u0438\u0445 \u0434\u0435\u0442\u0435\u0439:
    \u0434\u0432\u0443\u0445 \u0441\u044B\u043D\u043E\u0432\u0435\u0439 (\u0423\u0438\u043B\u044C\u044F\u043C
    \u042D\u0434\u0432\u0438\u043D \u0438 \u0410\u0440\u0447\u0438\u0431\u0430\u043B\u044C\u0434
    \u0413\u0435\u043D\u0440\u0438) \u0438 \u0434\u043E\u0447\u044C (\u0425\u0435\u043B\u0435\u043D
    \u042D\u043B\u0438\u0437\u0430\u0431\u0435\u0442). \u041E\u0434\u043D\u0430\u043A\u043E
    \u0441\u0435\u043C\u0435\u0439\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u043D\u0435 \u0441\u0442\u0430\u043B\u0430 \u0442\u0435\u043F\u043B\u0435\u0435.
    \u0425\u0435\u043B\u0435\u043D \u043F\u0435\u0440\u0438\u043E\u0434\u0438\u0447\u0435\u0441\u043A\u0438
    \u0443\u0435\u0437\u0436\u0430\u043B\u0430 \u043E\u0442 \u043C\u0443\u0436\u0430,
    \u0436\u0438\u043B\u0430 \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E \u0441
    \u0434\u0435\u0442\u044C\u043C\u0438 \u0443 \u0441\u0432\u043E\u0438\u0445 \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    \u0438\u043B\u0438 \u043D\u0430 \u043A\u0443\u0440\u043E\u0440\u0442\u0430\u0445
    \u043F\u043E \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F.
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D, \u043E\u0441\u0442\u0430\u0432\u0448\u0438\u0441\u044C
    \u043E\u0434\u0438\u043D \u0432 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439,
    \u043C\u0440\u0430\u0447\u043D\u043E\u0439 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438,
    \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u0441\u044F
    \u0432 \u0437\u0430\u0442\u0432\u043E\u0440\u043D\u0438\u043A\u0430.  ---  ###
    3. \U0001F943 \u0410\u043B\u043A\u043E\u0433\u043E\u043B\u0438\u0437\u043C \u0438
    \u0431\u044B\u0442\u043E\u0432\u043E\u0439 \u0445\u0430\u043E\u0441  \u041E\u0441\u0442\u0430\u0432\u0448\u0438\u0441\u044C
    \u0431\u0435\u0437 \u0436\u0435\u043D\u0441\u043A\u043E\u0439 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0438
    \u0438 \u0441\u0442\u0440\u0430\u0434\u0430\u044F \u043E\u0442 \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u0430,
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u043D\u0430\u0447\u0430\u043B
    \u0437\u043B\u043E\u0443\u043F\u043E\u0442\u0440\u0435\u0431\u043B\u044F\u0442\u044C
    \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u0435\u043C. \u042D\u0442\u043E \u043D\u0435
    \u0431\u044B\u043B\u043E \u0432\u0435\u0441\u0451\u043B\u044B\u043C \u043F\u044C\u044F\u043D\u0441\u0442\u0432\u043E\u043C;
    \u044D\u0442\u043E \u0431\u044B\u043B\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435,
    \u0443\u0433\u0440\u044E\u043C\u043E\u0435 \u043F\u0440\u0438\u0441\u0442\u0440\u0430\u0441\u0442\u0438\u0435
    \u043A \u0432\u0438\u0441\u043A\u0438 \u0438 \u043F\u043E\u0440\u0442\u0435\u0440\u0443. 
    \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \u0432\u043D\u0435\u0448\u043D\u043E\u0441\u0442\u044C \u0432
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 20 \u043B\u0435\u0442
    \u0436\u0438\u0437\u043D\u0438 \u043A\u0430\u043A \u0443\u0441\u0442\u0440\u0430\u0448\u0430\u044E\u0449\u0443\u044E:
    \u0432\u0435\u0447\u043D\u043E \u043D\u0435\u0431\u0440\u0438\u0442\u044B\u0439,
    \u0432 \u043D\u0435\u0447\u0438\u0449\u0435\u043D\u043E\u043C \u0441\u044E\u0440\u0442\u0443\u043A\u0435,
    \u0441 \u043A\u0440\u0430\u0441\u043D\u044B\u043C \u043B\u0438\u0446\u043E\u043C
    \u0438 \u043C\u0443\u0442\u043D\u044B\u043C\u0438 \u0433\u043B\u0430\u0437\u0430\u043C\u0438.
    \u041E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u044F \u043F\u0440\u0438\u0448\u043B\u0430
    \u0432 \u043F\u043E\u043B\u043D\u0435\u0439\u0448\u0438\u0439 \u0443\u043F\u0430\u0434\u043E\u043A:
    \u0432\u0441\u044E\u0434\u0443 \u0432\u0430\u043B\u044F\u043B\u0438\u0441\u044C
    \u0433\u0440\u0443\u0434\u044B \u043D\u0435\u0440\u0430\u0437\u043E\u0431\u0440\u0430\u043D\u043D\u044B\u0445
    \u0431\u0443\u043C\u0430\u0433, \u0433\u0440\u044F\u0437\u043D\u0430\u044F \u043F\u043E\u0441\u0443\u0434\u0430,
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u0438\u0431\u043E\u0440\u044B \u043F\u043E\u043A\u0440\u044B\u043B\u0438\u0441\u044C
    \u043F\u044B\u043B\u044C\u044E, \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E
    \u043E\u043D \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B \u0432\u0435\u0441\u0442\u0438
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F (\u0438\u0441\u043F\u043E\u043B\u043D\u044F\u044F
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043D\u043E\u043C\u0438\u043D\u0430\u043B\u044C\u043D\u043E, \u0447\u0435\u043C
    \u0432\u044B\u0437\u044B\u0432\u0430\u043B \u043D\u0435\u0434\u043E\u0432\u043E\u043B\u044C\u0441\u0442\u0432\u043E
    \u043D\u0430\u0447\u0430\u043B\u044C\u0441\u0442\u0432\u0430).  \u0415\u0433\u043E
    \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0438 \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u043F\u043E\u043B\u043D\u044B \u0437\u0430\u043F\u0438\u0441\u0435\u0439 \u043E
    \u0442\u043E\u043C, \u0447\u0442\u043E \u043E\u043D \u043F\u0440\u043E\u0441\u044B\u043F\u0430\u0435\u0442\u0441\u044F
    \u0441 \u043F\u043E\u0445\u043C\u0435\u043B\u044C\u0435\u043C, \u0434\u0430\u0435\u0442
    \u0441\u0435\u0431\u0435 \u0441\u043B\u043E\u0432\u043E \xAB\u0431\u043E\u043B\u044C\u0448\u0435
    \u043D\u0435 \u043F\u0438\u0442\u044C\xBB, \u043D\u043E \u043A \u0432\u0435\u0447\u0435\u0440\u0443
    \u0441\u043D\u043E\u0432\u0430 \u0431\u0435\u0440\u0435\u0442\u0441\u044F \u0437\u0430
    \u0431\u0443\u0442\u044B\u043B\u043A\u0443, \u0447\u0442\u043E\u0431\u044B \u0437\u0430\u0433\u043B\u0443\u0448\u0438\u0442\u044C
    \u0442\u043E\u0441\u043A\u0443. \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u044D\u0442\u043E, \u0435\u0433\u043E \u043C\u043E\u0437\u0433
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0433\u0435\u043D\u0435\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u0438\u0434\u0435\u0438
    \u2014 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E, \u043A\u0430\u043A
    \u043F\u0440\u0438 \u0442\u0430\u043A\u043E\u043C \u043E\u0431\u0440\u0430\u0437\u0435
    \u0436\u0438\u0437\u043D\u0438 \u043E\u043D \u0443\u043C\u0443\u0434\u0440\u044F\u043B\u0441\u044F
    \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u0442\u044C \u044F\u0441\u043D\u043E\u0441\u0442\u044C
    \u0443\u043C\u0430 \u0432 \u0447\u0430\u0441\u044B \u0440\u0430\u0431\u043E\u0442\u044B
    \u043D\u0430\u0434 \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u0430\u043C\u0438. 
    ---  ### 4. \U0001F468\u200D\U0001F467\u200D\U0001F466 \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0434\u0435\u0442\u044C\u043C\u0438 \u0438 \xAB\u0412\u0442\u043E\u0440\u043E\u0439
    \u0431\u0440\u0430\u043A\xBB  \u041A \u0434\u0435\u0442\u044F\u043C \u0443 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    \u0431\u044B\u043B\u043E \u0441\u043B\u043E\u0436\u043D\u043E\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435.
    \u041E\u043D \u043B\u044E\u0431\u0438\u043B \u0438\u0445, \u043D\u043E \u0431\u044B\u043B
    \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E \u043D\u0435\u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F \u0438\u0445 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0435\u043C
    \u0438\u0437-\u0437\u0430 \u0441\u0432\u043E\u0435\u0439 \u043E\u0442\u0440\u0435\u0448\u0451\u043D\u043D\u043E\u0441\u0442\u0438.
    \u0421\u0442\u0430\u0440\u0448\u0438\u0439 \u0441\u044B\u043D, \u0423\u0438\u043B\u044C\u044F\u043C
    \u042D\u0434\u0432\u0438\u043D, \u043F\u043E\u0448\u0451\u043B \u043F\u043E \u0441\u0442\u043E\u043F\u0430\u043C
    \u043E\u0442\u0446\u0430 \u0438 \u0441\u0442\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u043D\u043E \u0438\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0431\u044B\u043B\u0438 \u043F\u0440\u043E\u0445\u043B\u0430\u0434\u043D\u044B\u043C\u0438
    \u2014 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u0441\u044B\u043D \u0432\u0438\u0434\u0435\u043B,
    \u043A\u0430\u043A \u043E\u0442\u0435\u0446 \u0433\u0443\u0431\u0438\u0442 \u0441\u0435\u0431\u044F
    \u0432\u044B\u043F\u0438\u0432\u043A\u043E\u0439, \u0438 \u0441\u0442\u0430\u0440\u0430\u043B\u0441\u044F
    \u0434\u0438\u0441\u0442\u0430\u043D\u0446\u0438\u0440\u043E\u0432\u0430\u0442\u044C\u0441\u044F. 
    \u041E\u0434\u043D\u0430\u043A\u043E \u0432 \u0436\u0438\u0437\u043D\u0438 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    \u0431\u044B\u043B \u044D\u043F\u0438\u0437\u043E\u0434, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u044B \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    **\xAB\u043C\u043E\u0440\u0430\u043B\u044C\u043D\u044B\u043C \u0431\u0440\u0430\u043A\u043E\u043C\xBB**.
    \u0412 1850-\u0445 \u0433\u043E\u0434\u0430\u0445, \u043A\u043E\u0433\u0434\u0430
    \u0425\u0435\u043B\u0435\u043D \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0436\u0438\u043B\u0430 \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E, \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0441\u0442\u0430\u043B \u0436\u0438\u0442\u044C \u0432 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438
    \u0441 \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439 \u043F\u043E \u0438\u043C\u0435\u043D\u0438
    **\u041C\u044D\u0440\u0438 \u0425\u0430\u0442\u0442\u043E\u043D**. \u041E\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0434\u0430\u043B\u044C\u043D\u0435\u0439 \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u0446\u0435\u0439
    \u0438 \u0444\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u043B\u0430
    \u0440\u043E\u043B\u044C \u044D\u043A\u043E\u043D\u043E\u043C\u043A\u0438 \u0438
    \u0441\u0438\u0434\u0435\u043B\u043A\u0438.  \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u041C\u044D\u0440\u0438 \u0431\u044B\u043B\u0438 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0442\u0435\u043F\u043B\u0435\u0435, \u0447\u0435\u043C \u0441 \u0437\u0430\u043A\u043E\u043D\u043D\u043E\u0439
    \u0436\u0435\u043D\u043E\u0439. \u041E\u043D\u0430 \u043F\u044B\u0442\u0430\u043B\u0430\u0441\u044C
    \u043D\u0430\u0432\u0435\u0441\u0442\u0438 \u043F\u043E\u0440\u044F\u0434\u043E\u043A
    \u0432 \u0435\u0433\u043E \u0434\u043E\u043C\u0435 \u0438 \u0445\u043E\u0442\u044C
    \u043A\u0430\u043A-\u0442\u043E \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0435\u0433\u043E \u043F\u0440\u0438\u0451\u043C\u044B \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u044F.
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u0438\u0441\u043F\u044B\u0442\u044B\u0432\u0430\u043B
    \u043A \u043D\u0435\u0439 \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u043D\u043E\u0441\u0442\u044C.
    \u041E\u0434\u043D\u0430\u043A\u043E \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 (\u0438 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0435\u0433\u043E \u0434\u0435\u0442\u0438 \u043E\u0442 \u0425\u0435\u043B\u0435\u043D)
    \u043E\u0441\u0443\u0436\u0434\u0430\u043B\u043E \u044D\u0442\u0443 \u0441\u0432\u044F\u0437\u044C,
    \u0441\u0447\u0438\u0442\u0430\u044F \u0435\u0451 \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u044C\u043D\u043E\u0439,
    \u0442\u0430\u043A \u043A\u0430\u043A \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0440\u0430\u0437\u0432\u043E\u0434\u0430 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u043D\u0435 \u043E\u0444\u043E\u0440\u043C\u043B\u044F\u043B (\u0440\u0430\u0437\u0432\u043E\u0434
    \u0432 \u0432\u0438\u043A\u0442\u043E\u0440\u0438\u0430\u043D\u0441\u043A\u043E\u0439
    \u0418\u0440\u043B\u0430\u043D\u0434\u0438\u0438 \u0431\u044B\u043B \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u0435\u043D).   \u042D\u0442\u0430
    \u0434\u0432\u043E\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F \u0441\u0435\u043C\u0435\u0439\u043D\u0430\u044F
    \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044F (\u0440\u0430\u0437\u0440\u044B\u0432
    \u0441 \u0436\u0435\u043D\u043E\u0439 \u0438 \u0436\u0438\u0437\u043D\u044C \u0441
    \u0434\u0440\u0443\u0433\u043E\u0439 \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439,
    \u043D\u0435 \u044F\u0432\u043B\u044F\u044E\u0449\u0435\u0439\u0441\u044F \u0441\u0443\u043F\u0440\u0443\u0433\u043E\u0439)
    \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u043B\u0430 \u0435\u043C\u0443 \u043C\u043E\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0442\u0435\u0440\u0437\u0430\u043D\u0438\u0439. \u041E\u043D \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u0441\u0435\u0431\u044F
    \u0432\u0438\u043D\u043E\u0432\u0430\u0442\u044B\u043C \u043F\u0435\u0440\u0435\u0434
    \u0432\u0441\u0435\u043C\u0438 \u2014 \u043F\u0435\u0440\u0435\u0434 \u0425\u0435\u043B\u0435\u043D,
    \u043F\u0435\u0440\u0435\u0434 \u041C\u044D\u0440\u0438, \u043F\u0435\u0440\u0435\u0434
    \u0434\u0435\u0442\u044C\u043C\u0438.  ---  ### 5. \U0001F319 \u0423\u043F\u0430\u0434\u043E\u043A
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0434\u043D\u0438 
    \u041A \u043D\u0430\u0447\u0430\u043B\u0443 1860-\u0445 \u0433\u043E\u0434\u043E\u0432
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    \u0431\u044B\u043B\u043E \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u043E\u0434\u043E\u0440\u0432\u0430\u043D\u043E. \u0425\u0440\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u0438\u0437\u043C \u043F\u0440\u0438\u0432\u0435\u043B
    \u043A \u0442\u044F\u0436\u0435\u043B\u0435\u0439\u0448\u0435\u0439 \u043F\u043E\u0434\u0430\u0433\u0440\u0435
    (\u043E\u0442 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u043C\u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0441\u0442\u0440\u0430\u0434\u0430\u043B) \u0438 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430\u043C
    \u0441 \u043F\u043E\u0447\u043A\u0430\u043C\u0438. \u041E\u043D \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B \u0432\u044B\u0445\u043E\u0434\u0438\u0442\u044C
    \u0438\u0437 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438,
    \u043F\u0435\u0440\u0435\u0434\u0432\u0438\u0433\u0430\u043B\u0441\u044F \u0441
    \u0442\u0440\u0443\u0434\u043E\u043C \u0438 \u0441\u0438\u043B\u044C\u043D\u043E
    \u0440\u0430\u0441\u043F\u043E\u043B\u043D\u0435\u043B.  \u0412 \u043A\u043E\u043D\u0446\u0435
    \u0430\u0432\u0433\u0443\u0441\u0442\u0430 1865 \u0433\u043E\u0434\u0430 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u0440\u0435\u0437\u043A\u043E \u0443\u0445\u0443\u0434\u0448\u0438\u043B\u043E\u0441\u044C.
    \u0423 \u043D\u0435\u0433\u043E \u0441\u043B\u0443\u0447\u0438\u043B\u0441\u044F
    \u0441\u0438\u043B\u044C\u043D\u044B\u0439 \u043F\u0440\u0438\u0441\u0442\u0443\u043F
    \u043F\u043E\u0434\u0430\u0433\u0440\u044B, \u043F\u0435\u0440\u0435\u0448\u0435\u0434\u0448\u0438\u0439
    \u0432 \u043E\u0441\u043B\u043E\u0436\u043D\u0435\u043D\u0438\u044F \u043D\u0430
    \u0436\u0435\u043B\u0443\u0434\u043E\u043A \u0438 \u043F\u043E\u0447\u043A\u0438.
    \u0415\u0433\u043E \u0434\u0435\u0442\u0438 \u0443\u0441\u043F\u0435\u043B\u0438
    \u043F\u0440\u0438\u0435\u0445\u0430\u0442\u044C \u043A \u043D\u0435\u043C\u0443.  
    **2 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F 1865 \u0433\u043E\u0434\u0430**
    \u0423\u0438\u043B\u044C\u044F\u043C \u0420\u043E\u0443\u044D\u043D \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    60 \u043B\u0435\u0442 \u0432 \u0414\u0430\u043D\u0441\u0438\u043D\u043A\u0441\u043A\u043E\u0439
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438, \u0432
    \u0442\u043E\u043C \u0441\u0430\u043C\u043E\u043C \u0434\u043E\u043C\u0435, \u0433\u0434\u0435
    \u043F\u0440\u043E\u0432\u0451\u043B \u043F\u043E\u0447\u0442\u0438 40 \u043B\u0435\u0442
    \u0441\u0432\u043E\u0435\u0439 \u043E\u0434\u0438\u043D\u043E\u043A\u043E\u0439,
    \u0441\u0443\u043C\u0440\u0430\u0447\u043D\u043E\u0439 \u0438 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438.  
    ---  ### 6. \U0001F4DC \u041F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u0439
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442  \u0414\u0430\u0436\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0441\u0442\u0430\u043B\u0430 \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439
    \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u0430. \u0412 \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0438
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435 \u043A \u041C\u044D\u0440\u0438
    \u0425\u0430\u0442\u0442\u043E\u043D, \u043E\u0441\u0442\u0430\u0432\u0438\u0432
    \u0435\u0439 \u0447\u0430\u0441\u0442\u044C \u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u0430.
    \u042D\u0442\u043E \u0432\u044B\u0437\u0432\u0430\u043B\u043E \u044F\u0440\u043E\u0441\u0442\u043D\u044B\u0439
    \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u043C\u0435\u0436\u0434\u0443
    \u0435\u0433\u043E \u0437\u0430\u043A\u043E\u043D\u043D\u044B\u043C\u0438 \u0434\u0435\u0442\u044C\u043C\u0438
    \u043E\u0442 \u0425\u0435\u043B\u0435\u043D \u0411\u044D\u0439\u043B\u0438 \u0438
    \u0434\u0443\u0448\u0435\u043F\u0440\u0438\u043A\u0430\u0437\u0447\u0438\u043A\u0430\u043C\u0438.
    \u0421\u044B\u043D \u0423\u0438\u043B\u044C\u044F\u043C \u042D\u0434\u0432\u0438\u043D
    \u043E\u0441\u043F\u0430\u0440\u0438\u0432\u0430\u043B \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0435,
    \u0438 \u0432 \u0438\u0442\u043E\u0433\u0435 \u041C\u044D\u0440\u0438 \u0431\u044B\u043B\u0430
    \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u0430 \u043F\u043E\u043A\u0438\u043D\u0443\u0442\u044C
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u044E \u043F\u043E\u0447\u0442\u0438
    \u0441\u0440\u0430\u0437\u0443 \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u0445\u043E\u0440\u043E\u043D,
    \u043F\u043E\u043B\u0443\u0447\u0438\u0432 \u043B\u0438\u0448\u044C \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0435
    \u043F\u043E\u0441\u043E\u0431\u0438\u0435.  ---  ### \U0001F48E \u041F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442  \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0431\u044B\u043B \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u043C **\xAB\u0431\u0435\u0437\u0443\u043C\u043D\u043E\u0433\u043E
    \u0443\u0447\u0451\u043D\u043E\u0433\u043E\xBB** \u0432\u0438\u043A\u0442\u043E\u0440\u0438\u0430\u043D\u0441\u043A\u043E\u0439
    \u044D\u043F\u043E\u0445\u0438. \u0415\u0433\u043E \u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043E \u0442\u043E\u043C, \u043A\u0430\u043A \u0432\u044B\u0441\u043E\u0447\u0430\u0439\u0448\u0438\u0439
    \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442 \u0438 \u0433\u043B\u0443\u0431\u043E\u0447\u0430\u0439\u0448\u0430\u044F
    \u044D\u043C\u043E\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0430\u044F
    \u0447\u0443\u0432\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u043B\u0438 \u0431\u044B\u0442\u043E\u0432\u043E\u0435
    \u0441\u0447\u0430\u0441\u0442\u044C\u0435.   \u041E\u043D \u0436\u0438\u043B
    \u0432 \u043F\u043B\u0435\u043D\u0443 \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u043B\u043B\u044E\u0437\u0438\u0439 (\u043E\u0431\u0440\u0430\u0437 \u041A\u044D\u0442\u0440\u0438\u043D
    \u0414\u0438\u0441\u043D\u0435\u0439), \u043D\u0435 \u0441\u0443\u043C\u0435\u043B
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u0435\u043C\u044C\u044E, \u0441\u0442\u0440\u0430\u0434\u0430\u043B \u043E\u0442
    \u043D\u0435\u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u0441\u043E
    \u0441\u0442\u043E\u0440\u043E\u043D\u044B \u0436\u0435\u043D\u044B \u0438 \u0432
    \u0438\u0442\u043E\u0433\u0435 \u0432\u044B\u0431\u0440\u0430\u043B \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u0443\u0442\u0435\u0448\u0438\u0442\u0435\u043B\u0435\u0439 \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u044C
    \u0438 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443.
    \u041F\u043E \u0438\u0440\u043E\u043D\u0438\u0438 \u0441\u0443\u0434\u044C\u0431\u044B,
    \u0438\u043C\u0435\u043D\u043D\u043E \u0435\u0433\u043E \u043D\u0435\u0441\u0447\u0430\u0441\u0442\u044C\u0435
    \u0432 \u043B\u044E\u0431\u0432\u0438 \u0438 \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u043E
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438 \u0435\u043C\u0443 \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u044B \u2014 \u0432\u0435\u0434\u044C
    \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E \u043D\u0443\u0436\u043D\u0430
    \u0431\u044B\u043B\u0430 \u043F\u043E\u043B\u043D\u0430\u044F, \u043F\u043E\u0447\u0442\u0438
    \u043C\u043E\u043D\u0430\u0448\u0435\u0441\u043A\u0430\u044F \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u043D\u0430 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0435\u043C \u043C\u0438\u0440\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043D\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u0435\u043D
    \u0434\u0430\u0442\u044C \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u0439
    \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u0439 \u0431\u044B\u0442."
  personalLifeEn: 
  shortBioRu: "\u0421\u044D\u0440 \u0423\u0438\u043B\u044C\u044F\u043C \u0420\u043E\u0443\u044D\u043D
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D (1805\u20131865) \u2014
    \u0438\u0440\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A \u0438 \u0444\u0438\u0437\u0438\u043A,
    \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u043D\u0430\u043C\u043D\u043E\u0433\u043E
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438 \u0441\u0432\u043E\u0451
    \u0432\u0440\u0435\u043C\u044F. \u041E\u043D \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u043A\u0430\u043A \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C **\u0433\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u043E\u0432\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0441\u0442\u0430\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u0444\u0438\u0437\u0438\u043A\u0438,
    \u0438 \u043A\u0430\u043A \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u044C
    **\u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u043E\u0432**
    \u2014 \u043F\u0435\u0440\u0432\u043E\u0439 \u043D\u0435\u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B, \u043E\u0442\u043A\u0440\u044B\u0432\u0448\u0435\u0439
    \u043F\u0443\u0442\u044C \u043A \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C\u0443
    \u0432\u0435\u043A\u0442\u043E\u0440\u043D\u043E\u043C\u0443 \u0430\u043D\u0430\u043B\u0438\u0437\u0443. 
    \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u0435\u0433\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F,
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u043F\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u043C \u044D\u0442\u0430\u043F\u0430\u043C
    \u0436\u0438\u0437\u043D\u0438.  ### \U0001F4DC \u0414\u0435\u0442\u0441\u0442\u0432\u043E
    \u0438 \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442  \u0423\u0438\u043B\u044C\u044F\u043C
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0414\u0443\u0431\u043B\u0438\u043D\u0435 4 \u0430\u0432\u0433\u0443\u0441\u0442\u0430
    1805 \u0433\u043E\u0434\u0430. \u041E\u043D \u0431\u044B\u043B \u0447\u0435\u0442\u0432\u0451\u0440\u0442\u044B\u043C
    \u0438\u0437 \u0434\u0435\u0432\u044F\u0442\u0438 \u0434\u0435\u0442\u0435\u0439
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u044E\u0440\u0438\u0441\u0442\u0430. \u0418\u0437-\u0437\u0430
    \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0445 \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u0435\u0439
    \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u0439 \u0441 \u0433\u043E\u0434\u043E\u0432\u0430\u043B\u043E\u0433\u043E
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0430 \u0435\u0433\u043E \u0432\u043E\u0441\u043F\u0438\u0442\u044B\u0432\u0430\u043B
    \u0434\u044F\u0434\u044F, \u0414\u0436\u0435\u0439\u043C\u0441 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0432\u0438\u043A\u0430\u0440\u0438\u0439 \u0438 \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u0439
    \u043F\u0435\u0434\u0430\u0433\u043E\u0433, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441 \u0441\u0430\u043C\u043E\u0433\u043E \u043D\u0430\u0447\u0430\u043B\u0430
    \u0440\u0430\u0437\u0433\u043B\u044F\u0434\u0435\u043B \u0432 \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0435
    \u043D\u0435\u043E\u0431\u044B\u0447\u0430\u0439\u043D\u044B\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438. 
    \u0424\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u0430\u044F
    \u043F\u0430\u043C\u044F\u0442\u044C \u0438 \u043B\u044E\u0431\u043E\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0438\u0441\u044C
    \u043E\u0447\u0435\u043D\u044C \u0440\u0430\u043D\u043E:  *   **\u0412 3 \u0433\u043E\u0434\u0430**
    \u043E\u043D \u0443\u0436\u0435 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E
    \u0447\u0438\u0442\u0430\u043B \u0438 \u043E\u0441\u0432\u0430\u0438\u0432\u0430\u043B
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0443. *   **\u041A 7
    \u0433\u043E\u0434\u0430\u043C** \u043E\u043D \u0437\u043D\u0430\u043B \u043B\u0430\u0442\u044B\u043D\u044C,
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0439 \u0438 \u0434\u0440\u0435\u0432\u043D\u0435\u0435\u0432\u0440\u0435\u0439\u0441\u043A\u0438\u0439
    \u044F\u0437\u044B\u043A\u0438. *   **\u041A 12 \u0433\u043E\u0434\u0430\u043C**
    \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0434\u044F\u0434\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u043B
    \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u043E\u043C, \u043E\u043D \u0432\u044B\u0443\u0447\u0438\u043B
    \u0443\u0436\u0435 12 \u044F\u0437\u044B\u043A\u043E\u0432, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u043F\u0435\u0440\u0441\u0438\u0434\u0441\u043A\u0438\u0439, \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0439,
    \u0441\u0430\u043D\u0441\u043A\u0440\u0438\u0442, \u0445\u0438\u043D\u0434\u0443\u0441\u0442\u0430\u043D\u0438
    \u0438 \u043C\u0430\u043B\u0430\u0439\u0441\u043A\u0438\u0439. \u0412 13 \u043B\u0435\u0442
    \u043E\u043D \u0434\u0430\u0436\u0435 \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E \u043F\u043E
    \u0441\u0438\u0440\u0438\u0439\u0441\u043A\u043E\u0439 \u0433\u0440\u0430\u043C\u043C\u0430\u0442\u0438\u043A\u0435. 
    \u041E\u0434\u043D\u0430\u043A\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u044F\u0437\u044B\u043A\u0430\u043C \u0443\u0441\u0442\u0443\u043F\u0438\u043B
    \u043C\u0435\u0441\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0432\u0441\u0442\u0440\u0435\u0447\u0438 \u0441
    \u0434\u0435\u0432\u044F\u0442\u0438\u043B\u0435\u0442\u043D\u0438\u043C \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u043C
    \"\u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u043E\u043C\" \u0417\u0435\u0440\u0430\u0445\u043E\u043C
    \u041A\u043E\u043B\u0431\u0435\u0440\u043D\u043E\u043C. \u0412 \u0441\u043E\u0440\u0435\u0432\u043D\u043E\u0432\u0430\u043D\u0438\u0438
    \u043F\u043E \u0443\u0441\u0442\u043D\u043E\u043C\u0443 \u0441\u0447\u0451\u0442\u0443
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u043F\u0440\u043E\u0438\u0433\u0440\u0430\u043B,
    \u0438 \u044D\u0442\u043E \u043F\u043E\u0440\u0430\u0436\u0435\u043D\u0438\u0435
    \u0441\u0442\u0430\u043B\u043E \u043C\u043E\u0449\u043D\u044B\u043C \u0441\u0442\u0438\u043C\u0443\u043B\u043E\u043C. 
    \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 10 \u043B\u0435\u0442
    \u043E\u043D \u0438\u0437\u0443\u0447\u0438\u043B \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u0438\u0439
    \u043F\u0435\u0440\u0435\u0432\u043E\u0434 \xAB\u041D\u0430\u0447\u0430\u043B\xBB
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430, \u0432 13 \u2014 \xAB\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u0443\u044E
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0443\xBB \u041D\u044C\u044E\u0442\u043E\u043D\u0430,
    \u0430 \u0432 16 \u2014 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0447\u0430\u0441\u0442\u044C \u0435\u0433\u043E \u0436\u0435 \xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0447\u0430\u043B \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438\xBB. \u0412 17 \u043B\u0435\u0442
    \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435
    \xAB\u041D\u0435\u0431\u0435\u0441\u043D\u043E\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438\xBB
    \u041B\u0430\u043F\u043B\u0430\u0441\u0430 \u0438 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B
    \u0432 \u043D\u0435\u0439 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043E\u0448\u0438\u0431\u043A\u0443, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0443\u043A\u0430\u0437\u0430\u043B \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u043C\u0443
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0443 \u0418\u0440\u043B\u0430\u043D\u0434\u0438\u0438
    \u0414\u0436\u043E\u043D\u0443 \u0411\u0440\u0438\u043D\u043A\u043B\u0438. \u042D\u0442\u043E
    \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u043B\u043E \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435
    \u0411\u0440\u0438\u043D\u043A\u043B\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C
    \u044E\u043D\u043E\u0433\u043E \u0433\u0435\u043D\u0438\u044F.  ### \U0001F393
    \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436
    \u0438 \u043D\u0435\u0431\u044B\u0432\u0430\u043B\u043E\u0435 \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 
    \u0412 1823 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    18 \u043B\u0435\u0442, \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0422\u0440\u0438\u043D\u0438\u0442\u0438-\u043A\u043E\u043B\u043B\u0435\u0434\u0436
    \u0414\u0443\u0431\u043B\u0438\u043D\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430,
    \u0433\u0434\u0435 \u0441 \u0431\u043B\u0435\u0441\u043A\u043E\u043C \u0438\u0437\u0443\u0447\u0430\u043B
    \u0438 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0443, \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u043F\u043E\u043B\u0443\u0447\u0430\u044F \u0432\u044B\u0441\u0448\u0438\u0435
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u043F\u043E \u0432\u0441\u0435\u043C
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430\u043C.  \u0412 1824 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B \u0441\u0432\u043E\u044E
    \u043F\u0435\u0440\u0432\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443 \u043F\u043E
    \u043E\u043F\u0442\u0438\u043A\u0435 \xAB\u041E \u043A\u0430\u0443\u0441\u0442\u0438\u043A\u0430\u0445\xBB
    (On Caustics) \u0432 \u0418\u0440\u043B\u0430\u043D\u0434\u0441\u043A\u0443\u044E
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u0443\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E. 
    **\u0413\u043B\u0430\u0432\u043D\u044B\u043C \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043D\u044B\u043C
    \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C \u0441\u0442\u0430\u043B\u043E
    \u0435\u0433\u043E \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0432 1827 \u0433\u043E\u0434\u0443.** 22-\u043B\u0435\u0442\u043D\u0435\u043C\u0443
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0443, \u0435\u0449\u0451 \u043D\u0435
    \u0438\u043C\u0435\u0432\u0448\u0435\u043C\u0443 \u0443\u0447\u0451\u043D\u043E\u0439
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438, \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B\u0438
    \u043F\u043E\u0441\u0442 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438 \u0414\u0443\u0431\u043B\u0438\u043D\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u0438
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430
    \u0418\u0440\u043B\u0430\u043D\u0434\u0438\u0438 (\u043F\u043E\u0441\u043B\u0435
    \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0438 \u0411\u0440\u0438\u043D\u043A\u043B\u0438).
    \u042D\u0442\u043E \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0432\u044B\u0437\u0432\u0430\u043B\u043E \u043C\u043D\u043E\u0433\u043E \u0441\u043F\u043E\u0440\u043E\u0432,
    \u0442\u0430\u043A \u043A\u0430\u043A \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u043D\u0435 \u0438\u043C\u0435\u043B \u043E\u043F\u044B\u0442\u0430 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u0439, \u043D\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0435
    \u0432\u043B\u0430\u0441\u0442\u0438 \u043F\u043E\u0448\u043B\u0438 \u043D\u0430
    \u044D\u0442\u043E\u0442 \u0448\u0430\u0433, \u0432\u0438\u0434\u044F \u0432
    \u043D\u0451\u043C \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439 \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B.  ### \U0001F4A1 \u0420\u0430\u0441\u0446\u0432\u0435\u0442
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438:
    \u043E\u043F\u0442\u0438\u043A\u0430 \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430 
    \u041F\u043E\u0441\u0435\u043B\u0438\u0432\u0448\u0438\u0441\u044C \u0432 \u0414\u0430\u043D\u0441\u0438\u043D\u043A\u0441\u043A\u043E\u0439
    \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438, \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u0447\u0430\u0441\u0442\u044C \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u043F\u043E\u0441\u0432\u044F\u0449\u0430\u043B \u043D\u0435 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438,
    \u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 \u0438 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435.  \u0412 1832 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0443,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430
    \u0435\u043C\u0443 \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0441\u043B\u0430\u0432\u0443.
    \u0412 \u0442\u0440\u0435\u0442\u044C\u0435\u043C \u0434\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u0438
    \u043A \u0441\u0432\u043E\u0435\u0439 \xAB\u0422\u0435\u043E\u0440\u0438\u0438
    \u0441\u0438\u0441\u0442\u0435\u043C \u043B\u0443\u0447\u0435\u0439\xBB \u043E\u043D
    **\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043B \u044F\u0432\u043B\u0435\u043D\u0438\u0435
    \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0440\u0435\u0444\u0440\u0430\u043A\u0446\u0438\u0438**.
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043F\u0440\u0438
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0445 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445
    \u0441\u0432\u0435\u0442, \u043F\u0440\u043E\u0445\u043E\u0434\u044F \u0447\u0435\u0440\u0435\u0437
    \u0434\u0432\u0443\u0445\u043E\u0441\u043D\u044B\u0439 \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B,
    \u0434\u043E\u043B\u0436\u0435\u043D \u0432\u044B\u0445\u043E\u0434\u0438\u0442\u044C
    \u0438\u0437 \u043D\u0435\u0433\u043E \u043D\u0435 \u0432 \u0432\u0438\u0434\u0435
    \u043E\u0434\u043D\u043E\u0433\u043E \u043B\u0443\u0447\u0430, \u0430 \u0432
    \u0432\u0438\u0434\u0435 \u043F\u043E\u043B\u043E\u0433\u043E \u043A\u043E\u043D\u0443\u0441\u0430.
    \u042D\u0442\u043E \u0441\u043C\u0435\u043B\u043E\u0435 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u0435
    \u0432\u0441\u043A\u043E\u0440\u0435 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435
    \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u043B \u043D\u0430 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0435
    \u0435\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0430, \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u0425\u0430\u043C\u0444\u0440\u0438 \u041B\u043B\u043E\u0439\u0434.  \u0412
    1834\u20131835 \u0433\u043E\u0434\u0430\u0445 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u0438
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B **\xAB\u041E\u0431 \u043E\u0431\u0449\u0435\u043C
    \u043C\u0435\u0442\u043E\u0434\u0435 \u0432 \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0435\xBB**.
    \u0412 \u043D\u0438\u0445 \u043E\u043D \u043F\u0435\u0440\u0435\u043D\u0451\u0441
    \u0441\u0432\u043E\u0438 \u043E\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u043D\u0430 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443
    \u0438 \u0441\u043E\u0437\u0434\u0430\u043B \u043D\u043E\u0432\u044B\u0439, \u0447\u0440\u0435\u0437\u0432\u044B\u0447\u0430\u0439\u043D\u043E
    \u043E\u0431\u0449\u0438\u0439 \u043F\u043E\u0434\u0445\u043E\u0434 \u043A \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044E
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0441\u0438\u0441\u0442\u0435\u043C.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u044D\u0442\u043E\u0433\u043E \u043F\u0435\u0440\u0438\u043E\u0434\u0430:  *  
    **\u041F\u0440\u0438\u043D\u0446\u0438\u043F \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430**
    (\u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439 \u043F\u0440\u0438\u043D\u0446\u0438\u043F
    \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0433\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0430\u043B \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C
    \u043A\u0430\u043C\u043D\u0435\u043C \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438. *   **\u041A\u0430\u043D\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0442\u044C \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0443
    \u0447\u0435\u0440\u0435\u0437 \u0444\u0443\u043D\u043A\u0446\u0438\u0438 (\u0433\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0438\u0430\u043D\u044B)
    \u0438 \u043E\u0442\u043A\u0440\u044B\u043B\u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E
    \u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u044E \u043C\u0435\u0436\u0434\u0443
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u0430\u043C\u0438 \u0438
    \u0438\u043C\u043F\u0443\u043B\u044C\u0441\u0430\u043C\u0438.  \u0428\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u041F\u0438\u0442\u0435\u0440
    \u0422\u0435\u0439\u0442 \u043D\u0430\u0437\u0432\u0430\u043B \u044D\u0442\u0438
    \u0440\u0430\u0431\u043E\u0442\u044B \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C
    \u0432\u043A\u043B\u0430\u0434\u043E\u043C \u0432 \u0434\u0438\u043D\u0430\u043C\u0438\u043A\u0443
    \u0441\u043E \u0432\u0440\u0435\u043C\u0451\u043D \u041D\u044C\u044E\u0442\u043E\u043D\u0430
    \u0438 \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430.  \u0417\u0430 \u0441\u0432\u043E\u0438
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0437\u0430\u0441\u043B\u0443\u0433\u0438
    \u0432 1835 \u0433\u043E\u0434\u0443 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0431\u044B\u043B **\u043F\u043E\u0441\u0432\u044F\u0449\u0451\u043D \u0432
    \u0440\u044B\u0446\u0430\u0440\u0441\u043A\u043E\u0435 \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u043E**
    \u0432\u0438\u0446\u0435-\u043A\u043E\u0440\u043E\u043B\u0451\u043C \u0418\u0440\u043B\u0430\u043D\u0434\u0438\u0438
    , \u0430 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0435 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E
    \u043D\u0430\u0433\u0440\u0430\u0434\u0438\u043B\u043E \u0435\u0433\u043E \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u043C\u0435\u0434\u0430\u043B\u044C\u044E. \u0412 1837 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u0418\u0440\u043B\u0430\u043D\u0434\u0441\u043A\u043E\u0439 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u0438 \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A.  ###
    \u2728 \u0412\u0435\u043B\u0438\u043A\u043E\u0435 \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u0435:
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u043E\u0432 
    \u041A 1840-\u043C \u0433\u043E\u0434\u0430\u043C \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0431\u044B\u043B \u043E\u0434\u0435\u0440\u0436\u0438\u043C \u0438\u0434\u0435\u0435\u0439
    \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u0430\u043B\u0433\u0435\u0431\u0440\u0443
    \u0434\u043B\u044F \u0442\u0440\u0451\u0445\u043C\u0435\u0440\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u0431\u044B \u0441\u0442\u043E\u043B\u044C \u0436\u0435
    \u043F\u043E\u043B\u0435\u0437\u043D\u0430, \u043A\u0430\u043A \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430 \u0434\u043B\u044F \u0434\u0432\u0443\u043C\u0435\u0440\u043D\u043E\u0439
    \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438.  \u0414\u043E\u043B\u0433\u0438\u0435
    \u0433\u043E\u0434\u044B \u043E\u043D \u0431\u0435\u0437\u0443\u0441\u043F\u0435\u0448\u043D\u043E
    \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C
    \u0442\u0435\u043E\u0440\u0438\u044E \"\u0442\u0440\u0438\u043F\u043B\u0435\u0442\u043E\u0432\".
    \u041D\u0430\u043A\u043E\u043D\u0435\u0446, 16 \u043E\u043A\u0442\u044F\u0431\u0440\u044F
    1843 \u0433\u043E\u0434\u0430, \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0438
    \u0432\u0434\u043E\u043B\u044C \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043A\u0430\u043D\u0430\u043B\u0430 \u0432 \u0414\u0443\u0431\u043B\u0438\u043D\u0435
    \u0441 \u0436\u0435\u043D\u043E\u0439, \u0435\u0433\u043E \u043E\u0441\u0435\u043D\u0438\u043B\u043E.
    \u041E\u043D \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F \u043D\u0435
    \u0432 \u0442\u0440\u0451\u0445 \u0447\u0438\u0441\u043B\u0430\u0445, \u0430
    \u0432 \u0447\u0435\u0442\u044B\u0440\u0451\u0445 \u2014 \u0432 **\u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u0430\u0445**.
    \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u043C \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C
    \u0431\u044B\u043B \u043E\u0442\u043A\u0430\u0437 \u043E\u0442 \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u044F
    (\u0442.\u0435. `a \xD7 b \u2260 b \xD7 a`).  \u041E\u0445\u0432\u0430\u0447\u0435\u043D\u043D\u044B\u0439
    \u0432\u043E\u0441\u0442\u043E\u0440\u0433\u043E\u043C, \u043E\u043D \u0432\u044B\u0440\u0435\u0437\u0430\u043B
    \u043E\u0441\u043D\u043E\u0432\u043D\u0443\u044E \u0444\u043E\u0440\u043C\u0443\u043B\u0443
    \u043D\u0430 \u043A\u0430\u043C\u043D\u0435 \u043C\u043E\u0441\u0442\u0430 \u0411\u0440\u0443\u043C-\u0411\u0440\u0438\u0434\u0436:
    **`i\xB2 = j\xB2 = k\xB2 = ijk = -1`**. \u041E\u0441\u0442\u0430\u0442\u043E\u043A
    \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438, \u043F\u043E\u0447\u0442\u0438
    22 \u0433\u043E\u0434\u0430, \u043E\u043D \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044E \u044D\u0442\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u044B
    \u0438 \u0435\u0451 \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0439.
    \u0425\u043E\u0442\u044F \u043F\u043E\u0437\u0436\u0435 \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u044B
    \u0431\u044B\u043B\u0438 \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E \u0432\u044B\u0442\u0435\u0441\u043D\u0435\u043D\u044B
    \u0432\u0435\u043A\u0442\u043E\u0440\u043D\u044B\u043C \u0430\u043D\u0430\u043B\u0438\u0437\u043E\u043C
    \u0413\u0438\u0431\u0431\u0441\u0430 \u0438 \u0425\u0435\u0432\u0438\u0441\u0430\u0439\u0434\u0430,
    \u043E\u043D\u0438 \u043F\u043E\u043B\u043E\u0436\u0438\u043B\u0438 \u0435\u043C\u0443
    \u043D\u0430\u0447\u0430\u043B\u043E. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0432\u0432\u0451\u043B \u0442\u0430\u043A\u0438\u0435 \u0442\u0435\u0440\u043C\u0438\u043D\u044B,
    \u043A\u0430\u043A **\xAB\u0432\u0435\u043A\u0442\u043E\u0440\xBB**, **\xAB\u0441\u043A\u0430\u043B\u044F\u0440\xBB**
    \u0438 **\xAB\u043E\u043F\u0435\u0440\u0430\u0442\u043E\u0440 \u043D\u0430\u0431\u043B\u0430\xBB**. 
    ### \U0001F943 \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B 
    \u0416\u0438\u0437\u043D\u044C \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    \u043D\u0435 \u0431\u044B\u043B\u0430 \u0431\u0435\u0437\u043E\u0431\u043B\u0430\u0447\u043D\u043E\u0439.
    \u0412 \u044E\u043D\u043E\u0441\u0442\u0438 \u043E\u043D \u0442\u044F\u0436\u0435\u043B\u043E
    \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u043B \u0431\u0435\u0437\u043E\u0442\u0432\u0435\u0442\u043D\u0443\u044E
    \u043B\u044E\u0431\u043E\u0432\u044C \u043A \u041A\u044D\u0442\u0440\u0438\u043D
    \u0414\u0438\u0441\u043D\u0435\u0439, \u0447\u0442\u043E \u0442\u043E\u043B\u043A\u043D\u0443\u043B\u043E
    \u0435\u0433\u043E \u043A \u043F\u043E\u044D\u0437\u0438\u0438.  \u0412 1833
    \u0433\u043E\u0434\u0443 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0425\u0435\u043B\u0435\u043D \u041C\u0430\u0440\u0438\u0438 \u0411\u044D\u0439\u043B\u0438.
    \u0411\u0440\u0430\u043A \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u043D\u0435\u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C:
    \u043E\u043D\u0438 \u0431\u044B\u043B\u0438 \u0440\u0430\u0437\u043D\u044B\u043C\u0438
    \u043B\u044E\u0434\u044C\u043C\u0438, \u0425\u0435\u043B\u0435\u043D \u0447\u0430\u0441\u0442\u043E
    \u0431\u043E\u043B\u0435\u043B\u0430 \u0438 \u043F\u043E\u0434\u043E\u043B\u0433\u0443
    \u0436\u0438\u043B\u0430 \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E. \u042D\u0442\u043E
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u0442\u043E\u043C\u0443, \u0447\u0442\u043E
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u0441\u0442\u0430\u043B
    \u0437\u043B\u043E\u0443\u043F\u043E\u0442\u0440\u0435\u0431\u043B\u044F\u0442\u044C
    \u0430\u043B\u043A\u043E\u0433\u043E\u043B\u0435\u043C, \u0430 \u0435\u0433\u043E
    \u0434\u043E\u043C \u0432 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438
    \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u043B\u0441\u044F \u0432 \u0445\u0430\u043E\u0441. 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u044D\u0442\u043E,
    \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0434\u043E \u0441\u0430\u043C\u043E\u0439 \u0441\u043C\u0435\u0440\u0442\u0438.
    2 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F 1865 \u0433\u043E\u0434\u0430
    \u0441\u044D\u0440 \u0423\u0438\u043B\u044C\u044F\u043C \u0420\u043E\u0443\u044D\u043D
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 \u0414\u0443\u0431\u043B\u0438\u043D\u0435 \u043E\u0442 \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0430
    \u043F\u043E\u0434\u0430\u0433\u0440\u044B.  ### \U0001F4D6 \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    XIX \u0432\u0435\u043A\u0430. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438 \u043E\u0441\u043D\u043E\u0432\u044B
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043B\u044F \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438, \u043D\u043E \u0438 \u0441\u0442\u0430\u043B\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u044F\u0437\u044B\u043A\u043E\u043C \u0434\u043B\u044F \u0442\u0430\u043A\u0438\u0445
    \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432 \u0444\u0438\u0437\u0438\u043A\u0438
    XX \u0432\u0435\u043A\u0430, \u043A\u0430\u043A \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u0430\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430 \u0438 \u043E\u0431\u0449\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043E \u0442\u043E\u043C, \u043A\u0430\u043A \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0439
    \u0433\u0435\u043D\u0438\u0439, \u043D\u0435\u0443\u0434\u0435\u0440\u0436\u0438\u043C\u0430\u044F
    \u0441\u0442\u0440\u0430\u0441\u0442\u044C \u043A \u043D\u0430\u0443\u043A\u0435
    \u0438 \u043B\u0438\u0447\u043D\u044B\u0435 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438
    \u0441\u043F\u043B\u0435\u043B\u0438\u0441\u044C \u0432 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u0445
    \u0438 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u044B\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u043F\u0443\u0442\u0435\u0439 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438."
  shortBioEn: 
  interestingFactsRu: "\u041B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u0423\u0438\u043B\u044C\u044F\u043C\u0430
    \u0420\u043E\u0443\u044D\u043D\u0430 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043C\u043D\u043E\u0433\u043E\u0433\u0440\u0430\u043D\u043D\u0430,
    \u0447\u0442\u043E \u0437\u0430 \u0441\u0443\u0445\u0438\u043C\u0438 \u0441\u0442\u0440\u043E\u043A\u0430\u043C\u0438
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0442\u0440\u0443\u0434\u043E\u0432
    \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u0443\u0439\u043C\u0430
    \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u0432, \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u043E\u0432
    \u0438 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439. \u041E\u043D \u0431\u044B\u043B \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u0441\u0430\u043C\u044B\u043C \xAB\u043D\u0435\u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u044B\u043C\xBB
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0438 \u0441\u0430\u043C\u044B\u043C \xAB\u0437\u0435\u043C\u043D\u044B\u043C\xBB
    \u0433\u0435\u043D\u0438\u0435\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432\u044B\u0440\u0435\u0437\u0430\u043B \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u043D\u0430 \u043A\u0430\u043C\u043D\u0435, \u043F\u0440\u043E\u0438\u0433\u0440\u044B\u0432\u0430\u043B
    \u0434\u0435\u0442\u044F\u043C \u0432 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0435
    \u0438 \u0441\u0441\u043E\u0440\u0438\u043B\u0441\u044F \u0441 \u0436\u0435\u043D\u043E\u0439
    \u0438\u0437-\u0437\u0430 \u043C\u0443\u0445.  \u0412\u043E\u0442 \u043F\u043E\u0434\u0431\u043E\u0440\u043A\u0430
    \u0441\u0430\u043C\u044B\u0445 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0445,
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438 \u043F\u043E\u0440\u043E\u0439 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u0438\u0437 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438
    \u2014 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E. 
    ---  ### 1. \U0001F476 \xAB\u0412\u0443\u043D\u0434\u0435\u0440\u043A\u0438\u043D\u0434-\u043F\u043E\u043B\u0438\u0433\u043B\u043E\u0442\xBB:
    13 \u043B\u0435\u0442 \u0438 13 \u044F\u0437\u044B\u043A\u043E\u0432  \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    \u0447\u0430\u0441\u0442\u043E \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u044E\u0442
    \u0441 \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0433\u0435\u043D\u0438\u044F\u043C\u0438,
    \u043D\u043E \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u043E\u043D \u043F\u0440\u0435\u0432\u0437\u043E\u0448\u0435\u043B
    \u0434\u0430\u0436\u0435 \u041C\u0438\u0448\u0435\u043B\u044F \u041D\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u043C\u0443\u0441\u0430
    \u0438 \u0414\u0436\u043E\u043D\u0430 \u0421\u0442\u044E\u0430\u0440\u0442\u0430
    \u041C\u0438\u043B\u043B\u044F \u043F\u043E \u0447\u0430\u0441\u0442\u0438 \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u043A\u0438. 
    \u0412\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u043D\u044B\u0439 \u0434\u044F\u0434\u0435\u0439-\u0432\u0438\u043A\u0430\u0440\u0438\u0435\u043C,
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A \u0440\u043E\u0441 \u0432 \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0435,
    \u0433\u0434\u0435 \u0437\u043D\u0430\u043D\u0438\u0435 \u044F\u0437\u044B\u043A\u043E\u0432
    \u0441\u0447\u0438\u0442\u0430\u043B\u043E\u0441\u044C \u043F\u0440\u0438\u0437\u043D\u0430\u043A\u043E\u043C
    \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u0438\u0437\u043C\u0430.
    \u041E\u0434\u043D\u0430\u043A\u043E \u043A 13 \u0433\u043E\u0434\u0430\u043C
    \u0423\u0438\u043B\u044C\u044F\u043C \u0437\u043D\u0430\u043B \u043D\u0435 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0439
    \u043D\u0430\u0431\u043E\u0440 (\u043B\u0430\u0442\u044B\u043D\u044C, \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u0438\u0439,
    \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439, \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u0438\u0439),
    \u0430 \u044D\u043A\u0437\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0440\u0442\u0432\u044B\u0435 \u0438 \u0436\u0438\u0432\u044B\u0435
    \u044F\u0437\u044B\u043A\u0438: **\u0434\u0440\u0435\u0432\u043D\u0435\u0435\u0432\u0440\u0435\u0439\u0441\u043A\u0438\u0439,
    \u0441\u0438\u0440\u0438\u0439\u0441\u043A\u0438\u0439, \u0445\u0430\u043B\u0434\u0435\u0439\u0441\u043A\u0438\u0439
    (\u0430\u0440\u0430\u043C\u0435\u0439\u0441\u043A\u0438\u0439), \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0439,
    \u043F\u0435\u0440\u0441\u0438\u0434\u0441\u043A\u0438\u0439, \u0441\u0430\u043D\u0441\u043A\u0440\u0438\u0442,
    \u0431\u0435\u043D\u0433\u0430\u043B\u044C\u0441\u043A\u0438\u0439, \u043C\u0430\u043B\u0430\u0439\u0441\u043A\u0438\u0439
    \u0438 \u0434\u0430\u0436\u0435 \u043C\u0430\u0440\u0430\u0442\u0445\u0438.**  
    **\u0417\u0430\u0431\u0430\u0432\u043D\u0430\u044F \u0434\u0435\u0442\u0430\u043B\u044C:**
    \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0433\u0440\u0430\u043C\u043C\u0430\u0442\u0438\u043A\u0443
    \u0441\u0438\u0440\u0438\u0439\u0441\u043A\u043E\u0433\u043E \u044F\u0437\u044B\u043A\u0430
    \u0432 13 \u043B\u0435\u0442 \u2014 \u043D\u0435 \u0434\u043B\u044F \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438,
    \u0430 \u0434\u043B\u044F \u0441\u0435\u0431\u044F, \u0447\u0442\u043E\u0431\u044B
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0437\u043D\u0430\u043D\u0438\u044F. \u0412 \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0435
    \u0435\u0433\u043E \u0434\u044F\u0434\u0438 \u0435\u0441\u0442\u044C \u0437\u0430\u043F\u0438\u0441\u044C,
    \u0447\u0442\u043E \u043A 10 \u0433\u043E\u0434\u0430\u043C \u0423\u0438\u043B\u044C\u044F\u043C
    \u043C\u043E\u0433 \u043F\u0440\u043E\u0447\u0435\u0441\u0442\u044C \u0443\u0442\u0440\u0435\u043D\u043D\u044E\u044E
    \u043C\u043E\u043B\u0438\u0442\u0432\u0443 \u043D\u0430 8 \u0440\u0430\u0437\u043D\u044B\u0445
    \u044F\u0437\u044B\u043A\u0430\u0445 \u043F\u043E \u043E\u0447\u0435\u0440\u0435\u0434\u0438.
    \u0418 \u043E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0437\u0443\u0431\u0440\u0438\u043B
    \u2014 \u043E\u043D \u0441\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u043B \u0441\u0435\u043C\u0438\u0442\u0441\u043A\u0438\u0435
    \u043A\u043E\u0440\u043D\u0438 \u0441 \u0438\u043D\u0434\u043E\u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u043C\u0438,
    \u043F\u044B\u0442\u0430\u044F\u0441\u044C \u043D\u0430\u0439\u0442\u0438 \u043E\u0431\u0449\u0438\u0439
    \u043F\u0440\u0430\u044F\u0437\u044B\u043A, \u0442\u043E \u0435\u0441\u0442\u044C
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u043E\u043C\u043F\u0430\u0440\u0430\u0442\u0438\u0432\u0438\u0441\u0442\u0438\u043A\u043E\u0439
    \u043D\u0430 \u043B\u044E\u0431\u0438\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u043C
    \u0443\u0440\u043E\u0432\u043D\u0435 \u0435\u0449\u0451 \u0434\u043E \u0442\u043E\u0433\u043E,
    \u043A\u0430\u043A \u044D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u043E\u0439.  ---  ###
    2. \u2795 \u041F\u0440\u043E\u0438\u0433\u0440\u044B\u0448, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B \u0436\u0438\u0437\u043D\u044C  \u0412
    1818 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430 \u0423\u0438\u043B\u044C\u044F\u043C\u0443
    \u0431\u044B\u043B\u043E 13 \u043B\u0435\u0442, \u0432 \u0414\u0443\u0431\u043B\u0438\u043D
    \u043F\u0440\u0438\u0435\u0445\u0430\u043B \u0441 \u0433\u0430\u0441\u0442\u0440\u043E\u043B\u044F\u043C\u0438
    **\u0417\u0435\u0440\u0430\u0445 \u041A\u043E\u043B\u0431\u0435\u0440\u043D**
    \u2014 \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u0439
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A, \xAB\u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0444\u0435\u043D\u043E\u043C\u0435\u043D\xBB, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432 \u0443\u043C\u0435 \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E
    \u043F\u0435\u0440\u0435\u043C\u043D\u043E\u0436\u0430\u043B \u0448\u0435\u0441\u0442\u0438\u0437\u043D\u0430\u0447\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430.  \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0441\u0430\u043C\u043E\u0443\u0432\u0435\u0440\u0435\u043D\u043D\u044B\u0439
    \u0438 \u043D\u0430\u0447\u0438\u0442\u0430\u043D\u043D\u044B\u0439, \u0432\u044B\u0437\u0432\u0430\u043B
    \u041A\u043E\u043B\u0431\u0435\u0440\u043D\u0430 \u043D\u0430 \u0434\u0443\u044D\u043B\u044C
    \u043F\u043E \u0443\u0441\u0442\u043D\u043E\u043C\u0443 \u0441\u0447\u0435\u0442\u0443.
    \u0418 **\u043F\u0440\u043E\u0438\u0433\u0440\u0430\u043B** \u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0446\u0443.
    \u042D\u0442\u043E \u043F\u043E\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \u0441\u0442\u0430\u043B\u043E
    \u0434\u043B\u044F \u044E\u043D\u043E\u0433\u043E \u0433\u0435\u043D\u0438\u044F
    \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0448\u043E\u043A\u043E\u043C. \u041E\u043D \u043F\u043E\u043D\u044F\u043B,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043D\u0430\u0432\u044B\u043A\u0438 (\u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u044F\u0437\u044B\u043A\u043E\u0432\u044B\u0445) \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u0431\u044B\u0441\u0442\u0440\u044B.   **\u0418\u0442\u043E\u0433:** \u0412
    \u0442\u043E\u0442 \u0436\u0435 \u0432\u0435\u0447\u0435\u0440 \u0423\u0438\u043B\u044C\u044F\u043C
    \u0437\u0430\u0431\u0440\u043E\u0441\u0438\u043B \u0432\u0441\u0435 \u043A\u043D\u0438\u0433\u0438
    \u043F\u043E \u043B\u0438\u043D\u0433\u0432\u0438\u0441\u0442\u0438\u043A\u0435,
    \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B \u0434\u044F\u0434\u044E \u043A\u0443\u043F\u0438\u0442\u044C
    \u0435\u043C\u0443 \xAB\u041D\u0430\u0447\u0430\u043B\u0430\xBB \u0415\u0432\u043A\u043B\u0438\u0434\u0430
    \u0438 \u0441 \u0433\u043E\u043B\u043E\u0432\u043E\u0439 \u0443\u0448\u0435\u043B
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443. \u0422\u0430\u043A
    \u043E\u0434\u0438\u043D \u043F\u0440\u043E\u0438\u0433\u0440\u044B\u0448 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u043C\u0443
    \u0433\u0430\u0441\u0442\u0440\u043E\u043B\u0435\u0440\u0443 \u043F\u043E\u0434\u0430\u0440\u0438\u043B
    \u043C\u0438\u0440\u0443 \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430. 
    ---  ### 3. \u2712\uFE0F \u0421\u0442\u0443\u0434\u0435\u043D\u0442, \u0441\u0442\u0430\u0432\u0448\u0438\u0439
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0434\u043E
    \u0434\u0438\u043F\u043B\u043E\u043C\u0430  \u0412 1827 \u0433\u043E\u0434\u0443
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430 \u043D\u0430\u0437\u043D\u0430\u0447\u0438\u043B\u0438
    **\u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0438
    \u0414\u0443\u0431\u043B\u0438\u043D\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u0438 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u0438\u043C \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C
    \u0418\u0440\u043B\u0430\u043D\u0434\u0438\u0438**. \u0415\u043C\u0443 \u0431\u044B\u043B\u043E
    22 \u0433\u043E\u0434\u0430.   **\u0421\u0435\u043D\u0441\u0430\u0446\u0438\u044F:**
    \u041D\u0430 \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442 \u043E\u043D
    **\u0435\u0449\u0435 \u043D\u0435 \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442** \u0438 \u043D\u0435
    \u0438\u043C\u0435\u043B \u043D\u0438 \u043C\u0430\u0433\u0438\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439,
    \u043D\u0438 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438.
    \u0411\u043E\u043B\u0435\u0435 \u0442\u043E\u0433\u043E, \u043E\u043D \u043D\u0438
    \u0434\u043D\u044F \u043D\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C \u0438 \u043D\u0435
    \u0443\u043C\u0435\u043B \u0442\u043E\u043B\u043A\u043E\u043C \u043E\u0431\u0440\u0430\u0449\u0430\u0442\u044C\u0441\u044F
    \u0441 \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u043E\u043C!   \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0439
    \u0441\u043E\u0432\u0435\u0442 \u043F\u043E\u0448\u0435\u043B \u043D\u0430 \u0431\u0435\u0441\u043F\u0440\u0435\u0446\u0435\u0434\u0435\u043D\u0442\u043D\u044B\u0439
    \u0448\u0430\u0433, \u043D\u0430\u0440\u0443\u0448\u0438\u0432 \u0432\u0441\u0435
    \u0443\u0441\u0442\u0430\u0432\u044B, \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E
    \u0432\u0438\u0434\u0435\u043B\u0438 \u0432 \u043D\u0435\u043C \xAB\u0432\u0442\u043E\u0440\u043E\u0433\u043E
    \u041D\u044C\u044E\u0442\u043E\u043D\u0430\xBB. \u041A\u043E\u043D\u043A\u0443\u0440\u0435\u043D\u0442\u044B
    \u0432\u043E\u0437\u043C\u0443\u0449\u0430\u043B\u0438\u0441\u044C: \xAB\u041C\u0430\u043B\u044C\u0447\u0438\u0448\u043A\u0430
    \u043D\u0435 \u0437\u043D\u0430\u0435\u0442 \u0437\u0432\u0435\u0437\u0434\u043D\u043E\u0433\u043E
    \u043D\u0435\u0431\u0430!\xBB. \u041D\u043E \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0431\u044B\u0441\u0442\u0440\u043E \u0443\u0441\u043F\u043E\u043A\u043E\u0438\u043B
    \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432... \u0434\u043E\u043A\u0430\u0437\u0430\u0432
    \u0441\u0432\u043E\u044E \u043F\u0440\u0430\u0432\u043E\u0442\u0443 \u0443\u0436\u0435
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043E\u043F\u0442\u0438\u043A\u0438,
    \u0430 \u043D\u0435 \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u0439
    \u0437\u0430 \u0437\u0432\u0435\u0437\u0434\u0430\u043C\u0438.  ---  ### 4. \U0001F9CA
    \u041A\u0430\u043A \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435... \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0441\u043A\u0430\u043D\u0434\u0430\u043B\u0430  \u0418\u0441\u0442\u043E\u0440\u0438\u044F
    \u0441 **\u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0440\u0435\u0444\u0440\u0430\u043A\u0446\u0438\u0435\u0439**
    (1832) \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0439
    \u0431\u044B\u0442\u043E\u0432\u043E\u0439 \u044D\u043F\u0438\u0437\u043E\u0434.
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \u043B\u0443\u0447 \u0441\u0432\u0435\u0442\u0430 \u0432 \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u0435
    \u0430\u0440\u0430\u0433\u043E\u043D\u0438\u0442\u0430 \u0440\u0430\u0441\u043F\u0430\u0434\u0451\u0442\u0441\u044F
    \u043D\u0430 \u043A\u043E\u043D\u0443\u0441. \u0415\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0430
    \u0425\u0430\u043C\u0444\u0440\u0438 \u041B\u043B\u043E\u0439\u0434 \u0440\u0435\u0448\u0438\u043B
    \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C \u044D\u0442\u043E \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E. 
    \u041D\u043E \u0432\u0441\u0435 \u0431\u044B\u043B\u043E \u043D\u0435 \u0442\u0430\u043A
    \u043F\u0440\u043E\u0441\u0442\u043E: \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B
    \u0431\u044B\u043B \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439 \u0438
    \u043C\u0443\u0442\u043D\u044B\u0439. \u041B\u043B\u043E\u0439\u0434 \u043C\u0443\u0447\u0438\u043B\u0441\u044F
    \u043D\u0435\u0434\u0435\u043B\u044E, \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435
    \u0432\u0438\u0434\u0435\u043B. \u0418 \u0442\u0443\u0442 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0432 \u043F\u0438\u0441\u044C\u043C\u0435 \u043A \u041B\u043B\u043E\u0439\u0434\u0443
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B: *\xAB\u0412\u043E\u0437\u044C\u043C\u0438\u0442\u0435
    \u043A\u0443\u0441\u043E\u043A \u0430\u0440\u0430\u0433\u043E\u043D\u0438\u0442\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u0430\u043B\u044F\u0435\u0442\u0441\u044F
    \u0443 \u0412\u0430\u0441 \u043D\u0430 \u043A\u0430\u043C\u0438\u043D\u0435 \u0438
    \u0441\u043B\u0443\u0436\u0438\u0442 \u043F\u0440\u0435\u0441\u0441-\u043F\u0430\u043F\u044C\u0435.
    \u0418 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435 \u0435\u0433\u043E \u043D\u0435
    \u043D\u0430\u0431\u043E\u043A, \u0430 \u0442\u0430\u043A, \u043A\u0430\u043A
    \u043E\u043D \u043B\u0435\u0436\u0438\u0442 \u0443 \u0412\u0430\u0441 \u2014
    \u043F\u043E \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u0438\xBB*.   \u041B\u043B\u043E\u0439\u0434
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B \u044D\u0442\u043E\u043C\u0443
    \u0441\u043E\u0432\u0435\u0442\u0443 \u2014 \u0438 **\u0442\u0443\u0442 \u0436\u0435
    \u0443\u0432\u0438\u0434\u0435\u043B \u043A\u043E\u043D\u0443\u0441 \u0441\u0432\u0435\u0442\u0430**.
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u043F\u0440\u043E\u0441\u0442\u043E
    \u0437\u0430\u043F\u043E\u043C\u043D\u0438\u043B, \u043A\u0430\u043A \u0438\u043C\u0435\u043D\u043D\u043E
    \u0442\u043E\u0442 \u043F\u043E\u043B\u043E\u0436\u0438\u043B \u043C\u0438\u043D\u0435\u0440\u0430\u043B
    \u043D\u0430 \u0441\u0442\u043E\u043B\u0435 \u043C\u0435\u0441\u044F\u0446 \u043D\u0430\u0437\u0430\u0434!
    \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u0431\u044B\u043B\u043E \u0441\u0434\u0435\u043B\u0430\u043D\u043E
    \u043D\u0435 \u0437\u0430 \u0441\u0447\u0435\u0442 \u0441\u043B\u043E\u0436\u043D\u043E\u0439
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u0443\u0440\u044B, \u0430 \u0437\u0430
    \u0441\u0447\u0435\u0442 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0438 \u0438 \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u043A \u0431\u044B\u0442\u043E\u0432\u044B\u043C \u043C\u0435\u043B\u043E\u0447\u0430\u043C. 
    ---  ### 5. \U0001FAA8 \u0421\u0430\u043C\u044B\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043A\u0430\u043C\u0435\u043D\u044C \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 
    16 \u043E\u043A\u0442\u044F\u0431\u0440\u044F 1843 \u0433\u043E\u0434\u0430 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0448\u0435\u043B \u0441 \u0436\u0435\u043D\u043E\u0439 \u0425\u0435\u043B\u0435\u043D
    \u0432\u0434\u043E\u043B\u044C \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043A\u0430\u043D\u0430\u043B\u0430 \u0432 \u0414\u0443\u0431\u043B\u0438\u043D\u0435.
    \u0412\u043D\u0435\u0437\u0430\u043F\u043D\u043E \u0435\u0433\u043E \u043E\u0441\u0435\u043D\u0438\u043B\u0430
    \u0438\u0434\u0435\u044F \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u043E\u0432.  
    **\u0424\u0430\u043A\u0442:** \u0411\u043E\u044F\u0441\u044C \u0437\u0430\u0431\u044B\u0442\u044C
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443, \u043E\u043D **\u0432\u044B\u0440\u0435\u0437\u0430\u043B
    \u043D\u043E\u0436\u043E\u043C \u043D\u0430 \u043A\u0430\u043C\u043D\u0435 \u043C\u043E\u0441\u0442\u0430
    \u0411\u0440\u0443\u043C-\u0411\u0440\u0438\u0434\u0436** (Brougham Bridge) \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u0442\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u043E:  `i\xB2 = j\xB2 = k\xB2
    = ijk = -1`.   \u0421\u0435\u0433\u043E\u0434\u043D\u044F \u043D\u0430 \u044D\u0442\u043E\u043C
    \u043C\u043E\u0441\u0442\u0443 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0430
    \u043C\u0435\u043C\u043E\u0440\u0438\u0430\u043B\u044C\u043D\u0430\u044F \u0442\u0430\u0431\u043B\u0438\u0447\u043A\u0430.
    \u041D\u043E \u0435\u0441\u0442\u044C \u043D\u044E\u0430\u043D\u0441: \u0441\u0430\u043C
    \u043C\u043E\u0441\u0442 \u0431\u044B\u043B \u043F\u0435\u0440\u0435\u0441\u0442\u0440\u043E\u0435\u043D
    \u0432 1950-\u0445 \u0433\u043E\u0434\u0430\u0445. \u041A\u0430\u043C\u0435\u043D\u044C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u044B \u0432\u0438\u0434\u0435\u043B\u0438
    \u043D\u0430 \u0441\u0442\u0430\u0440\u044B\u0445 \u0444\u043E\u0442\u043E, \u0431\u044B\u043B
    \u0437\u0430\u043C\u0435\u043D\u0435\u043D. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0434\u0443\u0431\u043B\u0438\u043D\u0446\u044B \u0441\u0432\u044F\u0442\u043E
    \u0447\u0442\u044F\u0442 \u043C\u0435\u0441\u0442\u043E: \u0435\u0436\u0435\u0433\u043E\u0434\u043D\u043E
    16 \u043E\u043A\u0442\u044F\u0431\u0440\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0441\u043E \u0432\u0441\u0435\u0433\u043E \u043C\u0438\u0440\u0430 \u0443\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u044E\u0442
    \xAB\u041F\u0435\u0448\u0438\u0439 \u043C\u0430\u0440\u0448 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430\xBB
    (Hamilton Walk) \u0438\u043C\u0435\u043D\u043D\u043E \u043F\u043E \u044D\u0442\u043E\u0439
    \u043D\u0430\u0431\u0435\u0440\u0435\u0436\u043D\u043E\u0439. \u0410 \u0441\u0430\u043C
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u0442\u0430\u043A \u0433\u043E\u0440\u0434\u0438\u043B\u0441\u044F
    \u044D\u0442\u0438\u043C \u0441\u043E\u0431\u044B\u0442\u0438\u0435\u043C, \u0447\u0442\u043E
    \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0436\u0438\u0437\u043D\u0438 \u043E\u0442\u043C\u0435\u0447\u0430\u043B
    \u0433\u043E\u0434\u043E\u0432\u0449\u0438\u043D\u0443 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F,
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u044F \u0432 \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0435:
    \xAB\u0412 \u044D\u0442\u043E\u0442 \u0434\u0435\u043D\u044C \u043A\u043E \u043C\u043D\u0435
    \u043F\u0440\u0438\u0448\u043B\u0438 \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u044B\xBB. 
    ---  ### 6. \U0001F99F \u0412\u043E\u0439\u043D\u0430 \u0441 \u043C\u0443\u0445\u0430\u043C\u0438
    \u0438 \u0448\u0443\u043C\u043D\u044B\u0435 \u0441\u043E\u0441\u0435\u0434\u0438 
    \u0411\u0440\u0430\u043A \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0430
    \u0441 \u0425\u0435\u043B\u0435\u043D \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0435\u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C, \u0447\u0442\u043E
    \u0441\u0441\u043E\u0440\u044B \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u043B\u0438
    \u0434\u0430\u0436\u0435 \u0438\u0437-\u0437\u0430... \u043C\u0443\u0445. \u0412
    \u0414\u0430\u043D\u0441\u0438\u043D\u043A\u0441\u043A\u043E\u0439 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438
    \u0431\u044B\u043B\u043E \u0441\u044B\u0440\u043E \u0438 \u043C\u043D\u043E\u0433\u043E
    \u043D\u0430\u0441\u0435\u043A\u043E\u043C\u044B\u0445. \u0425\u0435\u043B\u0435\u043D
    \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u0430, \u0447\u0442\u043E\u0431\u044B
    \u043C\u0443\u0436 \u043A\u0443\u043F\u0438\u043B \u043C\u043E\u0441\u043A\u0438\u0442\u043D\u044B\u0435
    \u0441\u0435\u0442\u043A\u0438 \u043D\u0430 \u043E\u043A\u043D\u0430.  \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u043F\u043E\u0433\u0440\u0443\u0436\u0435\u043D\u043D\u044B\u0439 \u0432 \u0440\u0430\u0441\u0447\u0435\u0442\u044B
    \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u043E\u0432, \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E
    \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F, \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044F,
    \u0447\u0442\u043E **\xAB\u0436\u0443\u0436\u0436\u0430\u043D\u0438\u0435 \u043C\u0443\u0445
    \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442 \u0435\u043C\u0443 \u0430\u0431\u0441\u0442\u0440\u0430\u0433\u0438\u0440\u043E\u0432\u0430\u0442\u044C\u0441\u044F
    \u043E\u0442 \u0431\u044B\u0442\u0430\xBB**. \u0425\u0435\u043B\u0435\u043D \u0432
    \u043E\u0442\u0432\u0435\u0442 \u043A\u0440\u0438\u0447\u0430\u043B\u0430, \u0447\u0442\u043E
    \u043E\u043D \u0431\u0435\u0437\u0443\u043C\u0435\u0446, \u0438 \u0443\u0435\u0437\u0436\u0430\u043B\u0430
    \u043A \u0440\u043E\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0430\u043C.  
    \u0414\u0440\u0443\u0433\u043E\u0439 \u0444\u0430\u043A\u0442: \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0441\u043B\u0430\u0432\u0438\u043B\u0441\u044F \u0442\u0435\u043C, \u0447\u0442\u043E
    \u0432 \u043E\u0431\u0441\u0435\u0440\u0432\u0430\u0442\u043E\u0440\u0438\u0438
    \u0438\u0433\u0440\u0430\u043B \u043D\u0430 \u0444\u043E\u0440\u0442\u0435\u043F\u0438\u0430\u043D\u043E
    \u0432 3-4 \u0447\u0430\u0441\u0430 \u043D\u043E\u0447\u0438, \u0441\u043E\u0447\u0438\u043D\u044F\u044F
    \u043C\u0443\u0437\u044B\u043A\u0443 (\u043E\u043D \u0431\u044B\u043B \u043D\u0435\u043F\u043B\u043E\u0445\u0438\u043C
    \u043F\u0438\u0430\u043D\u0438\u0441\u0442\u043E\u043C). \u0421\u043E\u0441\u0435\u0434\u0438
    (\u043A\u0440\u0435\u0441\u0442\u044C\u044F\u043D\u0435 \u0438\u0437 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u0439
    \u0434\u0435\u0440\u0435\u0432\u043D\u0438) \u0436\u0430\u043B\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442, \u0447\u0442\u043E
    \xAB\u0437\u0432\u0435\u0437\u0434\u043E\u0447\u0435\u0442 \u043D\u0435 \u0434\u0430\u0435\u0442
    \u0441\u043F\u0430\u0442\u044C \u043B\u044E\u0434\u044F\u043C\xBB, \u043D\u043E
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u0438\u0433\u043D\u043E\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u044B, \u0433\u043E\u0432\u043E\u0440\u044F,
    \u0447\u0442\u043E \u043C\u0443\u0437\u044B\u043A\u0430 \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442
    \u0435\u043C\u0443 \u043F\u043E\u043D\u044F\u0442\u044C \xAB\u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u044E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439\xBB.  ---  ### 7. \U0001F340
    \u041F\u043E\u044D\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0437\u0430\u0431\u044B\u0432\u0430\u043B
    \u0441\u0442\u0438\u0445\u0438  \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C \u0441\u0447\u0438\u0442\u0430\u043B
    \u0441\u0435\u0431\u044F \u043F\u043E\u044D\u0442\u043E\u043C \u0432 \u0434\u0443\u0448\u0435.
    \u0412 \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438 \u043E\u043D \u0434\u0430\u0436\u0435
    \u0432\u0440\u0430\u0449\u0430\u043B\u0441\u044F \u0432 \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u044B\u0445
    \u043A\u0440\u0443\u0433\u0430\u0445 \u0414\u0443\u0431\u043B\u0438\u043D\u0430
    \u0438 \u0434\u0440\u0443\u0436\u0438\u043B \u0441 \u043F\u043E\u044D\u0442\u043E\u043C
    \u0423\u0438\u043B\u044C\u044F\u043C\u043E\u043C \u0412\u043E\u0440\u0434\u0441\u0432\u043E\u0440\u0442\u043E\u043C
    (\u043A\u0441\u0442\u0430\u0442\u0438, \u0412\u043E\u0440\u0434\u0441\u0432\u043E\u0440\u0442
    \u043E\u0442\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u043B \u0435\u0433\u043E
    \u043E\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0433\u043E\u0432\u043E\u0440\u044F,
    \u0447\u0442\u043E \u044D\u0442\u043E \xAB\u0441\u0443\u0448\u0438\u0442 \u0434\u0443\u0448\u0443\xBB).  
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u0438\u0437\u0434\u0430\u043B
    \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u0441\u0431\u043E\u0440\u043D\u0438\u043A
    \u0441\u0442\u0438\u0445\u043E\u0432. \u041D\u043E \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442: \u0435\u0433\u043E \u0441\u0442\u0438\u0445\u0438 \u0431\u044B\u043B\u0438
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0441\u043B\u043E\u0436\u043D\u044B\u043C\u0438
    \u0438 \u043F\u0435\u0440\u0435\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u044B\u043C\u0438
    \u0430\u043B\u043B\u0435\u0433\u043E\u0440\u0438\u044F\u043C\u0438 \u0438\u0437
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0439 \u043C\u0438\u0444\u043E\u043B\u043E\u0433\u0438\u0438,
    \u0447\u0442\u043E \u043D\u0438\u043A\u0442\u043E \u0438\u0437 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0441\u0430\u043C\u043E\u0433\u043E
    \u043F\u043E\u044D\u0442\u0430, \u043D\u0435 \u043C\u043E\u0433 \u0437\u0430\u043F\u043E\u043C\u043D\u0438\u0442\u044C
    \u0438\u0445 \u043D\u0430\u0438\u0437\u0443\u0441\u0442\u044C. \u041D\u0430 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u044B\u0445
    \u0447\u0442\u0435\u043D\u0438\u044F\u0445 \u043E\u043D **\u043F\u0443\u0442\u0430\u043B
    \u0441\u0442\u0440\u043E\u0444\u044B** \u0438 \u0447\u0438\u0442\u0430\u043B
    \u043E\u0434\u043D\u043E \u0441\u0442\u0438\u0445\u043E\u0442\u0432\u043E\u0440\u0435\u043D\u0438\u0435,
    \u0430 \u0432\u044B\u0445\u043E\u0434\u0438\u043B\u043E \u0434\u0440\u0443\u0433\u043E\u0435.
    \u0414\u0440\u0443\u0437\u044C\u044F \u0448\u0443\u0442\u0438\u043B\u0438, \u0447\u0442\u043E
    \u0435\u0433\u043E \u043F\u0430\u043C\u044F\u0442\u044C, \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E
    \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u044E\u0449\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u044B\u043A\u043B\u0430\u0434\u043A\u0438, \xAB\u0431\u043B\u043E\u043A\u0438\u0440\u0443\u0435\u0442\xBB
    \u0445\u0443\u0434\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0442\u0435\u043A\u0441\u0442\u044B.  ---  ### 8. \U0001F377 \u041F\u044C\u044F\u043D\u044B\u0439
    \u0433\u0435\u043D\u0438\u0439 \u0438 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438  \u041A \u043A\u043E\u043D\u0446\u0443
    \u0436\u0438\u0437\u043D\u0438 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0441\u0438\u043B\u044C\u043D\u043E \u043F\u0438\u043B. \u0421\u043E\u0441\u0435\u0434\u0438
    \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u0432\u0438\u0434\u0435\u043B\u0438
    \u0435\u0433\u043E \u0447\u0430\u0441\u0442\u043E \u0448\u0430\u0442\u0430\u044E\u0449\u0438\u043C\u0441\u044F.  
    **\u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441:** \u041F\u0440\u043E\u0432\u0435\u0434\u044F
    \u043D\u043E\u0447\u044C \u0437\u0430 \u043E\u0431\u0438\u043B\u044C\u043D\u044B\u043C
    \u0432\u043E\u0437\u043B\u0438\u044F\u043D\u0438\u0435\u043C \u0432\u0438\u0441\u043A\u0438,
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u043C\u043E\u0433 \u0441\u0435\u0441\u0442\u044C
    \u0443\u0442\u0440\u043E\u043C \u0441 \u0434\u0438\u043A\u043E\u0439 \u0433\u043E\u043B\u043E\u0432\u043D\u043E\u0439
    \u0431\u043E\u043B\u044C\u044E \u0438 **\u043F\u0438\u0441\u0430\u0442\u044C
    \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0441 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E**, \u043D\u0435 \u0434\u0435\u043B\u0430\u044F
    \u043E\u0448\u0438\u0431\u043E\u043A \u0432 \u0437\u043D\u0430\u043A\u0430\u0445
    (\u0430 \u0442\u0430\u043C, \u043D\u0430\u043F\u043E\u043C\u043D\u044E, \u043F\u043E\u0440\u044F\u0434\u043E\u043A
    \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u044F \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u043D:
    `i*j = k`, \u0430 `j*i = -k`).   \u0415\u0433\u043E \u043A\u043E\u043B\u043B\u0435\u0433\u0438
    \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u043B\u0438 \u0447\u0435\u0440\u043D\u043E\u0432\u0438\u043A\u0438
    \u0438 \u0443\u0434\u0438\u0432\u043B\u044F\u043B\u0438\u0441\u044C: \xAB\u042D\u0442\u043E
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043D\u0435 \u043C\u043E\u0433 \u043F\u043E\u043F\u0430\u0441\u0442\u044C
    \u043A\u043B\u044E\u0447\u043E\u043C \u0432 \u0437\u0430\u043C\u043E\u0447\u043D\u0443\u044E
    \u0441\u043A\u0432\u0430\u0436\u0438\u043D\u0443\xBB. \u0422\u0440\u0435\u0437\u0432\u044B\u043C
    \u0436\u0435 \u043E\u043D \u043F\u0438\u0441\u0430\u043B \u043C\u0435\u0434\u043B\u0435\u043D\u043D\u0435\u0435,
    \u043C\u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u0432\u044B\u0432\u0435\u0440\u044F\u044F
    \u043A\u0430\u0436\u0434\u0443\u044E \u0441\u0442\u0440\u043E\u0447\u043A\u0443.
    \u0410\u043B\u043A\u043E\u0433\u043E\u043B\u044C, \u043F\u043E\u0445\u043E\u0436\u0435,
    \u0441\u043D\u0438\u043C\u0430\u043B \u0443 \u043D\u0435\u0433\u043E \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0435
    \u0442\u043E\u0440\u043C\u043E\u0437\u0430 \u0438 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B
    \u043C\u043E\u0437\u0433\u0443 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u043D\u0430 \u043F\u043E\u043B\u043D\u044B\u0445 \u043E\u0431\u043E\u0440\u043E\u0442\u0430\u0445. 
    ---  ### 9. \U0001F4EE \u041F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0438\u0441\u044C\u043C\u043E \u043E \u0431\u0443\u0434\u0443\u0449\u0435\u043C 
    \u0412 1846 \u0433\u043E\u0434\u0443 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043F\u0438\u0441\u044C\u043C\u043E
    \u0441\u0432\u043E\u0435\u043C\u0443 \u0434\u0440\u0443\u0433\u0443 \u0410\u0432\u0433\u0443\u0441\u0442\u0443\u0441\u0443
    \u0434\u0435 \u041C\u043E\u0440\u0433\u0430\u043D\u0443 (\u0435\u0449\u0435 \u043E\u0434\u043D\u043E\u043C\u0443
    \u0432\u0435\u043B\u0438\u043A\u043E\u043C\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443).
    \u0412 \u043D\u0435\u043C \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u044B
    \"\u0432\u0441\u043A\u043E\u0440\u0435 \u0441\u0442\u0430\u043D\u0443\u0442 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0430\u043D\u0430\u043B\u0438\u0437\u0430
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\". 
    \u041D\u043E \u0441\u0430\u043C\u043E\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E\u0435:
    \u043E\u043D \u043F\u0438\u0441\u0430\u043B, \u0447\u0442\u043E **\xAB\u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u043C
    \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C \u043A\u0432\u0430\u0442\u0435\u0440\u043D\u0438\u043E\u043D\u043E\u0432
    \u0431\u0443\u0434\u0435\u0442 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F \u0441\u0444\u0435\u0440\u044B
    \u0432\u043D\u0443\u0442\u0440\u0438 \u0441\u0444\u0435\u0440\u044B\xBB**. \u0427\u0435\u0440\u0435\u0437
    100 \u043B\u0435\u0442 \u044D\u0442\u043E \u043E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C
    \u0442\u043E\u0447\u043D\u044B\u043C \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435\u043C
    \u0440\u0430\u0431\u043E\u0442\u044B \u0433\u0438\u0440\u043E\u0441\u043A\u043E\u043F\u043E\u0432
    \u0438 \u0441\u0438\u0441\u0442\u0435\u043C \u043E\u0440\u0438\u0435\u043D\u0442\u0430\u0446\u0438\u0438
    \u043A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043A\u043E\u0440\u0430\u0431\u043B\u0435\u0439!
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D \u043D\u0435 \u043C\u043E\u0433
    \u0437\u043D\u0430\u0442\u044C \u043F\u0440\u043E \u043A\u043E\u0441\u043C\u043E\u043D\u0430\u0432\u0442\u0438\u043A\u0443,
    \u043D\u043E \u0447\u0438\u0441\u0442\u043E \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u043E
    \xAB\u0443\u0432\u0438\u0434\u0435\u043B\xBB \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443
    \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u044F \u0432 \u0442\u0440\u0435\u0445\u043C\u0435\u0440\u043D\u043E\u043C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435.  --- 
    ### 10. \U0001F4C9 \u041F\u043E\u0445\u043E\u0440\u043E\u043D\u043D\u0430\u044F
    \u0438\u0440\u043E\u043D\u0438\u044F  \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0443\u043C\u0435\u0440 2 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F 1865
    \u0433\u043E\u0434\u0430. \u041D\u0430 \u0435\u0433\u043E \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u044B
    \u0432 \u0414\u0443\u0431\u043B\u0438\u043D\u0435 \u043F\u0440\u0438\u0448\u043B\u043E
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u043E\u0442\u0435\u043D
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u043C\u044D\u0440\u0430 \u0438 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u0432.  
    \u0418\u0440\u043E\u043D\u0438\u044F \u0444\u0430\u043A\u0442\u0430: \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u0431\u044B\u043B \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u0438\u043C
    \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u043E\u043C \u0418\u0440\u043B\u0430\u043D\u0434\u0438\u0438
    38 \u043B\u0435\u0442, \u043D\u043E \u0437\u0430 \u0432\u0441\u044E \u0441\u0432\u043E\u044E
    \u043A\u0430\u0440\u044C\u0435\u0440\u0443 **\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u043B\u0438\u0448\u044C 3 \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F** (\u0438 \u0442\u0435
    \u0431\u044B\u043B\u0438 \u043D\u0435 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0442\u043E\u0447\u043D\u044B). \u0415\u0433\u043E \u043F\u043E\u0445\u0432\u0430\u043B\u0438\u043B\u0438
    \u043D\u0430 \u043F\u0430\u043D\u0438\u0445\u0438\u0434\u0435 \u043A\u0430\u043A
    \xAB\u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0435\u0433\u043E \u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0430\xBB,
    \u0445\u043E\u0442\u044F \u0432\u0441\u0435 \u0437\u043D\u0430\u043B\u0438, \u0447\u0442\u043E
    \u043E\u043D \u043D\u0435 \u0441\u043C\u043E\u0442\u0440\u0435\u043B \u0432 \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F
    \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F\u043C\u0438.
    \u0415\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \u0446\u0435\u043B\u0438\u043A\u043E\u043C \u0431\u044B\u043B\u0430 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439.
    \u041D\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442
    \u043D\u0435 \u0445\u043E\u0442\u0435\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u0442\u044C,
    \u0447\u0442\u043E 38 \u043B\u0435\u0442 \u043F\u043B\u0430\u0442\u0438\u043B
    \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u0438\u0435 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0443,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439,
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u0432 \u043D\u0435\u043A\u0440\u043E\u043B\u043E\u0433\u0430\u0445
    \xAB\u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u044E\xBB \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043B\u0438
    \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E.  ---  ###
    11. \U0001F4AC \u0423\u0431\u0438\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u0444\u0440\u0430\u0437\u0430 \u043E \u0436\u0435\u043D\u0435  \u0412 \u043E\u0434\u043D\u043E\u043C
    \u0438\u0437 \u043F\u0438\u0441\u0435\u043C \u043A \u0441\u0432\u043E\u0435\u043C\u0443
