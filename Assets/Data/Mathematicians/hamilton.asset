  achievementsRu: "\u0423\u0438\u043B\u044C\u044F\u043C \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    (\u0430\u043D\u0433\u043B. William Hamilton) \u043C\u043E\u0436\u0435\u0442 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u044C\u0441\u044F
    \u043A \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u043C \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B\u0438\u044F\u043C:\n(\u0432
    \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043F\u043E\u0440\u044F\u0434\u043A\u0435) \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C, 2-\u0439 \u0433\u0435\u0440\u0446\u043E\u0433
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D (1616\u20141651) \u2014
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C \u0428\u043E\u0442\u043B\u0430\u043D\u0434\u0438\u0438.
    \u0423\u0438\u043B\u044C\u044F\u043C \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    (1665? \u2014 1751) \u2014 \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439
    \u043F\u043E\u044D\u0442-\u0441\u0430\u0442\u0438\u0440\u0438\u043A. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C (1704\u20141754) \u2014 \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439
    \u043F\u043E\u044D\u0442-\u044F\u043A\u043E\u0431\u0438\u0442. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C (1730\u20141803) \u2014 \u0431\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u0438\u0439
    \u0434\u0438\u043F\u043B\u043E\u043C\u0430\u0442 \u0438 \u0430\u043D\u0442\u0438\u043A\u0432\u0430\u0440,
    \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C \u0438\u0437\u044F\u0449\u043D\u044B\u0445
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C (1751\u20141801) \u2014 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u0439
    \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A."
  achievementsEn: 
  personalLifeRu: "\u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D, \u0423\u0438\u043B\u044C\u044F\u043C
    (1783\u20141856) \u2014 \u0438\u0440\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439
    \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u043E\u0438\u0441\u043F\u044B\u0442\u0430\u0442\u0435\u043B\u044C,
    \u0432\u0440\u0430\u0447 \u0438 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A.
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D, \u0423\u0438\u043B\u044C\u044F\u043C
    (1788\u20141856) \u2014 \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C \u0420\u043E\u0443\u044D\u043D (1805\u20141865)
    \u2014 \u0438\u0440\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A.
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D, \u0423\u0438\u043B\u044C\u044F\u043C,
    11-\u0439 \u0433\u0435\u0440\u0446\u043E\u0433 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    (1811\u20141863) \u2014 \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439
    \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442 \u0438 \u043F\u0435\u0440\u0432\u044B\u0439
    \u043F\u044D\u0440 \u0428\u043E\u0442\u043B\u0430\u043D\u0434\u0438\u0438. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C, 12-\u0439 \u0433\u0435\u0440\u0446\u043E\u0433
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D (1845\u20141895) \u2014
    \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439 \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442.
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D, \u0423\u0438\u043B\u044C\u044F\u043C
    (1899\u20141978)\u2014 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u044C
    \u0433\u0438\u0434\u0440\u043E\u0446\u0438\u043A\u043B\u0430. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C \u0414\u043E\u043D\u0430\u043B\u044C\u0434
    (1936\u20142000) \u2014 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u0439
    \u044D\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u0439 \u0431\u0438\u043E\u043B\u043E\u0433."
  personalLifeEn: 
  shortBioRu: "\u0423\u0438\u043B\u044C\u044F\u043C \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    \u043C\u043E\u0436\u0435\u0442 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u044C\u0441\u044F
    \u043A \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u043C \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B\u0438\u044F\u043C:(\u0432
    \u0445\u0440\u043E\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u043F\u043E\u0440\u044F\u0434\u043A\u0435)\u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C, 2-\u0439 \u0433\u0435\u0440\u0446\u043E\u0433
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D (1616\u20141651)_\u2014
    \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C \u0428\u043E\u0442\u043B\u0430\u043D\u0434\u0438\u0438.
    \u0423\u0438\u043B\u044C\u044F\u043C \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D_\u2014
    \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439 \u043F\u043E\u044D\u0442-\u0441\u0430\u0442\u0438\u0440\u0438\u043A.
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D, \u0423\u0438\u043B\u044C\u044F\u043C
    (1704\u20141754)_\u2014 \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439
    \u043F\u043E\u044D\u0442-\u044F\u043A\u043E\u0431\u0438\u0442. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C (1730\u20141803)_\u2014 \u0431\u0440\u0438\u0442\u0430\u043D\u0441\u043A\u0438\u0439
    \u0434\u0438\u043F\u043B\u043E\u043C\u0430\u0442 \u0438 \u0430\u043D\u0442\u0438\u043A\u0432\u0430\u0440,
    \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C \u0438\u0437\u044F\u0449\u043D\u044B\u0445
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C (1751\u20141801)_\u2014 \u0430\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u0439
    \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C (1783\u20141856) \u2014 \u0438\u0440\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439
    \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u043E\u0438\u0441\u043F\u044B\u0442\u0430\u0442\u0435\u043B\u044C,
    \u0432\u0440\u0430\u0447 \u0438 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A.
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D, \u0423\u0438\u043B\u044C\u044F\u043C
    (1788\u20141856)_\u2014 \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C \u0420\u043E\u0443\u044D\u043D (1805\u20141865)_\u2014
    \u0438\u0440\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A.
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D, \u0423\u0438\u043B\u044C\u044F\u043C,
    11-\u0439 \u0433\u0435\u0440\u0446\u043E\u0433 \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D
    (1811\u20141863) \u2014 \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439
    \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442 \u0438 \u043F\u0435\u0440\u0432\u044B\u0439
    \u043F\u044D\u0440 \u0428\u043E\u0442\u043B\u0430\u043D\u0434\u0438\u0438. \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D,
    \u0423\u0438\u043B\u044C\u044F\u043C, 12-\u0439 \u0433\u0435\u0440\u0446\u043E\u0433
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D (1845\u20141895) \u2014
    \u0448\u043E\u0442\u043B\u0430\u043D\u0434\u0441\u043A\u0438\u0439 \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442.
    \u0413\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D, \u0423\u0438\u043B\u044C\u044F\u043C
    (1899\u20141978)\u2014 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u044C
