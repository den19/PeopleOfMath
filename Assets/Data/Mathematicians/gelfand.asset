  achievementsRu: "\u0418\u0437\u0440\u0430\u0438\u043B\u044C \u041C\u043E\u0438\u0441\u0435\u0435\u0432\u0438\u0447
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0431\u044B\u043B \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C,
    \u0430 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C, \u0447\u044C\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u043E \u043E\u0431\u043B\u0438\u043A
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043D\u0430\u0443\u043A\u0438.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u043F\u0440\u043E\u0441\u0442\u0438\u0440\u0430\u0435\u0442\u0441\u044F
    \u043E\u0442 \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0434\u043E \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u044B, \u0438 \u0435\u0433\u043E \u0438\u043C\u044F
    \u0443\u0432\u0435\u043A\u043E\u0432\u0435\u0447\u0435\u043D\u043E \u0432 \u0434\u0435\u0441\u044F\u0442\u043A\u0430\u0445
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0442\u0435\u043E\u0440\u0435\u043C \u0438 \u043F\u043E\u043D\u044F\u0442\u0438\u0439. 
    \u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439 \u043E\u0431\u0437\u043E\u0440
    \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439
    \u0438 \u0432\u043A\u043B\u0430\u0434\u0430 \u0432 \u043D\u0430\u0443\u043A\u0443: 
    ### \U0001F9EC \u0413\u043B\u0443\u0431\u0438\u043D\u043D\u0430\u044F \u043E\u0441\u043D\u043E\u0432\u0430:
    \u0424\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437  \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434
    \u043D\u0430\u0447\u0430\u043B \u0441\u0432\u043E\u044E \u043A\u0430\u0440\u044C\u0435\u0440\u0443
    \u0441 \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u0438\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u2014 \u0440\u0430\u0437\u0434\u0435\u043B\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0438\u0437\u0443\u0447\u0430\u044E\u0449\u0435\u0433\u043E
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C\u0435\u0440\u043D\u044B\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430. \u0415\u0433\u043E
    \u0440\u0430\u043D\u043D\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u044B \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0434\u043B\u044F \u0446\u0435\u043B\u044B\u0445
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439 \u044D\u0442\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438.  *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0431\u0430\u043D\u0430\u0445\u043E\u0432\u044B\u0445
    \u0430\u043B\u0433\u0435\u0431\u0440 (\u043D\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u043A\u043E\u043B\u0435\u0446):** \u042D\u0442\u043E \u0431\u044B\u043B \u0435\u0433\u043E
    \u043F\u0435\u0440\u0432\u044B\u0439 \u043A\u0440\u0443\u043F\u043D\u044B\u0439
    \u043F\u0440\u043E\u0440\u044B\u0432 \u0432 \u043A\u043E\u043D\u0446\u0435 1930-\u0445
    \u2014 \u043D\u0430\u0447\u0430\u043B\u0435 1940-\u0445 \u0433\u043E\u0434\u043E\u0432.
    \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u0442\u0440\u043E\u0439\u043D\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u044B\u0445
    \u0431\u0430\u043D\u0430\u0445\u043E\u0432\u044B\u0445 \u0430\u043B\u0433\u0435\u0431\u0440,
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u0443\u044E \u0432\u043E\u043A\u0440\u0443\u0433
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438 **\u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u0434\u0435\u0430\u043B\u043E\u0432**. \u042D\u0442\u043E\u0442 \u043F\u043E\u0434\u0445\u043E\u0434
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0443\u043F\u0440\u043E\u0441\u0442\u0438\u0442\u044C \u0438 \u043E\u0431\u043E\u0431\u0449\u0438\u0442\u044C
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0442\u0435\u043E\u0440\u0438\u044E
    \u0412\u0438\u043D\u0435\u0440\u0430, \u043D\u043E \u0438 \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u0443 \u0434\u043B\u044F **\u0433\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F**
    \u2014 \u043C\u043E\u0449\u043D\u043E\u0433\u043E \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0432\u044F\u0437\u0430\u043B
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0435 \u0430\u043B\u0433\u0435\u0431\u0440\u044B
    \u0441 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430\u043C\u0438
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439.
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043E
    \u043F\u0435\u0440\u0432\u044B\u043C \u0442\u0440\u0438\u0443\u043C\u0444\u043E\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    C*-\u0430\u043B\u0433\u0435\u0431\u0440:** \u0412\u043C\u0435\u0441\u0442\u0435
    \u0441\u043E \u0441\u0432\u043E\u0438\u043C \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C
    \u041C.\u0410. \u041D\u0430\u0439\u043C\u0430\u0440\u043A\u043E\u043C \u043E\u043D
    \u0441\u0434\u0435\u043B\u0430\u043B \u0440\u0435\u0448\u0430\u044E\u0449\u0438\u0439
    \u0448\u0430\u0433 \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u0442\u0435\u043E\u0440\u0438\u0438
    C*-\u0430\u043B\u0433\u0435\u0431\u0440, \u0434\u043E\u043A\u0430\u0437\u0430\u0432
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E **\u0442\u0435\u043E\u0440\u0435\u043C\u0443
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430-\u041D\u0430\u0439\u043C\u0430\u0440\u043A\u0430**
    \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u0432 **GNS-\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044E**
    (\u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430-\u041D\u0430\u0439\u043C\u0430\u0440\u043A\u0430-\u0421\u0438\u0433\u0430\u043B\u0430).
    \u042D\u0442\u0438 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
    \u0441\u0442\u0430\u043B\u0438 \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C
    \u043A\u0430\u043C\u043D\u0435\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043F\u043F\u0430\u0440\u0430\u0442\u0430 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438.  ### \U0001FA9E \u041C\u043E\u0441\u0442
    \u0432 \u0444\u0438\u0437\u0438\u043A\u0443: \u0422\u0435\u043E\u0440\u0438\u044F
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u0438 \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u043D\u044B\u0435 \u0444\u0443\u043D\u043A\u0446\u0438\u0438 
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445, \u043A\u0442\u043E \u043E\u0441\u043E\u0437\u043D\u0430\u043B
    \u0438 \u0441\u043E\u0437\u0434\u0430\u043B \u044F\u0437\u044B\u043A, \u043D\u0430
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u0438 \u0444\u0438\u0437\u0438\u043A\u0430 \u043C\u043E\u0433\u0443\u0442 \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
    \u043D\u0430 \u0440\u0430\u0432\u043D\u044B\u0445.  *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C\u0435\u0440\u043D\u044B\u0445
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u0433\u0440\u0443\u043F\u043F \u041B\u0438:** \u042D\u0442\u043E, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0435 \u0432\u0430\u0436\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435. \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u0445 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0433\u0440\u0443\u043F\u043F \u041B\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0438\u043C\u0435\u0435\u0442 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0434\u043B\u044F \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u044B\u0445 \u0447\u0430\u0441\u0442\u0438\u0446.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u043D\u0430\u0434 **\u0441\u0445\u0435\u043C\u0430\u043C\u0438
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430-\u0426\u0435\u0442\u043B\u0438\u043D\u0430**
    (Gelfand\u2013Tsetlin patterns) \u0441\u0442\u0430\u043B\u0430 \u0448\u0438\u0440\u043E\u043A\u043E
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C\u044B\u043C \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C
    \u0432 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0435. *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    (\u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0439):**
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0438 \u0413.\u0415. \u0428\u0438\u043B\u043E\u0432
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B\u0438 \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0448\u0435\u0441\u0442\u0438\u0442\u043E\u043C\u043D\u044B\u0439 \u0442\u0440\u0443\u0434
    \xAB\u041E\u0431\u043E\u0431\u0449\u0435\u043D\u043D\u044B\u0435 \u0444\u0443\u043D\u043A\u0446\u0438\u0438\xBB
    (1958-1968 \u0433\u0433.), \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0430\u043B
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043D\u043E\u0439 \u043A\u043D\u0438\u0433\u043E\u0439
    \u0434\u043B\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0438 \u0444\u0438\u0437\u0438\u043A\u043E\u0432 \u0432\u043E \u0432\u0441\u0435\u043C
    \u043C\u0438\u0440\u0435. \u042D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u0440\u0430\u0437\u0432\u0438\u043B \u0442\u0435\u043E\u0440\u0438\u044E,
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u043D\u0443\u044E \u041B\u043E\u0440\u0430\u043D\u043E\u043C
    \u0428\u0432\u0430\u0440\u0446\u0435\u043C, \u0438 \u0441\u0434\u0435\u043B\u0430\u043B
    \u0435\u0435 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u0439 \u0434\u043B\u044F
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447.  ### \U0001F9E9 \u041E\u0442\u043A\u0440\u044B\u0442\u0438\u044F,
    \u0440\u0430\u0437\u0431\u0440\u043E\u0441\u0430\u043D\u043D\u044B\u0435 \u043F\u043E
    \u0432\u0441\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435 
    \u0421\u043F\u0438\u0441\u043E\u043A \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0439
    \u0438 \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432, \u043D\u043E\u0441\u044F\u0449\u0438\u0445
    \u0438\u043C\u044F \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430, \u043E\u0433\u0440\u043E\u043C\u0435\u043D
    \u0438 \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0443\u044E \u0448\u0438\u0440\u043E\u0442\u0443
    \u0435\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432:  *  
    **\u0418\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u0430\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F:**
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B
    \u044D\u0442\u0443 \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u0432 \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0443, \u043E\u0431\u043E\u0431\u0449\u0438\u0432
    \u0438\u0434\u0435\u0438 \u0420\u0430\u0434\u043E\u043D\u0430. \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u044D\u0442\u043E\u043C \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0438
    \u0441\u0442\u0430\u043B\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u043E\u0439 \u0438
    \u043F\u043E\u0437\u0438\u0442\u0440\u043E\u043D\u043D\u043E-\u044D\u043C\u0438\u0441\u0441\u0438\u043E\u043D\u043D\u043E\u0439
    \u0442\u043E\u043C\u043E\u0433\u0440\u0430\u0444\u0438\u0438 (\u041A\u0422 \u0438
    \u041F\u042D\u0422). *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0441\u043E\u043B\u0438\u0442\u043E\u043D\u043E\u0432
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u0443\u0435\u043C\u044B\u0435
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B:** \u041E\u043D \u0432\u043D\u0435\u0441
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435
    \u043D\u0435\u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0445 \u0432\u043E\u043B\u043D
    (\u0441\u043E\u043B\u0438\u0442\u043E\u043D\u043E\u0432), \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438
    \u0447\u0435\u0440\u0435\u0437 **\u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430-\u0414\u0438\u043A\u043E\u0433\u043E**
    (Gelfand\u2013Dikii equations). *   **\u041A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438
    \u0430\u043B\u0433\u0435\u0431\u0440 \u041B\u0438:** \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0414.\u0411. \u0424\u0443\u043A\u0441\u043E\u043C \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440 \u041B\u0438 \u0432\u0435\u043A\u0442\u043E\u0440\u043D\u044B\u0445
    \u043F\u043E\u043B\u0435\u0439 (**\u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430-\u0424\u0443\u043A\u0441\u0430**),
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0432\u0430\u0436\u043D\u044B\u043C
    \u0448\u0430\u0433\u043E\u043C \u0432 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438. *   **\u041E\u0431\u0440\u0430\u0442\u043D\u044B\u0435
    \u0441\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438:**
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u043D\u0430\u0434 \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0435\u0439 \u0428\u0442\u0443\u0440\u043C\u0430-\u041B\u0438\u0443\u0432\u0438\u043B\u043B\u044F
    (**\u0442\u0435\u043E\u0440\u0438\u044F \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430-\u041B\u0435\u0432\u0438\u0442\u0430\u043D\u0430**)
    \u043D\u0430\u0448\u043B\u0430 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0432 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u0440\u0430\u0441\u0441\u0435\u044F\u043D\u0438\u044F.
    *   **\u0420\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430-\u041A\u0438\u0440\u0438\u043B\u043B\u043E\u0432\u0430:**
    \u042D\u0442\u043E\u0442 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0434\u043B\u044F \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0438
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C\u0435\u0440\u043D\u044B\u0445
    \u0430\u043B\u0433\u0435\u0431\u0440. *   **\u0414\u0440\u0443\u0433\u0438\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438:** \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434
    \u0442\u0430\u043A\u0436\u0435 \u0432\u043D\u0435\u0441 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u0430\u0432\u0442\u043E\u043C\u043E\u0440\u0444\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439, \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u043D\u0443\u044E
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044E, \u0442\u0435\u043E\u0440\u0438\u044E
    \u0433\u0438\u043F\u0435\u0440\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0438 \u043D\u0435\u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u0443\u044E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0443.  ### \U0001F9EA \u041E\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043A \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438 \u0438 \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0435 
    \u0412\u043A\u043B\u0430\u0434 \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430
    \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u043B\u0441\u044F
    \u0447\u0438\u0441\u0442\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439.
    \u041B\u0438\u0447\u043D\u0430\u044F \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F
    (\u0441\u043C\u0435\u0440\u0442\u044C \u0441\u044B\u043D\u0430 \u043E\u0442 \u043B\u0435\u0439\u043A\u0435\u043C\u0438\u0438)
    \u043F\u043E\u0434\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0430 \u0435\u0433\u043E
    \u043A \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438
    \u0438 \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u044B.  *   **\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u044F:** \u041E\u043D \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043B
    \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440 \u0438 \u043C\u0435\u0436\u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0441\u043A\u0443\u044E
    \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u044E \u0432 \u041C\u0413\u0423,
    \u0433\u0434\u0435 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430\u043C\u0438
    \u043D\u0435\u0439\u0440\u043E\u0444\u0438\u0437\u0438\u043E\u043B\u043E\u0433\u0438\u0438,
    \u043A\u043B\u0435\u0442\u043E\u0447\u043D\u043E\u0439 \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438
    \u0438 \u0438\u043C\u043C\u0443\u043D\u043E\u043B\u043E\u0433\u0438\u0438. \u0415\u0433\u043E
    \u043F\u043E\u0434\u0445\u043E\u0434 \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0441\u044F
    \u0432 \u043F\u043E\u0438\u0441\u043A\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440 \u0432 \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0430\u0445, \u0442\u0430\u043A\u0438\u0445
    \u043A\u0430\u043A \u043C\u043E\u0440\u0444\u043E\u0433\u0435\u043D\u0435\u0437
    \u043A\u043B\u0435\u0442\u043E\u043A \u0438\u043B\u0438 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F\u043C\u0438. *   **\u041C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u0430\u044F
    \u0434\u0438\u0430\u0433\u043D\u043E\u0441\u0442\u0438\u043A\u0430:** \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u043E \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E
    \u043F\u0440\u0438\u0432\u0435\u043B\u0430 \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432 \u0434\u043B\u044F
    \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u043E\u0439 \u0442\u043E\u043C\u043E\u0433\u0440\u0430\u0444\u0438\u0438.
    \u041A\u0440\u043E\u043C\u0435 \u0442\u043E\u0433\u043E, \u043E\u043D \u043F\u044B\u0442\u0430\u043B\u0441\u044F
    \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u0442\u044C
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441 \u043A\u043B\u0438\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0434\u0438\u0430\u0433\u043D\u043E\u0441\u0442\u0438\u043A\u0438, \u0440\u0430\u0437\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u044F
    \xAB\u0434\u0438\u0430\u0433\u043D\u043E\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0433\u0440\u044B\xBB \u2014 \u043C\u0435\u0442\u043E\u0434\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438
    \u0441\u0432\u043E\u0435 \u0432\u0440\u0435\u043C\u044F.  ### \U0001F9D1\u200D\U0001F3EB
    \u041F\u0435\u0434\u0430\u0433\u043E\u0433 \u0438 \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C
    \u0448\u043A\u043E\u043B  \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0431\u044B\u043B
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0443\u0447\u0435\u043D\u044B\u043C,
    \u043D\u043E \u0438 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C
    \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u043E\u043C \u0441\u0432\u043E\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B,
    \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u2014 \u044D\u0442\u043E \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E,
    \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u043D\u0443\u0436\u043D\u043E \u0434\u0435\u043B\u0438\u0442\u044C\u0441\u044F
    \u0441\u043E \u0432\u0441\u0435\u043C\u0438.  *   **\u041B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440:** \u0415\u0433\u043E \u0441\u0435\u043C\u0438\u043D\u0430\u0440
    \u0432 \u041C\u0413\u0423, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u043E\u0431\u0438\u0440\u0430\u043B\u0441\u044F
    \u043D\u0430 14-\u043C \u044D\u0442\u0430\u0436\u0435 \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E
    \u0437\u0434\u0430\u043D\u0438\u044F \u043F\u043E\u0447\u0442\u0438 50 \u043B\u0435\u0442,
    \u0441\u0442\u0430\u043B \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u043F\u0440\u0438\u0442\u044F\u0436\u0435\u043D\u0438\u044F
    \u0434\u043B\u044F \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.
    \u041D\u0430 \u043D\u0435\u043C \u0446\u0430\u0440\u0438\u043B\u0430 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u0430\u044F
    \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0430\u044F \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0430,
    \u0438 \u0432\u0435\u043B\u0438\u043A\u0438\u0435 \u0443\u0447\u0435\u043D\u044B\u0435
    \u043E\u0431\u0449\u0430\u043B\u0438\u0441\u044C \u0441\u043E \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430\u043C\u0438
    \u043D\u0430 \u0440\u0430\u0432\u043D\u044B\u0445. *   **\u0412\u0441\u0435\u0441\u043E\u044E\u0437\u043D\u0430\u044F
    \u0437\u0430\u043E\u0447\u043D\u0430\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0448\u043A\u043E\u043B\u0430 (\u0412\u0417\u041C\u0428):** \u0412 1964 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B \u044D\u0442\u0443 \u0448\u043A\u043E\u043B\u0443,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0434\u0430\u043B\u0430 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u0442\u044B\u0441\u044F\u0447\u0430\u043C \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u0445
    \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u043E\u0442\u0434\u0430\u043B\u0435\u043D\u043D\u044B\u0445 \u0443\u0433\u043E\u043B\u043A\u043E\u0432
    \u0421\u0421\u0421\u0420 \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u0432\u044B\u0441\u0448\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443. \u042D\u0442\u043E
    \u0431\u044B\u043B \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435 \u043F\u0440\u043E\u0441\u0432\u0435\u0442\u0438\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0439
    \u043F\u043E\u0434\u0432\u0438\u0433.  ### \U0001F3C6 \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0438 \u043D\u0430\u0433\u0440\u0430\u0434\u044B  \u041E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430
    \u0431\u044B\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u043D \u043F\u043E \u0432\u0441\u0435\u043C\u0443
    \u043C\u0438\u0440\u0443. \u041E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434:  *   **\u041F\u0440\u0435\u043C\u0438\u044F
    \u0412\u043E\u043B\u044C\u0444\u0430 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    (1978)** \u2014 \u043E\u0434\u043D\u0430 \u0438\u0437 \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0445 \u043D\u0430\u0433\u0440\u0430\u0434
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. *   **\u041A\u0438\u043E\u0442\u0441\u043A\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F (1989)** \u2014 \u0437\u0430 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441
    \u043D\u0430\u0443\u043A\u0438. *   **\u041F\u0440\u0435\u043C\u0438\u044F \u0421\u0442\u0438\u043B\u0430
    (2005)** \u2014 \u0437\u0430 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443.
    *   **\u041F\u0440\u0435\u043C\u0438\u044F \u041C\u0430\u043A\u0410\u0440\u0442\u0443\u0440\u0430
    (\xAB\u0433\u0440\u0430\u043D\u0442 \u0434\u043B\u044F \u0433\u0435\u043D\u0438\u0435\u0432\xBB,
    1994)**. *   \u0422\u0440\u0438 \u043E\u0440\u0434\u0435\u043D\u0430 \u041B\u0435\u043D\u0438\u043D\u0430
    (\u0421\u0421\u0421\u0420). *   \u041B\u0435\u043D\u0438\u043D\u0441\u043A\u0430\u044F
    \u0438 \u0434\u0432\u0435 \u0421\u0442\u0430\u043B\u0438\u043D\u0441\u043A\u0438\u0435
    \u043F\u0440\u0435\u043C\u0438\u0438. *   \u0427\u043B\u0435\u043D\u0441\u0442\u0432\u043E
    \u0432 \u0434\u0435\u0441\u044F\u0442\u043A\u0430\u0445 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u043C\u0438\u0440\u0430, \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0435
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0435 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E
    \u0438 \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u0443\u044E
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A \u0421\u0428\u0410. 
    ### \U0001F4DC \u041A\u0440\u0430\u0442\u043A\u043E\u0435 \u0440\u0435\u0437\u044E\u043C\u0435 
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u043E\u0435\u0434\u0438\u043D\u0438\u043B,
    \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C \u0431\u044B, \u043D\u0435\u0441\u043E\u0432\u043C\u0435\u0441\u0442\u0438\u043C\u044B\u0435
    \u043C\u0438\u0440\u044B. \u041E\u043D \u043C\u043E\u0433 \u0441\u0442\u0440\u043E\u0438\u0442\u044C
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0447\u0435\u0440\u0435\u0437 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0432 \u0444\u0438\u0437\u0438\u043A\u0435, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u0441\u0430\u043C \u0436\u0435 \u0431\u0440\u0430\u043B\u0441\u044F \u0437\u0430
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447 \u0432 \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438
    \u0438 \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0435. \u0415\u0433\u043E \u0441\u0442\u0438\u043B\u044C
    \u0440\u0430\u0431\u043E\u0442\u044B, \u0435\u0433\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440 \u0438 \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u0430\u044F
    \u0438\u043C \u0448\u043A\u043E\u043B\u0430 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043B\u0438
    \u0446\u0435\u043B\u044B\u0435 \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F
    \u0443\u0447\u0435\u043D\u044B\u0445, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044E\u0442 \u0435\u0433\u043E
    \u0434\u0435\u043B\u043E \u043F\u043E \u0432\u0441\u0435\u043C\u0443 \u043C\u0438\u0440\u0443."
  achievementsEn: 
  personalLifeRu: "\u0418\u0437\u0440\u0430\u0438\u043B\u044C \u041C\u043E\u0438\u0441\u0435\u0435\u0432\u0438\u0447
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0431\u044B\u043B \u043D\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C, \u043D\u043E \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0441 \u0431\u043E\u0433\u0430\u0442\u043E\u0439 \u0438 \u0432 \u0447\u0435\u043C-\u0442\u043E
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u044C\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u0442\u0435\u0441\u043D\u043E \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u0430
    \u0441 \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438 \u0438\u0441\u043A\u0430\u043D\u0438\u044F\u043C\u0438. 
    ### \U0001F468\u200D\U0001F469\u200D\U0001F466 \u0421\u0435\u043C\u044C\u044F
    \u0438 \u0434\u0435\u0442\u0438  \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434
    \u0431\u044B\u043B \u0436\u0435\u043D\u0430\u0442 \u0442\u0440\u0438\u0436\u0434\u044B,
    \u0438 \u0435\u0433\u043E \u0441\u0435\u043C\u0435\u0439\u043D\u0430\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u043A\u0430\u043A \u0441 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0435\u043D\u0438\u0435\u043C
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0434\u0438\u043D\u0430\u0441\u0442\u0438\u0438,
    \u0442\u0430\u043A \u0438 \u0441 \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439. 
    *   **\u041F\u0435\u0440\u0432\u0430\u044F \u0436\u0435\u043D\u0430** \u2014
    **\u0424\u043B\u043E\u0440\u0430 \u041F\u0430\u0432\u043B\u043E\u0432\u043D\u0430
    \u042F\u0441\u0438\u043D\u043E\u0432\u0441\u043A\u0430\u044F** (1918\u20132020).
    \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043A\u043E\u0439,
    \u0430 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0444\u0438\u0437\u0438\u043E\u043B\u043E\u0433\u043E\u043C. \u042D\u0442\u043E\u0442
    \u0431\u0440\u0430\u043A \u0440\u0430\u0441\u043F\u0430\u043B\u0441\u044F, \u0438
    \u043F\u043E\u0437\u0436\u0435 \u043E\u043D\u0430 \u0432\u044B\u0448\u043B\u0430
    \u0437\u0430\u043C\u0443\u0436 \u0437\u0430 \u041C\u0438\u0445\u0430\u0438\u043B\u0430
    \u041B\u0438\u0442\u0432\u0438\u043D\u043E\u0432\u0430, \u0441\u044B\u043D\u0430
    \u043D\u0430\u0440\u043A\u043E\u043C\u0430 \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0445
    \u0434\u0435\u043B \u0421\u0421\u0421\u0420 \u041C.\u041C. \u041B\u0438\u0442\u0432\u0438\u043D\u043E\u0432\u0430.
    *   **\u0412\u0442\u043E\u0440\u0430\u044F \u0436\u0435\u043D\u0430** \u2014
    **\u0417\u043E\u0440\u044F (\u0417\u0438\u043D\u0430\u0438\u0434\u0430) \u042F\u043A\u043E\u0432\u043B\u0435\u0432\u043D\u0430
    \u0428\u0430\u043F\u0438\u0440\u043E** (1914\u20132013). \u041E\u043D\u0438 \u043F\u043E\u0436\u0435\u043D\u0438\u043B\u0438\u0441\u044C
    \u0432 1942 \u0433\u043E\u0434\u0443. \u041E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u0432\u044B\u043F\u0443\u0441\u043A\u043D\u0438\u0446\u0435\u0439
    \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u043C\u0435\u0445\u043C\u0430\u0442\u0430 \u041C\u0413\u0423, \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u043E\u043C
    \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A. \u0417\u043E\u0440\u044F \u042F\u043A\u043E\u0432\u043B\u0435\u0432\u043D\u0430
    \u0431\u044B\u043B\u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u043F\u0443\u0442\u043D\u0438\u0446\u0435\u0439
    \u0436\u0438\u0437\u043D\u0438, \u043D\u043E \u0438 \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u043E\u043C
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430, \u0443\u0447\u0430\u0441\u0442\u0432\u0443\u044F
    \u0432 \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u0438\u0438 \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u0439.
    \u0412 \u044D\u0442\u043E\u043C \u0431\u0440\u0430\u043A\u0435 \u0440\u043E\u0434\u0438\u043B\u0438\u0441\u044C
    \u0442\u0440\u043E\u0435 \u0441\u044B\u043D\u043E\u0432\u0435\u0439 :     *  
    **\u0421\u0435\u0440\u0433\u0435\u0439 \u0418\u0437\u0440\u0430\u0438\u043B\u0435\u0432\u0438\u0447
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434** (\u0440\u043E\u0434. 1944)
    \u2014 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u0434\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u043C \u0410\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430.     *   **\u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440
    \u0418\u0437\u0440\u0430\u0438\u043B\u0435\u0432\u0438\u0447 \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434**
    (\u0440\u043E\u0434. 1948) \u2014 \u0431\u0438\u043E\u0445\u0438\u043C\u0438\u043A,
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u043A\u043B\u0435\u0442\u043E\u0447\u043D\u043E\u0439
    \u0438 \u043C\u043E\u043B\u0435\u043A\u0443\u043B\u044F\u0440\u043D\u043E\u0439
    \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438 \u0432 \u0421\u0435\u0432\u0435\u0440\u043E-\u0417\u0430\u043F\u0430\u0434\u043D\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435 \u0432
    \u0427\u0438\u043A\u0430\u0433\u043E.     *   **\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440
    \u0418\u0437\u0440\u0430\u0438\u043B\u0435\u0432\u0438\u0447 \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434**
    \u2014 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u0443\u043C\u0435\u0440
    \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u043E\u0442 \u043E\u0441\u0442\u0440\u043E\u0433\u043E
    \u043B\u0435\u0439\u043A\u043E\u0437\u0430. \u042D\u0442\u0430 \u043F\u043E\u0442\u0435\u0440\u044F
    \u0441\u0442\u0430\u043B\u0430 \u0433\u043B\u0443\u0431\u043E\u0447\u0430\u0439\u0448\u0435\u0439
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F, \u043F\u043E \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F\u043C
    \u043A\u043E\u043B\u043B\u0435\u0433, \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0443\u043B\u0430
    \u0436\u0438\u0437\u043D\u044C \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430
    \u0438 \u043F\u043E\u0434\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0430 \u0435\u0433\u043E
    \u043A \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u043C\u0443 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E
    \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438 \u0438 \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u044B.
    *   **\u0422\u0440\u0435\u0442\u044C\u044F \u0436\u0435\u043D\u0430** \u2014
    **\u0422\u0430\u0442\u044C\u044F\u043D\u0430 \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440\u043E\u0432\u043D\u0430
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434** (\u0443\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u0430\u044F
    \u0410\u043B\u0435\u043A\u0441\u0435\u0435\u0432\u0441\u043A\u0430\u044F, \u0440\u043E\u0434.
    1952). \u041E\u043D\u0438 \u043F\u043E\u0436\u0435\u043D\u0438\u043B\u0438\u0441\u044C
    \u0432 1979 \u0433\u043E\u0434\u0443. \u041E\u043D\u0430 \u0442\u0430\u043A\u0436\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B\u0430
    \u0432 \u0420\u0430\u0442\u0433\u0435\u0440\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0432 \u0421\u0428\u0410. \u0412 \u044D\u0442\u043E\u043C \u0431\u0440\u0430\u043A\u0435
    \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u0434\u043E\u0447\u044C **\u0422\u0430\u0442\u044C\u044F\u043D\u0430
    \u0418\u0437\u0440\u0430\u0438\u043B\u0435\u0432\u043D\u0430 \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434**,
    \u0441\u0442\u0430\u0432\u0448\u0430\u044F \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u043E\u043C. 
    ### \U0001F9EC \u0421\u0432\u044F\u0437\u044C \u0441 \u043D\u0430\u0443\u043A\u043E\u0439
    \u0438 \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440  \u041B\u0438\u0447\u043D\u0430\u044F
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u0430\u044F
    \u0441\u043E \u0441\u043C\u0435\u0440\u0442\u044C\u044E \u0441\u044B\u043D\u0430
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0430 \u043E\u0442 \u043B\u0435\u0439\u043A\u0435\u043C\u0438\u0438
    \u0432 \u043A\u043E\u043D\u0446\u0435 1950-\u0445 \u2014 \u043D\u0430\u0447\u0430\u043B\u0435
    1960-\u0445 \u0433\u043E\u0434\u043E\u0432, \u0441\u0442\u0430\u043B\u0430 \u043C\u043E\u0449\u043D\u044B\u043C
    \u043A\u0430\u0442\u0430\u043B\u0438\u0437\u0430\u0442\u043E\u0440\u043E\u043C
    \u0434\u043B\u044F \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u044D\u0432\u043E\u043B\u044E\u0446\u0438\u0438.  *   \u041D\u0435 \u0438\u043C\u0435\u044F
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F, \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434,
    \u0434\u0432\u0438\u0436\u0438\u043C\u044B\u0439 \u043E\u0442\u0447\u0430\u044F\u043D\u0438\u0435\u043C
    \u0438 \u0436\u0435\u043B\u0430\u043D\u0438\u0435\u043C \u043F\u043E\u043D\u044F\u0442\u044C
    \u0441\u0443\u0442\u044C \u0431\u043E\u043B\u0435\u0437\u043D\u0438, \u043D\u0430\u0447\u0430\u043B
    \u0438\u0441\u043A\u0430\u0442\u044C \u0432\u0441\u0442\u0440\u0435\u0447 \u0441
    \u0432\u0435\u0434\u0443\u0449\u0438\u043C\u0438 \u0433\u0435\u043C\u0430\u0442\u043E\u043B\u043E\u0433\u0430\u043C\u0438
    \u0438 \u0431\u0438\u043E\u043B\u043E\u0433\u0430\u043C\u0438 \u0421\u0421\u0421\u0420.
    *   \u041E\u043D \u0431\u044B\u0441\u0442\u0440\u043E \u043F\u043E\u043D\u044F\u043B,
    \u0447\u0442\u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0435
    \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0441\u043A\u0438\u0435 \u043F\u043E\u0434\u0445\u043E\u0434\u044B
    \u043D\u0435 \u043C\u043E\u0433\u0443\u0442 \u0434\u0430\u0442\u044C \u043E\u0442\u0432\u0435\u0442\u043E\u0432,
    \u0438 \u043D\u0430\u0447\u0430\u043B \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u0432\u043E\u043A\u0440\u0443\u0433 \u0441\u0435\u0431\u044F \u043A\u0440\u0443\u0433
    \u0443\u0447\u0435\u043D\u044B\u0445 \u0438\u0437 \u0440\u0430\u0437\u043D\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439. \u0422\u0430\u043A \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0435\u0433\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    **\u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u044B\u0433\u0440\u0430\u043B \u0432\u044B\u0434\u0430\u044E\u0449\u0443\u044E\u0441\u044F
    \u0440\u043E\u043B\u044C \u0432 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0438
    \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0439 \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438,
    \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u0431\u0438\u043E\u043B\u043E\u0433\u043E\u0432 \u0438 \u0432\u0440\u0430\u0447\u0435\u0439
    \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C.  ### \U0001F30F \u041F\u043E\u0437\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u044D\u043C\u0438\u0433\u0440\u0430\u0446\u0438\u044F 
    \u0412 1989 \u0433\u043E\u0434\u0443, \u043F\u043E\u043B\u0443\u0447\u0438\u0432
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0432\u044B\u0435\u0437\u0434\u0430
    \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0443, \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434
    \u0441 \u0441\u0435\u043C\u044C\u0435\u0439 (\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u0441 \u0442\u0440\u0435\u0442\u044C\u0435\u0439 \u0436\u0435\u043D\u043E\u0439
    \u0422\u0430\u0442\u044C\u044F\u043D\u043E\u0439 \u0438 \u0434\u043E\u0447\u0435\u0440\u044C\u044E)
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0421\u0428\u0410. \u0412
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u043E\u043D \u0436\u0438\u043B \u0432 \u0433\u043E\u0440\u043E\u0434\u043A\u0435
    \u041F\u0438\u0441\u043A\u0430\u0442\u0430\u0443\u044D\u0439, \u0448\u0442\u0430\u0442
    \u041D\u044C\u044E-\u0414\u0436\u0435\u0440\u0441\u0438, \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E
    \u043E\u0442 \u0420\u0430\u0442\u0433\u0435\u0440\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430, \u0433\u0434\u0435
    \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0441\u0432\u043E\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0432\u043F\u043B\u043E\u0442\u044C \u0434\u043E
    \u0441\u043C\u0435\u0440\u0442\u0438. \u041E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 96 \u043B\u0435\u0442
    5 \u043E\u043A\u0442\u044F\u0431\u0440\u044F 2009 \u0433\u043E\u0434\u0430 \u0432
    \u041D\u044C\u044E-\u0411\u0440\u0430\u043D\u0441\u0443\u0438\u043A\u0435, \u0448\u0442\u0430\u0442
    \u041D\u044C\u044E-\u0414\u0436\u0435\u0440\u0441\u0438. \u0423 \u043D\u0435\u0433\u043E
    \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C \u0432\u0442\u043E\u0440\u0430\u044F
    \u0436\u0435\u043D\u0430 \u0417\u043E\u0440\u044F \u0428\u0430\u043F\u0438\u0440\u043E
    (\u0443\u043C\u0435\u0440\u043B\u0430 \u0432 2013 \u0433\u043E\u0434\u0443),
    \u0442\u0440\u0435\u0442\u044C\u044F \u0436\u0435\u043D\u0430 \u0422\u0430\u0442\u044C\u044F\u043D\u0430,
    \u0434\u0435\u0442\u0438 \u0438 \u043C\u043D\u043E\u0433\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0435
    \u0432\u043D\u0443\u043A\u0438."
  personalLifeEn: 
  shortBioRu: "\u0418\u0437\u0440\u0430\u0438\u043B\u044C \u041C\u043E\u0438\u0441\u0435\u0435\u0432\u0438\u0447
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 (1913\u20132009) \u2014 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    XX \u0432\u0435\u043A\u0430, \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C
    \u0438 \u043D\u0430\u0443\u0447\u043D\u043E\u0435 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u043E
    \u0431\u044B\u043B\u0438 \u0441\u0442\u043E\u043B\u044C \u0436\u0435 \u043D\u0435\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C\u0438,
    \u043A\u0430\u043A \u0438 \u0435\u0433\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F.
    \u041E\u043D \u0432\u043E\u0448\u0435\u043B \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043A\u0430\u043A \u0430\u0432\u0442\u043E\u0440
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432 \u0432 \u0441\u0430\u043C\u044B\u0445 \u0440\u0430\u0437\u043D\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u043D\u043E \u0438 \u043A\u0430\u043A \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B \u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F.  ### \U0001F9EC
    \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B \u0438 \u043F\u0443\u0442\u044C
    \u0432 \u043D\u0430\u0443\u043A\u0443  \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F 2 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F
    1913 \u0433\u043E\u0434\u0430 \u0432 \u043C\u0435\u0441\u0442\u0435\u0447\u043A\u0435
    \u041E\u043A\u043D\u044B (\u043F\u043E\u0437\u0436\u0435 \u041A\u0440\u0430\u0441\u043D\u044B\u0435
    \u041E\u043A\u043D\u044B) \u043D\u0430 \u044E\u0433\u0435 \u0423\u043A\u0440\u0430\u0438\u043D\u044B,
    \u0432 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0439 \u0441\u0435\u043C\u044C\u0435
    \u0431\u0443\u0445\u0433\u0430\u043B\u0442\u0435\u0440\u0430. \u0415\u0433\u043E
    \u043F\u0443\u0442\u044C \u0432 \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u043D\u0430\u0443\u043A\u0443
    \u0431\u044B\u043B \u043F\u043E\u043B\u043E\u043D \u043F\u0440\u0435\u043F\u044F\u0442\u0441\u0442\u0432\u0438\u0439
    \u0438 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u043C
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439 \u0441\u0438\u043B\u044B
    \u0442\u0430\u043B\u0430\u043D\u0442\u0430 \u0438 \u0446\u0435\u043B\u0435\u0443\u0441\u0442\u0440\u0435\u043C\u043B\u0435\u043D\u043D\u043E\u0441\u0442\u0438. 
    *   **\u0422\u0440\u0443\u0434\u043D\u043E\u0435 \u0434\u0435\u0442\u0441\u0442\u0432\u043E:**
    \u0412 1928 \u0433\u043E\u0434\u0443, \u0432 \u0440\u0430\u0437\u0433\u0430\u0440
    \u043A\u043E\u043B\u043B\u0435\u043A\u0442\u0438\u0432\u0438\u0437\u0430\u0446\u0438\u0438,
    \u043E\u043D \u0431\u044B\u043B \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D
    \u0438\u0437 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B \u0432 9-\u043C \u043A\u043B\u0430\u0441\u0441\u0435
    \u043A\u0430\u043A \u0441\u044B\u043D \xAB\u043D\u0435\u0442\u0440\u0443\u0434\u043E\u0432\u043E\u0433\u043E
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\xBB (\u0435\u0433\u043E \u043E\u0442\u0435\u0446
    \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u043B \u043C\u0435\u043B\u044C\u043D\u0438\u0446\u0435\u0439).
    *   **\u041F\u0443\u0442\u044C \u0432 \u041C\u043E\u0441\u043A\u0432\u0443:**
    \u041D\u0435 \u0438\u043C\u0435\u044F \u0437\u0430\u043A\u043E\u043D\u0447\u0435\u043D\u043D\u043E\u0433\u043E
    \u0441\u0440\u0435\u0434\u043D\u0435\u0433\u043E \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F,
    \u0432 1930 \u0433\u043E\u0434\u0443 \u043E\u043D \u0443\u0435\u0445\u0430\u043B
    \u0432 \u041C\u043E\u0441\u043A\u0432\u0443. \u0420\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432\u0430\u0445\u0442\u0435\u0440\u043E\u043C \u0432 \u041B\u0435\u043D\u0438\u043D\u0441\u043A\u043E\u0439
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0435, \u0433\u0434\u0435
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0441\u0430\u043C\u043E\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C
    \u0438 \u0447\u0438\u0442\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043D\u0438\u0433\u0438. *   **\u0421\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u0439
    \u0441\u043B\u0443\u0447\u0430\u0439:** \u0412 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0435
    \u0435\u0433\u043E \u0437\u0430\u043C\u0435\u0442\u0438\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u041C\u0413\u0423, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0434\u0430\u043B
    \u0435\u043C\u0443 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0437\u0430\u0434\u0430\u0447.
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0438\u0445 \u0440\u0435\u0448\u0438\u043B,
    \u043F\u0440\u0438\u0447\u0435\u043C \u043E\u0434\u043D\u0430 \u0438\u0437 \u0437\u0430\u0434\u0430\u0447
    \u0431\u044B\u043B\u0430 \u043D\u0435\u0440\u0435\u0448\u0435\u043D\u043D\u043E\u0439.
    \u0412\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D\u043D\u044B\u0439 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B \u0435\u0433\u043E \u043F\u043E\u0441\u0435\u0449\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u0438. \u042D\u0442\u0438\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0431\u044B\u043B \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    **\u0410\u043D\u0434\u0440\u0435\u0439 \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432**.  \u0422\u0430\u043A,
    \u0432 1932 \u0433\u043E\u0434\u0443, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    19 \u043B\u0435\u0442, \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0431\u044B\u043B
    \u043F\u0440\u0438\u043D\u044F\u0442 \u0432 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u0443\u0440\u0443
    \u041C\u0413\u0423 \u043A \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0443
    \u0438 \u043D\u0430\u0447\u0430\u043B \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C
    \u043D\u0430 \u043A\u0430\u0444\u0435\u0434\u0440\u0435. \u041F\u043E\u0437\u0436\u0435
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432 \u0441\u043A\u0430\u0436\u0435\u0442,
    \u0447\u0442\u043E \u0435\u0441\u0442\u044C \u043B\u0438\u0448\u044C \u0434\u0432\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430, \u0432 \u0431\u0435\u0441\u0435\u0434\u0435
    \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438 \u043E\u043D \xAB\u043E\u0449\u0443\u0449\u0430\u043B
    \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435 \u0432\u044B\u0441\u0448\u0435\u0433\u043E
    \u0440\u0430\u0437\u0443\u043C\u0430\xBB, \u0438 \u043E\u0434\u0438\u043D \u0438\u0437
    \u043D\u0438\u0445 \u2014 \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434. 
    ### \U0001F52C \u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434
    \u0431\u044B\u043B \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u043E\u043C
    \u0432 \u044D\u043F\u043E\u0445\u0443 \u0432\u0441\u0435 \u0431\u043E\u043B\u0435\u0435
    \u0443\u0437\u043A\u043E\u0439 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438.
    \u041E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0431\u043E\u043B\u0435\u0435
    \u0447\u0435\u043C \u0432 \u0434\u0435\u0441\u044F\u0442\u043A\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439,
    \u0435\u0433\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438 \xAB\u041C\u043E\u0446\u0430\u0440\u0442\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB \u0437\u0430
    \u043A\u0440\u0430\u0441\u043E\u0442\u0443 \u0438 \u043C\u0430\u0441\u0448\u0442\u0430\u0431
    \u0435\u0433\u043E \u0438\u0434\u0435\u0439. \u041E\u043D \u0430\u0432\u0442\u043E\u0440
    \u0431\u043E\u043B\u0435\u0435 800 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0441\u0442\u0430\u0442\u0435\u0439 \u0438 \u043E\u043A\u043E\u043B\u043E 30
    \u043A\u043D\u0438\u0433.  \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B \u0432\u043A\u043B\u044E\u0447\u0430\u044E\u0442: 
    *   **\u0424\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437:** \u0421\u043E\u0437\u0434\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u044B\u0445
    \u0431\u0430\u043D\u0430\u0445\u043E\u0432\u044B\u0445 \u0430\u043B\u0433\u0435\u0431\u0440
    (\u043D\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u043A\u043E\u043B\u0435\u0446), \u0447\u0442\u043E \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u043E
    \u0435\u043C\u0443 \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C.
    *   **C*-\u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0438 \u0442\u0435\u043E\u0440\u0438\u044F
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439:**
    \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E \u0441 \u041C.\u0410.
    \u041D\u0430\u0439\u043C\u0430\u0440\u043A\u043E\u043C \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0442\u0435\u043E\u0440\u0438\u0438 C*-\u0430\u043B\u0433\u0435\u0431\u0440
    \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0442\u0435\u043E\u0440\u0438\u044E
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C\u0435\u0440\u043D\u044B\u0445
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
    \u0433\u0440\u0443\u043F\u043F \u041B\u0438, \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u043C\u043E\u0441\u0442\u043E\u043C \u043C\u0435\u0436\u0434\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439
    \u0438 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u0444\u0438\u0437\u0438\u043A\u043E\u0439.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439:** \u0410\u0432\u0442\u043E\u0440
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0448\u0435\u0441\u0442\u0438\u0442\u043E\u043C\u043D\u043E\u0439 \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \xAB\u041E\u0431\u043E\u0431\u0449\u0435\u043D\u043D\u044B\u0435 \u0444\u0443\u043D\u043A\u0446\u0438\u0438\xBB,
    \u0441\u0442\u0430\u0432\u0448\u0435\u0439 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043D\u043E\u0439
    \u043A\u043D\u0438\u0433\u043E\u0439 \u0434\u043B\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0438 \u0444\u0438\u0437\u0438\u043A\u043E\u0432 \u043F\u043E \u0432\u0441\u0435\u043C\u0443
    \u043C\u0438\u0440\u0443. *   **\u0414\u0440\u0443\u0433\u0438\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438:**
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u0437\u0430\u0442\u0440\u043E\u043D\u0443\u043B\u0438
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u0443\u044E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E,
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044E (\u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430-\u0424\u0443\u043A\u0441\u0430),
    \u0442\u0435\u043E\u0440\u0438\u044E \u0441\u043E\u043B\u0438\u0442\u043E\u043D\u043E\u0432,
    \u043E\u0431\u0440\u0430\u0442\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438
    \u0441\u043F\u0435\u043A\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430. \u0415\u0433\u043E \u0438\u0434\u0435\u0438
    \u043B\u0435\u0433\u043B\u0438 \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u043C\u0435\u0442\u043E\u0434\u043E\u0432
    \u0434\u043B\u044F \u041C\u0420\u0422 \u0438 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u043E\u0439
    \u0442\u043E\u043C\u043E\u0433\u0440\u0430\u0444\u0438\u0438.  \u0412 1953 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u0410\u041D \u0421\u0421\u0421\u0420, \u043D\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u043C \u0441\u0442\u0430\u043B
    \u0442\u043E\u043B\u044C\u043A\u043E \u0432 1984 \u0433\u043E\u0434\u0443 \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 71 \u0433\u043E\u0434\u0430.
    \u041F\u0440\u0438\u0447\u0438\u043D\u043E\u0439 \u0442\u0430\u043A\u043E\u0439
    \u0437\u0430\u0434\u0435\u0440\u0436\u043A\u0438, \u043F\u043E \u043E\u0431\u0449\u0435\u043C\u0443
    \u043C\u043D\u0435\u043D\u0438\u044E, \u0431\u044B\u043B \u0430\u043D\u0442\u0438\u0441\u0435\u043C\u0438\u0442\u0438\u0437\u043C
    \u0432 \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0440\u0435\u0434\u0435 \u0438 \u0435\u0433\u043E \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u043E\u0439,
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u044B\u0439 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440. 
    ### \U0001F9D1\u200D\U0001F3EB \u041F\u0435\u0434\u0430\u0433\u043E\u0433, \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A
    \u0438 \u0431\u043E\u0440\u0435\u0446 \u0437\u0430 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0431\u044B\u043B \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u0443\u0447\u0435\u043D\u044B\u043C, \u043D\u043E
    \u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0447\u0438\u0442\u0430\u043B
    \u0441\u0432\u043E\u0435\u0439 \u043C\u0438\u0441\u0441\u0438\u0435\u0439 \u043F\u0440\u0438\u043E\u0431\u0449\u0430\u0442\u044C
    \u043A \u043A\u0440\u0430\u0441\u043E\u0442\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043A\u0430\u043A \u043C\u043E\u0436\u043D\u043E \u0431\u043E\u043B\u044C\u0448\u0435
    \u043B\u044E\u0434\u0435\u0439.  *   **\u041B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440:** \u0412 1943 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B \u0435\u0436\u0435\u043D\u0435\u0434\u0435\u043B\u044C\u043D\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u043B \u043F\u043E\u0447\u0442\u0438
    50 \u043B\u0435\u0442 \u043D\u0430 14-\u043C \u044D\u0442\u0430\u0436\u0435 \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E
    \u0437\u0434\u0430\u043D\u0438\u044F \u041C\u0413\u0423. \u041D\u0430 \u043D\u0435\u043C
    \u0446\u0430\u0440\u0438\u043B\u0430 \u0434\u0435\u043C\u043E\u043A\u0440\u0430\u0442\u0438\u0447\u043D\u0430\u044F
    \u0438 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0430\u044F \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0430,
    \u0433\u0434\u0435 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u044B \u0438 \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u044B
    \u043D\u0430 \u0440\u0430\u0432\u043D\u044B\u0445 \u043E\u0431\u0449\u0430\u043B\u0438\u0441\u044C
    \u0441 \u043C\u0430\u0441\u0442\u0438\u0442\u044B\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438.
    \u0421\u0435\u043C\u0438\u043D\u0430\u0440 \u0441\u0442\u0430\u043B \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439
    \u0448\u043A\u043E\u043B\u043E\u0439 \u0438 \xAB\u043E\u043A\u043D\u043E\u043C
    \u0432 \u043D\u0430\u0443\u043A\u0443\xBB \u0434\u043B\u044F \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.
    *   **\u0412\u0441\u0435\u0441\u043E\u044E\u0437\u043D\u0430\u044F \u0437\u0430\u043E\u0447\u043D\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0448\u043A\u043E\u043B\u0430 (\u0412\u0417\u041C\u0428):** \u0412 1964 \u0433\u043E\u0434\u0443
    \u043F\u043E \u0435\u0433\u043E \u0438\u043D\u0438\u0446\u0438\u0430\u0442\u0438\u0432\u0435
    \u0431\u044B\u043B\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0430 \u0412\u0417\u041C\u0428.
    \u041E\u043D\u0430 \u0434\u0430\u043B\u0430 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u043C \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u043A\u0430\u043C
    \u0438\u0437 \u043E\u0442\u0434\u0430\u043B\u0435\u043D\u043D\u044B\u0445 \u0443\u0433\u043E\u043B\u043A\u043E\u0432
    \u0421\u0421\u0421\u0420 \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u0439.
    \u041E\u043A\u043E\u043B\u043E 70 \u0442\u044B\u0441\u044F\u0447 \u0447\u0435\u043B\u043E\u0432\u0435\u043A
    \u043F\u0440\u043E\u0448\u043B\u0438 \u0447\u0435\u0440\u0435\u0437 \u044D\u0442\u0443
    \u0448\u043A\u043E\u043B\u0443, \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C \u0432\u043A\u043B\u0430\u0434\u043E\u043C
    \u0432 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432 \u0441\u0442\u0440\u0430\u043D\u0435. *   **\u0418\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438:** \u041B\u0438\u0447\u043D\u0430\u044F
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F (\u0441\u043C\u0435\u0440\u0442\u044C
    \u0441\u044B\u043D\u0430 \u043E\u0442 \u043B\u0435\u0439\u043A\u0435\u043C\u0438\u0438)
    \u043F\u043E\u0434\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0430 \u0435\u0433\u043E
    \u043A \u0437\u0430\u043D\u044F\u0442\u0438\u044F\u043C \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0435\u0439
    \u0438 \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u043E\u0439. \u041E\u043D \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043B
    \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440 \u0438 \u043C\u0435\u0436\u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0441\u043A\u0443\u044E
    \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u044E, \u0432\u043D\u0435\u0441
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043D\u0435\u0439\u0440\u043E\u0444\u0438\u0437\u0438\u043E\u043B\u043E\u0433\u0438\u044E,
    \u043A\u043B\u0435\u0442\u043E\u0447\u043D\u0443\u044E \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u044E
    \u0438 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043C\u0435\u0442\u043E\u0434\u043E\u0432
    \u0434\u0438\u0430\u0433\u043D\u043E\u0441\u0442\u0438\u043A\u0438.  ### \U0001F30D
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435  \u0412 1989 \u0433\u043E\u0434\u0443,
    \u043F\u043E\u0441\u043B\u0435 \u043C\u043D\u043E\u0433\u0438\u0445 \u043B\u0435\u0442
    \u043D\u0435\u0432\u044B\u0435\u0437\u0434\u043D\u043E\u0433\u043E \u0441\u0442\u0430\u0442\u0443\u0441\u0430,
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0443\u0435\u0445\u0430\u043B
    \u0432 \u0421\u0428\u0410. \u041E\u043D \u0431\u044B\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u043D\u044B\u043C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0432 \u0413\u0430\u0440\u0432\u0430\u0440\u0434\u0435
    \u0438 MIT, \u0430 \u0441 1991 \u0433\u043E\u0434\u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0432 \u0420\u0430\u0442\u0433\u0435\u0440\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u0432 \u041D\u044C\u044E-\u0414\u0436\u0435\u0440\u0441\u0438, \u0433\u0434\u0435
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0441\u0432\u043E\u044E
    \u043D\u0430\u0443\u0447\u043D\u0443\u044E \u0438 \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C.  \u0415\u0433\u043E
    \u0442\u0430\u043B\u0430\u043D\u0442 \u0431\u044B\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u043D
    \u0432\u043E \u0432\u0441\u0435\u043C \u043C\u0438\u0440\u0435: *   **\u041F\u0440\u0435\u043C\u0438\u0438:**
    \u041B\u0430\u0443\u0440\u0435\u0430\u0442 \u041B\u0435\u043D\u0438\u043D\u0441\u043A\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438 (1961), \u0434\u0432\u0443\u0445 \u0421\u0442\u0430\u043B\u0438\u043D\u0441\u043A\u0438\u0445
    \u043F\u0440\u0435\u043C\u0438\u0439 (1951, 1953), \u041F\u0440\u0435\u043C\u0438\u0438
    \u0412\u043E\u043B\u044C\u0444\u0430 \u043F\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    (1978), \u041A\u0438\u043E\u0442\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    (1989), \u043F\u0440\u0435\u043C\u0438\u0438 \u0421\u0442\u0438\u043B\u0430 (2005),
    \u0441\u0442\u0438\u043F\u0435\u043D\u0434\u0438\u0438 \u0424\u043E\u043D\u0434\u0430
    \u041C\u0430\u043A\u0430\u0440\u0442\u0443\u0440\u043E\u0432 (\xAB\u0433\u0440\u0430\u043D\u0442
    \u0434\u043B\u044F \u0433\u0435\u043D\u0438\u0435\u0432\xBB, 1994). *   **\u0427\u043B\u0435\u043D\u0441\u0442\u0432\u0430:**
    \u0418\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0439 \u0447\u043B\u0435\u043D
    \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430, \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A \u0421\u0428\u0410,
    \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A \u0438 \u043C\u043D\u043E\u0433\u0438\u0445 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439 \u043C\u0438\u0440\u0430.  \u0418\u0437\u0440\u0430\u0438\u043B\u044C
    \u041C\u043E\u0438\u0441\u0435\u0435\u0432\u0438\u0447 \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 5 \u043E\u043A\u0442\u044F\u0431\u0440\u044F
    2009 \u0433\u043E\u0434\u0430 \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    96 \u043B\u0435\u0442 \u0432 \u041D\u044C\u044E-\u0414\u0436\u0435\u0440\u0441\u0438,
    \u043E\u0441\u0442\u0430\u0432\u0438\u0432 \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0438 \u0446\u0435\u043B\u0443\u044E
    \u043F\u043B\u0435\u044F\u0434\u0443 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432,
    \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0449\u0438\u0445 \u0432 \u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\u0445
    \u043C\u0438\u0440\u0430."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0418\u0437\u0440\u0430\u0438\u043B\u044F
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430 \u043F\u043E\u043B\u043D\u0430
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u0435\u043B\u0430\u044E\u0442
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u043F\u043E-\u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u043C\u0443
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u043E\u0439. \u0412\u043E\u0442
    \u0441\u0430\u043C\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438. 
    ### \U0001F4D6 \u041E\u0442 \u0433\u0430\u0440\u0434\u0435\u0440\u043E\u0431\u0449\u0438\u043A\u0430
    \u0434\u043E \u0433\u0435\u043D\u0438\u044F  \u0421\u0430\u043C\u044B\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430 \u2014 \u0435\u0433\u043E
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u0439 \u043F\u0443\u0442\u044C
    \u0432 \u043D\u0430\u0443\u043A\u0443. \u0412 16 \u043B\u0435\u0442, \u0438\u043C\u0435\u044F
    \u0437\u0430 \u043F\u043B\u0435\u0447\u0430\u043C\u0438 \u0432\u0441\u0435\u0433\u043E
    9 \u043A\u043B\u0430\u0441\u0441\u043E\u0432, \u043E\u043D \u043F\u0440\u0438\u0435\u0445\u0430\u043B
    \u0432 \u041C\u043E\u0441\u043A\u0432\u0443 \u0438\u0437 \u0443\u043A\u0440\u0430\u0438\u043D\u0441\u043A\u043E\u0433\u043E
    \u043C\u0435\u0441\u0442\u0435\u0447\u043A\u0430 \u041E\u043A\u043D\u044B. \u0412
    \u0441\u0442\u043E\u043B\u0438\u0447\u043D\u043E\u043C \u041C\u0413\u0423 \u0435\u0433\u043E
    \u043D\u0435 \u043F\u0440\u0438\u043D\u044F\u043B\u0438 \u0438\u0437-\u0437\u0430
    \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u044F \u0430\u0442\u0442\u0435\u0441\u0442\u0430\u0442\u0430,
    \u0438 \u043E\u043D \u0443\u0441\u0442\u0440\u043E\u0438\u043B\u0441\u044F **\u0433\u0430\u0440\u0434\u0435\u0440\u043E\u0431\u0449\u0438\u043A\u043E\u043C
    \u0432 \u041B\u0435\u043D\u0438\u043D\u0441\u043A\u0443\u044E \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0443**,
    \u0447\u0442\u043E\u0431\u044B \u0438\u043C\u0435\u0442\u044C \u0434\u043E\u0441\u0442\u0443\u043F
    \u043A \u043A\u043D\u0438\u0433\u0430\u043C \u0438 \u0445\u043E\u0442\u044C \u043A\u0430\u043A-\u0442\u043E
    \u0432\u044B\u0436\u0438\u0442\u044C.  ### \U0001F9E9 \u0412\u0441\u0442\u0440\u0435\u0447\u0430,
    \u0440\u0435\u0448\u0438\u0432\u0448\u0430\u044F \u0441\u0443\u0434\u044C\u0431\u0443 
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u0432 \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0435
    \u044E\u043D\u043E\u0448\u0443, \u0447\u0438\u0442\u0430\u044E\u0449\u0435\u0433\u043E
    \u0441\u043B\u043E\u0436\u043D\u044B\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0440\u0443\u0434, \u0437\u0430\u043C\u0435\u0442\u0438\u043B \u0432\u0435\u043B\u0438\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A **\u0410\u043D\u0434\u0440\u0435\u0439
    \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432**.
    \u041F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 \u0434\u0430\u043B \u0435\u043C\u0443
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0437\u0430\u0434\u0430\u0447,
    \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
    \u0435\u0433\u043E \u0437\u043D\u0430\u043D\u0438\u044F, \u0438 \u0443\u0448\u0435\u043B.
    \u041A\u043E\u0433\u0434\u0430 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F, \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0440\u0435\u0448\u0438\u043B
    \u0432\u0441\u0435 \u0437\u0430\u0434\u0430\u0447\u0438, \u043D\u043E \u0438
    \u043E\u0434\u043D\u0443 \u0438\u0437 \u043D\u0438\u0445 \u2014 **\u043D\u0435\u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u0443\u044E**
    \u043D\u0430 \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442 \u2014 \u0440\u0435\u0448\u0438\u043B
    \u043D\u0435\u043E\u0431\u044B\u0447\u0430\u0439\u043D\u043E \u0438\u0437\u044F\u0449\u043D\u044B\u043C
    \u0441\u043F\u043E\u0441\u043E\u0431\u043E\u043C.  > **\u0412\u0430\u0436\u043D\u043E:**
    \u042D\u0442\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u2014 \u043E\u0434\u043D\u0430
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u043B\u0435\u0433\u0435\u043D\u0434 \u043E \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0435.
    \u0421\u0430\u043C \u043E\u043D \u0433\u043E\u0432\u043E\u0440\u0438\u043B, \u0447\u0442\u043E
    \u043D\u0435 \u043F\u043E\u043C\u043D\u0438\u0442, \u0440\u0435\u0448\u0438\u043B
    \u043B\u0438 \u0442\u0443 \u0441\u0430\u043C\u0443\u044E, \u043D\u0435\u0440\u0435\u0448\u0435\u043D\u043D\u0443\u044E
    \u0437\u0430\u0434\u0430\u0447\u0443, \u043D\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B,
    \u0447\u0442\u043E \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432
    \u0431\u044B\u043B \u043F\u043E\u0442\u0440\u044F\u0441\u0435\u043D \u0435\u0433\u043E
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044F\u043C\u0438.
    \u0422\u0430\u043A, \u0432 1932 \u0433\u043E\u0434\u0443, 19-\u043B\u0435\u0442\u043D\u0438\u0439
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434, \u043D\u0435 \u0438\u043C\u0435\u044F
    \u0434\u0430\u0436\u0435 \u0441\u0440\u0435\u0434\u043D\u0435\u0433\u043E \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F,
    \u0441\u0442\u0430\u043B \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u043E\u043C
    \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430 \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u041C\u0413\u0423.  ### \U0001F3AD \xAB\u041C\u043E\u0446\u0430\u0440\u0442
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438\xBB \u0438 \u0435\u0433\u043E
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0435 \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0441\u0447\u0438\u0442\u0430\u043B,
    \u0447\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043F\u043E\u0434\u043E\u0431\u043D\u0430 \u043C\u0443\u0437\u044B\u043A\u0435,
    \u0438 \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E
    \u043C\u043E\u0436\u043D\u043E \u0441\u0440\u0430\u0432\u043D\u0438\u0442\u044C
    \u0441 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u043C
    \u043A\u043E\u043C\u043F\u043E\u0437\u0438\u0442\u043E\u0440\u043E\u043C. \u0421\u0435\u0431\u044F
    \u043E\u043D \u0432\u0438\u0434\u0435\u043B **\u041C\u043E\u0446\u0430\u0440\u0442\u043E\u043C**,
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E, \u043F\u043E \u0435\u0433\u043E
    \u0441\u043B\u043E\u0432\u0430\u043C: *\xAB\u041C\u044B \u043B\u044E\u0431\u0438\u043C
    \u041C\u043E\u0446\u0430\u0440\u0442\u0430 \u043D\u0435 \u0437\u0430 \u0442\u043E
    \u0438\u043B\u0438 \u0438\u043D\u043E\u0435 \u0435\u0433\u043E \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435.
    \u0412\u0435\u043B\u0438\u043A\u0438\u043C \u043A\u043E\u043C\u043F\u043E\u0437\u0438\u0442\u043E\u0440\u043E\u043C
    \u0435\u0433\u043E \u0434\u0435\u043B\u0430\u044E\u0442 \u0432\u0441\u044F \u0441\u043E\u0432\u043E\u043A\u0443\u043F\u043D\u043E\u0441\u0442\u044C
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442 \u0438 \u0438\u0445 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E\u0435
    \u0432\u0435\u043B\u0438\u043A\u043E\u043B\u0435\u043F\u0438\u0435\xBB*.  ###
    \U0001F4AC \u041B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u044B\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440: \u0442\u0435\u0430\u0442\u0440 \u043E\u0434\u043D\u043E\u0433\u043E
    \u0430\u043A\u0442\u0435\u0440\u0430  \u0412 1943 \u0433\u043E\u0434\u0443 \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434
    \u043E\u0441\u043D\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u043E\u0431\u0438\u0440\u0430\u043B\u0441\u044F \u043F\u043E\u0447\u0442\u0438
    \u043F\u043E\u043B\u0432\u0435\u043A\u0430 \u0432 \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u0438
    1408 \u043D\u0430 14-\u043C \u044D\u0442\u0430\u0436\u0435 \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E
    \u0437\u0434\u0430\u043D\u0438\u044F \u041C\u0413\u0423. \u0410\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0430
    \u0442\u0430\u043C \u0431\u044B\u043B\u0430 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439
    \u0438 \u043E\u0447\u0435\u043D\u044C \u0436\u0435\u0441\u0442\u043A\u043E\u0439: 
    *   **\u0420\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u043E \u0438 \u0442\u0438\u0440\u0430\u043D\u0438\u044F:**
    \u0421\u0442\u0443\u0434\u0435\u043D\u0442\u044B \u0438 \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u043A\u0438
    \u0438\u043C\u0435\u043B\u0438 \u0440\u0430\u0432\u043D\u044B\u0435 \u043F\u0440\u0430\u0432\u0430
    \u0441 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u0430\u043C\u0438, \u043D\u043E
    \xAB\u0434\u0438\u043A\u0442\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u0439\xBB
    \u0441\u0442\u0438\u043B\u044C \u0432\u0435\u0434\u0435\u043D\u0438\u044F \u0441\u0435\u043C\u0438\u043D\u0430\u0440\u0430
    \u0431\u044B\u043B \u0431\u0435\u0437\u0436\u0430\u043B\u043E\u0441\u0442\u043D\u044B\u043C.
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u043C\u043E\u0433 \u043F\u0440\u0435\u0440\u0432\u0430\u0442\u044C
    \u0434\u043E\u043A\u043B\u0430\u0434\u0447\u0438\u043A\u0430 \u0447\u0435\u0440\u0435\u0437
    \u043F\u044F\u0442\u044C \u043C\u0438\u043D\u0443\u0442, \u0437\u0430\u044F\u0432\u0438\u0432,
    \u0447\u0442\u043E \u0442\u043E\u0442 \u043D\u0435\u0441\u0435\u0442 \u0447\u0443\u0448\u044C,
    \u0438 \u0441\u0430\u043C \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u044C,
    \xAB\u043A\u0430\u043A \u043D\u0430\u0434\u043E\xBB. *   **\u0422\u0440\u0435\u043D\u0438\u0440\u043E\u0432\u043A\u0430
    \u0433\u0435\u043D\u0438\u0435\u0432:** \u041E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043E\u043D \u043F\u0440\u0435\u0440\u0432\u0430\u043B \u0434\u043E\u043A\u043B\u0430\u0434
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E,
    \u043F\u043E\u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u043A \u0441\u0438\u0434\u0435\u0432\u0448\u0435\u043C\u0443
    \u0432 \u0437\u0430\u043B\u0435 **\u0448\u043A\u043E\u043B\u044C\u043D\u0438\u043A\u0443
    \u041C\u0430\u043A\u0441\u0438\u043C\u0443 \u041A\u043E\u043D\u0446\u0435\u0432\u0438\u0447\u0443**
    \u0438 \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B, \u043A\u0430\u043A \u043D\u0430\u0434\u043E
    \u0440\u0435\u0448\u0430\u0442\u044C \u0437\u0430\u0434\u0430\u0447\u0443. \u041D\u0430
    \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439 \u043D\u0435\u0434\u0435\u043B\u0435
    \u044D\u0442\u043E\u0442 \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u043A \u0441\u0434\u0435\u043B\u0430\u043B
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u0439 \u0434\u043E\u043A\u043B\u0430\u0434
    \u043D\u0430 \u0442\u0443 \u0436\u0435 \u0442\u0435\u043C\u0443. \u041C\u0430\u043A\u0441\u0438\u043C
    \u041A\u043E\u043D\u0446\u0435\u0432\u0438\u0447 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0441\u0442\u0438,
    \u043B\u0430\u0443\u0440\u0435\u0430\u0442\u043E\u043C \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439
    \u043F\u0440\u0435\u043C\u0438\u0438. *   **\xAB\u0413\u043B\u0430\u0432\u043D\u0430\u044F
    \u0441\u0438\u043D\u0430\u0433\u043E\u0433\u0430\xBB:** \u0421\u0435\u043C\u0438\u043D\u0430\u0440
    \u0431\u044B\u043B \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0437\u043D\u0430\u0447\u0438\u043C\u044B\u043C
    \u0446\u0435\u043D\u0442\u0440\u043E\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438, \u0447\u0442\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0441\u043E\u0432\u0435\u0442\u043E\u0432\u0430\u043B
    \u043C\u043E\u043B\u043E\u0434\u043E\u043C\u0443 \u0443\u0447\u0435\u043D\u043E\u043C\u0443,
    \u043F\u043E\u0442\u0435\u0440\u044F\u0432\u0448\u0435\u043C\u0443\u0441\u044F
    \u0432 \u0434\u0440\u0443\u0433\u0438\u0445 \u0441\u0435\u043C\u0438\u043D\u0430\u0440\u0430\u0445:
    *\xAB\u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439 \u0441\u0435\u043C\u0438\u043D\u0430\u0440
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430. \u0415\u0441\u043B\u0438
    \u0445\u043E\u0434\u0438\u0448\u044C \u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440\u044B \u043F\u0440\u043E\u0441\u0442\u043E
    \u043C\u043E\u043B\u0438\u0442\u044C\u0441\u044F, \u0442\u043E \u0434\u0435\u043B\u0430\u0439
    \u044D\u0442\u043E \u0432 \u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u0441\u0438\u043D\u0430\u0433\u043E\u0433\u0435\xBB*. 
    ### \U0001F9EC \u0414\u0432\u0430 \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434\u0430:
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438 \u0431\u0438\u043E\u043B\u043E\u0433 
    \u0412 \u043D\u0430\u0447\u0430\u043B\u0435 1960-\u0445 \u0433\u043E\u0434\u043E\u0432,
    \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u0441\u044B\u043D\u0430
    \u043E\u0442 \u043B\u0435\u0439\u043A\u0435\u043C\u0438\u0438, \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434
    \u043D\u0430\u0447\u0430\u043B \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u044E \u0438 \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0443.
    \u0415\u0433\u043E \u0443\u0441\u043F\u0435\u0445\u0438 \u0431\u044B\u043B\u0438
    \u0441\u0442\u043E\u043B\u044C \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B,
    \u0447\u0442\u043E \u0432 \u043D\u0430\u0443\u0447\u043D\u043E\u043C \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435
    \u0434\u043E\u043B\u0433\u043E \u0445\u043E\u0434\u0438\u043B\u0430 \u0448\u0443\u0442\u043A\u0430,
    \u0431\u0443\u0434\u0442\u043E **\u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0438 \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434-\u0431\u0438\u043E\u043B\u043E\u0433
    \u2014 \u044D\u0442\u043E \u0434\u0432\u0430 \u0440\u0430\u0437\u043D\u044B\u0445
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430**, \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u043C \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u043E\u0434\u0438\u043D \u0443\u0447\u0435\u043D\u044B\u0439
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u0441\u0442\u043E\u043B\u044C
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u043E\u043C
    \u0432 \u0442\u0430\u043A\u0438\u0445 \u0434\u0430\u043B\u0435\u043A\u0438\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445.  ### \U0001F331 \u041F\u0440\u043E\u0441\u0432\u0435\u0442\u0438\u0442\u0435\u043B\u044C
    \u0438 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A  \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434
    \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0447\u0435\u043D\u044B\u043C,
    \u043D\u043E \u0438 \u0432\u0435\u043B\u0438\u043A\u0438\u043C \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u043E\u043C.
    \u0412 1964 \u0433\u043E\u0434\u0443 \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    **\u0412\u0441\u0435\u0441\u043E\u044E\u0437\u043D\u0443\u044E \u0437\u0430\u043E\u0447\u043D\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 (\u0412\u0417\u041C\u0428)**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0434\u0430\u043B\u0430 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u0441\u043E\u0442\u043D\u044F\u043C \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u0445
    \u0434\u0435\u0442\u0435\u0439 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043E\u0442\u0434\u0430\u043B\u0435\u043D\u043D\u044B\u0445
    \u0443\u0433\u043E\u043B\u043A\u043E\u0432 \u0421\u0421\u0421\u0420 \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0443 \u043B\u0443\u0447\u0448\u0438\u0445
    \u043C\u043E\u0441\u043A\u043E\u0432\u0441\u043A\u0438\u0445 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u0432
    \u043F\u043E \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435. \u041C\u043D\u043E\u0433\u0438\u0435
    \u0441\u0447\u0438\u0442\u0430\u044E\u0442, \u0447\u0442\u043E \u0435\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0432 \u0441\u0442\u0440\u0430\u043D\u0435
    \u0431\u044B\u043B\u043E \u0431\u043E\u043B\u044C\u0448\u0435, \u0447\u0435\u043C
    \u0443 \u0432\u0441\u0435\u0445 \u044D\u043B\u0438\u0442\u043D\u044B\u0445 \u0441\u043F\u0435\u0446\u0448\u043A\u043E\u043B
    \u0432\u043C\u0435\u0441\u0442\u0435 \u0432\u0437\u044F\u0442\u044B\u0445.  ###
    \U0001F3DB\uFE0F \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u043A \u0441 \u0437\u0430\u0434\u0435\u0440\u0436\u043A\u043E\u0439
    \u0438 \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0441\u0442\u0430\u043B \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u0410\u041D \u0421\u0421\u0421\u0420 \u0432 1953 \u0433\u043E\u0434\u0443, \u043D\u043E
    **\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u043C \u0431\u044B\u043B
    \u0438\u0437\u0431\u0440\u0430\u043D \u0442\u043E\u043B\u044C\u043A\u043E \u0432
    1984-\u043C**, \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 71 \u0433\u043E\u0434\u0430.
    \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439
    \u0441 1964 \u0433\u043E\u0434\u0430, \u043A\u043E\u0433\u0434\u0430 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u043C-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C
    \u0441\u0442\u0430\u043B \u0443\u0447\u0435\u043D\u044B\u0439 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F.
    \u041C\u043D\u043E\u0433\u0438\u0435 \u0441\u0432\u044F\u0437\u044B\u0432\u0430\u043B\u0438
    \u044D\u0442\u0443 \u0437\u0430\u0434\u0435\u0440\u0436\u043A\u0443 \u043A\u0430\u043A
    \u0441 \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0430\u043D\u0442\u0438\u0441\u0435\u043C\u0438\u0442\u0438\u0437\u043C\u043E\u043C,
    \u0442\u0430\u043A \u0438 \u0441 \u0435\u0433\u043E \u0441\u043B\u043E\u0436\u043D\u044B\u043C,
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u044B\u043C \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C. 
    \u041F\u0440\u0438 \u044D\u0442\u043E\u043C \u0437\u0430 \u0440\u0443\u0431\u0435\u0436\u043E\u043C
    \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0439 \u0431\u044B\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u043D
    \u043D\u0430\u043C\u043D\u043E\u0433\u043E \u0440\u0430\u043D\u044C\u0448\u0435.
    \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434 \u0431\u044B\u043B \u043F\u043E\u0447\u0435\u0442\u043D\u044B\u043C
    \u0434\u043E\u043A\u0442\u043E\u0440\u043E\u043C \u041E\u043A\u0441\u0444\u043E\u0440\u0434\u0430,
    \u0413\u0430\u0440\u0432\u0430\u0440\u0434\u0430, \u0421\u043E\u0440\u0431\u043E\u043D\u043D\u044B
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0445 \u0432\u0435\u0434\u0443\u0449\u0438\u0445
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u043E\u0432
    \u043C\u0438\u0440\u0430, \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u043C
    \u0447\u043B\u0435\u043D\u043E\u043C \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439 \u043D\u0430\u0443\u043A, \u0430
    \u0442\u0430\u043A\u0436\u0435 \u043B\u0430\u0443\u0440\u0435\u0430\u0442\u043E\u043C
    \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0435\u0439\u0448\u0438\u0445
    \u043D\u0430\u0433\u0440\u0430\u0434, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u041F\u0440\u0435\u043C\u0438\u044E \u0412\u043E\u043B\u044C\u0444\u0430 \u0438
    \xAB\u0433\u0440\u0430\u043D\u0442 \u0434\u043B\u044F \u0433\u0435\u043D\u0438\u0435\u0432\xBB
    \u041C\u0430\u043A\u0430\u0440\u0442\u0443\u0440\u0430.  ### \U0001F33F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0435
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F  \u0412 1989 \u0433\u043E\u0434\u0443,
    \u043F\u043E\u043B\u0443\u0447\u0438\u0432 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u0432\u044B\u0435\u0437\u0434\u0430, \u0413\u0435\u043B\u044C\u0444\u0430\u043D\u0434
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0421\u0428\u0410, \u0433\u0434\u0435
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u0440\u0430\u0431\u043E\u0442\u0443
    \u0432 \u0420\u0430\u0442\u0433\u0435\u0440\u0441\u043A\u043E\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435.
    \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438, \u043D\u0430\u0447\u0438\u043D\u0430\u044F \u0441
    1994 \u0433\u043E\u0434\u0430, \u043E\u043D \u0438 \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u044F
    \u0441\u0442\u0430\u043B\u0438 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C\u0438
    **\u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0446\u0430\u043C\u0438,
    \u0430 \u0441 2000 \u0433\u043E\u0434\u0430 \u2014 \u0432\u0435\u0433\u0430\u043D\u0430\u043C\u0438**."
