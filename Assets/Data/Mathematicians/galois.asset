  id: galois
  wikiTitleRu: "Галуа, Эварист"
  wikidataId: Q1744
  fullNameRu: "Галуа, Эварист"
  fullNameEn: 
  birthDate: 
  deathDate: 
  countryKeys:
  - france
  centuryKeys:
