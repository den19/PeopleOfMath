  achievementsRu: "\u0415\u0441\u043B\u0438 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u042D\u0432\u0430\u0440\u0438\u0441\u0442\u0430 \u0413\u0430\u043B\u0443\u0430
    \u2014 \u044D\u0442\u043E \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0440\u043E\u043C\u0430\u043D, \u0442\u043E \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u2014 \u044D\u0442\u043E \u043F\u0440\u043E\u0440\u044B\u0432
    \u0432 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u043D\u043E\u0432\u043E\u0435
    \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0417\u0430 \u0441\u0432\u043E\u0438 20 \u043B\u0435\u0442 \u043E\u043D \u0443\u0441\u043F\u0435\u043B
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0435\u0448\u0438\u0442\u044C
    \u0441\u0442\u0430\u0440\u0443\u044E \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443,
    \u0430 \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u0446\u0435\u043B\u044B\u0439
    \u043D\u043E\u0432\u044B\u0439 \u044F\u0437\u044B\u043A \u0434\u043B\u044F \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432.  \u0427\u0442\u043E\u0431\u044B
    \u043F\u043E\u043D\u044F\u0442\u044C \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E,
    \u043D\u0443\u0436\u043D\u043E \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u0442\u044C
    \u0435\u0433\u043E \u043F\u043E\u044D\u0442\u0430\u043F\u043D\u043E: \u043E\u0442
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u0440\u0435\u0448\u0430\u043B, \u0434\u043E \u043F\u043E\u043D\u044F\u0442\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043D \u0432\u0432\u0435\u043B. 
    ### 1. \u0413\u043B\u0430\u0432\u043D\u0430\u044F \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430:
    \u041F\u043E\u0447\u0435\u043C\u0443 \u043D\u0435\u0442 \u043E\u0431\u0449\u0435\u0439
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B \u0434\u043B\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    5-\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438?  \u0412 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0438\u0437\u0434\u0430\u0432\u043D\u0430 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u0437\u0430\u0434\u0430\u0447\u0430: **\u0440\u0435\u0448\u0438\u0442\u044C
    \u043E\u0431\u0449\u0435\u0435 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435** \u0432\u0438\u0434\u0430
    \\( a_n x^n + a_{n-1} x^{n-1} + \\dots + a_0 = 0 \\) \u0432 **\u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0430\u0445**
    (\u0442\u043E \u0435\u0441\u0442\u044C \u0432\u044B\u0440\u0430\u0437\u0438\u0442\u044C
    \u043A\u043E\u0440\u043D\u0438 \u0447\u0435\u0440\u0435\u0437 \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u044B,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F \u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u043B\u043E\u0436\u0435\u043D\u0438\u0435, \u0432\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u0435,
    \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435, \u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0438 \u0438\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435 \u043A\u043E\u0440\u043D\u0435\u0439). 
    *   \u0414\u043B\u044F \\( n=2 \\) (\u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F) \u0444\u043E\u0440\u043C\u0443\u043B\u0430
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430 \u0441 \u0434\u0440\u0435\u0432\u043D\u043E\u0441\u0442\u0438.
    *   \u0414\u043B\u044F \\( n=3 \\) \u0438 \\( n=4 \\) \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u0431\u044B\u043B\u0438 \u0432\u044B\u0432\u0435\u0434\u0435\u043D\u044B \u0432
    \u044D\u043F\u043E\u0445\u0443 \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    (\u0422\u0430\u0440\u0442\u0430\u043B\u044C\u044F, \u041A\u0430\u0440\u0434\u0430\u043D\u043E,
    \u0424\u0435\u0440\u0440\u0430\u0440\u0438). *   \u0412 1824 \u0433\u043E\u0434\u0443
    \u041D\u0438\u043B\u044C\u0441 \u0425\u0435\u043D\u0440\u0438\u043A \u0410\u0431\u0435\u043B\u044C
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0434\u043B\u044F
    \u043E\u0431\u0449\u0435\u0433\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \\( n \\ge 5 \\) **\u0442\u0430\u043A\u043E\u0439
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B \u043D\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442**. 
    **\u0412\u043E\u043F\u0440\u043E\u0441:** *\u041F\u043E\u0447\u0435\u043C\u0443*
    \u0434\u043B\u044F \u043E\u0434\u043D\u0438\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    (\u0441\u0442\u0435\u043F\u0435\u043D\u0438 2, 3, 4) \u043E\u043D\u0430 \u0435\u0441\u0442\u044C,
    \u0430 \u0434\u043B\u044F \u0434\u0440\u0443\u0433\u0438\u0445 \u043D\u0435\u0442?
    \u0427\u0442\u043E \u0434\u0435\u043B\u0430\u0435\u0442 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \xAB\u0440\u0435\u0448\u0430\u0435\u043C\u044B\u043C\xBB \u0438\u043B\u0438 \xAB\u043D\u0435\u0440\u0435\u0448\u0430\u0435\u043C\u044B\u043C\xBB?
    \u0410\u0431\u0435\u043B\u044C \u043F\u043E\u043A\u0430\u0437\u0430\u043B *\u0444\u0430\u043A\u0442*,
    \u043D\u043E \u043D\u0435 \u0434\u0430\u043B *\u043A\u0440\u0438\u0442\u0435\u0440\u0438\u044F*.
    \u0413\u0430\u043B\u0443\u0430 \u043D\u0430\u0448\u0435\u043B \u044D\u0442\u043E\u0442
    \u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0439. \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0447\u0438\u043D\u0430 \u043A\u0440\u043E\u0435\u0442\u0441\u044F
    \u043D\u0435 \u0432 \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F,
    \u0430 \u0432 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0435 \u0435\u0433\u043E
    **\u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u0439**.  ---  ### 2. \u0412\u043A\u043B\u0430\u0434
    \u21161: \u0422\u0435\u043E\u0440\u0438\u044F \u0413\u0430\u043B\u0443\u0430
    (\u043E\u0441\u043D\u043E\u0432\u043D\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430) 
    \u042D\u0442\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0440\u0430\u0437\u0434\u0435\u043B \u0430\u043B\u0433\u0435\u0431\u0440\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0443\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442
    \u043C\u043E\u0441\u0442 \u043C\u0435\u0436\u0434\u0443 \u0434\u0432\u0443\u043C\u044F,
    \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C \u0431\u044B, \u0434\u0430\u043B\u0435\u043A\u0438\u043C\u0438
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C\u0438:  *   **\u0422\u0435\u043E\u0440\u0438\u0435\u0439
    \u043F\u043E\u043B\u0435\u0439** (\u043D\u0430\u0431\u043E\u0440\u044B \u0447\u0438\u0441\u0435\u043B,
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u0435 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0439). *   **\u0422\u0435\u043E\u0440\u0438\u0435\u0439
    \u0433\u0440\u0443\u043F\u043F** (\u043D\u0430\u0431\u043E\u0440\u044B \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0439
    \u0441 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0435\u0439 \u043A\u043E\u043C\u043F\u043E\u0437\u0438\u0446\u0438\u0438). 
    **\u0421\u0443\u0442\u044C \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B:** \u0415\u0441\u043B\u0438 \u0443
    \u0432\u0430\u0441 \u0435\u0441\u0442\u044C \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435,
    \u0435\u043C\u0443 \u043C\u043E\u0436\u043D\u043E \u0441\u043E\u043F\u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u0435 \xAB\u043F\u043E\u043B\u0435
    \u0440\u0430\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u044F\xBB (\u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0438\u0439
    \u043D\u0430\u0431\u043E\u0440 \u0447\u0438\u0441\u0435\u043B, \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u0449\u0438\u0439
    \u0432\u0441\u0435 \u043A\u043E\u0440\u043D\u0438 \u044D\u0442\u043E\u0433\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F). \u0417\u0430\u0442\u0435\u043C
    \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0441\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
    \u0432\u0441\u0435 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0435 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438
    \u044D\u0442\u0438\u0445 \u043A\u043E\u0440\u043D\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u044E\u0442 \u0432\u0441\u0435 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u043C\u0435\u0436\u0434\u0443
    \u043D\u0438\u043C\u0438. \u042D\u0442\u0438 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438
    \u043E\u0431\u0440\u0430\u0437\u0443\u044E\u0442 **\u0433\u0440\u0443\u043F\u043F\u0443
    \u0413\u0430\u043B\u0443\u0430** \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F. 
    **\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0439
    \u0413\u0430\u043B\u0443\u0430:** \u0423\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E \u0432 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0430\u0445
    **\u0442\u043E\u0433\u0434\u0430 \u0438 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u043E\u0433\u0434\u0430**, \u043A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E
    \u0433\u0440\u0443\u043F\u043F\u0430 \u0413\u0430\u043B\u0443\u0430 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    **\u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0439 \u0433\u0440\u0443\u043F\u043F\u043E\u0439**. 
    *\u0427\u0442\u043E \u044D\u0442\u043E \u0437\u043D\u0430\u0447\u0438\u0442 \u043D\u0430
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0435?* \u0413\u0440\u0443\u043F\u043F\u0430
    \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0439,
    \u0435\u0441\u043B\u0438 \u0438\u0437 \u043D\u0435\u0435 \u043C\u043E\u0436\u043D\u043E
    \xAB\u0441\u043E\u0431\u0440\u0430\u0442\u044C\xBB \u0446\u0435\u043F\u043E\u0447\u043A\u0443
    \u0432\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0445 \u043F\u043E\u0434\u0433\u0440\u0443\u043F\u043F,
    \u043A\u0430\u0436\u0434\u0430\u044F \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439,
    \u0430 \u0444\u0430\u043A\u0442\u043E\u0440\u044B \u043F\u043E \u043D\u0438\u043C
    \u2014 \u0446\u0438\u043A\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u043F\u0440\u043E\u0441\u0442\u044B\u0435
    \u0433\u0440\u0443\u043F\u043F\u044B (\u0433\u0440\u0443\u043F\u043F\u044B \u043F\u0440\u043E\u0441\u0442\u043E\u0433\u043E
    \u043F\u043E\u0440\u044F\u0434\u043A\u0430). *   \u0414\u043B\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    2-\u0439, 3-\u0439 \u0438 4-\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0438\u0445 \u0433\u0440\u0443\u043F\u043F\u044B \u0413\u0430\u043B\u0443\u0430
    \u0432\u0441\u0435\u0433\u0434\u0430 \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u044B.
    *   \u0414\u043B\u044F \u043E\u0431\u0449\u0435\u0433\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    5-\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u0433\u0440\u0443\u043F\u043F\u0430
    \u0413\u0430\u043B\u0443\u0430 \u2014 \u044D\u0442\u043E **\u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0440\u0443\u043F\u043F\u0430 \\( S_5 \\)**. \u041E\u043D\u0430 *\u043D\u0435
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F* \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0439
    (\u043E\u043D\u0430 \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u043F\u0440\u043E\u0441\u0442\u0443\u044E
    \u0437\u043D\u0430\u043A\u043E\u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E
    \u0433\u0440\u0443\u043F\u043F\u0443 \\( A_5 \\), \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043D\u0435 \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442 \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u043E\u0434\u0433\u0440\u0443\u043F\u043F). \u0421\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B \u043D\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442. 
    \u042D\u0442\u043E \u0431\u044B\u043B\u043E \u043F\u043E\u043B\u043D\u043E\u0435
    \u0438 \u0438\u0441\u0447\u0435\u0440\u043F\u044B\u0432\u0430\u044E\u0449\u0435\u0435
    \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043D\u0435 \u0431\u044B\u043B\u043E \u043D\u0438 \u0443 \u0410\u0431\u0435\u043B\u044F,
    \u043D\u0438 \u0443 \u0420\u0443\u0444\u0444\u0438\u043D\u0438.  ---  ### 3.
    \u0412\u043A\u043B\u0430\u0434 \u21162: \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0433\u0440\u0443\u043F\u043F  \u0414\u043E \u0413\u0430\u043B\u0443\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438 \u0433\u0440\u0443\u043F\u043F\u044B
    \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C \u043A\u0430\u043A \u043F\u043E\u0434\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438
    (\u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043D\u043E\u0432\u043A\u0438) \u043A\u043E\u0440\u043D\u0435\u0439
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. \u0413\u0430\u043B\u0443\u0430
    \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B \u044D\u0442\u043E \u0432
    \u0441\u0442\u0440\u043E\u0439\u043D\u0443\u044E \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E.  \u041E\u043D \u0432\u0432\u0435\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u0438\u0437\u0443\u0447\u0430\u044E\u0442\u0441\u044F
    \u043D\u0430 \u043F\u0435\u0440\u0432\u044B\u0445 \u043A\u0443\u0440\u0441\u0430\u0445
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u043E\u0432: 
    *   **\u041D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0430\u044F \u043F\u043E\u0434\u0433\u0440\u0443\u043F\u043F\u0430
    (\u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043D\u0430\u044F \u043F\u043E\u0434\u0433\u0440\u0443\u043F\u043F\u0430):**
    \u041E\u043D \u043F\u0435\u0440\u0432\u044B\u043C \u0447\u0435\u0442\u043A\u043E
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B,
    \u0447\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u043F\u043E\u0434\u0433\u0440\u0443\u043F\u043F\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0438\u0442
    \u0441\u0430\u043C\u0430 \u0432 \u0441\u0435\u0431\u044F \u043F\u0440\u0438 \u0441\u043E\u043F\u0440\u044F\u0436\u0435\u043D\u0438\u0438
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u043C\u0438 \u0432\u0441\u0435\u0439
    \u0433\u0440\u0443\u043F\u043F\u044B (\\( gHg^{-1} = H \\)). \u0411\u0435\u0437
    \u044D\u0442\u043E\u0433\u043E \u043F\u043E\u043D\u044F\u0442\u0438\u044F \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u0430
    \u0441\u0430\u043C\u0430 \u0438\u0434\u0435\u044F \xAB\u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0441\u0442\u0438\xBB.
    *   **\u0424\u0430\u043A\u0442\u043E\u0440-\u0433\u0440\u0443\u043F\u043F\u0430
    (\u0433\u0440\u0443\u043F\u043F\u0430 \u0432\u044B\u0447\u0435\u0442\u043E\u0432):**
    \u0425\u043E\u0442\u044F \u044D\u0442\u043E \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \u0431\u044B\u043B\u043E \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043E\u0432\u0430\u043D\u043E
    \u043F\u043E\u0437\u0436\u0435, \u0432 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0445
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0430\u0441\u044C \u0438\u0434\u0435\u044F
    \u0440\u0430\u0437\u0431\u0438\u0435\u043D\u0438\u044F \u0433\u0440\u0443\u043F\u043F\u044B
    \u043D\u0430 \u043A\u043B\u0430\u0441\u0441\u044B \u0441\u043C\u0435\u0436\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044F \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B
    \u044D\u0442\u0438\u0445 \u043A\u043B\u0430\u0441\u0441\u043E\u0432. *   **\u041F\u0440\u043E\u0441\u0442\u0430\u044F
    \u0433\u0440\u0443\u043F\u043F\u0430:** \u041E\u043D \u043E\u0441\u043E\u0437\u043D\u0430\u043B,
    \u0447\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u0433\u0440\u0443\u043F\u043F\u044B
    \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F \xAB\u0430\u0442\u043E\u043C\u0430\u043C\u0438\xBB,
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u0442\u0440\u043E\u044F\u0442\u0441\u044F
    \u0432\u0441\u0435 \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0435, \u0438
    \u0438\u043C\u0435\u043D\u043D\u043E \u043D\u0430\u043B\u0438\u0447\u0438\u0435
    \u043D\u0435\u0430\u0431\u0435\u043B\u0435\u0432\u043E\u0439 \u043F\u0440\u043E\u0441\u0442\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u044B \\( A_5 \\) (\u0437\u043D\u0430\u043A\u043E\u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0433\u0440\u0443\u043F\u043F\u044B \u043F\u044F\u0442\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438)
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043F\u0440\u0435\u043F\u044F\u0442\u0441\u0442\u0432\u0438\u0435\u043C
    \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. 
    \u0424\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438, \u0413\u0430\u043B\u0443\u0430
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043E\u0442\u0446\u043E\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B.  ---  ### 4. \u0412\u043A\u043B\u0430\u0434
    \u21163: \u0422\u0435\u043E\u0440\u0438\u044F \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445
    \u043F\u043E\u043B\u0435\u0439  \u0412 \u0441\u0432\u043E\u0438\u0445 \xAB\u0417\u0430\u043F\u0438\u0441\u043A\u0430\u0445
    \u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B\xBB
    (1830 \u0433\u043E\u0434) \u0413\u0430\u043B\u0443\u0430 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C\u0438, \u043D\u043E
    \u0438 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u043E\u0439. \u041E\u043D
    \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445
    \u043F\u043E\u043B\u0435\u0439** (\u043F\u043E\u043B\u0435\u0439 \u0413\u0430\u043B\u0443\u0430). 
    \u0427\u0442\u043E \u044D\u0442\u043E \u0442\u0430\u043A\u043E\u0435? \u042D\u0442\u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u0441 \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u043C
    \u0447\u0438\u0441\u043B\u043E\u043C \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u044B
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438 \u0441\u043B\u043E\u0436\u0435\u043D\u0438\u044F,
    \u0432\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u044F, \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u044F
    \u0438 \u0434\u0435\u043B\u0435\u043D\u0438\u044F (\u043A\u0440\u043E\u043C\u0435
    \u0434\u0435\u043B\u0435\u043D\u0438\u044F \u043D\u0430 \u043D\u043E\u043B\u044C).
    \u0421\u0435\u0433\u043E\u0434\u043D\u044F \u043E\u043D\u0438 \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0430\u044E\u0442\u0441\u044F
    \u043A\u0430\u043A \\( GF(p^n) \\) (Galois Field).  *   \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0442\u0430\u043A\u0438\u0435 \u043F\u043E\u043B\u044F \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442
    \u0434\u043B\u044F \u043B\u044E\u0431\u043E\u0433\u043E \u0447\u0438\u0441\u043B\u0430
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432, \u044F\u0432\u043B\u044F\u044E\u0449\u0435\u0433\u043E\u0441\u044F
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C\u044E \u043F\u0440\u043E\u0441\u0442\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 (\\( p^n \\)). *   \u041E\u043D \u0434\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434\u044B \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F
    \u0442\u0430\u043A\u0438\u0445 \u043F\u043E\u043B\u0435\u0439 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043D\u0435\u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043C\u044B\u0445 \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432
    \u043D\u0430\u0434 \u043F\u0440\u043E\u0441\u0442\u044B\u043C \u043F\u043E\u043B\u0435\u043C.
    *   **\u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435:**
    \u0421\u0435\u0433\u043E\u0434\u043D\u044F \u043F\u043E\u043B\u044F \u0413\u0430\u043B\u0443\u0430
    \u043B\u0435\u0436\u0430\u0442 \u0432 \u043E\u0441\u043D\u043E\u0432\u0435 \u0432\u0441\u0435\u0439
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0439
    \u0442\u0435\u0445\u043D\u0438\u043A\u0438. \u041E\u043D\u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F
    \u0432 \u043A\u043E\u0434\u0430\u0445 \u043A\u043E\u0440\u0440\u0435\u043A\u0446\u0438\u0438
    \u043E\u0448\u0438\u0431\u043E\u043A (Reed-Solomon, BCH), \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442 \u0432 CD-\u043F\u043B\u0435\u0435\u0440\u0430\u0445,
    QR-\u043A\u043E\u0434\u0430\u0445 \u0438 \u043A\u043E\u0441\u043C\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0441\u0432\u044F\u0437\u0438, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0432
    \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0432 AES \u2014 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u043C
    \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u0435 \u0448\u0438\u0444\u0440\u043E\u0432\u0430\u043D\u0438\u044F). 
    ---  ### 5. \u041C\u0435\u0442\u043E\u0434\u043E\u043B\u043E\u0433\u0438\u044F:
    \u0410\u043D\u0430\u043B\u0438\u0437 \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043C\u044B\u0435
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u044B  \u0413\u0430\u043B\u0443\u0430
    \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u044B\u043C, \u043A\u0442\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u0442\u0435\u043E\u0440\u0438\u044E
    **\u043D\u0435\u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043C\u044B\u0445 \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432**
    (\u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0435\u043B\u044C\u0437\u044F \u0440\u0430\u0437\u043B\u043E\u0436\u0438\u0442\u044C
    \u043D\u0430 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0434\u0432\u0443\u0445 \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432
    \u043C\u0435\u043D\u044C\u0448\u0435\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0441 \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u0430\u043C\u0438
    \u0432 \u0434\u0430\u043D\u043D\u043E\u043C \u043F\u043E\u043B\u0435) \u0434\u043B\u044F
    \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0438
    \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u0439 \u043F\u043E\u043B\u0435\u0439. 
    \u041E\u043D \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u043F\u0440\u0438\u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u0435
    \u043A\u043E\u0440\u043D\u044F \u043D\u0435\u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043C\u043E\u0433\u043E
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u0430 \u043A \u043F\u043E\u043B\u044E
    \u0440\u0430\u0432\u043D\u043E\u0441\u0438\u043B\u044C\u043D\u043E \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044E
    \u043D\u043E\u0432\u043E\u0433\u043E \u043F\u043E\u043B\u044F. \u042D\u0442\u043E\u0442
    \u043F\u043E\u0434\u0445\u043E\u0434 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B
    \u0435\u043C\u0443 \xAB\u0440\u0430\u0437\u0431\u0438\u0432\u0430\u0442\u044C\xBB
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u043D\u0430 \u0446\u0435\u043F\u043E\u0447\u043A\u0443 \u043F\u0440\u043E\u0441\u0442\u044B\u0445
    \u044D\u0442\u0430\u043F\u043E\u0432 (\u043F\u0440\u0438\u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u0435
    \u043A\u043E\u0440\u043D\u0435\u0439), \u0438 \u0435\u0441\u043B\u0438 \u0432\u0441\u0435
    \u044D\u0442\u0438 \u044D\u0442\u0430\u043F\u044B \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0438\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435\u043C \u043A\u043E\u0440\u043D\u0435\u0439
    (\u0446\u0438\u043A\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0440\u0430\u0441\u0448\u0438\u0440\u0435\u043D\u0438\u044F),
    \u0442\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \u0440\u0435\u0448\u0430\u0435\u043C\u043E. 
    ---  ### 6. \u0421\u0432\u044F\u0437\u044C \u0441 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439
    \u0438 \u0442\u0440\u0438\u0441\u0435\u043A\u0446\u0438\u0435\u0439 \u0443\u0433\u043B\u0430 
    \u0425\u043E\u0442\u044F \u044D\u0442\u043E \u043D\u0435 \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u0430\u044F
    \u0437\u0430\u0441\u043B\u0443\u0433\u0430, \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E \u0442\u0435\u043E\u0440\u0438\u044E \u0434\u043B\u044F
    \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0433\u043E
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0437\u0430\u0434\u0430\u0447
    \u0434\u0440\u0435\u0432\u043D\u0435\u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u0412 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u0442\u0435\u043E\u0440\u0438\u044F \u0413\u0430\u043B\u0443\u0430 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u0441\u0442\u0440\u043E\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C: 
    *   **\u0422\u0440\u0438\u0441\u0435\u043A\u0446\u0438\u0438 \u0443\u0433\u043B\u0430**
    (\u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u0438\u044F \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u0433\u043B\u0430 \u043D\u0430 \u0442\u0440\u0438 \u0440\u0430\u0432\u043D\u044B\u0435
    \u0447\u0430\u0441\u0442\u0438) \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0446\u0438\u0440\u043A\u0443\u043B\u044F \u0438 \u043B\u0438\u043D\u0435\u0439\u043A\u0438.
    *   **\u0423\u0434\u0432\u043E\u0435\u043D\u0438\u044F \u043A\u0443\u0431\u0430**
    (\u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F \u0440\u0435\u0431\u0440\u0430
    \u043A\u0443\u0431\u0430 \u0441 \u0432\u0434\u0432\u043E\u0435 \u0431\u043E\u043B\u044C\u0448\u0438\u043C
    \u043E\u0431\u044A\u0435\u043C\u043E\u043C). *   \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
    \u0447\u0442\u043E \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0439
    17-\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A \u043C\u043E\u0436\u043D\u043E
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C (\u044D\u0442\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0413\u0430\u0443\u0441\u0441, \u043D\u043E \u0442\u0435\u043E\u0440\u0438\u044F
    \u0413\u0430\u043B\u0443\u0430 \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0435\u0442
    *\u043F\u043E\u0447\u0435\u043C\u0443*), \u0430 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0439
    7-\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A \u2014 \u043D\u0435\u043B\u044C\u0437\u044F. 
    ---  ### 7. \u0424\u0435\u043D\u043E\u043C\u0435\u043D \xAB\u0417\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u044F\xBB
    (\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u043F\u0438\u0441\u044C\u043C\u0430) 
    \u0412 \u043D\u043E\u0447\u044C \u043F\u0435\u0440\u0435\u0434 \u0434\u0443\u044D\u043B\u044C\u044E
    \u0413\u0430\u043B\u0443\u0430 \u0432 \u0441\u043F\u0435\u0448\u043A\u0435 \u043D\u0430\u0431\u0440\u043E\u0441\u0430\u043B
    \u043F\u0438\u0441\u044C\u043C\u043E \u0441\u0432\u043E\u0435\u043C\u0443 \u0434\u0440\u0443\u0433\u0443
    \u041E\u0433\u044E\u0441\u0442\u0443 \u0428\u0435\u0432\u0430\u043B\u044C\u0435.
    \u0412 \u044D\u0442\u043E\u043C \u043F\u0438\u0441\u044C\u043C\u0435 \u043E\u043D
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0435\u0440\u0435\u0447\u0438\u0441\u043B\u044F\u043B
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B, \u043E\u043D \u0434\u0430\u0432\u0430\u043B
    **\u0441\u0445\u0435\u043C\u0443 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430**. 
    \u041E\u043D \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    **\xAB\u043F\u0440\u0438\u043C\u0438\u0442\u0438\u0432\u043D\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439\xBB**
    \u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0435\u0441\u043B\u0438
    \u0433\u0440\u0443\u043F\u043F\u0430 \u0413\u0430\u043B\u0443\u0430 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u043F\u0440\u0438\u043C\u0438\u0442\u0438\u0432\u043D\u0430 \u0438 \u043D\u0435
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043F\u043E\u0434\u0433\u0440\u0443\u043F\u043F\u043E\u0439
    \u0430\u0444\u0444\u0438\u043D\u043D\u043E\u0439 \u0433\u0440\u0443\u043F\u043F\u044B,
    \u0442\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \u043D\u0435
    \u0440\u0435\u0448\u0430\u0435\u0442\u0441\u044F \u0432 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0430\u0445.
    \u042D\u0442\u043E \u0431\u044B\u043B \u043D\u0430\u0431\u0440\u043E\u0441\u043E\u043A
    \u043F\u043E\u043B\u043D\u043E\u0439 \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0438. 
    \u0412 \u044D\u0442\u043E\u043C \u0436\u0435 \u043F\u0438\u0441\u044C\u043C\u0435
    \u043E\u043D \u0441 \u0433\u0440\u0443\u0441\u0442\u044C\u044E \u043F\u0438\u0441\u0430\u043B:
    *\xAB\u0412 \u044D\u0442\u043E\u0439 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0435\u0441\u0442\u044C \u043F\u0440\u043E\u0431\u0435\u043B\u044B...
    \u043D\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043D\u0435\u0442\xBB*.
    \u041E\u043D \u043F\u0440\u043E\u0441\u0438\u043B \u0434\u0440\u0443\u0437\u0435\u0439
    \u043D\u0435 \u0441\u0443\u0434\u0438\u0442\u044C \u0435\u0433\u043E \u0441\u0442\u0440\u043E\u0433\u043E
    \u0437\u0430 \u043A\u0440\u0430\u0442\u043A\u043E\u0441\u0442\u044C \u0438 \u043E\u0431\u0435\u0449\u0430\u043B,
    \u0447\u0442\u043E \u043F\u043E\u0437\u0436\u0435 \u0434\u0430\u0441\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0435
    \u0432\u044B\u043A\u043B\u0430\u0434\u043A\u0438 \u2014 \u043D\u043E \u044D\u0442\u0438\u0445
    \xAB\u043F\u043E\u0437\u0436\u0435\xBB \u0443 \u043D\u0435\u0433\u043E \u0443\u0436\u0435
    \u043D\u0435 \u0431\u044B\u043B\u043E.  ---  ### \u0418\u0442\u043E\u0433\u043E\u0432\u043E\u0435
    \u0440\u0435\u0437\u044E\u043C\u0435 \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434\u0430 
    \u0415\u0441\u043B\u0438 \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u0442\u044C
    \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E \u0441\u0436\u0430\u0442\u043E: 
    1.  **\u041F\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0442\u043E\u0447\u043A\u0443**
    \u0432 \u0432\u043E\u043F\u0440\u043E\u0441\u0435 \u043E \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0441\u0442\u0438
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0432 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0430\u0445.
    2.  **\u0421\u043E\u0437\u0434\u0430\u043B \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u0439
    \u044F\u0437\u044B\u043A** (\u0442\u0435\u043E\u0440\u0438\u044F \u0433\u0440\u0443\u043F\u043F),
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043C \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043A \u0430\u043B\u0433\u0435\u0431\u0440\u0435, \u043D\u043E \u0438 \u043A
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0444\u0438\u0437\u0438\u043A\u0435,
    \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438 \u0438
    \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435.
    3.  **\u041E\u0441\u043D\u043E\u0432\u0430\u043B \u043D\u043E\u0432\u043E\u0435
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435** \u2014 \xAB\u0410\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u0443\u044E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0443\xBB, \u0441\u043C\u0435\u0441\u0442\u0438\u0432
    \u0444\u043E\u043A\u0443\u0441 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0441 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439 \u0447\u0438\u0441\u0435\u043B
    \u043D\u0430 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440
    \u0438 \u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u0439.  \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u0431\u044B\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0441\u0436\u0430\u0442\u044B, \u043F\u043B\u043E\u0442\u043D\u044B \u0438 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B,
    \u0447\u0442\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    (\u041A\u043E\u0448\u0438, \u041F\u0443\u0430\u0441\u0441\u043E\u043D, \u0424\u0443\u0440\u044C\u0435)
    \u043D\u0435 \u0441\u043C\u043E\u0433\u043B\u0438 \u0438\u0445 \u043F\u043E\u043D\u044F\u0442\u044C.
    \u041B\u0438\u0448\u044C \u0441\u043F\u0443\u0441\u0442\u044F 14 \u043B\u0435\u0442
    \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438, \u043A\u043E\u0433\u0434\u0430
    \u0416\u043E\u0437\u0435\u0444 \u041B\u0438\u0443\u0432\u0438\u043B\u043B\u044C
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0435\u0433\u043E
    \u043C\u0430\u043D\u0443\u0441\u043A\u0440\u0438\u043F\u0442\u044B \u0432 \u0441\u0432\u043E\u0435\u043C
    \u0436\u0443\u0440\u043D\u0430\u043B\u0435, \u043C\u0438\u0440 \u0443\u0432\u0438\u0434\u0435\u043B,
    \u0447\u0442\u043E \u043E\u0434\u0438\u043D \u044E\u043D\u043E\u0448\u0430 \u043E\u0431\u043E\u0433\u043D\u0430\u043B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 XIX \u0432\u0435\u043A\u0430
    \u043A\u0430\u043A \u043C\u0438\u043D\u0438\u043C\u0443\u043C \u043D\u0430 50
    \u043B\u0435\u0442."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u042D\u0432\u0430\u0440\u0438\u0441\u0442\u0430 \u0413\u0430\u043B\u0443\u0430
    \u0431\u044B\u043B\u0430 \u043A\u043E\u0440\u043E\u0442\u043A\u043E\u0439 \u0438
    \u0431\u0443\u0440\u043D\u043E\u0439, \u0442\u0435\u0441\u043D\u043E \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u043D\u043E\u0439
    \u0441 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u0442\u0440\u0430\u0441\u0442\u044F\u043C\u0438 \u0438 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u044E\u0431\u043E\u0432\u044C\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F,
    \u0441\u043A\u043E\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043E, \u0441\u0442\u0430\u043B\u0430
    \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439 \u0435\u0433\u043E \u0433\u0438\u0431\u0435\u043B\u0438.
    \u0415\u0433\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u2014 \u044D\u0442\u043E \u043A\u043B\u0443\u0431\u043E\u043A
    \u0438\u0437 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0440\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430\u043D\u0441\u0442\u0432\u0430,
    \u0442\u044E\u0440\u0435\u043C\u043D\u043E\u0433\u043E \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F
    \u0438 \u0440\u043E\u043A\u043E\u0432\u043E\u0439 \u0432\u0441\u0442\u0440\u0435\u0447\u0438. 
    ### \u0421\u0435\u043C\u044C\u044F \u0438 \u0440\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B: \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440, \u0437\u0430\u043A\u0430\u043B\u0435\u043D\u043D\u044B\u0439
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439 \u041D\u0430 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438 \u0413\u0430\u043B\u0443\u0430
    \u0441\u0438\u043B\u044C\u043D\u043E \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u0430
    \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u044F. \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u041D\u0438\u043A\u043E\u043B\u044F-\u0413\u0430\u0431\u0440\u0438\u044D\u043B\u044C
    \u0413\u0430\u043B\u0443\u0430, \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u0440\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430\u043D\u0446\u0435\u043C
    \u0438 \u043C\u044D\u0440\u043E\u043C \u0433\u043E\u0440\u043E\u0434\u0430 \u0411\u0443\u0440-\u043B\u0430-\u0420\u0435\u043D.
    \u041E\u0442 \u043D\u0435\u0433\u043E, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u042D\u0432\u0430\u0440\u0438\u0441\u0442 \u0443\u043D\u0430\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F \u0438 \u043D\u0435\u043F\u0440\u0438\u043C\u0438\u0440\u0438\u043C\u043E\u0441\u0442\u044C.
    \u041C\u0430\u0442\u044C, \u0410\u0434\u0435\u043B\u0430\u0438\u0434\u0430-\u041C\u0430\u0440\u0438,
    \u0434\u0430\u043B\u0430 \u0441\u044B\u043D\u0443 \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E\u0435
    \u0434\u043E\u043C\u0430\u0448\u043D\u0435\u0435 \u0433\u0443\u043C\u0430\u043D\u0438\u0442\u0430\u0440\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435, \u043F\u0440\u0438\u0432\u0438\u0432
    \u0435\u043C\u0443 \u043B\u044E\u0431\u043E\u0432\u044C \u043A \u0430\u043D\u0442\u0438\u0447\u043D\u044B\u043C
    \u0433\u0435\u0440\u043E\u044F\u043C, \u0433\u043E\u0442\u043E\u0432\u044B\u043C
    \u043E\u0442\u0434\u0430\u0442\u044C \u0436\u0438\u0437\u043D\u044C \u0437\u0430
    \u0441\u0432\u043E\u0431\u043E\u0434\u0443.  \u0422\u0440\u0430\u0433\u0435\u0434\u0438\u044F,
    \u043D\u0430\u043B\u043E\u0436\u0438\u0432\u0448\u0430\u044F \u043E\u0442\u043F\u0435\u0447\u0430\u0442\u043E\u043A
    \u043D\u0430 \u0432\u0441\u044E \u0435\u0433\u043E \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C, \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430
    2 \u0438\u044E\u043B\u044F 1829 \u0433\u043E\u0434\u0430: \u0435\u0433\u043E
    \u043E\u0442\u0435\u0446 \u043F\u043E\u043A\u043E\u043D\u0447\u0438\u043B \u0441
    \u0441\u043E\u0431\u043E\u0439, \u043D\u0435 \u0432\u044B\u0434\u0435\u0440\u0436\u0430\u0432
    \u0442\u0440\u0430\u0432\u043B\u0438 \u0441\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u044B
    \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u043E\u0432
    \u0438 \u043C\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430.
    \u0414\u043B\u044F 17-\u043B\u0435\u0442\u043D\u0435\u0433\u043E \u042D\u0432\u0430\u0440\u0438\u0441\u0442\u0430
    \u044D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C
    \u043F\u043E\u0442\u0440\u044F\u0441\u0435\u043D\u0438\u0435\u043C, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0443\u0441\u0438\u043B\u0438\u0432\u0448\u0438\u043C \u0435\u0433\u043E \u043D\u0435\u043D\u0430\u0432\u0438\u0441\u0442\u044C
    \u043A \u043D\u0435\u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E\u0441\u0442\u0438
    \u0438 \u0443\u043A\u0440\u0435\u043F\u0438\u0432\u0448\u0438\u043C \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F.  ### \u0422\u044E\u0440\u0435\u043C\u043D\u043E\u0435
    \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435 \u0438 \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E
    \u0441\u043E \u0421\u0442\u0435\u0444\u0430\u043D\u0438 (1831\u20131832) \u0413\u0430\u043B\u0443\u0430
    \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u043D\u043E
    \u0438 \u043F\u043B\u0430\u043C\u0435\u043D\u043D\u044B\u043C \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u0435\u0440\u043E\u043C-\u0440\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430\u043D\u0446\u0435\u043C,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B\u043E \u0435\u0433\u043E
    \u043A \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u044B\u043C \u043A\u043E\u043D\u0444\u043B\u0438\u043A\u0442\u0430\u043C
    \u0441 \u0432\u043B\u0430\u0441\u0442\u044F\u043C\u0438. \u0417\u0430 \u0441\u0432\u043E\u0438
    \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u044B\u0435 \u0432\u044B\u0441\u0442\u0443\u043F\u043B\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0442\u0438\u0432 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u0432\u043B\u0430\u0441\u0442\u0438 \u043E\u043D \u0434\u0432\u0430\u0436\u0434\u044B
    \u043F\u043E\u043F\u0430\u0434\u0430\u043B \u0432 \u0442\u044E\u0440\u044C\u043C\u0443
    \u0421\u0435\u043D\u0442-\u041F\u0435\u043B\u0430\u0436\u0438. \u0412\u0442\u043E\u0440\u043E\u0435
    \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435 \u0434\u043B\u0438\u043B\u043E\u0441\u044C
    \u0441 \u0438\u044E\u043B\u044F 1831 \u0433\u043E\u0434\u0430 \u043F\u043E \u043C\u0430\u0440\u0442
    1832 \u0433\u043E\u0434\u0430.  \u0418\u0437-\u0437\u0430 \u044D\u043F\u0438\u0434\u0435\u043C\u0438\u0438
    \u0445\u043E\u043B\u0435\u0440\u044B \u0432 \u041F\u0430\u0440\u0438\u0436\u0435
    \u0435\u0433\u043E \u043F\u0435\u0440\u0435\u0432\u0435\u043B\u0438 \u0438\u0437
    \u0442\u044E\u0440\u044C\u043C\u044B \u0432 \u0447\u0430\u0441\u0442\u043D\u0443\u044E
    \u043B\u0435\u0447\u0435\u0431\u043D\u0438\u0446\u0443, \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u043B \u0434\u043E\u043A\u0442\u043E\u0440
    \u0416\u0430\u043D-\u041B\u0443\u0438 \u041F\u043E\u0442\u0435\u0440\u0435\u043D-\u0414\u044E\u043C\u043E\u0442\u0435\u043B\u044C.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C, \u0432 \u0441\u0442\u0435\u043D\u0430\u0445
    \u044D\u0442\u043E\u0439 \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u044B, \u0413\u0430\u043B\u0443\u0430
    \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B **\u0421\u0442\u0435\u0444\u0430\u043D\u0438-\u0424\u0435\u043B\u0438\u0441\u0438
    \u041F\u043E\u0442\u0435\u0440\u0435\u043D \u0434\u044E \u041C\u043E\u0442\u0435\u043B\u044C**,
    \u0434\u043E\u0447\u044C \u0432\u0440\u0430\u0447\u0430. \u042D\u0442\u043E \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E
    \u0441\u0442\u0430\u043B\u043E \u0440\u043E\u043A\u043E\u0432\u044B\u043C.  ###
    \"\u0411\u0435\u0441\u0447\u0435\u0441\u0442\u043D\u0430\u044F \u043A\u043E\u043A\u0435\u0442\u043A\u0430\"
    \u0438 \u0440\u043E\u043A\u043E\u0432\u0430\u044F \u0434\u0443\u044D\u043B\u044C
    \u0418\u0437 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432\u0448\u0438\u0445\u0441\u044F
    \u043F\u0438\u0441\u0435\u043C \u0413\u0430\u043B\u0443\u0430 \u044F\u0441\u043D\u043E,
    \u0447\u0442\u043E \u043E\u043D \u0431\u044B\u043B \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u043E
    \u0432\u043B\u044E\u0431\u043B\u0435\u043D \u0432 \u0421\u0442\u0435\u0444\u0430\u043D\u0438.
    \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E
    \u043E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430 \u0433\u043B\u0430\u0432\u043D\u043E\u0439
    \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439 \u0435\u0433\u043E \u0433\u0438\u0431\u0435\u043B\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0438\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0431\u044B\u043B\u0438 \u043C\u0443\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u0438, \u043F\u043E-\u0432\u0438\u0434\u0438\u043C\u043E\u043C\u0443, \u0431\u0435\u0437\u043E\u0442\u0432\u0435\u0442\u043D\u044B\u043C\u0438.
    \u0412 \u043F\u0438\u0441\u044C\u043C\u0435 \u0434\u0440\u0443\u0433\u0443 \u041E\u0433\u044E\u0441\u0442\u0443
    \u0428\u0435\u0432\u0430\u043B\u044C\u0435 \u0437\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0434\u043D\u0435\u0439 \u0434\u043E \u0434\u0443\u044D\u043B\u0438 \u043E\u043D
    \u0441 \u0433\u043E\u0440\u0435\u0447\u044C\u044E \u043F\u0438\u0441\u0430\u043B
    \u043E \u043F\u0435\u0440\u0435\u0436\u0438\u0442\u043E\u0439 \u0431\u0443\u0440\u0435
    \u0441\u0442\u0440\u0430\u0441\u0442\u0435\u0439: *\xAB\u041D\u043E \u043A\u0430\u043A
    \u0438\u0437\u0433\u043B\u0430\u0434\u0438\u0442\u044C \u0441\u043B\u0435\u0434\u044B
    \u0442\u043E\u0439 \u0431\u0443\u0440\u0438 \u0441\u0442\u0440\u0430\u0441\u0442\u0435\u0439,
    \u0447\u0435\u0440\u0435\u0437 \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u044F
    \u043F\u0440\u043E\u0448\u0451\u043B? \u041A\u0430\u043A \u0443\u0442\u0435\u0448\u0438\u0442\u044C\u0441\u044F,
    \u043A\u043E\u0433\u0434\u0430 \u0437\u0430 \u043E\u0434\u0438\u043D \u043C\u0435\u0441\u044F\u0446
    \u0438\u0441\u0447\u0435\u0440\u043F\u0430\u043D \u0434\u043E \u0434\u043D\u0430
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A \u0441\u0430\u043C\u043E\u0433\u043E
    \u0441\u043B\u0430\u0434\u043E\u0441\u0442\u043D\u043E\u0433\u043E \u0431\u043B\u0430\u0436\u0435\u043D\u0441\u0442\u0432\u0430...\xBB*. 
    \u0421\u0430\u043C \u0413\u0430\u043B\u0443\u0430 \u0432 \u043F\u0440\u0435\u0434\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u0445
    \u043F\u0438\u0441\u044C\u043C\u0430\u0445 \u043D\u0430\u0437\u044B\u0432\u0430\u043B
    \u0441\u0435\u0431\u044F *\xAB\u0436\u0435\u0440\u0442\u0432\u043E\u0439 \u0431\u0435\u0441\u0447\u0435\u0441\u0442\u043D\u043E\u0439
    \u043A\u043E\u043A\u0435\u0442\u043A\u0438 \u0438 \u0434\u0432\u0443\u0445 \u0433\u043B\u0443\u043F\u0446\u043E\u0432,
    \u043E\u0431\u043C\u0430\u043D\u0443\u0442\u044B\u0445 \u0435\u044E\xBB*. \u0421\u0442\u0435\u0444\u0430\u043D\u0438
    \u0443\u0436\u0435 \u0431\u044B\u043B\u0430 \u043F\u043E\u043C\u043E\u043B\u0432\u043B\u0435\u043D\u0430
    \u0441 \u043D\u0435\u043A\u0438\u043C \u0433\u043E\u0441\u043F\u043E\u0434\u0438\u043D\u043E\u043C
    \u043F\u043E \u0438\u043C\u0435\u043D\u0438 **\u041F\u0435\u0448\u043E \u0434'\u042D\u0440\u0431\u0435\u043D\u0432\u0438\u043B\u043B\u044C**
    (\u043F\u043E \u0434\u0440\u0443\u0433\u0438\u043C \u0434\u0430\u043D\u043D\u044B\u043C,
    \u0434\u0443\u044D\u043B\u044C \u043C\u043E\u0433\u043B\u0430 \u0431\u044B\u0442\u044C
    \u0441 \u0435\u0433\u043E \u0442\u043E\u0432\u0430\u0440\u0438\u0449\u0435\u043C-\u0440\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430\u043D\u0446\u0435\u043C
    \u042D\u0440\u043D\u0435\u0441\u0442\u043E\u043C \u0414\u044E\u0448\u0430\u0442\u043B\u0435,
    \u0447\u044C\u0438 \u0438\u043D\u0438\u0446\u0438\u0430\u043B\u044B \"L.D.\"
    \u0444\u0438\u0433\u0443\u0440\u0438\u0440\u0443\u044E\u0442 \u0432 \u0433\u0430\u0437\u0435\u0442\u043D\u044B\u0445
    \u043E\u0442\u0447\u0435\u0442\u0430\u0445).  \u0423\u0442\u0440\u043E\u043C
    30 \u043C\u0430\u044F 1832 \u0433\u043E\u0434\u0430 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0430\u0441\u044C
    \u0434\u0443\u044D\u043B\u044C. \u041E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0435\u0435 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u0432\u044B\u0437\u044B\u0432\u0430\u044E\u0442
    \u0441\u043F\u043E\u0440\u044B. \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0432\u0435\u0440\u0441\u0438\u0439,
    \u0434\u0443\u044D\u043B\u044C \u0431\u044B\u043B\u0430 \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441 \u043B\u044E\u0431\u043E\u0432\u043D\u043E\u0439
    \u0438\u043D\u0442\u0440\u0438\u0433\u043E\u0439, \u0438 \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u0438
    \u0441\u0442\u0440\u0435\u043B\u044F\u043B\u0438\u0441\u044C \u0432 \u0443\u043F\u043E\u0440,
    \u043F\u043E\u043B\u0430\u0433\u0430\u044F\u0441\u044C \u043D\u0430 \u0441\u0443\u0434\u044C\u0431\u0443,
    \u043F\u0440\u0438\u0447\u0435\u043C \u0437\u0430\u0440\u044F\u0436\u0435\u043D
    \u0431\u044B\u043B \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0434\u0438\u043D
    \u043F\u0438\u0441\u0442\u043E\u043B\u0435\u0442. \u041F\u0443\u043B\u044F \u043F\u043E\u043F\u0430\u043B\u0430
    \u0413\u0430\u043B\u0443\u0430 \u0432 \u0436\u0438\u0432\u043E\u0442, \u043E\u043D
    \u0431\u044B\u043B \u0441\u043C\u0435\u0440\u0442\u0435\u043B\u044C\u043D\u043E
    \u0440\u0430\u043D\u0435\u043D. \u0415\u0433\u043E \u0431\u0440\u043E\u0441\u0438\u043B\u0438
    \u0443\u043C\u0438\u0440\u0430\u0442\u044C \u043D\u0430 \u043C\u0435\u0441\u0442\u0435
    \u0434\u0443\u044D\u043B\u0438, \u0438 \u043B\u0438\u0448\u044C \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0447\u0430\u0441\u043E\u0432 \u0441\u043F\u0443\u0441\u0442\u044F \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0439
    \u043F\u0440\u043E\u0445\u043E\u0436\u0438\u0439 \u043D\u0430\u0448\u0435\u043B
    \u0435\u0433\u043E \u0438 \u043E\u0442\u0432\u0435\u0437 \u0432 \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u0443
    \u041A\u043E\u0448\u0435\u043D, \u0433\u0434\u0435 \u043D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
    \u0434\u0435\u043D\u044C, 31 \u043C\u0430\u044F, \u043E\u043D \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F. 
    \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442 \u0442\u0430\u043A\u0436\u0435
    \u0441\u0442\u043E\u0439\u043A\u0438\u0435 \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u043D\u0438\u044F,
    \u0447\u0442\u043E \u0434\u0443\u044D\u043B\u044C \u0431\u044B\u043B\u0430 \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u043B\u044E\u0431\u043E\u0432\u043D\u043E\u0439
    \u0434\u0440\u0430\u043C\u043E\u0439, \u0430 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u0440\u043E\u0432\u043E\u043A\u0430\u0446\u0438\u0435\u0439, \u043F\u043E\u0434\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u043E\u0439
    \u0440\u043E\u044F\u043B\u0438\u0441\u0442\u0430\u043C\u0438, \u0447\u0442\u043E\u0431\u044B
    \u0440\u0430\u0441\u043F\u0440\u0430\u0432\u0438\u0442\u044C\u0441\u044F \u0441
    \u043E\u043F\u0430\u0441\u043D\u044B\u043C \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u0435\u0440\u043E\u043C.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0441\u0430\u043C\u0438 \u043F\u0438\u0441\u044C\u043C\u0430
    \u0413\u0430\u043B\u0443\u0430, \u0433\u0434\u0435 \u043E\u043D \u043F\u0440\u043E\u0441\u0438\u0442
    \u043D\u0435 \u0432\u0438\u043D\u0438\u0442\u044C \u0435\u0433\u043E \u0443\u0431\u0438\u0439\u0446,
    \u0442\u0430\u043A \u043A\u0430\u043A \"\u043E\u043D\u0438 \u0431\u044B\u043B\u0438
    \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0438\", \u0432\u043D\u043E\u0441\u044F\u0442
    \u0432 \u044D\u0442\u0443 \u0438\u0441\u0442\u043E\u0440\u0438\u044E \u0435\u0449\u0435
    \u0431\u043E\u043B\u044C\u0448\u0435 \u0437\u0430\u0433\u0430\u0434\u043E\u043A. 
    \u0422\u0430\u043A, \u043B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0413\u0430\u043B\u0443\u0430, \u043F\u043E\u043B\u043D\u0430\u044F \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0439,
    \u0442\u044E\u0440\u0435\u043C\u043D\u044B\u0445 \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0439
    \u0438 \u0431\u0435\u0437\u043E\u0442\u0432\u0435\u0442\u043D\u043E\u0439 \u043B\u044E\u0431\u0432\u0438,
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u043E\u0431\u043E\u0440\u0432\u0430\u043B\u0430\u0441\u044C
    \u043D\u0430 \u0434\u0443\u044D\u043B\u0438, \u043E\u0441\u0442\u0430\u0432\u0438\u0432
    \u043F\u043E\u0442\u043E\u043C\u043A\u0430\u043C \u0435\u0433\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F, \u0437\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u044B\u0435
    \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044E\u044E \u0431\u0435\u0441\u0441\u043E\u043D\u043D\u0443\u044E
    \u043D\u043E\u0447\u044C \u043F\u0435\u0440\u0435\u0434 \u0441\u043C\u0435\u0440\u0442\u044C\u044E."
  personalLifeEn: 
  shortBioRu: "\u042D\u0432\u0430\u0440\u0438\u0441\u0442 \u0413\u0430\u043B\u0443\u0430
    \u2014 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A,
    \u043F\u0440\u043E\u0436\u0438\u0432\u0448\u0438\u0439 \u0432\u0441\u0435\u0433\u043E
    20 \u043B\u0435\u0442, \u043D\u043E \u0443\u0441\u043F\u0435\u0432\u0448\u0438\u0439
    \u0437\u0430\u043B\u043E\u0436\u0438\u0442\u044C \u043E\u0441\u043D\u043E\u0432\u044B
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u044B.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430 \u043D\u0435\u0440\u0430\u0437\u0440\u044B\u0432\u043D\u043E
    \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441 \u043D\u0430\u0443\u043A\u043E\u0439,
    \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u043E\u0439 \u0438 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0435\u0439.
    \u0412\u043E\u0442 \u0435\u0433\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F.  ### \U0001F4DC \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B (1811\u20131823) 
    \u042D\u0432\u0430\u0440\u0438\u0441\u0442 \u0413\u0430\u043B\u0443\u0430 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    25 \u043E\u043A\u0442\u044F\u0431\u0440\u044F 1811 \u0433\u043E\u0434\u0430 \u0432
    \u0433\u043E\u0440\u043E\u0434\u043A\u0435 \u0411\u0443\u0440-\u043B\u0430-\u0420\u0435\u043D,
    \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E \u043E\u0442 \u041F\u0430\u0440\u0438\u0436\u0430.
    \u041E\u043D \u0431\u044B\u043B \u0432\u0442\u043E\u0440\u044B\u043C \u0440\u0435\u0431\u0435\u043D\u043A\u043E\u043C
    \u0432 \u0441\u0435\u043C\u044C\u0435.  *   **\u0421\u0435\u043C\u044C\u044F
    \u0438 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0435:** \u0415\u0433\u043E
    \u043E\u0442\u0435\u0446, \u041D\u0438\u043A\u043E\u043B\u044F-\u0413\u0430\u0431\u0440\u0438\u044D\u043B\u044C
    \u0413\u0430\u043B\u0443\u0430, \u0431\u044B\u043B \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C
    \u0440\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430\u043D\u0446\u0435\u043C
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u043B \u043F\u043E\u0441\u0442 \u043C\u044D\u0440\u0430
    \u0433\u043E\u0440\u043E\u0434\u0430. \u041C\u0430\u0442\u044C, \u0410\u0434\u0435\u043B\u0430\u0438\u0434\u0430-\u041C\u0430\u0440\u0438
    \u0414\u0435\u043C\u0430\u043D\u0442, \u0431\u044B\u043B\u0430 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439 \u0438 \u0441\u0442\u0430\u043B\u0430
    \u043F\u0435\u0440\u0432\u044B\u043C \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C
    \u0441\u044B\u043D\u0430, \u043F\u0440\u0438\u0432\u0438\u0432 \u0435\u043C\u0443
    \u043B\u044E\u0431\u043E\u0432\u044C \u043A \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0435 \u0438 \u043B\u0430\u0442\u044B\u043D\u0438. 
    ### \U0001F393 \u0428\u043A\u043E\u043B\u044C\u043D\u044B\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0433\u0435\u043D\u0438\u044F
    (1823\u20131829)  \u0412 12 \u043B\u0435\u0442 \u0413\u0430\u043B\u0443\u0430
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439,
    \u043D\u043E \u0441\u0443\u0440\u043E\u0432\u044B\u0439 \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u0438\u0439
    \u043A\u043E\u043B\u043B\u0435\u0436 \u041B\u0443\u0438-\u043B\u0435-\u0413\u0440\u0430\u043D
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435. \u0423\u0447\u0435\u0431\u043D\u043E\u0435
    \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0441\u043B\u0430\u0432\u0438\u043B\u043E\u0441\u044C
    \u0441\u0442\u0440\u043E\u0433\u043E\u0439 \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u043E\u0439,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0434\u043B\u044F \u043D\u0435\u0433\u043E
    \u0442\u044F\u0436\u0435\u043B\u044B\u043C \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u0435\u043C. 
    *   **\u041F\u0440\u043E\u0431\u0443\u0436\u0434\u0435\u043D\u0438\u0435 \u0442\u0430\u043B\u0430\u043D\u0442\u0430:**
    \u0414\u043E 15 \u043B\u0435\u0442 \u0413\u0430\u043B\u0443\u0430 \u043D\u0435
    \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B \u043E\u0441\u043E\u0431\u043E\u0433\u043E
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0430 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u043D\u043E \u0432\u0441\u0435 \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u043E\u0441\u044C,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u0442\u0440\u0443\u0434\u044B \u0432\u0435\u043B\u0438\u043A\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432. \u041E\u043D
    \"\u043A\u0430\u043A \u0440\u043E\u043C\u0430\u043D\" \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043B
    \"\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E\" \u041B\u0435\u0436\u0430\u043D\u0434\u0440\u0430,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0443\u0433\u043B\u0443\u0431\u0438\u043B\u0441\u044F
    \u0432 \u0440\u0430\u0431\u043E\u0442\u044B \u041B\u0430\u0433\u0440\u0430\u043D\u0436\u0430
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439.
    \u041F\u043E \u0441\u043B\u043E\u0432\u0430\u043C \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439,
    \u0438\u043C\u0435\u043D\u043D\u043E \u0437\u0430\u043D\u044F\u0442\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u0438
    \u0435\u0433\u043E \u0438\u0437 \u043F\u043E\u0441\u043B\u0443\u0448\u043D\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u0438\u043A\u0430 \u0432 \"\u043E\u0434\u0435\u0440\u0436\u0438\u043C\u043E\u0433\u043E\"
    \u0433\u0435\u043D\u0438\u044F. *   **\u041D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A:**
    \u0412 1828 \u0433\u043E\u0434\u0443 \u0435\u0433\u043E \u0442\u0430\u043B\u0430\u043D\u0442
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u041B\u0443\u0438 \u0420\u0438\u0448\u0430\u0440, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u043B \u044E\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0438 \u043F\u043E\u043C\u043E\u0433
    \u0435\u043C\u0443 \u0432 \u0435\u0433\u043E \u043F\u0435\u0440\u0432\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\u0445. 
    ### \U0001F6AB \u041D\u0435\u0443\u0434\u0430\u0447\u0438, \u043F\u043E\u0442\u0435\u0440\u0438
    \u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    (1829)  \u042D\u0442\u043E\u0442 \u0433\u043E\u0434 \u0441\u0442\u0430\u043B
    \u043F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u043C \u0438 \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0432 \u0436\u0438\u0437\u043D\u0438 \u0413\u0430\u043B\u0443\u0430.  *   **\u041F\u0440\u043E\u0432\u0430\u043B
    \u0432 \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443:** \u0413\u0430\u043B\u0443\u0430 \u0434\u0432\u0430\u0436\u0434\u044B
    \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u0442\u044C
    \u0432 \u0441\u0430\u043C\u0443\u044E \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E
    \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443. \u041D\u0430 \u0443\u0441\u0442\u043D\u044B\u0445
    \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0430\u0445 \u0435\u0433\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0431\u044B\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043A\u0440\u0430\u0442\u043A\u0438\u043C\u0438 \u0438 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u043C\u0438,
    \u0447\u0442\u043E \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0430\u0442\u043E\u0440\u044B
    \u043D\u0435 \u043C\u043E\u0433\u043B\u0438 \u0438\u0445 \u043F\u043E\u043D\u044F\u0442\u044C.
    \u041F\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435, \u0432 \u043E\u0442\u0447\u0430\u044F\u043D\u0438\u0438
    \u043E\u0442 \u043D\u0435\u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u044F,
    \u043E\u043D \u0448\u0432\u044B\u0440\u043D\u0443\u043B \u0442\u0440\u044F\u043F\u043A\u0443
    \u0434\u043B\u044F \u0441\u0442\u0438\u0440\u0430\u043D\u0438\u044F \u0434\u043E\u0441\u043A\u0438
    \u0432 \u0433\u043E\u043B\u043E\u0432\u0443 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0430\u0442\u043E\u0440\u0443,
    \u0447\u0442\u043E \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0437\u0430\u043A\u0440\u044B\u043B\u043E \u0435\u043C\u0443 \u043F\u0443\u0442\u044C
    \u0432 \u044D\u0442\u043E \u0443\u0447\u0435\u0431\u043D\u043E\u0435 \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0435.
    *   **\u0421\u043C\u0435\u0440\u0442\u044C \u043E\u0442\u0446\u0430:** 2 \u0438\u044E\u043B\u044F
    1829 \u0433\u043E\u0434\u0430 \u0435\u0433\u043E \u043E\u0442\u0435\u0446 \u043F\u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0441 \u0441\u043E\u0431\u043E\u0439. \u041F\u0440\u0438\u0447\u0438\u043D\u043E\u0439
    \u0441\u0442\u0430\u043B\u0430 \u0442\u0440\u0430\u0432\u043B\u044F \u0441\u043E
    \u0441\u0442\u043E\u0440\u043E\u043D\u044B \u043C\u0435\u0441\u0442\u043D\u043E\u0433\u043E
    \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430, \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0438\u0432\u0448\u0435\u0433\u043E
    \u043A\u043B\u0435\u0432\u0435\u0442\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0430\u043C\u0444\u043B\u0435\u0442\u044B. *   **\u041F\u0435\u0440\u0432\u0430\u044F
    \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \u0438 \u043F\u043E\u0442\u0435\u0440\u044F:** \u0412 17 \u043B\u0435\u0442 \u0413\u0430\u043B\u0443\u0430
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u0441\u0432\u043E\u044E
    \u043F\u0435\u0440\u0432\u0443\u044E \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043E \u0446\u0435\u043F\u043D\u044B\u0445
    \u0434\u0440\u043E\u0431\u044F\u0445. \u0412 \u0442\u043E\u043C \u0436\u0435
    \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0443\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E
    \u043D\u0430\u0443\u043A \u0441\u0432\u043E\u0439 \u0433\u043B\u0430\u0432\u043D\u044B\u0439
    \u043C\u0435\u043C\u0443\u0430\u0440 \u043E \u0440\u0435\u0448\u0435\u043D\u0438\u0438
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. \u0420\u0435\u0446\u0435\u043D\u0437\u0435\u043D\u0442,
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0439\u0441\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u041E\u0433\u044E\u0441\u0442\u0435\u043D \u041B\u0443\u0438 \u041A\u043E\u0448\u0438,
    \u043E\u0434\u043E\u0431\u0440\u0438\u043B \u0440\u0430\u0431\u043E\u0442\u0443,
    \u043D\u043E \u043F\u043E\u0442\u0435\u0440\u044F\u043B \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C,
    \u0442\u0430\u043A \u0438 \u043D\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0432
    \u0435\u0435 \u0432 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E. \u042D\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u0440\u043E\u043A\u043E\u0432\u044B\u043C \u043D\u0430\u0447\u0430\u043B\u043E\u043C
    \u0447\u0435\u0440\u0435\u0434\u044B \u043D\u0435\u0443\u0434\u0430\u0447 \u0441
    \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F\u043C\u0438 \u0435\u0433\u043E
    \u0433\u043B\u0430\u0432\u043D\u043E\u0433\u043E \u0442\u0440\u0443\u0434\u0430. 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043D\u0435\u0443\u0434\u0430\u0447\u0438,
    \u0432 1829 \u0433\u043E\u0434\u0443 \u0413\u0430\u043B\u0443\u0430 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u043C\u0435\u043D\u0435\u0435 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u0443\u044E
    \u0412\u044B\u0441\u0448\u0443\u044E \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 (\u0442\u043E\u0433\u0434\u0430 \u2014 \u041F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0448\u043A\u043E\u043B\u0430).  ### \U0001F3DB\uFE0F \u0412 \u0432\u043E\u0434\u043E\u0432\u043E\u0440\u043E\u0442\u0435
    \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u0438 (1830\u20131831)  \u0413\u043E\u0434\u044B
    \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u044F \u0432 \u0412\u044B\u0441\u0448\u0435\u0439
    \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u0448\u043A\u043E\u043B\u0435
    \u0441\u043E\u0432\u043F\u0430\u043B\u0438 \u0441 \u043F\u0435\u0440\u0438\u043E\u0434\u043E\u043C
    \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043F\u043E\u0442\u0440\u044F\u0441\u0435\u043D\u0438\u0439
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438.  *   **\u0418\u044E\u043B\u044C\u0441\u043A\u0430\u044F
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F 1830 \u0433\u043E\u0434\u0430:**
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438,
    \u0441\u0432\u0435\u0440\u0433\u043D\u0443\u0432\u0448\u0435\u0439 \u043A\u043E\u0440\u043E\u043B\u044F
    \u041A\u0430\u0440\u043B\u0430 X, \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440
    \u0448\u043A\u043E\u043B\u044B \u0437\u0430\u043F\u0435\u0440 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432
    \u0432\u043D\u0443\u0442\u0440\u0438, \u0447\u0442\u043E\u0431\u044B \u043E\u043D\u0438
    \u043D\u0435 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u0432 \u0443\u043B\u0438\u0447\u043D\u044B\u0445 \u0431\u043E\u044F\u0445. \u0412\u043E\u0437\u043C\u0443\u0449\u0435\u043D\u043D\u044B\u0439
    \u044D\u0442\u0438\u043C, \u0413\u0430\u043B\u0443\u0430 \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0440\u0435\u0437\u043A\u043E\u0435 \u043F\u0438\u0441\u044C\u043C\u043E \u0441
    \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0439 \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u0430,
    \u0437\u0430 \u0447\u0442\u043E \u0432 \u043D\u0430\u0447\u0430\u043B\u0435 1831
    \u0433\u043E\u0434\u0430 \u0431\u044B\u043B \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D.
    *   **\u0410\u043A\u0442\u0438\u0432\u043D\u0430\u044F \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043F\u043E\u0437\u0438\u0446\u0438\u044F:** \u0413\u0430\u043B\u0443\u0430
    \u0431\u044B\u043B \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u043C
    \u0440\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430\u043D\u0446\u0435\u043C
    \u0438 \u0432\u0441\u0442\u0443\u043F\u0438\u043B \u0432 \u0442\u0430\u0439\u043D\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E \"\u0414\u0440\u0443\u0437\u044C\u044F
    \u043D\u0430\u0440\u043E\u0434\u0430\". \u041E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u0432 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0430\u043A\u0446\u0438\u044F\u0445, \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E
    \u043A \u0435\u0433\u043E \u0430\u0440\u0435\u0441\u0442\u0430\u043C.  ### \u26D3\uFE0F
    \u0422\u044E\u0440\u044C\u043C\u0430, \u043B\u044E\u0431\u043E\u0432\u044C \u0438
    \u0434\u0443\u044D\u043B\u044C (1831\u20131832)  \u041F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0438
    \u043B\u0438\u0447\u043D\u0430\u044F \u0434\u0440\u0430\u043C\u0430 \u043F\u0440\u0438\u0432\u0435\u043B\u0438
    \u0413\u0430\u043B\u0443\u0430 \u043A \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u043C\u0443
    \u0444\u0438\u043D\u0430\u043B\u0443.  *   **\u0410\u0440\u0435\u0441\u0442\u044B:**
    10 \u043C\u0430\u044F 1831 \u0433\u043E\u0434\u0430 \u043E\u043D \u0431\u044B\u043B
    \u0430\u0440\u0435\u0441\u0442\u043E\u0432\u0430\u043D \u0437\u0430 \u0442\u043E\u0441\u0442
    \u0441 \u043A\u0438\u043D\u0436\u0430\u043B\u043E\u043C \u0432 \u0447\u0435\u0441\u0442\u044C
    \u043A\u043E\u0440\u043E\u043B\u044F \u041B\u0443\u0438-\u0424\u0438\u043B\u0438\u043F\u043F\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u043B \u0440\u0430\u0441\u0446\u0435\u043D\u0435\u043D
    \u043A\u0430\u043A \u0443\u0433\u0440\u043E\u0437\u0430. \u0415\u0433\u043E \u043E\u043F\u0440\u0430\u0432\u0434\u0430\u043B\u0438,
    \u043D\u043E \u0443\u0436\u0435 14 \u0438\u044E\u043B\u044F \u043E\u043D \u0431\u044B\u043B
    \u0432\u043D\u043E\u0432\u044C \u0430\u0440\u0435\u0441\u0442\u043E\u0432\u0430\u043D
    \u0438 \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\u0435\u043D \u043A \u0448\u0435\u0441\u0442\u0438
    \u043C\u0435\u0441\u044F\u0446\u0430\u043C \u0442\u044E\u0440\u0435\u043C\u043D\u043E\u0433\u043E
    \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F \u0437\u0430 \u043D\u043E\u0448\u0435\u043D\u0438\u0435
    \u0432\u043E\u0435\u043D\u043D\u043E\u0439 \u0444\u043E\u0440\u043C\u044B \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043D\u043E\u0439
    \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u0447\u0430\u0441\u0442\u0438 \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u0433\u0432\u0430\u0440\u0434\u0438\u0438. *   **\u0412 \u0442\u044E\u0440\u044C\u043C\u0435:**
    \u0412 \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0438 \u0413\u0430\u043B\u0443\u0430
    \u043D\u0435 \u043F\u0440\u0435\u043A\u0440\u0430\u0449\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u043D\u044F\u0442\u0438\u0439. \u0422\u0430\u043C \u043E\u043D,
    \u043F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C,
    \u043F\u0435\u0440\u0435\u0436\u0438\u043B \u043D\u0435\u0440\u0432\u043D\u044B\u0439
    \u0441\u0440\u044B\u0432 \u0438 \u0434\u0430\u0436\u0435 \u043F\u044B\u0442\u0430\u043B\u0441\u044F
    \u043F\u043E\u043A\u043E\u043D\u0447\u0438\u0442\u044C \u0441 \u0441\u043E\u0431\u043E\u0439.
    *   **\u0420\u043E\u043A\u043E\u0432\u0430\u044F \u043B\u044E\u0431\u043E\u0432\u044C:**
    \u041F\u043E\u0441\u043B\u0435 \u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0432 \u0430\u043F\u0440\u0435\u043B\u0435 1832 \u0433\u043E\u0434\u0430 \u043E\u043D
    \u0436\u0438\u043B \u0432 \u043F\u0430\u043D\u0441\u0438\u043E\u043D\u0435, \u0433\u0434\u0435
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F \u0441\u043E
    \u0421\u0442\u0435\u0444\u0430\u043D\u0438 \u041F\u043E\u0442\u0435\u0440\u0435\u043D-\u0414\u044E\u043C\u043E\u0442\u0435\u043B\u044C,
    \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u0432\u0440\u0430\u0447\u0430. \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u043D\u0435\u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u043D\u0430\u044F
    \u0438\u043B\u0438 \u0437\u0430\u043F\u0440\u0435\u0442\u043D\u0430\u044F \u043B\u044E\u0431\u043E\u0432\u044C
    \u043A \u043D\u0435\u0439 \u0441\u0442\u0430\u043B\u0430 \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439
    \u0435\u0433\u043E \u0434\u0443\u044D\u043B\u0438.  ### \U0001F940 \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F
    \u043D\u043E\u0447\u044C \u0438 \u0441\u043C\u0435\u0440\u0442\u044C (1832) 
    \u0423\u0442\u0440\u043E\u043C 30 \u043C\u0430\u044F 1832 \u0433\u043E\u0434\u0430
    \u0413\u0430\u043B\u0443\u0430 \u0431\u044B\u043B \u0441\u043C\u0435\u0440\u0442\u0435\u043B\u044C\u043D\u043E
    \u0440\u0430\u043D\u0435\u043D \u0432 \u0436\u0438\u0432\u043E\u0442 \u043D\u0430
    \u0434\u0443\u044D\u043B\u0438. \u041E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0434\u0443\u044D\u043B\u0438 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440
    \u0442\u043E\u0447\u043D\u043E \u043D\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B:
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442\u0441\u044F \u043A\u0430\u043A
    \u043B\u044E\u0431\u043E\u0432\u043D\u0430\u044F \u0438\u043D\u0442\u0440\u0438\u0433\u0430,
    \u0442\u0430\u043A \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043F\u0440\u043E\u0432\u043E\u043A\u0430\u0446\u0438\u044F \u0440\u043E\u044F\u043B\u0438\u0441\u0442\u043E\u0432. 
    *   **\u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0435:**
    \u041D\u0430\u043A\u0430\u043D\u0443\u043D\u0435 \u0434\u0443\u044D\u043B\u0438,
    \u043F\u0440\u0435\u0434\u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044F \u0441\u0432\u043E\u044E
    \u0433\u0438\u0431\u0435\u043B\u044C, \u0413\u0430\u043B\u0443\u0430 \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043F\u0438\u0441\u0435\u043C,
    \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0431\u044B\u043B\u043E \u0430\u0434\u0440\u0435\u0441\u043E\u0432\u0430\u043D\u043E
    \u0435\u0433\u043E \u0434\u0440\u0443\u0433\u0443 \u041E\u0433\u044E\u0441\u0442\u0443
    \u0428\u0435\u0432\u0430\u043B\u044C\u0435. \u0412 \u043D\u0435\u043C \u043E\u043D
    \u0432 \u0441\u043F\u0435\u0448\u043A\u0435 \u0438\u0437\u043B\u043E\u0436\u0438\u043B
    \u0441\u0432\u043E\u0438 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0434\u0435\u0438, \u0443\u043C\u043E\u043B\u044F\u044F \u0434\u0440\u0443\u0433\u0430
    \u043F\u0435\u0440\u0435\u0434\u0430\u0442\u044C \u0438\u0445 \u0443\u0447\u0435\u043D\u044B\u043C.
    *   **\u0413\u0438\u0431\u0435\u043B\u044C:** \u041D\u0430 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
    \u0434\u0435\u043D\u044C, 31 \u043C\u0430\u044F 1832 \u0433\u043E\u0434\u0430,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 20 \u043B\u0435\u0442,
    \u0413\u0430\u043B\u0443\u0430 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F.
    \u041F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D \u043D\u0430 \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435
    \u041C\u043E\u043D\u043F\u0430\u0440\u043D\u0430\u0441.  ### \U0001F4A1 \u041D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  \u0413\u043B\u0430\u0432\u043D\u0430\u044F
    \u0437\u0430\u0441\u043B\u0443\u0433\u0430 \u0413\u0430\u043B\u0443\u0430 \u043F\u0435\u0440\u0435\u0434
    \u043D\u0430\u0443\u043A\u043E\u0439 \u2014 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    **\u0442\u0435\u043E\u0440\u0438\u0438 \u0413\u0430\u043B\u0443\u0430**, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0430 \u0433\u043B\u0443\u0431\u043E\u043A\u0443\u044E
    \u0441\u0432\u044F\u0437\u044C \u043C\u0435\u0436\u0434\u0443 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u0433\u0440\u0443\u043F\u043F \u0438 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u043F\u043E\u043B\u0435\u0439, \u0440\u0435\u0448\u0438\u0432 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443
    \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0441\u0442\u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0432 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0430\u0445.
    \u041E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u0430\u043B
    \u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0439 \u0440\u0430\u0437\u0440\u0435\u0448\u0438\u043C\u043E\u0441\u0442\u0438,
    \u043D\u043E \u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u043F\u043E\u0447\u0435\u043C\u0443
    \u0434\u043B\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    5 \u0438 \u0432\u044B\u0448\u0435 \u043E\u0431\u0449\u0435\u0433\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u043D\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442, \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u0432
    \u0432\u044B\u0432\u043E\u0434\u044B \u0410\u0431\u0435\u043B\u044F.  *   \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u0431\u044B\u043B\u0438 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u043C\u0438 \u0438
    \u0441\u0436\u0430\u0442\u044B\u043C\u0438, \u0447\u0442\u043E \u043D\u0435 \u0431\u044B\u043B\u0438
    \u043F\u043E\u043D\u044F\u0442\u044B \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0430\u043C\u0438.
    \u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u043C\u0435\u043C\u0443\u0430\u0440
    \u0431\u044B\u043B \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D
    \u043B\u0438\u0448\u044C \u0432 1846 \u0433\u043E\u0434\u0443 \u0416\u043E\u0437\u0435\u0444\u043E\u043C
    \u041B\u0438\u0443\u0432\u0438\u043B\u043B\u0435\u043C, \u0441\u043F\u0443\u0441\u0442\u044F
    14 \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0430\u0432\u0442\u043E\u0440\u0430. *   \u0422\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E\u0441\u043B\u0435 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0430 \u041A\u0430\u043C\u0438\u043B\u044F
    \u0416\u043E\u0440\u0434\u0430\u043D\u0430 \u0432 1870 \u0433\u043E\u0434\u0443
    \u0438\u0434\u0435\u0438 \u0413\u0430\u043B\u0443\u0430 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438
    \u0448\u0438\u0440\u043E\u043A\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435. 
    \u041E\u043D \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0442\u0432\u043E\u0440\u0446\u043E\u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u044B,
    \u0438 \u0435\u0433\u043E \u0438\u043C\u044F \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0432\u043F\u0438\u0441\u0430\u043D\u043E \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u042D\u0432\u0430\u0440\u0438\u0441\u0442\u0430
    \u0413\u0430\u043B\u0443\u0430 \u2014 \u044D\u0442\u043E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0438 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F,
    \u043D\u043E \u0438 \u043A\u043B\u0430\u0434\u0435\u0437\u044C \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u0445
    \u0441\u043E\u0432\u043F\u0430\u0434\u0435\u043D\u0438\u0439, \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u0432 \u0438 \u043B\u0435\u0433\u0435\u043D\u0434.
    \u0417\u0430 \u0435\u0433\u043E \u043A\u043E\u0440\u043E\u0442\u043A\u043E\u0439
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0435\u0439 \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0434\u0435\u0442\u0430\u043B\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u0435\u043B\u0430\u044E\u0442
    \u0435\u0433\u043E \u043E\u0431\u0440\u0430\u0437 \u0435\u0449\u0435 \u0431\u043E\u043B\u0435\u0435
    \u044F\u0440\u043A\u0438\u043C \u0438 \u0437\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u044B\u043C. 
    \u0412\u043E\u0442 \u0441\u0430\u043C\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u043E \u043D\u0435\u043C, \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0435
    \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E. 
    ### 1. \xAB\u0413\u0430\u043B\u0443\u0430 \u2014 \u0434\u0443\u0440\u0430\u043A,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0440\u0435\u0448\u0430\u0435\u0442
    \u0442\u043E\u043B\u044C\u043A\u043E \u0432 \u0443\u043C\u0435\xBB \u042D\u0442\u043E
    \u0441\u0430\u043C\u0430\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u043B\u0435\u0433\u0435\u043D\u0434\u0430 \u043E \u043F\u0440\u043E\u0432\u0430\u043B\u0435
    \u0413\u0430\u043B\u0443\u0430 \u043D\u0430 \u0432\u0441\u0442\u0443\u043F\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0430\u0445 \u0432 \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443.   *   **\u0421\u0443\u0442\u044C \u043B\u0435\u0433\u0435\u043D\u0434\u044B:**
    \u042D\u043A\u0437\u0430\u043C\u0435\u043D\u0430\u0442\u043E\u0440 \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B
    \u0413\u0430\u043B\u0443\u0430 \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u044C
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u0437\u0430\u0434\u0430\u0447\u0438
    \u043F\u043E \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u0430\u043C. \u0413\u0430\u043B\u0443\u0430
    \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u0443\u0433\u043B\u0443\u0431\u0438\u043B\u0441\u044F
    \u0432 \u0441\u0432\u043E\u0438 \u043C\u044B\u0441\u043B\u0438, \u0447\u0442\u043E
    \u043D\u0430\u0447\u0430\u043B \u0440\u0435\u0448\u0430\u0442\u044C \u0437\u0430\u0434\u0430\u0447\u0443
    \u0432 \u0443\u043C\u0435, \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u044F
    \u043B\u0438\u0448\u044C \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043E\u0442\u0432\u0435\u0442\u044B. \u041A\u043E\u0433\u0434\u0430 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0430\u0442\u043E\u0440
    \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B \u0435\u0433\u043E \u0437\u0430\u043F\u0438\u0441\u0430\u0442\u044C
    \u0445\u043E\u0434 \u0440\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0439,
    \u0413\u0430\u043B\u0443\u0430, \u0440\u0430\u0437\u0434\u0440\u0430\u0436\u0435\u043D\u043D\u044B\u0439
    \u0442\u0435\u043C, \u0447\u0442\u043E \u0435\u0433\u043E \u043F\u0440\u0435\u0440\u044B\u0432\u0430\u044E\u0442,
    \u0448\u0432\u044B\u0440\u043D\u0443\u043B \u0432 \u043D\u0435\u0433\u043E \u043C\u043E\u043A\u0440\u043E\u0439
    \u0442\u0440\u044F\u043F\u043A\u043E\u0439 \u0434\u043B\u044F \u0441\u0442\u0438\u0440\u0430\u043D\u0438\u044F
    \u0441 \u0434\u043E\u0441\u043A\u0438 (\u0438\u043B\u0438, \u043F\u043E \u0434\u0440\u0443\u0433\u0438\u043C
    \u0432\u0435\u0440\u0441\u0438\u044F\u043C, \u0434\u043E\u0441\u043A\u043E\u0439
    \u0434\u043B\u044F \u0441\u0442\u0438\u0440\u0430\u043D\u0438\u044F). *   **\u0420\u0435\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C:**
    \u0425\u043E\u0442\u044F \u044D\u0442\u0430 \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043E\u0447\u0435\u043D\u044C \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u0430,
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u0441\u043E\u043C\u043D\u0435\u0432\u0430\u044E\u0442\u0441\u044F
    \u0432 \u0435\u0435 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E\u0439
    \u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E\u0441\u0442\u0438.
    \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u0442\u043E\u0447\u043D\u043E,
    \u0447\u0442\u043E \u043D\u0430 \u044D\u043A\u0437\u0430\u043C\u0435\u043D\u0430\u0445
    \u043E\u043D \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0435, \u043D\u043E \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0441\u0436\u0430\u0442\u044B\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u044F,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043A\u043E\u043C\u0438\u0441\u0441\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0435 \u043C\u043E\u0433\u043B\u0430
    \u043F\u043E\u043D\u044F\u0442\u044C. \u0413\u0430\u043B\u0443\u0430 \u0431\u044B\u043B
    \u0433\u0435\u043D\u0438\u0435\u043C, \u043D\u043E \u043E\u043D \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438
    \u043D\u0435 \u0443\u043C\u0435\u043B *\u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0442\u044C*
    \u0441\u0432\u043E\u0438 \u043C\u044B\u0441\u043B\u0438 \u0432 \u0440\u0430\u043C\u043A\u0430\u0445
    \u0448\u043A\u043E\u043B\u044C\u043D\u043E\u0439 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B,
    \u0447\u0442\u043E \u0438 \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u043F\u0440\u043E\u0432\u0430\u043B\u0443. 
    ### 2. \u0420\u0443\u043A\u043E\u043F\u0438\u0441\u044C, \u043F\u043E\u0442\u0435\u0440\u044F\u043D\u043D\u0430\u044F
    \u0434\u0432\u0430\u0436\u0434\u044B \u0413\u0430\u043B\u0443\u0430 \u0431\u044B\u043B
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E \u043D\u0435\u0432\u0435\u0437\u0443\u0447
    \u0432 \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u0445 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438
    \u0441\u0432\u043E\u0438\u0445 \u0442\u0440\u0443\u0434\u043E\u0432.  *   **\u0412
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0440\u0430\u0437** \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B
    \u0441\u0432\u043E\u0439 \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u043C\u0435\u043C\u0443\u0430\u0440
    \u041E\u0433\u044E\u0441\u0442\u0435\u043D\u0443 \u041B\u0443\u0438 \u041A\u043E\u0448\u0438,
    \u043E\u0434\u043D\u043E\u043C\u0443 \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 \u0442\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u041A\u043E\u0448\u0438 \u043E\u0434\u043E\u0431\u0440\u0438\u043B
    \u0440\u0430\u0431\u043E\u0442\u0443 \u0438 \u043E\u0431\u044F\u0437\u0430\u043B\u0441\u044F
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C \u0435\u0435
    \u0432 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A.
    \u041E\u0434\u043D\u0430\u043A\u043E \u041A\u043E\u0448\u0438 \u043B\u0438\u0431\u043E
    \u043F\u043E\u0442\u0435\u0440\u044F\u043B \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u044C,
    \u043B\u0438\u0431\u043E (\u043F\u043E \u0434\u0440\u0443\u0433\u043E\u0439 \u0432\u0435\u0440\u0441\u0438\u0438)
    \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0443\u0442\u0435\u0440\u044F\u043D\u0430
    \u0432 \u0430\u0440\u0445\u0438\u0432\u0430\u0445 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438.
    \u0413\u0430\u043B\u0443\u0430 \u0442\u0430\u043A \u0438 \u043D\u0435 \u0434\u043E\u0436\u0434\u0430\u043B\u0441\u044F
    \u043E\u0442\u0432\u0435\u0442\u0430. *   **\u0412\u043E \u0432\u0442\u043E\u0440\u043E\u0439
    \u0440\u0430\u0437**, \u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435 \u0442\u044E\u0440\u044C\u043C\u044B,
    \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u043D\u044B\u0439
    \u0432\u0430\u0440\u0438\u0430\u043D\u0442 \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u044E
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A \u2014
    \u0421\u0438\u043C\u0435\u043E\u043D\u0443 \u0414\u0435\u043D\u0438 \u041F\u0443\u0430\u0441\u0441\u043E\u043D\u0443.
    \u041F\u0443\u0430\u0441\u0441\u043E\u043D \u0438\u0437\u0443\u0447\u0438\u043B
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043C\u0435\u0441\u044F\u0446\u0435\u0432 \u0438 \u0432\u044B\u043D\u0435\u0441
    \u0432\u0435\u0440\u0434\u0438\u043A\u0442: *\xAB\u041C\u044B \u043F\u044B\u0442\u0430\u043B\u0438\u0441\u044C
    \u043F\u043E\u043D\u044F\u0442\u044C \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430...
    \u043D\u043E \u0438\u0445 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E,
    \u0447\u0442\u043E\u0431\u044B \u043C\u044B \u043C\u043E\u0433\u043B\u0438 \u0432\u044B\u043D\u0435\u0441\u0442\u0438
    \u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0435\xBB*. \u0420\u0443\u043A\u043E\u043F\u0438\u0441\u044C
    \u0441\u043D\u043E\u0432\u0430 \u043D\u0435 \u043F\u043E\u043D\u044F\u043B\u0438
    \u0438 \u0437\u0430\u0434\u0432\u0438\u043D\u0443\u043B\u0438 \u0432 \u0430\u0440\u0445\u0438\u0432.
    \u041B\u0438\u0448\u044C \u0441\u043F\u0443\u0441\u0442\u044F 14 \u043B\u0435\u0442
    \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u0413\u0430\u043B\u0443\u0430
    \u0416\u043E\u0437\u0435\u0444 \u041B\u0438\u0443\u0432\u0438\u043B\u043B\u044C
    \u043D\u0430\u0448\u0435\u043B \u044D\u0442\u0438 \u0437\u0430\u043F\u0438\u0441\u0438
    \u0438 \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u0434\u0435\u0440\u0436\u0438\u0442
    \u0432 \u0440\u0443\u043A\u0430\u0445 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434.  ### 3. \u0417\u0430\u043F\u0438\u0441\u043A\u0430
    \u043D\u0430 \u043F\u043E\u043B\u044F\u0445: \xAB\u041D\u0430 \u044D\u0442\u043E
    \u0443 \u043C\u0435\u043D\u044F \u043D\u0435\u0442 \u0432\u0440\u0435\u043C\u0435\u043D\u0438\xBB
    \u0412 \u043D\u043E\u0447\u044C \u043F\u0435\u0440\u0435\u0434 \u0434\u0443\u044D\u043B\u044C\u044E,
    \u043D\u0430\u043A\u0430\u043D\u0443\u043D\u0435 \u0441\u0432\u043E\u0435\u0439
    \u0433\u0438\u0431\u0435\u043B\u0438, \u0413\u0430\u043B\u0443\u0430 \u043F\u0438\u0441\u0430\u043B
    \u043F\u0438\u0441\u044C\u043C\u043E \u0434\u0440\u0443\u0433\u0443 \u0441 \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C
    \u0441\u0432\u043E\u0438\u0445 \u0438\u0434\u0435\u0439. \u041D\u0430 \u043F\u043E\u043B\u044F\u0445
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0438, \u0440\u044F\u0434\u043E\u043C
    \u0441 \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0442\u0435\u043E\u0440\u0435\u043C, \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0443\u044E \u0444\u0440\u0430\u0437\u0443:
    *\xAB\u0414\u043B\u044F \u044D\u0442\u043E\u0433\u043E \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u044C...
    \u0438 \u0443 \u043C\u0435\u043D\u044F \u043D\u0435\u0442 \u0432\u0440\u0435\u043C\u0435\u043D\u0438\xBB*
    (\u043F\u043E-\u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438: *\xABIl
    faut une infinit\xE9... et je n'ai pas le temps\xBB*).  \u042D\u0442\u043E\u0442
    \u0436\u0435\u0441\u0442\u043A\u0438\u0439, \u043F\u043E\u0447\u0442\u0438 \u0446\u0438\u043D\u0438\u0447\u043D\u044B\u0439
    \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0430\u0440\u0438\u0439, \u0431\u0440\u043E\u0448\u0435\u043D\u043D\u044B\u0439
    \u0432 \u043B\u0438\u0446\u043E \u0432\u0435\u0447\u043D\u043E\u0441\u0442\u0438,
    \u0441\u0442\u0430\u043B \u0441\u0438\u043C\u0432\u043E\u043B\u043E\u043C \u0435\u0433\u043E
    \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0441\u0443\u0434\u044C\u0431\u044B
    \u2014 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0439 \u0443\u043C,
    \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D\u043D\u044B\u0439 \u0438\u0437-\u0437\u0430
    \u043F\u0443\u0441\u0442\u044F\u043A\u043E\u0432\u043E\u0439 \u0434\u0443\u044D\u043B\u0438. 
    ### 4. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0432 \u0442\u044E\u0440\u044C\u043C\u0435
    \u0438 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0441\u043A\u0430\u043D\u0434\u0430\u043B \u0412\u043E \u0432\u0440\u0435\u043C\u044F
    \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F \u0432 \u0442\u044E\u0440\u044C\u043C\u0435
    \u0421\u0435\u043D\u0442-\u041F\u0435\u043B\u0430\u0436\u0438 \u0413\u0430\u043B\u0443\u0430
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439, \u043D\u043E
    \u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B \u0432\u0435\u0441\u0442\u0438
    \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0431\u043E\u0440\u044C\u0431\u0443. 
    *   \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u0442\u044E\u0440\u0435\u043C\u043D\u043E\u0435
    \u043D\u0430\u0447\u0430\u043B\u044C\u0441\u0442\u0432\u043E \u043F\u0440\u043E\u0432\u0435\u043B\u043E
    \u043E\u0431\u044B\u0441\u043A \u0432 \u0435\u0433\u043E \u043A\u0430\u043C\u0435\u0440\u0435
    \u0438 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0438\u043B\u043E \u0442\u0430\u043C...
    \u043D\u0435 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u043B\u0438\u0441\u0442\u043E\u0432\u043A\u0438, \u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0438. \u041D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441
    \u043E\u0445\u0440\u0430\u043D\u043D\u0438\u043A\u043E\u0432, \u0447\u0442\u043E
    \u044D\u0442\u043E \u0437\u0430 \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0435
    \u0437\u043D\u0430\u043A\u0438, \u0413\u0430\u043B\u0443\u0430 \u043E\u0442\u0432\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0435\u0433\u043E \u043F\u0440\u043E\u0435\u043A\u0442
    \u043A\u043E\u043D\u0441\u0442\u0438\u0442\u0443\u0446\u0438\u0438 \u043D\u043E\u0432\u043E\u0439
    \u0424\u0440\u0430\u043D\u0446\u0438\u0438, \u0437\u0430\u0448\u0438\u0444\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043E\u0441\u043E\u0431\u044B\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C.
    \u041D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435 \u044D\u0442\u043E
    \u0431\u044B\u043B\u0438 \u043D\u0430\u0431\u0440\u043E\u0441\u043A\u0438 \u0435\u0433\u043E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u0440\u0443\u043F\u043F. *   \u041D\u0430\u0445\u043E\u0434\u044F\u0441\u044C
    \u0432 \u0442\u043E\u0439 \u0436\u0435 \u0442\u044E\u0440\u044C\u043C\u0435,
    \u043E\u043D \u043F\u043E\u0441\u0441\u043E\u0440\u0438\u043B\u0441\u044F \u0441
    \u0434\u0440\u0443\u0433\u0438\u043C \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u043D\u044B\u043C
    \u043D\u0430 \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043E\u0447\u0432\u0435 \u0438 \u0434\u0430\u0436\u0435 \u0431\u044B\u043B
    \u0440\u0430\u043D\u0435\u043D \u0432 \u043F\u043B\u0435\u0447\u043E \u043D\u043E\u0436\u043E\u043C
    \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0434\u0440\u0430\u043A\u0438. 
    ### 5. \u0421\u0430\u043C\u043E\u0443\u0431\u0438\u0439\u0441\u0442\u0432\u043E
    \u0438 \u0441\u0435\u043C\u0435\u0440\u043A\u0430 \u043F\u0438\u043A \u041B\u0435\u0433\u0435\u043D\u0434\u0430
    \u0433\u043B\u0430\u0441\u0438\u0442, \u0447\u0442\u043E \u0432 \u0442\u044E\u0440\u044C\u043C\u0435
    \u0413\u0430\u043B\u0443\u0430 \u0432\u043F\u0430\u043B \u0432 \u0433\u043B\u0443\u0431\u043E\u0447\u0430\u0439\u0448\u0443\u044E
    \u0434\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u044E. \u041E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043D\u043E\u0447\u044C\u044E \u043E\u043D \u0432\u0437\u044F\u043B \u0431\u0440\u0438\u0442\u0432\u0443
    \u0438 \u043F\u043E\u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043F\u0435\u0440\u0435\u0440\u0435\u0437\u0430\u0442\u044C
    \u0441\u0435\u0431\u0435 \u0433\u043E\u0440\u043B\u043E. \u041E\u0434\u043D\u0430\u043A\u043E,
    \u043F\u043E \u0438\u0440\u043E\u043D\u0438\u0438 \u0441\u0443\u0434\u044C\u0431\u044B,
    \u0435\u0433\u043E \u0441\u043F\u0430\u0441\u043B\u043E \u043D\u0435 \u0432\u043C\u0435\u0448\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043B\u044E\u0434\u0435\u0439, \u0430... *\u0433\u0440\u043E\u043C*. \u0412\u043D\u0435\u0437\u0430\u043F\u043D\u044B\u0439
    \u0440\u0430\u0441\u043A\u0430\u0442 \u0433\u0440\u043E\u043C\u0430 (\u043F\u043E
    \u0434\u0440\u0443\u0433\u0438\u043C \u0434\u0430\u043D\u043D\u044B\u043C \u2014
    \u0433\u043E\u043B\u043E\u0441 \u0441\u043E\u043A\u0430\u043C\u0435\u0440\u043D\u0438\u043A\u0430)
    \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u043B \u0435\u0433\u043E \u0432\u0437\u0434\u0440\u043E\u0433\u043D\u0443\u0442\u044C,
    \u0438 \u043E\u043D \u043F\u043E\u0440\u0435\u0437\u0430\u043B \u0442\u043E\u043B\u044C\u043A\u043E
    \u043A\u043E\u0436\u0443, \u043D\u0435 \u0437\u0430\u0434\u0435\u0432 \u0430\u0440\u0442\u0435\u0440\u0438\u0438.
    \u041F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0433\u043E \u043E\u043D \u0443\u0441\u043F\u043E\u043A\u043E\u0438\u043B\u0441\u044F
    \u0438 \u043F\u043E\u043A\u043B\u044F\u043B\u0441\u044F \u0436\u0438\u0442\u044C
    \u0440\u0430\u0434\u0438 \u043D\u0430\u0443\u043A\u0438.  ### 6. \u0417\u0430\u0433\u0430\u0434\u043A\u0430
    \u0434\u0443\u044D\u043B\u0438: \u041B\u044E\u0431\u043E\u0432\u044C \u0438\u043B\u0438
    \u043F\u043E\u043B\u0438\u0442\u0438\u043A\u0430? \u041E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0434\u0443\u044D\u043B\u0438 \u0413\u0430\u043B\u0443\u0430 \u043F\u043E\u043A\u0440\u044B\u0442\u044B
    \u043C\u0440\u0430\u043A\u043E\u043C \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440. 
    *   **\u0412\u0435\u0440\u0441\u0438\u044F \u043B\u044E\u0431\u0432\u0438:**
    \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F, \u0447\u0442\u043E \u043E\u043D
    \u0432\u044B\u0437\u0432\u0430\u043B \u043D\u0430 \u0434\u0443\u044D\u043B\u044C
    \u043D\u0435\u043A\u043E\u0435\u0433\u043E \u041F\u0435\u0448\u043E \u0434'\u042D\u0440\u0431\u0435\u043D\u0432\u0438\u043B\u043B\u044F,
    \u0436\u0435\u043D\u0438\u0445\u0430 \u0441\u0432\u043E\u0435\u0439 \u0432\u043E\u0437\u043B\u044E\u0431\u043B\u0435\u043D\u043D\u043E\u0439
    \u0421\u0442\u0435\u0444\u0430\u043D\u0438 \u041F\u043E\u0442\u0435\u0440\u0435\u043D-\u0414\u044E\u043C\u043E\u0442\u0435\u043B\u044C.
    *   **\u0412\u0435\u0440\u0441\u0438\u044F \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F:**
    \u041C\u043D\u043E\u0433\u0438\u0435 \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u0441\u043A\u043B\u043E\u043D\u044F\u044E\u0442\u0441\u044F \u043A \u0442\u043E\u043C\u0443,
    \u0447\u0442\u043E \u0434\u0443\u044D\u043B\u044C \u0431\u044B\u043B\u0430 \u043F\u043E\u0434\u0441\u0442\u0440\u043E\u0435\u043D\u0430
    \u0440\u043E\u044F\u043B\u0438\u0441\u0442\u0430\u043C\u0438. \u0413\u0430\u043B\u0443\u0430
    \u0431\u044B\u043B \u043A\u0440\u0430\u0439\u043D\u0435 \u043E\u043F\u0430\u0441\u0435\u043D
    \u043A\u0430\u043A \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u044B\u0439
    \u043B\u0438\u0434\u0435\u0440, \u0438 \u0435\u0433\u043E \u043F\u0440\u043E\u0449\u0435
    \u0431\u044B\u043B\u043E \u0443\u0441\u0442\u0440\u0430\u043D\u0438\u0442\u044C
    \u0432 \u043F\u043E\u0435\u0434\u0438\u043D\u043A\u0435 \u0447\u0435\u0441\u0442\u0438,
    \u0447\u0435\u043C \u0430\u0440\u0435\u0441\u0442\u043E\u0432\u044B\u0432\u0430\u0442\u044C.
    \u0412 \u043F\u043E\u043B\u044C\u0437\u0443 \u044D\u0442\u043E\u0439 \u0432\u0435\u0440\u0441\u0438\u0438
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u0442\u043E\u0442 \u0444\u0430\u043A\u0442,
    \u0447\u0442\u043E \u0435\u0433\u043E \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u0438
    \u0431\u044B\u043B\u0438 \u043E\u0442\u043B\u0438\u0447\u043D\u044B\u043C\u0438
    \u0441\u0442\u0440\u0435\u043B\u043A\u0430\u043C\u0438, \u0430 \u0441\u0430\u043C
    \u0413\u0430\u043B\u0443\u0430 \u0432 \u0436\u0438\u0437\u043D\u0438 \u043D\u0435
    \u0434\u0435\u0440\u0436\u0430\u043B \u043F\u0438\u0441\u0442\u043E\u043B\u0435\u0442\u0430
    \u0432 \u0440\u0443\u043A\u0430\u0445. *   **\u0412\u0435\u0440\u0441\u0438\u044F
    \"\u0433\u043B\u0443\u043F\u0446\u043E\u0432\":** \u0412 \u043F\u0440\u0435\u0434\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u0445
    \u043F\u0438\u0441\u044C\u043C\u0430\u0445 \u043E\u043D \u043F\u0438\u0441\u0430\u043B:
    *\xAB\u042F \u0443\u043C\u0438\u0440\u0430\u044E \u0436\u0435\u0440\u0442\u0432\u043E\u0439
    \u0431\u0435\u0441\u0447\u0435\u0441\u0442\u043D\u043E\u0439 \u043A\u043E\u043A\u0435\u0442\u043A\u0438
    \u0438 \u0434\u0432\u0443\u0445 \u0433\u043B\u0443\u043F\u0446\u043E\u0432, \u043E\u0431\u043C\u0430\u043D\u0443\u0442\u044B\u0445
    \u0435\u044E\xBB*. \u041E\u043D \u0442\u0430\u043A\u0436\u0435 \u043F\u0440\u043E\u0441\u0438\u043B
    \u0434\u0440\u0443\u0437\u0435\u0439 *\xAB\u043D\u0435 \u0441\u0443\u0434\u0438\u0442\u044C
    \u0441\u0442\u0440\u043E\u0433\u043E\xBB* \u0435\u0433\u043E \u0443\u0431\u0438\u0439\u0446,
    \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u043E\u043D\u0438 \u0431\u044B\u043B\u0438
    *\xAB\u0447\u0435\u0441\u0442\u043D\u044B\u043C\u0438 \u0438 \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0438\u043C\u0438\xBB*.
    \u042D\u0442\u043E \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0435 \u0432\u0435\u043B\u0438\u043A\u043E\u0434\u0443\u0448\u0438\u0435
    \u0434\u0430\u0435\u0442 \u043F\u0438\u0449\u0443 \u0434\u043B\u044F \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0442\u043E\u043B\u043A\u043E\u0432\u0430\u043D\u0438\u0439.  ### 7. \u041C\u043E\u0433\u0438\u043B\u0430
    \u0431\u0435\u0437 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F \u042D\u0432\u0430\u0440\u0438\u0441\u0442
    \u0413\u0430\u043B\u0443\u0430 \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u043D\u0430 \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u043C \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435
    \u041C\u043E\u043D\u043F\u0430\u0440\u043D\u0430\u0441. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043D\u0430 \u0435\u0433\u043E \u043C\u043E\u0433\u0438\u043B\u0435 **\u043D\u0435\u0442
    \u043D\u0438\u043A\u0430\u043A\u0438\u0445 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0439
    \u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435**. \u041D\u0430
    \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u043D\u043E\u043C \u043A\u0430\u043C\u043D\u0435
    \u0432\u044B\u0441\u0435\u0447\u0435\u043D\u044B \u043B\u0438\u0448\u044C \u0434\u0430\u0442\u044B
    \u0436\u0438\u0437\u043D\u0438 \u0438 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u0430\u044F
    \u044D\u043F\u0438\u0442\u0430\u0444\u0438\u044F. \u041C\u043D\u043E\u0433\u0438\u0435
    \u0441\u0447\u0438\u0442\u0430\u044E\u0442, \u0447\u0442\u043E \u044D\u0442\u043E
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0430\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u043D\u0435\u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E\u0441\u0442\u044C.
    \u041B\u0438\u0448\u044C \u0432 1848 \u0433\u043E\u0434\u0443, \u043A\u043E\u0433\u0434\u0430
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438 \u0432\u043D\u043E\u0432\u044C
    \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F,
    \u0435\u0433\u043E \u0438\u043C\u044F \u043A\u0430\u043A \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0431\u043E\u0440\u0446\u0430 \u0431\u044B\u043B\u043E \u0432\u043F\u0438\u0441\u0430\u043D\u043E
    \u0432 \u0441\u043F\u0438\u0441\u043A\u0438 \u0433\u0435\u0440\u043E\u0435\u0432,
    \u043D\u043E \u043F\u0440\u043E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u0437\u0430\u0431\u044B\u043B\u0438
    \u043F\u043E\u0447\u0442\u0438 \u043D\u0430 20 \u043B\u0435\u0442.  ### 8. \u0421\u0430\u043C\u044B\u0439
    \u043C\u043E\u043B\u043E\u0434\u043E\u0439 \u0433\u0435\u043D\u0438\u0439 \u0432
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0425\u043E\u0442\u044F \u0413\u0430\u043B\u0443\u0430 \u043F\u0440\u043E\u0436\u0438\u043B
    \u0432\u0441\u0435\u0433\u043E 20 \u043B\u0435\u0442, \u043E\u043D \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043C\u043E\u043B\u043E\u0434\u044B\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u0437\u0430\u043B\u043E\u0436\u0438\u0432\u0448\u0438\u0445
    \u043E\u0441\u043D\u043E\u0432\u044B \u0446\u0435\u043B\u043E\u0433\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0430
    \u043D\u0430\u0443\u043A\u0438. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0447\u0442\u043E \u0435\u0433\u043E \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0438\u0434\u0435\u0438 \u043E \u0433\u0440\u0443\u043F\u043F\u0430\u0445 \u043E\u043D
    \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0437\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0442\u044C,
    \u043A\u043E\u0433\u0434\u0430 \u0435\u043C\u0443 \u0431\u044B\u043B\u043E \u0432\u0441\u0435\u0433\u043E
    **17 \u043B\u0435\u0442**. \u0414\u043B\u044F \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F,
    \u041D\u044C\u044E\u0442\u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0441\u0432\u043E\u0438
    \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0432 23 \u0433\u043E\u0434\u0430, \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D
    \u2014 \u0432 26, \u0430 \u0413\u0430\u043B\u0443\u0430 \u0432 17 \u043B\u0435\u0442
    \u0443\u0436\u0435 \u0440\u0435\u0448\u0430\u043B \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u0443\u0447\u0438\u043B\u0438
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0435 \u0443\u043C\u044B
    \u043D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438 \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0439. 
    ### 9. \xAB\u0412\u043E\u0441\u0441\u0442\u0430\u043D\u0438\u0435\xBB \u0432
    \u0412\u044B\u0441\u0448\u0435\u0439 \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 \u041A\u043E\u0433\u0434\u0430 \u0432 1830 \u0433\u043E\u0434\u0443
    \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430 \u0418\u044E\u043B\u044C\u0441\u043A\u0430\u044F
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F, \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440
    \u0448\u043A\u043E\u043B\u044B \u0437\u0430\u043F\u0435\u0440 \u0432\u0441\u0435\u0445
    \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u0432 \u0432 \u0437\u0434\u0430\u043D\u0438\u0438,
    \u0447\u0442\u043E\u0431\u044B \u043E\u043D\u0438 \u043D\u0435 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u0432 \u0443\u043B\u0438\u0447\u043D\u044B\u0445 \u0431\u043E\u044F\u0445. \u0413\u0430\u043B\u0443\u0430
    \u043F\u0440\u0438\u0448\u0435\u043B \u0432 \u044F\u0440\u043E\u0441\u0442\u044C.
    \u041E\u043D \u0432\u044B\u0432\u0435\u0441\u0438\u043B \u0432 \u0445\u043E\u043B\u043B\u0435
    \u0448\u043A\u043E\u043B\u044B \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u043F\u043B\u0430\u043A\u0430\u0442 \u0441 \u043F\u0440\u0438\u0437\u044B\u0432\u043E\u043C
    \u043A \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u0438\u044E \u043F\u0440\u043E\u0442\u0438\u0432
    \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u0430, \u0430 \u0437\u0430\u0442\u0435\u043C
    \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E \u043E\u0431\u043E\u0437\u0432\u0430\u043B
    \u0434\u0438\u0440\u0435\u043A\u0442\u043E\u0440\u0430 \u0442\u0440\u0443\u0441\u043E\u043C.
    \u0417\u0430 \u044D\u0442\u043E \u0435\u0433\u043E \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u043B\u0438
    \u0438\u0437 \u0448\u043A\u043E\u043B\u044B \u2014 \u043D\u0435 \u0437\u0430
    \u043F\u043B\u043E\u0445\u0438\u0435 \u043E\u0446\u0435\u043D\u043A\u0438, \u0430
    \u0437\u0430 \u0438\u0437\u043B\u0438\u0448\u043D\u044E\u044E \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C. \u041F\u0440\u0438\u043C\u0435\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
    \u0447\u0442\u043E \u043F\u043E\u0437\u0436\u0435, \u0432 1848 \u0433\u043E\u0434\u0443,
    \u044D\u0442\u0430 \u0441\u0430\u043C\u0430\u044F \u0448\u043A\u043E\u043B\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043A\u043E\u043B\u044B\u0431\u0435\u043B\u044C\u044E
    \u0440\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F.  ### 10. \u0421\u0435\u043A\u0440\u0435\u0442\u043D\u044B\u0439
    \u043A\u043E\u0434 \u0438 \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u0413\u0430\u043B\u0443\u0430 \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u043B
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0441\u0438\u0441\u0442\u0435\u043C
    \u0448\u0438\u0444\u0440\u043E\u0432\u0430\u043D\u0438\u044F \u043D\u0430 100
    \u043B\u0435\u0442 \u0432\u043F\u0435\u0440\u0435\u0434. \u0421\u043E\u0437\u0434\u0430\u043D\u043D\u044B\u0435
    \u0438\u043C **\u043F\u043E\u043B\u044F \u0413\u0430\u043B\u0443\u0430 (GF)**
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u043E\u0432. \u0417\u0430\u0431\u0430\u0432\u043D\u044B\u0439
    \u0444\u0430\u043A\u0442: \u0435\u0441\u043B\u0438 \u0431\u044B \u0432\u043B\u0430\u0441\u0442\u044F\u043C
    \u0432 XIX \u0432\u0435\u043A\u0435 \u0441\u043A\u0430\u0437\u0430\u043B\u0438,
    \u0447\u0442\u043E \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0435 \"\u0437\u0430\u043A\u043E\u0440\u044E\u0447\u043A\u0438\"
    \u044D\u0442\u043E\u0433\u043E \u0431\u0435\u0437\u0443\u043C\u043D\u043E\u0433\u043E
    \u044E\u043D\u043E\u0448\u0438 \u0431\u0443\u0434\u0443\u0442 \u0437\u0430\u0449\u0438\u0449\u0430\u0442\u044C
    \u0431\u0430\u043D\u043A\u043E\u0432\u0441\u043A\u0438\u0435 \u0442\u0440\u0430\u043D\u0437\u0430\u043A\u0446\u0438\u0438
    \u0432 XXI \u0432\u0435\u043A\u0435, \u043E\u043D\u0438 \u0431\u044B \u0441\u043E\u0447\u043B\u0438
    \u044D\u0442\u043E \u0448\u0443\u0442\u043A\u043E\u0439.  ### 11. \u0422\u043E\u0447\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u0439 \u0412
    \u043E\u0434\u043D\u043E\u043C \u0438\u0437 \u0441\u0432\u043E\u0438\u0445 \u043F\u0438\u0441\u0435\u043C
    \u0413\u0430\u043B\u0443\u0430 \u043F\u0438\u0441\u0430\u043B, \u0447\u0442\u043E
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430 \u0431\u0443\u0434\u0435\u0442
    \u043F\u043E\u043B\u0435\u0437\u043D\u0430 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0434\u043B\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u044B, \u043D\u043E \u0438
    \u0434\u043B\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B. \u0412 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
    \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044F \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442
    \u0441\u0442\u0440\u043E\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432
    \u0441 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u043C
    \u0447\u0438\u0441\u043B\u043E\u043C \u0441\u0442\u043E\u0440\u043E\u043D. \u042D\u0442\u043E
    \u0431\u044B\u043B\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u043E \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u043E\u0437\u0436\u0435, \u043D\u043E \u043E\u043D \u0431\u044B\u043B
    \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E \u043F\u0440\u0430\u0432. 
    \u042D\u0432\u0430\u0440\u0438\u0441\u0442 \u0413\u0430\u043B\u0443\u0430 \u0431\u044B\u043B
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0433\u0435\u043D\u0438\u0435\u043C;
    \u043E\u043D \u0431\u044B\u043B \u0436\u0438\u0432\u044B\u043C \u043E\u043B\u0438\u0446\u0435\u0442\u0432\u043E\u0440\u0435\u043D\u0438\u0435\u043C
    \u0440\u043E\u043C\u0430\u043D\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0433\u0435\u0440\u043E\u044F XIX \u0432\u0435\u043A\u0430: \u0431\u0443\u043D\u0442\u0430\u0440\u044C,
    \u0432\u043B\u044E\u0431\u043B\u0435\u043D\u043D\u044B\u0439, \u0431\u0435\u0437\u0443\u043C\u0435\u0446
    \u0438 \u043F\u0440\u043E\u0432\u0438\u0434\u0435\u0446, \u043E\u0441\u0442\u0430\u0432\u0438\u0432\u0448\u0438\u0439
    \u0441\u043B\u0435\u0434 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439, \u0447\u0442\u043E \u0435\u0433\u043E
    \u0438\u0434\u0435\u0438 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044E\u0442
    \u0434\u0432\u0438\u0433\u0430\u0442\u044C \u043D\u0430\u0443\u043A\u0443 \u0438
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0438 \u0441\u043F\u0443\u0441\u0442\u044F
    \u043F\u043E\u0447\u0442\u0438 \u0434\u0432\u0430 \u0432\u0435\u043A\u0430."
