  achievementsRu: "\u0414\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u041F\u0438\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E (\u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438)
    \u0432\u044B\u0445\u043E\u0434\u044F\u0442 \u0434\u0430\u043B\u0435\u043A\u043E
    \u0437\u0430 \u0440\u0430\u043C\u043A\u0438 \u043F\u0440\u043E\u0441\u0442\u043E\u0433\u043E
    \xAB\u043F\u0440\u0438\u0432\u043E\u0437\u0430 \u0446\u0438\u0444\u0440\xBB \u0432
    \u0415\u0432\u0440\u043E\u043F\u0443. \u041E\u043D \u0431\u044B\u043B \u043F\u0435\u0440\u0432\u043E\u043F\u0440\u043E\u0445\u043E\u0434\u0446\u0435\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442 \u0434\u043B\u044F \u043A\u043E\u043C\u043C\u0435\u0440\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0430\u043B\u0433\u0435\u0431\u0440\u044B
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B \u043D\u0430
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0439
    \u0432\u043F\u0435\u0440\u0435\u0434. \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434
    \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u043D\u0430 \u0447\u0435\u0442\u044B\u0440\u0435 \u0433\u043B\u043E\u0431\u0430\u043B\u044C\u043D\u044B\u0445
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F: **\u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F**, **\u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B**, **\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0438** \u0438 **\u0447\u0438\u0441\u0442\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B**.  \u041D\u0438\u0436\u0435
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439 \u0440\u0430\u0437\u0431\u043E\u0440
    \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439. 
    ### 1. \u041F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0430\u0446\u0438\u044F
    \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u043E\u0439 \u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B (\u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F)  \u042D\u0442\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435 \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438,
    \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0435\u0435 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0443\u044E
    \u043D\u0430\u0443\u043A\u0443. \u0412 \u0441\u0432\u043E\u0435\u0439 \xAB\u041A\u043D\u0438\u0433\u0435
    \u0430\u0431\u0430\u043A\u0430\xBB (1202/1228) \u043E\u043D \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043E\u043F\u0438\u0441\u0430\u043B \u0446\u0438\u0444\u0440\u044B \u2014 \u043E\u043D
    **\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043B** \u0438\u0445 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435. 
    *   **\u0412\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u043D\u0443\u043B\u044F
    \u0438 \u0440\u0430\u0437\u0440\u044F\u0434\u043E\u0432:** \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u0447\u0435\u0442\u043A\u043E \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B,
    \u0447\u0442\u043E \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u0446\u0438\u0444\u0440\u044B
    \u0437\u0430\u0432\u0438\u0441\u0438\u0442 \u043E\u0442 \u0435\u0435 \u043F\u043E\u0437\u0438\u0446\u0438\u0438
    (\u0435\u0434\u0438\u043D\u0438\u0446\u044B, \u0434\u0435\u0441\u044F\u0442\u043A\u0438,
    \u0441\u043E\u0442\u043D\u0438). \u041E\u043D \u0432\u0432\u0435\u043B \u0432
    \u043E\u0431\u0438\u0445\u043E\u0434 \u043D\u043E\u043B\u044C (`zephirum`) \u043D\u0435
    \u043A\u0430\u043A \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0443\u0441\u0442\u043E\u0435
    \u043C\u0435\u0441\u0442\u043E, \u0430 \u043A\u0430\u043A \u043F\u043E\u043B\u043D\u043E\u0446\u0435\u043D\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E, \u0443\u0447\u0430\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0435
    \u0432 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F\u0445. *  
    **\u0414\u0440\u043E\u0431\u0438 \u043D\u043E\u0432\u043E\u0433\u043E \u0442\u0438\u043F\u0430:**
    \u0412\u043C\u0435\u0441\u0442\u043E \u0433\u0440\u043E\u043C\u043E\u0437\u0434\u043A\u0438\u0445
    \u0448\u0435\u0441\u0442\u0438\u0434\u0435\u0441\u044F\u0442\u0435\u0440\u0438\u0447\u043D\u044B\u0445
    \u0434\u0440\u043E\u0431\u0435\u0439 (\u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0432\u0430\u0432\u0438\u043B\u043E\u043D\u044F\u043D \u0438 \u0433\u0440\u0435\u043A\u043E\u0432)
    \u0438\u043B\u0438 \u0440\u0438\u043C\u0441\u043A\u0438\u0445 \u0434\u0440\u043E\u0431\u0435\u0439,
    \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C **\u0441\u043E\u0441\u0442\u0430\u0432\u043D\u044B\u0435
    \u0434\u0440\u043E\u0431\u0438** \u0438 \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u044B\u0435
    \u0434\u0440\u043E\u0431\u0438 (\u0445\u043E\u0442\u044F \u0432 \u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u044F \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u0430\u044F
    \u0437\u0430\u043F\u044F\u0442\u0430\u044F \u0435\u0449\u0435 \u043D\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0430\u0441\u044C,
    \u043E\u043D \u0440\u0430\u0437\u0431\u0438\u0432\u0430\u043B \u0446\u0435\u043B\u044B\u0435
    \u0447\u0430\u0441\u0442\u0438 \u043D\u0430 \u0435\u0434\u0438\u043D\u0438\u0446\u044B,
    \u0434\u0435\u0441\u044F\u0442\u043A\u0438, \u0441\u043E\u0442\u043D\u0438 \u0438
    \u0442.\u0434.).  *   **\u041F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B:** \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B \u0434\u043B\u044F \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0430
    \u0432\u0430\u043B\u044E\u0442, \u043C\u0435\u0440 \u0432\u0435\u0441\u0430 \u0438
    \u0434\u043B\u0438\u043D\u044B (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B \u0434\u043B\u044F \u043A\u043E\u043D\u0432\u0435\u0440\u0442\u0430\u0446\u0438\u0438
    \u043F\u0438\u0437\u0430\u043D\u0441\u043A\u0438\u0445 \u043B\u0438\u0440 \u0432
    \u0441\u0438\u0446\u0438\u043B\u0438\u0439\u0441\u043A\u0438\u0435 \u0443\u043D\u0446\u0438\u0438),
    \u0447\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B\u043E \u0435\u0433\u043E
    \u043A\u043D\u0438\u0433\u0443 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043D\u044B\u043C
    \u043F\u043E\u0441\u043E\u0431\u0438\u0435\u043C \u0434\u043B\u044F \u043A\u0443\u043F\u0446\u043E\u0432. 
    > *\u0412\u0430\u0436\u043D\u043E:* \u0418\u043C\u0435\u043D\u043D\u043E \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0430\u0432\u0442\u043E\u0440\u0438\u0442\u0435\u0442\u0443 \u0438 \u044F\u0441\u043D\u043E\u0441\u0442\u0438
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u043A\u0443\u043F\u0446\u044B \u0424\u043B\u043E\u0440\u0435\u043D\u0446\u0438\u0438
    \u0438 \u041F\u0438\u0437\u044B \u043D\u0430\u0447\u0430\u043B\u0438 \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u043F\u0435\u0440\u0435\u0445\u043E\u0434\u0438\u0442\u044C \u043D\u0430 \xAB\u0438\u043D\u0434\u0438\u0439\u0441\u043A\u0438\u0439
    \u043C\u0435\u0442\u043E\u0434\xBB, \u0432\u044B\u0442\u0435\u0441\u043D\u0438\u0432
    \u0441\u0447\u0435\u0442 \u043D\u0430 \u0430\u0431\u0430\u043A\u0435 \u0438 \u0440\u0438\u043C\u0441\u043A\u0438\u0435
    \u0446\u0438\u0444\u0440\u044B \u0438\u0437 \u0434\u0435\u043B\u043E\u0432\u043E\u0439
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u0446\u0438\u0438 \u043A
    \u043A\u043E\u043D\u0446\u0443 XIII \u0432\u0435\u043A\u0430.  ---  ### 2. \u0412\u043A\u043B\u0430\u0434
    \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0443 \u0438 \u043C\u0435\u0442\u043E\u0434\u044B
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 
    \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043F\u0440\u043E\u0434\u0432\u0438\u043D\u0443\u043B \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u043D\u0430\u043D\u0438\u044F, \u0437\u0430\u0438\u043C\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u043D\u044B\u0435
    \u0443 \u0430\u0440\u0430\u0431\u043E\u0432 (\u0430\u043B\u044C-\u0425\u043E\u0440\u0435\u0437\u043C\u0438)
    \u0438 \u0438\u043D\u0434\u0438\u0439\u0446\u0435\u0432, \u043D\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438\u0445 \u0438 \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u043B \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    \u043D\u0430\u0445\u043E\u0434\u043A\u0430\u043C\u0438.  *   **\u0420\u0435\u0448\u0435\u043D\u0438\u0435
    \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439:**
    \u042D\u0442\u043E \u0435\u0433\u043E \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0435\u0441\u044F
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0435. \u041D\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0442\u0443\u0440\u043D\u0438\u0440\u0435 1225 \u0433\u043E\u0434\u0430 \u043F\u0440\u0438
    \u0434\u0432\u043E\u0440\u0435 \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430
    II \u0435\u043C\u0443 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B\u0438
    \u0440\u0435\u0448\u0438\u0442\u044C \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    **x\xB3 + 2x\xB2 + 10x = 20**.      *   \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043A\u043E\u0440\u0435\u043D\u044C
    \u044D\u0442\u043E\u0433\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u043D\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043D\u0438 \u0446\u0435\u043B\u044B\u043C
    \u0447\u0438\u0441\u043B\u043E\u043C, \u043D\u0438 \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u0434\u0440\u043E\u0431\u044C\u044E, \u043D\u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0438\u0447\u043D\u043E\u0439
    \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E
    (\u0442\u043E \u0435\u0441\u0442\u044C \u043D\u0435 \u0432\u044B\u0440\u0430\u0436\u0430\u0435\u0442\u0441\u044F
    \u0447\u0435\u0440\u0435\u0437 \u221A).     *   \u041E\u043D \u043D\u0430\u0448\u0435\u043B
    **\u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u043D\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u043A\u043E\u0440\u043D\u044F \u0441 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u0434\u043E 9-\u0433\u043E \u0437\u043D\u0430\u043A\u0430 \u043F\u043E\u0441\u043B\u0435
    \u0437\u0430\u043F\u044F\u0442\u043E\u0439**: *x = 1.368808107...*      *   \u042D\u0442\u043E\u0442
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u0431\u044B\u043B \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u044B\u043C
    \u0434\u043B\u044F \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    \u041E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043C\u0435\u0442\u043E\u0434\u044B \u0432\u0430\u0432\u0438\u043B\u043E\u043D\u0441\u043A\u043E\u0439
    \u0430\u043F\u043F\u0440\u043E\u043A\u0441\u0438\u043C\u0430\u0446\u0438\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0437\u0430\u043D\u043E\u0432\u043E
    \u043E\u0442\u043A\u0440\u044B\u043B \u0432 \u0415\u0432\u0440\u043E\u043F\u0435
    \u0442\u043E\u043B\u044C\u043A\u043E \u0421\u0442\u0435\u0432\u0438\u043D \u0432
    XVI \u0432\u0435\u043A\u0435. *   **\u041C\u0435\u0442\u043E\u0434 \u043B\u043E\u0436\u043D\u043E\u0433\u043E
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F (Regula Falsi):** \u041E\u043D
    \u0430\u0434\u0430\u043F\u0442\u0438\u0440\u043E\u0432\u0430\u043B \u0438 \u0443\u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0434\u0440\u0435\u0432\u043D\u0438\u0439 \u043C\u0435\u0442\u043E\u0434 \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u043B\u0438\u043D\u0435\u0439\u043D\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439,
    \u0441\u0432\u0435\u0434\u044F \u0435\u0433\u043E \u043A \u0441\u0442\u0440\u043E\u0433\u0438\u043C
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C\u0430\u043C. *   **\u041A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F:** \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u0434\u0430\u043B \u043F\u043E\u043B\u043D\u0443\u044E \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044E
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0438 \u0441\u0442\u0440\u043E\u0433\u0438\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0438\u0445 \u0440\u0435\u0448\u0435\u043D\u0438\u0439, \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044F
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435,
    \u043D\u043E \u0438 \u0434\u043E\u043F\u0443\u0441\u043A\u0430\u044F (\u0432
    \u0441\u0447\u0435\u0442\u0430\u0445) \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043A\u043E\u0440\u043D\u0438 \u043A\u0430\u043A \xAB\u0434\u043E\u043B\u0433\u0438\xBB.
    *   **\u041F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u0435
    \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u043A\u0438:** \u0425\u043E\u0442\u044F
    \u043E\u043D \u043D\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0431\u0443\u043A\u0432\u0435\u043D\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u044B
    (\u043E\u043D\u0430 \u043F\u043E\u044F\u0432\u0438\u0442\u0441\u044F \u0442\u043E\u043B\u044C\u043A\u043E
    \u0443 \u0412\u0438\u0435\u0442\u0430), \u043E\u043D \u0432\u0432\u0435\u043B
    \u0435\u0434\u0438\u043D\u0443\u044E \u0442\u0435\u0440\u043C\u0438\u043D\u043E\u043B\u043E\u0433\u0438\u044E
    \u0434\u043B\u044F \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445,
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432 \u0438 \u043A\u0443\u0431\u043E\u0432
    \u0447\u0438\u0441\u0435\u043B, \u0447\u0442\u043E \u0443\u043F\u0440\u043E\u0441\u0442\u0438\u043B\u043E
    \u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u0435 \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447.  ---  ### 3. \u0422\u0435\u043E\u0440\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B (\xAB\u041A\u043D\u0438\u0433\u0430 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432\xBB
    \u2014 Liber Quadratorum)  \u042D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434
    (1225 \u0433.) \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F **\u0432\u0435\u0440\u0448\u0438\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0433\u0435\u043D\u0438\u044F \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438**.
    \u0417\u0434\u0435\u0441\u044C \u043E\u043D \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u0435\u0442
    \u043D\u0435 \u043A\u0430\u043A \u043F\u0440\u0430\u043A\u0442\u0438\u043A-\u0431\u0443\u0445\u0433\u0430\u043B\u0442\u0435\u0440,
    \u0430 \u043A\u0430\u043A \u0447\u0438\u0441\u0442\u044B\u0439 \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A,
    \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u0432\u0448\u0438\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B \u0424\u0435\u0440\u043C\u0430 \u0438 \u042D\u0439\u043B\u0435\u0440\u0430. 
    *   **\u041A\u043E\u043D\u0433\u0440\u0443\u044D\u043D\u0442\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430:** \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u0434\u0430\u043B \u043F\u043E\u043B\u043D\u043E\u0435 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u0442\u0430\u043A \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u044B\u0445
    \xAB\u043A\u043E\u043D\u0433\u0440\u0443\u044D\u043D\u0442\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B\xBB (congruum). \u041E\u043D \u043E\u0442\u043A\u0440\u044B\u043B
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 \u0434\u043B\u044F \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F \u0441\u0443\u043C\u043C\u043E\u0439
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432 \u0434\u0432\u0443\u0445
    \u0440\u0430\u0437\u043D\u044B\u0445 \u043F\u0430\u0440 \u0447\u0438\u0441\u0435\u043B.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0447\u0438\u0441\u043B\u043E
    5 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043A\u043E\u043D\u0433\u0440\u0443\u044D\u043D\u0442\u043D\u044B\u043C,
    \u0442\u0430\u043A \u043A\u0430\u043A 5 = 1\xB2 + 2\xB2, \u0438 \u043E\u043D\u043E
    \u0436\u0435 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u0440\u0430\u0437\u043D\u043E\u0441\u0442\u044C
    \u043C\u0435\u0436\u0434\u0443 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430\u043C\u0438.
    *   **\u0422\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u043E \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    (\u0411\u0440\u0430\u0445\u043C\u0430\u0433\u0443\u043F\u0442\u044B-\u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438):**
    \u041E\u043D \u0441\u0442\u0440\u043E\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043B
    \u0442\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u043E, \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0435\u0435
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0442\u044C \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0434\u0432\u0443\u0445 \u0441\u0443\u043C\u043C \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432
    \u0432 \u0432\u0438\u0434\u0435 \u0441\u0443\u043C\u043C\u044B \u0434\u0432\u0443\u0445
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432:     (a\xB2 + b\xB2)(c\xB2
    + d\xB2) = (ac \xB1 bd)\xB2 + (ad \u2213 bc)\xB2.     \u042D\u0442\u043E \u0442\u043E\u0436\u0434\u0435\u0441\u0442\u0432\u043E
    \u0441\u0442\u0430\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u0432\u0441\u0435\u0439 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u0438\u0444\u0430\u0433\u043E\u0440\u043E\u0432\u044B\u0445
    \u0442\u0440\u043E\u0435\u043A \u0438 \u043D\u0430\u0448\u043B\u043E \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0434\u0430\u0436\u0435 \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u043E\u0440\u043C. *   **\u0414\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F:** \u0412 \xAB\u041A\u043D\u0438\u0433\u0435
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432\xBB \u043E\u043D \u0440\u0435\u0448\u0438\u043B
    \u0441\u0435\u0440\u0438\u044E \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 (\u0430\u043D\u0430\u043B\u0438\u0437
    \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u0430), \u043F\u043E\u043A\u0430\u0437\u0430\u0432,
    \u043A\u0430\u043A \u043D\u0430\u0439\u0442\u0438 \u0446\u0435\u043B\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0434\u043B\u044F \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0432\u0438\u0434\u0430 x\xB2 + y\xB2 = z\xB2, \u043F\u0440\u0438\u0447\u0435\u043C
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0440\u043E\u0439\u043A\u0438,
    \u0430 \u0441\u0435\u0440\u0438\u0438 \u0442\u0440\u043E\u0435\u043A \u0441 \u0437\u0430\u0434\u0430\u043D\u043D\u044B\u043C\u0438
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\u043C\u0438. *   **\u0421\u0443\u043C\u043C\u044B
    \u043A\u0443\u0431\u043E\u0432:** \u041E\u043D \u043D\u0430\u0448\u0435\u043B
    \u043C\u0435\u0442\u043E\u0434\u044B \u0434\u043B\u044F \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u043E\u0436\u043D\u043E
    \u0440\u0430\u0437\u043B\u043E\u0436\u0438\u0442\u044C \u043D\u0430 \u0441\u0443\u043C\u043C\u0443
    \u0434\u0432\u0443\u0445 \u043A\u0443\u0431\u043E\u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u043C\u0438
    \u0441\u043F\u043E\u0441\u043E\u0431\u0430\u043C\u0438, \u0447\u0442\u043E \u043D\u0430
    \u0441\u043E\u0442\u043D\u0438 \u043B\u0435\u0442 \u043F\u0440\u0435\u0434\u0432\u043E\u0441\u0445\u0438\u0442\u0438\u043B\u043E
    \u0437\u0430\u0434\u0430\u0447\u0443 \u043E \u0442\u0430\u043A\u0441\u0438 (\u0447\u0438\u0441\u043B\u0430
    \u0425\u0430\u0440\u0434\u0438-\u0420\u0430\u043C\u043D\u0443\u0434\u0436\u0430\u043D\u0430). 
    ---  ### 4. \u041F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438 \u0438 \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0442\u043E\u0440\u0438\u043A\u0430 
    \u0421\u0430\u043C\u043E\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043D\u0430 \u0441\u0430\u043C\u043E\u043C
    \u0434\u0435\u043B\u0435 \u0431\u044B\u043B\u043E \u0434\u043B\u044F \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u043B\u0438\u0448\u044C *\u043A\u0440\u0430\u0441\u0438\u0432\u043E\u0439 \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0430\u0446\u0438\u0435\u0439*
    \u043A \u0437\u0430\u0434\u0430\u0447\u0435 \u043E \u0440\u0430\u0437\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0438
    \u043A\u0440\u043E\u043B\u0438\u043A\u043E\u0432 \u0432 12-\u0439 \u0433\u043B\u0430\u0432\u0435
    \xAB\u041A\u043D\u0438\u0433\u0438 \u0430\u0431\u0430\u043A\u0430\xBB. \u041E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u0432 \u044D\u0442\u0443 \u043E\u0431\u043B\u0430\u0441\u0442\u044C
    \u043E\u0433\u0440\u043E\u043C\u0435\u043D:  *   **\u0421\u0430\u043C\u0430 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C:**
    1, 1, 2, 3, 5, 8, 13, 21, 34... *   **\u0420\u0435\u043A\u0443\u0440\u0440\u0435\u043D\u0442\u043D\u043E\u0435
    \u043F\u0440\u0430\u0432\u0438\u043B\u043E:** \u041E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0447\u0435\u0442\u043A\u043E \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0440\u0435\u043A\u0443\u0440\u0440\u0435\u043D\u0442\u043D\u043E\u0435 \u0441\u043E\u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435
    (\u043A\u0430\u0436\u0434\u043E\u0435 \u0447\u0438\u0441\u043B\u043E \u0440\u0430\u0432\u043D\u043E
    \u0441\u0443\u043C\u043C\u0435 \u0434\u0432\u0443\u0445 \u043F\u0440\u0435\u0434\u044B\u0434\u0443\u0449\u0438\u0445).
    *   **\u0411\u0438\u043D\u043E\u043C\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u044B:** \u0420\u0430\u0431\u043E\u0442\u0430\u044F
    \u0441 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E,
    \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438 \u0437\u0430\u043C\u0435\u0442\u0438\u043B,
    \u0447\u0442\u043E \u0441\u0443\u043C\u043C\u0430 \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u0432 \u0432 \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0435
    \u041F\u0430\u0441\u043A\u0430\u043B\u044F (\u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u0435\u0449\u0435 \u043D\u0435 \u0431\u044B\u043B
    \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D) \u0434\u0430\u0435\u0442 \u0442\u0435
    \u0436\u0435 \u0447\u0438\u0441\u043B\u0430. \u041E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B
    \u043E\u0441\u043D\u043E\u0432\u044B \u0434\u043B\u044F \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F
    \u0447\u0438\u0441\u043B\u0430 \u043A\u043E\u043C\u0431\u0438\u043D\u0430\u0446\u0438\u0439
    (\u0445\u043E\u0442\u044F \u0438 \u043D\u0435 \u0432\u044B\u0432\u0435\u043B
    \u043E\u0431\u0449\u0443\u044E \u0444\u043E\u0440\u043C\u0443\u043B\u0443). *  
    **\u0421\u0432\u044F\u0437\u044C \u0441 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439:**
    \u0412 \xAB\u041F\u0440\u0430\u043A\u0442\u0438\u043A\u0435 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB
    \u043E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435
    \u0441\u043E\u0441\u0435\u0434\u043D\u0438\u0445 \u0447\u0438\u0441\u0435\u043B
    \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438 \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0441\u044F
    \u043A \xAB\u0431\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u0438\xBB (\u0437\u043E\u043B\u043E\u0442\u043E\u043C\u0443
    \u0441\u0435\u0447\u0435\u043D\u0438\u044E, \u03C6 \u2248 1.618), \u0445\u043E\u0442\u044F
    \u0441\u0430\u043C \u0442\u0435\u0440\u043C\u0438\u043D \xAB\u0437\u043E\u043B\u043E\u0442\u043E\u0435
    \u0441\u0435\u0447\u0435\u043D\u0438\u0435\xBB \u043F\u043E\u044F\u0432\u0438\u0442\u0441\u044F
    \u043F\u043E\u0437\u0436\u0435. \u041E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u044D\u0442\u043E \u0434\u043B\u044F \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0445 \u043C\u043D\u043E\u0433\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432
    \u0438 \u0434\u0435\u043B\u0435\u043D\u0438\u044F \u043E\u0442\u0440\u0435\u0437\u043A\u043E\u0432
    \u0432 \u043A\u0440\u0430\u0439\u043D\u0435\u043C \u0438 \u0441\u0440\u0435\u0434\u043D\u0435\u043C
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0438.  ---  ### 5. \u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    \u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F (\xAB\u041F\u0440\u0430\u043A\u0442\u0438\u043A\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB)  \u0412 \u044D\u0442\u043E\u043C
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435 (1220 \u0433.) \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u0432\u044B\u0441\u0442\u0443\u043F\u0438\u043B \u043A\u0430\u043A \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0437\u0430\u0442\u043E\u0440
    \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438,
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u043A \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0437\u0430\u0434\u0430\u0447\u0430\u043C.  *   **\u0422\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u044F:**
    \u041E\u043D \u0432\u0432\u0435\u043B \u0432 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0443\u044E
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0443 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0441\u0438\u043D\u0443\u0441\u043E\u0432 \u0438 \u0445\u043E\u0440\u0434 (\u0445\u043E\u0442\u044F
    \u0438 \u043D\u0435 \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0438\u0445 \u0442\u0430\u043A),
    \u0430\u0434\u0430\u043F\u0442\u0438\u0440\u043E\u0432\u0430\u0432 \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0435
    \u0442\u0440\u0438\u0433\u043E\u043D\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0430\u0431\u043B\u0438\u0446\u044B \u0434\u043B\u044F \u0438\u0437\u043C\u0435\u0440\u0435\u043D\u0438\u044F
    \u0432\u044B\u0441\u043E\u0442 \u0437\u0434\u0430\u043D\u0438\u0439 \u0438 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0439
    \u0434\u043E \u043D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0445
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E \u043C\u0435\u0434\u0438\u0430\u043D\u0430\u0445:** \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u043F\u0440\u0438\u043D\u0430\u0434\u043B\u0435\u0436\u0438\u0442 **\u043F\u0435\u0440\u0432\u043E\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E**
    \u0442\u043E\u0433\u043E \u0444\u0430\u043A\u0442\u0430, \u0447\u0442\u043E \u0432\u0441\u0435
    \u0442\u0440\u0438 \u043C\u0435\u0434\u0438\u0430\u043D\u044B \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430
    \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u044E\u0442\u0441\u044F \u0432
    \u043E\u0434\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u0435 (\u0446\u0435\u043D\u0442\u0440\u043E\u0438\u0434).
    \u042D\u0442\u043E \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u043E\u0441\u044C
    \u0435\u0449\u0435 \u0432 \u0434\u0440\u0435\u0432\u043D\u043E\u0441\u0442\u0438,
    \u043D\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u0434\u0430\u043B \u0435\u043C\u0443 \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435. *   **\u041A\u0432\u0430\u0434\u0440\u0430\u0442\u0443\u0440\u0430
    \u043A\u0440\u0443\u0433\u0430 \u0438 \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u044F:**
    \u041E\u043D \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F \u0437\u0430\u0434\u0430\u0447\u0435\u0439
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0443\u0440\u044B \u043A\u0440\u0443\u0433\u0430,
    \u043D\u0430\u0439\u0434\u044F \u0432\u0435\u0441\u044C\u043C\u0430 \u0442\u043E\u0447\u043D\u043E\u0435
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u0435 \u0447\u0438\u0441\u043B\u0430
    \u03C0 (\u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u0434\u0440\u043E\u0431\u044C 864/275, \u0447\u0442\u043E \u0434\u0430\u0435\u0442
    3.1418 \u2014 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C \u0432\u044B\u0448\u0435,
    \u0447\u0435\u043C \u0443 \u0410\u0440\u0445\u0438\u043C\u0435\u0434\u0430, \u0445\u043E\u0442\u044F
    \u0438 \u043D\u0435 \u043F\u0440\u0435\u0432\u043E\u0441\u0445\u043E\u0434\u044F\u0449\u0430\u044F
    \u043A\u0438\u0442\u0430\u0439\u0441\u043A\u0438\u0435 \u043C\u0435\u0442\u043E\u0434\u044B
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438). *   **\u0410\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430:** \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u0432\u0432\u0435\u043B \u0432 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u0434\u043B\u044F \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043D\u0430\u0438\u0431\u043E\u043B\u044C\u0448\u0435\u0433\u043E \u043E\u0431\u0449\u0435\u0433\u043E
    \u0434\u0435\u043B\u0438\u0442\u0435\u043B\u044F, \u0440\u0430\u0441\u043F\u0438\u0441\u0430\u0432
    \u0435\u0433\u043E \u0432 \u0444\u043E\u0440\u043C\u0435, \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u0439
    \u0434\u043B\u044F \u043A\u0443\u043F\u0446\u043E\u0432 (\u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0432\u044B\u0447\u0438\u0442\u0430\u043D\u0438\u0435).  ---  ### 6. \u0418\u043D\u043D\u043E\u0432\u0430\u0446\u0438\u0438
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043D\u043E\u0442\u0430\u0446\u0438\u0438  \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u0438\u0441\u0442\u0435\u043C\u0443
    \u0437\u0430\u043F\u0438\u0441\u0438 \u0434\u0440\u043E\u0431\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u0439:  *   **\u0426\u0435\u043F\u043D\u044B\u0435
    \u0434\u0440\u043E\u0431\u0438:** \u041F\u0440\u0438 \u0440\u0430\u0431\u043E\u0442\u0435
    \u0441 \u0434\u0440\u043E\u0431\u044F\u043C\u0438 \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u043D\u0443\u044E \u0437\u0430\u043F\u0438\u0441\u044C,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u044B\u043B\u0430 \u043F\u0440\u0435\u0434\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u043E\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 \u0446\u0435\u043F\u043D\u044B\u0445
    (\u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0445) \u0434\u0440\u043E\u0431\u0435\u0439.
    *   **\u0427\u0435\u0440\u0442\u0430 \u0434\u0440\u043E\u0431\u0438:** \u0425\u043E\u0442\u044F
    \u043E\u043D \u043D\u0435 \u0438\u0437\u043E\u0431\u0440\u0435\u043B \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u0434\u0440\u043E\u0431\u043D\u0443\u044E \u0447\u0435\u0440\u0442\u0443 (\u044D\u0442\u043E
    \u0441\u0434\u0435\u043B\u0430\u044E\u0442 \u0430\u0440\u0430\u0431\u044B), \u0438\u043C\u0435\u043D\u043D\u043E
    \u0447\u0435\u0440\u0435\u0437 \u0435\u0433\u043E \u043A\u043D\u0438\u0433\u0438
    \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0446\u044B \u0443\u0441\u0432\u043E\u0438\u043B\u0438
    \u0437\u0430\u043F\u0438\u0441\u044C \u0434\u0440\u043E\u0431\u0435\u0439 \u0441
    \u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u0435\u043C \u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0430\u0442\u0435\u043B\u0435\u043C,
    \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u043C\u0438
    \u0434\u0440\u0443\u0433 \u043D\u0430\u0434 \u0434\u0440\u0443\u0433\u043E\u043C.
    *   **\u0421\u0442\u0435\u043F\u0435\u043D\u0438:** \u041E\u043D \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F \u0434\u043B\u044F
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432 (`zensus`), \u043A\u0443\u0431\u043E\u0432
    (`cubus`) \u0438 \u0431\u0438\u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432
    (`census census`), \u0441\u043E\u0437\u0434\u0430\u0432 \u0431\u0430\u0437\u0443,
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0447\u0435\u0440\u0435\u0437
    \u0442\u0440\u0438\u0441\u0442\u0430 \u043B\u0435\u0442 \u0424\u0440\u0430\u043D\u0441\u0443\u0430
    \u0412\u0438\u0435\u0442 \u0438 \u0414\u0435\u043A\u0430\u0440\u0442 \u043F\u043E\u0441\u0442\u0440\u043E\u044F\u0442
    \u0431\u0443\u043A\u0432\u0435\u043D\u043D\u0443\u044E \u0430\u043B\u0433\u0435\u0431\u0440\u0443. 
    ---  ### \u0420\u0435\u0437\u044E\u043C\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F 
    \u0412\u043A\u043B\u0430\u0434 \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u0432 \u043D\u0430\u0443\u043A\u0443 \u0443\u043D\u0438\u043A\u0430\u043B\u0435\u043D
    \u0442\u0435\u043C, \u0447\u0442\u043E \u043E\u043D **\u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E**
    \u043F\u043E\u0434\u043D\u044F\u043B \u0438 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u0443\u044E,
    \u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443. \u041E\u043D \u0431\u044B\u043B
    \u043F\u0435\u0440\u0432\u044B\u043C \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0446\u0435\u043C
    \u043F\u043E\u0441\u043B\u0435 \u043F\u0430\u0434\u0435\u043D\u0438\u044F \u0420\u0438\u043C\u0430,
    \u043A\u0442\u043E: 1.  \u0414\u043E\u043A\u0430\u0437\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u043D\u043E\u0432\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F.
    2.  \u0420\u0435\u0448\u0438\u043B \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u0442\u0440\u0435\u0442\u044C\u0435\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0441 \u043D\u0435\u0434\u043E\u0441\u0442\u0438\u0436\u0438\u043C\u043E\u0439
    \u0434\u043B\u044F XIII \u0432\u0435\u043A\u0430 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E.
    3.  \u041F\u0440\u043E\u0432\u0435\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0435
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. 4.  \u0421\u0432\u044F\u0437\u0430\u043B
    \u0430\u043B\u0433\u0435\u0431\u0440\u0443 \u0441 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0435\u0439
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u0432 \u0435\u0434\u0438\u043D\u0443\u044E
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0443. 
    \u0424\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438, \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u0441\u043E\u0437\u0434\u0430\u043B \u0442\u043E\u0442 \u044F\u0437\u044B\u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0430 \u0415\u0432\u0440\u043E\u043F\u0430
    \u0434\u043E \u044D\u043F\u043E\u0445\u0438 \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F,
    \u0430 \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C \u043D\u0435\u043F\u0440\u0435\u0432\u0437\u043E\u0439\u0434\u0435\u043D\u043D\u043E\u0439
    \u0434\u043E \u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u044F \u0440\u0430\u0431\u043E\u0442
    \u041F\u044C\u0435\u0440\u0430 \u0424\u0435\u0440\u043C\u0430 \u0432 XVII \u0432\u0435\u043A\u0435."
  achievementsEn: 
  personalLifeRu: "\u041E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u041F\u0438\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E (\u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438)
    \u043C\u043E\u0436\u043D\u043E \u0441\u043A\u0430\u0437\u0430\u0442\u044C \u043E\u0434\u043D\u043E:
    **\u043E\u043D\u0430 \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0441\u043A\u0440\u044B\u0442\u043E\u0439
    \u043E\u0442 \u043D\u0430\u0441**. \u0412 \u044D\u0442\u043E\u043C \u0441\u043C\u044B\u0441\u043B\u0435
    \u043E\u043D \u0431\u044B\u043B \"\u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u0431\u0435\u0437 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438\".
    \u0415\u0441\u043B\u0438 \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B \u0438 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F
    \u0445\u043E\u0440\u043E\u0448\u043E \u0437\u0430\u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u044B
    \u0432 \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u043F\u0440\u0435\u0434\u0438\u0441\u043B\u043E\u0432\u0438\u044F\u0445, \u0442\u043E
    \u0432\u0441\u044F \"\u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0430\u044F\"
    \u0441\u0442\u043E\u0440\u043E\u043D\u0430, \u043A\u0430\u043A \u044D\u0442\u043E
    \u0447\u0430\u0441\u0442\u043E \u0431\u044B\u0432\u0430\u0435\u0442 \u0441 \u0443\u0447\u0451\u043D\u044B\u043C\u0438
    \u0421\u0440\u0435\u0434\u043D\u0435\u0432\u0435\u043A\u043E\u0432\u044C\u044F,
    \u043E\u043A\u0443\u0442\u0430\u043D\u0430 \u043C\u0440\u0430\u043A\u043E\u043C. 
    ### \u041E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435 \u0441\u0435\u043C\u044C\u0438:
    \u0416\u0435\u043D\u0430\u0442 \u043B\u0438 \u043E\u043D \u0431\u044B\u043B \u0438
    \u0431\u044B\u043B\u0438 \u043B\u0438 \u0443 \u043D\u0435\u0433\u043E \u0434\u0435\u0442\u0438? 
    \u041D\u0430 \u044D\u0442\u043E\u0442 \u0432\u043E\u043F\u0440\u043E\u0441 \u0443
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u0432 \u0435\u0441\u0442\u044C
    \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0434\u0438\u043D \u043E\u0442\u0432\u0435\u0442:
    **\u043D\u0435\u0442 \u043D\u0438\u043A\u0430\u043A\u0438\u0445 \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u0439**.
    \u041D\u0438 \u0432 \u043E\u0434\u043D\u043E\u043C \u0438\u0437 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432\u0448\u0438\u0445\u0441\u044F
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u043E\u0432 \u2014 \u043D\u0438
    \u0432 \u0435\u0433\u043E \u043A\u043D\u0438\u0433\u0430\u0445, \u043D\u0438
    \u0432 \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445 \u0437\u0430\u043F\u0438\u0441\u044F\u0445
    \u041F\u0438\u0437\u044B \u2014 \u043D\u0435\u0442 \u043D\u0438 \u043C\u0430\u043B\u0435\u0439\u0448\u0435\u0433\u043E
    \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F \u043E \u0436\u0435\u043D\u0435
    \u0438\u043B\u0438 \u0434\u0435\u0442\u044F\u0445. \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u043C,
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442 \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435,
    \u0447\u0442\u043E \u043E\u043D \u0442\u0430\u043A \u0438 \u043D\u0435 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u0438 \u043D\u0435 \u0438\u043C\u0435\u043B \u043F\u043E\u0442\u043E\u043C\u0441\u0442\u0432\u0430.
    \u041F\u0440\u0438\u0447\u0438\u043D\u043E\u0439 \u044D\u0442\u043E\u0433\u043E
    \u043C\u043E\u0433\u043B\u0438 \u0431\u044B\u0442\u044C \u0435\u0433\u043E \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u044B\u0435
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F \u0432 \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438,
    \u0430 \u0432 \u0437\u0440\u0435\u043B\u043E\u043C \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    \u2014 \u043F\u043E\u043B\u043D\u0430\u044F \u043F\u043E\u0433\u0440\u0443\u0436\u0451\u043D\u043D\u043E\u0441\u0442\u044C
    \u0432 \u043D\u0430\u0443\u043A\u0443 \u0438 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0432\u0430\u0436\u043D\u043E \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u043D\u0443\u0442\u044C:
    \u044D\u0442\u043E \u0432\u0441\u0435\u0433\u043E \u043B\u0438\u0448\u044C \u0434\u043E\u0433\u0430\u0434\u043A\u0430,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u0430\u044F \u043D\u0430 \u043C\u043E\u043B\u0447\u0430\u043D\u0438\u0438
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u0432.  ### \u0421\u0435\u043C\u044C\u044F
    \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435 
    \u0417\u0434\u0435\u0441\u044C \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044F
    \u0431\u043E\u043B\u0435\u0435 \u044F\u0441\u043D\u0430, \u0445\u043E\u0442\u044F
    \u0438 \u043D\u0435 \u0431\u0435\u0437 \u043D\u044E\u0430\u043D\u0441\u043E\u0432. 
    *   **\u041E\u0442\u0435\u0446: \u0413\u0443\u043B\u044C\u0435\u043B\u044C\u043C\u043E
    (\u0413\u0438\u043B\u044C\u0435\u0440\u043C\u043E)**. \u0415\u0433\u043E \u043E\u0442\u0435\u0446
    \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C \u0441\u0435\u043C\u044C\u0438
    \u0411\u043E\u043D\u0430\u0447\u0447\u0438 \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u043B
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u0438\u0441\u0430\u0440\u044F (publicus scriba) \u0438\u043B\u0438 \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u044F
    \u041F\u0438\u0437\u0430\u043D\u0441\u043A\u043E\u0439 \u0440\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0438.
    \u0412\u0430\u0436\u043D\u043E \u0443\u0442\u043E\u0447\u043D\u0438\u0442\u044C:
    \u043E\u043D \u043D\u0435 \u0431\u044B\u043B \"\u0441\u044B\u043D\u043E\u043C
    \u0411\u043E\u043D\u0430\u0447\u0447\u0438\" (filius Bonacci) \u0432 \u043F\u0440\u044F\u043C\u043E\u043C
    \u0441\u043C\u044B\u0441\u043B\u0435, \u0430 \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C
    \u044D\u0442\u043E\u0433\u043E \u0440\u043E\u0434\u0430. \u041F\u0440\u043E\u0437\u0432\u0438\u0449\u0435
    \"\u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438\", \u043F\u043E\u0434
    \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u043C\u044B \u0435\u0433\u043E \u0437\u043D\u0430\u0435\u043C,
    \u0432\u043E\u0437\u043D\u0438\u043A\u043B\u043E \u043A\u0430\u043A \u0441\u043E\u043A\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u043E\u0442 \"filius Bonacci\" \u0438 \u0431\u044B\u043B\u043E \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043D\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u043E\u043C \u0413\u0438\u0439\u043E\u043C\u043E\u043C
    \u041B\u0438\u0431\u0440\u0438 \u043B\u0438\u0448\u044C \u0432 XIX \u0432\u0435\u043A\u0435.
    *   **\u041C\u0430\u0442\u044C**: \u0412 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430\u0445 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043C\u0430\u0442\u044C \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u0437\u0432\u0430\u043B\u0438 **\u0410\u043B\u0435\u0441\u0441\u0430\u043D\u0434\u0440\u0430**
    \u0438 \u043E\u043D\u0430 \u0443\u043C\u0435\u0440\u043B\u0430, \u043A\u043E\u0433\u0434\u0430
    \u0435\u043C\u0443 \u0431\u044B\u043B\u043E \u043E\u043A\u043E\u043B\u043E \u0434\u0435\u0432\u044F\u0442\u0438
    \u043B\u0435\u0442, \u043D\u043E \u044D\u0442\u043E \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435
    \u043D\u0435 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043E\u0431\u0449\u0435\u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043D\u044B\u043C
    \u0438 \u0447\u0430\u0441\u0442\u043E \u043D\u0435 \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0430\u0432\u0442\u043E\u0440\u0438\u0442\u0435\u0442\u043D\u043E\u0439
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u0435.  ### \u041F\u0440\u043E\u0437\u0432\u0438\u0449\u0435
    \"\u0411\u0438\u0433\u043E\u043B\u043B\u043E\" (Bigollo)  \u041F\u043E\u043C\u0438\u043C\u043E
    \"\u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438\", \u0443 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u0431\u044B\u043B\u043E \u0435\u0449\u0451 \u043E\u0434\u043D\u043E \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435,
    \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u043E\u043D, \u043A\u0430\u043A \u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0442,
    \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F \u0441\u0430\u043C
    \u2014 **\u0411\u0438\u0433\u043E\u043B\u043B\u043E (Bigollo)**. \u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u044D\u0442\u043E\u0433\u043E \u0441\u043B\u043E\u0432\u0430 \u043D\u0435\u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E:
    *   \u0412 \u0442\u043E\u0441\u043A\u0430\u043D\u0441\u043A\u043E\u043C \u0434\u0438\u0430\u043B\u0435\u043A\u0442\u0435
    \u043E\u043D\u043E \u043C\u043E\u0433\u043B\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0442\u044C
    **\"\u0431\u0435\u0437\u0434\u0435\u043B\u044C\u043D\u0438\u043A\"** \u0438\u043B\u0438
    \"\u043B\u043E\u0434\u044B\u0440\u044C\" (bighellone) \u2014 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u0441 \u043B\u0451\u0433\u043A\u043E\u0439 \u0438\u0440\u043E\u043D\u0438\u0435\u0439
    \u043E\u0442 \u0437\u0435\u043C\u043B\u044F\u043A\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u043B\u0438 \u0435\u0433\u043E
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F \u0447\u0438\u0441\u0442\u043E\u0439,
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u0447\u0438\u0441\u0435\u043B. *   \u0421 \u0434\u0440\u0443\u0433\u043E\u0439
    \u0441\u0442\u043E\u0440\u043E\u043D\u044B, \u044D\u0442\u043E \u0436\u0435 \u0441\u043B\u043E\u0432\u043E
    \u043C\u043E\u0433\u043B\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0442\u044C
    **\"\u043C\u043D\u043E\u0433\u043E \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u0432\u0448\u0438\u0439\"**,
    \u0447\u0442\u043E \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E \u0442\u043E\u0447\u043D\u043E
    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438.  ###
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B:
    \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E 
    \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435, \u0447\u0442\u043E \u043C\u044B
    \u0437\u043D\u0430\u0435\u043C \u043E \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438,
    \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F \u0432 \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0435 \u043E\u0442 **1240 \u0433\u043E\u0434\u0430**.
    \u0420\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430 \u041F\u0438\u0437\u0430
    \u043F\u0440\u0438\u043D\u044F\u043B\u0430 \u0443\u043A\u0430\u0437 \u043E \u043D\u0430\u0433\u0440\u0430\u0436\u0434\u0435\u043D\u0438\u0438
    \"\u0441\u0435\u0440\u044C\u0451\u0437\u043D\u043E\u0433\u043E \u0438 \u0443\u0447\u0451\u043D\u043E\u0433\u043E
    \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u0411\u0438\u0433\u043E\u043B\u043B\u043E\" (discretus et sapiens) \u0435\u0436\u0435\u0433\u043E\u0434\u043D\u044B\u043C
    \u0436\u0430\u043B\u043E\u0432\u0430\u043D\u044C\u0435\u043C \u0432 \u0440\u0430\u0437\u043C\u0435\u0440\u0435
    20 \u043B\u0438\u0440.  \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u043D\u0435
    \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u0435\u043D\u0441\u0438\u044F, \u0430
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0435\u0433\u043E \u0437\u0430\u0441\u043B\u0443\u0433
    \u043F\u0435\u0440\u0435\u0434 \u0433\u043E\u0440\u043E\u0434\u043E\u043C \u0438
    \u0435\u0433\u043E \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0430\u043C\u0438,
    \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u043D\u043E\u0435 \u0432 \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u043D\u043E\u0441\u0442\u0438
    \u0437\u0430 \u0435\u0433\u043E \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u0435
    \u0438 \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0435
    \u0443\u0441\u043B\u0443\u0433\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043E\u043D, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043E\u043A\u0430\u0437\u044B\u0432\u0430\u043B
    \u0433\u043E\u0440\u043E\u0434\u0443 \u043F\u043E \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u043C
    \u0431\u0443\u0445\u0433\u0430\u043B\u0442\u0435\u0440\u0438\u0438 \u0438 \u0441\u0447\u0435\u0442\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u0430.
    \u042D\u0442\u0430 \u0437\u0430\u043F\u0438\u0441\u044C \u2014 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u0435
    \u043E \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438. \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0443\u043C\u0435\u0440 \u0432 \u041F\u0438\u0437\u0435
    \u043C\u0435\u0436\u0434\u0443 1240 \u0438 1250 \u0433\u043E\u0434\u0430\u043C\u0438,
    \u043D\u043E \u0442\u043E\u0447\u043D\u0430\u044F \u0434\u0430\u0442\u0430 \u0438
    \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u0441\u0442\u0430\u044E\u0442\u0441\u044F
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C\u0438.  \u0422\u0430\u043A\u0438\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, **\u043B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u2014 \u044D\u0442\u043E \u043F\u043E\u0447\u0442\u0438 \u0441\u043F\u043B\u043E\u0448\u043D\u043E\u0435
    \u0431\u0435\u043B\u043E\u0435 \u043F\u044F\u0442\u043D\u043E**. \u041C\u044B
    \u0437\u043D\u0430\u0435\u043C \u0435\u0433\u043E \u043A\u0430\u043A \u0444\u0438\u0433\u0443\u0440\u0443
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E \u0438
    \u043D\u0430\u0443\u0447\u043D\u0443\u044E: \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0438\u043A\u0430,
    \u0443\u0447\u0435\u043D\u0438\u043A\u0430, \u0443\u0447\u0438\u0442\u0435\u043B\u044F,
    \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u044F \u0438 \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u0430.
    \u0412\u0441\u0451, \u0447\u0442\u043E \u043A\u0430\u0441\u0430\u0435\u0442\u0441\u044F
    \u0435\u0433\u043E \u0447\u0430\u0441\u0442\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438,
    \u043E\u0441\u0442\u0430\u043B\u043E\u0441\u044C \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438."
  personalLifeEn: 
  shortBioRu: "**\u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E \u041F\u0438\u0437\u0430\u043D\u0441\u043A\u0438\u0439
    (\u043E\u043A. 1170 \u2014 \u043E\u043A. 1250)**, \u0431\u043E\u043B\u0435\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u043F\u043E\u0434 \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435\u043C
    **\u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438**, \u0431\u044B\u043B
    \u043F\u0435\u0440\u0432\u044B\u043C \u043A\u0440\u0443\u043F\u043D\u044B\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u0441\u0440\u0435\u0434\u043D\u0435\u0432\u0435\u043A\u043E\u0432\u043E\u0439
    \u0415\u0432\u0440\u043E\u043F\u044B. \u0415\u0433\u043E \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0430\u044F
    \u0437\u0430\u0441\u043B\u0443\u0433\u0430 \u2014 \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u0435
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435 \u0438\u043D\u0434\u043E-\u0430\u0440\u0430\u0431\u0441\u043A\u043E\u0439
    \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u043E\u043F\u0438\u0441\u0430\u043B \u0432 \u0441\u0432\u043E\u0435\u043C \u0433\u043B\u0430\u0432\u043D\u043E\u043C
    \u0442\u0440\u0443\u0434\u0435 \u2014 \xAB\u041A\u043D\u0438\u0433\u0435 \u0430\u0431\u0430\u043A\u0430\xBB. 
    \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u044D\u0442\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u0430\u044F
    \u043D\u0430 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0430\u043A\u0442\u0430\u0445 \u0438 \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u0445. 
    ### \u0420\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B \u0438 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F 
    \u041E \u0436\u0438\u0437\u043D\u0438 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E \u043D\u0435\u043C\u043D\u043E\u0433\u043E,
    \u0438 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F
    \u043C\u044B \u0447\u0435\u0440\u043F\u0430\u0435\u043C \u0438\u0437 \u0435\u0433\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445 \u043A\u043D\u0438\u0433.
    \u041E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0432 \u0438\u0442\u0430\u043B\u044C\u044F\u043D\u0441\u043A\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u0435 \u041F\u0438\u0437\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0445
    \u0442\u043E\u0440\u0433\u043E\u0432\u044B\u0445 \u0446\u0435\u043D\u0442\u0440\u043E\u0432
    \u0421\u0440\u0435\u0434\u0438\u0437\u0435\u043C\u043D\u043E\u043C\u043E\u0440\u044C\u044F.
    \u0422\u043E\u0447\u043D\u044B\u0439 \u0433\u043E\u0434 \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D, \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u043A
    \u043C\u0435\u0436\u0434\u0443 **1170 \u0438 1180 \u0433\u043E\u0434\u0430\u043C\u0438**. 
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, **\u0413\u0438\u043B\u044C\u0435\u0440\u043C\u043E
    (\u0413\u0443\u043B\u044C\u0435\u043B\u044C\u043C\u043E)** , \u0431\u044B\u043B
    \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0435\u043C \u0438 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u043B
    \u0444\u0443\u043D\u043A\u0446\u0438\u0438 \u0442\u0430\u043C\u043E\u0436\u0435\u043D\u043D\u043E\u0433\u043E
    \u0447\u0438\u043D\u043E\u0432\u043D\u0438\u043A\u0430, \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u044F
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B \u043F\u0438\u0437\u0430\u043D\u0441\u043A\u0438\u0445
    \u043A\u0443\u043F\u0446\u043E\u0432 \u0432 \u0421\u0435\u0432\u0435\u0440\u043D\u043E\u0439
    \u0410\u0444\u0440\u0438\u043A\u0435, \u0432 \u043F\u043E\u0440\u0442\u0443 **\u0411\u0435\u0434\u0436\u0430\u044F**
    (\u043D\u0430 \u0442\u0435\u0440\u0440\u0438\u0442\u043E\u0440\u0438\u0438 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u0410\u043B\u0436\u0438\u0440\u0430). \u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C,
    \u0435\u0449\u0435 \u0432 \u043E\u0442\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u0435,
    \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E \u043D\u0430\u0447\u0430\u043B
    \u0438\u0437\u0443\u0447\u0430\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443.
    \u0416\u0435\u043B\u0430\u044F, \u0447\u0442\u043E\u0431\u044B \u0441\u044B\u043D
    \u043F\u043E\u0448\u0435\u043B \u043F\u043E \u0435\u0433\u043E \u0441\u0442\u043E\u043F\u0430\u043C,
    \u043E\u0442\u0435\u0446 \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u043B
    \u0435\u0433\u043E \u0432 \u0410\u043B\u0436\u0438\u0440, \u0433\u0434\u0435
    \u044E\u043D\u043E\u0448\u0430 \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F
    \u0441 **\xAB\u0438\u043D\u0434\u0438\u0439\u0441\u043A\u0438\u043C \u043C\u0435\u0442\u043E\u0434\u043E\u043C\xBB**
    \u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u0443 \u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0445
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439.  \u041E\u0447\u0430\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u043E\u0439 \u0438 \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C\u044E
    \u044D\u0442\u0438\u0445 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439,
    \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u0434\u043E\u043B\u0433\u0438\u0435 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F
    \u043F\u043E \u0421\u0440\u0435\u0434\u0438\u0437\u0435\u043C\u043D\u043E\u043C\u043E\u0440\u044C\u044E.
    \u041E\u043D \u043F\u043E\u0441\u0435\u0442\u0438\u043B **\u0415\u0433\u0438\u043F\u0435\u0442,
    \u0421\u0438\u0440\u0438\u044E, \u0412\u0438\u0437\u0430\u043D\u0442\u0438\u044E
    (\u0413\u0440\u0435\u0446\u0438\u044E), \u0421\u0438\u0446\u0438\u043B\u0438\u044E
    \u0438 \u041F\u0440\u043E\u0432\u0430\u043D\u0441**. \u0426\u0435\u043B\u044C\u044E
    \u044D\u0442\u0438\u0445 \u043F\u043E\u0435\u0437\u0434\u043E\u043A \u0431\u044B\u043B\u043E
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u0435\u0442\u043E\u0434\u043E\u0432, \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0432 \u044D\u0442\u0438\u0445 \u0440\u0435\u0433\u0438\u043E\u043D\u0430\u0445.
    \u041F\u043E \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0441\u043B\u043E\u0432\u0430\u043C, \u043E\u043D \xAB\u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u043C\u043D\u043E\u0433\u043E \u0442\u0440\u0443\u0434\u0430 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u043C\u0443
    \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u044E \u0438\u0445 \u043C\u0435\u0442\u043E\u0434\u043E\u0432
    \u0438 \u043E\u0432\u043B\u0430\u0434\u0435\u043B \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E\u043C
    \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E \u0441\u043F\u043E\u0440\u0430\xBB. 
    ### \u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435 \u0438
    \xAB\u041A\u043D\u0438\u0433\u0430 \u0430\u0431\u0430\u043A\u0430\xBB  \u041E\u043A\u043E\u043B\u043E
    **1200 \u0433\u043E\u0434\u0430** \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F \u0432 \u041F\u0438\u0437\u0443,
    \u0433\u0434\u0435 \u0438 \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0438\u043B
    \u043A \u0440\u0430\u0431\u043E\u0442\u0435 \u043D\u0430\u0434 \u0441\u0432\u043E\u0438\u043C
    \u0433\u043B\u0430\u0432\u043D\u044B\u043C \u0442\u0440\u0443\u0434\u043E\u043C
    \u2014 **\xAB\u041A\u043D\u0438\u0433\u043E\u0439 \u0430\u0431\u0430\u043A\u0430\xBB
    (Liber Abaci)**. \u041F\u0435\u0440\u0432\u043E\u0435 \u0438\u0437\u0434\u0430\u043D\u0438\u0435
    \u043A\u043D\u0438\u0433\u0438 \u0431\u044B\u043B\u043E \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u043E
    \u0432 **1202 \u0433\u043E\u0434\u0443**, \u043D\u043E \u0434\u043E \u043D\u0430\u0441
    \u0434\u043E\u0448\u043B\u0430 \u0442\u043E\u043B\u044C\u043A\u043E \u0435\u0435
    \u0434\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u0430\u044F \u0432\u0435\u0440\u0441\u0438\u044F
    **1228 \u0433\u043E\u0434\u0430**.  *   **\u0421\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435
    \u0438 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435:** \u041A\u043D\u0438\u0433\u0430
    \u043D\u0435 \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u0441\u0447\u0435\u0442\u043D\u043E\u0439 \u0434\u043E\u0441\u043A\u0435 (\u0430\u0431\u0430\u043A\u0435),
    \u043A\u0430\u043A \u043C\u043E\u0436\u043D\u043E \u0431\u044B\u043B\u043E \u0431\u044B
    \u043F\u043E\u0434\u0443\u043C\u0430\u0442\u044C \u0438\u0437 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u044F.
    \u041D\u0430\u043F\u0440\u043E\u0442\u0438\u0432, \u043E\u043D\u0430 \u0441\u043B\u0443\u0436\u0438\u043B\u0430
    \u0432\u0441\u0435\u043E\u0431\u044A\u0435\u043C\u043B\u044E\u0449\u0438\u043C
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C \u043F\u043E
    \u043D\u043E\u0432\u043E\u0439 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0435,
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u043E\u0439 \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u043E\u0439
    \u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u0435.
    \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0434\u0435\u0441\u044F\u0442\u044C **\xAB\u0438\u043D\u0434\u0438\u0439\u0441\u043A\u0438\u0445
    \u0444\u0438\u0433\u0443\u0440\xBB** (\u0446\u0438\u0444\u0440 \u043E\u0442 0
    \u0434\u043E 9) \u0438 \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043C\u0435\u0441\u0442\u0430
    \u0447\u0438\u0441\u043B\u0430. *   **\u0421\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430:**
    \xAB\u041A\u043D\u0438\u0433\u0430 \u0430\u0431\u0430\u043A\u0430\xBB \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0430
    \u0438\u0437 15 \u0433\u043B\u0430\u0432, \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0431\u044B\u043B\u0438 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u044B:    
    *   \u0410\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0430 \u0446\u0435\u043B\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u0438 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
    \u0441 \u0434\u0440\u043E\u0431\u044F\u043C\u0438.     *   \u0417\u0430\u0434\u0430\u0447\u0438
    \u043A\u043E\u043C\u043C\u0435\u0440\u0447\u0435\u0441\u043A\u043E\u0439 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438:
    \u0440\u0430\u0441\u0447\u0435\u0442 \u043F\u0440\u0438\u0431\u044B\u043B\u0438,
    \u043E\u0431\u043C\u0435\u043D \u0432\u0430\u043B\u044E\u0442, \u043F\u0435\u0440\u0435\u0432\u043E\u0434
    \u043C\u0435\u0440 \u0438 \u0432\u0435\u0441\u043E\u0432, \u043F\u0440\u043E\u0446\u0435\u043D\u0442\u044B.    
    *   \u041F\u0440\u0430\u0432\u0438\u043B\u0430 \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u0439 (\xAB\u0442\u0440\u043E\u0439\u043D\u043E\u0435
    \u043F\u0440\u0430\u0432\u0438\u043B\u043E\xBB) \u0438 \u043C\u0435\u0442\u043E\u0434
    \u043B\u043E\u0436\u043D\u043E\u0433\u043E \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F.    
    *   \u0417\u0430\u0434\u0430\u0447\u0438 \u043D\u0430 \u0441\u0443\u043C\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u0440\u044F\u0434\u043E\u0432, \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u0440\u043E\u0433\u0440\u0435\u0441\u0441\u0438\u0438.     *   \u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    **\u0437\u0430\u0434\u0430\u0447\u0430 \u043E \u043A\u0440\u043E\u043B\u0438\u043A\u0430\u0445**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u0440\u0438\u0432\u0435\u043B\u0430
    \u043A \u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u044E \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u0447\u0438\u0441\u0435\u043B 1, 1, 2, 3, 5, 8, 13... (\u0445\u043E\u0442\u044F
    \u0441\u0430\u043C\u043E \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435 \xAB\u0447\u0438\u0441\u043B\u0430
    \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438\xBB \u0437\u0430\u043A\u0440\u0435\u043F\u0438\u043B\u043E\u0441\u044C
    \u0437\u0430 \u043D\u0438\u043C\u0438 \u043B\u0438\u0448\u044C \u0432 XIX \u0432\u0435\u043A\u0435).    
    *   \u041F\u0440\u0438\u0435\u043C\u044B \u0438\u0437\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u044F
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0445 \u0438 \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043A\u043E\u0440\u043D\u0435\u0439, \u043F\u0440\u0438\u043C\u0435\u0440\u044B
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0445 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B (\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043D
    \u0442\u0440\u0430\u043A\u0442\u043E\u0432\u0430\u043B \u043A\u0430\u043A \u0434\u043E\u043B\u0433). 
    \u041A\u0430\u043A \u043E\u0442\u043C\u0435\u0447\u0430\u043B \u0438\u0441\u0442\u043E\u0440\u0438\u043A
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0410. \u041F.
    \u042E\u0448\u043A\u0435\u0432\u0438\u0447, \u044D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \xAB\u0440\u0435\u0437\u043A\u043E \u0432\u043E\u0437\u0432\u044B\u0448\u0430\u0435\u0442\u0441\u044F
    \u043D\u0430\u0434 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0439
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u043E-\u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043E\u0439 XII\u2014XIV
    \u0432\u0435\u043A\u043E\u0432 \u0440\u0430\u0437\u043D\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0435\u043C
    \u0438 \u0441\u0438\u043B\u043E\u0439 \u043C\u0435\u0442\u043E\u0434\u043E\u0432\xBB. 
    ### \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438 \u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C  \u0422\u0430\u043B\u0430\u043D\u0442 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u043D\u0435 \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u043D\u0435\u0437\u0430\u043C\u0435\u0447\u0435\u043D\u043D\u044B\u043C.
    \u0415\u0433\u043E \u043A\u043D\u0438\u0433\u0430 \u0438 \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044F
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u043B\u0438 \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430 \u0421\u0432\u044F\u0449\u0435\u043D\u043D\u043E\u0439
    \u0420\u0438\u043C\u0441\u043A\u043E\u0439 \u0438\u043C\u043F\u0435\u0440\u0438\u0438
    **\u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430 II \u0413\u043E\u0433\u0435\u043D\u0448\u0442\u0430\u0443\u0444\u0435\u043D\u0430**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0441\u0432\u043E\u0435\u0439 \u043B\u044E\u0431\u043E\u0432\u044C\u044E \u043A
    \u043D\u0430\u0443\u043A\u0430\u043C \u0438 \u043E\u043A\u0440\u0443\u0436\u0438\u043B
    \u0441\u0435\u0431\u044F \u0443\u0447\u0435\u043D\u044B\u043C\u0438.  \u041E\u043A\u043E\u043B\u043E
    **1225 \u0433\u043E\u0434\u0430**, \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u043E\u0434\u043D\u043E\u0433\u043E \u0438\u0437 \u0432\u0438\u0437\u0438\u0442\u043E\u0432
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430 \u0432 \u041F\u0438\u0437\u0443,
    \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E \u0431\u044B\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D
    \u043A\u043E \u0434\u0432\u043E\u0440\u0443. \u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0443\u0440\u043D\u0438\u0440 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0441\u044F
    \u043F\u0440\u0438 \u0443\u0447\u0430\u0441\u0442\u0438\u0438 \u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u044B\u0445
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u0432 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435 **\u0418\u043E\u0430\u043D\u043D\u0430
    \u041F\u0430\u043B\u0435\u0440\u043C\u0441\u043A\u043E\u0433\u043E**. \u0418\u043E\u0430\u043D\u043D
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0441\u043B\u043E\u0436\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447, \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    **x\xB3 + 2x\xB2 + 10x = 20**. \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435 \u0441\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0441 \u0437\u0430\u0434\u0430\u0447\u0435\u0439, \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0432
    \u043A\u043E\u0440\u0435\u043D\u044C \u0441 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E
    \u0434\u043E 10\u207B\u2079 , \u0438 \u043D\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043B\u0435\u0442 \u0441\u0442\u0430\u043B \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u043D\u044B\u043C
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430, \u0436\u0438\u0432\u044F
    \u043F\u0440\u0438 \u0435\u0433\u043E \u0434\u0432\u043E\u0440\u0435.  ### \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B  \u0412
    \u044D\u0442\u043E\u0442 \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u0439
    \u043F\u0435\u0440\u0438\u043E\u0434 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u0432\u043E\u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0440\u0430\u0431\u043E\u0442\u044B,
    \u043F\u043E\u043C\u0438\u043C\u043E \xAB\u041A\u043D\u0438\u0433\u0438 \u0430\u0431\u0430\u043A\u0430\xBB: 
    1.  **\xAB\u041F\u0440\u0430\u043A\u0442\u0438\u043A\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB
    (Practica Geometriae, 1220)** \u2014 \u0441\u0431\u043E\u0440\u043D\u0438\u043A
    \u0442\u0435\u043E\u0440\u0435\u043C \u0438\u0437 \xAB\u041D\u0430\u0447\u0430\u043B\xBB
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u0438 \u0434\u0440\u0443\u0433\u0438\u0445
    \u0440\u0430\u0431\u043E\u0442, \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u044B\u0439
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C \u0438\u0437\u043C\u0435\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u043C\u0435\u0442\u043E\u0434\u0430\u043C. \u0412 \u044D\u0442\u043E\u0439 \u043A\u043D\u0438\u0433\u0435,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u0441\u043E\u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F
    \u043F\u0435\u0440\u0432\u043E\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0442\u0440\u0438 \u043C\u0435\u0434\u0438\u0430\u043D\u044B
    \u0442\u0440\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A\u0430 \u043F\u0435\u0440\u0435\u0441\u0435\u043A\u0430\u044E\u0442\u0441\u044F
    \u0432 \u043E\u0434\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u0435. 2.  **\xAB\u041A\u043D\u0438\u0433\u0430
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043E\u0432\xBB (Liber Quadratorum,
    1225)** \u2014 \u0448\u0435\u0434\u0435\u0432\u0440 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E,
    \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u043D\u044B\u0439 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B. \u041A\u043D\u0438\u0433\u0430 \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0435\u0442
    \u0434\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u0432\u044B \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F
    \u0432\u0442\u043E\u0440\u043E\u0439 \u0441\u0442\u0435\u043F\u0435\u043D\u0438.
    \u042D\u0442\u043E\u0442 \u0442\u0440\u0443\u0434 \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0441\u0442\u0430\u0432\u0438\u0442 \u0435\u0433\u043E \u0432 \u043E\u0434\u0438\u043D
    \u0440\u044F\u0434 \u0441 \u0441\u0430\u043C\u0438\u043C \u0414\u0438\u043E\u0444\u0430\u043D\u0442\u043E\u043C
    \u0438 \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0437\u0434\u043D\u0438\u043C
    \u041F\u044C\u0435\u0440\u043E\u043C \u0424\u0435\u0440\u043C\u0430 \u043A\u0430\u043A
    \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0435\u0433\u043E \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u0430
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438. 3. 
    **\xAB\u0426\u0432\u0435\u0442\u043E\u043A\xBB (Flos, 1225)** \u2014 \u0440\u0430\u0431\u043E\u0442\u0430,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043F\u0440\u0438\u0432\u0435\u0434\u0435\u043D\u044B
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447, \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0445
    \u0435\u043C\u0443 \u043D\u0430 \u0442\u0443\u0440\u043D\u0438\u0440\u0435 \u043F\u0440\u0438
    \u0434\u0432\u043E\u0440\u0435 \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430
    II.  ### \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \u0434\u043E\u0441\u0442\u043E\u0432\u0435\u0440\u043D\u043E\u0435 \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043E \u0436\u0438\u0437\u043D\u0438 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u043F\u043E\u0441\u043B\u0435 1228 \u0433\u043E\u0434\u0430 \u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0441\u044F
    \u043A **1240 \u0433\u043E\u0434\u0443**. \u0412 \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0435
    \u041F\u0438\u0437\u0430\u043D\u0441\u043A\u043E\u0439 \u0440\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0438
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u0441\u044F, \u0447\u0442\u043E \u0435\u043C\u0443
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0430
    \u0435\u0436\u0435\u0433\u043E\u0434\u043D\u0430\u044F \u043F\u0435\u043D\u0441\u0438\u044F
    \u0437\u0430 \u0437\u0430\u0441\u043B\u0443\u0433\u0438 \u043F\u0435\u0440\u0435\u0434
    \u0433\u043E\u0440\u043E\u0434\u043E\u043C. \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u043E\u043D \u0443\u043C\u0435\u0440 \u0432 \u041F\u0438\u0437\u0435
    \u043E\u043A\u043E\u043B\u043E **1250 \u0433\u043E\u0434\u0430**.  \u041F\u0440\u0438\u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0445
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442\u043E\u0432 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u043D\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C,
    \u0430 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0435
    \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F \u2014 \u044D\u0442\u043E
    \u043F\u043B\u043E\u0434 \u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F
    \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u043E\u0432 \u0431\u043E\u043B\u0435\u0435
    \u043F\u043E\u0437\u0434\u043D\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. 
    \u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u043A\u043E\u043B\u043E\u0441\u0441\u0430\u043B\u044C\u043D\u043E. \u041E\u043D
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B
    \u0415\u0432\u0440\u043E\u043F\u0443 \u0441 \xAB\u0430\u0440\u0430\u0431\u0441\u043A\u0438\u043C\u0438\xBB
    (\u0438\u043D\u0434\u0438\u0439\u0441\u043A\u0438\u043C\u0438) \u0446\u0438\u0444\u0440\u0430\u043C\u0438,
    \u043D\u043E \u0438 \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0443\u0431\u0435\u0434\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0438\u0445 \u043F\u0440\u0435\u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u0430.
    \u0415\u0433\u043E \xAB\u041A\u043D\u0438\u0433\u0430 \u0430\u0431\u0430\u043A\u0430\xBB
    \u0441\u0442\u0430\u043B\u0430 \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u043D\u0430\u043D\u0438\u0439, \u043F\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0443\u0447\u0438\u043B\u0438\u0441\u044C \u043C\u043D\u043E\u0433\u0438\u0435
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u044F \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432, \u0430 \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B \u043F\u0440\u043E\u043B\u043E\u0436\u0438\u043B\u0438
    \u043F\u0443\u0442\u044C \u0443\u0447\u0435\u043D\u044B\u043C \u0412\u043E\u0437\u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F.
    \u041D\u0430\u0437\u0432\u0430\u043D\u043D\u0430\u044F \u0432 \u0435\u0433\u043E
    \u0447\u0435\u0441\u0442\u044C \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0447\u0438\u0441\u0435\u043B \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0446\u0438\u0435\u0439: \u0435\u0435
    \u0437\u0430\u043A\u043E\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438
    \u0431\u044B\u043B\u0438 \u043F\u043E\u0437\u0436\u0435 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u044B
    \u0432 \u043F\u0440\u0438\u0440\u043E\u0434\u0435 \u2014 \u0432 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0435
    \u043B\u0438\u0441\u0442\u044C\u0435\u0432, \u0441\u043E\u0441\u043D\u043E\u0432\u044B\u0445
    \u0448\u0438\u0448\u0435\u043A \u0438 \u0441\u043F\u0438\u0440\u0430\u043B\u044F\u0445
    \u0440\u0430\u043A\u043E\u0432\u0438\u043D."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0438 \u043D\u0430\u0443\u0447\u043D\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u041F\u0438\u0437\u0430\u043D\u0441\u043A\u043E\u0433\u043E, \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043C\u044B \u0437\u043D\u0430\u0435\u043C \u043A\u0430\u043A \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438,
    \u043F\u043E\u043B\u043D\u044B \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0441\u043E\u0432\u043F\u0430\u0434\u0435\u043D\u0438\u0439, \u0437\u0430\u0431\u0430\u0432\u043D\u044B\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043A\u0443\u0440\u044C\u0435\u0437\u043E\u0432
    \u0438 \u0444\u0430\u043A\u0442\u043E\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u043D\u0430\u0447\u0435 \u043A\u0430\u043A \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C\u0438
    \u043D\u0435 \u043D\u0430\u0437\u043E\u0432\u0435\u0448\u044C. \u0412\u043E\u0442
    \u0441\u0430\u043C\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435
    \u0438\u0437 \u043D\u0438\u0445:  ### \U0001F4DC \u0417\u0430\u0433\u0430\u0434\u043A\u0430
    \u0438\u043C\u0435\u043D\u0438: \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043D\u0430 \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435 \u043D\u0435
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E  \u041E\u0434\u0438\u043D
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u043D\u0438\u043A\u0442\u043E \u043D\u0435
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0435\u0433\u043E \xAB\u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438\xBB.
    \u042D\u0442\u043E \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435, \u043F\u043E\u0434
    \u043A\u043E\u0442\u043E\u0440\u044B\u043C \u043E\u043D \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0432\u0441\u0435\u043C\u0443 \u043C\u0438\u0440\u0443, \u0432\u043E\u0437\u043D\u0438\u043A\u043B\u043E
    \u0441\u043F\u0443\u0441\u0442\u044F \u0431\u043E\u043B\u0435\u0435 \u0447\u0435\u043C
    600 \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438,
    \u0432 **1838 \u0433\u043E\u0434\u0443**, \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0443 \u0413\u0438\u0439\u043E\u043C\u0443
    \u041B\u0438\u0431\u0440\u0438.  *   **\u041E\u0442\u043A\u0443\u0434\u0430 \u0432\u0437\u044F\u043B\u043E\u0441\u044C
    \u0438\u043C\u044F?** \u041E\u043D \u0431\u044B\u043B \u0441\u044B\u043D\u043E\u043C
    \u0442\u043E\u0440\u0433\u043E\u0432\u0446\u0430 \u0413\u0443\u043B\u044C\u0435\u043B\u044C\u043C\u043E
    \u0411\u043E\u043D\u0430\u0447\u0447\u0438. \u041F\u043E-\u043B\u0430\u0442\u044B\u043D\u0438
    \"\u0441\u044B\u043D \u0411\u043E\u043D\u0430\u0447\u0447\u0438\" \u0437\u0432\u0443\u0447\u0438\u0442
    \u043A\u0430\u043A *filius Bonacci*. \u0421\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C
    \u044D\u0442\u043E \u0441\u043B\u043E\u0432\u043E\u0441\u043E\u0447\u0435\u0442\u0430\u043D\u0438\u0435
    \u0441\u043E\u043A\u0440\u0430\u0442\u0438\u043B\u043E\u0441\u044C \u0438 \u0442\u0440\u0430\u043D\u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u043E\u0441\u044C
    \u0432 \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u043E\u0435 **Fibonacci**.
    *   **\u0410 \u043A\u0430\u043A \u043E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B
    \u0441\u0435\u0431\u044F \u0441\u0430\u043C?** \u0412 \u0441\u0432\u043E\u0438\u0445
    \u0442\u0440\u0443\u0434\u0430\u0445 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u043F\u043E\u0434\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0441\u044F \u043A\u0430\u043A
    **\u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E \u041F\u0438\u0437\u0430\u043D\u0441\u043A\u0438\u0439**
    (Leonardo Pisano, \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u044F \u043D\u0430
    \u043C\u0435\u0441\u0442\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F)
    \u0438\u043B\u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043F\u0440\u043E\u0437\u0432\u0438\u0449\u0435 **\u0411\u0438\u0433\u043E\u043B\u043B\u043E
    (Bigollo)**. \u042D\u0442\u043E \u0441\u043B\u043E\u0432\u043E \u0441 \u0442\u043E\u0441\u043A\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u0434\u0438\u0430\u043B\u0435\u043A\u0442\u0430 \u043F\u0435\u0440\u0435\u0432\u043E\u0434\u0438\u0442\u0441\u044F
    \u043A\u0430\u043A **\"\u0431\u0435\u0437\u0434\u0435\u043B\u044C\u043D\u0438\u043A\"**,
    \u043D\u043E \u0442\u0430\u043A\u0436\u0435 \u043C\u043E\u0436\u0435\u0442 \u043E\u0437\u043D\u0430\u0447\u0430\u0442\u044C
    \u0438 **\"\u0441\u0442\u0440\u0430\u043D\u043D\u0438\u043A, \u043C\u043D\u043E\u0433\u043E
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u0432\u0448\u0438\u0439\"**.
    \u0427\u0442\u043E \u0438\u0437 \u044D\u0442\u043E\u0433\u043E \u0441\u043F\u0440\u0430\u0432\u0435\u0434\u043B\u0438\u0432\u043E,
    \u0430 \u0447\u0442\u043E \u2014 \u043D\u0430\u0441\u043C\u0435\u0448\u043A\u0430
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432
    \u043D\u0430\u0434 \"\u0431\u0435\u0441\u043F\u043E\u043B\u0435\u0437\u043D\u043E\u0439\"
    \u043D\u0430\u0443\u043A\u043E\u0439, \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F
    \u0437\u0430\u0433\u0430\u0434\u043A\u043E\u0439.  ### \U0001F430 \u0421\u0430\u043C\u0430\u044F
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F \u0438 \"\u043D\u0435\u043F\u0440\u0430\u043A\u0442\u0438\u0447\u043D\u0430\u044F\"
    \u0437\u0430\u0434\u0430\u0447\u0430  \u041F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C,
    \u043E\u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u0438\u0432\u0448\u0430\u044F
    \u0435\u0433\u043E \u0438\u043C\u044F, \u043F\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C
    \u0432 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0437\u0430\u0434\u0430\u0447\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430... \u0432\u0435\u0441\u044C\u043C\u0430 \u0434\u0430\u043B\u0435\u043A\u0430
    \u043E\u0442 \u0440\u0435\u0430\u043B\u0438\u0439 \u0441\u0440\u0435\u0434\u043D\u0435\u0432\u0435\u043A\u043E\u0432\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438.  \u0412 \u0441\u0432\u043E\u0435\u0439 \xAB\u041A\u043D\u0438\u0433\u0435
    \u0430\u0431\u0430\u043A\u0430\xBB (Liber Abaci, 1202) \u043E\u043D \u043F\u043E\u043C\u0435\u0441\u0442\u0438\u043B
    \u043F\u0430\u0440\u0443 \u043A\u0440\u043E\u043B\u0438\u043A\u043E\u0432 \u0432
    \u0437\u0430\u0433\u043E\u043D \u0438 \u0437\u0430\u0434\u0430\u043B\u0441\u044F
    \u0432\u043E\u043F\u0440\u043E\u0441\u043E\u043C: \u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043F\u0430\u0440 \u0440\u043E\u0434\u0438\u0442\u0441\u044F \u0437\u0430 \u0433\u043E\u0434,
    \u0435\u0441\u043B\u0438 \u043A\u0430\u0436\u0434\u0430\u044F \u043F\u0430\u0440\u0430
    \u043A\u0430\u0436\u0434\u044B\u0439 \u043C\u0435\u0441\u044F\u0446 \u0434\u0430\u0435\u0442
    \u043D\u043E\u0432\u0443\u044E \u043F\u0430\u0440\u0443, \u0430 \u043A\u0440\u043E\u043B\u0438\u043A\u0438,
    \u0440\u0430\u0437\u0443\u043C\u0435\u0435\u0442\u0441\u044F, \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0443\u043C\u0438\u0440\u0430\u044E\u0442. \u041F\u043E\u043B\u0443\u0447\u0438\u0432\u0448\u0430\u044F\u0441\u044F
    \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u2014 **1, 1, 2, 3, 5, 8, 13...**, \u0433\u0434\u0435 \u043A\u0430\u0436\u0434\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E \u2014 \u0441\u0443\u043C\u043C\u0430 \u0434\u0432\u0443\u0445
    \u043F\u0440\u0435\u0434\u044B\u0434\u0443\u0449\u0438\u0445, \u2014 \u0432 \u0438\u0442\u043E\u0433\u0435
    \u0441\u0442\u0430\u043B\u0430 \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0435\u0435,
    \u0447\u0435\u043C \u0441\u0430\u043C\u0430 \xAB\u041A\u043D\u0438\u0433\u0430
    \u0430\u0431\u0430\u043A\u0430\xBB.  ### \U0001F3A8 \u041F\u0440\u0438\u0440\u043E\u0434\u0430,
    \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E \u0438 \u0434\u0435\u043D\u044C\u0433\u0438:
    \u043C\u0430\u0433\u0438\u044F \u0447\u0438\u0441\u0435\u043B \u043F\u043E\u0432\u0441\u044E\u0434\u0443 
    \u041F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438 \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438\u0433\u0440\u043E\u0439. \u0415\u0435 \u0437\u0430\u043A\u043E\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438 \u0441\u0432\u044F\u0437\u044C
    \u0441 **\u0437\u043E\u043B\u043E\u0442\u044B\u043C \u0441\u0435\u0447\u0435\u043D\u0438\u0435\u043C**
    (\u0447\u0438\u0441\u043B\u043E \u0424\u0438, \u2248 1.618), \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u044E\u0442\u0441\u044F
    \u0432 \u0441\u0430\u043C\u044B\u0445 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0445
    \u043C\u0435\u0441\u0442\u0430\u0445.  *   **\u0412 \u043F\u0440\u0438\u0440\u043E\u0434\u0435:**
    \u042D\u0442\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439, \u0441\u0430\u043C\u043E\u0435
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0435. \u0427\u0438\u0441\u043B\u0430
    \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438 \u043C\u043E\u0436\u043D\u043E
    \u0443\u0432\u0438\u0434\u0435\u0442\u044C \u0432 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0435
    \u043B\u0435\u043F\u0435\u0441\u0442\u043A\u043E\u0432 \u0443 \u0446\u0432\u0435\u0442\u043E\u0432,
    \u0432 \u0441\u043F\u0438\u0440\u0430\u043B\u044F\u0445 \u0441\u043E\u0441\u043D\u043E\u0432\u044B\u0445
    \u0448\u0438\u0448\u0435\u043A \u0438 \u0430\u043D\u0430\u043D\u0430\u0441\u043E\u0432,
    \u0432 \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0438
    \u0441\u0435\u043C\u044F\u043D \u0432 \u043F\u043E\u0434\u0441\u043E\u043B\u043D\u0443\u0445\u0435
    \u0438 \u0434\u0430\u0436\u0435 \u0432 \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0435
    \u0440\u0430\u043A\u043E\u0432\u0438\u043D\u044B \u043D\u0430\u0443\u0442\u0438\u043B\u0443\u0441\u0430.
    *   **\u0412 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0435 \u0438 \u043C\u0443\u0437\u044B\u043A\u0435:**
    \u0418\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u0435, \u043F\u043E \u043C\u043D\u0435\u043D\u0438\u044E
    \u043C\u043D\u043E\u0433\u0438\u0445, \u043F\u0440\u043E\u043F\u043E\u0440\u0446\u0438\u0438
    \u0437\u043E\u043B\u043E\u0442\u043E\u0433\u043E \u0441\u0435\u0447\u0435\u043D\u0438\u044F
    \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438
    \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0438 \u0438 \u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u043E\u0440\u044B,
    \u043E\u0442 \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E \u0434\u0430 \u0412\u0438\u043D\u0447\u0438
    \u0434\u043E \u0421\u0430\u043B\u044C\u0432\u0430\u0434\u043E\u0440\u0430 \u0414\u0430\u043B\u0438.
    \u0410 \u043A\u043E\u043C\u043F\u043E\u0437\u0438\u0442\u043E\u0440\u044B \u0432\u0440\u043E\u0434\u0435
    \u0414\u0435\u0431\u044E\u0441\u0441\u0438 \u0438 \u0411\u0430\u0440\u0442\u043E\u043A\u0430
    \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0438 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u0435\u043D\u0438\u0435
    \u0432 \u0440\u0438\u0442\u043C\u0430\u0445, \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u043D\u044B\u0445
    \u043D\u0430 \u0447\u0438\u0441\u043B\u0430\u0445 \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438.
    *   **\u0412 \u043C\u0438\u0440\u0435 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432:**
    \u041F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u043D\u0430\u0448\u043B\u0430 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0434\u0430\u0436\u0435 \u043D\u0430 \u0431\u0438\u0440\u0436\u0435. \u0421\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0442
    **\u0443\u0440\u043E\u0432\u043D\u0438 \u043A\u043E\u0440\u0440\u0435\u043A\u0446\u0438\u0438
    \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438** (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    23.6%, 38.2%, 61.8%), \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0442\u0440\u0435\u0439\u0434\u0435\u0440\u044B
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442 \u0434\u043B\u044F
    \u043F\u0440\u043E\u0433\u043D\u043E\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0445 \u0440\u0430\u0437\u0432\u043E\u0440\u043E\u0442\u043E\u0432
    \u0446\u0435\u043D\u044B.  ### \u2694\uFE0F \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u043E\u0435\u0434\u0438\u043D\u043E\u043A \u043F\u0440\u0438 \u0434\u0432\u043E\u0440\u0435
    \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430  \u0421\u043B\u0430\u0432\u0430
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u043B\u0430
    \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435 \u0438\u043C\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430
    \u0421\u0432\u044F\u0449\u0435\u043D\u043D\u043E\u0439 \u0420\u0438\u043C\u0441\u043A\u043E\u0439
    \u0438\u043C\u043F\u0435\u0440\u0438\u0438 **\u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0430
    II**. \u041E\u043A\u043E\u043B\u043E 1225 \u0433\u043E\u0434\u0430 \u043F\u0440\u0438
    \u0434\u0432\u043E\u0440\u0435 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0441\u044F
    \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0443\u0440\u043D\u0438\u0440, \u0433\u0434\u0435 \u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u044B\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444 \u0418\u043E\u0430\u043D\u043D \u041F\u0430\u043B\u0435\u0440\u043C\u0441\u043A\u0438\u0439
    \u0437\u0430\u0434\u0430\u043B \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u0442\u0440\u0438 \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438.  \u041E\u0434\u043D\u0430 \u0438\u0437
    \u043D\u0438\u0445 \u0437\u0430\u043A\u043B\u044E\u0447\u0430\u043B\u0430\u0441\u044C
    \u0432 \u0440\u0435\u0448\u0435\u043D\u0438\u0438 \u043A\u0443\u0431\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F **x\xB3 + 2x\xB2 + 10x
    = 20**. \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0440\u0435\u0448\u0438\u043B \u0435\u0435, \u043D\u043E \u0438 \u043D\u0430\u0448\u0435\u043B
    \u043A\u043E\u0440\u0435\u043D\u044C \u0441 **\u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E \u0434\u043E \u0434\u0435\u0432\u044F\u0442\u043E\u0433\u043E
    \u0437\u043D\u0430\u043A\u0430 \u043F\u043E\u0441\u043B\u0435 \u0437\u0430\u043F\u044F\u0442\u043E\u0439**
    (1.368808107...), \u043D\u0435 \u043E\u0441\u0442\u0430\u0432\u0438\u0432 \u043D\u0438\u043A\u0430\u043A\u0438\u0445
    \u0437\u0430\u043F\u0438\u0441\u0435\u0439 \u043E \u0441\u0432\u043E\u0435\u043C
    \u043C\u0435\u0442\u043E\u0434\u0435 \u0440\u0430\u0441\u0447\u0435\u0442\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043D\u0430 \u0432\u0435\u043A\u0430
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B \u0441\u0432\u043E\u0435 \u0432\u0440\u0435\u043C\u044F. 
    ### \U0001F4DA \"\u041A\u043D\u0438\u0433\u0430 \u0430\u0431\u0430\u043A\u0430\"
    \u2014 \u0431\u043E\u043B\u044C\u0448\u0435, \u0447\u0435\u043C \u043F\u0440\u043E\u0441\u0442\u043E
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A  \u0425\u043E\u0442\u044F \u043C\u044B
    \u043F\u043E\u043C\u043D\u0438\u043C \u0435\u0433\u043E \u043F\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438,
    \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u043D\u0430\u0443\u043A\u0443 \u2014 \u044D\u0442\u043E \u0441\u0430\u043C\u0430
    \xAB\u041A\u043D\u0438\u0433\u0430 \u0430\u0431\u0430\u043A\u0430\xBB. \u042D\u0442\u0430
    \u043A\u043D\u0438\u0433\u0430 \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u044B\u043C
    \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u043C \u0442\u0440\u0443\u0434\u043E\u043C
    \u0432 \u0415\u0432\u0440\u043E\u043F\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0439:
    1.  **\u0412\u043D\u0435\u0434\u0440\u0438\u043B \u0438\u043D\u0434\u043E-\u0430\u0440\u0430\u0431\u0441\u043A\u0438\u0435
    \u0446\u0438\u0444\u0440\u044B (0-9)** \u0438 \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u0438\u0445 \u043F\u043E\u0437\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u0437\u0430\u043F\u0438\u0441\u0438. 2.  \u041F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0431\u043E\u043B\u0435\u0435 \u0443\u0434\u043E\u0431\u043D\u0443\u044E \u0437\u0430\u043F\u0438\u0441\u044C
    \u0434\u0440\u043E\u0431\u0435\u0439 (\u0432\u0432\u0435\u043B \u0447\u0435\u0440\u0442\u0443
    \u0434\u0440\u043E\u0431\u0438) \u0438 \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u043E\u0433\u043E \u043A\u043E\u0440\u043D\u044F.
    3.  \u0424\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0441\u0442\u0430\u043B
    \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u043D\u0430\u043D\u0438\u0439 \u0434\u043B\u044F \u0441\u0440\u0435\u0434\u043D\u0435\u0432\u0435\u043A\u043E\u0432\u043E\u0439
    \u0415\u0432\u0440\u043E\u043F\u044B, \u043F\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0443\u0447\u0438\u043B\u0438\u0441\u044C \u043D\u0435 \u043E\u0434\u043D\u043E
    \u043F\u043E\u043A\u043E\u043B\u0435\u043D\u0438\u0435.  ### \U0001F48E \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435
    \"\u0441\u043F\u0430\u0441\u0438\u0431\u043E\" \u043E\u0442 \u0440\u043E\u0434\u043D\u043E\u0433\u043E
    \u0433\u043E\u0440\u043E\u0434\u0430  \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u043E \u0436\u0438\u0437\u043D\u0438 \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u0434\u0430\u0442\u0438\u0440\u0443\u0435\u0442\u0441\u044F **1240 \u0433\u043E\u0434\u043E\u043C**.
    \u0420\u0435\u0441\u043F\u0443\u0431\u043B\u0438\u043A\u0430 \u041F\u0438\u0437\u0430
    \u043F\u0440\u0438\u043D\u044F\u043B\u0430 \u0443\u043A\u0430\u0437 \u043E \u0432\u044B\u043F\u043B\u0430\u0442\u0435
    \u0435\u043C\u0443 \u0435\u0436\u0435\u0433\u043E\u0434\u043D\u043E\u0439 \u043F\u0435\u043D\u0441\u0438\u0438
    \u0432 \u0440\u0430\u0437\u043C\u0435\u0440\u0435 20 \u043B\u0438\u0440. \u0412
    \u0434\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u0435 \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043D
    \"\u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u043C \u0438 \u0443\u0447\u0435\u043D\u044B\u043C
    \u043C\u0430\u0433\u0438\u0441\u0442\u0440\u043E\u043C \u041B\u0435\u043E\u043D\u0430\u0440\u0434\u043E
    \u0411\u0438\u0433\u043E\u043B\u043B\u043E\". \u042D\u0442\u043E \u0431\u044B\u043B\u0430
    \u043F\u0440\u0438\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0433\u043E\u0440\u043E\u0434\u0430 \u0437\u0430 \u0435\u0433\u043E \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0438\u0439
    \u0442\u0440\u0443\u0434 \u043D\u0430 \u0431\u043B\u0430\u0433\u043E \u0433\u0440\u0430\u0436\u0434\u0430\u043D,
    \u0432 \u043F\u0435\u0440\u0432\u0443\u044E \u043E\u0447\u0435\u0440\u0435\u0434\u044C
    \u0432 \u0441\u0444\u0435\u0440\u0435 \u0431\u0443\u0445\u0433\u0430\u043B\u0442\u0435\u0440\u0438\u0438
    \u0438 \u043A\u043E\u043C\u043C\u0435\u0440\u0447\u0435\u0441\u043A\u0438\u0445
    \u0440\u0430\u0441\u0447\u0435\u0442\u043E\u0432.  \u041D\u0430\u0434\u0435\u044E\u0441\u044C,
    \u044D\u0442\u0438 \u0444\u0430\u043A\u0442\u044B \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438
    \u043F\u043E-\u043D\u043E\u0432\u043E\u043C\u0443 \u0432\u0437\u0433\u043B\u044F\u043D\u0443\u0442\u044C
    \u043D\u0430 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C \u0424\u0438\u0431\u043E\u043D\u0430\u0447\u0447\u0438
    \u2014 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u0447\u044C\u0435 \u0438\u043C\u044F
    \u0441\u0442\u0430\u043B\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u043E\u0439
    \u0441\u043F\u0443\u0441\u0442\u044F \u0441\u0442\u043E\u043B\u0435\u0442\u0438\u044F."
