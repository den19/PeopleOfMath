  achievementsRu: "\u0425\u043E\u0442\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0414\u0435\u043A\u0430\u0440\u0442\u0430
    \u0448\u0438\u0440\u043E\u043A\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u0435\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u0432 **\u0442\u043E\u0447\u043D\u044B\u0435
    \u0438 \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u043D\u0430\u0443\u043A\u0438** \u043D\u0435 \u043C\u0435\u043D\u0435\u0435
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u0435\u043D. \u041F\u043E
    \u0441\u0443\u0442\u0438, \u0414\u0435\u043A\u0430\u0440\u0442 \u0431\u044B\u043B
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u043C \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u043C
    \u0443\u0447\u0435\u043D\u044B\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435,
    \u0444\u0438\u0437\u0438\u043A\u0435, \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0438
    \u0438 \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0435.   \u041D\u0438\u0436\u0435
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439 \u0440\u0430\u0437\u0431\u043E\u0440
    \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439,
    \u0440\u0430\u0437\u0431\u0438\u0442\u044B\u0439 \u043F\u043E \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C
    \u0437\u043D\u0430\u043D\u0438\u0439.  ---  ### 1. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430:
    \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438 \u043D\u043E\u0432\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B  \u042D\u0442\u043E, \u043F\u043E\u0436\u0430\u043B\u0443\u0439,
    \u0441\u0430\u043C\u044B\u0439 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0438 \u0434\u043E\u043B\u0433\u043E\u0432\u0435\u0447\u043D\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430, \u0438\u0437\u043C\u0435\u043D\u0438\u0432\u0448\u0438\u0439
    \u0432\u0441\u044E \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    - **\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438:** \u0414\u043E \u0414\u0435\u043A\u0430\u0440\u0442\u0430
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430 \u0438 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438 \u0440\u0430\u0437\u0434\u0435\u043B\u044C\u043D\u043E.
    \u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u0431\u044B\u043B\u0430
    \u0433\u0440\u0435\u0447\u0435\u0441\u043A\u043E\u0439 (\u0415\u0432\u043A\u043B\u0438\u0434),
    \u0430 \u0430\u043B\u0433\u0435\u0431\u0440\u0430 \u2014 \u0430\u0440\u0430\u0431\u0441\u043A\u043E\u0439
    (\u0431\u0443\u043A\u0432\u0435\u043D\u043D\u044B\u0435 \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F).
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432, \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u0432
    **\u043C\u0435\u0442\u043E\u0434 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442**.
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043B\u044E\u0431\u043E\u0435
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043C\u0435\u0441\u0442\u043E \u0442\u043E\u0447\u0435\u043A (\u043B\u0438\u043D\u0438\u044F,
    \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0441\u0442\u044C, \u043A\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0441\u0435\u0447\u0435\u043D\u0438\u0435) \u043C\u043E\u0436\u043D\u043E \u043E\u043F\u0438\u0441\u0430\u0442\u044C
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435\u043C \u0441 \u0434\u0432\u0443\u043C\u044F
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C\u0438 \\( x \\)
    \u0438 \\( y \\). \u0418 \u043D\u0430\u043E\u0431\u043E\u0440\u043E\u0442: \u043B\u044E\u0431\u043E\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \u0437\u0430\u0434\u0430\u0435\u0442
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u0443\u044E \u043A\u0440\u0438\u0432\u0443\u044E
    \u043D\u0430 \u043F\u043B\u043E\u0441\u043A\u043E\u0441\u0442\u0438. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0432\u0432\u0435\u043B \u043E\u0431\u0449\u0435\u043F\u0440\u0438\u043D\u044F\u0442\u044B\u0435
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F:
    \\( x, y, z \\) \u2014 \u0434\u043B\u044F \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445,
    \u0430 \\( a, b, c \\) \u2014 \u0434\u043B\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D. - **\u0414\u0435\u043A\u0430\u0440\u0442\u043E\u0432
    \u043B\u0438\u0441\u0442:** \u0417\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u0430\u044F
    \u043A\u0440\u0438\u0432\u0430\u044F \u0442\u0440\u0435\u0442\u044C\u0435\u0433\u043E
    \u043F\u043E\u0440\u044F\u0434\u043A\u0430 \\( x^3 + y^3 = 3axy \\), \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043B, \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440 \u043D\u043E\u0441\u0438\u0442 \u0435\u0433\u043E
    \u0438\u043C\u044F. - **\u041D\u043E\u0432\u0430\u044F \u043D\u043E\u0442\u0430\u0446\u0438\u044F
    \u0441\u0442\u0435\u043F\u0435\u043D\u0435\u0439:** \u0418\u043C\u0435\u043D\u043D\u043E
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0432\u0432\u0435\u043B \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0441\u0442\u0435\u043F\u0435\u043D\u0435\u0439 \u043A\u0430\u043A \\( x^3,
    x^4 \\) (\u0440\u0430\u043D\u0435\u0435 \u0441\u0442\u0435\u043F\u0435\u043D\u0438
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438 \u0433\u0440\u043E\u043C\u043E\u0437\u0434\u043A\u0438\u043C\u0438
    \u043B\u0430\u0442\u0438\u043D\u0441\u043A\u0438\u043C\u0438 \u0441\u043B\u043E\u0432\u0430\u043C\u0438).
    \u042D\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0443
    \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u043E\u0439 \u0438 \u043E\u0431\u043E\u0437\u0440\u0438\u043C\u043E\u0439.
    - **\u041F\u0440\u0430\u0432\u0438\u043B\u043E \u0437\u043D\u0430\u043A\u043E\u0432
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430:** \u0421\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043F\u0440\u0430\u0432\u0438\u043B\u043E \u0434\u043B\u044F \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u0447\u0438\u0441\u043B\u0430 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0438 \u043E\u0442\u0440\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u043A\u043E\u0440\u043D\u0435\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u043F\u043E \u0447\u0435\u0440\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044E
    \u0437\u043D\u0430\u043A\u043E\u0432 \u0432 \u0435\u0433\u043E \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u0430\u0445.
    \u042D\u0442\u043E\u0442 \u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0439 \u0434\u043E
    \u0441\u0438\u0445 \u043F\u043E\u0440 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439. - **\u041C\u0435\u0442\u043E\u0434
    \u043D\u0435\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u0445
    \u043A\u043E\u044D\u0444\u0444\u0438\u0446\u0438\u0435\u043D\u0442\u043E\u0432:**
    \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0432\u044B\u0441\u0448\u0438\u0445
    \u0441\u0442\u0435\u043F\u0435\u043D\u0435\u0439 \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0441\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u0438\u0445 \u043A \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u043C
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\u043C.  ---  ### 2. \u0424\u0438\u0437\u0438\u043A\u0430
    \u0438 \u043E\u043F\u0442\u0438\u043A\u0430: \u041C\u0435\u0445\u0430\u043D\u0438\u0446\u0438\u0437\u043C
    \u0438 \xAB\u0432\u0438\u0445\u0440\u0438\xBB  \u0412 \u0444\u0438\u0437\u0438\u043A\u0435
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0431\u044B\u043B \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    **\u043C\u0435\u0445\u0430\u043D\u0438\u0441\u0442\u043E\u043C**. \u041E\u043D
    \u043E\u0442\u0432\u0435\u0440\u0433\u0430\u043B \xAB\u0441\u043A\u0440\u044B\u0442\u044B\u0435
    \u0441\u0438\u043B\u044B\xBB \u0438 \u043C\u0430\u0433\u0438\u044E, \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u044F,
    \u0447\u0442\u043E \u0432\u0441\u0435 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u044F\u0432\u043B\u0435\u043D\u0438\u044F \u043C\u043E\u0436\u043D\u043E \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u044C
    \u0441\u0442\u043E\u043B\u043A\u043D\u043E\u0432\u0435\u043D\u0438\u0435\u043C
    \u0438 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435\u043C \u043C\u0435\u043B\u044C\u0447\u0430\u0439\u0448\u0438\u0445
    \u0447\u0430\u0441\u0442\u0438\u0446 \u043C\u0430\u0442\u0435\u0440\u0438\u0438
    (\u043A\u043E\u0440\u043F\u0443\u0441\u043A\u0443\u043B).  - **\u0417\u0430\u043A\u043E\u043D
    \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u044F \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F (\u0438\u043C\u043F\u0443\u043B\u044C\u0441\u0430):**
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043F\u0435\u0440\u0432\u044B\u043C \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043E\u0431\u0449\u0438\u0439 \u0437\u0430\u043A\u043E\u043D \u043F\u0440\u0438\u0440\u043E\u0434\u044B:
    *\xAB\u041E\u0431\u0449\u0435\u0435 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0432 \u043C\u0438\u0440\u0435
    \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u0435\u0442\u0441\u044F \u043D\u0435\u0438\u0437\u043C\u0435\u043D\u043D\u044B\u043C\xBB*.
    \u041E\u043D \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B \u043C\u0435\u0440\u0443
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u043A\u0430\u043A \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u043C\u0430\u0441\u0441\u044B \u043D\u0430 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C
    (\\( mv \\)). \u0425\u043E\u0442\u044F \u0435\u0433\u043E \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0430
    \u0431\u044B\u043B\u0430 \u043D\u0435 \u0441\u043E\u0432\u0441\u0435\u043C \u0442\u043E\u0447\u043D\u043E\u0439
    (\u043E\u043D \u043D\u0435 \u0443\u0447\u0438\u0442\u044B\u0432\u0430\u043B \u0432\u0435\u043A\u0442\u043E\u0440\u043D\u044B\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438),
    \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u043D \u0432\u0432\u0435\u043B \u044D\u0442\u043E\u0442
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u043E\u0437\u0436\u0435 \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    \u0432 \u0441\u0432\u043E\u0438 \u0437\u0430\u043A\u043E\u043D\u044B. - **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0432\u0438\u0445\u0440\u0435\u0439 (\u041A\u0430\u0440\u0442\u0435\u0437\u0438\u0430\u043D\u0441\u043A\u0438\u0435
    \u0432\u0438\u0445\u0440\u0438):** \u0414\u043B\u044F \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u044F
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u043F\u043B\u0430\u043D\u0435\u0442
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0441\u043E\u0437\u0434\u0430\u043B \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u0443\u044E
    \u043A\u043E\u0441\u043C\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043C\u043E\u0434\u0435\u043B\u044C. \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u0435\u0439, \u043A\u043E\u0441\u043C\u043E\u0441 \u0437\u0430\u043F\u043E\u043B\u043D\u0435\u043D
    \u0442\u043E\u043D\u0447\u0430\u0439\u0448\u0435\u0439 \u043C\u0430\u0442\u0435\u0440\u0438\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u0432 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u043C \u043A\u0440\u0443\u0433\u043E\u0432\u043E\u043C
    \u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0438 (\u0432\u0438\u0445\u0440\u0438).
    \u041F\u043B\u0430\u043D\u0435\u0442\u044B, \u043F\u043E \u0435\u0433\u043E \u043C\u043D\u0435\u043D\u0438\u044E,
    \u0443\u0432\u043B\u0435\u043A\u0430\u044E\u0442\u0441\u044F \u044D\u0442\u0438\u043C\u0438
    \u0432\u0438\u0445\u0440\u044F\u043C\u0438, \u043F\u043E\u0434\u043E\u0431\u043D\u043E
    \u043B\u0438\u0441\u0442\u044C\u044F\u043C, \u043F\u043E\u043F\u0430\u0432\u0448\u0438\u043C
    \u0432 \u0432\u043E\u0434\u043E\u0432\u043E\u0440\u043E\u0442. \u042D\u0442\u0430
    \u0442\u0435\u043E\u0440\u0438\u044F \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u043B\u0430
    \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u044E \u043A\u0430\u043A
    \u0446\u0435\u043D\u0442\u0440\u043E\u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u0432\u0438\u0445\u0440\u0435\u0439.
    \u0425\u043E\u0442\u044F \u041D\u044C\u044E\u0442\u043E\u043D \u043F\u043E\u0437\u0436\u0435
    \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433\u043D\u0435\u0442 \u044D\u0442\u0443
    \u0442\u0435\u043E\u0440\u0438\u044E \u0432 \u043F\u043E\u043B\u044C\u0437\u0443
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0433\u043E
    \u0442\u044F\u0433\u043E\u0442\u0435\u043D\u0438\u044F, \u0432\u0438\u0445\u0440\u0438
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430 \u0434\u043E\u043C\u0438\u043D\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u0432 \u0435\u0432\u0440\u043E\u043F\u0435\u0439\u0441\u043A\u043E\u0439 \u0444\u0438\u0437\u0438\u043A\u0435
    \u043F\u043E\u0447\u0442\u0438 100 \u043B\u0435\u0442. - **\u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0437\u0430\u043A\u043E\u043D \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u044F
    \u0441\u0432\u0435\u0442\u0430 (\u0417\u0430\u043A\u043E\u043D \u0421\u043D\u0435\u043B\u043B\u0430
    \u2014 \u0414\u0435\u043A\u0430\u0440\u0442\u0430):** \u0412 \u0441\u0432\u043E\u0435\u043C
    \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0438 \xAB\u0414\u0438\u043E\u043F\u0442\u0440\u0438\u043A\u0430\xBB
    (1637) \u0414\u0435\u043A\u0430\u0440\u0442 \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E
    \u043E\u0442 \u0421\u043D\u0435\u043B\u043B\u0430 \u0438 \u0441\u0442\u0440\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u044B\u0432\u0435\u043B \u0437\u0430\u043A\u043E\u043D \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u044F
    \u0441\u0432\u0435\u0442\u0430 \u043D\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0435
    \u0434\u0432\u0443\u0445 \u0441\u0440\u0435\u0434:     \\[     n_1 \\sin \\theta_1
    = n_2 \\sin \\theta_2     \\]     \u041E\u043D \u0434\u0430\u043B \u0435\u0433\u043E
    \u0447\u0435\u0442\u043A\u0443\u044E \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0443
    \u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u0434\u043B\u044F \u0440\u0430\u0441\u0447\u0435\u0442\u0430
    \u043E\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u043B\u0438\u043D\u0437.
    \u0414\u043E \u043D\u0435\u0433\u043E \u0437\u0430\u043A\u043E\u043D \u0438\u0441\u043A\u0430\u043B\u0438
    \u0432 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0438 \u0443\u0433\u043B\u043E\u0432,
    \u0430 \u0414\u0435\u043A\u0430\u0440\u0442 \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E
    \u043A\u043B\u044E\u0447\u0435\u0432\u0430\u044F \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u0430
    \u2014 \u044D\u0442\u043E **\u0441\u0438\u043D\u0443\u0441** \u0443\u0433\u043B\u0430.
    - **\u0422\u0435\u043E\u0440\u0438\u044F \u0440\u0430\u0434\u0443\u0433\u0438:**
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0434\u0430\u043B \u043F\u043E\u043B\u043D\u043E\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u044A\u044F\u0441\u043D\u0435\u043D\u0438\u0435 \u0440\u0430\u0434\u0443\u0433\u0438.
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u043E\u043D\u0430
    \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u0435\u0442 \u0438\u0437-\u0437\u0430
    \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u044F \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u0445
    \u043B\u0443\u0447\u0435\u0439 \u0432 \u043A\u0430\u043F\u043B\u044F\u0445 \u0432\u043E\u0434\u044B
    \u0438 \u0438\u0445 \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0433\u043E
    \u043E\u0442\u0440\u0430\u0436\u0435\u043D\u0438\u044F \u043E\u0442 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0435\u0439
    \u0441\u0442\u0435\u043D\u043A\u0438 \u043A\u0430\u043F\u043B\u0438. \u0421 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u0441\u0432\u043E\u0438\u0445 \u0437\u0430\u043A\u043E\u043D\u043E\u0432 \u043E\u043D
    \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u043B \u0443\u0433\u043B\u044B,
    \u043F\u043E\u0434 \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438 \u043C\u044B
    \u0432\u0438\u0434\u0438\u043C \u043F\u0435\u0440\u0432\u0443\u044E \u0438 \u0432\u0442\u043E\u0440\u0443\u044E
    \u0440\u0430\u0434\u0443\u0433\u0438 (42\xB0 \u0438 52\xB0). - **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0441\u0432\u0435\u0442\u0430 \u043A\u0430\u043A \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F:**
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0441\u0447\u0438\u0442\u0430\u043B \u0441\u0432\u0435\u0442
    \u043D\u0435 \u0432\u043E\u043B\u043D\u043E\u0439 \u0438 \u043D\u0435 \u043F\u043E\u0442\u043E\u043A\u043E\u043C
    \u0447\u0430\u0441\u0442\u0438\u0446 (\u043A\u043E\u0440\u043F\u0443\u0441\u043A\u0443\u043B),
    \u0430 **\u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C**, \u043F\u0435\u0440\u0435\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u0447\u0435\u0440\u0435\u0437 \u043F\u0440\u043E\u0437\u0440\u0430\u0447\u043D\u0443\u044E
    \u0441\u0440\u0435\u0434\u0443 (\u044D\u0444\u0438\u0440) \u043E\u0442 \u0441\u0432\u0435\u0442\u044F\u0449\u0435\u0433\u043E\u0441\u044F
    \u0442\u0435\u043B\u0430 \u043A \u0433\u043B\u0430\u0437\u0443, \u0430\u043D\u0430\u043B\u043E\u0433\u0438\u0447\u043D\u043E
    \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044E \u0432 \u043F\u0430\u043B\u043A\u0435.
    \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u043E \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u044C
    \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u0438\u044F
    \u0441\u0432\u0435\u0442\u0430 (\u043F\u043E \u0435\u0433\u043E \u043C\u043D\u0435\u043D\u0438\u044E)
    \u0438 \u043F\u0440\u044F\u043C\u043E\u043B\u0438\u043D\u0435\u0439\u043D\u043E\u0441\u0442\u044C. 
    ---  ### 3. \u0424\u0438\u0437\u0438\u043E\u043B\u043E\u0433\u0438\u044F \u0438
    \u043C\u0435\u0434\u0438\u0446\u0438\u043D\u0430: \u041F\u0435\u0440\u0432\u0430\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u043C\u043E\u0434\u0435\u043B\u044C
    \u0442\u0435\u043B\u0430  \u0414\u0435\u043A\u0430\u0440\u0442 \u2014 \u043E\u0442\u0435\u0446
    **\u043F\u0441\u0438\u0445\u043E\u0444\u0438\u0437\u0438\u043E\u043B\u043E\u0433\u0438\u0438**
    \u0438 \u0440\u0435\u0444\u043B\u0435\u043A\u0441\u043E\u043B\u043E\u0433\u0438\u0438.
    \u0415\u0433\u043E \u043F\u043E\u0434\u0445\u043E\u0434 \u043A \u0436\u0438\u0432\u043E\u043C\u0443
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u0443 \u043A\u0430\u043A \u043A
    \u0441\u043B\u043E\u0436\u043D\u043E\u043C\u0443 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u0443
    (\xAB\u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0435-\u043C\u0430\u0448\u0438\u043D\u044B\xBB)
    \u0441\u0442\u0430\u043B \u043E\u0441\u043D\u043E\u0432\u043E\u0439 \u0434\u043B\u044F
    \u0432\u0441\u0435\u0439 \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u0439
    \u0444\u0438\u0437\u0438\u043E\u043B\u043E\u0433\u0438\u0438 \u041D\u043E\u0432\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438.  - **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0440\u0435\u0444\u043B\u0435\u043A\u0441\u0430 (\u0434\u0443\u0433\u043E\u0432\u043E\u0439
    \u0440\u0435\u0444\u043B\u0435\u043A\u0441):** \u0414\u0435\u043A\u0430\u0440\u0442
    \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u043E\u043F\u0438\u0441\u0430\u043B
    \u0440\u0435\u0444\u043B\u0435\u043A\u0442\u043E\u0440\u043D\u0443\u044E \u0434\u0443\u0433\u0443.
    \u041E\u043D \u043F\u043E\u043B\u0430\u0433\u0430\u043B, \u0447\u0442\u043E \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0435
    \u0438 \u0442\u0435\u043B\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u044E\u0442 \u043A\u0430\u043A \u0433\u0438\u0434\u0440\u0430\u0432\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0430\u0448\u0438\u043D\u044B. \u0421\u043E\u0433\u043B\u0430\u0441\u043D\u043E
    \u0435\u0433\u043E \u0441\u0445\u0435\u043C\u0435:     1. \u0412\u043D\u0435\u0448\u043D\u0438\u0439
    \u043E\u0431\u044A\u0435\u043A\u0442 \u0434\u0430\u0432\u0438\u0442 \u043D\u0430
    \u043D\u0435\u0440\u0432 (\xAB\u043D\u0438\u0442\u044C\xBB), \u043D\u0430\u0442\u044F\u0433\u0438\u0432\u0430\u044F
    \u043A\u043B\u0430\u043F\u0430\u043D \u0432 \u0433\u043E\u043B\u043E\u0432\u043D\u043E\u043C
    \u043C\u043E\u0437\u0433\u0435.     2. \u041A\u043B\u0430\u043F\u0430\u043D \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F.    
    3. \u041F\u043E \u043F\u043E\u043B\u044B\u043C \u0442\u0440\u0443\u0431\u043A\u0430\u043C
    (\u043D\u0435\u0440\u0432\u0430\u043C) \u0438\u0437 \u043C\u043E\u0437\u0433\u0430
    \u0432 \u043C\u044B\u0448\u0446\u044B \u0443\u0441\u0442\u0440\u0435\u043C\u043B\u044F\u044E\u0442\u0441\u044F
    \xAB\u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0435 \u0434\u0443\u0445\u0438\xBB
    (\u0442\u043E\u043D\u0447\u0430\u0439\u0448\u0438\u0435 \u0447\u0430\u0441\u0442\u0438\u0446\u044B
    \u043A\u0440\u043E\u0432\u0438).     4. \u041C\u044B\u0448\u0446\u0430 \u043D\u0430\u0434\u0443\u0432\u0430\u0435\u0442\u0441\u044F
    \u0438 \u0441\u043E\u043A\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F.    
    \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u043F\u0435\u0440\u0432\u0430\u044F
    \u043D\u0430\u0443\u0447\u043D\u0430\u044F \u043C\u043E\u0434\u0435\u043B\u044C,
    \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u044E\u0449\u0430\u044F \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435
    \u0431\u0435\u0437 \u0432\u043C\u0435\u0448\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0434\u0443\u0448\u0438, \u0430 \u0447\u0438\u0441\u0442\u043E \u0440\u0435\u0444\u043B\u0435\u043A\u0442\u043E\u0440\u043D\u043E.
    - **\u0414\u0443\u0430\u043B\u0438\u0437\u043C \u0434\u0443\u0448\u0438 \u0438
    \u0442\u0435\u043B\u0430 (\u041F\u0438\u043D\u0435\u0430\u043B\u044C\u043D\u0430\u044F
    \u0436\u0435\u043B\u0435\u0437\u0430):** \u0414\u0435\u043A\u0430\u0440\u0442
    \u0438\u0441\u043A\u0430\u043B \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043E\u0440\u0433\u0430\u043D, \u0433\u0434\u0435 \u043D\u0435\u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u0430\u044F
    \u0434\u0443\u0448\u0430 \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u0438\u0440\u0443\u0435\u0442
    \u0441 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u044B\u043C
    \u0442\u0435\u043B\u043E\u043C. \u0422\u0430\u043A\u0438\u043C \u043E\u0440\u0433\u0430\u043D\u043E\u043C
    \u043E\u043D \u043E\u0431\u044A\u044F\u0432\u0438\u043B **\u0448\u0438\u0448\u043A\u043E\u0432\u0438\u0434\u043D\u043E\u0435
    \u0442\u0435\u043B\u043E (\u044D\u043F\u0438\u0444\u0438\u0437)**. \u041E\u043D
    \u043E\u0448\u0438\u0431\u0430\u043B\u0441\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E
    (\u043C\u044B \u0437\u043D\u0430\u0435\u043C, \u0447\u0442\u043E \u044D\u043F\u0438\u0444\u0438\u0437
    \u2014 \u0436\u0435\u043B\u0435\u0437\u0430 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0435\u0439
    \u0441\u0435\u043A\u0440\u0435\u0446\u0438\u0438), \u043D\u043E \u0430\u043D\u0430\u0442\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0438
    \u043E\u043D \u0432\u044B\u0431\u0440\u0430\u043B \u0435\u0433\u043E \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E,
    \u0442\u0430\u043A \u043A\u0430\u043A \u044D\u0442\u043E \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u043D\u0435\u043F\u0430\u0440\u043D\u0430\u044F \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430
    \u043C\u043E\u0437\u0433\u0430. \u0415\u043C\u0443 \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u0437\u0434\u0435\u0441\u044C
    \xAB\u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0435 \u0434\u0443\u0445\u0438\xBB
    \u0444\u043E\u0440\u043C\u0438\u0440\u0443\u044E\u0442 \u043C\u044B\u0441\u043B\u0435\u043D\u043D\u044B\u0435
    \u043E\u0431\u0440\u0430\u0437\u044B. - **\u0422\u0435\u043E\u0440\u0438\u044F
    \u044D\u043C\u043E\u0446\u0438\u0439 (\xAB\u0421\u0442\u0440\u0430\u0441\u0442\u0438
    \u0434\u0443\u0448\u0438\xBB):** \u0412 \u0441\u0432\u043E\u0435\u043C \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u043C
    \u0442\u0440\u0443\u0434\u0435 \u043E\u043D \u0434\u0430\u043B \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044E
    \u0448\u0435\u0441\u0442\u0438 \u0431\u0430\u0437\u043E\u0432\u044B\u0445 \u044D\u043C\u043E\u0446\u0438\u0439
    (\u0443\u0434\u0438\u0432\u043B\u0435\u043D\u0438\u0435, \u043B\u044E\u0431\u043E\u0432\u044C,
    \u043D\u0435\u043D\u0430\u0432\u0438\u0441\u0442\u044C, \u0436\u0435\u043B\u0430\u043D\u0438\u0435,
    \u0440\u0430\u0434\u043E\u0441\u0442\u044C, \u043F\u0435\u0447\u0430\u043B\u044C)
    \u0438 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E \u043E\u043F\u0438\u0441\u0430\u043B,
    \u043A\u0430\u043A \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \xAB\u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445
    \u0434\u0443\u0445\u043E\u0432\xBB \u0432\u044B\u0437\u044B\u0432\u0430\u044E\u0442
    \u0442\u0435\u043B\u0435\u0441\u043D\u044B\u0435 \u043F\u0440\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u044F
    \u044D\u0442\u0438\u0445 \u044D\u043C\u043E\u0446\u0438\u0439 (\u0443\u0447\u0430\u0449\u0435\u043D\u0438\u0435
    \u043F\u0443\u043B\u044C\u0441\u0430, \u043F\u043E\u043A\u0440\u0430\u0441\u043D\u0435\u043D\u0438\u0435,
    \u043F\u043B\u0430\u0447). - **\u041F\u0440\u043E\u0442\u0438\u0432 \u0432\u0438\u0432\u0438\u0441\u0435\u043A\u0446\u0438\u0438
    (\u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441):** \u0411\u0443\u0434\u0443\u0447\u0438
    \u043C\u0435\u0445\u0430\u043D\u0438\u0446\u0438\u0441\u0442\u043E\u043C, \u0414\u0435\u043A\u0430\u0440\u0442,
    \u0442\u0435\u043C \u043D\u0435 \u043C\u0435\u043D\u0435\u0435, \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u043B
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0436\u0435\u0441\u0442\u043E\u043A\u043E\u0433\u043E
    \u0432\u0441\u043A\u0440\u044B\u0442\u0438\u044F \u0436\u0438\u0432\u044B\u0445
    \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445. \u041E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u0434\u0430\u0436\u0435 \u0435\u0441\u043B\u0438 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435
    \u043A\u0440\u0438\u0447\u0438\u0442 \u043E\u0442 \u0431\u043E\u043B\u0438, \u044D\u0442\u043E
    \u0432\u0441\u0435\u0433\u043E \u043B\u0438\u0448\u044C \u0440\u0430\u0431\u043E\u0442\u0430
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u0430, \u043F\u043E\u0434\u043E\u0431\u043D\u0430\u044F
    \u0441\u043A\u0440\u0438\u043F\u0443 \u043D\u0435\u0441\u043C\u0430\u0437\u0430\u043D\u043D\u043E\u0433\u043E
    \u043A\u043E\u043B\u0435\u0441\u0430, \u0430 \u043D\u0435 \u043F\u0440\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u0435
    \u0441\u0442\u0440\u0430\u0434\u0430\u043D\u0438\u044F. \u042D\u0442\u043E \u0431\u044B\u043B\u043E
    \u044D\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0441\u043F\u043E\u0440\u043D\u043E\u0435,
    \u043D\u043E \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u0434\u043B\u044F \u0435\u0433\u043E \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435.  ---  ###
    4. \u041A\u043E\u0441\u043C\u043E\u043B\u043E\u0433\u0438\u044F \u0438 \u0433\u0435\u043E\u043B\u043E\u0433\u0438\u044F:
    \u0418\u0441\u0442\u043E\u0440\u0438\u044F \u0417\u0435\u043C\u043B\u0438  \u0412
    \u043D\u0435\u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043D\u043E\u043C
    \u043F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435
    \xAB\u041C\u0438\u0440\xBB \u0414\u0435\u043A\u0430\u0440\u0442 \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B
    \u0441\u043C\u0435\u043B\u044B\u0435 \u0434\u043E\u0433\u0430\u0434\u043A\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0430\u043C\u043D\u043E\u0433\u043E
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u043B\u0438 \u0432\u0440\u0435\u043C\u044F. 
    - **\u0422\u0435\u043E\u0440\u0438\u044F \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u043F\u043B\u0430\u043D\u0435\u0442:** \u041E\u043D \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u043B,
    \u0447\u0442\u043E \u0417\u0435\u043C\u043B\u044F \u0438 \u0434\u0440\u0443\u0433\u0438\u0435
    \u043F\u043B\u0430\u043D\u0435\u0442\u044B \u043D\u0435\u043A\u043E\u0433\u0434\u0430
    \u0431\u044B\u043B\u0438 \u0437\u0432\u0435\u0437\u0434\u0430\u043C\u0438 (\u0441\u043E\u043B\u043D\u0446\u0430\u043C\u0438),
    \u043D\u043E \u043E\u0441\u0442\u044B\u043B\u0438, \u043F\u043E\u043A\u0440\u044B\u043B\u0438\u0441\u044C
    \u043A\u043E\u0440\u043E\u0439 \u0438 \u043F\u043E\u0433\u0430\u0441\u043B\u0438.
    \u0421\u043E\u043B\u043D\u0446\u0435 \u0436\u0435, \u043F\u043E \u0435\u0433\u043E
    \u043C\u043D\u0435\u043D\u0438\u044E, \u2014 \u0435\u0449\u0435 \u043D\u0435
    \u043E\u0441\u0442\u044B\u0432\u0448\u0430\u044F \u0437\u0432\u0435\u0437\u0434\u0430.
    - **\u0413\u0435\u043E\u043C\u043E\u0440\u0444\u043E\u043B\u043E\u0433\u0438\u044F:**
    \u041E\u043D \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043B \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0433\u043E\u0440, \u0434\u043E\u043B\u0438\u043D \u0438 \u043A\u043E\u043D\u0442\u0438\u043D\u0435\u043D\u0442\u043E\u0432
    **\u043E\u0445\u043B\u0430\u0436\u0434\u0435\u043D\u0438\u0435\u043C \u0438 \u0441\u0436\u0430\u0442\u0438\u0435\u043C**.
    \u041F\u043E \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u0438, \u043A\u043E\u0433\u0434\u0430
    \u043C\u043E\u043B\u043E\u0434\u0430\u044F \u0417\u0435\u043C\u043B\u044F \u043E\u0441\u0442\u044B\u0432\u0430\u043B\u0430,
    \u0435\u0435 \u043A\u043E\u0440\u0430 \u0441\u043C\u043E\u0440\u0449\u0438\u0432\u0430\u043B\u0430\u0441\u044C,
    \u043E\u0431\u0440\u0430\u0437\u0443\u044F \u0441\u043A\u043B\u0430\u0434\u043A\u0438
    (\u0433\u043E\u0440\u044B), \u0430\u043D\u0430\u043B\u043E\u0433\u0438\u0447\u043D\u043E
    \u0442\u043E\u043C\u0443, \u043A\u0430\u043A \u0441\u043C\u043E\u0440\u0449\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u043A\u043E\u0436\u0438\u0446\u0430 \u044F\u0431\u043B\u043E\u043A\u0430, \u043A\u043E\u0433\u0434\u0430
    \u043E\u043D\u043E \u0441\u043E\u0445\u043D\u0435\u0442. \u042D\u0442\u043E \u0431\u044B\u043B\u0430
    \u043F\u0435\u0440\u0432\u0430\u044F \u0433\u043B\u043E\u0431\u0430\u043B\u044C\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u0433\u043E\u0440\u043E\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F.
    - **\u041E\u043A\u0430\u043C\u0435\u043D\u0435\u043B\u043E\u0441\u0442\u0438:**
    \u041E\u0442\u0440\u0438\u0446\u0430\u044F \u0431\u0438\u0431\u043B\u0435\u0439\u0441\u043A\u0438\u0439
    \u0412\u0441\u0435\u043C\u0438\u0440\u043D\u044B\u0439 \u043F\u043E\u0442\u043E\u043F,
    \u043E\u043D \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E
    \u043E\u043A\u0430\u043C\u0435\u043D\u0435\u043B\u043E\u0441\u0442\u0438 \u043C\u043E\u0440\u0441\u043A\u0438\u0445
    \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445 \u043D\u0430 \u0432\u0435\u0440\u0448\u0438\u043D\u0430\u0445
    \u0433\u043E\u0440 \u2014 \u044D\u0442\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u043E\u0433\u043E, \u0447\u0442\u043E \u0441\u0443\u0448\u0430 \u0438
    \u043C\u043E\u0440\u0435 \u043D\u0435\u043E\u0434\u043D\u043E\u043A\u0440\u0430\u0442\u043D\u043E
    \u043C\u0435\u043D\u044F\u043B\u0438\u0441\u044C \u043C\u0435\u0441\u0442\u0430\u043C\u0438
    \u0432 \u0442\u0435\u0447\u0435\u043D\u0438\u0435 \u0434\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0433\u0435\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u044D\u043F\u043E\u0445.  ---  ### 5. \u0418\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u044B\u0435
    \u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F  \u0414\u0435\u043A\u0430\u0440\u0442
    \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A\u043E\u043C,
    \u043D\u043E \u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u043E\u043C. \u041E\u043D
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u0430\u0434 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435\u043C: 
    - **\u0428\u043B\u0438\u0444\u043E\u0432\u0430\u043B\u044C\u043D\u044B\u0445
    \u0441\u0442\u0430\u043D\u043A\u043E\u0432 \u0434\u043B\u044F \u043B\u0438\u043D\u0437:**
    \u0412 \xAB\u0414\u0438\u043E\u043F\u0442\u0440\u0438\u043A\u0435\xBB \u043E\u043D
    \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u043E \u043E\u043F\u0438\u0441\u0430\u043B
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044E \u0441\u0442\u0430\u043D\u043A\u0430
    \u0434\u043B\u044F \u0448\u043B\u0438\u0444\u043E\u0432\u043A\u0438 \u0433\u0438\u043F\u0435\u0440\u0431\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043B\u0438\u043D\u0437, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u0430\u0432\u0430\u043B\u0438
    \u043C\u0435\u043D\u044C\u0448\u0435 \u0445\u0440\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0430\u0431\u0435\u0440\u0440\u0430\u0446\u0438\u0438, \u0447\u0435\u043C \u043E\u0431\u044B\u0447\u043D\u044B\u0435
    \u0441\u0444\u0435\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u043B\u0438\u043D\u0437\u044B.
    - **\u0422\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u043E\u0432:** \u041F\u044B\u0442\u0430\u043B\u0441\u044F
    \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u0442\u0435\u043B\u0435\u0441\u043A\u043E\u043F\u044B
    \u0434\u043B\u044F \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F
    \u0437\u0430 \u0437\u0432\u0435\u0437\u0434\u0430\u043C\u0438, \u0445\u043E\u0442\u044F
    \u0435\u0433\u043E \u043E\u043F\u0442\u0438\u043A\u0430 (\u043E\u043D \u0441\u0447\u0438\u0442\u0430\u043B
    \u0441\u0432\u0435\u0442 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C)
    \u043C\u0435\u0448\u0430\u043B\u0430 \u0435\u043C\u0443 \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E
    \u043E\u0446\u0435\u043D\u0438\u0442\u044C \u043F\u0440\u0435\u043B\u043E\u043C\u043B\u0435\u043D\u0438\u0435,
    \u0438\u0437-\u0437\u0430 \u0447\u0435\u0433\u043E \u0435\u0433\u043E \u043F\u0440\u0438\u0431\u043E\u0440\u044B
    \u0443\u0441\u0442\u0443\u043F\u0430\u043B\u0438 \u0433\u0430\u043B\u0438\u043B\u0435\u0435\u0432\u0441\u043A\u0438\u043C. 
    ---  ### \u0418\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043C\u0435\u0441\u0442\u043E: \u041C\u0435\u0436\u0434\u0443 \u0413\u0430\u043B\u0438\u043B\u0435\u0435\u043C
    \u0438 \u041D\u044C\u044E\u0442\u043E\u043D\u043E\u043C  \u0412 \u043D\u0430\u0443\u043A\u0435
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0435 \u043C\u0435\u0441\u0442\u043E:
    1. \u041E\u043D **\u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B** \u043D\u0430\u0443\u0447\u043D\u0443\u044E
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E \u0413\u0430\u043B\u0438\u043B\u0435\u044F,
    \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u043E\u0441\u0442\u0430\u0442\u043A\u0438 \u0441\u0445\u043E\u043B\u0430\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438 (\u043E\u043D \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u043F\u043E\u043D\u044F\u0442\u0438\u0439 \xAB\u043B\u0435\u0433\u043A\u043E\u0441\u0442\u044C\xBB
    \u0438 \xAB\u0442\u044F\u0436\u0435\u0441\u0442\u044C\xBB \u043A\u0430\u043A
    \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0445 \u0441\u0432\u043E\u0439\u0441\u0442\u0432
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u0432). 2. \u041E\u043D **\u0441\u043E\u0437\u0434\u0430\u043B
    \u044F\u0437\u044B\u043A** (\u0430\u043B\u0433\u0435\u0431\u0440\u0443 \u0438
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B), \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u041D\u044C\u044E\u0442\u043E\u043D \u0447\u0435\u0440\u0435\u0437 40 \u043B\u0435\u0442
    \u043D\u0430\u043F\u0438\u0448\u0435\u0442 \u0441\u0432\u043E\u0438 \xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043D\u0430\u0447\u0430\u043B\u0430 \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438\xBB. 3. **\u0420\u0430\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0441 \u041D\u044C\u044E\u0442\u043E\u043D\u043E\u043C:** \u0415\u0441\u043B\u0438
    \u041D\u044C\u044E\u0442\u043E\u043D \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u0438 \u043A\u0430\u043A
    **\u0434\u0430\u043B\u044C\u043D\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F**
    (\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F \u043D\u0430 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0438
    \u0447\u0435\u0440\u0435\u0437 \u043F\u0443\u0441\u0442\u043E\u0442\u0443), \u0447\u0442\u043E
    \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C \u0414\u0435\u043A\u0430\u0440\u0442\u0443
    \u043C\u0438\u0441\u0442\u0438\u043A\u043E\u0439, \u0442\u043E \u0414\u0435\u043A\u0430\u0440\u0442
    \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u043B \u043D\u0430 **\u0431\u043B\u0438\u0437\u043A\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0438**
    (\u043F\u0435\u0440\u0435\u0434\u0430\u0447\u0435 \u0441\u0438\u043B\u044B \u0442\u043E\u043B\u044C\u043A\u043E
    \u0447\u0435\u0440\u0435\u0437 \u043F\u0440\u044F\u043C\u043E\u0439 \u043A\u043E\u043D\u0442\u0430\u043A\u0442
    \u0447\u0430\u0441\u0442\u0438\u0446). \u0412 \u044D\u0442\u043E\u043C \u0441\u043F\u043E\u0440\u0435,
    \u0441 \u0442\u043E\u0447\u043A\u0438 \u0437\u0440\u0435\u043D\u0438\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u0444\u0438\u0437\u0438\u043A\u0438
    \u0438 \u0442\u0435\u043E\u0440\u0438\u0438 \u043F\u043E\u043B\u044F, \u0414\u0435\u043A\u0430\u0440\u0442
    \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0432 \u0447\u0435\u043C-\u0442\u043E
    \u0434\u0430\u0436\u0435 \u0431\u043E\u043B\u0435\u0435 \u043F\u0440\u043E\u0437\u043E\u0440\u043B\u0438\u0432,
    \u0447\u0435\u043C \u041D\u044C\u044E\u0442\u043E\u043D: \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    \u0444\u0438\u0437\u0438\u043A\u0430 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u043C\u0430\u0433\u043D\u0438\u0442\u043D\u043E\u0435
    \u043F\u043E\u043B\u0435) \u0432\u0435\u0440\u043D\u0443\u043B\u0430\u0441\u044C
    \u043A \u0438\u0434\u0435\u0435 \u043E \u0442\u043E\u043C, \u0447\u0442\u043E
    \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435
    \u043F\u0435\u0440\u0435\u0434\u0430\u0435\u0442\u0441\u044F \u0447\u0435\u0440\u0435\u0437
    \u043F\u043E\u0441\u0440\u0435\u0434\u043D\u0438\u043A\u0430 (\u043F\u043E\u043B\u0435),
    \u0430 \u043D\u0435 \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E \u0447\u0435\u0440\u0435\u0437
    \u043F\u0443\u0441\u0442\u043E\u0442\u0443."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0420\u0435\u043D\u0435 \u0414\u0435\u043A\u0430\u0440\u0442\u0430 \u2014 \u044D\u0442\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u043C\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u043E\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0431\u0435\u0436\u0430\u043B \u043E\u0442 \u043C\u0438\u0440\u0441\u043A\u043E\u0439
    \u0441\u0443\u0435\u0442\u044B, \u043D\u043E \u043F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u043D\u0435 \u0431\u044B\u043B \u0430\u0441\u043A\u0435\u0442\u043E\u043C. \u041E\u043D
    \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0439:
    \u0434\u0432\u043E\u0440\u044F\u043D\u0438\u043D\u043E\u043C, \u0441\u043A\u0440\u044B\u0432\u0430\u044E\u0449\u0438\u043C
    \u0441\u0432\u043E\u0439 \u0430\u0434\u0440\u0435\u0441, \u043E\u0442\u0446\u043E\u043C,
    \u043F\u043E\u0442\u0435\u0440\u044F\u0432\u0448\u0438\u043C \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E
    \u0440\u0435\u0431\u0435\u043D\u043A\u0430, \u0438 \u043C\u0438\u0437\u0430\u043D\u0442\u0440\u043E\u043F\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u0435\u043B \u043E\u0431\u0448\u0438\u0440\u043D\u0435\u0439\u0448\u0443\u044E
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443 \u0441\u043E \u0432\u0441\u0435\u0439
    \u0415\u0432\u0440\u043E\u043F\u043E\u0439.  \u041D\u0438\u0436\u0435 \u2014
    \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E\u0435
    \u043F\u043E\u0433\u0440\u0443\u0436\u0435\u043D\u0438\u0435 \u0432 \u0438\u043D\u0442\u0438\u043C\u043D\u0443\u044E,
    \u0431\u044B\u0442\u043E\u0432\u0443\u044E \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0442\u043E\u0440\u043E\u043D\u0443 \u0436\u0438\u0437\u043D\u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430. 
    ---  ### 1. \u0412\u043D\u0435\u0448\u043D\u043E\u0441\u0442\u044C, \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440
    \u0438 \u0431\u044B\u0442\u043E\u0432\u044B\u0435 \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0438 
    - **\u0412\u043D\u0435\u0448\u043D\u043E\u0441\u0442\u044C:** \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438 \u0414\u0435\u043A\u0430\u0440\u0442\u0430
    \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u0433\u043E
    \u0440\u043E\u0441\u0442\u0430, \u0441 \u043A\u0440\u0443\u043F\u043D\u043E\u0439
    \u0433\u043E\u043B\u043E\u0432\u043E\u0439, \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u043B\u0431\u043E\u043C \u0438 \u0442\u043E\u043D\u043A\u0438\u043C, \u043F\u0440\u043E\u043D\u0438\u0446\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0432\u0437\u0433\u043B\u044F\u0434\u043E\u043C. \u041E\u043D \u0431\u044B\u043B
    \u0431\u043B\u0435\u0434\u0435\u043D \u0438\u0437-\u0437\u0430 \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u043F\u043E\u043C\u0435\u0449\u0435\u043D\u0438\u044F\u0445
    \u0438 \u0438\u043C\u0435\u043B \u0442\u0438\u0445\u0438\u0439, \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043B\u043E\u043C\u043A\u0438\u0439 \u0433\u043E\u043B\u043E\u0441. \u041D\u043E\u0441\u0438\u043B
    \u043E\u043D \u0441\u043A\u0440\u043E\u043C\u043D\u0443\u044E, \u043D\u043E \u0432\u0441\u0435\u0433\u0434\u0430
    \u043E\u043F\u0440\u044F\u0442\u043D\u0443\u044E \u0434\u0432\u043E\u0440\u044F\u043D\u0441\u043A\u0443\u044E
    \u043E\u0434\u0435\u0436\u0434\u0443 \u2014 \u0447\u0435\u0440\u043D\u044B\u0439
    \u043A\u0430\u043C\u0437\u043E\u043B \u0438 \u043F\u0440\u043E\u0441\u0442\u043E\u0439
    \u0431\u0435\u043B\u044B\u0439 \u0432\u043E\u0440\u043E\u0442\u043D\u0438\u043A.
    - **\u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440:** \u041E\u043D \u0431\u044B\u043B
    \u043A\u0440\u0430\u0439\u043D\u0435 \u0437\u0430\u043C\u043A\u043D\u0443\u0442,
    \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u0435\u043D \u0438
    \u043D\u0435\u0434\u043E\u0432\u0435\u0440\u0447\u0438\u0432. \u0414\u0440\u0443\u0437\u044C\u044F
    \u043E\u0442\u043C\u0435\u0447\u0430\u043B\u0438 \u0435\u0433\u043E \u0438\u0440\u043E\u043D\u0438\u0447\u043D\u044B\u0439
    \u0438 \u0438\u043D\u043E\u0433\u0434\u0430 \u043A\u043E\u043B\u043A\u0438\u0439
    \u0443\u043C. \u0414\u0435\u043A\u0430\u0440\u0442 \u043F\u0430\u0442\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438
    \u0431\u043E\u044F\u043B\u0441\u044F \u043E\u0433\u043B\u0430\u0441\u043A\u0438
    \u0438 \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439,
    \u0438\u0437-\u0437\u0430 \u0447\u0435\u0433\u043E \u0432 \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u0438
    \u043E\u043D \u043F\u0435\u0440\u0435\u0435\u0437\u0436\u0430\u043B \u0441 \u043C\u0435\u0441\u0442\u0430
    \u043D\u0430 \u043C\u0435\u0441\u0442\u043E 24 \u0440\u0430\u0437\u0430 \u0437\u0430
    20 \u043B\u0435\u0442, \u0447\u0430\u0441\u0442\u043E \u0434\u0430\u0436\u0435
    \u043D\u0435 \u0441\u043E\u043E\u0431\u0449\u0430\u044F \u0434\u0440\u0443\u0437\u044C\u044F\u043C
    \u043D\u043E\u0432\u043E\u0433\u043E \u0430\u0434\u0440\u0435\u0441\u0430. \u041E\u043D
    \u0431\u044B\u043B \u043F\u0435\u0440\u0444\u0435\u043A\u0446\u0438\u043E\u043D\u0438\u0441\u0442\u043E\u043C
    \u0438 \u043F\u0435\u0434\u0430\u043D\u0442\u043E\u043C \u0432 \u0434\u0435\u043B\u0430\u0445
    \u043D\u0430\u0443\u043A\u0438, \u043D\u043E \u0432 \u0431\u044B\u0442\u0443
    \u2014 \u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u044B\u043C. - **\u0420\u0435\u0436\u0438\u043C
    \u0434\u043D\u044F:** \u0414\u0435\u043A\u0430\u0440\u0442 \u0431\u044B\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u043C \xAB\u0441\u043E\u0432\u043E\u0439\xBB.
    \u041E\u043D \u043B\u043E\u0436\u0438\u043B\u0441\u044F \u0434\u0430\u043B\u0435\u043A\u043E
    \u0437\u0430 \u043F\u043E\u043B\u043D\u043E\u0447\u044C \u0438 \u0432\u0441\u0442\u0430\u0432\u0430\u043B
    \u043E\u043A\u043E\u043B\u043E 11\u201312 \u0447\u0430\u0441\u043E\u0432 \u0434\u043D\u044F.
    \u0421\u0432\u043E\u0435 \u043B\u0443\u0447\u0448\u0435\u0435 \u0432\u0440\u0435\u043C\u044F
    \u0434\u043B\u044F \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439
    \u043E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B \xAB\u0443\u0442\u0440\u043E\u043C
    \u0441\u0440\u0435\u0434\u0438 \u043D\u043E\u0447\u0438\xBB (\u043E\u0431\u044B\u0447\u043D\u043E
    \u0441 2 \u0434\u043E 5 \u0447\u0430\u0441\u043E\u0432 \u0443\u0442\u0440\u0430,
    \u043A\u043E\u0433\u0434\u0430 \u0432\u0441\u0435 \u0441\u043F\u0430\u043B\u0438,
    \u043E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 \u043A\u0440\u043E\u0432\u0430\u0442\u0438).
    \u0418\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u043E\u0442 \u043F\u0440\u0438\u0432\u044B\u0447\u043D\u044B\u0439
    \u0440\u0435\u0436\u0438\u043C \u0438 \u0441\u0442\u0430\u043B \u043A\u043E\u0441\u0432\u0435\u043D\u043D\u043E\u0439
    \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438
    \u0432 \u0428\u0432\u0435\u0446\u0438\u0438, \u0433\u0434\u0435 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0430
    \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430 \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u043B\u0430
    \u0435\u0433\u043E \u0432\u0441\u0442\u0430\u0432\u0430\u0442\u044C \u0432 5
    \u0443\u0442\u0440\u0430. - **\u0417\u0434\u043E\u0440\u043E\u0432\u044C\u0435:**
    \u0411\u0443\u0434\u0443\u0447\u0438 \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
    \u0445\u0440\u0443\u043F\u043A\u0438\u043C, \u043E\u043D \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C
    \u0436\u0430\u043B\u043E\u0432\u0430\u043B\u0441\u044F \u043D\u0430 \u0441\u0443\u0445\u043E\u0439
    \u043A\u0430\u0448\u0435\u043B\u044C, \u0441\u043B\u0430\u0431\u044B\u0435 \u043B\u0435\u0433\u043A\u0438\u0435
    \u0438 \u0441\u043A\u043B\u043E\u043D\u043D\u043E\u0441\u0442\u044C \u043A \u043B\u0438\u0445\u043E\u0440\u0430\u0434\u043A\u0430\u043C.
    \u041E\u043D \u043B\u0435\u0447\u0438\u043B\u0441\u044F \u043A\u0440\u043E\u0432\u043E\u043F\u0443\u0441\u043A\u0430\u043D\u0438\u044F\u043C\u0438
    \u0438 \u0441\u0442\u0440\u043E\u0433\u043E\u0439 \u0434\u0438\u0435\u0442\u043E\u0439,
    \u043D\u043E \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u043B\u044E\u0431\u0438\u043B
    \u0432\u043A\u0443\u0441\u043D\u043E \u043F\u043E\u0435\u0441\u0442\u044C \u0438
    \u0432\u044B\u043F\u0438\u0442\u044C \u0445\u043E\u0440\u043E\u0448\u0435\u0433\u043E
    \u0431\u0443\u0440\u0433\u0443\u043D\u0434\u0441\u043A\u043E\u0433\u043E \u0432\u0438\u043D\u0430. 
    ---  ### 2. \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0436\u0435\u043D\u0449\u0438\u043D\u0430\u043C\u0438:
    \u0424\u0440\u0430\u043D\u0441\u0438\u043D\u0430 \u0438 \u0425\u0435\u043B\u0435\u043D\u0430
    \u042F\u043D\u0441  \u042D\u0442\u043E \u0441\u0430\u043C\u0430\u044F \u0442\u0440\u043E\u0433\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u043D\u0430\u044F \u0433\u043B\u0430\u0432\u0430
    \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438.  -
    **\u0421\u043B\u0443\u0436\u0430\u043D\u043A\u0430 \u0425\u0435\u043B\u0435\u043D\u0430
    \u042F\u043D\u0441 \u0432\u0430\u043D \u0434\u0435\u0440 \u0421\u0442\u0440\u043E\u043C:**
    \u0412 1634 \u0433\u043E\u0434\u0443, \u0436\u0438\u0432\u044F \u0432 \u0410\u043C\u0441\u0442\u0435\u0440\u0434\u0430\u043C\u0435,
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043D\u0430\u043D\u044F\u043B \u0441\u043B\u0443\u0436\u0430\u043D\u043A\u0443
    \u0434\u043B\u044F \u0432\u0435\u0434\u0435\u043D\u0438\u044F \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u0430.
    \u0415\u044E \u0441\u0442\u0430\u043B\u0430 \u0425\u0435\u043B\u0435\u043D\u0430
    \u2014 \u0434\u0435\u0432\u0443\u0448\u043A\u0430 \u0438\u0437 \u043F\u0440\u043E\u0441\u0442\u043E\u0439
    \u0441\u0435\u043C\u044C\u0438, \u0434\u043E\u0447\u044C \u0442\u0440\u0430\u043A\u0442\u0438\u0440\u0449\u0438\u043A\u0430.
    \u0412 1635 \u0433\u043E\u0434\u0443 \u0443 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C
    \u0434\u043E\u0447\u044C.  - **\u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0441 \u0425\u0435\u043B\u0435\u043D\u043E\u0439:** \u042D\u0442\u043E \u043D\u0435
    \u0431\u044B\u043B \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u0440\u043E\u043C\u0430\u043D
    \u0432 \u043F\u043E\u044D\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C \u0441\u043C\u044B\u0441\u043B\u0435.
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0441\u044F
    \u043A \u0425\u0435\u043B\u0435\u043D\u0435 \u0441 \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435\u043C,
    \u043D\u043E \u043A\u0430\u043A \u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0443
    \u0431\u043E\u043B\u0435\u0435 \u043D\u0438\u0437\u043A\u043E\u0433\u043E \u0441\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0441\u0442\u0430\u0442\u0443\u0441\u0430. \u041E\u043D \u0442\u0430\u043A \u0438
    \u043D\u0435 \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u043D\u0430 \u043D\u0435\u0439
    (\u0431\u0440\u0430\u043A \u0441 \u043F\u0440\u0438\u0441\u043B\u0443\u0433\u043E\u0439
    \u0431\u044B\u043B \u0431\u044B \u043C\u0435\u0437\u0430\u043B\u044C\u044F\u043D\u0441\u043E\u043C
    \u0438 \u0438\u0441\u043F\u043E\u0440\u0442\u0438\u043B \u0431\u044B \u0435\u0433\u043E
    \u0434\u0432\u043E\u0440\u044F\u043D\u0441\u043A\u0443\u044E \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044E).
    \u041E\u0434\u043D\u0430\u043A\u043E \u043E\u043D \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u043B
    \u0435\u0435 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u043E, \u0438 \u043E\u043D\u0430
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C \u0441 \u043D\u0438\u043C
    \u0434\u043E \u0441\u0430\u043C\u043E\u0439 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438.
    \u041F\u043E\u0441\u043B\u0435 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438
    \u0441 \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u0438\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u043E\u0445\u043B\u0430\u0434\u0435\u043B\u0438, \u043D\u043E \u0425\u0435\u043B\u0435\u043D\u0430
    \u0432\u0435\u043B\u0430 \u0435\u0433\u043E \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u043E
    \u0432\u043F\u043B\u043E\u0442\u044C \u0434\u043E \u043E\u0442\u044A\u0435\u0437\u0434\u0430
    \u0432 \u0428\u0432\u0435\u0446\u0438\u044E. - **\u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0441\u043C\u0435\u0440\u0442\u044C \u0424\u0440\u0430\u043D\u0441\u0438\u043D\u044B
    (1635\u20131640):** \u0414\u0435\u043A\u0430\u0440\u0442 \u0431\u044B\u043B \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E
    \u043E\u0447\u0430\u0440\u043E\u0432\u0430\u043D \u0434\u043E\u0447\u0435\u0440\u044C\u044E.
    \u041E\u043D \u043D\u0430\u0437\u0432\u0430\u043B \u0435\u0435 \u0424\u0440\u0430\u043D\u0441\u0438\u043D\u043E\u0439
    \u0432 \u0447\u0435\u0441\u0442\u044C \u0441\u0435\u0431\u044F (\u0424\u0440\u0430\u043D\u0441\u0438\u043D
    \u2014 \u0436\u0435\u043D\u0441\u043A\u0430\u044F \u0444\u043E\u0440\u043C\u0430
    \u043E\u0442 \u0424\u0440\u0430\u043D\u0441\u0443\u0430/\u0420\u0435\u043D\u0435).
    \u0412 \u043F\u0438\u0441\u044C\u043C\u0430\u0445 \u0434\u0440\u0443\u0437\u044C\u044F\u043C
    \u043E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0435\u0451 \u0441\u0432\u043E\u0435\u0439
    \xAB\u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u0439 \u0433\u043E\u043B\u043B\u0430\u043D\u0434\u043A\u043E\u0439\xBB
    \u0438 \xAB\u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0443\u0442\u0435\u0448\u0435\u043D\u0438\u0435\u043C \u0432 \u044D\u0442\u043E\u043C
    \u043C\u0438\u0440\u0435\xBB.  - **\u0422\u0440\u0430\u0433\u0435\u0434\u0438\u044F:**
    \u0412 1640 \u0433\u043E\u0434\u0443 \u043F\u044F\u0442\u0438\u043B\u0435\u0442\u043D\u044F\u044F
    \u0424\u0440\u0430\u043D\u0441\u0438\u043D\u0430 \u0437\u0430\u0431\u043E\u043B\u0435\u043B\u0430
    \u0441\u043A\u0430\u0440\u043B\u0430\u0442\u0438\u043D\u043E\u0439. \u0414\u0435\u043A\u0430\u0440\u0442,
    \u0431\u0443\u0434\u0443\u0447\u0438 \u0432\u0440\u0430\u0447\u043E\u043C \u043F\u043E
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044E, \u0431\u0435\u0437\u0443\u0441\u043F\u0435\u0448\u043D\u043E
    \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0435\u0435 \u043B\u0435\u0447\u0438\u0442\u044C.
    \u0414\u0435\u0432\u043E\u0447\u043A\u0430 \u0443\u043C\u0435\u0440\u043B\u0430
    \u0443 \u043D\u0435\u0433\u043E \u043D\u0430 \u0440\u0443\u043A\u0430\u0445.
    \u042D\u0442\u043E \u0441\u043E\u0431\u044B\u0442\u0438\u0435 \u0441\u043B\u043E\u043C\u0430\u043B\u043E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430. \u041E\u043D \u0433\u043E\u0432\u043E\u0440\u0438\u043B,
    \u0447\u0442\u043E \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u0432 \u0436\u0438\u0437\u043D\u0438
    \u043D\u0435 \u043F\u043B\u0430\u043A\u0430\u043B \u0442\u0430\u043A \u0433\u043E\u0440\u044C\u043A\u043E,
    \u043A\u0430\u043A \u0432 \u0442\u043E\u0442 \u0434\u0435\u043D\u044C. \u041E\u043D
    \u0443\u0435\u0445\u0430\u043B \u0438\u0437 \u0410\u043C\u0441\u0442\u0435\u0440\u0434\u0430\u043C\u0430
    \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u044E, \u0447\u0442\u043E\u0431\u044B
    \u0441\u043A\u0440\u044B\u0442\u044C \u0441\u0432\u043E\u044E \u043F\u0435\u0447\u0430\u043B\u044C,
    \u0438 \u043F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0433\u043E \u0441\u0442\u0430\u043B
    \u0435\u0449\u0435 \u0431\u043E\u043B\u0435\u0435 \u043C\u0440\u0430\u0447\u043D\u044B\u043C
    \u0438 \u043E\u0442\u0441\u0442\u0440\u0430\u043D\u0435\u043D\u043D\u044B\u043C.
    \u0412 \u0435\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u044D\u0442\u0430 \u0431\u043E\u043B\u044C \u043E\u0442\u0440\u0430\u0437\u0438\u043B\u0430\u0441\u044C
    \u0432 \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435 \xAB\u0421\u0442\u0440\u0430\u0441\u0442\u0438
    \u0434\u0443\u0448\u0438\xBB, \u0433\u0434\u0435 \u043E\u043D \u0441 \u043E\u0441\u043E\u0431\u044B\u043C
    \u0446\u0438\u043D\u0438\u0437\u043C\u043E\u043C \u0438 \u0431\u043E\u043B\u044C\u044E
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442 \u0444\u0438\u0437\u0438\u043E\u043B\u043E\u0433\u0438\u044E
    \u0433\u043E\u0440\u044F.  ---  ### 3. \u0414\u0440\u0443\u0436\u0431\u0430 \u0438
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430 (\u0421\u043E\u0446\u0438\u0430\u043B\u044C\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C)  \u041F\u0440\u0438 \u0441\u0432\u043E\u0435\u0439
    \u043C\u0438\u0437\u0430\u043D\u0442\u0440\u043E\u043F\u0438\u0438 \u0414\u0435\u043A\u0430\u0440\u0442
    \u0431\u044B\u043B \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u0437\u0430\u0432\u0438\u0441\u0438\u043C \u043E\u0442 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u043D\u0438\u044F. \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u0434\u0440\u0443\u0433\u043E\u043C \u0438 \xAB\u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u044B\u043C
    \u0430\u0433\u0435\u043D\u0442\u043E\u043C\xBB \u043D\u0430 \u043F\u0440\u043E\u0442\u044F\u0436\u0435\u043D\u0438\u0438
    \u0432\u0441\u0435\u0439 \u0436\u0438\u0437\u043D\u0438 \u0431\u044B\u043B **\u041C\u0430\u0440\u0435\u043D
    \u041C\u0435\u0440\u0441\u0435\u043D\u043D** (\u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439
    \u043C\u043E\u043D\u0430\u0445-\u043C\u0438\u043D\u0438\u043C\u0430\u043B\u0438\u0442
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A). \u0418\u043C\u0435\u043D\u043D\u043E
    \u041C\u0435\u0440\u0441\u0435\u043D\u043D\u0443 \u0414\u0435\u043A\u0430\u0440\u0442
    \u0434\u043E\u0432\u0435\u0440\u044F\u043B \u0432\u0441\u0435 \u0441\u0432\u043E\u0438
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0438, \u0438 \u0438\u043C\u0435\u043D\u043D\u043E
    \u0447\u0435\u0440\u0435\u0437 \u041C\u0435\u0440\u0441\u0435\u043D\u043D\u0430
    \u0448\u043B\u0430 \u0432\u0441\u044F \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u043F\u043E\u043B\u0435\u043C\u0438\u043A\u0430.  - **\u0421\u0432\u044F\u0437\u044C
    \u0441 \u043F\u0440\u0438\u043D\u0446\u0435\u0441\u0441\u043E\u0439 \u0415\u043B\u0438\u0437\u0430\u0432\u0435\u0442\u043E\u0439
    \u0411\u043E\u0433\u0435\u043C\u0441\u043A\u043E\u0439:** \u042D\u0442\u043E
    \u043E\u0434\u043D\u0430 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043A\u0440\u0430\u0441\u0438\u0432\u044B\u0445
    \u043F\u043B\u0430\u0442\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u0442\u043E\u0440\u0438\u0439 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438. \u0421 1643 \u0433\u043E\u0434\u0430
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043D\u0430\u0447\u0430\u043B \u0438\u043D\u0442\u0435\u043D\u0441\u0438\u0432\u043D\u0443\u044E
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0443 \u0441 \u0415\u043B\u0438\u0437\u0430\u0432\u0435\u0442\u043E\u0439
    \u041F\u0444\u0430\u043B\u044C\u0446\u0441\u043A\u043E\u0439 (\u0434\u043E\u0447\u0435\u0440\u044C\u044E
    \xAB\u0417\u0438\u043C\u043D\u0435\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u044F\xBB
    \u0411\u043E\u0433\u0435\u043C\u0438\u0438). \u041E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u0443\u043C\u043D\u0435\u0439\u0448\u0435\u0439 \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439
    \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043F\u0438\u0441\u0430\u043B \u0435\u0439
    \u043D\u0435 \u043A\u0430\u043A \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0439
    \u043E\u0441\u043E\u0431\u0435, \u0430 \u043A\u0430\u043A \u0440\u0430\u0432\u043D\u043E\u0439
    \u043F\u043E \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442\u0443. \u0418\u043C\u0435\u043D\u043D\u043E
    \u0432 \u043F\u0438\u0441\u044C\u043C\u0430\u0445 \u043A \u043D\u0435\u0439 \u043E\u043D
    \u0434\u0435\u0442\u0430\u043B\u044C\u043D\u043E \u0440\u0430\u0437\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u043B
    \u044D\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u0447\u0430\u0441\u0442\u044C
    \u0441\u0432\u043E\u0435\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438
    \u0438 \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u044E \u0441\u0432\u043E\u0431\u043E\u0434\u044B
    \u0432\u043E\u043B\u0438. \u041E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B
    \u0435\u0451 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439,
    \u043A\u0442\u043E \u043F\u043E\u043D\u044F\u043B \u0435\u0433\u043E \xAB\u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u044E\xBB
    \u043B\u0443\u0447\u0448\u0435 \u0432\u0441\u0435\u0445 \u0443\u0447\u0435\u043D\u044B\u0445-\u043C\u0443\u0436\u0447\u0438\u043D.
    \u041F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430 \u0434\u043B\u0438\u043B\u0430\u0441\u044C
    \u0434\u043E \u0441\u0430\u043C\u043E\u0439 \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438.
    - **\u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0430 \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430:**
    \u0412\u0442\u043E\u0440\u0430\u044F \u0437\u043D\u0430\u0447\u0438\u043C\u0430\u044F
    \xAB\u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u0430\u044F \u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043A\u0430\xBB.
    \u041D\u043E \u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0442\u0451\u043F\u043B\u044B\u0445
    \u0438 \u043D\u0435\u0436\u043D\u044B\u0445 \u043F\u0438\u0441\u0435\u043C \u043A
    \u0415\u043B\u0438\u0437\u0430\u0432\u0435\u0442\u0435, \u043E\u0431\u0449\u0435\u043D\u0438\u0435
    \u0441 \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u043E\u0439 \u0431\u044B\u043B\u043E
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E-\u0445\u043E\u043B\u043E\u0434\u043D\u044B\u043C.
    \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430 \u0441\u0447\u0438\u0442\u0430\u043B\u0430
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430 \u043B\u0438\u0448\u044C \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u043C
    \xAB\u044D\u043A\u0441\u043F\u043E\u043D\u0430\u0442\u043E\u043C\xBB \u0434\u043B\u044F
    \u0441\u0432\u043E\u0435\u0433\u043E \u0434\u0432\u043E\u0440\u0430.  ---  ###
    4. \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u0434\u0435\u043D\u044C\u0433\u0430\u043C\u0438
    \u0438 \u0430\u0440\u0438\u0441\u0442\u043E\u043A\u0440\u0430\u0442\u0438\u0435\u0439 
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0431\u044B\u043B \u0434\u0432\u043E\u0440\u044F\u043D\u0438\u043D\u043E\u043C
    \u0438 \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    (\u0432 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u0430
    \u0443\u0447\u0435\u043D\u044B\u0445 \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438).
    \u0415\u0433\u043E \u043A\u0430\u043F\u0438\u0442\u0430\u043B \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0438: 
    - \u041D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E, \u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u0435
    \u043E\u0442\u0446\u043E\u043C (\u0437\u0435\u043C\u0435\u043B\u044C\u043D\u044B\u0435
    \u0432\u043B\u0430\u0434\u0435\u043D\u0438\u044F \u0432 \u041F\u0443\u0430\u0442\u0443).
    - \u041F\u0435\u043D\u0441\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0430\u043B \u043E\u0442 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u043E\u043B\u044F (\u041B\u044E\u0434\u043E\u0432\u0438\u043A
    XIII \u0434\u0430\u0440\u043E\u0432\u0430\u043B \u0435\u043C\u0443 \u043F\u0435\u043D\u0441\u0438\u043E\u043D
    \u0432 1000 \u043B\u0438\u0432\u0440\u043E\u0432 \u0432 1635 \u0433\u043E\u0434\u0443).
    - \u0417\u0430 \u0441\u0432\u043E\u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u044B \u043E\u043D **\u043D\u0435
    \u043F\u043E\u043B\u0443\u0447\u0430\u043B \u0433\u043E\u043D\u043E\u0440\u0430\u0440\u043E\u0432**
    \u043A\u0430\u043A \u0441\u0435\u0439\u0447\u0430\u0441. \u041D\u0430\u043E\u0431\u043E\u0440\u043E\u0442,
    \u043E\u043D \u0438\u0437\u0434\u0430\u0432\u0430\u043B \u0438\u0445 \u0437\u0430
    \u0441\u0432\u043E\u0439 \u0441\u0447\u0435\u0442 \u0438 \u0440\u0430\u0437\u0434\u0430\u0432\u0430\u043B
    \u0431\u0435\u0441\u043F\u043B\u0430\u0442\u043D\u043E \u0437\u043D\u0430\u0442\u043D\u044B\u043C
    \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044F\u043C, \u0447\u0442\u043E\u0431\u044B
    \u0437\u0430\u0440\u0443\u0447\u0438\u0442\u044C\u0441\u044F \u0438\u0445 \u0437\u0430\u0449\u0438\u0442\u043E\u0439. 
    \u041E\u043D \u0431\u044B\u043B \u043F\u0440\u0438\u0436\u0438\u043C\u0438\u0441\u0442
    \u0438 \u0440\u0430\u0441\u0447\u0435\u0442\u043B\u0438\u0432. \u041F\u0435\u0440\u0435\u0435\u0437\u0436\u0430\u044F,
    \u043E\u043D \u0432\u0441\u0435\u0433\u0434\u0430 \u0434\u043E\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u043B\u0441\u044F
    \u043E \u043D\u0438\u0437\u043A\u043E\u0439 \u0430\u0440\u0435\u043D\u0434\u043D\u043E\u0439
    \u043F\u043B\u0430\u0442\u0435, \u043D\u043E \u043F\u0440\u0438 \u044D\u0442\u043E\u043C
    \u0434\u0435\u0440\u0436\u0430\u043B \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u0441\u043B\u0443\u0433 (\u043A\u0430\u043C\u0435\u0440\u0434\u0438\u043D\u0435\u0440\u0430,
    \u043A\u0443\u0445\u0430\u0440\u043A\u0443 \u0438, \u043A\u043E\u043D\u0435\u0447\u043D\u043E,
    \u0425\u0435\u043B\u0435\u043D\u0443). \u041E\u043D \u043E\u0447\u0435\u043D\u044C
    \u0440\u0435\u0432\u043D\u043E\u0441\u0442\u043D\u043E \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0441\u044F
    \u043A \u0441\u0432\u043E\u0435\u043C\u0443 \u0441\u0442\u0430\u0442\u0443\u0441\u0443,
    \u043F\u0440\u0438 \u043B\u044E\u0431\u043E\u043C \u0443\u0434\u043E\u0431\u043D\u043E\u043C
    \u0441\u043B\u0443\u0447\u0430\u0435 \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u044F
    \u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u0430\u043C,
    \u0447\u0442\u043E \u043E\u043D \xAB\u0448\u0435\u0432\u0430\u043B\u044C\u0435,
    \u0441\u0435\u043D\u044C\u043E\u0440 \u0434\u044E \u041F\u0435\u0440\u0440\u043E\u043D\xBB
    (\u0445\u043E\u0442\u044F \u043F\u043E\u043C\u0435\u0441\u0442\u044C\u0435 \u0431\u044B\u043B\u043E
    \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u043C).  ---  ### 5. \u041F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F
    \u0438 \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u0435
    \u043F\u043E\u0441\u0442\u0443\u043F\u043A\u0438  - **\u041E\u0445\u043E\u0442\u0430
    \u043D\u0430 \u0432\u0435\u0434\u044C\u043C \u0432 \u0422\u0438\u0440\u043E\u043B\u0435:**
    \u0412 1619 \u0433\u043E\u0434\u0443, \u0431\u0443\u0434\u0443\u0447\u0438 \u043D\u0430
    \u0432\u043E\u0435\u043D\u043D\u043E\u0439 \u0441\u043B\u0443\u0436\u0431\u0435
    \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u0438, \u0414\u0435\u043A\u0430\u0440\u0442
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
    \u0432 \u043E\u0442\u0434\u0430\u043B\u0435\u043D\u043D\u0443\u044E \u0434\u0435\u0440\u0435\u0432\u043D\u044E
    (\u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0437\u0438\u043C\u043E\u0432\u043A\u0438),
    \u0447\u0442\u043E\u0431\u044B \u043D\u0430\u0439\u0442\u0438 \xAB\u0431\u0440\u0430\u0442\u0441\u0442\u0432\u043E
    \u0440\u043E\u0437\u0435\u043D\u043A\u0440\u0435\u0439\u0446\u0435\u0440\u043E\u0432\xBB
    \u2014 \u0442\u0430\u0439\u043D\u043E\u0435 \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E, \u043E \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0445\u043E\u0434\u0438\u043B\u0438 \u0441\u043B\u0443\u0445\u0438. \u041E\u043D
    \u0438\u0445 \u043D\u0435 \u043D\u0430\u0448\u0435\u043B, \u0437\u0430\u0442\u043E
    \u043D\u0430\u0448\u0435\u043B \u0443\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u0435
    \u0434\u043B\u044F \u0441\u0432\u043E\u0438\u0445 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445
    \u043E\u0437\u0430\u0440\u0435\u043D\u0438\u0439. - **\u042D\u043F\u0438\u0437\u043E\u0434
    \u0441 \u044F\u0439\u0446\u043E\u043C:** \u0412 \u041F\u0430\u0440\u0438\u0436\u0435
    \u0432 1620-\u0445 \u0433\u043E\u0434\u0430\u0445, \u0447\u0442\u043E\u0431\u044B
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u043D\u0430\u043B\u0438\u0447\u0438\u0435
    \u0432\u0430\u043A\u0443\u0443\u043C\u0430 (\u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043D \u043E\u0442\u0440\u0438\u0446\u0430\u043B), \u0414\u0435\u043A\u0430\u0440\u0442
    \u044F\u043A\u043E\u0431\u044B \u043F\u0440\u043E\u0432\u0435\u043B \u043E\u043F\u044B\u0442
    \u0441\u043E \u0441\u0442\u0435\u043A\u043B\u044F\u043D\u043D\u043E\u0439 \u0442\u0440\u0443\u0431\u043A\u043E\u0439
    \u0438 \u044F\u0439\u0446\u043E\u043C, \u0432\u0433\u043E\u043D\u044F\u044F \u0435\u0433\u043E
    \u0432 \u0433\u043E\u0440\u043B\u044B\u0448\u043A\u043E \u0441\u043E\u0441\u0443\u0434\u0430
    \u0441\u0438\u043B\u043E\u0439 \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0432\u043E\u0437\u0434\u0443\u0445\u0430. \u042D\u0442\u0438 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0448\u043E\u0443 \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u0430\u043B\u0438
    \u043A \u043D\u0435\u043C\u0443 \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435
    \u0437\u043D\u0430\u0442\u0438. - **\u0421\u0441\u043E\u0440\u044B \u0441 \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0430\u043C\u0438:**
    \u0412 \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u0438 \u043E\u043D \u0432\u0435\u043B
    \u0441\u0435\u0431\u044F \u0432\u044B\u0437\u044B\u0432\u0430\u044E\u0449\u0435
    \u0441\u043C\u0435\u043B\u043E \u0434\u043B\u044F \u0441\u0432\u043E\u0435\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u041A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E
    \u043E\u0431\u0432\u0438\u043D\u044F\u043B\u0438 \u0432 \u0430\u0442\u0435\u0438\u0437\u043C\u0435,
    \u043E\u043D \u043D\u0435 \u0441\u043A\u0440\u044B\u0432\u0430\u043B\u0441\u044F,
    \u0430 \u043F\u0438\u0441\u0430\u043B \u044F\u0437\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
    \u043F\u0430\u043C\u0444\u043B\u0435\u0442\u044B \u043D\u0430 \u0434\u0435\u043A\u0430\u043D\u0430
    \u0423\u0442\u0440\u0435\u0445\u0442\u0441\u043A\u043E\u0433\u043E \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430
    \u0412\u043E\u044D\u0446\u0438\u044F, \u043D\u0430\u0437\u044B\u0432\u0430\u044F
    \u0435\u0433\u043E \xAB\u0442\u0443\u043F\u0438\u0446\u0435\u0439\xBB. \u042D\u0442\u043E
    \u0447\u0443\u0442\u044C \u043D\u0435 \u0441\u0442\u043E\u0438\u043B\u043E \u0435\u043C\u0443
    \u0438\u0437\u0433\u043D\u0430\u043D\u0438\u044F \u0438\u0437 \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u0438
    \u0432 1646 \u0433\u043E\u0434\u0443 \u2014 \u043E\u043D \u0431\u044B\u043B \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D
    \u043D\u0430 \u0432\u0440\u0435\u043C\u044F \u0443\u0435\u0445\u0430\u0442\u044C
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E, \u0447\u0442\u043E\u0431\u044B
    \u043E\u0441\u0442\u044B\u043B\u0438 \u0441\u0442\u0440\u0430\u0441\u0442\u0438,
    \u043D\u043E \u0431\u044B\u0441\u0442\u0440\u043E \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F. 
    ---  ### 6. \u0416\u0438\u0437\u043D\u044C \u0432 \u0428\u0432\u0435\u0446\u0438\u0438:
    \u0424\u0430\u0442\u0430\u043B\u044C\u043D\u0430\u044F \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u0430\u044F
    \u043F\u0440\u0438\u0445\u043E\u0442\u044C  \u042D\u0442\u043E \u0431\u044B\u043B\u0430
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F \u0438 \u0441\u0430\u043C\u0430\u044F
    \u0442\u044F\u0436\u0435\u043B\u0430\u044F \u0433\u043B\u0430\u0432\u0430 \u0435\u0433\u043E
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438.  - **\u041F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435:**
    \u0412 1649 \u0433\u043E\u0434\u0443 23-\u043B\u0435\u0442\u043D\u044F\u044F
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0430 \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F \u0441\u0432\u043E\u0438\u043C
    \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u043D\u044B\u043C
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C (\u043E\u043D\u0430
    \u043E\u0434\u0435\u0432\u0430\u043B\u0430\u0441\u044C \u043A\u0430\u043A \u043C\u0443\u0436\u0447\u0438\u043D\u0430,
    \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0430\u0441\u044C \u0432\u044B\u0445\u043E\u0434\u0438\u0442\u044C
    \u0437\u0430\u043C\u0443\u0436 \u0438 \u043F\u043E\u0437\u0436\u0435 \u043E\u0442\u0440\u0435\u043A\u043B\u0430\u0441\u044C
    \u043E\u0442 \u0442\u0440\u043E\u043D\u0430), \u0437\u0430\u0441\u044B\u043F\u0430\u043B\u0430
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430 \u043F\u0438\u0441\u044C\u043C\u0430\u043C\u0438.
    \u041E\u043D\u0430 \u043D\u0435 \u0445\u043E\u0442\u0435\u043B\u0430 \u0435\u0433\u043E
    \u043A\u043D\u0438\u0433, \u043E\u043D\u0430 \u0445\u043E\u0442\u0435\u043B\u0430,
    \u0447\u0442\u043E\u0431\u044B \u043E\u043D \u043B\u0438\u0447\u043D\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u043B
    \u0435\u0435 \u0432 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438. -
    **\u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u043A\u043B\u0438\u043C\u0430\u0442\u043E\u0432:**
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043D\u0435 \u0445\u043E\u0442\u0435\u043B
    \u0435\u0445\u0430\u0442\u044C (\xAB\u042F \u0440\u043E\u0436\u0434\u0435\u043D
    \u0432 \u0441\u0430\u0434\u0430\u0445 \u0422\u044E\u0438\u043B\u044C\u0440\u0438,
    \u0430 \u043D\u0435 \u0441\u0440\u0435\u0434\u0438 \u0441\u043A\u0430\u043B \u0438
    \u043C\u0435\u0434\u0432\u0435\u0434\u0435\u0439 \u0421\u0435\u0432\u0435\u0440\u0430\xBB
    \u2014 \u043F\u0438\u0441\u0430\u043B \u043E\u043D), \u043D\u043E \u043F\u043E\u0434
    \u0434\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E
    \u043F\u043E\u0441\u043B\u0430 \u0438 \u0441\u0442\u0440\u0430\u0445\u0430 \u043F\u043E\u0442\u0435\u0440\u044F\u0442\u044C
    \u043F\u043E\u043A\u0440\u043E\u0432\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0441\u0434\u0430\u043B\u0441\u044F. - **\u0410\u0434\u0441\u043A\u0438\u0439
    \u0433\u0440\u0430\u0444\u0438\u043A:** \u041F\u0440\u0438\u0431\u044B\u0432
    \u0432 \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C \u0432 \u043E\u043A\u0442\u044F\u0431\u0440\u0435
    1649 \u0433\u043E\u0434\u0430, \u043E\u043D \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F
    \u0441 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u043C. \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0430
    \u0431\u044B\u043B\u0430 \u0444\u0430\u043D\u0430\u0442\u0438\u0447\u043D\u044B\u043C
    \xAB\u0436\u0430\u0432\u043E\u0440\u043E\u043D\u043A\u043E\u043C\xBB \u0438 \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043B\u0430
    \u0443\u0440\u043E\u043A\u043E\u0432 \u0432 **5 \u0447\u0430\u0441\u043E\u0432
    \u0443\u0442\u0440\u0430** \u0432 \u0441\u0432\u043E\u0435\u0439 \u043D\u0435\u043E\u0442\u0430\u043F\u043B\u0438\u0432\u0430\u0435\u043C\u043E\u0439
    \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0435 (\u0437\u0438\u043C\u043E\u0439
    \u0432 \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C\u0435 \u0442\u0435\u043C\u043F\u0435\u0440\u0430\u0442\u0443\u0440\u0430
    \u043F\u0430\u0434\u0430\u0435\u0442 \u0434\u043E -20\xB0C). \u0414\u043B\u044F
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430, \u043F\u0440\u0438\u0432\u044B\u043A\u0448\u0435\u0433\u043E
    \u0432\u0441\u0442\u0430\u0432\u0430\u0442\u044C \u0432 \u043F\u043E\u043B\u0434\u0435\u043D\u044C,
    \u044D\u0442\u043E \u0431\u044B\u043B\u043E \u043F\u044B\u0442\u043A\u043E\u0439.
    - **\u041E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u043E:** \u0412
    \u0428\u0432\u0435\u0446\u0438\u0438 \u0441 \u043D\u0438\u043C \u043D\u0435 \u0431\u044B\u043B\u043E
    \u0425\u0435\u043B\u0435\u043D\u044B. \u041E\u043D \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u0435\u0431\u044F \u0447\u0443\u0436\u0430\u043A\u043E\u043C \u043F\u0440\u0438
    \u0434\u0432\u043E\u0440\u0435, \u0433\u0434\u0435 \u0432\u0441\u0435 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438
    \u043F\u043E-\u0448\u0432\u0435\u0434\u0441\u043A\u0438 \u0438\u043B\u0438 \u043F\u043E-\u043D\u0435\u043C\u0435\u0446\u043A\u0438.
    \u041E\u043D \u0436\u0430\u043B\u043E\u0432\u0430\u043B\u0441\u044F, \u0447\u0442\u043E
    \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u0441\u044F \u0432 \xAB\u0436\u0438\u0432\u0443\u044E
    \u043A\u043D\u0438\u0433\u0443\xBB \u0434\u043B\u044F \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u044B,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u044E\u0442
    \u0442\u043E\u0433\u0434\u0430, \u043A\u043E\u0433\u0434\u0430 \u0445\u043E\u0442\u044F\u0442,
    \u0430 \u043D\u0435 \u0442\u043E\u0433\u0434\u0430, \u043A\u043E\u0433\u0434\u0430
    \u043D\u0443\u0436\u043D\u043E.  ---  ### 7. \u0422\u0430\u0439\u043D\u0430 \u0441\u043C\u0435\u0440\u0442\u0438:
    \u0411\u043E\u043B\u0435\u0437\u043D\u044C \u0438\u043B\u0438 \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435? 
    \u0412 \u043D\u0430\u0447\u0430\u043B\u0435 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    1650 \u0433\u043E\u0434\u0430, \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u044F\u0441\u044C
    \u0441 \u043E\u0447\u0435\u0440\u0435\u0434\u043D\u043E\u0433\u043E \u0440\u0430\u043D\u043D\u0435\u0433\u043E
    \u0443\u0440\u043E\u043A\u0430 \u043E\u0442 \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u044B,
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043F\u043E\u043F\u0430\u043B \u043F\u043E\u0434
    \u043B\u0435\u0434\u044F\u043D\u043E\u0439 \u0434\u043E\u0436\u0434\u044C \u0438
    \u043F\u0440\u043E\u0441\u0442\u0443\u0434\u0438\u043B\u0441\u044F. \u041E\u043D
    \u0441\u043B\u0435\u0433 \u0441 \u0432\u044B\u0441\u043E\u043A\u043E\u0439 \u0442\u0435\u043C\u043F\u0435\u0440\u0430\u0442\u0443\u0440\u043E\u0439
    \u0438 \u043A\u0430\u0448\u043B\u0435\u043C.  - **\u041B\u0435\u0447\u0435\u043D\u0438\u0435
    \u0432\u0440\u0430\u0447\u0435\u0439:** \u041F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u044B\u0435
    \u0432\u0440\u0430\u0447\u0438 (\u0441\u0430\u043C \u0414\u0435\u043A\u0430\u0440\u0442
    \u0431\u044B\u043B \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0441\u043B\u0430\u0431,
    \u0447\u0442\u043E\u0431\u044B \u043B\u0435\u0447\u0438\u0442\u044C \u0441\u0435\u0431\u044F)
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B\u0438 \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u0443\u044E
    \u0434\u043B\u044F \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438,
    \u043D\u043E \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0434\u043B\u044F \u043F\u043D\u0435\u0432\u043C\u043E\u043D\u0438\u0438 \u043F\u0440\u043E\u0446\u0435\u0434\u0443\u0440\u0443:
    **\u043A\u0440\u043E\u0432\u043E\u043F\u0443\u0441\u043A\u0430\u043D\u0438\u0435**.
    \u042D\u0442\u043E \u0435\u0449\u0435 \u0431\u043E\u043B\u044C\u0448\u0435 \u043E\u0441\u043B\u0430\u0431\u0438\u043B\u043E
    \u0435\u0433\u043E \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C. - **\u0417\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0435:**
    \u041F\u0435\u0440\u0435\u0434 \u0441\u043C\u0435\u0440\u0442\u044C\u044E \u043E\u043D
    \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B \u043F\u0440\u0438\u0432\u0435\u0441\u0442\u0438
    \u0441\u0432\u044F\u0449\u0435\u043D\u043D\u0438\u043A\u0430 \u0438 \u043F\u0440\u043E\u0434\u0438\u043A\u0442\u043E\u0432\u0430\u043B
    \u043E\u0447\u0435\u043D\u044C \u043A\u043E\u0440\u043E\u0442\u043A\u043E\u0435
    \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0435, \u043E\u0441\u0442\u0430\u0432\u0438\u0432
    \u0432\u0441\u0435 \u0441\u0432\u043E\u0435 \u0441\u043A\u0443\u0434\u043D\u043E\u0435
    \u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u043E (\u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C
    \u043A\u043D\u0438\u0433\u0438 \u0438 \u0434\u043E\u043B\u0433\u0438) \u0425\u0435\u043B\u0435\u043D\u0435
    \u042F\u043D\u0441. - **\u0412\u0435\u0440\u0441\u0438\u044F \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F:**
    \u0412 1980-\u0445 \u0433\u043E\u0434\u0430\u0445 \u0448\u0432\u0435\u0434\u0441\u043A\u0438\u0439
    \u0432\u0440\u0430\u0447-\u0442\u043E\u043A\u0441\u0438\u043A\u043E\u043B\u043E\u0433
    \u042D\u0439\u043A\u0435 \u041F\u0438\u043B\u044C\u0446 \u0438\u0437\u0443\u0447\u0438\u043B
    \u043E\u0441\u0442\u0430\u043D\u043A\u0438 \u0414\u0435\u043A\u0430\u0440\u0442\u0430
    (\u0432\u043E\u043B\u043E\u0441\u044B, \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432\u0448\u0438\u0435\u0441\u044F
    \u0432 \u0440\u0435\u043B\u0438\u043A\u0432\u0430\u0440\u0438\u0438) \u0438 \u043D\u0430\u0448\u0435\u043B
    \u0432 \u043D\u0438\u0445 **\u043F\u043E\u0432\u044B\u0448\u0435\u043D\u043D\u043E\u0435
    \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435 \u043C\u044B\u0448\u044C\u044F\u043A\u0430**
    (\u0432 11 \u0440\u0430\u0437 \u0432\u044B\u0448\u0435 \u043D\u043E\u0440\u043C\u044B).     
    - *\u041A\u043E\u043D\u0441\u043F\u0438\u0440\u043E\u043B\u043E\u0433\u0438\u044F:*
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0441\u0438\u043B\u044C\u043D\u043E \u043C\u0435\u0448\u0430\u043B
    \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439 \u0446\u0435\u0440\u043A\u0432\u0438
    \u0438 \u0438\u0435\u0437\u0443\u0438\u0442\u0430\u043C, \u043F\u043E\u0442\u043E\u043C\u0443
    \u0447\u0442\u043E \u0435\u0433\u043E \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0437\u043C
    \u043F\u043E\u0434\u0440\u044B\u0432\u0430\u043B \u0430\u0432\u0442\u043E\u0440\u0438\u0442\u0435\u0442
    \u0432\u0435\u0440\u044B. \u0411\u043E\u043B\u0435\u0435 \u0442\u043E\u0433\u043E,
    \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430 \u0432 1654 \u0433\u043E\u0434\u0443
    (\u0447\u0435\u0440\u0435\u0437 4 \u0433\u043E\u0434\u0430) \u0442\u0430\u0439\u043D\u043E
    \u043F\u0440\u0438\u043D\u044F\u043B\u0430 \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E,
    \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0438\u0437\u043C\u0435\u043D\u043E\u0439 \u0432 \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u0441\u043A\u043E\u0439
    \u0428\u0432\u0435\u0446\u0438\u0438. \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0442,
    \u0447\u0442\u043E \u0438\u0435\u0437\u0443\u0438\u0442\u044B, \u0436\u0435\u043B\u0430\u0432\u0448\u0438\u0435
    \u043E\u0431\u0440\u0430\u0442\u0438\u0442\u044C \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0443,
    \u0431\u043E\u044F\u043B\u0438\u0441\u044C, \u0447\u0442\u043E \u0414\u0435\u043A\u0430\u0440\u0442
    \u043E\u0442\u0433\u043E\u0432\u043E\u0440\u0438\u0442 \u0435\u0451, \u0438 \u0443\u0431\u0440\u0430\u043B\u0438
    \u0435\u0433\u043E \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043C\u044B\u0448\u044C\u044F\u043A\u0430,
    \u043F\u043E\u0434\u043C\u0435\u0448\u0430\u043D\u043D\u043E\u0433\u043E \u0432
    \u0432\u0438\u043D\u043E \u0438\u043B\u0438 \u043F\u0440\u0438\u0447\u0430\u0441\u0442\u0438\u0435.    
    - *\u041E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u0430\u044F \u0432\u0435\u0440\u0441\u0438\u044F:*
    \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438-\u043E\u0440\u0442\u043E\u0434\u043E\u043A\u0441\u044B
    \u043E\u0442\u0432\u0435\u0440\u0433\u0430\u044E\u0442 \u044D\u0442\u0443 \u0432\u0435\u0440\u0441\u0438\u044E,
    \u0443\u043A\u0430\u0437\u044B\u0432\u0430\u044F, \u0447\u0442\u043E \u043C\u044B\u0448\u044C\u044F\u043A
    \u0432 \u0442\u0443 \u044D\u043F\u043E\u0445\u0443 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u043A\u0430\u043A \u043B\u0435\u043A\u0430\u0440\u0441\u0442\u0432\u043E (\u0432
    \u043C\u0430\u043B\u044B\u0445 \u0434\u043E\u0437\u0430\u0445) \u043E\u0442 \u043B\u0438\u0445\u043E\u0440\u0430\u0434\u043E\u043A,
    \u0438 \u043E\u043D \u043C\u043E\u0433 \u043D\u0430\u043A\u043E\u043F\u0438\u0442\u044C\u0441\u044F
    \u0432 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043C\u0435 \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043F\u0443\u0442\u0435\u043C. \u041E\u0434\u043D\u0430\u043A\u043E \u0437\u0430\u0433\u0430\u0434\u043A\u0430
    \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F
    \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0439 \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440.  \u0423\u043C\u0435\u0440 \u043E\u043D 11 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    1650 \u0433\u043E\u0434\u0430, \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441\u044F
    \u043F\u0435\u0440\u0435\u0434 \u044D\u0442\u0438\u043C, \u043F\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435,
    \u0444\u0440\u0430\u0437\u0443: *\xAB\u0414\u0443\u0448\u0430 \u043C\u043E\u044F,
    \u0442\u044B \u0434\u043E\u043B\u0433\u043E \u0431\u044B\u043B\u0430 \u0432 \u0442\u0435\u043C\u043D\u0438\u0446\u0435,
    \u0442\u0435\u043F\u0435\u0440\u044C \u043D\u0430\u0441\u0442\u0430\u043B \u0447\u0430\u0441
    \u0432\u044B\u0439\u0442\u0438 \u0438\u0437 \u043D\u0435\u0451\xBB*."
  personalLifeEn: 
  shortBioRu: "\u0420\u0435\u043D\u0435 \u0414\u0435\u043A\u0430\u0440\u0442 (1596\u20131650)
    \u2014 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u0438\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444,
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A \u0438 \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u043E\u0438\u0441\u043F\u044B\u0442\u0430\u0442\u0435\u043B\u044C,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0441\u0447\u0438\u0442\u0430\u044E\u0442 \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A\u043E\u0432
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u041D\u043E\u0432\u043E\u0433\u043E
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0438 \u043D\u0430\u0443\u0447\u043D\u043E\u0439
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438. \u0415\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E: \u043E\u0442 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E
    \u0442\u0435\u0437\u0438\u0441\u0430 \xAB\u042F \u043C\u044B\u0441\u043B\u044E,
    \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
    \u044F \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\xBB \u0434\u043E
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 \u0438 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u043E\u0432
    \u043C\u0435\u0445\u0430\u043D\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u0437\u0438\u043A\u0438.  \u041D\u0438\u0436\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0430
    \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F, \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0430\u044F
    \u0432\u0441\u0435 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435 \u044D\u0442\u0430\u043F\u044B
    \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438.  ### \u269C\uFE0F \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B (1596\u20131606) 
    \u0420\u0435\u043D\u0435 \u0414\u0435\u043A\u0430\u0440\u0442 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    31 \u043C\u0430\u0440\u0442\u0430 1596 \u0433\u043E\u0434\u0430 \u0432 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u043C
    \u0433\u043E\u0440\u043E\u0434\u043A\u0435 \u041B\u0430-\u042D-\u0430\u043D-\u0422\u0443\u0440\u0435\u043D
    (\u043D\u044B\u043D\u0435 \u2014 \u0433\u043E\u0440\u043E\u0434 \u0414\u0435\u043A\u0430\u0440\u0442)
    \u0432 \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u0424\u0440\u0430\u043D\u0446\u0438\u0438,
    \u0432 \u0441\u0442\u0430\u0440\u0438\u043D\u043D\u043E\u043C, \u043D\u043E \u043E\u0431\u0435\u0434\u043D\u0435\u0432\u0448\u0435\u043C
    \u0434\u0432\u043E\u0440\u044F\u043D\u0441\u043A\u043E\u043C \u0440\u043E\u0434\u0443.
    \u041E\u043D \u0431\u044B\u043B \u043C\u043B\u0430\u0434\u0448\u0438\u043C, \u0442\u0440\u0435\u0442\u044C\u0438\u043C
    \u0441\u044B\u043D\u043E\u043C \u0432 \u0441\u0435\u043C\u044C\u0435.  - **\u0421\u0435\u043C\u044C\u044F:**
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u0416\u043E\u0430\u043A\u0438\u043C
    \u0414\u0435\u043A\u0430\u0440\u0442, \u0431\u044B\u043B \u0441\u0443\u0434\u044C\u0435\u0439
    \u0438 \u0441\u043E\u0432\u0435\u0442\u043D\u0438\u043A\u043E\u043C \u043F\u0430\u0440\u043B\u0430\u043C\u0435\u043D\u0442\u0430
    \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u0420\u0435\u043D\u043D \u0438 \u0440\u0435\u0434\u043A\u043E
    \u0431\u044B\u0432\u0430\u043B \u0434\u043E\u043C\u0430. \u041C\u0430\u0442\u044C,
    \u0416\u0430\u043D\u043D\u0430 \u0411\u0440\u043E\u0448\u0430\u0440, \u0443\u043C\u0435\u0440\u043B\u0430,
    \u043A\u043E\u0433\u0434\u0430 \u0420\u0435\u043D\u0435 \u0431\u044B\u043B \u0432\u0441\u0435\u0433\u043E
    \u0433\u043E\u0434 \u043E\u0442 \u0440\u043E\u0434\u0443, \u0438 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u043D\u0438\u0435\u043C
    \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0430 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0430\u0441\u044C
    \u0435\u0433\u043E \u0431\u0430\u0431\u0443\u0448\u043A\u0430 \u043F\u043E \u043C\u0430\u0442\u0435\u0440\u0438\u043D\u0441\u043A\u043E\u0439
    \u043B\u0438\u043D\u0438\u0438. - **\u0414\u0435\u0442\u0441\u0442\u0432\u043E:**
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0441 \u0434\u0435\u0442\u0441\u0442\u0432\u0430
    \u043E\u0442\u043B\u0438\u0447\u0430\u043B\u0441\u044F \u0445\u0440\u0443\u043F\u043A\u0438\u043C
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435\u043C, \u043D\u043E \u043F\u0440\u0438
    \u044D\u0442\u043E\u043C \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439
    \u043B\u044E\u0431\u043E\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C\u044E.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u0432\u0438\u0434\u044F \u0442\u044F\u0433\u0443
    \u0441\u044B\u043D\u0430 \u043A \u043D\u0430\u0443\u043A\u0430\u043C, \u0432
    \u0448\u0443\u0442\u043A\u0443 \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0435\u0433\u043E
    \xAB\u0441\u0432\u043E\u0438\u043C \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u043C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u043E\u043C\xBB.  ### \U0001F393 \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u044E\u043D\u043E\u0441\u0442\u044C (1606\u20131618)  - **\u041A\u043E\u043B\u043B\u0435\u0436
    \u041B\u0430-\u0424\u043B\u0435\u0448 (1606\u20131614):** \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435
    10 \u043B\u0435\u0442 \u0414\u0435\u043A\u0430\u0440\u0442 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u044B\u0439 \u0438\u0435\u0437\u0443\u0438\u0442\u0441\u043A\u0438\u0439
    \u043A\u043E\u043B\u043B\u0435\u0436 \u041B\u0430-\u0424\u043B\u0435\u0448 (\u0410\u043D\u0436\u0443),
    \u043E\u0434\u043D\u043E \u0438\u0437 \u043B\u0443\u0447\u0448\u0438\u0445 \u0443\u0447\u0435\u0431\u043D\u044B\u0445
    \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0439 \u0415\u0432\u0440\u043E\u043F\u044B
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u0417\u0434\u0435\u0441\u044C
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435,
    \u0438\u0437\u0443\u0447\u0430\u043B \u0434\u0440\u0435\u0432\u043D\u0438\u0435
    \u044F\u0437\u044B\u043A\u0438, \u0440\u0438\u0442\u043E\u0440\u0438\u043A\u0443,
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0438 \u0444\u0438\u0437\u0438\u043A\u0443,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u044B
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F. - **\u0412\u043B\u0438\u044F\u043D\u0438\u0435:**
    \u0420\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u043E\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u043D\u0435 \u0443\u0431\u0435\u0434\u0438\u043B\u043E \u0435\u0433\u043E, \u0430
    \u0441\u043A\u043E\u0440\u0435\u0435 \u0443\u043A\u0440\u0435\u043F\u0438\u043B\u043E
    \u0441\u043A\u0435\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0435
    \u043A \u0441\u0445\u043E\u043B\u0430\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438, \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u043D\u0430 \u0430\u0432\u0442\u043E\u0440\u0438\u0442\u0435\u0442\u0435 \u0410\u0440\u0438\u0441\u0442\u043E\u0442\u0435\u043B\u044F.
    \u0412 \u043A\u043E\u043B\u043B\u0435\u0436\u0435 \u043E\u043D \u0442\u0430\u043A\u0436\u0435
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F \u0441
    \u041C\u0430\u0440\u0435\u043D\u043E\u043C \u041C\u0435\u0440\u0441\u0435\u043D\u043D\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u0441\u0442\u0430\u043D\u0435\u0442 \u0435\u0433\u043E \u0431\u043B\u0438\u0437\u043A\u0438\u043C
    \u0434\u0440\u0443\u0433\u043E\u043C \u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u043C
    \u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u0432 \u043D\u0430\u0443\u0447\u043D\u043E\u043C \u043C\u0438\u0440\u0435. -
    **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u041F\u0443\u0430\u0442\u044C\u0435
    (1614\u20131616):** \u0421\u043B\u0435\u0434\u0443\u044F \u0436\u0435\u043B\u0430\u043D\u0438\u044E
    \u043E\u0442\u0446\u0430 \u0441\u0442\u0430\u0442\u044C \u044E\u0440\u0438\u0441\u0442\u043E\u043C,
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u041F\u0443\u0430\u0442\u044C\u0435,
    \u0433\u0434\u0435 \u0432 1616 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430
    \u0438 \u043B\u0438\u0446\u0435\u043D\u0446\u0438\u0430\u0442\u0430 (\u043C\u0430\u0433\u0438\u0441\u0442\u0440\u0430)
    \u043F\u0440\u0430\u0432\u0430 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u043A\u0430\u043D\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0438 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u0430\u0432\u0430.  ### \U0001F5FA\uFE0F \xAB\u0412\u0435\u043B\u0438\u043A\u0430\u044F
    \u043A\u043D\u0438\u0433\u0430 \u043C\u0438\u0440\u0430\xBB \u0438 \u0432\u043E\u0435\u043D\u043D\u0430\u044F
    \u0441\u043B\u0443\u0436\u0431\u0430 (1618\u20131628)  \u0420\u0430\u0437\u043E\u0447\u0430\u0440\u043E\u0432\u0430\u0432\u0448\u0438\u0441\u044C
    \u0432 \u0441\u0445\u043E\u043B\u0430\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0443\u0447\u0435\u043D\u043E\u0441\u0442\u0438, \u0414\u0435\u043A\u0430\u0440\u0442
    \u0440\u0435\u0448\u0438\u043B \xAB\u0438\u0437\u0443\u0447\u0438\u0442\u044C
    \u0432\u0435\u043B\u0438\u043A\u0443\u044E \u043A\u043D\u0438\u0433\u0443 \u043C\u0438\u0440\u0430\xBB
    \u0447\u0435\u0440\u0435\u0437 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F
    \u0438 \u0432\u043E\u0435\u043D\u043D\u0443\u044E \u0441\u043B\u0443\u0436\u0431\u0443. 
    - **\u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u044F \u0438 \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E
    \u0441 \u0411\u0435\u043A\u043C\u0430\u043D\u043E\u043C (1618):** \u0412 1618
    \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u043D\u0430 \u0441\u043B\u0443\u0436\u0431\u0443 \u0432 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0435
    \u043D\u0430\u0435\u043C\u043D\u043E\u0433\u043E \u043E\u0444\u0438\u0446\u0435\u0440\u0430
    \u0432 \u0430\u0440\u043C\u0438\u044E \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u0441\u043A\u043E\u0433\u043E
    \u0448\u0442\u0430\u0442\u0433\u0430\u043B\u044C\u0442\u0435\u0440\u0430 \u041C\u043E\u0440\u0438\u0446\u0430
    \u041D\u0430\u0441\u0441\u0430\u0443\u0441\u043A\u043E\u0433\u043E \u0432 \u041D\u0438\u0434\u0435\u0440\u043B\u0430\u043D\u0434\u0430\u0445.
    \u0412 \u0433\u043E\u0440\u043E\u0434\u0435 \u0411\u0440\u0435\u0434\u0430 \u043E\u043D
    \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u043B\u0441\u044F \u0441
    \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F \u0444\u0438\u0437\u0438\u043A\u043E\u043C
    \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C \u0418\u0441\u0430\u0430\u043A\u043E\u043C
    \u0411\u0435\u043A\u043C\u0430\u043D\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043A\u0430\u0437\u0430\u043B \u043D\u0430 \u043D\u0435\u0433\u043E \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u0438 \u043F\u043E\u0434\u0442\u043E\u043B\u043A\u043D\u0443\u043B
    \u043A \u0437\u0430\u043D\u044F\u0442\u0438\u044F\u043C \u0442\u043E\u0447\u043D\u044B\u043C\u0438
    \u043D\u0430\u0443\u043A\u0430\u043C\u0438. \u0414\u043B\u044F \u0411\u0435\u043A\u043C\u0430\u043D\u0430
    \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u0441\u0432\u043E\u0439
    \u043F\u0435\u0440\u0432\u044B\u0439 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0432\u0448\u0438\u0439\u0441\u044F
    \u0442\u0440\u0443\u0434 \u2014 \xABCompendium of Music\xBB (\u0421\u0436\u0430\u0442\u043E\u0435
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u043C\u0443\u0437\u044B\u043A\u0438).
    - **\u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044F \u0438 \xAB\u043E\u0437\u0430\u0440\u0435\u043D\u0438\u0435\xBB
    (1619\u20131620):** \u0417\u0430\u0442\u0435\u043C \u0414\u0435\u043A\u0430\u0440\u0442
    \u043F\u0435\u0440\u0435\u0448\u0435\u043B \u043D\u0430 \u0441\u043B\u0443\u0436\u0431\u0443
    \u043A \u0431\u0430\u0432\u0430\u0440\u0441\u043A\u043E\u043C\u0443 \u0433\u0435\u0440\u0446\u043E\u0433\u0443
    \u041C\u0430\u043A\u0441\u0438\u043C\u0438\u043B\u0438\u0430\u043D\u0443 \u0438
    \u043F\u0440\u0438\u043D\u044F\u043B \u0443\u0447\u0430\u0441\u0442\u0438\u0435
    \u0432 \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u043C \u044D\u0442\u0430\u043F\u0435
    \u0422\u0440\u0438\u0434\u0446\u0430\u0442\u0438\u043B\u0435\u0442\u043D\u0435\u0439
    \u0432\u043E\u0439\u043D\u044B, \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435
    \u0432 \u0431\u0438\u0442\u0432\u0435 \u043F\u0440\u0438 \u0411\u0435\u043B\u043E\u0439
    \u0413\u043E\u0440\u0435 (1620). - **\u0422\u0440\u0438 \u0441\u043D\u0430:**
    \u0418\u043C\u0435\u043D\u043D\u043E \u0432 \u044D\u0442\u043E\u0442 \u043F\u0435\u0440\u0438\u043E\u0434,
    10 \u043D\u043E\u044F\u0431\u0440\u044F 1619 \u0433\u043E\u0434\u0430, \u0432\u043E
    \u0432\u0440\u0435\u043C\u044F \u0437\u0438\u043C\u043E\u0432\u043A\u0438 \u0432
    \u041D\u043E\u0439\u0431\u0443\u0440\u0433\u0435-\u043D\u0430-\u0414\u0443\u043D\u0430\u0435,
    \u0414\u0435\u043A\u0430\u0440\u0442, \u043F\u043E \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0441\u043B\u043E\u0432\u0430\u043C, \u043F\u0435\u0440\u0435\u0436\u0438\u043B
    \u0442\u0440\u0438 \xAB\u0441\u043D\u0430\xBB \u0438\u043B\u0438 \xAB\u043E\u0437\u0430\u0440\u0435\u043D\u0438\u044F\xBB,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0435\u043C\u0443 \u0431\u044B\u043B\u0430
    \u043E\u0442\u043A\u0440\u044B\u0442\u0430 \u043D\u043E\u0432\u0430\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F
    \u0438 \u043E\u0441\u043D\u043E\u0432\u044B \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0438\u0434\u0435\u044F \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043C\u0435\u0442\u043E\u0434\u0430 \u0434\u043B\u044F \u0432\u0441\u0435\u0445
    \u043D\u0430\u0443\u043A.  - **\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E \u0438 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F
    (1620\u20131628):** \u041E\u0441\u0442\u0430\u0432\u0438\u0432 \u0441\u043B\u0443\u0436\u0431\u0443
    \u0432 1621 \u0433\u043E\u0434\u0443, \u0414\u0435\u043A\u0430\u0440\u0442 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u043F\u043E \u0415\u0432\u0440\u043E\u043F\u0435 (\u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0418\u0442\u0430\u043B\u0438\u044E, \u0433\u0434\u0435 \u043F\u043E\u0441\u0435\u0442\u0438\u043B
    \u0420\u0438\u043C \u0438 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0430\u043B\u043E\u043C\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0432 \u041B\u043E\u0440\u0435\u0442\u043E), \u0430 \u0437\u0430\u0442\u0435\u043C
    \u043F\u0440\u043E\u0432\u0435\u043B \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043B\u0435\u0442 \u0432 \u041F\u0430\u0440\u0438\u0436\u0435. \u0412 \u041F\u0430\u0440\u0438\u0436\u0435
    \u043E\u043D \u0430\u043A\u0442\u0438\u0432\u043D\u043E \u0432\u0440\u0430\u0449\u0430\u043B\u0441\u044F
    \u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043A\u0440\u0443\u0433\u0430\u0445,
    \u043E\u0431\u0449\u0430\u043B\u0441\u044F \u0441 \u041C\u0435\u0440\u0441\u0435\u043D\u043D\u043E\u043C,
    \u043D\u043E \u0442\u0430\u043A\u0436\u0435 \u0432\u0435\u043B \u0441\u0432\u0435\u0442\u0441\u043A\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C. \u0412 1627 \u0433\u043E\u0434\u0443 \u043E\u043D
    \u043F\u0440\u0438\u043D\u044F\u043B \u0443\u0447\u0430\u0441\u0442\u0438\u0435
    \u0432 \u043E\u0441\u0430\u0434\u0435 \u041B\u0430-\u0420\u043E\u0448\u0435\u043B\u0438,
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0433\u043E \u043E\u043F\u043B\u043E\u0442\u0430
    \u0433\u0443\u0433\u0435\u043D\u043E\u0442\u043E\u0432.  ### \U0001F1F3\U0001F1F1
    \u0413\u043E\u0434\u044B \u0432 \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u0438:
    \u0440\u0430\u0441\u0446\u0432\u0435\u0442 \u043A\u0430\u0440\u0442\u0435\u0437\u0438\u0430\u043D\u0441\u0442\u0432\u0430
    (1628\u20131649)  \u042D\u0442\u043E \u0441\u0430\u043C\u044B\u0439 \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u044B\u0439
    \u0438 \u0432\u0430\u0436\u043D\u044B\u0439 \u043F\u0435\u0440\u0438\u043E\u0434
    \u0432 \u0436\u0438\u0437\u043D\u0438 \u0414\u0435\u043A\u0430\u0440\u0442\u0430.
    \u041E\u043F\u0430\u0441\u0430\u044F\u0441\u044C \u043E\u0431\u0432\u0438\u043D\u0435\u043D\u0438\u0439
    \u0432 \u0435\u0440\u0435\u0441\u0438 \u0438 \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    \u0441\u043E \u0441\u0442\u043E\u0440\u043E\u043D\u044B \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0446\u0435\u0440\u043A\u0432\u0438, \u043E\u043D \u0432 1628 \u0433\u043E\u0434\u0443
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u041D\u0438\u0434\u0435\u0440\u043B\u0430\u043D\u0434\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u043B\u0430\u0432\u0438\u043B\u0438\u0441\u044C
    \u0441\u0432\u043E\u0435\u0439 \u0432\u0435\u0440\u043E\u0442\u0435\u0440\u043F\u0438\u043C\u043E\u0441\u0442\u044C\u044E.
    \u0417\u0434\u0435\u0441\u044C \u043E\u043D \u043F\u0440\u043E\u0432\u0435\u043B
    20 \u043B\u0435\u0442 \u0432 \u0443\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u0438,
    \u0447\u0430\u0441\u0442\u043E \u043C\u0435\u043D\u044F\u044F \u043C\u0435\u0441\u0442\u043E
    \u0436\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430 \u0438 \u0441\u043A\u0440\u044B\u0432\u0430\u044F
    \u0441\u0432\u043E\u0439 \u0430\u0434\u0440\u0435\u0441, \u0447\u0442\u043E\u0431\u044B
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C \u0441\u0435\u0431\u044F
    \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u043D\u0430\u0443\u043A\u0435.  - **\u0413\u043B\u0430\u0432\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B:** \u0412 \u041D\u0438\u0434\u0435\u0440\u043B\u0430\u043D\u0434\u0430\u0445
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0441\u043E\u0437\u0434\u0430\u043B \u0432\u0441\u0435
    \u0441\u0432\u043E\u0438 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u044F:    
    - **\xAB\u0420\u0430\u0441\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0435 \u043E
    \u043C\u0435\u0442\u043E\u0434\u0435\xBB (1637):** \u041E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043D\u043E
    \u043D\u0430 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u043C
    \u044F\u0437\u044B\u043A\u0435 \u0441 \u0442\u0440\u0435\u043C\u044F \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F\u043C\u0438-\xAB\u044D\u0441\u0441\u0435\xBB:
    \xAB\u0414\u0438\u043E\u043F\u0442\u0440\u0438\u043A\u0430\xBB, \xAB\u041C\u0435\u0442\u0435\u043E\u0440\u044B\xBB
    \u0438 \xAB\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F\xBB. \u0412
    \u044D\u0442\u043E\u043C \u0442\u0440\u0443\u0434\u0435 \u043E\u043D \u0438\u0437\u043B\u043E\u0436\u0438\u043B
    \u0441\u0432\u043E\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F: \xABJe pense, donc je suis\xBB (\xAB\u042F
    \u043C\u044B\u0441\u043B\u044E, \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u043D\u043E,
    \u044F \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\xBB).     - **\xAB\u0420\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u044F
    \u043E \u043F\u0435\u0440\u0432\u043E\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438\xBB
    (1641, \u043D\u0430 \u043B\u0430\u0442\u044B\u043D\u0438):** \u0412 \u044D\u0442\u043E\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 \u043E\u043D \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u0435\u0442
    \u0441\u0432\u043E\u044E \u043C\u0435\u0442\u0430\u0444\u0438\u0437\u0438\u043A\u0443
    \u0438 \u0434\u0430\u0435\u0442 \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0431\u044B\u0442\u0438\u044F \u0411\u043E\u0433\u0430.     - **\xAB\u041F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u0430
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438\xBB (1644, \u043D\u0430
    \u043B\u0430\u0442\u044B\u043D\u0438):** \u0421\u0438\u0441\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u0438\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u0435 \u0435\u0433\u043E \u0444\u0438\u0437\u0438\u043A\u0438,
    \u043A\u043E\u0441\u043C\u043E\u043B\u043E\u0433\u0438\u0438 \u0438 \u043C\u0435\u0442\u0430\u0444\u0438\u0437\u0438\u043A\u0438. 
    - **\u0422\u0440\u0430\u0433\u0435\u0434\u0438\u044F \xAB\u041C\u0438\u0440\u0430\xBB
    (1633):** \u0412 1633 \u0433\u043E\u0434\u0443 \u0414\u0435\u043A\u0430\u0440\u0442
    \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 \xAB\u041C\u0438\u0440, \u0438\u043B\u0438 \u0422\u0440\u0430\u043A\u0442\u0430\u0442
    \u043E \u0441\u0432\u0435\u0442\u0435\xBB (Le Monde), \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B \u0433\u0435\u043B\u0438\u043E\u0446\u0435\u043D\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u041A\u043E\u043F\u0435\u0440\u043D\u0438\u043A\u0430.
    \u0423\u0437\u043D\u0430\u0432 \u043E\u0431 \u043E\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0438
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u0435\u0439,
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0432 \u0441\u0442\u0440\u0430\u0445\u0435
    \u043E\u0442\u043B\u043E\u0436\u0438\u043B \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044E,
    \u0442\u0430\u043A \u043A\u0430\u043A \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u0448\u043B\u0438 \u0432\u0440\u0430\u0437\u0440\u0435\u0437
    \u0441 \u0446\u0435\u0440\u043A\u043E\u0432\u043D\u044B\u043C\u0438 \u0434\u043E\u0433\u043C\u0430\u0442\u0430\u043C\u0438.
    \u041E\u043D \u043F\u0438\u0441\u0430\u043B \u041C\u0435\u0440\u0441\u0435\u043D\u043D\u0443:
    \xAB\u0415\u0441\u043B\u0438 \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435
    \u0417\u0435\u043C\u043B\u0438 \u0435\u0441\u0442\u044C \u043B\u043E\u0436\u044C,
    \u0442\u043E \u043B\u043E\u0436\u044C \u0438 \u0432\u0441\u0435 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F
    \u043C\u043E\u0435\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438\xBB.
    - **\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u0438
    \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F:** \u0412 1635 \u0433\u043E\u0434\u0443
    \u0443 \u0414\u0435\u043A\u0430\u0440\u0442\u0430 \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C
    \u0434\u043E\u0447\u044C \u0424\u0440\u0430\u043D\u0441\u0438\u043D\u0430 \u043E\u0442
    \u0441\u043B\u0443\u0436\u0430\u043D\u043A\u0438 \u0425\u0435\u043B\u0435\u043D\u044B
    \u042F\u043D\u0441 \u0432\u0430\u043D \u0434\u0435\u0440 \u0421\u0442\u0440\u043E\u043C.
    \u0425\u043E\u0442\u044F \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043A\u0440\u0435\u0449\u0435\u043D\u0430,
    \u0435\u0435 \u0447\u0430\u0441\u0442\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \xAB\u043D\u0435\u0437\u0430\u043A\u043E\u043D\u043D\u043E\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u043E\u0439\xBB.
    \u041F\u044F\u0442\u0438\u043B\u0435\u0442\u043D\u044F\u044F \u0424\u0440\u0430\u043D\u0441\u0438\u043D\u0430
    \u0443\u043C\u0435\u0440\u043B\u0430 \u043E\u0442 \u0441\u043A\u0430\u0440\u043B\u0430\u0442\u0438\u043D\u044B
    \u0432 1640 \u0433\u043E\u0434\u0443, \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E
    \u0434\u043B\u044F \u0414\u0435\u043A\u0430\u0440\u0442\u0430 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C
    \u0433\u043E\u0440\u0435\u043C \u0432 \u0436\u0438\u0437\u043D\u0438. - **\u0422\u0440\u0430\u0432\u043B\u044F
    \u0432 \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u0438:** \u041A 1640-\u043C
    \u0433\u043E\u0434\u0430\u043C \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u044C
    \u043A\u0430\u0440\u0442\u0435\u0437\u0438\u0430\u043D\u0441\u0442\u0432\u0430
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\u0445
    \u0432\u044B\u0437\u0432\u0430\u043B\u0430 \u043E\u043F\u0430\u0441\u0435\u043D\u0438\u044F
    \u043A\u0430\u043B\u044C\u0432\u0438\u043D\u0438\u0441\u0442\u0441\u043A\u0438\u0445
    \u0431\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u043E\u0432, \u0442\u0430\u043A\u0438\u0445
    \u043A\u0430\u043A \u0413\u0438\u0441\u0431\u0435\u0440\u0442 \u0412\u043E\u044D\u0446\u0438\u0439.
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430 \u043E\u0431\u0432\u0438\u043D\u044F\u043B\u0438
    \u0432 \u0430\u0442\u0435\u0438\u0437\u043C\u0435 \u0438 \u0435\u0440\u0435\u0441\u0438,
    \u043E\u043D \u0432\u0435\u043B \u043E\u0436\u0435\u0441\u0442\u043E\u0447\u0435\u043D\u043D\u0443\u044E
    \u043F\u043E\u043B\u0435\u043C\u0438\u043A\u0443 \u0441 \u043D\u0438\u043C\u0438
    \u0438 \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D \u0431\u044B\u043B \u0438\u0441\u043A\u0430\u0442\u044C
    \u0437\u0430\u0449\u0438\u0442\u044B \u0443 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0433\u043E
    \u043F\u043E\u0441\u043B\u0430 \u0438 \u043F\u0440\u0438\u043D\u0446\u0430 \u041E\u0440\u0430\u043D\u0441\u043A\u043E\u0433\u043E. 
    ### \U0001F451 \u0428\u0432\u0435\u0446\u0438\u044F \u0438 \u0441\u043C\u0435\u0440\u0442\u044C
    (1649\u20131650)  \u0412 1649 \u0433\u043E\u0434\u0443, \u0438\u0437\u043C\u0443\u0447\u0435\u043D\u043D\u044B\u0439
    \u043C\u043D\u043E\u0433\u043E\u043B\u0435\u0442\u043D\u0435\u0439 \u0442\u0440\u0430\u0432\u043B\u0435\u0439,
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043F\u0440\u0438\u043D\u044F\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435
    \u0448\u0432\u0435\u0434\u0441\u043A\u043E\u0439 \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u044B
    \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u044B, \u0441 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0434\u0430\u0432\u043D\u043E \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0441\u044F,
    \u0438 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C.
    \u0415\u0435 \u0446\u0435\u043B\u044C\u044E \u0431\u044B\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A, \u0430
    \u0441\u0430\u043C \u0414\u0435\u043A\u0430\u0440\u0442 \u0434\u043E\u043B\u0436\u0435\u043D
    \u0431\u044B\u043B \u043E\u0431\u0443\u0447\u0430\u0442\u044C \u0435\u0435 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438. 
    - **\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0434\u043D\u0438:**
    \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C\u0441\u043A\u0438\u0439
    \u043A\u043B\u0438\u043C\u0430\u0442 \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0433\u0443\u0431\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C \u0434\u043B\u044F
    \u0445\u0440\u0443\u043F\u043A\u043E\u0433\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430. \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0430
    \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u043B\u0430 \u043D\u0430 \u0437\u0430\u043D\u044F\u0442\u0438\u044F\u0445
    \u0432 5 \u0447\u0430\u0441\u043E\u0432 \u0443\u0442\u0440\u0430, \u0447\u0442\u043E
    \u043D\u0430\u0440\u0443\u0448\u0430\u043B\u043E \u043F\u0440\u0438\u0432\u044B\u0447\u043D\u044B\u0439
    \u0434\u043B\u044F \u0414\u0435\u043A\u0430\u0440\u0442\u0430 \u0440\u0435\u0436\u0438\u043C.
    \u0412 \u043D\u0430\u0447\u0430\u043B\u0435 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    1650 \u0433\u043E\u0434\u0430 \u043E\u043D \u043F\u0440\u043E\u0441\u0442\u0443\u0434\u0438\u043B\u0441\u044F
    \u043F\u043E \u0434\u043E\u0440\u043E\u0433\u0435 \u0432\u043E \u0434\u0432\u043E\u0440\u0435\u0446
    \u0438 \u0437\u0430\u0431\u043E\u043B\u0435\u043B. - **\u0421\u043C\u0435\u0440\u0442\u044C
    \u0438 \u0437\u0430\u0433\u0430\u0434\u043A\u0430:** 11 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    1650 \u0433\u043E\u0434\u0430 \u0420\u0435\u043D\u0435 \u0414\u0435\u043A\u0430\u0440\u0442
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u043D\u0430 \u0434\u0435\u0432\u044F\u0442\u044B\u0439
    \u0434\u0435\u043D\u044C \u0431\u043E\u043B\u0435\u0437\u043D\u0438. \u041E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u043F\u0440\u0438\u0447\u0438\u043D\u043E\u0439 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0437\u0432\u0430\u043D\u0430 \u043F\u043D\u0435\u0432\u043C\u043E\u043D\u0438\u044F.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0438 \u0430\u043B\u044C\u0442\u0435\u0440\u043D\u0430\u0442\u0438\u0432\u043D\u0430\u044F
    \u0432\u0435\u0440\u0441\u0438\u044F \u2014 \u043E**\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u043C
    \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0438 \u043C\u044B\u0448\u044C\u044F\u043A\u043E\u043C.**
    \u0415\u0435 \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B\u0438 \u0432 XX
    \u0432\u0435\u043A\u0435 \u043D\u0430 \u043E\u0441\u043D\u043E\u0432\u0435 \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u043D\u044B\u0445
    \u0441\u043B\u0435\u0434\u043E\u0432 \u043C\u044B\u0448\u044C\u044F\u043A\u0430
    \u0432 \u0435\u0433\u043E \u043E\u0441\u0442\u0430\u043D\u043A\u0430\u0445. \u0421\u0442\u043E\u0440\u043E\u043D\u043D\u0438\u043A\u0438
    \u044D\u0442\u043E\u0439 \u0432\u0435\u0440\u0441\u0438\u0438 \u043F\u043E\u043B\u0430\u0433\u0430\u044E\u0442,
    \u0447\u0442\u043E \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0430\u0433\u0435\u043D\u0442\u044B \u043E\u043F\u0430\u0441\u0430\u043B\u0438\u0441\u044C,
    \u0447\u0442\u043E \u0441\u0432\u043E\u0431\u043E\u0434\u043E\u043C\u044B\u0441\u043B\u0438\u0435
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430 \u043C\u043E\u0436\u0435\u0442 \u043F\u043E\u043C\u0435\u0448\u0430\u0442\u044C
    \u0438\u0445 \u043F\u043B\u0430\u043D\u0430\u043C \u043F\u043E \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u044E
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u044B \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u044B
    \u0432 \u043A\u0430\u0442\u043E\u043B\u0438\u0446\u0438\u0437\u043C (\u0447\u0442\u043E
    \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E \u0432 1654 \u0433\u043E\u0434\u0443). 
    ### \u26B0\uFE0F \u041F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u0430\u044F
    \u0441\u0443\u0434\u044C\u0431\u0430 \u0438 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 
    - **\u041F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438:** \u0423\u0436\u0435
    \u0432 1663 \u0433\u043E\u0434\u0443 \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u044F
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430 \u0431\u044B\u043B\u0438 \u0432\u043D\u0435\u0441\u0435\u043D\u044B
    \u0432 \u043A\u0430\u0442\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \xAB\u0418\u043D\u0434\u0435\u043A\u0441 \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043D\u044B\u0445
    \u043A\u043D\u0438\u0433\xBB, \u0430 \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438
    \u0443\u043A\u0430\u0437\u043E\u043C \u041B\u044E\u0434\u043E\u0432\u0438\u043A\u0430
    XIV \u0437\u0430\u043F\u0440\u0435\u0449\u0430\u043B\u043E\u0441\u044C \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435
    \u0435\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438 \u0432\u043E
    \u0432\u0441\u0435\u0445 \u0443\u0447\u0435\u0431\u043D\u044B\u0445 \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u044F\u0445.
    - **\u041E\u0441\u0442\u0430\u043D\u043A\u0438:** \u041F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0431\u044B\u043B \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u0432 \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C\u0435. \u0412 1666
    \u0433\u043E\u0434\u0443 \u0435\u0433\u043E \u043E\u0441\u0442\u0430\u043D\u043A\u0438
    \u0431\u044B\u043B\u0438 \u043F\u0435\u0440\u0435\u0432\u0435\u0437\u0435\u043D\u044B
    \u0432 \u041F\u0430\u0440\u0438\u0436 \u0438 \u0437\u0430\u0445\u043E\u0440\u043E\u043D\u0435\u043D\u044B
    \u0432 \u0430\u0431\u0431\u0430\u0442\u0441\u0442\u0432\u0435 \u0421\u0435\u043D-\u0416\u0435\u0440\u043C\u0435\u043D-\u0434\u0435-\u041F\u0440\u0435,
    \u0433\u0434\u0435 \u043F\u043E\u043A\u043E\u044F\u0442\u0441\u044F \u0438 \u043F\u043E
    \u0441\u0435\u0439 \u0434\u0435\u043D\u044C, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043F\u043B\u0430\u043D\u044B \u041D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u043A\u043E\u043D\u0432\u0435\u043D\u0442\u0430 \u0432 1792 \u0433\u043E\u0434\u0443
    \u043F\u0435\u0440\u0435\u043D\u0435\u0441\u0442\u0438 \u0438\u0445 \u0432 \u041F\u0430\u043D\u0442\u0435\u043E\u043D. 
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0433\u043E\u043D\u0435\u043D\u0438\u044F,
    \u0438\u0434\u0435\u0438 \u0414\u0435\u043A\u0430\u0440\u0442\u0430 (\u043A\u0430\u0440\u0442\u0435\u0437\u0438\u0430\u043D\u0441\u0442\u0432\u043E)
    \u043E\u043A\u0430\u0437\u0430\u043B\u0438 \u0433\u043B\u0443\u0431\u043E\u0447\u0430\u0439\u0448\u0435\u0435
    \u0432\u043B\u0438\u044F\u043D\u0438\u0435 \u043D\u0430 \u0432\u0441\u044E \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0443\u044E
    \u0437\u0430\u043F\u0430\u0434\u043D\u0443\u044E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E
    \u0438 \u043D\u0430\u0443\u043A\u0443. \u0415\u0433\u043E \u0434\u0443\u0430\u043B\u0438\u0437\u043C
    \u0434\u0443\u0448\u0438 \u0438 \u0442\u0435\u043B\u0430, \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043C\u0435\u0442\u043E\u0434 \u0438 \u0432\u043A\u043B\u0430\u0434 \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0441\u0442\u0430\u043B\u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u043C\u044B\u0441\u043B\u0438\u0442\u0435\u043B\u0435\u0439
    \u043E\u0442 \u0421\u043F\u0438\u043D\u043E\u0437\u044B \u0438 \u041B\u0435\u0439\u0431\u043D\u0438\u0446\u0430
    \u0434\u043E \u041A\u0430\u043D\u0442\u0430 \u0438 \u0413\u0443\u0441\u0441\u0435\u0440\u043B\u044F."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0420\u0435\u043D\u0435 \u0414\u0435\u043A\u0430\u0440\u0442\u0430
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0441\u0443\u0445\u0430\u044F
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F. \u0417\u0430 \u043E\u0431\u0440\u0430\u0437\u043E\u043C
    \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0438\u0441\u0442\u0430
    \u0441\u043A\u0440\u044B\u0432\u0430\u043B\u0441\u044F \u0447\u0443\u0434\u0430\u043A\u043E\u0432\u0430\u0442\u044B\u0439
    \u0438\u043F\u043E\u0445\u043E\u043D\u0434\u0440\u0438\u043A, \u0431\u0435\u0441\u0441\u0442\u0440\u0430\u0448\u043D\u044B\u0439
    \u0434\u0443\u044D\u043B\u044F\u043D\u0442 \u0432 \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438
    \u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u043E\u044F\u043B\u0441\u044F \u043B\u0435\u0442\u0430\u0442\u044C \u043D\u0430
    \u043A\u043E\u0440\u0430\u0431\u043B\u044F\u0445.   \u041D\u0438\u0436\u0435
    \u2014 \u043A\u043E\u043B\u043B\u0435\u043A\u0446\u0438\u044F \u0441\u0430\u043C\u044B\u0445
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0445, \u043A\u0443\u0440\u044C\u0435\u0437\u043D\u044B\u0445
    \u0438 \u043C\u0430\u043B\u043E\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432 \u0438\u0437 \u0436\u0438\u0437\u043D\u0438
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430, \u0440\u0430\u0437\u0434\u0435\u043B\u0435\u043D\u043D\u0430\u044F
    \u043F\u043E \u0442\u0435\u043C\u0430\u043C.  ---  ### 1. \u042D\u043F\u0438\u0441\u0442\u043E\u043B\u044F\u0440\u043D\u044B\u0439
    \u043C\u0430\u043D\u044C\u044F\u043A: \u041F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0430
    \u043A\u0430\u043A \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u0434\u0435\u043B\u043E
    \u0436\u0438\u0437\u043D\u0438  \u0414\u0435\u043A\u0430\u0440\u0442, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0437\u0430\u0442\u0432\u043E\u0440\u043D\u0438\u043A\u043E\u043C, \u0432\u0435\u043B
    \u043E\u0434\u043D\u0443 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043E\u0431\u0448\u0438\u0440\u043D\u044B\u0445
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043E\u043A \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430\u0443\u043A\u0438 (\u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C
    \u043E\u043A\u043E\u043B\u043E 500 \u0435\u0433\u043E \u043F\u0438\u0441\u0435\u043C).
    \u041D\u043E \u0437\u0434\u0435\u0441\u044C \u0435\u0441\u0442\u044C \u043D\u044E\u0430\u043D\u0441\u044B: 
    - **\u0421\u0442\u0440\u0430\u0445 \u043F\u0435\u0440\u0435\u0434 \u0431\u0443\u043C\u0430\u0433\u043E\u0439:**
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043F\u0430\u043D\u0438\u0447\u0435\u0441\u043A\u0438
    \u0431\u043E\u044F\u043B\u0441\u044F, \u0447\u0442\u043E \u0435\u0433\u043E \u043F\u0438\u0441\u044C\u043C\u0430
    \u043F\u043E\u043F\u0430\u0434\u0443\u0442 \u0432 \u0440\u0443\u043A\u0438 \u0432\u0440\u0430\u0433\u043E\u0432-\u0438\u0435\u0437\u0443\u0438\u0442\u043E\u0432.
    \u041F\u043E\u044D\u0442\u043E\u043C\u0443 \u043E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439 \u0448\u0438\u0444\u0440
    \u0438 \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u043A\u043E\u0434\u043E\u0432\u044B\u0445
    \u0438\u043C\u0435\u043D \u0434\u043B\u044F \u0441\u0432\u043E\u0438\u0445 \u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u0432.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0432 \u043F\u0438\u0441\u044C\u043C\u0430\u0445
    \u043A \u041C\u0435\u0440\u0441\u0435\u043D\u043D\u0443 \u043E\u043D \u043D\u0430\u0437\u044B\u0432\u0430\u043B
    \u0413\u0430\u043B\u0438\u043B\u0435\u044F \u043F\u0440\u043E\u0441\u0442\u043E
    \xAB\u0421\u0438\u043D\u044C\u043E\u0440\u043E\u043C\xBB, \u0430 \u0441\u0432\u043E\u0438
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0438 \u2014 \xAB\u043C\u043E\u0438\u043C\u0438
    \u0434\u0435\u0442\u044C\u043C\u0438\xBB. \u041E\u043D \u0447\u0430\u0441\u0442\u043E
    \u043F\u0438\u0441\u0430\u043B \u043D\u0430 \u043F\u043E\u043B\u044F\u0445 \u0444\u0440\u0430\u0437\u0443
    *\xAB\u041F\u0440\u043E\u0447\u0438\u0442\u0430\u0439 \u0438 \u0441\u043E\u0436\u0433\u0438\xBB*.
    - **\xAB\u0421\u043F\u043B\u0435\u0442\u043D\u0438\u043A\xBB:** \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u0441\u0443\u0445\u0438\u0445 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u043E\u0432, \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u044B\u0435
    \u043F\u0438\u0441\u044C\u043C\u0430 \u043F\u043E\u043B\u043D\u044B \u0441\u0430\u0440\u043A\u0430\u0437\u043C\u0430.
    \u041E\u043D \u043C\u043E\u0433 \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C
    \u041C\u0435\u0440\u0441\u0435\u043D\u043D\u0443: \xAB\u041D\u0430\u0434\u043E\u0435\u043B
    \u043C\u043D\u0435 \u044D\u0442\u043E\u0442 \u0412\u043E\u044D\u0446\u0438\u0439
    (\u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0432\u0440\u0430\u0433-\u0442\u0435\u043E\u043B\u043E\u0433).
    \u0415\u0441\u043B\u0438 \u0431\u044B \u044F \u0431\u044B\u043B \u043B\u044F\u0433\u0443\u0448\u043A\u043E\u0439,
    \u044F \u0431\u044B \u043F\u0435\u0440\u0435\u043F\u0440\u044B\u0433\u043D\u0443\u043B
    \u0447\u0435\u0440\u0435\u0437 \u0435\u0433\u043E \u0433\u043B\u0443\u043F\u0443\u044E
    \u0433\u043E\u043B\u043E\u0432\u0443\xBB.  ---  ### 2. \u0414\u0443\u044D\u043B\u044F\u043D\u0442
    \u0438 \u0432\u043E\u043B\u044C\u043D\u043E\u0434\u0443\u043C\u0435\u0446 \u0432
    \u044E\u043D\u043E\u0441\u0442\u0438  \u041C\u0430\u043B\u043E \u043A\u0442\u043E
    \u0437\u043D\u0430\u0435\u0442, \u0447\u0442\u043E \u0431\u0443\u0434\u0443\u0449\u0438\u0439
    \u0430\u0432\u0442\u043E\u0440 \xAB\u0420\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439
    \u043E \u043F\u0435\u0440\u0432\u043E\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438\xBB
    \u0432 \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438 \u0431\u044B\u043B
    \u043E\u0442\u0447\u0430\u044F\u043D\u043D\u044B\u043C \u0437\u0430\u0431\u0438\u044F\u043A\u043E\u0439. 
    - **\u041E\u0441\u043A\u043E\u0440\u0431\u043B\u0435\u043D\u0438\u0435 \u0447\u0435\u0441\u0442\u0438:**
    \u0412 1620-\u0445 \u0433\u043E\u0434\u0430\u0445, \u0436\u0438\u0432\u044F \u0432
    \u041F\u0430\u0440\u0438\u0436\u0435, \u0414\u0435\u043A\u0430\u0440\u0442 \u043F\u043E\u0441\u0441\u043E\u0440\u0438\u043B\u0441\u044F
    \u0441 \u043D\u0435\u043A\u0438\u043C \u0448\u0435\u0432\u0430\u043B\u044C\u0435
    \u0434\u0435 \u0411\u0430\u0440\u0440\u043E\u043C \u0438\u0437-\u0437\u0430 \u043A\u0430\u0440\u0442\u043E\u0447\u043D\u043E\u0433\u043E
    \u0434\u043E\u043B\u0433\u0430 \u0438\u043B\u0438 (\u043F\u043E \u0434\u0440\u0443\u0433\u043E\u0439
    \u0432\u0435\u0440\u0441\u0438\u0438) \u0438\u0437-\u0437\u0430 \u043D\u0430\u0441\u043C\u0435\u0448\u0435\u043A
    \u043D\u0430\u0434 \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u043C\u0438
    \u0437\u0430\u043D\u044F\u0442\u0438\u044F\u043C\u0438. \u041F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A
    \u0431\u044B\u043B \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0433\u043E \u0440\u043E\u0441\u0442\u0430
    \u0438 \u0433\u0440\u043E\u0437\u0438\u043B \u043F\u043E\u0431\u0438\u0442\u044C
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430. - **\u0424\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F
    \u043A\u043B\u0438\u043D\u043A\u0430:** \u0414\u0435\u043A\u0430\u0440\u0442,
    \u043D\u0435 \u043E\u0442\u043B\u0438\u0447\u0430\u0432\u0448\u0438\u0439\u0441\u044F
    \u0431\u043E\u0433\u0430\u0442\u044B\u0440\u0441\u043A\u0438\u043C \u0442\u0435\u043B\u043E\u0441\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C,
    \u0441\u043A\u0430\u0437\u0430\u043B \u0434\u0435 \u0411\u0430\u0440\u0440\u0443:
    *\xAB\u042F \u043D\u0435 \u0441\u0442\u0430\u043D\u0443 \u0434\u0440\u0430\u0442\u044C\u0441\u044F
    \u0441 \u0432\u0430\u043C\u0438 \u0442\u0430\u043C, \u0433\u0434\u0435 \u0432\u0430\u043C
    \u0443\u0434\u043E\u0431\u043D\u043E. \u0418\u0434\u0435\u043C\u0442\u0435 \u043D\u0430
    \u0442\u043E\u0442 \u043F\u0443\u0441\u0442\u044B\u0440\u044C, \u0433\u0434\u0435
    \u044F \u0441\u043C\u043E\u0433\u0443 \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u0432\u044B\u043F\u0430\u0434 \u0438 \u0437\u0430\u043A\u043E\u043B\u043E\u0442\u044C
    \u0432\u0430\u0441, \u0430 \u0432\u044B \u043D\u0435 \u0441\u043C\u043E\u0436\u0435\u0442\u0435
    \u043C\u0435\u043D\u044F \u0434\u043E\u0441\u0442\u0430\u0442\u044C \u0441\u0432\u043E\u0435\u0439
    \u0434\u043B\u0438\u043D\u043D\u043E\u0439 \u0448\u043F\u0430\u0433\u043E\u0439\xBB*.
    \u041F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A \u0441\u0442\u0440\u0443\u0441\u0438\u043B
    \u0438 \u0438\u0437\u0432\u0438\u043D\u0438\u043B\u0441\u044F. \u042D\u0442\u0430
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u043E\u0431\u043B\u0435\u0442\u0435\u043B\u0430
    \u0432\u0435\u0441\u044C \u041F\u0430\u0440\u0438\u0436, \u0443\u043A\u0440\u0435\u043F\u0438\u0432
    \u0440\u0435\u043F\u0443\u0442\u0430\u0446\u0438\u044E \u0414\u0435\u043A\u0430\u0440\u0442\u0430
    \u043A\u0430\u043A \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u0440\u043E\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u0435\u0442 \u0434\u0430\u0436\u0435
    \u0434\u0443\u044D\u043B\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438. 
    ---  ### 3. \u0424\u043E\u0431\u0438\u044F \u043C\u043E\u0440\u0435\u043F\u043B\u0430\u0432\u0430\u0442\u0435\u043B\u044F 
    \u0423\u0447\u0438\u0442\u044B\u0432\u0430\u044F, \u0447\u0442\u043E \u0414\u0435\u043A\u0430\u0440\u0442
    \u0431\u044B\u043B \u043C\u0435\u0445\u0430\u043D\u0438\u0446\u0438\u0441\u0442\u043E\u043C
    \u0438 \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u043B \u0432\u0441\u0435 \u0444\u0438\u0437\u0438\u043A\u043E\u0439,
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u0430\u044F \u0444\u043E\u0431\u0438\u044F
    \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442 \u043F\u0430\u0440\u0430\u0434\u043E\u043A\u0441\u0430\u043B\u044C\u043D\u043E. 
    - **\u041D\u0438\u043A\u0430\u043A\u0438\u0445 \u043A\u043E\u0440\u0430\u0431\u043B\u0435\u0439:**
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043D\u0430 \u0434\u0443\u0445 \u043D\u0435
    \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u043B \u043C\u043E\u0440\u0441\u043A\u0438\u0435
    \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u044F. \u041F\u0435\u0440\u0435\u043F\u0440\u0430\u0432\u043B\u044F\u044F\u0441\u044C
    \u0438\u0437 \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u0438 \u0432\u043E
    \u0424\u0440\u0430\u043D\u0446\u0438\u044E, \u043E\u043D \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u043B
    \u0434\u0435\u043B\u0430\u0442\u044C \u043A\u0440\u044E\u043A \u0438 \u0435\u0445\u0430\u0442\u044C
    \u0441\u0443\u0445\u0438\u043C \u043F\u0443\u0442\u0435\u043C \u0447\u0435\u0440\u0435\u0437
    \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044E, \u0445\u043E\u0442\u044F \u044D\u0442\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u043E \u0432 \u0442\u0440\u0438 \u0440\u0430\u0437\u0430
    \u0431\u043E\u043B\u044C\u0448\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u0438.
    - **\u041F\u0440\u0438\u0447\u0438\u043D\u0430 \u0441\u0442\u0440\u0430\u0445\u0430:**
    \u041E\u043D \u0431\u043E\u044F\u043B\u0441\u044F \u043D\u0435 \u0448\u0442\u043E\u0440\u043C\u0430,
    \u0430 **\u043C\u043E\u0440\u0441\u043A\u043E\u0439 \u0431\u043E\u043B\u0435\u0437\u043D\u0438**.
    \u0412 \u043F\u0438\u0441\u044C\u043C\u0435 \u0434\u0440\u0443\u0433\u0443 \u043E\u043D
    \u043F\u0438\u0441\u0430\u043B, \u0447\u0442\u043E \u043C\u043E\u0440\u0441\u043A\u0430\u044F
    \u043A\u0430\u0447\u043A\u0430 \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442
    \u0435\u0433\u043E \u0442\u0435\u043B\u043E \u0441\u043E\u0434\u0440\u043E\u0433\u0430\u0442\u044C\u0441\u044F
    \u0442\u0430\u043A, \u0447\u0442\u043E \xAB\u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0435
    \u0434\u0443\u0445\u0438\xBB (\u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u044F
    \u043D\u0435\u0440\u0432\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B)
    \u043F\u0440\u0438\u0445\u043E\u0434\u044F\u0442 \u0432 \u0445\u0430\u043E\u0441,
    \u0438 \u043E\u043D \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u0441\u0432\u044F\u0437\u043D\u043E
    \u043C\u044B\u0441\u043B\u0438\u0442\u044C. \u0414\u043B\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u0447\u044C\u044F \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F \u0441\u0442\u0440\u043E\u0438\u043B\u0430\u0441\u044C
    \u043D\u0430 \xAB\u044F\u0441\u043D\u043E\u043C \u0438 \u043E\u0442\u0447\u0435\u0442\u043B\u0438\u0432\u043E\u043C
    \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0438\xBB, \u044D\u0442\u043E \u0431\u044B\u043B\u043E
    \u0440\u0430\u0432\u043D\u043E\u0441\u0438\u043B\u044C\u043D\u043E \u0431\u0435\u0437\u0443\u043C\u0438\u044E. 
    ---  ### 4. \u0413\u0430\u0441\u0442\u0440\u043E\u043D\u043E\u043C\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u044D\u043A\u0441\u0446\u0435\u043D\u0442\u0440\u0438\u043A\u0430  \u0414\u0435\u043A\u0430\u0440\u0442
    \u0431\u044B\u043B \u0433\u0443\u0440\u043C\u0430\u043D\u043E\u043C, \u043D\u043E
    \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u0432\u0435\u0440\u0438\u043B, \u0447\u0442\u043E
    \u0435\u0434\u0430 \u0432\u043B\u0438\u044F\u0435\u0442 \u043D\u0430 \u0438\u043D\u0442\u0435\u043B\u043B\u0435\u043A\u0442.
    \u041E\u043D \u0441\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0434\u043B\u044F
    \u0441\u0435\u0431\u044F \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u0434\u0438\u0435\u0442\u0443,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0438\u043D\u043E\u0433\u0434\u0430
    \u043D\u0430\u0440\u0443\u0448\u0430\u043B \u0441\u0430\u043C\u044B\u043C \u0430\u0431\u0441\u0443\u0440\u0434\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C.  - **\u0421\u043B\u0430\u0434\u043A\u043E\u0435
    \u0434\u043B\u044F \u0443\u043C\u0430:** \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B,
    \u0447\u0442\u043E \u0443\u043F\u043E\u0442\u0440\u0435\u0431\u043B\u0435\u043D\u0438\u0435
    \u0432\u0430\u0440\u0435\u043D\u044B\u0445 \u044F\u0438\u0446, \u0432\u0435\u0442\u0447\u0438\u043D\u044B
    \u0438 \u0431\u043E\u043B\u044C\u0448\u043E\u0433\u043E \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430
    \u0441\u043B\u0430\u0434\u043A\u043E\u0433\u043E \u0432\u0438\u043D\u0430 (\u043C\u0443\u0441\u043A\u0430\u0442\u0430)
    \u0443\u043B\u0443\u0447\u0448\u0430\u0435\u0442 \u043A\u0440\u043E\u0432\u043E\u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u0435
    \u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u0443\u0435\u0442
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044E \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u0434\u0435\u0439. \u0412 \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u0435
    \xAB\u041E \u0441\u0442\u0440\u0430\u0441\u0442\u044F\u0445\xBB \u043E\u043D
    \u0434\u0430\u0436\u0435 \u043D\u0430\u043C\u0435\u043A\u0430\u0435\u0442, \u0447\u0442\u043E
    \u043C\u043E\u0437\u0433 \u043B\u0443\u0447\u0448\u0435 \u0432\u0441\u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442 \u043F\u043E\u0441\u043B\u0435
    \u0441\u044B\u0442\u043D\u043E\u0433\u043E \u043E\u0431\u0435\u0434\u0430. -
    **\u041A\u0443\u0440\u0438\u0446\u0430 \u0432 \u043C\u043E\u043B\u043E\u043A\u0435:**
    \u0415\u0433\u043E \u043B\u044E\u0431\u0438\u043C\u044B\u043C \u0431\u043B\u044E\u0434\u043E\u043C
    \u0431\u044B\u043B \u0431\u0443\u043B\u044C\u043E\u043D \u0438\u0437 \u0441\u0442\u0430\u0440\u043E\u0439
    \u043A\u0443\u0440\u0438\u0446\u044B, \u0441\u0432\u0430\u0440\u0435\u043D\u043D\u043E\u0439
    \u0432 \u043C\u043E\u043B\u043E\u043A\u0435 \u0441 \u043F\u0440\u044F\u043D\u043E\u0441\u0442\u044F\u043C\u0438.
    \u041E\u043D \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u044D\u0442\u043E
    \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E \xAB\u0443\u0432\u043B\u0430\u0436\u043D\u044F\u0435\u0442\xBB
    \u043C\u043E\u0437\u0433, \u043F\u043E\u043C\u043E\u0433\u0430\u044F \u043F\u0440\u0438
    \u0435\u0433\u043E \u0445\u0440\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0441\u0443\u0445\u043E\u043C \u043A\u0430\u0448\u043B\u0435.  - **\u041E\u0442\u043A\u0430\u0437
    \u043E\u0442 \u043C\u044F\u0441\u0430 \u0432 \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0438:**
    \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0436\u0438\u0437\u043D\u0438 \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0446\u0435\u043C,
    \u043F\u0438\u0442\u0430\u044F\u0441\u044C \u043B\u0438\u0448\u044C \u0440\u044B\u0431\u043E\u0439,
    \u043E\u0432\u043E\u0449\u0430\u043C\u0438 \u0438 \u0445\u043B\u0435\u0431\u043E\u043C,
    \u0442\u0430\u043A \u043A\u0430\u043A \u043C\u044F\u0441\u043E, \u043F\u043E
    \u0435\u0433\u043E \u043C\u043D\u0435\u043D\u0438\u044E, \xAB\u0434\u0435\u043B\u0430\u043B\u043E
    \u043A\u0440\u043E\u0432\u044C \u0433\u0443\u0441\u0442\u043E\u0439 \u0438 \u043C\u0435\u0448\u0430\u043B\u043E
    \u0434\u0443\u043C\u0430\u0442\u044C \u043E \u0411\u043E\u0433\u0435\xBB.  --- 
    ### 5. \u041A\u043E\u043D\u0444\u043B\u0438\u043A\u0442 \u0441 \u044D\u043C\u0431\u0440\u0438\u043E\u043B\u043E\u0433\u0438\u0435\u0439:
    \u0421\u043F\u043E\u0440 \u043E \u0449\u0435\u043D\u043A\u0430\u0445  \u0412
    XVII \u0432\u0435\u043A\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430
    \u0442\u0435\u043E\u0440\u0438\u044F \u043F\u0440\u0435\u0444\u043E\u0440\u043C\u0438\u0437\u043C\u0430
    \u2014 \u0441\u0447\u0438\u0442\u0430\u043B\u043E\u0441\u044C, \u0447\u0442\u043E
    \u0432\u0441\u0435 \u0436\u0438\u0432\u044B\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0430
    \u0443\u0436\u0435 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u044B
    \u0432 \u043C\u0438\u043D\u0438\u0430\u0442\u044E\u0440\u0435 \u0432 \u0441\u043F\u0435\u0440\u043C\u0435
    \u0438\u043B\u0438 \u044F\u0439\u0446\u0435\u043A\u043B\u0435\u0442\u043A\u0435. 
    - **\u0412\u0441\u043A\u0440\u044B\u0442\u0438\u0435 \u0414\u0435\u043A\u0430\u0440\u0442\u0430:**
    \u0427\u0442\u043E\u0431\u044B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
    \u0447\u0442\u043E \u0436\u0438\u0437\u043D\u044C \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u0435\u0442
    \u043F\u043E\u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E (\u044D\u043F\u0438\u0433\u0435\u043D\u0435\u0437),
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0432 \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0438
    \u0432\u0440\u0430\u0447\u0435\u0439 \u0441\u0434\u0435\u043B\u0430\u043B \u0432\u0441\u043A\u0440\u044B\u0442\u0438\u0435
    \u0431\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0441\u043E\u0431\u0430\u043A\u0438.
    \u041E\u043D \u043F\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0432
    \u0443\u0442\u0440\u043E\u0431\u0435 \u044D\u043C\u0431\u0440\u0438\u043E\u043D
    \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442 \u043D\u0435 \u043A\u0430\u043A
    \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0430\u044F \u0441\u043E\u0431\u0430\u043A\u0430,
    \u0430 \u043A\u0430\u043A \u0431\u0435\u0441\u0444\u043E\u0440\u043C\u0435\u043D\u043D\u044B\u0439
    \u0441\u0433\u0443\u0441\u0442\u043E\u043A. - **\u0428\u043E\u043A\u0438\u0440\u0443\u044E\u0449\u0438\u0439
    \u0432\u044B\u0432\u043E\u0434:** \u041F\u043E\u0441\u043B\u0435 \u043E\u043F\u044B\u0442\u0430
    \u043E\u043D \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0430\u0442\u0438\u0432\u043D\u043E
    \u0432\u044B\u043C\u044B\u043B \u0440\u0443\u043A\u0438 \u0438 \u0437\u0430\u044F\u0432\u0438\u043B,
    \u0447\u0442\u043E \u0432\u0441\u0435 \u044D\u0442\u0438 \"\u0447\u0443\u0434\u0435\u0441\u0430\"
    \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u2014 \u043F\u0440\u043E\u0441\u0442\u043E\u0435
    \u043D\u0430\u0433\u0440\u0435\u0432\u0430\u043D\u0438\u0435 \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u0435\u0439.
    \u0421\u043B\u0443\u0445\u0438 \u043E \u0442\u043E\u043C, \u0447\u0442\u043E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444 \u0432\u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442
    \u0436\u0438\u0432\u044B\u0445 (\u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E
    \u0443\u043C\u0435\u0440\u0448\u0438\u0445) \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445
    \u0440\u0430\u0434\u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0441\u0432\u043E\u0435\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438,
    \u0432\u044B\u0437\u0432\u0430\u043B\u0438 \u0441\u043A\u0430\u043D\u0434\u0430\u043B,
    \u0438 \u0414\u0435\u043A\u0430\u0440\u0442\u0443 \u043F\u0440\u0438\u0448\u043B\u043E\u0441\u044C
    \u0441\u043A\u0440\u044B\u0432\u0430\u0442\u044C\u0441\u044F \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043D\u0435\u0434\u0435\u043B\u044C.  ---  ### 6. \u0410\u0442\u0435\u0438\u0441\u0442
    \u0438\u043B\u0438 \u0445\u0438\u0442\u0440\u044B\u0439 \u043A\u0430\u0442\u043E\u043B\u0438\u043A?
    \u041F\u043E\u043B\u0435\u043C\u0438\u043A\u0430 \u0441 \u041F\u0430\u0441\u043A\u0430\u043B\u0435\u043C 
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0438 \u0411\u043B\u0435\u0437 \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u043B\u0438\u0441\u044C \u0432 1647
    \u0433\u043E\u0434\u0443. \u042D\u0442\u043E \u0431\u044B\u043B\u0430 \u0431\u0438\u0442\u0432\u0430
    \u0434\u0432\u0443\u0445 \u0433\u0435\u043D\u0438\u0435\u0432.  - **\u042F\u0431\u043B\u043E\u043A\u043E
    \u0440\u0430\u0437\u0434\u043E\u0440\u0430:** \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0439
    \u043E\u043F\u044B\u0442 (\xAB\u043E\u0433\u043E\u043D\u044C\xBB \u0432\u0435\u0440\u044B)
    \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u0442\u044C \u0432\u044B\u0448\u0435
    \u0440\u0430\u0437\u0443\u043C\u0430. \u0414\u0435\u043A\u0430\u0440\u0442 \u0445\u043E\u043B\u043E\u0434\u043D\u043E
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B: *\xAB\u0413\u043E\u0441\u043F\u043E\u0434\u0438\u043D
    \u041F\u0430\u0441\u043A\u0430\u043B\u044C, \u044F \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0433\u043E\u0432\u043E\u0440\u044E \u043E \u0442\u043E\u043C,
    \u0447\u0435\u0433\u043E \u043D\u0435 \u043C\u043E\u0433\u0443 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\xBB*.
    - **\u0424\u0430\u043A\u0442 \u043E \"\u0444\u0438\u043A\u0442\u0438\u0432\u043D\u043E\u043C
    \u0411\u043E\u0433\u0435\":** \u041F\u0430\u0441\u043A\u0430\u043B\u044C \u0432\u043E\u0437\u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430 \u043F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E,
    \u043A\u0430\u043A \u043F\u0440\u043E\u0447\u0438\u0442\u0430\u043B \u0435\u0433\u043E
    \u0442\u0440\u0430\u043A\u0442\u0430\u0442\u044B. \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u043E\u0431\u0432\u0438\u043D\u0438\u043B \u0414\u0435\u043A\u0430\u0440\u0442\u0430
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E \u0442\u043E\u0442 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442
    \u0411\u043E\u0433\u0430 \u043B\u0438\u0448\u044C \u043A\u0430\u043A *\xAB\u0443\u0441\u043B\u043E\u0432\u043D\u0443\u044E
    \u0437\u0430\u0433\u043B\u0443\u0448\u043A\u0443\xBB* (\u0447\u0442\u043E\u0431\u044B
    \u043E\u0431\u044A\u044F\u0441\u043D\u0438\u0442\u044C \u043D\u0430\u0447\u0430\u043B\u043E
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F \u0412\u0441\u0435\u043B\u0435\u043D\u043D\u043E\u0439,
    \u0430 \u043F\u043E\u0442\u043E\u043C \u0437\u0430\u0431\u044B\u0432\u0430\u0435\u0442
    \u043E \u041D\u0435\u043C). \u0414\u0435\u043A\u0430\u0440\u0442 \u0432 \u043E\u0442\u0432\u0435\u0442
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B, \u0447\u0442\u043E \u041F\u0430\u0441\u043A\u0430\u043B\u044C
    \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u044D\u043C\u043E\u0446\u0438\u043E\u043D\u0430\u043B\u0435\u043D
    \u0438 \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0442 \u0441\u0432\u043E\u0438
    \u043D\u0435\u0440\u0432\u043D\u044B\u0435 \u0441\u0440\u044B\u0432\u044B \u0437\u0430
    \u043E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u0438\u044F \u0441\u0432\u044B\u0448\u0435.
    \u042D\u0442\u043E \u0431\u044B\u043B \u0445\u043E\u043B\u043E\u0434\u043D\u044B\u0439
    \u0438 \u0432\u0435\u0436\u043B\u0438\u0432\u044B\u0439 \u0440\u0430\u0437\u0440\u044B\u0432,
    \u043F\u043E\u0441\u043B\u0435 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u043E\u043D\u0438 \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u043B\u0438\u0441\u044C. 
    ---  ### 7. \u0414\u0435\u043A\u0430\u0440\u0442 \u0438 \u0435\u0433\u043E \xAB\u0410\u0434\u0430\u043C\xBB
    \u2014 \u043E\u0448\u0438\u0431\u043A\u0430 \u0430\u043D\u0430\u0442\u043E\u043C\u0438\u0438 
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043E\u0447\u0435\u043D\u044C \u0433\u043E\u0440\u0434\u0438\u043B\u0441\u044F
    \u0441\u0432\u043E\u0438\u043C \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435\u043C
    \u0448\u0438\u0448\u043A\u043E\u0432\u0438\u0434\u043D\u043E\u0439 \u0436\u0435\u043B\u0435\u0437\u044B
    (\u044D\u043F\u0438\u0444\u0438\u0437\u0430) \u043A\u0430\u043A \u043C\u0435\u0441\u0442\u0430
    \u043E\u0431\u0438\u0442\u0430\u043D\u0438\u044F \u0434\u0443\u0448\u0438. \u041E\u043D
    \u0434\u0430\u0436\u0435 \u0432\u0441\u043A\u0440\u044B\u043B \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0431\u0430\u0440\u0430\u043D\u044C\u0438\u0445 \u0433\u043E\u043B\u043E\u0432,
    \u0447\u0442\u043E\u0431\u044B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u044D\u0442\u043E.  - **\u0424\u0430\u043A\u0442 \u043E\u0448\u0438\u0431\u043A\u0438:**
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B,
    \u0447\u0442\u043E \u044D\u043F\u0438\u0444\u0438\u0437 \u043F\u0430\u0440\u0438\u0442
    \u0432 \u0446\u0435\u043D\u0442\u0440\u0435 \u0436\u0435\u043B\u0443\u0434\u043E\u0447\u043A\u043E\u0432
    \u043C\u043E\u0437\u0433\u0430, \u043A\u0430\u043A \xAB\u0441\u043E\u043B\u043D\u0446\u0435
    \u0432 \u0446\u0435\u043D\u0442\u0440\u0435 \u043C\u0438\u0440\u0430\xBB. \u041E\u0434\u043D\u0430\u043A\u043E
    \u043E\u043D \u043D\u0435 \u0437\u043D\u0430\u043B, \u0447\u0442\u043E \u0443
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u044D\u0442\u0430 \u0436\u0435\u043B\u0435\u0437\u0430
    **\u043F\u0440\u043E\u0447\u043D\u043E \u043F\u0440\u0438\u043A\u0440\u0435\u043F\u043B\u0435\u043D\u0430**
    \u043A \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044E \u043C\u043E\u0437\u0433\u0430.
    \u041A\u043E\u0433\u0434\u0430 \u0430\u043D\u0430\u0442\u043E\u043C\u044B \u0443\u043A\u0430\u0437\u0430\u043B\u0438
    \u0435\u043C\u0443 \u043D\u0430 \u044D\u0442\u043E, \u0414\u0435\u043A\u0430\u0440\u0442
    \u043E\u0442\u043C\u0430\u0445\u043D\u0443\u043B\u0441\u044F, \u0441\u043A\u0430\u0437\u0430\u0432,
    \u0447\u0442\u043E \u0443 \u043B\u044E\u0434\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u043D \u0432\u0441\u043A\u0440\u044B\u0432\u0430\u043B (\u043F\u043E-\u0432\u0438\u0434\u0438\u043C\u043E\u043C\u0443,
    \u0443 \u043A\u0430\u0437\u043D\u0435\u043D\u043D\u044B\u0445 \u043F\u0440\u0435\u0441\u0442\u0443\u043F\u043D\u0438\u043A\u043E\u0432),
    \u0436\u0435\u043B\u0435\u0437\u0430 \"\u043F\u043E\u0434\u0432\u0438\u0436\u043D\u0435\u0435
    \u0438\u0437-\u0437\u0430 \u0431\u0443\u0440\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438\". 
    - **\u0421\u043C\u0435\u0448\u043D\u043E\u0435 \u043F\u0440\u043E\u0442\u0438\u0432\u043E\u0440\u0435\u0447\u0438\u0435:**
    \u041E\u043D \u0432\u0435\u0440\u0438\u043B, \u0447\u0442\u043E \u0434\u0443\u0448\u0430
    \u0441\u0438\u0434\u0438\u0442 \u0432 \u0436\u0435\u043B\u0435\u0437\u0435, \u043D\u043E
    \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u043B,
    \u0447\u0442\u043E \u0434\u0443\u0448\u0430 \xAB\u043D\u0435\u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u0430\xBB.
    \u041A\u043E\u0433\u0434\u0430 \u0435\u0433\u043E \u0441\u043F\u0440\u043E\u0441\u0438\u043B\u0438,
    \u043A\u0430\u043A \u043D\u0435\u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u043C\u043E\u0436\u0435\u0442 \u0434\u0430\u0432\u0438\u0442\u044C \u043D\u0430
    \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u043E\u0435 \u0442\u0435\u043B\u043E
    \u0432 \u0436\u0435\u043B\u0435\u0437\u0435, \u0414\u0435\u043A\u0430\u0440\u0442
    \u0447\u0435\u0441\u0442\u043D\u043E \u043E\u0442\u0432\u0435\u0442\u0438\u043B:
    *\xAB\u042F \u043D\u0435 \u043E\u0431\u044F\u0437\u0430\u043D \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0442\u044C
    \u0447\u0443\u0434\u043E, \u044D\u0442\u043E \u0442\u0430\u0439\u043D\u0430 \u0442\u0432\u043E\u0440\u0435\u043D\u0438\u044F\xBB*. 
    ---  ### 8. \u041F\u043E\u0447\u0435\u043C\u0443 \u0435\u0433\u043E \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0438 \"\u041E\u043F\u0430\u0441\u043D\u043E\u0439\"? 
    \u0412 1663 \u0433\u043E\u0434\u0443 (\u0443\u0436\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438) \u0435\u0433\u043E \u043A\u043D\u0438\u0433\u0438
    \u043F\u043E\u043F\u0430\u043B\u0438 \u0432 \u0418\u043D\u0434\u0435\u043A\u0441
    \u0437\u0430\u043F\u0440\u0435\u0449\u0435\u043D\u043D\u044B\u0445 \u043A\u043D\u0438\u0433.
    \u041D\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0435\u043D \u0441\u0430\u043C
    \u0444\u0430\u043A\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u0435\u043B
    \u043F\u0440\u0438 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438 \u0432 \u0413\u043E\u043B\u043B\u0430\u043D\u0434\u0438\u0438: 
    - **\u0421\u0443\u0434 \u043D\u0430\u0434 \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u043E\u043C:**
    \u041E\u0434\u0438\u043D \u0441\u0442\u0443\u0434\u0435\u043D\u0442 \u0423\u0442\u0440\u0435\u0445\u0442\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430 \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E
    \u0437\u0430\u0449\u0438\u0449\u0430\u043B \u0442\u0435\u043E\u0440\u0438\u044E
    \u0414\u0435\u043A\u0430\u0440\u0442\u0430 \u043E \u0442\u043E\u043C, \u0447\u0442\u043E
    \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0435 \u2014 \u044D\u0442\u043E \u043C\u0430\u0448\u0438\u043D\u044B
    \u0438 \u043D\u0435 \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044E\u0442 \u0431\u043E\u043B\u0438.
    \u041D\u0435\u0434\u0440\u0443\u0433\u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0430
    \u0434\u043E\u043D\u0435\u0441\u043B\u0438 \u0438\u043D\u043A\u0432\u0438\u0437\u0438\u0446\u0438\u0438,
    \u0447\u0442\u043E \u0414\u0435\u043A\u0430\u0440\u0442 \u0443\u0447\u0438\u0442,
    \u0431\u0443\u0434\u0442\u043E \u043B\u044E\u0434\u0438 \u2014 \u0442\u043E\u0436\u0435
    \u043C\u0430\u0448\u0438\u043D\u044B (\u0445\u043E\u0442\u044F \u043E\u043D \u0447\u0435\u0442\u043A\u043E
    \u0440\u0430\u0437\u0434\u0435\u043B\u044F\u043B \u0434\u0443\u0448\u0443 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430).
    - **\u0426\u0435\u0440\u043A\u043E\u0432\u043D\u044B\u0439 \u043F\u0440\u043E\u0446\u0435\u0441\u0441:**
    \u0414\u0435\u043A\u0430\u0440\u0442 \u043D\u0435 \u044F\u0432\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0441\u0443\u0434, \u043D\u043E \u043F\u0440\u0438\u0441\u043B\u0430\u043B
    \u043F\u0438\u0441\u044C\u043C\u043E, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0438\u0437\u0434\u0435\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0446\u0435\u0440\u043A\u043E\u0432\u043D\u0438\u043A\u0430\u043C:
    *\xAB\u0414\u043E\u043A\u0430\u0436\u0438\u0442\u0435, \u0447\u0442\u043E \u0443
    \u0441\u043E\u0431\u0430\u043A\u0438 \u0435\u0441\u0442\u044C \u0431\u0435\u0441\u0441\u043C\u0435\u0440\u0442\u043D\u0430\u044F
    \u0434\u0443\u0448\u0430, \u0438 \u044F \u043F\u0440\u0438\u0437\u043D\u0430\u044E
    \u043E\u0448\u0438\u0431\u043A\u0443. \u0415\u0441\u043B\u0438 \u0432\u044B \u043D\u0435
    \u043C\u043E\u0436\u0435\u0442\u0435, \u0442\u043E \u0434\u0430\u0439\u0442\u0435
    \u043C\u043D\u0435 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u0444\u0438\u0437\u0438\u043A\u0443\xBB*. \u042D\u0442\u043E \u0434\u0435\u0440\u0437\u043A\u043E\u0435
    \u043F\u0438\u0441\u044C\u043C\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u0438
    \u043D\u0430 \u0437\u0430\u0441\u0435\u0434\u0430\u043D\u0438\u0438, \u0438 \u043F\u0430\u0441\u0442\u043E\u0440\u044B
    \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u044B \u0431\u044B\u043B\u0438
    \u043E\u0442\u0441\u0442\u0443\u043F\u0438\u0442\u044C, \u0442\u0430\u043A \u043A\u0430\u043A
    \u043D\u0435 \u043C\u043E\u0433\u043B\u0438 \u043D\u0430\u0439\u0442\u0438 \u0446\u0438\u0442\u0430\u0442
    \u0438\u0437 \u0411\u0438\u0431\u043B\u0438\u0438 \u043E \u0434\u0443\u0448\u0430\u0445
    \u0436\u0438\u0432\u043E\u0442\u043D\u044B\u0445.  ---  ### 9. \u0422\u0440\u0438
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445 \u0441\u043D\u0430:
    \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u043F\u0440\u0438\u0448\u043B\u0430
    \u0432\u043E \u0441\u043D\u0435  \u0421\u0430\u043C\u044B\u0439 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0444\u0430\u043A\u0442 \u0438\u0437 \u0435\u0433\u043E \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0438
    \u2014 \u044D\u0442\u043E \u043D\u043E\u0447\u044C \u043D\u0430 10 \u043D\u043E\u044F\u0431\u0440\u044F
    1619 \u0433\u043E\u0434\u0430 \u0432 \u041D\u043E\u0439\u0431\u0443\u0440\u0433\u0435. 
    - **\u0421\u043E\u043D \u21161:** \u0415\u043C\u0443 \u043F\u0440\u0438\u0441\u043D\u0438\u043B\u0441\u044F
    \u0432\u0438\u0445\u0440\u044C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0433\u043D\u0430\u043B
    \u0435\u0433\u043E \u043A \u0446\u0435\u0440\u043A\u0432\u0438. - **\u0421\u043E\u043D
    \u21162:** \u0415\u043C\u0443 \u043F\u0440\u0438\u0441\u043D\u0438\u043B\u0441\u044F
    \u0443\u0434\u0430\u0440 \u0433\u0440\u043E\u043C\u0430 \u0438 \u0441\u0432\u0435\u0440\u043A\u0430\u044E\u0449\u0430\u044F
    \u043C\u043E\u043B\u043D\u0438\u044F. - **\u0421\u043E\u043D \u21163:** \u0415\u043C\u0443
    \u043F\u0440\u0438\u0441\u043D\u0438\u043B\u0430\u0441\u044C \u043A\u043D\u0438\u0433\u0430
    \u044D\u043D\u0446\u0438\u043A\u043B\u043E\u043F\u0435\u0434\u0438\u0438, \u043E\u0442\u043A\u0440\u044B\u0442\u0430\u044F
    \u043D\u0430 \u0441\u0442\u0438\u0445\u0435 *\xABQuod vitae sectabor iter?\xBB*
    (\xAB\u041A\u0430\u043A\u043E\u0439 \u043F\u0443\u0442\u044C \u0436\u0438\u0437\u043D\u0438
    \u043C\u043D\u0435 \u0438\u0437\u0431\u0440\u0430\u0442\u044C?\xBB), \u0438 \u0440\u044F\u0434\u043E\u043C
    \u0441\u0442\u043E\u044F\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u0434\u0430\u0432\u0448\u0438\u0439
    \u0435\u043C\u0443 \u043A\u043D\u0438\u0433\u0443 \u043F\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. 
    \u041F\u0440\u043E\u0441\u043D\u0443\u0432\u0448\u0438\u0441\u044C, \u0414\u0435\u043A\u0430\u0440\u0442
    \u0443\u043F\u0430\u043B \u043D\u0430 \u043A\u043E\u043B\u0435\u043D\u0438 \u0438,
    \u043F\u043E \u0435\u0433\u043E \u0441\u043B\u043E\u0432\u0430\u043C, \xAB\u043F\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0441\u0435\u0431\u044F \u043E\u0445\u0432\u0430\u0447\u0435\u043D\u043D\u044B\u043C
    \u043E\u0433\u043D\u0435\u043C \u044D\u043D\u0442\u0443\u0437\u0438\u0430\u0437\u043C\u0430\xBB.
    \u041E\u043D \u043F\u043E\u043D\u044F\u043B, \u0447\u0442\u043E \u0432\u0441\u0435
    \u043D\u0430\u0443\u043A\u0438 \u043C\u043E\u0436\u043D\u043E \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C
    \u043E\u0431\u0449\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043C\u0435\u0442\u043E\u0434\u043E\u0439. \u041E\u043D \u043F\u043E\u043A\u043B\u044F\u043B\u0441\u044F
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u0442\u044C \u043D\u043E\u0432\u0443\u044E
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044E \u0438 \u0434\u0430\u0436\u0435
    \u0441\u0445\u043E\u0434\u0438\u043B \u0432 \u0446\u0435\u0440\u043A\u043E\u0432\u044C
    \u0411\u043E\u0433\u043E\u043C\u0430\u0442\u0435\u0440\u0438 \u0432 \u041B\u043E\u0440\u0435\u0442\u043E,
    \u0447\u0442\u043E\u0431\u044B \u0434\u0430\u0442\u044C \u043E\u0431\u0435\u0442
    (\u043E\u043D \u0441\u0447\u0438\u0442\u0430\u043B \u044D\u0442\u0438 \u0441\u043D\u044B
    \u0431\u043E\u0436\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u0437\u043D\u0430\u043A\u043E\u043C). 
    ---  ### 10. \u041A\u0443\u043B\u0438\u043D\u0430\u0440\u043D\u044B\u0439 \u043A\u0443\u0440\u044C\u0435\u0437:
    \u041A\u0430\u043A \u0414\u0435\u043A\u0430\u0440\u0442 \"\u0443\u0431\u0438\u043B\"
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0433\u043E \u043F\u043E\u0432\u0430\u0440\u0430 
    \u0412\u043E \u0432\u0440\u0435\u043C\u044F \u0432\u0438\u0437\u0438\u0442\u0430
    \u0432 \u0421\u0442\u043E\u043A\u0433\u043E\u043B\u044C\u043C \u0414\u0435\u043A\u0430\u0440\u0442
    \u043F\u0438\u0442\u0430\u043B\u0441\u044F \u043F\u0440\u0435\u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u0442\u0435\u043C, \u0447\u0442\u043E \u043F\u0440\u0438\u0432\u043E\u0437\u0438\u043B
    \u0441 \u0441\u043E\u0431\u043E\u0439 \u0438\u0437 \u0424\u0440\u0430\u043D\u0446\u0438\u0438
    (\u0432\u0438\u043D\u0430 \u0438 \u0441\u044B\u0440\u044B), \u0442\u0430\u043A
    \u043A\u0430\u043A \u0448\u0432\u0435\u0434\u0441\u043A\u0443\u044E \u043A\u0443\u0445\u043D\u044E
    \u0441\u0447\u0438\u0442\u0430\u043B \u0432\u0430\u0440\u0432\u0430\u0440\u0441\u043A\u043E\u0439. 
    - **\u0418\u043D\u0446\u0438\u0434\u0435\u043D\u0442:** \u041E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0430 \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430
    \u0437\u0430\u0445\u043E\u0442\u0435\u043B\u0430 \u0443\u0433\u043E\u0441\u0442\u0438\u0442\u044C
    \u0435\u0433\u043E \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u044B\u043C
    \u0448\u0432\u0435\u0434\u0441\u043A\u0438\u043C \u0431\u043B\u044E\u0434\u043E\u043C
    \u0438\u0437 \u043A\u0432\u0430\u0448\u0435\u043D\u043E\u0439 \u0441\u0435\u043B\u044C\u0434\u0438.
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0431\u0440\u0435\u0437\u0433\u043B\u0438\u0432\u043E
    \u043E\u0442\u043E\u0434\u0432\u0438\u043D\u0443\u043B \u0442\u0430\u0440\u0435\u043B\u043A\u0443
    \u0438 \u0433\u0440\u043E\u043C\u043A\u043E (\u043D\u0430 \u0432\u0435\u0441\u044C
    \u0441\u0442\u043E\u043B) \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441, \u0447\u0442\u043E
    \u044D\u0442\u0430 \u0435\u0434\u0430 \"\u043F\u043E\u0434\u0445\u043E\u0434\u0438\u0442
    \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043B\u044F \u0440\u0430\u0431\u043E\u0432,
    \u043D\u043E \u043D\u0435 \u0434\u043B\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u0438\u0449\u0443\u0449\u0435\u0433\u043E \u0438\u0441\u0442\u0438\u043D\u0443\".
    - **\u041F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u044F:** \u041E\u0441\u043A\u043E\u0440\u0431\u043B\u0435\u043D\u043D\u044B\u0439
    \u043F\u0440\u0438\u0434\u0432\u043E\u0440\u043D\u044B\u0439 \u043F\u043E\u0432\u0430\u0440
    \u043F\u043E\u0434\u0430\u043B \u0432 \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0443.
    \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430, \u0443 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0431\u044B\u043B\u043E \u0447\u0443\u0432\u0441\u0442\u0432\u043E \u044E\u043C\u043E\u0440\u0430,
    \u0432\u044B\u0437\u0432\u0430\u043B\u0430 \u0414\u0435\u043A\u0430\u0440\u0442\u0430
    \u0438 \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u043B\u0430 \u0435\u0433\u043E
    \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E \u0438\u0437\u0432\u0438\u043D\u0438\u0442\u044C\u0441\u044F
    \u043F\u0435\u0440\u0435\u0434 \u043F\u043E\u0432\u0430\u0440\u043E\u043C, \u0438\u043D\u0430\u0447\u0435
    \u043E\u043D \u043B\u0438\u0448\u0438\u043B\u0441\u044F \u0431\u044B \u043F\u0435\u043D\u0441\u0438\u0438.
    \u0414\u0435\u043A\u0430\u0440\u0442 \u0438\u0437\u0432\u0438\u043D\u0438\u043B\u0441\u044F,
    \u043D\u043E \u0432 \u0442\u043E\u0442 \u0436\u0435 \u0434\u0435\u043D\u044C
    \u0432 \u043F\u0438\u0441\u044C\u043C\u0435 \u041C\u0435\u0440\u0441\u0435\u043D\u043D\u0443
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B: *\"\u0421\u044A\u0435\u0441\u0442\u044C
    \u044D\u0442\u0443 \u0442\u0443\u0445\u043B\u0443\u044E \u0440\u044B\u0431\u0443
    \u2014 \u0437\u043D\u0430\u0447\u0438\u0442 \u043E\u0442\u043A\u0430\u0437\u0430\u0442\u044C\u0441\u044F
    \u043E\u0442 \u0440\u0430\u0437\u0443\u043C\u0430, \u044F \u043B\u0443\u0447\u0448\u0435
    \u0443\u043C\u0440\u0443\"*. \u0418\u0440\u043E\u043D\u0438\u044F \u0441\u0443\u0434\u044C\u0431\u044B:
    \u043E\u043D \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0443\u043C\u0435\u0440 \u0447\u0435\u0440\u0435\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043C\u0435\u0441\u044F\u0446\u0435\u0432, \u043D\u043E \u043D\u0435 \u043E\u0442
    \u0440\u044B\u0431\u044B, \u0430 \u043E\u0442 \u0445\u043E\u043B\u043E\u0434\u0430. 
    ---  ### 11. \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0441\u043B\u043E\u0432\u0430
    \u0438 \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u043F\u0440\u0435\u0434\u0441\u043A\u0430\u0437\u0430\u043D\u0438\u0435 
    \u0415\u0441\u0442\u044C \u043B\u0435\u0433\u0435\u043D\u0434\u0430, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u0438\u0441\u0442\u043E\u0440\u0438\u043A\u0438 \u043E\u0441\u043F\u0430\u0440\u0438\u0432\u0430\u044E\u0442,
    \u043D\u043E \u043E\u043D\u0430 \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u043A\u0440\u0430\u0441\u0438\u0432\u0430,
    \u0447\u0442\u043E\u0431\u044B \u0435\u0435 \u043D\u0435 \u043F\u0440\u0438\u0432\u0435\u0441\u0442\u0438. 
    - **\u0420\u0430\u0437\u0433\u043E\u0432\u043E\u0440 \u0441 \u043C\u043E\u043D\u0430\u0445\u043E\u043C:**
    \u0423\u0442\u0440\u043E\u043C \u043F\u0435\u0440\u0435\u0434 \u0441\u043C\u0435\u0440\u0442\u044C\u044E,
    \u043A\u043E\u0433\u0434\u0430 \u0414\u0435\u043A\u0430\u0440\u0442 \u0443\u0436\u0435
    \u0431\u0440\u0435\u0434\u0438\u043B \u043E\u0442 \u0436\u0430\u0440\u0430, \u043A
    \u043D\u0435\u043C\u0443 \u043F\u0440\u0438\u0448\u0435\u043B \u043C\u043E\u043D\u0430\u0445-\u0438\u0435\u0437\u0443\u0438\u0442
    (\u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043E\u043D \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B
    \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C) \u0434\u043B\u044F \u0438\u0441\u043F\u043E\u0432\u0435\u0434\u0438.
    \u041C\u043E\u043D\u0430\u0445 \u0441\u043F\u0440\u043E\u0441\u0438\u043B: *\xAB\u0412\u0435\u0440\u0438\u0442\u0435
    \u043B\u0438 \u0432\u044B \u0432 \u0421\u0432\u044F\u0442\u0443\u044E \u0422\u0440\u043E\u0438\u0446\u0443?\xBB*.
    \u0414\u0435\u043A\u0430\u0440\u0442, \u043F\u043E \u043B\u0435\u0433\u0435\u043D\u0434\u0435,
    \u043E\u0442\u043A\u0440\u044B\u043B \u0433\u043B\u0430\u0437\u0430 \u0438 \u0441
    \u0443\u043B\u044B\u0431\u043A\u043E\u0439 \u043E\u0442\u0432\u0435\u0442\u0438\u043B:
    *\xAB\u042F \u0432\u0435\u0440\u044E \u0432 \u0411\u043E\u0433\u0430, \u043D\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0422\u0440\u043E\u0438\u0446\u044B... \u044D\u0442\u043E \u0437\u0430\u0434\u0430\u0447\u0430
    \u0434\u043B\u044F \u0430\u043D\u0433\u0435\u043B\u043E\u0432, \u0430 \u043D\u0435
    \u0434\u043B\u044F \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0430\xBB*. - **\u041F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u0442\u0432\u043E:**
    \u041A\u043E\u0440\u043E\u043B\u0435\u0432\u0430 \u041A\u0440\u0438\u0441\u0442\u0438\u043D\u0430,
    \u0443\u0437\u043D\u0430\u0432 \u043E \u0441\u043C\u0435\u0440\u0442\u0438 \u0414\u0435\u043A\u0430\u0440\u0442\u0430,
    \u0437\u0430\u043F\u043B\u0430\u043A\u0430\u043B\u0430 \u0438 \u0441\u043A\u0430\u0437\u0430\u043B\u0430
    \u0444\u0440\u0430\u0437\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0441\u0442\u0430\u043B\u0430
    \u043F\u0440\u043E\u0440\u043E\u0447\u0435\u0441\u043A\u043E\u0439: *\xAB\u041E\u043D
    \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0434\u043E\u043B\u0433\u043E \u0441\u043F\u0430\u043B,
    \u0447\u0442\u043E\u0431\u044B \u0443\u043C\u0435\u0440\u0435\u0442\u044C \u0431\u043E\u0434\u0440\u0441\u0442\u0432\u0443\u044F.
    \u041D\u043E \u0435\u0433\u043E \u0438\u0434\u0435\u0438 \u0435\u0449\u0435 \u0441\u043E\u0442\u0440\u044F\u0441\u0443\u0442
    \u0415\u0432\u0440\u043E\u043F\u0443\xBB*. \u041E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u043F\u0440\u0430\u0432\u0430 \u2014 \u0443\u0436\u0435 \u0447\u0435\u0440\u0435\u0437
    20 \u043B\u0435\u0442 \u0438\u0434\u0435\u0438 \u043A\u0430\u0440\u0442\u0435\u0437\u0438\u0430\u043D\u0441\u0442\u0432\u0430
    \u0441\u0442\u0430\u043B\u0438 \u0433\u043B\u0430\u0432\u043D\u043E\u0439 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0435\u0439
    \u0432\u043E \u0432\u0441\u0435\u0445 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430\u0445
    \u0415\u0432\u0440\u043E\u043F\u044B."
