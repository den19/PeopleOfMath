  achievementsRu: "\u041F\u0430\u0444\u043D\u0443\u0442\u0438\u0439 \u041B\u044C\u0432\u043E\u0432\u0438\u0447
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435,
    \u0441\u0442\u0430\u0432 \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A\u043E\u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0415\u0433\u043E \u0432\u043A\u043B\u0430\u0434 \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439, \u0438 \u0447\u0442\u043E \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
    \u0432\u0430\u0436\u043D\u043E, \u043E\u043D \u0432\u0441\u0435\u0433\u0434\u0430
    \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0441\u0432\u043E\u0438\u043C \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0432\u044B\u043A\u043B\u0430\u0434\u043A\u0430\u043C. \u0412\u043E\u0442 \u043E\u0431\u0437\u043E\u0440
    \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u0439. 
    ### \U0001F4D0 \u0422\u0435\u043E\u0440\u0438\u044F \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439 \u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437  \u042D\u0442\u043E, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430\u044F
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442,
    \u0437\u0430\u043B\u043E\u0436\u0438\u0432\u0448\u0430\u044F \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442
    \u0434\u043B\u044F \u0446\u0435\u043B\u043E\u0433\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  *   **\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043D\u0430\u0438\u043B\u0443\u0447\u0448\u0435\u0433\u043E
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u044F:** \u0427\u0435\u0431\u044B\u0448\u0451\u0432
    \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u0441\u0442\u0440\u043E\u0433\u043E
    \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0438 \u0440\u0435\u0448\u0438\u043B
    \u0437\u0430\u0434\u0430\u0447\u0443 \u043E \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0438
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u043E \u043E\u0442\u043A\u043B\u043E\u043D\u044F\u0435\u0442\u0441\u044F
    \u043E\u0442 \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u0439 \u0444\u0443\u043D\u043A\u0446\u0438\u0438
    \u043D\u0430 \u043E\u0442\u0440\u0435\u0437\u043A\u0435 (\u0437\u0430\u0434\u0430\u0447\u0430
    \u043E \u043D\u0430\u0438\u043B\u0443\u0447\u0448\u0435\u043C \u0440\u0430\u0432\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u043C
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u0438). \u042D\u0442\u043E
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u0435\u0433\u043E \u043A \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445 **\u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430**, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u0448\u0438\u0440\u043E\u043A\u043E
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F \u0432
    \u0432\u044B\u0447\u0438\u0441\u043B\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435, \u0442\u0435\u043E\u0440\u0438\u0438
    \u0444\u0438\u043B\u044C\u0442\u0440\u043E\u0432 \u0438 \u0434\u0440\u0443\u0433\u0438\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445. *   **\u0422\u0435\u043E\u0440\u0435\u043C\u0430
    \u043E\u0431 \u0430\u043B\u044C\u0442\u0435\u0440\u043D\u0430\u043D\u0441\u0435:**
    \u041E\u043D \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0439, \u043F\u043E \u043A\u043E\u0442\u043E\u0440\u043E\u043C\u0443
    \u043C\u043E\u0436\u043D\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C,
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043B\u0438 \u0434\u0430\u043D\u043D\u044B\u0439
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D \u043D\u0430\u0438\u043B\u0443\u0447\u0448\u0438\u043C
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u0435\u043C (\u0447\u0435\u0431\u044B\u0448\u0451\u0432\u0441\u043A\u0438\u0439
    \u0430\u043B\u044C\u0442\u0435\u0440\u043D\u0430\u043D\u0441). \u042D\u0442\u043E\u0442
    \u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0439 \u0441\u0442\u0430\u043B \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0432
    \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u0439.
    *   **\u041A\u0432\u0430\u0434\u0440\u0430\u0442\u0443\u0440\u043D\u044B\u0435
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B:** \u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    **\u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0443\u0440\u043D\u044B\u0435 \u0444\u043E\u0440\u043C\u0443\u043B\u044B
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430**, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0442 \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0443\u043F\u0440\u043E\u0441\u0442\u0438\u0442\u044C \u0438 \u0441\u043E\u043A\u0440\u0430\u0442\u0438\u0442\u044C
    \u043E\u0431\u044A\u0451\u043C \u0441\u043B\u043E\u0436\u043D\u044B\u0445 \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439, \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u044F
    \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u0438\u0445 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u043E\u0440\u0442\u043E\u0433\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432:** \u0412
    \u0442\u0435\u0441\u043D\u043E\u0439 \u0441\u0432\u044F\u0437\u0438 \u0441 \u0442\u0435\u043E\u0440\u0438\u0435\u0439
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u0439 \u043E\u043D
    \u0440\u0430\u0437\u0432\u0438\u043B \u043E\u0431\u0449\u0443\u044E \u0442\u0435\u043E\u0440\u0438\u044E
    \u043E\u0440\u0442\u043E\u0433\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432. \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u0440\u0438\u0432\u0435\u043B\u0438
    \u043A \u043F\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u044E \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430\u2013\u042D\u0440\u043C\u0438\u0442\u0430
    \u0438 \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430\u2013\u041B\u0430\u0433\u0435\u0440\u0440\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0430\u0445\u043E\u0434\u044F\u0442
    \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0432 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435 \u0438 \u0430\u043D\u0430\u043B\u0438\u0437\u0435. 
    ### \U0001F522 \u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B 
    \u0420\u0430\u0431\u043E\u0442\u044B \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0438
    \u0435\u043C\u0443 \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0441\u043B\u0430\u0432\u0443
    \u0438 \u0441\u0442\u0430\u043B\u0438 \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u043C
    \u0448\u0430\u0433\u043E\u043C \u0432 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0438
    \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B.  *  
    **\u0420\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B:**
    \u0412 \u0441\u0432\u043E\u0438\u0445 \u043C\u0435\u043C\u0443\u0430\u0440\u0430\u0445
    1848\u20131850 \u0433\u043E\u0434\u043E\u0432 \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432, \u0432\u043F\u0435\u0440\u0432\u044B\u0435
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E \u043F\u0440\u043E\u0434\u0432\u0438\u043D\u0443\u0432\u0448\u0438\u0441\u044C
    \u0432 \u044D\u0442\u043E\u043C \u0432\u043E\u043F\u0440\u043E\u0441\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430. \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B \u03C0(x)
    \u0432\u0435\u0434\u0451\u0442 \u0441\u0435\u0431\u044F \u043A\u0430\u043A x
    / ln(x), \u0445\u043E\u0442\u044F \u0438 \u043D\u0435 \u0441\u043C\u043E\u0433
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u0441\u0430\u043C\u0443 \u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 (\u044D\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B\u0438
    \u0410\u0434\u0430\u043C\u0430\u0440 \u0438 \u0412\u0430\u043B\u043B\u0435-\u041F\u0443\u0441\u0441\u0435\u043D
    \u043F\u043E\u0437\u0436\u0435). *   **\u041F\u043E\u0441\u0442\u0443\u043B\u0430\u0442
    \u0411\u0435\u0440\u0442\u0440\u0430\u043D\u0430:** \u041E\u043D \u0441\u0442\u0440\u043E\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E \u0434\u043B\u044F
    \u043B\u044E\u0431\u043E\u0433\u043E n > 1 \u043C\u0435\u0436\u0434\u0443 n \u0438
    2n \u0432\u0441\u0435\u0433\u0434\u0430 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0445\u043E\u0442\u044F \u0431\u044B \u043E\u0434\u043D\u043E \u043F\u0440\u043E\u0441\u0442\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E. *   **\u041E\u0446\u0435\u043D\u043A\u0438 \u0434\u043B\u044F
    \u03C0(x):** \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B
    \u0433\u0440\u0430\u043D\u0438\u0446\u044B, \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043C\u043E\u0436\u0435\u0442 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u03C0(x), \u0434\u043E\u043A\u0430\u0437\u0430\u0432
    \u043D\u0435\u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F \u0431\u044B\u043B\u0438
    \u043B\u0443\u0447\u0448\u0438\u043C\u0438 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C\u0438
    \u043E\u0446\u0435\u043D\u043A\u0430\u043C\u0438. *   **\u0413\u0438\u043F\u043E\u0442\u0435\u0437\u0430
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430:** \u0412 1853 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0432\u044B\u0434\u0432\u0438\u043D\u0443\u043B \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u0432\u0438\u0434\u0430 4n+3 \u043D\u0435\u043C\u043D\u043E\u0433\u043E
    \u0431\u043E\u043B\u044C\u0448\u0435, \u0447\u0435\u043C \u0432\u0438\u0434\u0430
    4n+1. \u042D\u0442\u043E \xAB\u0441\u043C\u0435\u0449\u0435\u043D\u0438\u0435
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430\xBB (Chebyshev's bias) \u0441\u0442\u0430\u043B\u043E
    \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u044C\u044E
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0432
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B. *   **\xAB\u0422\u0435\u043E\u0440\u0438\u044F
    \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439\xBB:** \u0415\u0433\u043E
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0430\u044F \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044F
    \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u043E\u0439 \u043E\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u0435\u0439 \u043F\u043E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B \u0438 \u043D\u0435
    \u0443\u0442\u0440\u0430\u0442\u0438\u043B\u0430 \u0441\u0432\u043E\u0435\u0433\u043E
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440, \u044F\u0432\u043B\u044F\u044F\u0441\u044C \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u043E\u043C
    \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043A\u0440\u0438\u043F\u0442\u043E\u0433\u0440\u0430\u0444\u0438\u0438.  ###
    \U0001F3B2 \u0422\u0435\u043E\u0440\u0438\u044F \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439 
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A\u043E\u043C
    \u0440\u0443\u0441\u0441\u043A\u043E\u0439 \u0448\u043A\u043E\u043B\u044B \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.  *  
    **\u0417\u0430\u043A\u043E\u043D \u0431\u043E\u043B\u044C\u0448\u0438\u0445 \u0447\u0438\u0441\u0435\u043B:**
    \u041E\u043D \u0434\u0430\u043B \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u0438
    \u043E\u0431\u0449\u0435\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0431\u043E\u043B\u044C\u0448\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B \u0432 \u0444\u043E\u0440\u043C\u0435, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043D\u043E\u0441\u0438\u0442 \u0435\u0433\u043E \u0438\u043C\u044F. \u042D\u0442\u043E\u0442
    \u0437\u0430\u043A\u043E\u043D \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0435\u0442,
    \u043F\u043E\u0447\u0435\u043C\u0443 \u0441\u0440\u0435\u0434\u043D\u0438\u0435
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F \u0431\u043E\u043B\u044C\u0448\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0445
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D \u0441\u0442\u0430\u043D\u043E\u0432\u044F\u0442\u0441\u044F
    \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u044B\u043C\u0438. *   **\u041D\u0435\u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u043E
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430:** \u0412 1866 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435 \u043D\u0435\u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u043E,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u043E\u0446\u0435\u043D\u0438\u0442\u044C \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u044C
    \u043E\u0442\u043A\u043B\u043E\u043D\u0435\u043D\u0438\u044F \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0439
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u044B \u043E\u0442 \u0435\u0451 \u0441\u0440\u0435\u0434\u043D\u0435\u0433\u043E
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F, \u0437\u043D\u0430\u044F \u043B\u0438\u0448\u044C
    \u0435\u0451 \u0434\u0438\u0441\u043F\u0435\u0440\u0441\u0438\u044E. \u042D\u0442\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442 \u0432\u0441\u0435\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439.
    *   **\u0426\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u0430\u044F \u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u0430\u044F
    \u0442\u0435\u043E\u0440\u0435\u043C\u0430:** \u041E\u043D \u043F\u0435\u0440\u0432\u044B\u043C
    \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0438 \u0434\u043E\u043A\u0430\u0437\u0430\u043B (\u0445\u043E\u0442\u044F \u0438
    \u0441 \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u0438\u043C \u043F\u0440\u043E\u0431\u0435\u043B\u043E\u043C,
    \u043F\u043E\u0437\u0436\u0435 \u0432\u043E\u0441\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u044B\u043C
    \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C\u0438) \u043E\u0431\u0449\u0443\u044E
    \u0432\u0435\u0440\u0441\u0438\u044E \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439
    \u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B,
    \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u044E\u0449\u0443\u044E, \u043F\u043E\u0447\u0435\u043C\u0443
    \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0441\u0443\u043C\u043C\u044B \u0431\u043E\u043B\u044C\u0448\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0445
    \u0432\u0435\u043B\u0438\u0447\u0438\u043D \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0441\u044F
    \u043A \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u043C\u0443. *  
    **\u041C\u0435\u0442\u043E\u0434 \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u0432:**
    \u0414\u043B\u044F \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0441\u0432\u043E\u0438\u0445 \u0442\u0435\u043E\u0440\u0435\u043C \u043E\u043D
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B **\u043C\u0435\u0442\u043E\u0434
    \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u0432**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0445
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439. 
    ### \u2699\uFE0F \u0422\u0435\u043E\u0440\u0438\u044F \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432
    \u0438 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u0430\u044F \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430 
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B
    \u043E\u043F\u0438\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u0443\u044E \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0443
    \u043C\u0430\u0448\u0438\u043D \u0432 \u0442\u043E\u0447\u043D\u0443\u044E \u043D\u0430\u0443\u043A\u0443,
    \u0437\u0430\u043B\u043E\u0436\u0438\u0432 \u043E\u0441\u043D\u043E\u0432\u044B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0441\u0438\u043D\u0442\u0435\u0437\u0430
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432.  *   **\u041E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A
    \u0441\u0438\u043D\u0442\u0435\u0437\u0430 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432:**
    \u041E\u043D \u043F\u0435\u0440\u0432\u044B\u043C \u043F\u043E\u0434\u043E\u0448\u0451\u043B
    \u043A \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432 \u043A\u0430\u043A
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0435, \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u0432
    \u0442\u0435\u043E\u0440\u0438\u044E **\u0448\u0430\u0440\u043D\u0438\u0440\u043D\u043E-\u0440\u044B\u0447\u0430\u0436\u043D\u044B\u0445
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432** \u0434\u043B\u044F
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F. \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    \u043E\u043A\u043E\u043B\u043E **40 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432** \u0438 80 \u0438\u0445
    \u043C\u043E\u0434\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0439. *   **\xAB\u0421\u0442\u043E\u043F\u043E\u0445\u043E\u0434\u044F\u0449\u0430\u044F\xBB
    \u043C\u0430\u0448\u0438\u043D\u0430:** \u0415\u0433\u043E \u0441\u0430\u043C\u043E\u0435
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0435
    \u2014 \u043F\u0435\u0440\u0432\u044B\u0439 \u0432 \u043C\u0438\u0440\u0435 \u0448\u0430\u0433\u0430\u044E\u0449\u0438\u0439
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C, \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445 \u0448\u0430\u0433\u043E\u0445\u043E\u0434\u043E\u0432
    \u0438 \u0440\u043E\u0431\u043E\u0442\u043E\u0432. \u041E\u043D\u0430 \u0434\u0435\u043C\u043E\u043D\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u043D\u0430 \u0412\u0441\u0435\u043C\u0438\u0440\u043D\u044B\u0445 \u0432\u044B\u0441\u0442\u0430\u0432\u043A\u0430\u0445.
    *   **\u0414\u0440\u0443\u0433\u0438\u0435 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F:**
    \u0415\u0433\u043E \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u0430\u044F
    \u043C\u044B\u0441\u043B\u044C \u0431\u044B\u043B\u0430 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u043E\u0439. \u0421\u0440\u0435\u0434\u0438
    \u0435\u0433\u043E \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043E\u043A:
    \u0441\u0430\u043C\u043E\u043A\u0430\u0442\u043D\u043E\u0435 \u043A\u0440\u0435\u0441\u043B\u043E
    (\u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437 \u0438\u043D\u0432\u0430\u043B\u0438\u0434\u043D\u043E\u0439
    \u043A\u043E\u043B\u044F\u0441\u043A\u0438), \u0441\u043E\u0440\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u044C\u043D\u0430\u044F
    \u0437\u0435\u0440\u043D\u043E\u0432\u0430\u044F \u043C\u0430\u0448\u0438\u043D\u0430,
    \u0433\u0440\u0435\u0431\u043D\u043E\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C,
    \u0431\u044B\u0441\u0442\u0440\u044B\u0439 \u0430\u0440\u0438\u0444\u043C\u043E\u043C\u0435\u0442\u0440
    \u0438 \u0446\u0435\u043D\u0442\u0440\u043E\u0431\u0435\u0436\u043D\u044B\u0439
    \u0440\u0435\u0433\u0443\u043B\u044F\u0442\u043E\u0440.  ### \U0001F3AF \u0411\u0430\u043B\u043B\u0438\u0441\u0442\u0438\u043A\u0430
    \u0438 \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435 
    \u0412 \u0433\u043E\u0434\u044B \u041A\u0440\u044B\u043C\u0441\u043A\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u0431\u044B\u043B
    \u043F\u0440\u0438\u0432\u043B\u0435\u0447\u0451\u043D \u043A \u0440\u0430\u0431\u043E\u0442\u0435
    \u043D\u0430\u0434 \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u0438\u0435\u043C
    \u0434\u0430\u043B\u044C\u043D\u043E\u0431\u043E\u0439\u043D\u043E\u0441\u0442\u0438
    \u0438 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u0438 \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u0439\u0441\u043A\u043E\u0439
    \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u044B.  *   **\u0424\u043E\u0440\u043C\u0443\u043B\u0430
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430:** \u041F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0451\u043D\u043D\u0443\u044E \u0444\u043E\u0440\u043C\u0443\u043B\u0443
    \u0434\u043B\u044F \u0440\u0430\u0441\u0447\u0451\u0442\u0430 \u0434\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u043F\u043E\u043B\u0451\u0442\u0430 \u0441\u043D\u0430\u0440\u044F\u0434\u0430,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u0432 \u0431\u0430\u043B\u043B\u0438\u0441\u0442\u0438\u043A\u0435. *   **\u0424\u043E\u0440\u043C\u0430
    \u0441\u043D\u0430\u0440\u044F\u0434\u0430:** \u041E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043B
    \xAB\u043D\u0430\u0438\u0432\u044B\u0433\u043E\u0434\u043D\u0435\u0439\u0448\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\xBB \u0443\u0434\u043B\u0438\u043D\u0451\u043D\u043D\u043E\u0433\u043E
    \u0441\u043D\u0430\u0440\u044F\u0434\u0430 \u0434\u043B\u044F \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0435\u043D\u0438\u044F
    \u0435\u0433\u043E \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438
    \u0432 \u043F\u043E\u043B\u0451\u0442\u0435. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043C\u0435\u0442\u043E\u0434\u044B
    \u0438\u043D\u0442\u0435\u0440\u043F\u043E\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F
    \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0439 \u0434\u043B\u044F
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044F \u0442\u0430\u0431\u043B\u0438\u0446
    \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u044B.  ### \U0001F3DB\uFE0F \u041E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B  \u041F\u043E\u0436\u0430\u043B\u0443\u0439, \u0435\u0433\u043E
    \u0432\u0430\u0436\u043D\u0435\u0439\u0448\u0438\u043C \u0432\u043A\u043B\u0430\u0434\u043E\u043C
    \u0432 \u043D\u0430\u0443\u043A\u0443 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043C\u043E\u0449\u043D\u043E\u0439
    **\u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B**. \u0415\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C\u0438
    \u0431\u044B\u043B\u0438 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438: \u0410.\u0410.
    \u041C\u0430\u0440\u043A\u043E\u0432, \u0410.\u041C. \u041B\u044F\u043F\u0443\u043D\u043E\u0432,
    \u0414.\u0410. \u0413\u0440\u0430\u0432\u0435, \u042E.\u0412. \u0421\u043E\u0445\u043E\u0446\u043A\u0438\u0439
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B\u0438 \u0438 \u0440\u0430\u0437\u0432\u0438\u043B\u0438
    \u0435\u0433\u043E \u0438\u0434\u0435\u0438, \u043E\u0431\u0435\u0441\u043F\u0435\u0447\u0438\u0432
    \u043C\u0438\u0440\u043E\u0432\u043E\u0435 \u043B\u0438\u0434\u0435\u0440\u0441\u0442\u0432\u043E
    \u0440\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043D\u0430\u0443\u043A\u0438 \u043D\u0430 \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u044F
    \u0432\u043F\u0435\u0440\u0451\u0434."
  achievementsEn: 
  personalLifeRu: "\u0421\u0432\u0435\u0434\u0435\u043D\u0438\u0439 \u043E \u043B\u0438\u0447\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u041F\u0430\u0444\u043D\u0443\u0442\u0438\u044F
    \u041B\u044C\u0432\u043E\u0432\u0438\u0447\u0430 \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430
    \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\u043E\u0441\u044C \u043D\u0435\u043C\u043D\u043E\u0433\u043E,
    \u0442\u0430\u043A \u043A\u0430\u043A \u043E\u043D \u0431\u044B\u043B \u043E\u0447\u0435\u043D\u044C
    \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C,
    \u043D\u0435 \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043D\u0438 \u043C\u0435\u043C\u0443\u0430\u0440\u043E\u0432,
    \u043D\u0438 \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u043E\u0432, \u0438 \u043F\u043E\u0447\u0442\u0438
    \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0433\u043E\u0432\u043E\u0440\u0438\u043B
    \u043E \u0441\u0435\u0431\u0435. \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435
    \u0444\u0430\u043A\u0442\u044B \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C
    \u043A\u0430\u0441\u0430\u044E\u0442\u0441\u044F \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u0438,
    \u0434\u0435\u0442\u0441\u0442\u0432\u0430 \u0438 \u043F\u0440\u0438\u0432\u044B\u0447\u0435\u043A,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u0435\u0433\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440.  ### \U0001F46A
    \u0421\u0435\u043C\u044C\u044F \u0438 \u0434\u0435\u0442\u0441\u0442\u0432\u043E
    \u0432 \u041E\u043A\u0430\u0442\u043E\u0432\u043E  \u041F\u0430\u0444\u043D\u0443\u0442\u0438\u0439
    \u041B\u044C\u0432\u043E\u0432\u0438\u0447 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    16 \u043C\u0430\u044F 1821 \u0433\u043E\u0434\u0430 \u0432 \u0441\u0435\u043B\u0435
    \u041E\u043A\u0430\u0442\u043E\u0432\u043E \u041A\u0430\u043B\u0443\u0436\u0441\u043A\u043E\u0439
    \u0433\u0443\u0431\u0435\u0440\u043D\u0438\u0438. \u041E\u043D \u0431\u044B\u043B
    \u0441\u0442\u0430\u0440\u0448\u0438\u043C \u0438\u0437 \u0434\u0435\u0432\u044F\u0442\u0438
    \u0434\u0435\u0442\u0435\u0439 \u0432 \u0441\u0435\u043C\u044C\u0435: \u0443
    \u043D\u0435\u0433\u043E \u0431\u044B\u043B\u043E \u0447\u0435\u0442\u0432\u0435\u0440\u043E
    \u0431\u0440\u0430\u0442\u044C\u0435\u0432 (\u041F\u0430\u0432\u0435\u043B, \u041F\u0451\u0442\u0440,
    \u041D\u0438\u043A\u043E\u043B\u0430\u0439, \u0412\u043B\u0430\u0434\u0438\u043C\u0438\u0440)
    \u0438 \u0447\u0435\u0442\u044B\u0440\u0435 \u0441\u0435\u0441\u0442\u0440\u044B
    (\u0415\u043B\u0438\u0437\u0430\u0432\u0435\u0442\u0430, \u0415\u043A\u0430\u0442\u0435\u0440\u0438\u043D\u0430,
    \u041D\u0430\u0434\u0435\u0436\u0434\u0430, \u041E\u043B\u044C\u0433\u0430). 
    \u0415\u0433\u043E \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438 \u0431\u044B\u043B\u0438
    \u043E\u0447\u0435\u043D\u044C \u0440\u0430\u0437\u043D\u044B\u043C\u0438 \u043B\u044E\u0434\u044C\u043C\u0438:
    *   **\u041E\u0442\u0435\u0446, \u041B\u0435\u0432 \u041F\u0430\u0432\u043B\u043E\u0432\u0438\u0447**,
    \u0431\u044B\u043B \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u043E\u043C
    \u041E\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B 1812 \u0433\u043E\u0434\u0430. \u0412 \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0435
    \u043E\u043D \u0432\u0435\u043B \u0445\u043E\u0437\u044F\u0439\u0441\u0442\u0432\u043E
    \u0438 \u0431\u044B\u043B \u0443\u0432\u0430\u0436\u0430\u0435\u043C\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0432 \u0443\u0435\u0437\u0434\u0435,
    \u0438\u0437\u0431\u0438\u0440\u0430\u043B\u0441\u044F \u043F\u0440\u0435\u0434\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u0435\u043C
    \u0434\u0432\u043E\u0440\u044F\u043D\u0441\u0442\u0432\u0430. *   **\u041C\u0430\u0442\u044C,
    \u0410\u0433\u0440\u0430\u0444\u0435\u043D\u0430 \u0418\u0432\u0430\u043D\u043E\u0432\u043D\u0430**,
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0430 \u0438\u0437
    \u0441\u0442\u0430\u0440\u0438\u043D\u043D\u043E\u0433\u043E \u0434\u0432\u043E\u0440\u044F\u043D\u0441\u043A\u043E\u0433\u043E
    \u0440\u043E\u0434\u0430 \u041F\u043E\u0437\u043D\u044F\u043A\u043E\u0432\u044B\u0445.
    \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438 \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0438
    \u0435\u0451 \u043A\u0430\u043A \u0436\u0435\u043D\u0449\u0438\u043D\u0443 \u0432\u043B\u0430\u0441\u0442\u043D\u0443\u044E,
    \u0440\u0430\u0441\u0447\u0435\u0442\u043B\u0438\u0432\u0443\u044E \u0438 \u0441\u0443\u0440\u043E\u0432\u0443\u044E,
    \u0447\u0442\u043E \u0441\u0438\u043B\u044C\u043D\u043E \u043F\u043E\u0432\u043B\u0438\u044F\u043B\u043E
    \u043D\u0430 \u0434\u043E\u043C\u0430\u0448\u043D\u044E\u044E \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0443. 
    \u0414\u0435\u0442\u0441\u0442\u0432\u043E \u041F\u0430\u0444\u043D\u0443\u0442\u0438\u044F
    \u043F\u0440\u043E\u0448\u043B\u043E \u0432 \u0441\u0442\u0430\u0440\u043E\u043C
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u043C \u0434\u043E\u043C\u0435 \u0432
    \u041E\u043A\u0430\u0442\u043E\u0432\u043E. \u041D\u0430 \u0435\u0433\u043E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440
    \u0441\u0438\u043B\u044C\u043D\u043E \u043F\u043E\u0432\u043B\u0438\u044F\u043B
    \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u043A
    \u2014 \u0445\u0440\u043E\u043C\u043E\u0442\u0430 \u043D\u0430 \u043E\u0434\u043D\u0443
    \u043D\u043E\u0433\u0443. \u0418\u0437-\u0437\u0430 \u044D\u0442\u043E\u0433\u043E
    \u043E\u043D \u043D\u0435 \u043C\u043E\u0433 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u0432 \u043F\u043E\u0434\u0432\u0438\u0436\u043D\u044B\u0445 \u0438\u0433\u0440\u0430\u0445
    \u0441\u043E \u0441\u0432\u0435\u0440\u0441\u0442\u043D\u0438\u043A\u0430\u043C\u0438,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0443\u0447\u0438\u043B\u043E \u0435\u0433\u043E
    \u043A \u0443\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044E \u0438 \u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u043D\u043E\u0439
    \u0443\u043C\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435.
    \u0423\u0436\u0435 \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u043E\u043D
    \u043C\u043D\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B
    \u0437\u0430 \u043A\u043D\u0438\u0433\u0430\u043C\u0438 \u0438 \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441 \u043A \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435,
    \u043C\u0430\u0441\u0442\u0435\u0440\u0438\u043B \u0438\u0433\u0440\u0443\u0448\u043A\u0438
    \u0438 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0435 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430. 
    ### \U0001F3EB \u042E\u043D\u043E\u0441\u0442\u044C \u0438 \u0443\u0447\u0435\u0431\u0430 
    \u0412 1832 \u0433\u043E\u0434\u0443 \u0441\u0435\u043C\u044C\u044F \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432 \u041C\u043E\u0441\u043A\u0432\u0443, \u0447\u0442\u043E\u0431\u044B \u0434\u0430\u0442\u044C
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0441\u0442\u0430\u0440\u0448\u0438\u043C
    \u0441\u044B\u043D\u043E\u0432\u044C\u044F\u043C. \u0414\u043E\u043C\u0430\u0448\u043D\u0438\u043C\u0438
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F\u043C\u0438 \u041F\u0430\u0444\u043D\u0443\u0442\u0438\u044F
    \u0431\u044B\u043B\u0438 \u043B\u0443\u0447\u0448\u0438\u0435 \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438.
    \u0423\u0447\u0438\u0442\u0435\u043B\u0435\u043C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0431\u044B\u043B \u041F\u043B\u0430\u0442\u043E\u043D \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447
    \u041F\u043E\u0433\u043E\u0440\u0435\u043B\u044C\u0441\u043A\u0438\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043F\u0440\u0438\u0432\u0438\u043B \u0435\u043C\u0443 \u043B\u044E\u0431\u043E\u0432\u044C
    \u043A \u0442\u043E\u0447\u043D\u044B\u043C \u043D\u0430\u0443\u043A\u0430\u043C.
    \u041B\u0430\u0442\u044B\u043D\u044C \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B
    \u0410\u043B\u0435\u043A\u0441\u0435\u0439 \u0422\u0435\u0440\u0435\u043D\u0442\u044C\u0435\u0432\u0438\u0447
    \u0422\u0430\u0440\u0430\u0441\u0435\u043D\u043A\u043E\u0432 \u2014 \u0432\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438
    \u043E\u043D \u0441\u0442\u0430\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u0432\u0440\u0430\u0447\u043E\u043C \u0438 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0441\u0442\u0430\u0440\u0448\u0435\u0439 \u0441\u0435\u0441\u0442\u0440\u0435
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430, \u0415\u043B\u0438\u0437\u0430\u0432\u0435\u0442\u0435
    \u041B\u044C\u0432\u043E\u0432\u043D\u0435. \u0425\u043E\u0442\u044F \u043C\u0430\u0442\u044C
    \u0431\u044B\u043B\u0430 \u043F\u0440\u043E\u0442\u0438\u0432 \u044D\u0442\u043E\u0433\u043E
    \u0431\u0440\u0430\u043A\u0430, \u043E\u043D \u0432\u0441\u0451 \u0436\u0435
    \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0441\u044F.  ### \U0001F464 \u041B\u0438\u0447\u043D\u043E\u0441\u0442\u044C
    \u0438 \u043F\u0440\u0438\u0432\u044B\u0447\u043A\u0438  *   **\u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440:**
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u0431\u044B\u043B \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u043C
    \u0438 \u043D\u0435\u043E\u0431\u0449\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C. \u0412 \u0441\u0442\u0443\u0434\u0435\u043D\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B \u043E\u043D \u043D\u0438\u0447\u0435\u043C \u043D\u0435
    \u0432\u044B\u0434\u0435\u043B\u044F\u043B\u0441\u044F \u0441\u0440\u0435\u0434\u0438
    \u0442\u043E\u0432\u0430\u0440\u0438\u0449\u0435\u0439, \u043E\u0442\u043B\u0438\u0447\u0430\u043B\u0441\u044F
    \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u044B\u043C \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435\u043C
    \u0438 \u0431\u044B\u043B \u0431\u0435\u0440\u0435\u0436\u043B\u0438\u0432. \u042D\u0442\u0430
    \u0431\u0435\u0440\u0435\u0436\u043B\u0438\u0432\u043E\u0441\u0442\u044C, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u0438\u0437-\u0437\u0430 \u0444\u0438\u043D\u0430\u043D\u0441\u043E\u0432\u044B\u0445
    \u0442\u0440\u0443\u0434\u043D\u043E\u0441\u0442\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u0435\u0440\u0435\u0436\u0438\u043B\u0430 \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u044F
    \u0432 1840-\u0445 \u0433\u043E\u0434\u0430\u0445. *   **\u041C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u0435:** \u041A\u043E\u0433\u0434\u0430
    \u0441\u0435\u043C\u044C\u044F \u0440\u0430\u0437\u043E\u0440\u0438\u043B\u0430\u0441\u044C,
    \u041F\u0430\u0444\u043D\u0443\u0442\u0438\u0439 \u0436\u0438\u043B \u043D\u0430
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439 \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u043E\u043A.
    \u0412\u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u0438, \u0441\u0442\u0430\u0432
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C \u0443\u0447\u0435\u043D\u044B\u043C,
    \u043E\u043D \u043D\u0435 \u0436\u0430\u043B\u0435\u043B \u0434\u0435\u043D\u0435\u0433
    \u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0430 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043C\u043E\u0434\u0435\u043B\u0435\u0439 \u0441\u0432\u043E\u0438\u0445 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432
    \u0438 \u043F\u0440\u0438\u0431\u043E\u0440\u043E\u0432. *   **\u041F\u0440\u0438\u0432\u044B\u0447\u043A\u0438
    \u0438 \u043E\u0431\u0440\u0430\u0437 \u0436\u0438\u0437\u043D\u0438:** \u041E\u043D
    \u0431\u044B\u043B \u043E\u0447\u0435\u043D\u044C \u0430\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u044B\u043C
    \u0438 \u043F\u0443\u043D\u043A\u0442\u0443\u0430\u043B\u044C\u043D\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0447\u0438\u0442\u0430\u044F \u043B\u0435\u043A\u0446\u0438\u0438 \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u043E\u043D \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u043E\u043F\u0430\u0437\u0434\u044B\u0432\u0430\u043B
    \u0438 \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0437\u0430\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u043B
    \u0430\u0443\u0434\u0438\u0442\u043E\u0440\u0438\u044E. \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B \u0436\u0438\u0437\u043D\u0438 \u043E\u043D \u043F\u043E-\u043F\u0440\u0435\u0436\u043D\u0435\u043C\u0443
    \u0432\u0435\u043B \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u0439 \u043E\u0431\u0440\u0430\u0437
    \u0436\u0438\u0437\u043D\u0438, \u043D\u0435 \u043B\u044E\u0431\u0438\u043B \u0432\u0440\u0430\u0447\u0435\u0439
    \u0438 \u043F\u0435\u0440\u0435\u043D\u043E\u0441\u0438\u043B \u0431\u043E\u043B\u0435\u0437\u043D\u0438
    \u043D\u0430 \u043D\u043E\u0433\u0430\u0445.  ### \U0001F9D1\u200D\U0001F91D\u200D\U0001F9D1
    \u0421\u0435\u043C\u0435\u0439\u043D\u044B\u0435 \u0441\u0432\u044F\u0437\u0438
    \u0441 \u0438\u043C\u0435\u043D\u0438\u044F\u043C\u0438  \u0421\u0435\u043C\u044C\u044F
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u044B\u0445 \u0431\u044B\u043B\u0430
    \u0442\u0435\u0441\u043D\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u0430 \u0441
    \u0437\u0435\u043C\u043B\u044F\u043C\u0438 \u0432 \u0422\u0443\u043B\u044C\u0441\u043A\u043E\u0439
    \u0438 \u041B\u0438\u043F\u0435\u0446\u043A\u043E\u0439 \u0433\u0443\u0431\u0435\u0440\u043D\u0438\u044F\u0445:
    *   \u0418\u043C\u0435\u043D\u0438\u0435 \xAB\u0427\u0435\u0431\u0443\u0448\u043E\u0432
    \u0441\u0430\u0434\xBB \u043D\u0435\u0434\u0430\u043B\u0435\u043A\u043E \u043E\u0442
    \u0415\u043B\u044C\u0446\u0430 \u0431\u044B\u043B\u043E \u0434\u0430\u043D\u043E
    \u0432 \u043F\u0440\u0438\u0434\u0430\u043D\u043E\u0435 \u0437\u0430 \u0441\u0435\u0441\u0442\u0440\u043E\u0439
    \u0415\u043B\u0438\u0437\u0430\u0432\u0435\u0442\u043E\u0439 \u041B\u044C\u0432\u043E\u0432\u043D\u043E\u0439,
    \u043A\u043E\u0433\u0434\u0430 \u043E\u043D\u0430 \u0432\u044B\u0448\u043B\u0430
    \u0437\u0430\u043C\u0443\u0436. *   \u0412\u0442\u043E\u0440\u0430\u044F \u0441\u0435\u0441\u0442\u0440\u0430,
    \u0415\u043A\u0430\u0442\u0435\u0440\u0438\u043D\u0430 \u041B\u044C\u0432\u043E\u0432\u043D\u0430,
    \u0432\u044B\u0448\u043B\u0430 \u0437\u0430\u043C\u0443\u0436 \u0437\u0430 \u0435\u043B\u0435\u0446\u043A\u043E\u0433\u043E
    \u043F\u043E\u043C\u0435\u0449\u0438\u043A\u0430 \u041C\u0438\u0445\u0430\u0438\u043B\u0430
    \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u0438\u0447\u0430 \u041B\u043E\u043F\u0430\u0442\u0438\u043D\u0430.
    *   \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E, \u0447\u0442\u043E \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u044B
    \u0431\u044B\u043B\u0438 \u0441\u043E\u0441\u0435\u0434\u044F\u043C\u0438 \u043F\u0440\u0435\u0434\u043A\u043E\u0432
    \u043F\u043E\u044D\u0442\u0430 \u041C\u0438\u0445\u0430\u0438\u043B\u0430 \u041B\u0435\u0440\u043C\u043E\u043D\u0442\u043E\u0432\u0430,
    \u0430 \u0438\u0445 \u043E\u0442\u0446\u044B \u0432\u043C\u0435\u0441\u0442\u0435
    \u0441\u043B\u0443\u0436\u0438\u043B\u0438 \u0432 \u043E\u043F\u043E\u043B\u0447\u0435\u043D\u0438\u0438
    \u0432 1812 \u0433\u043E\u0434\u0443.  ### \U0001F56F\uFE0F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0434\u043D\u0438  \u041F\u0430\u0444\u043D\u0443\u0442\u0438\u0439 \u041B\u044C\u0432\u043E\u0432\u0438\u0447
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F
    8 \u0434\u0435\u043A\u0430\u0431\u0440\u044F 1894 \u0433\u043E\u0434\u0430 \u0432
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0435. \u041E\u043D, \u043A\u0430\u043A
    \u0432\u0441\u0435\u0433\u0434\u0430, \u0432\u0441\u0442\u0430\u043B \u0443\u0442\u0440\u043E\u043C,
    \u043E\u0434\u0435\u043B\u0441\u044F \u0438 \u0437\u0430\u0432\u0430\u0440\u0438\u043B
    \u0441\u0435\u0431\u0435 \u0447\u0430\u0439. \u041A\u043E\u0433\u0434\u0430 \u0441\u043B\u0443\u0433\u0430
    \u0432\u043E\u0448\u0435\u043B \u0432 \u043A\u043E\u043C\u043D\u0430\u0442\u0443,
    \u043E\u043D \u043D\u0430\u0448\u0435\u043B \u0443\u0447\u0435\u043D\u043E\u0433\u043E
    \u0443\u0436\u0435 \u043C\u0451\u0440\u0442\u0432\u044B\u043C, \u0441\u0438\u0434\u044F\u0449\u0438\u043C
    \u0437\u0430 \u0441\u0442\u043E\u043B\u043E\u043C \u0441 \u0447\u0430\u0448\u043A\u043E\u0439
    \u0447\u0430\u044F \u0432 \u0440\u0443\u043A\u0435. \u041F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u043E\u043D \u0432 \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u043C \u0441\u043A\u043B\u0435\u043F\u0435
    \u0432 \u0441\u0435\u043B\u0435 \u0421\u043F\u0430\u0441-\u041F\u0440\u043E\u0433\u043D\u0430\u043D\u044C\u0435
    (\u041A\u0430\u043B\u0443\u0436\u0441\u043A\u0430\u044F \u043E\u0431\u043B\u0430\u0441\u0442\u044C),
    \u0433\u0434\u0435 \u043F\u043E\u043A\u043E\u044F\u0442\u0441\u044F \u0438 \u0435\u0433\u043E
    \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438."
  personalLifeEn: 
  shortBioRu: "\u041F\u0430\u0444\u043D\u0443\u0442\u0438\u0439 \u041B\u044C\u0432\u043E\u0432\u0438\u0447
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u2014 \u044D\u0442\u043E, \u0431\u0435\u0437
    \u043F\u0440\u0435\u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u0438\u044F,
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u0443\u043C\u043E\u0432 \u0432 \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043D\u0430\u0443\u043A\u0438,
    \u0440\u0443\u0441\u0441\u043A\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A
    \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A XIX \u0432\u0435\u043A\u0430,
    \u0447\u044C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0438
    \u043E\u0441\u043D\u043E\u0432\u044B \u0446\u0435\u043B\u044B\u0445 \u0440\u0430\u0437\u0434\u0435\u043B\u043E\u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u041E\u043D \u0431\u044B\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u044B\u043C \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u043A\u043E\u043C,
    \u043D\u043E \u0438 \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0438\u043C \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043E\u043C-\u043F\u0440\u0430\u043A\u0442\u0438\u043A\u043E\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0441\u0442\u0440\u0435\u043C\u0438\u043B\u0441\u044F
    \u0441\u043E\u0435\u0434\u0438\u043D\u0438\u0442\u044C \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0435
    \u043D\u0430\u0443\u043A\u0438 \u0441 \u0440\u0435\u0430\u043B\u044C\u043D\u044B\u043C\u0438
    \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u043C\u0438 \u0437\u0430\u0434\u0430\u0447\u0430\u043C\u0438. 
    \u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u044D\u0442\u043E\u0433\u043E \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0433\u043E\u0441\u044F
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E.  ### \U0001F4DC \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0440\u0430\u043D\u043D\u0438\u0435 \u0433\u043E\u0434\u044B (1821\u20131837) 
    \u041F\u0430\u0444\u043D\u0443\u0442\u0438\u0439 \u041B\u044C\u0432\u043E\u0432\u0438\u0447
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    **4 (16) \u043C\u0430\u044F 1821 \u0433\u043E\u0434\u0430** \u0432 \u0441\u0435\u043B\u0435
    **\u041E\u043A\u0430\u0442\u043E\u0432\u043E** \u0411\u043E\u0440\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0443\u0435\u0437\u0434\u0430 \u041A\u0430\u043B\u0443\u0436\u0441\u043A\u043E\u0439
    \u0433\u0443\u0431\u0435\u0440\u043D\u0438\u0438 (\u043D\u044B\u043D\u0435 \u0434\u0435\u0440\u0435\u0432\u043D\u044F
    \u0410\u043A\u0430\u0442\u043E\u0432\u043E \u0432 \u041A\u0430\u043B\u0443\u0436\u0441\u043A\u043E\u0439
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438). \u041E\u043D \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B
    \u0438\u0437 \u0441\u0442\u0430\u0440\u0438\u043D\u043D\u043E\u0433\u043E \u0434\u0432\u043E\u0440\u044F\u043D\u0441\u043A\u043E\u0433\u043E
    \u0440\u043E\u0434\u0430. \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u041B\u0435\u0432
    \u041F\u0430\u0432\u043B\u043E\u0432\u0438\u0447, \u0431\u044B\u043B \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u043E\u043C
    \u041E\u0442\u0435\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B 1812 \u0433\u043E\u0434\u0430.  \u041F\u0435\u0440\u0432\u043E\u043D\u0430\u0447\u0430\u043B\u044C\u043D\u043E\u0435
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435 \u0427\u0435\u0431\u044B\u0448\u0451\u0432
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u043C\u0430. \u041C\u0430\u0442\u044C,
    \u0410\u0433\u0440\u0430\u0444\u0435\u043D\u0430 \u0418\u0432\u0430\u043D\u043E\u0432\u043D\u0430,
    \u043E\u0431\u0443\u0447\u0438\u043B\u0430 \u0435\u0433\u043E \u0433\u0440\u0430\u043C\u043E\u0442\u0435,
    \u0430 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0435 \u0438 \u0444\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u043C\u0443
    \u044F\u0437\u044B\u043A\u0443 \u2014 \u0434\u0432\u043E\u044E\u0440\u043E\u0434\u043D\u0430\u044F
    \u0441\u0435\u0441\u0442\u0440\u0430. \u0421 \u0440\u0430\u043D\u043D\u0435\u0433\u043E
    \u0434\u0435\u0442\u0441\u0442\u0432\u0430 \u0443 \u043D\u0435\u0433\u043E \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u0436\u0438\u0432\u043E\u0439 \u0438\u043D\u0442\u0435\u0440\u0435\u0441 \u043A
    \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435: \u043E\u043D \u043B\u044E\u0431\u0438\u043B
    \u0440\u0430\u0437\u0431\u0438\u0440\u0430\u0442\u044C \u0438\u0433\u0440\u0443\u0448\u043A\u0438
    \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u044B, \u043F\u044B\u0442\u0430\u044F\u0441\u044C
    \u043F\u043E\u043D\u044F\u0442\u044C, \u043A\u0430\u043A \u043E\u043D\u0438 \u0443\u0441\u0442\u0440\u043E\u0435\u043D\u044B,
    \u0438 \u0434\u0430\u0436\u0435 \u043C\u0430\u0441\u0442\u0435\u0440\u0438\u043B
    \u0438\u0445 \u0441\u0430\u043C.  \u0412 1832 \u0433\u043E\u0434\u0443 \u0441\u0435\u043C\u044C\u044F
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430 \u0432 \u041C\u043E\u0441\u043A\u0432\u0443,
    \u0447\u0442\u043E\u0431\u044B \u0434\u0430\u0442\u044C \u0434\u0435\u0442\u044F\u043C
    \u043B\u0443\u0447\u0448\u0435\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435.
    \u0422\u0430\u043C \u041F\u0430\u0444\u043D\u0443\u0442\u0438\u0439 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0441\u044F
    \u0441 \u043B\u0443\u0447\u0448\u0438\u043C\u0438 \u0447\u0430\u0441\u0442\u043D\u044B\u043C\u0438
    \u0443\u0447\u0438\u0442\u0435\u043B\u044F\u043C\u0438, \u0432 \u0442\u043E\u043C
    \u0447\u0438\u0441\u043B\u0435 \u0441 \u041F. \u041D. \u041F\u043E\u0433\u043E\u0440\u0435\u043B\u044C\u0441\u043A\u0438\u043C,
    \u0443 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u0442\u0430\u043A\u0436\u0435
    \u0443\u0447\u0438\u043B\u0441\u044F \u0418\u0432\u0430\u043D \u0422\u0443\u0440\u0433\u0435\u043D\u0435\u0432. 
    ### \U0001F393 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B \u0438 \u043D\u0430\u0447\u0430\u043B\u043E \u043D\u0430\u0443\u0447\u043D\u043E\u0433\u043E
    \u043F\u0443\u0442\u0438 (1837\u20131849)  \u0412 1837 \u0433\u043E\u0434\u0443,
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 16 \u043B\u0435\u0442,
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u043D\u0430 \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u043E\u0433\u043E
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442\u0430 **\u041C\u043E\u0441\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430**. \u0415\u0433\u043E
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C \u0441\u0442\u0430\u043B
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440 **\u041D\u0438\u043A\u043E\u043B\u0430\u0439
    \u0414\u043C\u0438\u0442\u0440\u0438\u0435\u0432\u0438\u0447 \u0411\u0440\u0430\u0448\u043C\u0430\u043D**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043A\u0430\u0437\u0430\u043B
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u0432\u043B\u0438\u044F\u043D\u0438\u0435
    \u043D\u0430 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432
    \u043C\u043E\u043B\u043E\u0434\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E,
    \u043F\u0440\u0438\u0432\u0438\u0432 \u0435\u043C\u0443 \u043B\u044E\u0431\u043E\u0432\u044C
    \u043A \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u043C \u0430\u0441\u043F\u0435\u043A\u0442\u0430\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0437\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u0443
    \u0441 \u0440\u0430\u0431\u043E\u0442\u0430\u043C\u0438 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430
    \u0416\u0430\u043D\u0430-\u0412\u0438\u043A\u0442\u043E\u0440\u0430 \u041F\u043E\u043D\u0441\u0435\u043B\u0435. 
    \u0423\u0436\u0435 \u0432 \u0441\u0442\u0443\u0434\u0435\u043D\u0447\u0435\u0441\u043A\u0438\u0435
    \u0433\u043E\u0434\u044B \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u0441\u0432\u043E\u0439 \u0442\u0430\u043B\u0430\u043D\u0442. \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430 **\xAB\u0412\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435
    \u043A\u043E\u0440\u043D\u0435\u0439 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439\xBB**
    (1838), \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u043E\u0431\u0449\u0438\u0439 \u043C\u0435\u0442\u043E\u0434 \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u043D\u043E\u0433\u043E
    \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F \u043A\u043E\u0440\u043D\u0435\u0439,
    \u0431\u044B\u043B\u0430 \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D\u0430
    **\u0441\u0435\u0440\u0435\u0431\u0440\u044F\u043D\u043E\u0439 \u043C\u0435\u0434\u0430\u043B\u0438**
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430.  \u0412
    1841 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u043A\u043E\u043D\u0447\u0438\u043B
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0441\u043E
    \u0437\u0432\u0430\u043D\u0438\u0435\u043C \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0430.
    \u0412 \u044D\u0442\u043E \u0432\u0440\u0435\u043C\u044F \u0435\u0433\u043E \u0441\u0435\u043C\u044C\u044F
    \u0440\u0430\u0437\u043E\u0440\u0438\u043B\u0430\u0441\u044C \u0438\u0437-\u0437\u0430
    \u043D\u0435\u0443\u0440\u043E\u0436\u0430\u044F, \u0438 \u0427\u0435\u0431\u044B\u0448\u0451\u0432
    \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u0431\u0435\u0437 \u0441\u0440\u0435\u0434\u0441\u0442\u0432
    \u043A \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044E.
    \u041E\u0434\u043D\u0430\u043A\u043E \u043E\u043D, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043A\u0440\u0430\u0439\u043D\u044E\u044E \u043D\u0443\u0436\u0434\u0443,
    \u043D\u0435 \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043D\u0430\u0443\u043A\u0443. 
    \u0412 1846 \u0433\u043E\u0434\u0443 \u043E\u043D \u0443\u0441\u043F\u0435\u0448\u043D\u043E
    \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u043C\u0430\u0433\u0438\u0441\u0442\u0435\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E **\xAB\u041E\u043F\u044B\u0442
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430\u0440\u043D\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439\xBB**.
    \u0412 \u044D\u0442\u043E\u043C \u0442\u0440\u0443\u0434\u0435 \u043E\u043D \u0434\u0430\u043B
    \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u041F\u0443\u0430\u0441\u0441\u043E\u043D\u0430,
    \u043E\u0434\u043D\u043E\u0433\u043E \u0438\u0437 \u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0431\u043E\u043B\u044C\u0448\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B, \u0438 \u0432\u0432\u0435\u043B \u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u043E\u0431\u043E\u0440\u043E\u0442 \u0441\u0432\u043E\u0435 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435
    **\u043D\u0435\u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u043E \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430**. 
    \u0412 1847 \u0433\u043E\u0434\u0443, \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043D\u044B\u0439
    \u0432 \u041C\u043E\u0441\u043A\u0432\u0435, \u043D\u043E \u043D\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u0432\u0448\u0438\u0439
    \u0442\u0430\u043C \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438, \u0427\u0435\u0431\u044B\u0448\u0451\u0432
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433,
    \u0433\u0434\u0435 \u0437\u0430\u0449\u0438\u0442\u0438\u043B \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    **\xAB\u041E\u0431 \u0438\u043D\u0442\u0435\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0438
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043B\u043E\u0433\u0430\u0440\u0438\u0444\u043C\u043E\u0432\xBB**
    \u0438 \u043D\u0430\u0447\u0430\u043B \u0447\u0438\u0442\u0430\u0442\u044C \u043B\u0435\u043A\u0446\u0438\u0438
    \u0432 **\u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435**. \u0412
    1849 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    **\xAB\u0422\u0435\u043E\u0440\u0438\u044F \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439\xBB**,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u0432\u044F\u0449\u0435\u043D\u0430
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B \u0438 \u043F\u0440\u0438\u043D\u0435\u0441\u043B\u0430
    \u0435\u043C\u0443 \u0414\u0435\u043C\u0438\u0434\u043E\u0432\u0441\u043A\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E. \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0441\u0442\u0430\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439,
    \u0447\u0442\u043E \u0434\u043E\u043B\u0433\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0441\u043B\u0443\u0436\u0438\u043B\u0430 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u043C
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C \u043F\u043E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B.  ### \U0001F3C6
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u043A \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440
    (1850\u20131882)  \u0412 1850 \u0433\u043E\u0434\u0443 \u0427\u0435\u0431\u044B\u0448\u0451\u0432
    \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430, \u0433\u0434\u0435
    \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0431\u043E\u043B\u0435\u0435
    30 \u043B\u0435\u0442. \u0415\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B\u0430\u0441\u044C: *   **1853
    \u0433\u043E\u0434** \u2014 \u0438\u0437\u0431\u0440\u0430\u043D \u0430\u0434\u044A\u044E\u043D\u043A\u0442\u043E\u043C,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u044D\u043A\u0441\u0442\u0440\u0430\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u043C \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A. *  
    **1856 \u0433\u043E\u0434** \u2014 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
    \u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u043C \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u043C. 
    \u041D\u0430\u0443\u0447\u043D\u044B\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430 \u043F\u043E\u0440\u0430\u0436\u0430\u043B\u0438
    \u0441\u0432\u043E\u0435\u0439 \u0448\u0438\u0440\u043E\u0442\u043E\u0439. \u041E\u043D
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0441\u043B\u0435\u0434 \u0432 \u0441\u0430\u043C\u044B\u0445 \u0440\u0430\u0437\u043D\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438. \u0415\u0433\u043E \u043F\u043E\u0434\u0445\u043E\u0434
    \u0431\u044B\u043B \u0443\u043D\u0438\u043A\u0430\u043B\u0435\u043D: \u043E\u043D
    \u0438\u0441\u043A\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u0434\u043B\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F
    \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u044B\u0445 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447, \u0438 \u044D\u0442\u043E \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B\u043E
    \u043A \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F\u043C \u043C\u0438\u0440\u043E\u0432\u043E\u0433\u043E
    \u0443\u0440\u043E\u0432\u043D\u044F.  ### \U0001F52C \u041D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F  #### 1. \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0438 \u0442\u0435\u043E\u0440\u0438\u044F
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u0439
    \u042D\u0442\u043E, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0441\u0430\u043C\u044B\u0439
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430. \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B
    **\u0442\u0435\u043E\u0440\u0438\u044E \u043D\u0430\u0438\u043B\u0443\u0447\u0448\u0435\u0433\u043E
    \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0435\u043D\u0438\u044F \u0444\u0443\u043D\u043A\u0446\u0438\u0439**
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432.
    \u0412 \u0445\u043E\u0434\u0435 \u0440\u0430\u0431\u043E\u0442\u044B \u043D\u0430\u0434
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u043C \u043F\u0430\u0440\u0430\u043B\u043B\u0435\u043B\u043E\u0433\u0440\u0430\u043C\u043C\u0430
    \u0423\u0430\u0442\u0442\u0430, \u043E\u043D \u043F\u0440\u0438\u0448\u0435\u043B
    \u043A \u0437\u0430\u0434\u0430\u0447\u0435 \u043E \u043F\u043E\u0438\u0441\u043A\u0435
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0431\u044B \u043C\u0438\u043D\u0438\u043C\u0430\u043B\u044C\u043D\u043E \u043E\u0442\u043A\u043B\u043E\u043D\u044F\u043B\u0441\u044F
    \u043E\u0442 \u043D\u0443\u043B\u044F \u043D\u0430 \u0437\u0430\u0434\u0430\u043D\u043D\u043E\u043C
    \u043E\u0442\u0440\u0435\u0437\u043A\u0435. \u0420\u0435\u0448\u0435\u043D\u0438\u0435\u043C
    \u0441\u0442\u0430\u043B\u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0435
    **\u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u044B \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442\u0441\u044F \u0432
    \u0441\u0430\u043C\u044B\u0445 \u0440\u0430\u0437\u043D\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445,
    \u043E\u0442 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0434\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0444\u0438\u043B\u044C\u0442\u0440\u043E\u0432. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    **\u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0442\u0438\u0432\u043D\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0444\u0443\u043D\u043A\u0446\u0438\u0439**
    \u0438 **\u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u0440\u0442\u043E\u0433\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u043E\u0432** (\u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u044B
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430-\u042D\u0440\u043C\u0438\u0442\u0430,
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430-\u041B\u0430\u0433\u0435\u0440\u0440\u0430). 
    #### 2. \u0422\u0435\u043E\u0440\u0438\u044F \u0447\u0438\u0441\u0435\u043B \u0427\u0435\u0431\u044B\u0448\u0451\u0432
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0440\u043E\u0440\u044B\u0432
    \u0432 \u0438\u0437\u0443\u0447\u0435\u043D\u0438\u0438 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B. \u0412
    \u0440\u0430\u0431\u043E\u0442\u0430\u0445 **\xAB\u041E\u0431 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0438
    \u0447\u0438\u0441\u043B\u0430 \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B,
    \u043D\u0435 \u043F\u0440\u0435\u0432\u043E\u0441\u0445\u043E\u0434\u044F\u0449\u0438\u0445
    \u0434\u0430\u043D\u043D\u043E\u0439 \u0432\u0435\u043B\u0438\u0447\u0438\u043D\u044B\xBB**
    (1848) \u0438 **\xAB\u041E \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u043B\u0430\u0445\xBB**
    (1850) \u043E\u043D \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u043F\u043E\u0441\u043B\u0435
    \u0415\u0432\u043A\u043B\u0438\u0434\u0430 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E
    \u043F\u0440\u043E\u0434\u0432\u0438\u043D\u0443\u043B\u0441\u044F \u0432 \u044D\u0442\u043E\u043C
    \u0432\u043E\u043F\u0440\u043E\u0441\u0435. \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043C\u0435\u0436\u0434\u0443 \u043B\u044E\u0431\u044B\u043C
    \u0447\u0438\u0441\u043B\u043E\u043C \u0438 \u0435\u0433\u043E \u0443\u0434\u0432\u043E\u0435\u043D\u0438\u0435\u043C
    \u0432\u0441\u0435\u0433\u0434\u0430 \u0435\u0441\u0442\u044C \u043F\u0440\u043E\u0441\u0442\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E (\u043F\u043E\u0441\u0442\u0443\u043B\u0430\u0442
    \u0411\u0435\u0440\u0442\u0440\u0430\u043D\u0430), \u0438 \u043F\u043E\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0447\u0438\u0441\u0435\u043B \u0434\u043E
    x \u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u0432\u0435\u0434\u0435\u0442 \u0441\u0435\u0431\u044F \u043A\u0430\u043A x/ln(x),
    \u0445\u043E\u0442\u044F \u0438 \u043D\u0435 \u0441\u043C\u043E\u0433 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u0441\u0430\u043C\u0443 \u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443\u043B\u0443 (\u044D\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043B\u0438
    \u0443\u0436\u0435 \u0432 \u043A\u043E\u043D\u0446\u0435 \u0432\u0435\u043A\u0430
    \u0410\u0434\u0430\u043C\u0430\u0440 \u0438 \u0412\u0430\u043B\u043B\u0435-\u041F\u0443\u0441\u0441\u0435\u043D).
    \u042D\u0442\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0441\u0434\u0435\u043B\u0430\u043B\u0438
    \u0435\u0433\u043E \u0438\u043C\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C
    \u0432\u043E \u0432\u0441\u0435\u0439 \u0415\u0432\u0440\u043E\u043F\u0435. 
    #### 3. \u0422\u0435\u043E\u0440\u0438\u044F \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u043F\u043E \u043F\u0440\u0430\u0432\u0443
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A\u043E\u043C
    \u0440\u0443\u0441\u0441\u043A\u043E\u0439 \u0448\u043A\u043E\u043B\u044B \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439. \u041E\u043D
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u0430\u043B \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0437\u0430\u043A\u043E\u043D\u0430 \u0431\u043E\u043B\u044C\u0448\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B, \u043D\u043E \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    **\xAB\u043C\u0435\u0442\u043E\u0434 \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u0432\xBB**,
    \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0434\u043E\u043A\u0430\u0437\u0430\u043B **\u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u0443\u044E
    \u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u0443\u044E \u0442\u0435\u043E\u0440\u0435\u043C\u0443**
    \u0432 \u0431\u043E\u043B\u0435\u0435 \u043E\u0431\u0449\u0435\u0439 \u0444\u043E\u0440\u043C\u0435,
    \u0447\u0435\u043C \u0442\u0435\u043E\u0440\u0435\u043C\u0430 \u041C\u0443\u0430\u0432\u0440\u0430-\u041B\u0430\u043F\u043B\u0430\u0441\u0430.
    \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u043B\u0438
    \u0442\u0435\u043E\u0440\u0438\u044E \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439
    \u0432 \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0443.  #### 4. \u0422\u0435\u043E\u0440\u0438\u044F
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432 \u0427\u0435\u0431\u044B\u0448\u0451\u0432
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F **\u043E\u0441\u043D\u043E\u0432\u043E\u043F\u043E\u043B\u043E\u0436\u043D\u0438\u043A\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0441\u0438\u043D\u0442\u0435\u0437\u0430
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432**. \u041E\u043D
    \u043F\u043E\u0434\u043E\u0448\u0435\u043B \u043A \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E
    \u043C\u0430\u0448\u0438\u043D \u043A\u0430\u043A \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0437\u0430\u0434\u0430\u0447\u0435: \u0441\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043B
    \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043D\u0438\u044F, \u043D\u0430\u0448\u0435\u043B
    \u043A\u0440\u0438\u0442\u0435\u0440\u0438\u0438 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0430
    \u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043C\u0435\u0442\u043E\u0434\u044B
    \u0440\u0430\u0441\u0447\u0435\u0442\u0430 \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u0430\u0440\u0430\u043C\u0435\u0442\u0440\u043E\u0432. \u0415\u0433\u043E
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u0430\u044F \u043C\u044B\u0441\u043B\u044C
    \u0431\u044B\u043B\u0430 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E
    \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u043E\u0439: *  
    \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0431\u043E\u043B\u0435\u0435
    **40 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432** \u0438 \u043E\u043A\u043E\u043B\u043E
    80 \u0438\u0445 \u043C\u043E\u0434\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0439.
    *   \u0421\u0440\u0435\u0434\u0438 \u0435\u0433\u043E \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0439:
    **\xAB\u0441\u0442\u043E\u043F\u043E\u0445\u043E\u0434\u044F\u0449\u0430\u044F\xBB
    \u043C\u0430\u0448\u0438\u043D\u0430** (\u0438\u043C\u0438\u0442\u0438\u0440\u043E\u0432\u0430\u0432\u0448\u0430\u044F
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0433\u043E),
    \u0433\u0440\u0435\u0431\u043D\u043E\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C,
    \u0441\u0430\u043C\u043E\u043A\u0430\u0442\u043D\u043E\u0435 \u043A\u0440\u0435\u0441\u043B\u043E,
    \u0441\u043E\u0440\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u044C\u043D\u0430\u044F
    \u043C\u0430\u0448\u0438\u043D\u0430, \u0430\u0440\u0438\u0444\u043C\u043E\u043C\u0435\u0442\u0440-\u043F\u043E\u043B\u0443\u0430\u0432\u0442\u043E\u043C\u0430\u0442.
    *   \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E **\u0448\u0430\u0440\u043D\u0438\u0440\u043D\u043E-\u0440\u044B\u0447\u0430\u0436\u043D\u044B\u0445
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432**, \u0432 \u0442\u043E\u043C
    \u0447\u0438\u0441\u043B\u0435 \u0434\u043B\u044F \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u043A\u0440\u0443\u0433\u043E\u0432\u043E\u0433\u043E \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F
    \u0432 \u043F\u0440\u044F\u043C\u043E\u043B\u0438\u043D\u0435\u0439\u043D\u043E\u0435
    (\u0438 \u043D\u0430\u043E\u0431\u043E\u0440\u043E\u0442).  ### \u2699\uFE0F
    \u041F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0435 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438 \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435 
    \u0422\u0430\u043B\u0430\u043D\u0442 \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430
    \u0431\u044B\u043B \u0432\u043E\u0441\u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043D
    \u043D\u0430 \u0433\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C
    \u0443\u0440\u043E\u0432\u043D\u0435. *   **\u0410\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u044F:**
    \u0412 \u0433\u043E\u0434\u044B \u041A\u0440\u044B\u043C\u0441\u043A\u043E\u0439
    \u0432\u043E\u0439\u043D\u044B (1853\u20131856) \u043E\u043D \u0431\u044B\u043B
    \u043F\u0440\u0438\u0432\u043B\u0435\u0447\u0435\u043D \u043A \u0440\u0430\u0431\u043E\u0442\u0435
    \u0432 \u0430\u0440\u0442\u0438\u043B\u043B\u0435\u0440\u0438\u0439\u0441\u043A\u043E\u043C
    \u0432\u0435\u0434\u043E\u043C\u0441\u0442\u0432\u0435. \u041E\u043D \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u043E\u0432\u044B\u0448\u0430\u043B\u0430 **\u0434\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C \u0441\u0442\u0440\u0435\u043B\u044C\u0431\u044B**,
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u043D\u043E\u0432\u0443\u044E,
    \u0431\u043E\u043B\u0435\u0435 \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u0443\u044E
    \u0444\u043E\u0440\u043C\u0443 \u0441\u043D\u0430\u0440\u044F\u0434\u0430. \u0415\u0433\u043E
    **\u0444\u043E\u0440\u043C\u0443\u043B\u0430 \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430**
    \u0434\u043B\u044F \u0440\u0430\u0441\u0447\u0435\u0442\u0430 \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438
    \u043F\u043E\u043B\u0435\u0442\u0430 \u0441\u043D\u0430\u0440\u044F\u0434\u0430
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0430\u0441\u044C
    \u0432 \u0431\u0430\u043B\u043B\u0438\u0441\u0442\u0438\u043A\u0435. *   **\u041F\u0440\u043E\u0441\u0432\u0435\u0449\u0435\u043D\u0438\u0435:**
    \u0421 1856 \u043F\u043E 1873 \u0433\u043E\u0434 \u043E\u043D \u0431\u044B\u043B
    \u0430\u043A\u0442\u0438\u0432\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u0423\u0447\u0435\u043D\u043E\u0433\u043E \u043A\u043E\u043C\u0438\u0442\u0435\u0442\u0430
    \u041C\u0438\u043D\u0438\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u0430 \u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0433\u043E
    \u043F\u0440\u043E\u0441\u0432\u0435\u0449\u0435\u043D\u0438\u044F. \u041E\u043D
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u0432 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0435
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0441\u043A\u043E\u0433\u043E
    \u0443\u0441\u0442\u0430\u0432\u0430 1863 \u0433\u043E\u0434\u0430, \u0440\u0435\u0446\u0435\u043D\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u0438 \u0438 \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u044B \u0434\u043B\u044F \u0448\u043A\u043E\u043B. 
    ### \U0001F3DB\uFE0F \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u0438
    \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    (1882\u20131894)  \u0412 1882 \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435
    35 \u043B\u0435\u0442 \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435,
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u0432\u044B\u0448\u0435\u043B \u0432
    \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0443, \u0447\u0442\u043E\u0431\u044B
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C
    \u0441\u0435\u0431\u044F \u043D\u0430\u0443\u0447\u043D\u044B\u043C \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\u043C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B
    \u0434\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0445 \u0434\u043D\u0435\u0439. 
    \u041F\u0440\u0438 \u0436\u0438\u0437\u043D\u0438 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043C\u0438\u0440\u043E\u0432\u043E\u0435 \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435.
    \u041E\u043D \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C **24 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u043D\u0430\u0443\u043A \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043E\u0431\u0449\u0435\u0441\u0442\u0432
    \u043C\u0438\u0440\u0430**, \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u0443\u044E,
    \u041F\u0430\u0440\u0438\u0436\u0441\u043A\u0443\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A, \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0435
    \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u043A\u043E\u0435 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E
    \u0438 \u0428\u0432\u0435\u0434\u0441\u043A\u0443\u044E \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u044E
    \u043D\u0430\u0443\u043A. \u0422\u0430\u043A\u0436\u0435 \u043E\u043D \u0431\u044B\u043B
    \u043F\u043E\u0447\u0435\u0442\u043D\u044B\u043C \u0447\u043B\u0435\u043D\u043E\u043C
    \u0432\u0441\u0435\u0445 \u0440\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u0438\u0445
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u043E\u0432. 
    \u0421\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F \u041F\u0430\u0444\u043D\u0443\u0442\u0438\u0439
    \u041B\u044C\u0432\u043E\u0432\u0438\u0447 **26 \u043D\u043E\u044F\u0431\u0440\u044F
    (8 \u0434\u0435\u043A\u0430\u0431\u0440\u044F) 1894 \u0433\u043E\u0434\u0430**
    \u0432 \u041F\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433\u0435. \u041F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D
    \u0432 \u0440\u043E\u0434\u043E\u0432\u043E\u043C \u0438\u043C\u0435\u043D\u0438\u0438
    \u0432 \u0441\u0435\u043B\u0435 \u0421\u043F\u0430\u0441-\u041F\u0440\u043E\u0433\u043D\u0430\u043D\u044C\u0435
    \u041A\u0430\u043B\u0443\u0436\u0441\u043A\u043E\u0439 \u0433\u0443\u0431\u0435\u0440\u043D\u0438\u0438. 
    ### \U0001F947 \u041F\u0430\u043C\u044F\u0442\u044C \u0418\u043C\u044F \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430
    \u0443\u0432\u0435\u043A\u043E\u0432\u0435\u0447\u0435\u043D\u043E \u0432 \u043D\u0430\u0443\u043A\u0435:
    \u0432 \u0435\u0433\u043E \u0447\u0435\u0441\u0442\u044C \u043D\u0430\u0437\u0432\u0430\u043D\u044B
    \u043C\u043D\u043E\u0433\u043E\u0447\u043B\u0435\u043D\u044B, \u043D\u0435\u0440\u0430\u0432\u0435\u043D\u0441\u0442\u0432\u043E,
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043A\u0440\u0430\u0442\u0435\u0440 \u043D\u0430 \u041B\u0443\u043D\u0435 \u0438
    \u0430\u0441\u0442\u0435\u0440\u043E\u0438\u0434. \u0412 1944 \u0433\u043E\u0434\u0443
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u044F \u043D\u0430\u0443\u043A \u0421\u0421\u0421\u0420
    \u0443\u0447\u0440\u0435\u0434\u0438\u043B\u0430 \u043F\u0440\u0435\u043C\u0438\u044E
    \u0438\u043C\u0435\u043D\u0438 \u041F. \u041B. \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430,
    \u0430 \u0441 1997 \u0433\u043E\u0434\u0430 \u0420\u0410\u041D \u0432\u0440\u0443\u0447\u0430\u0435\u0442
    **\u0417\u043E\u043B\u043E\u0442\u0443\u044E \u043C\u0435\u0434\u0430\u043B\u044C
    \u0438\u043C\u0435\u043D\u0438 \u041F. \u041B. \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0430**
    \u0437\u0430 \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u0435\u0441\u044F \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0412\u043E\u0442 \u043F\u043E\u0434\u0431\u043E\u0440\u043A\u0430
    \u0441\u0430\u043C\u044B\u0445 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0445
    \u0438 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0445 \u0444\u0430\u043A\u0442\u043E\u0432
    \u0438\u0437 \u0436\u0438\u0437\u043D\u0438 \u044D\u0442\u043E\u0433\u043E \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u0435\u0433\u043E
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043A\u0430\u043A \u0433\u0435\u043D\u0438\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043D\u043E \u0438
    \u043A\u0430\u043A \u043E\u0447\u0435\u043D\u044C \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430.  ### \U0001F916 \u0418\u043D\u0436\u0435\u043D\u0435\u0440,
    \u043E\u043F\u0435\u0440\u0435\u0434\u0438\u0432\u0448\u0438\u0439 \u0432\u0440\u0435\u043C\u044F:
    \u043E\u0442\u0435\u0446 \u0440\u043E\u0431\u043E\u0442\u043E\u0442\u0435\u0445\u043D\u0438\u043A\u0438
    \u0438 \u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u044C \"\u0441\u0442\u043E\u043F\u043E\u0445\u043E\u0434\u0430\" 
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043E\u0431\u0440\u0430\u0437\u0430
    \u043A\u0430\u0431\u0438\u043D\u0435\u0442\u043D\u043E\u0433\u043E \u0443\u0447\u0435\u043D\u043E\u0433\u043E,
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u0431\u044B\u043B \u0441\u0442\u0440\u0430\u0441\u0442\u043D\u044B\u043C
    \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0430\u0442\u0435\u043B\u0435\u043C-\u043C\u0435\u0445\u0430\u043D\u0438\u043A\u043E\u043C.
    \u041E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0441\u0432\u044B\u0448\u0435
    **40 \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432** \u0438 \u043E\u043A\u043E\u043B\u043E
    **80 \u0438\u0445 \u043C\u043E\u0434\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u0439**.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u0430\u044F \"\u0437\u0432\u0435\u0437\u0434\u0430\"
    \u2014 **\u0441\u0442\u043E\u043F\u043E\u0445\u043E\u0434\u044F\u0449\u0430\u044F
    \u043C\u0430\u0448\u0438\u043D\u0430**, \u043A\u043E\u0442\u043E\u0440\u0443\u044E
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \"\u043F\u0440\u0430\u0434\u0435\u0434\u0443\u0448\u043A\u043E\u0439\"
    \u0432\u0441\u0435\u0445 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445
    \u0448\u0430\u0433\u0430\u044E\u0449\u0438\u0445 \u0440\u043E\u0431\u043E\u0442\u043E\u0432.
    \u042D\u0442\u043E\u0442 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C, \u0438\u043C\u0438\u0442\u0438\u0440\u0443\u044E\u0449\u0438\u0439
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435 \u043B\u043E\u0448\u0430\u0434\u0438,
    \u0431\u044B\u043B \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D
    \u043D\u0430 \u0412\u0441\u0435\u043C\u0438\u0440\u043D\u043E\u0439 \u0432\u044B\u0441\u0442\u0430\u0432\u043A\u0435
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u0432 1878 \u0433\u043E\u0434\u0443
    \u0438 \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B \u043F\u0443\u0431\u043B\u0438\u043A\u0443
    \u0432 \u043F\u043E\u043B\u043D\u044B\u0439 \u0432\u043E\u0441\u0442\u043E\u0440\u0433. 
    \u0421\u0440\u0435\u0434\u0438 \u0435\u0433\u043E \u0434\u0440\u0443\u0433\u0438\u0445
    \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0434\u043B\u044F XIX \u0432\u0435\u043A\u0430 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u0439:
    *   **\u0421\u0430\u043C\u043E\u043A\u0430\u0442\u043D\u043E\u0435 \u043A\u0440\u0435\u0441\u043B\u043E**
    \u2014 \u043F\u043E \u0441\u0443\u0442\u0438, \u043F\u0440\u043E\u043E\u0431\u0440\u0430\u0437
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0438\u043D\u0432\u0430\u043B\u0438\u0434\u043D\u043E\u0439
    \u043A\u043E\u043B\u044F\u0441\u043A\u0438. *   **\u0410\u0440\u0438\u0444\u043C\u043E\u043C\u0435\u0442\u0440
    \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0433\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F**
    \u2014 \u043F\u0435\u0440\u0432\u044B\u0439 \u0432 \u043C\u0438\u0440\u0435 \u0441\u0447\u0435\u0442\u043D\u044B\u0439
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442, \u0440\u0430\u0431\u043E\u0442\u0430\u0432\u0448\u0438\u0439
    \u0432 \u0431\u044B\u0441\u0442\u0440\u043E\u043C \u0442\u0435\u043C\u043F\u0435,
    \u0431\u043E\u043B\u0435\u0435 500 \u0432\u044B\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0439
    \u0432 \u0447\u0430\u0441. \u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E,
    \u0435\u0433\u043E \u043D\u0435 \u043E\u0446\u0435\u043D\u0438\u043B\u0438 \u043F\u043E
    \u0434\u043E\u0441\u0442\u043E\u0438\u043D\u0441\u0442\u0432\u0443, \u043D\u043E
    \u043E\u043D \u043F\u043E\u0434\u0442\u043E\u043B\u043A\u043D\u0443\u043B \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435
    \u043A\u0438\u0431\u0435\u0440\u043D\u0435\u0442\u0438\u043A\u0438. *   **\u0421\u043E\u0440\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u044C\u043D\u0430\u044F
    \u043C\u0430\u0448\u0438\u043D\u0430**, \u043C\u043E\u0434\u0435\u043B\u0438
    \u0433\u0440\u0435\u0431\u043D\u044B\u0445 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432
    \u0438 \u043C\u043D\u043E\u0433\u043E\u0435 \u0434\u0440\u0443\u0433\u043E\u0435. 
    ### \U0001F3A9 \"\u041F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u043C,
    \u0447\u0442\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A \u0438\u043C\u0435\u0435\u0442
    \u0444\u043E\u0440\u043C\u0443 \u0448\u0430\u0440\u0430...\"  \u042D\u0442\u0430
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u2014 \u043E\u0434\u0438\u043D \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0430\u043D\u0435\u043A\u0434\u043E\u0442\u043E\u0432 \u043E \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u0435.
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u043E\u043D \u0447\u0438\u0442\u0430\u043B
    \u0432 \u041F\u0430\u0440\u0438\u0436\u0435 \u0434\u043E\u043A\u043B\u0430\u0434
    \u043D\u0430 \u0442\u0435\u043C\u0443 **\"\u041E \u043A\u0440\u043E\u0439\u043A\u0435
    \u043E\u0434\u0435\u0436\u0434\u044B\"** (\u044D\u0442\u043E \u0431\u044B\u043B\u0430
    \u0440\u0430\u0431\u043E\u0442\u0430 \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438). \u041D\u0430 \u043B\u0435\u043A\u0446\u0438\u044E,
    \u043F\u0440\u043E\u0441\u043B\u044B\u0448\u0430\u0432 \u043F\u0440\u043E \u043E\u0434\u0435\u0436\u0434\u0443,
    \u0441\u043E\u0431\u0440\u0430\u043B\u0430\u0441\u044C \u0446\u0435\u043B\u0430\u044F
    \u0442\u043E\u043B\u043F\u0430 \u043F\u043E\u0440\u0442\u043D\u044B\u0445 \u0438
    \u0437\u0430\u043A\u0440\u043E\u0439\u0449\u0438\u043A\u043E\u0432. \u0423\u0447\u0435\u043D\u044B\u0439
    \u0432\u044B\u0448\u0435\u043B \u043A \u043D\u0438\u043C \u0438 \u0441\u043A\u0430\u0437\u0430\u043B:
    **\"\u0414\u043B\u044F \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u044B, \u0434\u0430\u043C\u044B
    \u0438 \u0433\u043E\u0441\u043F\u043E\u0434\u0430, \u043F\u0440\u0435\u0434\u043F\u043E\u043B\u043E\u0436\u0438\u043C,
    \u0447\u0442\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0435
    \u0442\u0435\u043B\u043E \u0438\u043C\u0435\u0435\u0442 \u0444\u043E\u0440\u043C\u0443
    \u0448\u0430\u0440\u0430...\"**. \u041F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0439
    \u0444\u0440\u0430\u0437\u044B \u0437\u0430\u043B \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u043D\u043E
    \u043E\u043F\u0443\u0441\u0442\u0435\u043B \u2014 \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C
    \u0442\u043E\u043B\u044C\u043A\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u041E\u0434\u043D\u0430\u043A\u043E, \u0438\u0440\u043E\u043D\u0438\u044F \u0441\u0443\u0434\u044C\u0431\u044B:
    \u0444\u043E\u0440\u043C\u0443\u043B\u044B, \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u044B\u0435
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432\u044B\u043C, \u043F\u043E\u0442\u043E\u043C
    \u043F\u0440\u0438\u0433\u043E\u0434\u0438\u043B\u0438\u0441\u044C \u043D\u0435
    \u043F\u043E\u0440\u0442\u043D\u044B\u043C, \u0430 \u0434\u043B\u044F \u0448\u0438\u0442\u044C\u044F
    \u0432\u043E\u0437\u0434\u0443\u0448\u043D\u044B\u0445 \u0448\u0430\u0440\u043E\u0432. 
    ### \U0001F4D0 \u041F\u0430\u0440\u0430\u0434\u043E\u043A\u0441 \u0444\u0430\u043C\u0438\u043B\u0438\u0438
    \u0438 \u0434\u0435\u0442\u0441\u043A\u0430\u044F \u0445\u0440\u043E\u043C\u043E\u0442\u0430 
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u0441\u0430\u043C
    \u0443\u0447\u0435\u043D\u044B\u0439 **\u0432\u0441\u0435\u0433\u0434\u0430 \u043D\u0430\u0441\u0442\u0430\u0438\u0432\u0430\u043B
    \u043D\u0430 \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u0438\u0438 \u0441\u0432\u043E\u0435\u0439
    \u0444\u0430\u043C\u0438\u043B\u0438\u0438 \u0447\u0435\u0440\u0435\u0437 \u0431\u0443\u043A\u0432\u0443
    \"\u0451\"** \u2014 \u0427\u0435\u0431\u044B\u0448\u0451\u0432. \u042D\u0442\u043E
    \u043F\u0440\u0430\u0432\u0438\u043B\u043E \u0447\u0435\u0442\u043A\u043E \u0441\u043E\u0431\u043B\u044E\u0434\u0430\u0435\u0442\u0441\u044F
    \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043D\u0430\u0443\u043A\u0435. 
    \u0415\u0433\u043E \u0434\u0435\u0442\u0441\u0442\u0432\u043E \u0431\u044B\u043B\u043E
    \u043E\u043C\u0440\u0430\u0447\u0435\u043D\u043E \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043A\u043E\u043C \u2014 **\u0445\u0440\u043E\u043C\u043E\u0442\u043E\u0439
    \u043D\u0430 \u043E\u0434\u043D\u0443 \u043D\u043E\u0433\u0443**. \u0418\u0437-\u0437\u0430
    \u044D\u0442\u043E\u0433\u043E \u043E\u043D \u043D\u0435 \u043C\u043E\u0433 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u0432 \u043F\u043E\u0434\u0432\u0438\u0436\u043D\u044B\u0445 \u0438\u0433\u0440\u0430\u0445
    \u0441\u043E \u0441\u0432\u0435\u0440\u0441\u0442\u043D\u0438\u043A\u0430\u043C\u0438,
    \u0447\u0442\u043E \u043F\u0440\u0438\u0443\u0447\u0438\u043B\u043E \u0435\u0433\u043E
    \u043A \u0443\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044E \u0438 \u043D\u0430\u043F\u0440\u044F\u0436\u0435\u043D\u043D\u043E\u0439
    \u0443\u043C\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435,
    \u0438, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0438\u043C\u0435\u043D\u043D\u043E
    \u044D\u0442\u043E \u0440\u0430\u0437\u0432\u0438\u043B\u043E \u0435\u0433\u043E
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u0443\u044E \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C
    \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u043E\u0432. 
    ### \U0001F48E \u0421\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u044C,
    \u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0441\u0442\u044C \u0438
    \"\u0433\u0435\u043D\u0435\u0440\u0430\u043B\" \u043E\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 
    \u0427\u0435\u0431\u044B\u0448\u0451\u0432 \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C
    \u043A\u0440\u0430\u0439\u043D\u0435 \u0441\u043A\u0440\u043E\u043C\u043D\u044B\u043C
    \u0438 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u044B\u043C. \u041E\u043D \u0442\u0430\u043A
    \u0438 \u043D\u0435 \u0436\u0435\u043D\u0438\u043B\u0441\u044F \u0438 \u0432\u0435\u043B
    \u0430\u0441\u043A\u0435\u0442\u0438\u0447\u043D\u044B\u0439 \u043E\u0431\u0440\u0430\u0437
    \u0436\u0438\u0437\u043D\u0438, \u0441\u043D\u0438\u043C\u0430\u044F \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0443
    \u0438 \u0434\u0435\u0440\u0436\u0430 \u043B\u0438\u0448\u044C \u043E\u0434\u043D\u0443
    \u043A\u0443\u0445\u0430\u0440\u043A\u0443. \u041E\u043D \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u0436\u0430\u043B\u0435\u043B \u0434\u0435\u043D\u0435\u0433 \u043D\u0430
    \u0441\u0432\u043E\u0438 \u0438\u0437\u043E\u0431\u0440\u0435\u0442\u0435\u043D\u0438\u044F,
    \u043D\u043E, \u043F\u043E \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F\u043C
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u043E\u0432,
    \u043C\u043E\u0433 \u0447\u0430\u0441\u0430\u043C\u0438 \u0442\u043E\u0440\u0433\u043E\u0432\u0430\u0442\u044C\u0441\u044F
    \u0441 \u0438\u0437\u0432\u043E\u0437\u0447\u0438\u043A\u043E\u043C \u0438\u0437-\u0437\u0430
    \u043A\u043E\u043F\u0435\u0439\u043A\u0438. \u0415\u0433\u043E **\u0440\u0430\u0441\u0441\u0435\u044F\u043D\u043D\u043E\u0441\u0442\u044C**
    \u0432\u043E\u0448\u043B\u0430 \u0432 \u043B\u0435\u0433\u0435\u043D\u0434\u044B:
    \u043E\u0434\u043D\u0430\u0436\u0434\u044B, \u0441\u0438\u0434\u044F \u0443 \u0441\u0435\u0431\u044F
    \u0434\u043E\u043C\u0430 \u0441 \u0433\u043E\u0441\u0442\u044F\u043C\u0438, \u043E\u043D
    \u0432\u043D\u0435\u0437\u0430\u043F\u043D\u043E \u043F\u043E\u0434\u043D\u044F\u043B\u0441\u044F,
    \u043E\u0431\u044A\u044F\u0432\u0438\u043B, \u0447\u0442\u043E \u0443\u0441\u0442\u0430\u043B
    \u0438 \u0435\u043C\u0443 \u043F\u043E\u0440\u0430 \u0441\u043E\u0431\u0438\u0440\u0430\u0442\u044C\u0441\u044F
    **\u0434\u043E\u043C\u043E\u0439**, \u0438 \u043D\u0430\u0447\u0430\u043B \u043E\u0434\u0435\u0432\u0430\u0442\u044C\u0441\u044F
    \u043F\u0440\u044F\u043C\u043E \u043F\u0440\u0438 \u0432\u0441\u0435\u0445 \u0433\u043E\u0441\u0442\u044F\u0445. 
    \u041F\u0440\u0438 \u044D\u0442\u043E\u043C \u043E\u043D \u0431\u044B\u043B \u0437\u0430\u0431\u043E\u0442\u043B\u0438\u0432\u044B\u043C
    \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u043E\u043C \u0438 \u0434\u043E\u0431\u0438\u043B\u0441\u044F
    \u0438\u0437\u0431\u0440\u0430\u043D\u0438\u044F \u0421\u043E\u0444\u044C\u0438
    \u041A\u043E\u0432\u0430\u043B\u0435\u0432\u0441\u043A\u043E\u0439 \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A, \u043D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u043F\u0440\u0435\u0434\u0440\u0430\u0441\u0441\u0443\u0434\u043A\u0438
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438. \u0415\u0433\u043E
    \u0437\u0430\u0441\u043B\u0443\u0433\u0438 \u043F\u0440\u0438\u0437\u043D\u0430\u0432\u0430\u043B\u0438
    \u043F\u043E \u0432\u0441\u0435\u043C\u0443 \u043C\u0438\u0440\u0443: \u043E\u043D
    \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C 25 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0439
    \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u043E\u0431\u0449\u0435\u0441\u0442\u0432,
    \u0430 **\u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442 \u0424\u0440\u0430\u043D\u0446\u0438\u0438
    \u043B\u0438\u0447\u043D\u043E \u0432\u0440\u0443\u0447\u0438\u043B \u0435\u043C\u0443
    \u043A\u043E\u043C\u0430\u043D\u0434\u043E\u0440\u0441\u043A\u0438\u0439 \u043A\u0440\u0435\u0441\u0442
    \u043E\u0440\u0434\u0435\u043D\u0430 \u041F\u043E\u0447\u0435\u0442\u043D\u043E\u0433\u043E
    \u043B\u0435\u0433\u0438\u043E\u043D\u0430**.  ### \U0001F4DA \u0416\u0438\u0437\u043D\u044C
    \u0434\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0439 \u0441\u0435\u043A\u0443\u043D\u0434\u044B 
    \u0423\u043C\u0435\u0440 \u041F\u0430\u0444\u043D\u0443\u0442\u0438\u0439 \u041B\u044C\u0432\u043E\u0432\u0438\u0447
    **8 \u0434\u0435\u043A\u0430\u0431\u0440\u044F 1894 \u0433\u043E\u0434\u0430
    \u043F\u0440\u044F\u043C\u043E \u0437\u0430 \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u044B\u043C
    \u0441\u0442\u043E\u043B\u043E\u043C**. \u041E\u043D \u043F\u0435\u0440\u0435\u043D\u0435\u0441
    \u0433\u0440\u0438\u043F\u043F \u043D\u0430 \u043D\u043E\u0433\u0430\u0445, \u043D\u043E
    \u043D\u0435 \u043F\u0440\u0435\u043A\u0440\u0430\u0449\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C.
    \u0423\u0442\u0440\u043E\u043C \u043E\u043D, \u043A\u0430\u043A \u043E\u0431\u044B\u0447\u043D\u043E,
    \u043E\u0434\u0435\u043B\u0441\u044F, \u0437\u0430\u0432\u0430\u0440\u0438\u043B
    \u0441\u0435\u0431\u0435 \u0447\u0430\u0439, \u0438 \u043A\u043E\u0433\u0434\u0430
    \u0441\u043B\u0443\u0433\u0430 \u0432\u043E\u0448\u0435\u043B \u0432 \u043A\u043E\u043C\u043D\u0430\u0442\u0443,
    \u043E\u043D \u0443\u0436\u0435 \u0431\u044B\u043B \u043C\u0435\u0440\u0442\u0432,
    \u0441\u0438\u0434\u044F \u0441 \u0447\u0430\u0448\u043A\u043E\u0439 \u0433\u043E\u0440\u044F\u0447\u0435\u0433\u043E
    \u0447\u0430\u044F \u0432 \u0440\u0443\u043A\u0435."
