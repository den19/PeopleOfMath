  achievementsRu: "\u0420\u0438\u0445\u0430\u0440\u0434 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u0431\u044B\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432 \u0431\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E\u043C
    \u0441\u043C\u044B\u0441\u043B\u0435 \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0438\u043B\u0438
    \u044F\u0437\u044B\u043A \u0441\u0432\u043E\u0435\u0439 \u043D\u0430\u0443\u043A\u0438.
    \u0415\u0433\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u043D\u0435
    \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u043C\u0438 \u0442\u0435\u043E\u0440\u0435\u043C\u0430\u043C\u0438
    \u2014 \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u044B \u0438 \u0434\u0430\u043B
    \u0441\u0442\u0440\u043E\u0433\u0438\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0434\u043E \u043D\u0435\u0433\u043E \u0441\u0447\u0438\u0442\u0430\u043B\u0438\u0441\u044C
    \u0438\u043D\u0442\u0443\u0438\u0442\u0438\u0432\u043D\u043E \u044F\u0441\u043D\u044B\u043C\u0438.
    \u0412\u043A\u043B\u0430\u0434 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430
    \u043F\u0440\u043E\u0441\u0442\u0438\u0440\u0430\u0435\u0442\u0441\u044F \u043E\u0442
    \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u0434\u043E \u0441\u0430\u043C\u043E\u0439
    \u0441\u0435\u0440\u0434\u0446\u0435\u0432\u0438\u043D\u044B \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B.  ### \U0001F4D0 \u0421\u0442\u0440\u043E\u0433\u043E\u0435
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435 \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B  \u0413\u043B\u0430\u0432\u043D\u043E\u0439 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u0441\u0435\u0440\u0435\u0434\u0438\u043D\u044B
    XIX \u0432\u0435\u043A\u0430 \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u043E\u043F\u043E\u0440\u0430
    \u043D\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u044E, \u0430 \u043D\u0435 \u043D\u0430
    \u0441\u0442\u0440\u043E\u0433\u0443\u044E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0443.
    \u0420\u0430\u0431\u043E\u0442\u0430\u044F \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u0432 \u0426\u044E\u0440\u0438\u0445\u0435, \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u043E\u0449\u0443\u0442\u0438\u043B \u044D\u0442\u0443 \u043D\u0435\u0445\u0432\u0430\u0442\u043A\u0443
    \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u0438 \u043F\u0440\u0438 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0435
    \u043B\u0435\u043A\u0446\u0438\u0439 \u0438 \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043F\u0435\u0440\u0435\u0434 \u0441\u043E\u0431\u043E\u0439 \u0446\u0435\u043B\u044C
    \u0434\u0430\u0442\u044C \u0447\u0438\u0441\u0442\u043E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u0438. 
    \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C \u0435\u0433\u043E
    \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439 \u0441\u0442\u0430\u043B
    \u043F\u0440\u043E\u0440\u044B\u0432, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043D \u043E\u0441\u043E\u0437\u043D\u0430\u043B 24 \u043D\u043E\u044F\u0431\u0440\u044F
    1858 \u0433\u043E\u0434\u0430 \u0438 \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0432 1872 \u0433\u043E\u0434\u0443 \u0432 \u0440\u0430\u0431\u043E\u0442\u0435
    **\xAB\u041D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430\xBB** (*Stetigkeit und Irrationalzahlen*). \u0415\u0433\u043E
    \u043A\u043B\u044E\u0447\u0435\u0432\u0430\u044F \u0438\u0434\u0435\u044F \u2014
    **\u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u043E\u0432\u043E \u0441\u0435\u0447\u0435\u043D\u0438\u0435**. 
    \u0412\u043C\u0435\u0441\u0442\u043E \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442\u044C \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430 \u0447\u0435\u0440\u0435\u0437 \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0435
    \u0434\u0435\u0441\u044F\u0442\u0438\u0447\u043D\u044B\u0435 \u0434\u0440\u043E\u0431\u0438,
    \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0435:
    \u0435\u0441\u043B\u0438 \u0440\u0430\u0437\u0431\u0438\u0442\u044C \u0432\u0441\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u043D\u0430 \u0434\u0432\u0430 \u043D\u0435\u043F\u0443\u0441\u0442\u044B\u0445
    \u043A\u043B\u0430\u0441\u0441\u0430 `A` \u0438 `B` \u0442\u0430\u043A, \u0447\u0442\u043E
    \u043A\u0430\u0436\u0434\u043E\u0435 \u0447\u0438\u0441\u043B\u043E \u0438\u0437
    `A` \u043C\u0435\u043D\u044C\u0448\u0435 \u043B\u044E\u0431\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u0438\u0437 `B`, \u0442\u043E \u0442\u0430\u043A\u043E\u0435
    \u0441\u0435\u0447\u0435\u043D\u0438\u0435 **\u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u0442
    \u043E\u0434\u043D\u043E \u0438 \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u0434\u043D\u043E
    \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435 \u0447\u0438\u0441\u043B\u043E**.
    \u0415\u0441\u043B\u0438 \u0432 \u043A\u043B\u0430\u0441\u0441\u0435 `A` \u0435\u0441\u0442\u044C
    \u043D\u0430\u0438\u0431\u043E\u043B\u044C\u0448\u0435\u0435 \u0447\u0438\u0441\u043B\u043E
    (\u0438\u043B\u0438 \u0432 `B` \u2014 \u043D\u0430\u0438\u043C\u0435\u043D\u044C\u0448\u0435\u0435),
    \u0442\u043E \u044D\u0442\u043E \u0441\u0435\u0447\u0435\u043D\u0438\u0435 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u0435\u0442
    \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0447\u0438\u0441\u043B\u0443. \u0415\u0441\u043B\u0438 \u0436\u0435 \u043D\u0438
    \u043E\u0434\u0438\u043D \u0438\u0437 \u043A\u043B\u0430\u0441\u0441\u043E\u0432
    \u043D\u0435 \u0438\u043C\u0435\u0435\u0442 \u043A\u0440\u0430\u0439\u043D\u0435\u0433\u043E
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u0430, \u0442\u043E \u0441\u0435\u0447\u0435\u043D\u0438\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u0442 \u043D\u043E\u0432\u043E\u0435,
    \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0435
    \u0447\u0438\u0441\u043B\u043E. \u042D\u0442\u043E\u0442 \u043C\u0435\u0442\u043E\u0434
    \u0434\u0430\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435
    \u0431\u0435\u0437\u0443\u043F\u0440\u0435\u0447\u043D\u043E \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u0438
    \u0438 \xAB\u0437\u0430\u043F\u043E\u043B\u043D\u0438\u043B\xBB \u0432\u0441\u0435
    \u043F\u0440\u043E\u0431\u0435\u043B\u044B, \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u0432\u0448\u0438\u0435
    \u0432 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0435 \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B. \u0412\u043C\u0435\u0441\u0442\u0435 \u0441 \u0430\u043A\u0441\u0438\u043E\u043C\u043E\u0439
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430-\u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430,
    \u0443\u0441\u0442\u0430\u043D\u0430\u0432\u043B\u0438\u0432\u0430\u044E\u0449\u0435\u0439
    \u0432\u0437\u0430\u0438\u043C\u043D\u043E-\u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u043E\u0435
    \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435 \u043C\u0435\u0436\u0434\u0443
    \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    \u0447\u0438\u0441\u043B\u0430\u043C\u0438 \u0438 \u0442\u043E\u0447\u043A\u0430\u043C\u0438
    \u043F\u0440\u044F\u043C\u043E\u0439, \u044D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0437\u0430\u043B\u043E\u0436\u0438\u043B\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E \u0430\u043D\u0430\u043B\u0438\u0437\u0430. 
    ### \U0001F9F1 \u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B: \u041A\u043E\u043B\u044C\u0446\u0430
    \u0438 \u0418\u0434\u0435\u0430\u043B\u044B  \u0412\u0442\u043E\u0440\u044B\u043C
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u043C \u0432\u043A\u043B\u0430\u0434\u043E\u043C
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430 \u0441\u0442\u0430\u043B\u043E
    \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043E\u0441\u043D\u043E\u0432
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043E\u043D \u043E\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0438\u043B \u0432
    \u0440\u0430\u043C\u043A\u0430\u0445 \u0440\u0430\u0431\u043E\u0442 \u043F\u043E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B. \u0413\u043B\u0430\u0432\u043D\u0430\u044F
    \u0437\u0430\u0434\u0430\u0447\u0430 \u0432\u043E\u0437\u043D\u0438\u043A\u043B\u0430
    \u0438\u0437 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B, \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0439
    \u041A\u0443\u043C\u043C\u0435\u0440\u043E\u043C: \u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C\u0430\u0445 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0432 \u043A\u043E\u043B\u044C\u0446\u0435 \u0447\u0438\u0441\u0435\u043B \u0432\u0438\u0434\u0430
    `a + b\u221A-5`) \u043D\u0430\u0440\u0443\u0448\u0430\u0435\u0442\u0441\u044F
    \u043E\u0441\u043D\u043E\u0432\u043D\u0430\u044F \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438, \u0438 \u0447\u0438\u0441\u043B\u043E
    \u043D\u0435\u043B\u044C\u0437\u044F \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0440\u0430\u0437\u043B\u043E\u0436\u0438\u0442\u044C
    \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u043C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u0438.
    \u041A\u0443\u043C\u043C\u0435\u0440 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0434\u043B\u044F \u0438\u0441\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0438 \u0432\u0432\u0435\u0441\u0442\u0438
    \xAB\u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u0435 \u0447\u0438\u0441\u043B\u0430\xBB. 
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434 \u043F\u043E\u0434\u043E\u0448\u0435\u043B
    \u043A \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0435 \u0441 \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0438\u0430\u043B\u044C\u043D\u043E
    \u043D\u043E\u0432\u043E\u0439, \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u043E
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439 \u043F\u043E\u0437\u0438\u0446\u0438\u0438.
    \u0412\u043C\u0435\u0441\u0442\u043E \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B
    \u0432\u0432\u043E\u0434\u0438\u0442\u044C \u043C\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \xAB\u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B\u0435\xBB \u0447\u0438\u0441\u043B\u0430,
    \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u043D\u0435 \u0441\u0430\u043C\u0438 \u0447\u0438\u0441\u043B\u0430, \u0430
    **\u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u0447\u0438\u0441\u0435\u043B**,
    \u043E\u0431\u043B\u0430\u0434\u0430\u044E\u0449\u0438\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u044B\u043C\u0438
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\u043C\u0438. \u0412 1871 \u0433\u043E\u0434\u0443
    \u0432 \u0434\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u044F\u0445 \u043A
    \xAB\u0422\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B\xBB \u0414\u0438\u0440\u0438\u0445\u043B\u0435
    \u043E\u043D \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B \u044D\u0442\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u043A\u0430\u043A **\xAB\u0438\u0434\u0435\u0430\u043B\u044B\xBB**
    \u0438 \u0432\u0432\u0435\u043B \u043F\u043E\u043D\u044F\u0442\u0438\u0435 **\xAB\u043A\u043E\u043B\u044C\u0446\u0430\xBB**
    (\u0445\u043E\u0442\u044F \u0441\u0430\u043C \u0442\u0435\u0440\u043C\u0438\u043D
    \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u043F\u043E\u0437\u0436\u0435). 
    \u041F\u0440\u0435\u0438\u043C\u0443\u0449\u0435\u0441\u0442\u0432\u043E \u043F\u043E\u0434\u0445\u043E\u0434\u0430
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430 \u0431\u044B\u043B\u043E
    \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u043C:  1.  **\u0421\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C**:
    \u0418\u0434\u0435\u0430\u043B \u2014 \u044D\u0442\u043E \u0440\u0435\u0430\u043B\u044C\u043D\u043E
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0435 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0447\u0438\u0441\u0435\u043B \u0432 \u0438\u0437\u0443\u0447\u0430\u0435\u043C\u043E\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C\u0435, \u0430 \u043D\u0435 \u0433\u0438\u043F\u043E\u0442\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043E\u0431\u044A\u0435\u043A\u0442 \u0438\u0437\u0432\u043D\u0435. \u0421\u0430\u043C
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434 \u043F\u0438\u0441\u0430\u043B,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0438\u0434\u0435\u0430\u043B\u044B \xAB\u043D\u0430\u0441\u043B\u0430\u0436\u0434\u0430\u044E\u0442\u0441\u044F
    \u044F\u0441\u043D\u044B\u043C \u0441\u043E\u043B\u043D\u0435\u0447\u043D\u044B\u043C
    \u0441\u0432\u0435\u0442\u043E\u043C \u0440\u0435\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F\xBB.
    2.  **\u0412\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438**: \u0412
    \u0442\u0435\u043E\u0440\u0438\u0438, \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u043E\u0439
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u043E\u043C, \u043E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C,
    \u0447\u0442\u043E, \u0445\u043E\u0442\u044F \u0447\u0438\u0441\u043B\u0430 \u043C\u043E\u0433\u0443\u0442
    \u0440\u0430\u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0442\u044C\u0441\u044F
    \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u043C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u0438
    \u043D\u0435 \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u043B\u044E\u0431\u043E\u0439 \u043D\u0435\u043D\u0443\u043B\u0435\u0432\u043E\u0439
    \u0438\u0434\u0435\u0430\u043B \u0432 \u043A\u043E\u043B\u044C\u0446\u0435 **\u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C** \u0440\u0430\u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u0438\u0434\u0435\u0430\u043B\u044B.
    \u0422\u0430\u043A\u0438\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C, \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u043E \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438
    \u0431\u044B\u043B\u043E \u0441\u043F\u0430\u0441\u0435\u043D\u043E \u043D\u0430
    \u043D\u043E\u0432\u043E\u043C, \u0431\u043E\u043B\u0435\u0435 \u0432\u044B\u0441\u043E\u043A\u043E\u043C
    \u0443\u0440\u043E\u0432\u043D\u0435. 3.  **\u041E\u0431\u0449\u043D\u043E\u0441\u0442\u044C**:
    \u0415\u0433\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044F
    \u0431\u044B\u043B\u0438 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043D\u044B
    \u0438 \u043D\u0435 \u0437\u0430\u0432\u0438\u0441\u0435\u043B\u0438 \u043E\u0442
    \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0439 \u0444\u043E\u0440\u043C\u044B
    \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0447\u0438\u0441\u0435\u043B, \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C \u0438\u0445 \u043A \u0441\u0430\u043C\u044B\u043C
    \u0440\u0430\u0437\u043D\u044B\u043C \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.  \u042D\u0442\u043E\u0442
    \u043F\u043E\u0434\u0445\u043E\u0434 \u0441\u0442\u0430\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u0432\u0441\u0435\u0439 \u0431\u0443\u0434\u0443\u0449\u0435\u0439
    \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u044B.
    \u042D\u043C\u043C\u0438 \u041D\u0451\u0442\u0435\u0440, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B\u0430 \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435
    \u044D\u0442\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438 \u0432 XX \u0432\u0435\u043A\u0435,
    \u0447\u0430\u0441\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0430
    \u0441\u0432\u043E\u0438\u043C \u0441\u0442\u0443\u0434\u0435\u043D\u0442\u0430\u043C:
    **\xAB\u042D\u0442\u043E \u0443\u0436\u0435 \u0435\u0441\u0442\u044C \u0443 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430\xBB**,
    \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u0438\u0432\u0430\u044F, \u0447\u0442\u043E
    \u043C\u043D\u043E\u0433\u0438\u0435 \u0431\u0430\u0437\u043E\u0432\u044B\u0435
    \u0438\u0434\u0435\u0438 \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0432 \u0437\u0430\u0447\u0430\u0442\u043A\u0435
    \u043F\u0440\u0438\u0441\u0443\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
    \u0432 \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0445.  ### \U0001F522
    \u0410\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u043A\u0430 \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u044F 
    \u0412 \u0440\u0430\u0431\u043E\u0442\u0435 **\xAB\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435
    \u0447\u0438\u0441\u043B\u0430 \u0438 \u0434\u043B\u044F \u0447\u0435\u0433\u043E
    \u043E\u043D\u0438 \u0441\u043B\u0443\u0436\u0430\u0442?\xBB** (*Was sind und
    was sollen die Zahlen?*, 1888) \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u043E\u0431\u0440\u0430\u0442\u0438\u043B\u0441\u044F \u043A \u0441\u0430\u043C\u043E\u043C\u0443
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0443 \u2014 \u043F\u043E\u043D\u044F\u0442\u0438\u044E
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0447\u0438\u0441\u043B\u0430.
    \u0412 \u044D\u0442\u043E\u0439 \u043A\u043D\u0438\u0433\u0435 \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0440\u044F\u0434\u0430.  \u0412 \u0435\u0433\u043E \u043E\u0441\u043D\u043E\u0432\u0435
    \u043B\u0435\u0436\u0430\u043B\u043E \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \xAB\u0441\u0438\u0441\u0442\u0435\u043C\u044B\xBB (\u0442\u043E \u0435\u0441\u0442\u044C
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430) \u0438 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F.
    \u041E\u043D \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0435
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E \u043A\u0430\u043A \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E,
    \u0440\u0430\u0432\u043D\u043E\u043C\u043E\u0449\u043D\u043E\u0435 \u0441\u0432\u043E\u0435\u0439
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439 \u0447\u0430\u0441\u0442\u0438,
    \u0438 \u043D\u0430 \u044D\u0442\u043E\u0439 \u043E\u0441\u043D\u043E\u0432\u0435
    \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B \u0430\u043A\u0441\u0438\u043E\u043C\u044B
    \u0434\u043B\u044F \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u0447\u0435\u0440\u0435\u0437 \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \xAB\u0446\u0435\u043F\u044C\xBB \u0438 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u044E
    \xAB\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\xBB. \u0413\u043E\u0434
    \u0441\u043F\u0443\u0441\u0442\u044F \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435
    \u041F\u0435\u0430\u043D\u043E \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B
    \u0441\u0432\u043E\u044E, \u0441\u043B\u0435\u0433\u043A\u0430 \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u043D\u0443\u044E,
    \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u0430\u043A\u0441\u0438\u043E\u043C,
    \u0441\u043E\u0441\u043B\u0430\u0432\u0448\u0438\u0441\u044C \u043D\u0430 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430,
    \u0438 \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u044D\u0442\u0438 \u0430\u043A\u0441\u0438\u043E\u043C\u044B
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B \u043A\u0430\u043A **\u0430\u043A\u0441\u0438\u043E\u043C\u044B
    \u041F\u0435\u0430\u043D\u043E**.  \u042D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430
    \u0442\u0430\u043A\u0436\u0435 \u044F\u0440\u043A\u043E \u043E\u0442\u0440\u0430\u0436\u0430\u0435\u0442
    \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0443\u044E \u043F\u043E\u0437\u0438\u0446\u0438\u044E
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430: \u043E\u043D \u0431\u044B\u043B
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D, \u0447\u0442\u043E \u0447\u0438\u0441\u043B\u0430
    \u2014 \u044D\u0442\u043E \u043D\u0435 \u043F\u043B\u0430\u0442\u043E\u043D\u043E\u0432\u0441\u043A\u0438\u0435
    \u0441\u0443\u0449\u043D\u043E\u0441\u0442\u0438, \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0438\u0435
    \u0432 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E\u043C \u043C\u0438\u0440\u0435,
    \u0430 **\xAB\u0441\u0432\u043E\u0431\u043E\u0434\u043D\u044B\u0435 \u0442\u0432\u043E\u0440\u0435\u043D\u0438\u044F
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0440\u0430\u0437\u0443\u043C\u0430\xBB**, \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u044B\u0435
    \u0434\u043B\u044F \u0442\u043E\u0433\u043E, \u0447\u0442\u043E\u0431\u044B \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u043C \u0442\u043E\u0447\u043D\u043E\u0435
    \u0438 \u0441\u0442\u0440\u043E\u0433\u043E\u0435 \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0435. 
    ### \U0001F9E9 \u0414\u0440\u0443\u0433\u0438\u0435 \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F  \u041F\u043E\u043C\u0438\u043C\u043E
    \u0442\u0440\u0435\u0445 \u0441\u0442\u043E\u043B\u043F\u043E\u0432, \u0435\u0433\u043E
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 \u0432\u043A\u043B\u044E\u0447\u0430\u0435\u0442: 
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u044B\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439**: \u0412 \u043F\u0438\u0441\u044C\u043C\u0435
    \u0411\u043E\u0440\u0445\u0430\u0440\u0434\u0442\u0443 (1877) \u043E\u043D \u0443\u043A\u0430\u0437\u0430\u043B
    \u043D\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u0432\u0430\u0436\u043D\u043E\u0441\u0442\u044C \u0444\u0443\u043D\u043A\u0446\u0438\u0438
    `j` (\u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442), \u0447\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043D\u044B\u043C
    \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C \u0432 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0438
    \u0442\u0435\u043E\u0440\u0438\u0438 \u044D\u043B\u043B\u0438\u043F\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043C\u043E\u0434\u0443\u043B\u044F\u0440\u043D\u044B\u0445 \u0444\u0443\u043D\u043A\u0446\u0438\u0439.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0444\u0443\u043D\u043A\u0446\u0438\u0439**: \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0413. \u0412\u0435\u0431\u0435\u0440\u043E\u043C (1882) \u043E\u043D
    \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u043B \u0441\u0432\u043E\u0438 \u0438\u0434\u0435\u0430\u043B\u044B
    \u043A \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F\u043C, \u0441\u043E\u0437\u0434\u0430\u0432
    \u0442\u0435\u043E\u0440\u0438\u044E \xAB\u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u0435\u043B\u0438\u0442\u0435\u043B\u0435\u0439\xBB, \u0447\u0442\u043E
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E \u043F\u043E-\u043D\u043E\u0432\u043E\u043C\u0443
    \u043F\u043E\u0434\u043E\u0439\u0442\u0438 \u043A \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u0420\u0438\u043C\u0430\u043D\u0430-\u0420\u043E\u0445\u0430.
    *   **\u0420\u0435\u0434\u0430\u043A\u0442\u043E\u0440\u0441\u043A\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435**: \u041E\u043D \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B
    \u043C\u043D\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0438\u0437\u0434\u0430\u043D\u0438\u044E
    \u0438 \u043A\u043E\u043C\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044E
    \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0439 \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439
    \u0441\u0432\u043E\u0438\u0445 \u0432\u0435\u043B\u0438\u043A\u0438\u0445 \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u0439
    \u0438 \u0434\u0440\u0443\u0437\u0435\u0439 \u2014 \u0413\u0430\u0443\u0441\u0441\u0430,
    \u0414\u0438\u0440\u0438\u0445\u043B\u0435 \u0438 \u0420\u0438\u043C\u0430\u043D\u0430,
    \u0447\u0435\u043C \u043E\u043A\u0430\u0437\u0430\u043B \u043D\u0435\u043E\u0446\u0435\u043D\u0438\u043C\u0443\u044E
    \u0443\u0441\u043B\u0443\u0433\u0443 \u0438\u0441\u0442\u043E\u0440\u0438\u0438
    \u043D\u0430\u0443\u043A\u0438.  \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u043D\u0435 \u0438\u0441\u043A\u0430\u043B \u0432\u043D\u0435\u0448\u043D\u0435\u0433\u043E
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044F, \u043D\u043E \u0435\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u0441\u0442\u0430\u043B\u0438 \u0442\u0435\u043C
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u043E\u043C, \u043D\u0430
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0431\u044B\u043B\u0430 \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0430
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 XX \u0432\u0435\u043A\u0430.
    \u0415\u0433\u043E \u0438\u0434\u0435\u0438 \u043E \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430\u0445,
    \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0445 \u0438 \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u0438
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438
    \u0442\u0435\u043E\u0440\u0438\u044E \u0447\u0438\u0441\u0435\u043B, \u043D\u043E
    \u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0438 \u0441\u0430\u043C
    \u043C\u0435\u0442\u043E\u0434 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0420\u0438\u0445\u0430\u0440\u0434\u0430 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430
    \u0431\u044B\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0436\u0435 \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0439 \u0438 \u0440\u0430\u0437\u043C\u0435\u0440\u0435\u043D\u043D\u043E\u0439,
    \u043D\u0430\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0431\u044B\u043B\u0430
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
    \u0438 \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u043E\u0439. \u041E\u043D
    \u0431\u044B\u043B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0447\u0435\u0440\u043F\u0430\u043B \u0441\u0438\u043B\u044B \u0438 \u043D\u0430\u0445\u043E\u0434\u0438\u043B
    \u043F\u043E\u043B\u043D\u043E\u0435 \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u0435\u043D\u0438\u0435
    \u0432 \u0441\u0432\u043E\u0435\u043C \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u043C
    \u043A\u0440\u0443\u0433\u0443, \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u0435
    \u0438 \u0440\u043E\u0434\u043D\u043E\u043C \u0433\u043E\u0440\u043E\u0434\u0435,
    \u043D\u0435 \u0441\u0442\u0440\u0435\u043C\u044F\u0441\u044C \u043A \u0432\u043D\u0435\u0448\u043D\u0435\u043C\u0443
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044E \u0438 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u0430\u043C. 
    ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466 \u0421\u0435\u043C\u044C\u044F
    \u0438 \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435 
    \u0420\u0438\u0445\u0430\u0440\u0434 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434,
    \u043F\u043E\u043B\u043D\u043E\u0435 \u0438\u043C\u044F \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0431\u044B\u043B\u043E \u042E\u043B\u0438\u0443\u0441 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C
    \u0420\u0438\u0445\u0430\u0440\u0434, \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    6 \u043E\u043A\u0442\u044F\u0431\u0440\u044F 1831 \u0433\u043E\u0434\u0430 \u0432
    \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435 \u0432 \u0441\u0435\u043C\u044C\u0435
    \u0441 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C\u0438 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043A\u043E\u0440\u043D\u044F\u043C\u0438. \u041E\u043D \u0431\u044B\u043B \u043C\u043B\u0430\u0434\u0448\u0438\u043C
    \u0438\u0437 \u0447\u0435\u0442\u044B\u0440\u0435\u0445 \u0434\u0435\u0442\u0435\u0439.
    \u0415\u0433\u043E \u043E\u0442\u0435\u0446, \u042E\u043B\u0438\u0443\u0441 \u041B\u0435\u0432\u0438\u043D
    \u0423\u043B\u044C\u0440\u0438\u0445 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434,
    \u0431\u044B\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u043F\u0440\u0430\u0432\u0430 \u0438 \u0432\u0438\u0434\u043D\u044B\u043C \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440\u043E\u043C
    \u0432 \u043C\u0435\u0441\u0442\u043D\u043E\u043C \u041A\u043E\u043B\u043B\u0435\u0433\u0438\u0443\u043C\u0435
    \u041A\u0430\u0440\u043E\u043B\u0438\u043D\u0443\u043C. \u041C\u0430\u0442\u044C,
    \u041A\u0430\u0440\u043E\u043B\u0438\u043D\u0430 \u0413\u0435\u043D\u0440\u0438\u0435\u0442\u0442\u0430
    (\u0443\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u0430\u044F \u042D\u043C\u043F\u0435\u0440\u0438\u0443\u0441),
    \u0431\u044B\u043B\u0430 \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430,
    \u0442\u0430\u043A\u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u0432\u0448\u0435\u0433\u043E
    \u0432 \u044D\u0442\u043E\u043C \u0436\u0435 \u043A\u043E\u043B\u043B\u0435\u0433\u0438\u0443\u043C\u0435.
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u043F\u043E\u0432\u0437\u0440\u043E\u0441\u043B\u0435\u0432,
    \u0420\u0438\u0445\u0430\u0440\u0434 \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u043B
    \u043D\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
    \u0441\u0432\u043E\u0438 \u043F\u0435\u0440\u0432\u044B\u0435 \u0438\u043C\u0435\u043D\u0430
    \u2014 \u042E\u043B\u0438\u0443\u0441 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C,
    \u0438 \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D \u043F\u0440\u043E\u0441\u0442\u043E
    \u043A\u0430\u043A \u0420\u0438\u0445\u0430\u0440\u0434 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434. 
    \u0415\u0433\u043E \u0431\u0440\u0430\u0442 \u0410\u0434\u043E\u043B\u044C\u0444
    \u0441\u0442\u0430\u043B \u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u043E\u043A\u0440\u0443\u0436\u043D\u043E\u0433\u043E \u0441\u0443\u0434\u0430
    \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435. \u041E\u0434\u043D\u0430
    \u0438\u0437 \u0441\u0435\u0441\u0442\u0435\u0440, \u041C\u0430\u0442\u0438\u043B\u044C\u0434\u0430,
    \u0443\u043C\u0435\u0440\u043B\u0430 \u0432 1860 \u0433\u043E\u0434\u0443. \u0421\u0443\u0434\u044C\u0431\u0430
    \u0432\u0442\u043E\u0440\u043E\u0439 \u0441\u0435\u0441\u0442\u0440\u044B, \u042E\u043B\u0438\u0438,
    \u043E\u043A\u0430\u0437\u0430\u043B\u0430\u0441\u044C \u0442\u0435\u0441\u043D\u043E
    \u043F\u0435\u0440\u0435\u043F\u043B\u0435\u0442\u0435\u043D\u0430 \u0441 \u0436\u0438\u0437\u043D\u044C\u044E
    \u0441\u0430\u043C\u043E\u0433\u043E \u0420\u0438\u0445\u0430\u0440\u0434\u0430. 
    ### \U0001F3E0 \u0416\u0438\u0437\u043D\u044C \u0441 \u0441\u0435\u0441\u0442\u0440\u043E\u0439
    \u0438 \u043B\u0438\u0447\u043D\u044B\u0435 \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u044F 
    \u0412\u0441\u044E \u0441\u0432\u043E\u044E \u0432\u0437\u0440\u043E\u0441\u043B\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u0420\u0438\u0445\u0430\u0440\u0434 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0441\u044F \u0445\u043E\u043B\u043E\u0441\u0442\u044F\u043A\u043E\u043C.
    \u041C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u044B \u043E \u0435\u0433\u043E
    \u043B\u0438\u0447\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438 \u0441\u0445\u043E\u0434\u044F\u0442\u0441\u044F
    \u043D\u0430 \u0442\u043E\u043C, \u0447\u0442\u043E \u043E\u043D \u043F\u0440\u043E\u0436\u0438\u043B
    \u0434\u043E\u043B\u0433\u0438\u0435 \u0433\u043E\u0434\u044B \u0432\u043C\u0435\u0441\u0442\u0435
    \u0441\u043E \u0441\u0432\u043E\u0435\u0439 \u043D\u0435\u0437\u0430\u043C\u0443\u0436\u043D\u0435\u0439
    \u0441\u0435\u0441\u0442\u0440\u043E\u0439 \u042E\u043B\u0438\u0435\u0439 (Julie).
    \u0418\u0445 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B\u0430\u0441\u044C \u0432\u043F\u043B\u043E\u0442\u044C
    \u0434\u043E \u0441\u0430\u043C\u043E\u0439 \u0441\u043C\u0435\u0440\u0442\u0438
    \u042E\u043B\u0438\u0438 \u0432 1914 \u0433\u043E\u0434\u0443.  \u0421\u0435\u043C\u044C\u044F
    \u0438, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u0441\u0435\u0441\u0442\u0440\u0430
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u0437\u0430\u043C\u0435\u043D\u044F\u043B\u0438
    \u0435\u043C\u0443 \u0436\u0435\u043D\u0443 \u0438 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0434\u0435\u0442\u0435\u0439. \u0418\u0441\u0442\u043E\u0440\u0438\u043A\u0438
    \u043D\u0430\u0443\u043A\u0438 \u043E\u0442\u043C\u0435\u0447\u0430\u044E\u0442,
    \u0447\u0442\u043E \u0435\u0433\u043E \xAB\u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439,
    \u0437\u043D\u0430\u043A\u043E\u043C\u044B\u0439 \u043C\u0438\u0440\xBB \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0443\u0434\u043E\u0432\u043B\u0435\u0442\u0432\u043E\u0440\u044F\u043B \u0435\u0433\u043E
    \u0437\u0430\u043F\u0440\u043E\u0441\u044B, \u0438 \u0432 \u043D\u0435\u043C
    \u043E\u043D \u043D\u0430\u0445\u043E\u0434\u0438\u043B \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u0434\u043E\u0441\u0443\u0433\u0430 \u0438 \u0441\u0432\u043E\u0431\u043E\u0434\u044B
    \u0434\u043B\u044F \u0441\u0432\u043E\u0438\u0445 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439.
    \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u044B
    \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u0438\u0432\u0430\u044E\u0442, \u0447\u0442\u043E
    \u043E\u043D \u0441\u043E\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0438\u0433\u043D\u043E\u0440\u0438\u0440\u043E\u0432\u0430\u043B \u0432\u0441\u0435
    \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438 \u0434\u043B\u044F
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D \u0438\u043B\u0438 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u0431\u043E\u043B\u0435\u0435 \u0432\u044B\u0441\u043E\u043A\u043E\u0433\u043E
    \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u0438\u044F, \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u044F
    \u043E\u0441\u0442\u0430\u0432\u0430\u0442\u044C\u0441\u044F \u0432 \u043F\u0440\u0438\u0432\u044B\u0447\u043D\u043E\u0439
    \u0441\u0440\u0435\u0434\u0435. \u041E\u043D \u043D\u0435 \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u043F\u043E\u0442\u0440\u0435\u0431\u043D\u043E\u0441\u0442\u0438 \u0432 \u0441\u0430\u043C\u043E\u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0438
    \u0432\u043E \u0432\u043D\u0435\u0448\u043D\u0435\u043C \u043C\u0438\u0440\u0435,
    \u043F\u043E\u0441\u043A\u043E\u043B\u044C\u043A\u0443 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0440\u0435\u0430\u043B\u0438\u0437\u043E\u0432\u044B\u0432\u0430\u043B \u0441\u0435\u0431\u044F
    \u0432 \u043D\u0430\u0443\u043A\u0435. \u0418\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
    \u0447\u0442\u043E \u0435\u0433\u043E \u0441\u0435\u0441\u0442\u0440\u0430 \u042E\u043B\u0438\u044F
    \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B\u0430 \u0443\u0432\u0430\u0436\u0430\u0435\u043C\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435
    \u2014 \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043F\u0438\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u0438\u0446\u0435\u0439
    \u0438 \u0432 1893 \u0433\u043E\u0434\u0443 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430
    \u043C\u0435\u0441\u0442\u043D\u0443\u044E \u043B\u0438\u0442\u0435\u0440\u0430\u0442\u0443\u0440\u043D\u0443\u044E
    \u043F\u0440\u0435\u043C\u0438\u044E.  ### \U0001F4CD \u041D\u0435\u0441\u043F\u0435\u0448\u043D\u044B\u0439
    \u0445\u043E\u0434 \u0436\u0438\u0437\u043D\u0438 \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435 
    \u0412\u0441\u044F \u0436\u0438\u0437\u043D\u044C \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430
    \u0431\u044B\u043B\u0430 \u043F\u0440\u043E\u0447\u043D\u043E \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D\u0430
    \u043A \u0435\u0433\u043E \u0440\u043E\u0434\u043D\u043E\u043C\u0443 \u0433\u043E\u0440\u043E\u0434\u0443
    \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0443, \u0433\u0434\u0435
    \u043E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F, \u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u0447\u0430\u0441\u0442\u044C \u0436\u0438\u0437\u043D\u0438
    \u0438 \u0443\u043C\u0435\u0440. \u041F\u043E\u0441\u043B\u0435 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F \u0438 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435 \u0438 \u0426\u044E\u0440\u0438\u0445\u0435,
    \u0432 1862 \u0433\u043E\u0434\u0443 \u043E\u043D \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433, \u043F\u0440\u0438\u043D\u044F\u0432
    \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C \u0432 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u043D\u043E\u043C
    \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u043A\u0443\u043C\u0435
    (\u043D\u044B\u043D\u0435 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0441\u043A\u0438\u0439
    \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442),
    \u0433\u0434\u0435 \u043A\u043E\u0433\u0434\u0430-\u0442\u043E \u0443\u0447\u0438\u043B\u0441\u044F
    \u0435\u0433\u043E \u043E\u0442\u0435\u0446.  \u041E\u043D \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0434\u043E
    1894 \u0433\u043E\u0434\u0430, \u043F\u043E\u0441\u043B\u0435 \u0447\u0435\u0433\u043E
    \u0432\u044B\u0448\u0435\u043B \u043D\u0430 \u043F\u0435\u043D\u0441\u0438\u044E,
    \u043D\u043E \u0434\u0430\u0436\u0435 \u043F\u043E\u0441\u043B\u0435 \u044D\u0442\u043E\u0433\u043E
    \u0438\u043D\u043E\u0433\u0434\u0430 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B
    \u0447\u0438\u0442\u0430\u0442\u044C \u043B\u0435\u043A\u0446\u0438\u0438 \u0438
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044F\u043C\u0438.
    \u0415\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439 \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0439
    \u044D\u043F\u0438\u0437\u043E\u0434 \u043F\u043B\u043E\u0445\u043E\u0433\u043E
    \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F \u0441\u043B\u0443\u0447\u0438\u043B\u0441\u044F
    \u0441 \u043D\u0438\u043C \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E \u0447\u0435\u0440\u0435\u0437
    10 \u043B\u0435\u0442 \u043F\u043E\u0441\u043B\u0435 \u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0441\u043A\u0438\u0439
    \u043F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u043A\u0443\u043C, \u0432\u0441\u043A\u043E\u0440\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438 \u043E\u0442\u0446\u0430.
    \u041A \u0441\u0447\u0430\u0441\u0442\u044C\u044E, \u043E\u043D \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043E\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0438 \u0432 \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u043E\u043C,
    \u0432\u043F\u043B\u043E\u0442\u044C \u0434\u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439
    \u0441\u0442\u0430\u0440\u043E\u0441\u0442\u0438, \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u043B
    \u0445\u043E\u0440\u043E\u0448\u0435\u0435 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435. 
    \u0420\u0438\u0445\u0430\u0440\u0434 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 12 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    1916 \u0433\u043E\u0434\u0430 \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435
    \u0432 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 84 \u043B\u0435\u0442."
  personalLifeEn: 
  shortBioRu: "\u0420\u0438\u0445\u0430\u0440\u0434 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    (\u043F\u043E\u043B\u043D\u043E\u0435 \u0438\u043C\u044F \u2014 \u042E\u043B\u0438\u0443\u0441
    \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C \u0420\u0438\u0445\u0430\u0440\u0434
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434) \u2014 \u043E\u0434\u0438\u043D
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043D\u0435\u043C\u0435\u0446\u043A\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 XIX \u0432\u0435\u043A\u0430,
    \u0447\u044C\u0438 \u0438\u0434\u0435\u0438 \u0432\u043E \u043C\u043D\u043E\u0433\u043E\u043C
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u043B\u0438 \u043E\u0431\u043B\u0438\u043A
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u041E\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F 6 \u043E\u043A\u0442\u044F\u0431\u0440\u044F
    1831 \u0433\u043E\u0434\u0430 \u0438 \u0443\u043C\u0435\u0440 12 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    1916 \u0433\u043E\u0434\u0430 \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435,
    \u0433\u0434\u0435 \u0438 \u043F\u0440\u043E\u0448\u043B\u0430 \u0431\u043E\u043B\u044C\u0448\u0430\u044F
    \u0447\u0430\u0441\u0442\u044C \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438. 
    ### \U0001F9EC \u0421\u0435\u043C\u044C\u044F \u0438 \u0440\u0430\u043D\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B  \u0420\u0438\u0445\u0430\u0440\u0434 \u0431\u044B\u043B
    \u043C\u043B\u0430\u0434\u0448\u0438\u043C \u0438\u0437 \u0447\u0435\u0442\u044B\u0440\u0435\u0445
    \u0434\u0435\u0442\u0435\u0439 \u0432 \u0443\u0432\u0430\u0436\u0430\u0435\u043C\u043E\u0439
    \u0438 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u043D\u043E\u0439
    \u0441\u0435\u043C\u044C\u0435. \u0415\u0433\u043E \u043E\u0442\u0435\u0446,
    \u042E\u043B\u0438\u0443\u0441 \u041B\u0435\u0432\u0438\u043D \u0423\u043B\u044C\u0440\u0438\u0445
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434, \u0431\u044B\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u044E\u0440\u0438\u0441\u043F\u0440\u0443\u0434\u0435\u043D\u0446\u0438\u0438
    \u0438 \u0432\u0438\u0434\u043D\u044B\u043C \u0434\u0435\u044F\u0442\u0435\u043B\u0435\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438, \u043E\u043D \u044F\u0432\u043B\u044F\u043B\u0441\u044F
    \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440\u043E\u043C
    \u043C\u0435\u0441\u0442\u043D\u043E\u0433\u043E \u041A\u043E\u043B\u043B\u0435\u0433\u0438\u0443\u043C\u0430
    \u041A\u0430\u0440\u043E\u043B\u0438\u043D\u0443\u043C. \u041C\u0430\u0442\u044C,
    \u041A\u0430\u0440\u043E\u043B\u0438\u043D\u0430 \u0413\u0435\u043D\u0440\u0438\u0435\u0442\u0442\u0430
    (\u0443\u0440\u043E\u0436\u0434\u0435\u043D\u043D\u0430\u044F \u042D\u043C\u043F\u0435\u0440\u0438\u0443\u0441),
    \u0431\u044B\u043B\u0430 \u0434\u043E\u0447\u0435\u0440\u044C\u044E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430,
    \u0442\u0430\u043A\u0436\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u0432\u0448\u0435\u0433\u043E
    \u0432 \u044D\u0442\u043E\u043C \u043A\u043E\u043B\u043B\u0435\u0433\u0438\u0443\u043C\u0435. 
    \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0447\u0442\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441
    \u043A \u0442\u043E\u0447\u043D\u044B\u043C \u043D\u0430\u0443\u043A\u0430\u043C
    \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u0443 \u043D\u0435\u0433\u043E
    \u043D\u0435 \u0441\u0440\u0430\u0437\u0443. \u0412 \u0448\u043A\u043E\u043B\u0435
    \u0435\u0433\u043E \u0431\u043E\u043B\u044C\u0448\u0435 \u043F\u0440\u0438\u0432\u043B\u0435\u043A\u0430\u043B\u0438
    \u0444\u0438\u0437\u0438\u043A\u0430 \u0438 \u0445\u0438\u043C\u0438\u044F, \u043E\u0434\u043D\u0430\u043A\u043E
    \u0435\u0433\u043E \u043D\u0435 \u0443\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u043B\u0430
    \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u0430\u044F
    \u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u044C
    \u044D\u0442\u0438\u0445 \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D,
    \u0447\u0442\u043E \u0438 \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u0435\u0433\u043E
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443.  ### \U0001F393
    \u041F\u0443\u0442\u044C \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435:
    \u0423\u0447\u0435\u043D\u0438\u043A \u0413\u0430\u0443\u0441\u0441\u0430  \u0412
    1848 \u0433\u043E\u0434\u0443 \u0448\u0435\u0441\u0442\u043D\u0430\u0434\u0446\u0430\u0442\u0438\u043B\u0435\u0442\u043D\u0438\u0439
    \u0420\u0438\u0445\u0430\u0440\u0434 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u041A\u043E\u043B\u043B\u0435\u0433\u0438\u0443\u043C \u041A\u0430\u0440\u043E\u043B\u0438\u043D\u0443\u043C
    \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435, \u0433\u0434\u0435
    \u0438\u0437\u0443\u0447\u0430\u043B \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
    \u0438 \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u044C\u043D\u043E\u0435
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u0435, \u0430\u043D\u0430\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E \u0438 \u043E\u0441\u043D\u043E\u0432\u044B
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430. \u0412 1850 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0441\u043A\u043E\u043C
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0432 \u0442\u043E \u0432\u0440\u0435\u043C\u044F \u043D\u0435 \u0431\u044B\u043B
    \u0432\u0435\u0434\u0443\u0449\u0438\u043C \u0446\u0435\u043D\u0442\u0440\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 (\u0442\u0430\u043A\u043E\u0432\u044B\u043C
    \u0441\u0447\u0438\u0442\u0430\u043B\u0441\u044F \u0411\u0435\u0440\u043B\u0438\u043D),
    \u043D\u043E \u0442\u0430\u043C \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B
    \u0432\u0435\u043B\u0438\u043A\u0438\u0439 \u041A\u0430\u0440\u043B \u0424\u0440\u0438\u0434\u0440\u0438\u0445
    \u0413\u0430\u0443\u0441\u0441.  \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u0441\u0442\u0430\u043B \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u043C
    \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C \u0413\u0430\u0443\u0441\u0441\u0430.
    \u0412 \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 21 \u0433\u043E\u0434\u0430,
    \u0432 1852 \u0433\u043E\u0434\u0443, \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0437\u0430 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u044D\u0439\u043B\u0435\u0440\u043E\u0432\u044B\u0445
    \u0438\u043D\u0442\u0435\u0433\u0440\u0430\u043B\u043E\u0432. \u041E\u0434\u043D\u0430\u043A\u043E,
    \u043F\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u043C\u0443
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430,
    \u044D\u0442\u0430 \u0440\u0430\u0431\u043E\u0442\u0430 \u043D\u0435 \u0432 \u043F\u043E\u043B\u043D\u043E\u0439
    \u043C\u0435\u0440\u0435 \u0440\u0430\u0441\u043A\u0440\u044B\u043B\u0430 \u0435\u0433\u043E
    \u0442\u0430\u043B\u0430\u043D\u0442.  \u041E\u0441\u043E\u0437\u043D\u0430\u0432
    \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043A\u0438 \u0441\u0432\u043E\u0435\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F, \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u043F\u0440\u043E\u0432\u0435\u043B \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0435
    \u0434\u0432\u0430 \u0433\u043E\u0434\u0430 \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0435,
    \u0433\u0434\u0435 \u0441\u043B\u0443\u0448\u0430\u043B \u043B\u0435\u043A\u0446\u0438\u0438
    \u0432\u0435\u0434\u0443\u0449\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u2014 \u042D\u0440\u043D\u0441\u0442\u0430
    \u041A\u0443\u043C\u043C\u0435\u0440\u0430 \u0438 \u041B\u0435\u043E\u043F\u043E\u043B\u044C\u0434\u0430
    \u041A\u0440\u043E\u043D\u0435\u043A\u0435\u0440\u0430. \u0412\u0435\u0440\u043D\u0443\u0432\u0448\u0438\u0441\u044C
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D, \u0432 1854 \u0433\u043E\u0434\u0443
    \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0445\u0430\u0431\u0438\u043B\u0438\u0442\u0430\u0446\u0438\u044E
    (\u0432\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u0438\u0439 \u0434\u0438\u043F\u043B\u043E\u043C,
    \u0434\u0430\u044E\u0449\u0438\u0439 \u043F\u0440\u0430\u0432\u043E \u043D\u0430
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u0435 \u0432
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435) \u0438
    \u043D\u0430\u0447\u0430\u043B \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u043F\u0440\u0438\u0432\u0430\u0442-\u0434\u043E\u0446\u0435\u043D\u0442\u043E\u043C,
    \u0447\u0438\u0442\u0430\u044F \u043A\u0443\u0440\u0441\u044B \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0441\u0442\u0435\u0439 \u0438
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438.  \u0412 \u044D\u0442\u043E\u0442
    \u043F\u0435\u0440\u0438\u043E\u0434 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u0430
    \u0441\u0443\u0434\u044C\u0431\u043E\u043D\u043E\u0441\u043D\u0430\u044F \u0432\u0441\u0442\u0440\u0435\u0447\u0430.
    \u0412 1855 \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
    \u0413\u0430\u0443\u0441\u0441\u0430, \u0435\u0433\u043E \u043A\u0430\u0444\u0435\u0434\u0440\u0443
    \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435 \u0437\u0430\u043D\u044F\u043B
    \u041F\u0435\u0442\u0435\u0440 \u0413\u0443\u0441\u0442\u0430\u0432 \u041B\u0435\u0436\u0451\u043D-\u0414\u0438\u0440\u0438\u0445\u043B\u0435.
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u043E\u0441\u0435\u0449\u0430\u043B \u0435\u0433\u043E \u043B\u0435\u043A\u0446\u0438\u0438,
    \u043D\u043E \u0438 \u0441\u0442\u0430\u043B \u0435\u0433\u043E \u0431\u043B\u0438\u0437\u043A\u0438\u043C
    \u0434\u0440\u0443\u0433\u043E\u043C. \u041E\u043D \u043F\u0438\u0441\u0430\u043B,
    \u0447\u0442\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u0414\u0438\u0440\u0438\u0445\u043B\u0435
    \xAB\u0441\u0434\u0435\u043B\u0430\u043B \u0435\u0433\u043E \u043D\u043E\u0432\u044B\u043C
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u043E\u043C\xBB, \u0443\u043A\u0430\u0437\u0430\u043B
    \u043D\u0430 \u043F\u0440\u043E\u0431\u0435\u043B\u044B \u0432 \u0437\u043D\u0430\u043D\u0438\u044F\u0445
    \u0438 \u043F\u043E\u043C\u043E\u0433 \u0438\u0445 \u0432\u043E\u0441\u043F\u043E\u043B\u043D\u0438\u0442\u044C.
    \u0412\u043B\u0438\u044F\u043D\u0438\u0435 \u0414\u0438\u0440\u0438\u0445\u043B\u0435
    \u043D\u0430 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430 \u0442\u0440\u0443\u0434\u043D\u043E
    \u043F\u0435\u0440\u0435\u043E\u0446\u0435\u043D\u0438\u0442\u044C, \u0438 \u043F\u043E\u0437\u0436\u0435
    \u043E\u043D \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u0442 \u043C\u043D\u043E\u0433\u043E
    \u043B\u0435\u0442 \u0438\u0437\u0434\u0430\u043D\u0438\u044E \u0438 \u043F\u0435\u0440\u0435\u0440\u0430\u0431\u043E\u0442\u043A\u0435
    \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u043E\u0432.  ### \U0001F468\u200D\U0001F3EB
    \u041F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0430\u044F
    \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C \u0438
    \u0437\u0440\u0435\u043B\u044B\u0435 \u0433\u043E\u0434\u044B  \u0412 1858 \u0433\u043E\u0434\u0443
    \u043F\u043E \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u0438
    \u0414\u0438\u0440\u0438\u0445\u043B\u0435 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u044C
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430 \u0432 \u041F\u043E\u043B\u0438\u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435 \u0426\u044E\u0440\u0438\u0445\u0430 (\u043D\u044B\u043D\u0435
    \u0428\u0432\u0435\u0439\u0446\u0430\u0440\u0441\u043A\u0430\u044F \u0432\u044B\u0441\u0448\u0430\u044F
    \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u0448\u043A\u043E\u043B\u0430
    \u0426\u044E\u0440\u0438\u0445\u0430). \u0418\u043C\u0435\u043D\u043D\u043E \u0437\u0434\u0435\u0441\u044C,
    \u043F\u0440\u0438 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0435
    \u043A \u043B\u0435\u043A\u0446\u0438\u044F\u043C \u043F\u043E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u043C\u0443
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044E, \u043E\u043D \u0441\u0442\u043E\u043B\u043A\u043D\u0443\u043B\u0441\u044F
    \u0441 \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u0435\u043C \u0441\u0442\u0440\u043E\u0433\u043E\u0433\u043E
    \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u044F \u0430\u043D\u0430\u043B\u0438\u0437\u0430.
    \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C \u0435\u0433\u043E
    \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0439 \u0441\u0442\u0430\u043B\u043E
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0435 \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \xAB\u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u043E\u0432\u0430 \u0441\u0435\u0447\u0435\u043D\u0438\u044F\xBB,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043E\u043D \u043E\u0441\u043E\u0437\u043D\u0430\u043B
    24 \u043D\u043E\u044F\u0431\u0440\u044F 1858 \u0433\u043E\u0434\u0430.  \u0412
    1862 \u0433\u043E\u0434\u0443 \u043E\u043D \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F
    \u0432 \u0440\u043E\u0434\u043D\u043E\u0439 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433,
    \u043F\u0440\u0438\u043D\u044F\u0432 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435
    \u043E\u0442 \u0441\u0432\u043E\u0435\u0433\u043E \u0441\u0442\u0430\u0440\u043E\u0433\u043E
    \u043A\u043E\u043B\u043B\u0435\u0434\u0436\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043A \u0442\u043E\u043C\u0443 \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0431\u044B\u043B
    \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D \u0432
    \u0412\u044B\u0441\u0448\u0443\u044E \u0442\u0435\u0445\u043D\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443 (Braunschweig Polytechnikum). \u0412 \u044D\u0442\u043E\u043C
    \u0443\u0447\u0435\u0431\u043D\u043E\u043C \u0437\u0430\u0432\u0435\u0434\u0435\u043D\u0438\u0438
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434 \u043F\u0440\u043E\u0440\u0430\u0431\u043E\u0442\u0430\u043B
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C \u0434\u043E
    1894 \u0433\u043E\u0434\u0430, \u0430 \u0437\u0430\u0442\u0435\u043C \u0432\u044B\u0448\u0435\u043B
    \u043D\u0430 \u043F\u0435\u043D\u0441\u0438\u044E, \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u044F
    \u0438\u0437\u0440\u0435\u0434\u043A\u0430 \u0447\u0438\u0442\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u0438 \u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F \u043D\u0430\u0443\u043A\u043E\u0439. 
    \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430
    \u0431\u044B\u043B\u0430 \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0439 \u0438
    \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0435\u043D\u0430
    \u0432\u043E\u043A\u0440\u0443\u0433 \u043D\u0430\u0443\u043A\u0438 \u0438 \u0441\u0435\u043C\u044C\u0438.
    \u041E\u043D \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0431\u044B\u043B
    \u0436\u0435\u043D\u0430\u0442 \u0438 \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C
    \u043F\u0440\u043E\u0436\u0438\u043B \u0441\u043E \u0441\u0432\u043E\u0435\u0439
    \u0441\u0435\u0441\u0442\u0440\u043E\u0439 \u042E\u043B\u0438\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0442\u0430\u043A\u0436\u0435 \u043D\u0435 \u0432\u044B\u0448\u043B\u0430 \u0437\u0430\u043C\u0443\u0436. 
    ### \U0001F4A1 \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435 
    \u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u0420\u0438\u0445\u0430\u0440\u0434\u0430 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430
    \u043E\u0433\u0440\u043E\u043C\u043D\u043E \u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E.
    \u0415\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u044B\u0435 \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043B\u0435\u0436\u0430\u0442 \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445 :  *   **\u0421\u0442\u0440\u043E\u0433\u043E\u0435
    \u043E\u0431\u043E\u0441\u043D\u043E\u0432\u0430\u043D\u0438\u0435 \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B (\xAB\u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u043E\u0432\u044B
    \u0441\u0435\u0447\u0435\u043D\u0438\u044F\xBB)**: \u0412 \u0441\u0432\u043E\u0435\u0439
    \u0440\u0430\u0431\u043E\u0442\u0435 \xAB\u041D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u043E\u0441\u0442\u044C
    \u0438 \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0435
    \u0447\u0438\u0441\u043B\u0430\xBB (1872) \u043E\u043D \u0434\u0430\u043B \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u0438\u0440\u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0447\u0438\u0441\u043B\u0430 \u043A\u0430\u043A \xAB\u0441\u0435\u0447\u0435\u043D\u0438\u044F\xBB
    (\u0440\u0430\u0437\u0431\u0438\u0435\u043D\u0438\u044F) \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0432\u0441\u0435\u0445 \u0440\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B \u043D\u0430 \u0434\u0432\u0430 \u043A\u043B\u0430\u0441\u0441\u0430.
    \u042D\u0442\u0430 \u0438\u0434\u0435\u044F \u0441\u0442\u0430\u043B\u0430 \u043E\u0441\u043D\u043E\u0432\u043E\u0439
    \u0434\u043B\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430, \u0430 \u0441\u0430\u043C \u043C\u0435\u0442\u043E\u0434,
    \u043D\u0430\u0437\u044B\u0432\u0430\u0435\u043C\u044B\u0439 \xAB\u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u043E\u0432\u044B\u043C
    \u0441\u0435\u0447\u0435\u043D\u0438\u0435\u043C\xBB, \u0434\u043E \u0441\u0438\u0445
    \u043F\u043E\u0440 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0441\u043F\u043E\u0441\u043E\u0431\u043E\u043C \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0445
    \u0447\u0438\u0441\u0435\u043B. *   **\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043E\u0441\u043D\u043E\u0432 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B**: \u0412 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0445
    \u0434\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u044F\u0445 \u043A \u043B\u0435\u043A\u0446\u0438\u044F\u043C
    \u0414\u0438\u0440\u0438\u0445\u043B\u0435 \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B (\u0438\u0437\u0434\u0430\u043D\u0438\u044F 1879
    \u0438 1894 \u0433\u043E\u0434\u043E\u0432) \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u0432\u0432\u0435\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043F\u043E\u043D\u044F\u0442\u0438\u044F \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u2014 **\u0438\u0434\u0435\u0430\u043B**
    \u0438 **\u043A\u043E\u043B\u044C\u0446\u043E** (\u0445\u043E\u0442\u044F \u0442\u0435\u0440\u043C\u0438\u043D
    \xAB\u043A\u043E\u043B\u044C\u0446\u043E\xBB \u0431\u044B\u043B \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D
    \u043F\u043E\u0437\u0436\u0435 \u0413\u0438\u043B\u044C\u0431\u0435\u0440\u0442\u043E\u043C).
    \u0422\u0435\u043E\u0440\u0438\u044F \u0438\u0434\u0435\u0430\u043B\u043E\u0432
    \u0431\u044B\u043B\u0430 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043D\u0430
    \u0438\u043C \u0434\u043B\u044F \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u044F
    \u0442\u0435\u043E\u0440\u0435\u043C\u044B \u043E \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u0440\u0430\u0437\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u044B\u0435
    \u043C\u043D\u043E\u0436\u0438\u0442\u0435\u043B\u0438 \u0432 \u043F\u043E\u043B\u044F\u0445
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B, \u0433\u0434\u0435 \u044D\u0442\u0430 \u0442\u0435\u043E\u0440\u0435\u043C\u0430,
    \u0432\u043E\u043E\u0431\u0449\u0435 \u0433\u043E\u0432\u043E\u0440\u044F, \u043D\u0435
    \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442. *   **\u0410\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u043A\u0430
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B**:
    \u0412 \u0440\u0430\u0431\u043E\u0442\u0435 \xAB\u0427\u0442\u043E \u0442\u0430\u043A\u043E\u0435
    \u0447\u0438\u0441\u043B\u0430 \u0438 \u0434\u043B\u044F \u0447\u0435\u0433\u043E
    \u043E\u043D\u0438 \u0441\u043B\u0443\u0436\u0430\u0442?\xBB (1888) \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0430\u043A\u0441\u0438\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u043D\u0430\u0442\u0443\u0440\u0430\u043B\u044C\u043D\u044B\u0445 \u0447\u0438\u0441\u0435\u043B,
    \u0432\u0432\u0435\u0434\u044F \u043F\u043E\u043D\u044F\u0442\u0438\u044F \xAB\u0435\u0434\u0438\u043D\u0438\u0446\u044B\xBB
    \u0438 \xAB\u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438 \u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F\xBB.
    \u042D\u0442\u0430 \u0441\u0438\u0441\u0442\u0435\u043C\u0430, \u043D\u0435\u043C\u043D\u043E\u0433\u043E
    \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u043D\u0430\u044F, \u0431\u044B\u043B\u0430
    \u0432\u0441\u043A\u043E\u0440\u0435 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0430
    \u0414\u0436\u0443\u0437\u0435\u043F\u043F\u0435 \u041F\u0435\u0430\u043D\u043E
    \u0438 \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u043A\u0430\u043A **\u0430\u043A\u0441\u0438\u043E\u043C\u044B \u041F\u0435\u0430\u043D\u043E**.
    *   **\u0420\u0430\u0431\u043E\u0442\u044B \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432**: \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u043E\u0434\u043D\u0438\u043C \u0438\u0437 \u043F\u0435\u0440\u0432\u044B\u0445
    \u043F\u0440\u0438\u0437\u043D\u0430\u043B \u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u043B \u0442\u0435\u043E\u0440\u0438\u044E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432 \u0413\u0435\u043E\u0440\u0433\u0430
    \u041A\u0430\u043D\u0442\u043E\u0440\u0430. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0434\u0430\u043B \u043F\u0435\u0440\u0432\u043E\u0435 \u0441\u0442\u0440\u043E\u0433\u043E\u0435
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435 **\u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0433\u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430**: \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E, \u0435\u0441\u043B\u0438
    \u043E\u043D\u043E \u0440\u0430\u0432\u043D\u043E\u043C\u043E\u0449\u043D\u043E
    (\u043F\u043E\u0434\u043E\u0431\u043D\u043E) \u0441\u0432\u043E\u0435\u0439 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0447\u0430\u0441\u0442\u0438.  \u041F\u043E\u043C\u0438\u043C\u043E \u044D\u0442\u0438\u0445
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432, \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u0432\u043D\u0435\u0441 \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0447\u0438\u0441\u0435\u043B, \u0442\u0435\u043E\u0440\u0438\u044E \u0413\u0430\u043B\u0443\u0430
    (\u043E\u043D \u043F\u0435\u0440\u0432\u044B\u043C \u043D\u0430\u0447\u0430\u043B
    \u0447\u0438\u0442\u0430\u0442\u044C \u043B\u0435\u043A\u0446\u0438\u0438 \u043F\u043E
    \u044D\u0442\u043E\u0439 \u0442\u0435\u043C\u0435 \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435),
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B \u0440\u0435\u0434\u0430\u043A\u0442\u043E\u0440\u043E\u043C
    \u043F\u043E\u0441\u043C\u0435\u0440\u0442\u043D\u044B\u0445 \u0441\u043E\u0431\u0440\u0430\u043D\u0438\u0439
    \u0441\u043E\u0447\u0438\u043D\u0435\u043D\u0438\u0439 \u0413\u0430\u0443\u0441\u0441\u0430,
    \u0414\u0438\u0440\u0438\u0445\u043B\u0435 \u0438 \u0420\u0438\u043C\u0430\u043D\u0430. 
    \u0420\u0438\u0445\u0430\u0440\u0434 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 12 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    1916 \u0433\u043E\u0434\u0430 \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435,
    \u043E\u0441\u0442\u0430\u0432\u0438\u0432 \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u043E
    \u044F\u0437\u044B\u043A \u0438 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438."
  shortBioEn: 
  interestingFactsRu: "\u0412\u043D\u0435\u0448\u043D\u0435 \u0436\u0438\u0437\u043D\u044C
    \u0420\u0438\u0445\u0430\u0440\u0434\u0430 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430,
    \u043F\u0440\u043E\u0448\u0435\u0434\u0448\u0430\u044F \u0432 \u0435\u0433\u043E
    \u0440\u043E\u0434\u043D\u043E\u043C \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435,
    \u0431\u044B\u043B\u0430 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E\u0439
    \u0438 \u0440\u0430\u0437\u043C\u0435\u0440\u0435\u043D\u043D\u043E\u0439. \u0417\u0430
    \u044D\u0442\u043E\u0439 \u0432\u043D\u0435\u0448\u043D\u0435\u0439 \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u043E\u0439
    \u0441\u043A\u0440\u044B\u0432\u0430\u043B\u0430\u0441\u044C \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C,
    \u043F\u043E\u043B\u043D\u0430\u044F \u043E\u0441\u0442\u0440\u043E\u0443\u043C\u0438\u044F,
    \u0442\u043E\u043D\u043A\u0438\u0445 \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u0439
    \u0438 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0445 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445
    \u0432\u0437\u0433\u043B\u044F\u0434\u043E\u0432 \u043D\u0430 \u0441\u0430\u043C\u0443
    \u0441\u0443\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    ### \U0001F9E0 \u0414\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438
    \u0447\u0435\u0440\u0435\u0437... \u0441\u0430\u043C\u043E\u0433\u043E \u0441\u0435\u0431\u044F 
    \u0412 \u0441\u0432\u043E\u0435\u0439 \u0440\u0430\u0431\u043E\u0442\u0435 \xAB\u0427\u0442\u043E
    \u0442\u0430\u043A\u043E\u0435 \u0447\u0438\u0441\u043B\u0430 \u0438 \u0434\u043B\u044F
    \u0447\u0435\u0433\u043E \u043E\u043D\u0438 \u0441\u043B\u0443\u0436\u0430\u0442?\xBB
    (1888) \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0435
    \xAB\u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\xBB
    \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0445 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432.
    \u041E\u043D\u043E \u043D\u0435 \u043E\u043F\u0438\u0440\u0430\u043B\u043E\u0441\u044C
    \u043D\u0430 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u044B\u0435
    \u0430\u043A\u0441\u0438\u043E\u043C\u044B, \u0430 \u043D\u0430\u0447\u0438\u043D\u0430\u043B\u043E\u0441\u044C
    \u0441 \u0441\u0430\u043C\u043E\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0433\u043E
    \u0438 \u043D\u0435\u043F\u043E\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0433\u043E. 
    \u041E\u043D \u043F\u0438\u0441\u0430\u043B: \xAB\u041C\u043E\u0439 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
    \u043C\u0438\u0440 \u043C\u044B\u0441\u043B\u0435\u0439, \u0442\u043E \u0435\u0441\u0442\u044C
    \u0441\u043E\u0432\u043E\u043A\u0443\u043F\u043D\u043E\u0441\u0442\u044C S \u0432\u0441\u0435\u0445
    \u0432\u0435\u0449\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u043E\u0433\u0443\u0442
    \u0431\u044B\u0442\u044C \u043E\u0431\u044A\u0435\u043A\u0442\u0430\u043C\u0438
    \u043C\u043E\u0435\u0439 \u043C\u044B\u0441\u043B\u0438, \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u0435\u043D.
    \u0418\u0431\u043E \u0435\u0441\u043B\u0438 s \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442 S, \u0442\u043E \u043C\u044B\u0441\u043B\u044C
    s' \u043E \u0442\u043E\u043C, \u0447\u0442\u043E s \u043C\u043E\u0436\u0435\u0442
    \u0431\u044B\u0442\u044C \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u043C \u043C\u043E\u0435\u0439
    \u043C\u044B\u0441\u043B\u0438, \u0441\u0430\u043C\u0430 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u043E\u043C S\xBB.  \u041F\u0440\u043E\u0441\u0442\u044B\u043C\u0438
    \u0441\u043B\u043E\u0432\u0430\u043C\u0438, \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043C\u0435\u0442\u0430-\u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0435: \u043A\u0430\u043A
    \u0442\u043E\u043B\u044C\u043A\u043E \u0432\u044B \u0434\u0443\u043C\u0430\u0435\u0442\u0435
    \u043E \u043A\u0430\u043A\u043E\u0439-\u043B\u0438\u0431\u043E \u043C\u044B\u0441\u043B\u0438,
    \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u0435\u0442 \u043D\u043E\u0432\u0430\u044F
    \u043C\u044B\u0441\u043B\u044C \u2014 \u043C\u044B\u0441\u043B\u044C \u043E\u0431
    \u044D\u0442\u043E\u0439 \u043C\u044B\u0441\u043B\u0438. \u042D\u0442\u043E\u0442
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441 \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0442\u044C
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E, \u0447\u0442\u043E,
    \u043F\u043E \u0435\u0433\u043E \u043C\u043D\u0435\u043D\u0438\u044E, \u0441\u043B\u0443\u0436\u0438\u043B\u043E
    \xAB\u0436\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u043C\xBB \u043F\u0440\u0438\u043C\u0435\u0440\u043E\u043C
    \u0431\u0435\u0441\u043A\u043E\u043D\u0435\u0447\u043D\u043E\u0441\u0442\u0438.
    \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u044B
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440
    \u041B\u0451\u0439\u0442\u0446\u0435\u043D \u042D\u0433\u0431\u0435\u0440\u0442
    \u042F\u043D \u0411\u0440\u0430\u0443\u044D\u0440, \u043A\u0440\u0438\u0442\u0438\u043A\u043E\u0432\u0430\u043B\u0438
    \u044D\u0442\u043E\u0442 \u0445\u043E\u0434, \u0441\u0447\u0438\u0442\u0430\u044F
    \u0435\u0433\u043E \u043F\u043E\u043F\u044B\u0442\u043A\u043E\u0439 \u0432\u044B\u0432\u0435\u0441\u0442\u0438
    \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u0443\u044E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0438\u0441\u0442\u0438\u043D\u0443 \u0438\u0437 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0433\u043E
    \u044D\u043C\u043F\u0438\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0444\u0430\u043A\u0442\u0430 (\u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u044F
    \u0441\u043E\u0437\u043D\u0430\u043D\u0438\u044F). \u0422\u0435\u043C \u043D\u0435
    \u043C\u0435\u043D\u0435\u0435, \u044D\u0442\u043E\u0442 \u043F\u0430\u0441\u0441\u0430\u0436
    \u043E\u0441\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0438 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0445 \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u0432
    \u0432 \u0435\u0433\u043E \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0435. 
    ### \U0001F602 \u041E\u0441\u0442\u0440\u043E\u0443\u043C\u0438\u0435 \u0438
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E \u044E\u043C\u043E\u0440\u0430  \u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u0438\u043A\u0438
    \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0438 \u043E\u0442\u043C\u0435\u0447\u0430\u043B\u0438,
    \u0447\u0442\u043E \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434, \u043F\u0440\u0438
    \u0432\u0441\u0435\u0439 \u0441\u0432\u043E\u0435\u0439 \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0441\u0442\u0438,
    \u043E\u0431\u043B\u0430\u0434\u0430\u043B \u0442\u043E\u043D\u043A\u0438\u043C
    \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u043C \u044E\u043C\u043E\u0440\u0430,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043F\u0440\u043E\u044F\u0432\u043B\u044F\u043B\u043E\u0441\u044C
    \u0432 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043A\u0435 \u0438 \u0434\u0430\u0436\u0435
    \u0432 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0437\u0430\u043C\u0435\u0447\u0430\u043D\u0438\u044F\u0445. 
    *   **\u041E\u0442\u0432\u0435\u0442 \u043D\u0430 \u043D\u0435\u043A\u0440\u043E\u043B\u043E\u0433**:
    \u041E\u0434\u043D\u0430\u0436\u0434\u044B \u0438\u0437\u0434\u0430\u0442\u0435\u043B\u0438
    \u043A\u0430\u043B\u0435\u043D\u0434\u0430\u0440\u044F \u043E\u0448\u0438\u0431\u043E\u0447\u043D\u043E
    \u0441\u043E\u043E\u0431\u0449\u0438\u043B\u0438 \u043E \u0435\u0433\u043E \u0441\u043C\u0435\u0440\u0442\u0438,
    \u0443\u043A\u0430\u0437\u0430\u0432 \u043D\u0435\u0432\u0435\u0440\u043D\u044B\u0439
    \u0433\u043E\u0434. \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434, \u0436\u0438\u0432\u043E\u0439
    \u0438 \u0437\u0434\u043E\u0440\u043E\u0432\u044B\u0439, \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u0438\u043C \u043F\u0438\u0441\u044C\u043C\u043E \u0441 \u0441\u0443\u0445\u0438\u043C
    \u0438 \u0438\u0440\u043E\u043D\u0438\u0447\u043D\u044B\u043C \u0437\u0430\u043C\u0435\u0447\u0430\u043D\u0438\u0435\u043C:
    \xAB\u0414\u0430\u0442\u0430 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C
    \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E\u0439, \u0430 \u0433\u043E\u0434
    \u2014 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u0442\u043E\u0447\u043D\u043E
    \u043D\u0435\u0442\xBB. \u042D\u0442\u043E\u0442 \u044D\u043F\u0438\u0437\u043E\u0434
    \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E \u0438\u043B\u043B\u044E\u0441\u0442\u0440\u0438\u0440\u0443\u0435\u0442
    \u0435\u0433\u043E \u043D\u0435\u0432\u043E\u0437\u043C\u0443\u0442\u0438\u043C\u043E\u0441\u0442\u044C
    \u0438 \u044F\u0441\u043D\u043E\u0441\u0442\u044C \u0443\u043C\u0430.  *   **\u0412\u0437\u0433\u043B\u044F\u0434
    \u043D\u0430 \u0434\u043E\u0436\u0434\u043B\u0438\u0432\u0443\u044E \u043F\u043E\u0433\u043E\u0434\u0443**:
    \u0412 \u043F\u0438\u0441\u044C\u043C\u0435 \u043A \u0441\u0432\u043E\u0435\u0439
    \u0441\u0435\u0441\u0442\u0440\u0435 \u042E\u043B\u0438\u0438 \u043E\u043D \u0441
    \u043B\u0435\u0433\u043A\u043E\u0439 \u0438\u0440\u043E\u043D\u0438\u0435\u0439
    \u0437\u0430\u043C\u0435\u0442\u0438\u043B: \xAB\u0414\u043E\u0436\u0434\u043B\u0438\u0432\u044B\u0439
    \u0434\u0435\u043D\u044C = \u0441\u0435\u0440\u044B\u0439 \u0434\u0435\u043D\u044C
    = \u0445\u043E\u0440\u043E\u0448\u0438\u0439 \u0434\u0435\u043D\u044C\xBB. \u0412\u0438\u0434\u0438\u043C\u043E,
    \u0434\u043B\u044F \u0443\u0447\u0435\u043D\u043E\u0433\u043E, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0438\u0441\u043A\u0430\u043B \u0443\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F
    \u0434\u043B\u044F \u0441\u0432\u043E\u0438\u0445 \u043C\u044B\u0441\u043B\u0435\u0439,
    \u043D\u0435\u043F\u043E\u0433\u043E\u0434\u0430 \u0431\u044B\u043B\u0430 \u043F\u043E\u0432\u043E\u0434\u043E\u043C
    \u043E\u0441\u0442\u0430\u0442\u044C\u0441\u044F \u0434\u043E\u043C\u0430 \u0438
    \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439.  ### \U0001F4DC
    \u0420\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u0430\u044F \u0442\u0435\u0440\u043F\u0438\u043C\u043E\u0441\u0442\u044C
    \u0438 \u0440\u0435\u0434\u0430\u043A\u0442\u043E\u0440\u0441\u043A\u0430\u044F
    \u0447\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C  \u0413\u043B\u0443\u0431\u043E\u043A\u043E
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0439 \u0447\u0435\u043B\u043E\u0432\u0435\u043A,
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434, \u0442\u0435\u043C \u043D\u0435
    \u043C\u0435\u043D\u0435\u0435, \u043F\u0440\u043E\u044F\u0432\u0438\u043B \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0434\u043B\u044F \u0441\u0432\u043E\u0435\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    (1870-\u0435 \u0433\u043E\u0434\u044B, \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044F)
    \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0441\u0442\u044C \u0438 \u0441\u0432\u0435\u0442\u0441\u043A\u043E\u0441\u0442\u044C. 
    \u041A\u043E\u0433\u0434\u0430 \u043E\u043D \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044E \u0441\u0432\u043E\u0435\u0433\u043E
    \u0434\u0440\u0443\u0433\u0430 \u0411\u0435\u0440\u043D\u0445\u0430\u0440\u0434\u0430
    \u0420\u0438\u043C\u0430\u043D\u0430, \u043E\u043D \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B
    \u043F\u0438\u0441\u044C\u043C\u0430 \u0435\u0433\u043E \u0432\u0434\u043E\u0432\u044B
    \u042D\u043B\u0438\u0437\u044B. \u0412 \u043D\u0438\u0445 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043B\u0438\u0441\u044C
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435
    \u0444\u0440\u0430\u0437\u044B, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043E \u0442\u043E\u043C, \u043A\u0430\u043A \u0434\u0443\u0448\u0430 \u0420\u0438\u043C\u0430\u043D\u0430
    \xAB\u0432\u043E\u0437\u043D\u0435\u0441\u043B\u0430\u0441\u044C \u043A \u0411\u043E\u0433\u0443\xBB
    (*aufgegangen in Gott*). \u0412 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u0438
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434 \u0441\u043E\u0437\u043D\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0437\u0430\u043C\u0435\u043D\u0438\u043B \u044D\u0442\u0438 \u0432\u044B\u0440\u0430\u0436\u0435\u043D\u0438\u044F
    \u043D\u0430 \u043D\u0435\u0439\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0435
    \u0438 \u0441\u0432\u0435\u0442\u0441\u043A\u043E\u0435 \u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435:
    \xAB\u0435\u0433\u043E \u0447\u0438\u0441\u0442\u043E\u0435, \u0431\u043B\u0430\u0433\u043E\u0440\u043E\u0434\u043D\u043E\u0435
    \u0441\u0435\u0440\u0434\u0446\u0435 \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u043B\u043E
    \u0431\u0438\u0442\u044C\u0441\u044F\xBB.  \u041E\u043D \u043F\u043E\u0448\u0435\u043B
    \u043D\u0430 \u044D\u0442\u043E, \u0436\u0435\u043B\u0430\u044F, \u0447\u0442\u043E\u0431\u044B
    \u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u044F \u0431\u044B\u043B\u0430
    \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u0430 \u0438 \u043F\u043E\u043D\u044F\u0442\u043D\u0430
    \u0432\u0441\u0435\u043C \u0447\u0438\u0442\u0430\u0442\u0435\u043B\u044F\u043C,
    \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E \u043E\u0442 \u0438\u0445
    \u0432\u0435\u0440\u043E\u0438\u0441\u043F\u043E\u0432\u0435\u0434\u0430\u043D\u0438\u044F,
    \u0438 \u043D\u0435 \u043D\u0430\u0432\u044F\u0437\u044B\u0432\u0430\u043B\u0430
    \u0440\u0435\u043B\u0438\u0433\u0438\u043E\u0437\u043D\u044B\u0435 \u0432\u0437\u0433\u043B\u044F\u0434\u044B.
    \u042D\u0442\u043E \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u0435\u0433\u043E \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435 \u043A \u043D\u0430\u0443\u043A\u0435
    \u043A\u0430\u043A \u043A \u043E\u0431\u0449\u0435\u043C\u0443 \u0434\u0435\u043B\u0443,
    \u0441\u0442\u043E\u044F\u0449\u0435\u043C\u0443 \u0432\u044B\u0448\u0435 \u043B\u0438\u0447\u043D\u044B\u0445
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u0438\u0439. \u0415\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
    \u0437\u0430\u0432\u0435\u0449\u0430\u043D\u0438\u0435 \u043D\u0430 \u043D\u0430\u0434\u0433\u0440\u043E\u0431\u043D\u043E\u043C
    \u043A\u0430\u043C\u043D\u0435 \u0446\u0438\u0442\u0438\u0440\u0443\u0435\u0442
    \u0412\u0442\u043E\u0440\u043E\u0435 \u043F\u043E\u0441\u043B\u0430\u043D\u0438\u0435
    \u043A \u0422\u0438\u043C\u043E\u0444\u0435\u044E 4:7-8: \xAB\u041F\u043E\u0434\u0432\u0438\u0433\u043E\u043C
    \u0434\u043E\u0431\u0440\u044B\u043C \u044F \u043F\u043E\u0434\u0432\u0438\u0437\u0430\u043B\u0441\u044F,
    \u0442\u0435\u0447\u0435\u043D\u0438\u0435 \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B,
    \u0432\u0435\u0440\u0443 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u043B\xBB,
    \u0447\u0442\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443\u0435\u0442
    \u043E \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u043B\u0438\u0447\u043D\u043E\u0439,
    \u043D\u043E \u043D\u0435 \u043D\u0430\u0432\u044F\u0437\u0447\u0438\u0432\u043E\u0439
    \u0432\u0435\u0440\u0435.  ### \U0001F468\u200D\U0001F3EB \u0412\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F
    \u043E \u0432\u0435\u043B\u0438\u043A\u043E\u043C \u0413\u0430\u0443\u0441\u0441\u0435 
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434 \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u0431\u0435\u0441\u0446\u0435\u043D\u043D\u044B\u0435, \u0436\u0438\u0432\u044B\u0435
    \u043C\u0435\u043C\u0443\u0430\u0440\u044B \u043E \u0441\u0432\u043E\u0435\u043C
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435, \u041A\u0430\u0440\u043B\u0435 \u0424\u0440\u0438\u0434\u0440\u0438\u0445\u0435
    \u0413\u0430\u0443\u0441\u0441\u0435, \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C
    \u043E\u043D \u0443\u0447\u0438\u043B\u0441\u044F \u0432 \u0413\u0451\u0442\u0442\u0438\u043D\u0433\u0435\u043D\u0435.
    \u042D\u0442\u0438 \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F
    \u0440\u0438\u0441\u0443\u044E\u0442 \u043E\u0431\u0440\u0430\u0437 \u0432\u0435\u043B\u0438\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430 \u043D\u0435 \u043A\u0430\u043A
    \u043D\u0435\u0434\u043E\u0441\u044F\u0433\u0430\u0435\u043C\u043E\u0433\u043E
    \u0433\u0435\u043D\u0438\u044F, \u0430 \u043A\u0430\u043A \u0436\u0438\u0432\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430.  \u041E\u043D \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442
    \u0441\u0432\u043E\u0439 \u043F\u0435\u0440\u0432\u044B\u0439 \u0432\u0438\u0437\u0438\u0442
    \u043A \u0413\u0430\u0443\u0441\u0441\u0443: \xAB\u0441 \u0437\u0430\u043C\u0438\u0440\u0430\u043D\u0438\u0435\u043C
    \u0441\u0435\u0440\u0434\u0446\u0430, \u044F \u0432\u043E\u0448\u0435\u043B \u0432
    \u0435\u0433\u043E \u0436\u0438\u043B\u0443\u044E \u043A\u043E\u043C\u043D\u0430\u0442\u0443\xBB.
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434 \u0437\u0430\u043F\u043E\u043C\u043D\u0438\u043B
    \u043C\u0430\u043D\u0435\u0440\u0443 \u0413\u0430\u0443\u0441\u0441\u0430 \u0447\u0438\u0442\u0430\u0442\u044C
    \u043B\u0435\u043A\u0446\u0438\u0438 \u2014 \u0441\u0438\u0434\u0435\u0442\u044C
    \u0432 \u043A\u043E\u0440\u0438\u0447\u043D\u0435\u0432\u043E\u043C \u0441\u044E\u0440\u0442\u0443\u043A\u0435
    \u0438 \u0441\u0435\u0440\u044B\u0445 \u0431\u0440\u044E\u043A\u0430\u0445, \u0432
    \u0447\u0435\u0440\u043D\u043E\u0439 \u0448\u0430\u043F\u043E\u0447\u043A\u0435,
    \u0438 \u043A\u043E\u0433\u0434\u0430 \u043E\u043D \u0445\u043E\u0442\u0435\u043B
    \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u043D\u0443\u0442\u044C \u0432\u0430\u0436\u043D\u044B\u0439
    \u043C\u043E\u043C\u0435\u043D\u0442, \u043E\u043D \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u043B
    \u0433\u043E\u043B\u043E\u0432\u0443 \u0438 \xAB\u043F\u0440\u0438\u0441\u0442\u0430\u043B\u044C\u043D\u043E
    \u0441\u043C\u043E\u0442\u0440\u0435\u043B \u043D\u0430 \u043D\u0435\u0433\u043E
    \u0441\u0432\u043E\u0438\u043C\u0438 \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u044B\u043C\u0438
    \u043F\u0440\u043E\u043D\u0438\u043A\u043D\u043E\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    \u0433\u043E\u043B\u0443\u0431\u044B\u043C\u0438 \u0433\u043B\u0430\u0437\u0430\u043C\u0438\xBB.
    \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434 \u0442\u0430\u043A\u0436\u0435
    \u043E\u0442\u043C\u0435\u0442\u0438\u043B, \u0447\u0442\u043E \u0413\u0430\u0443\u0441\u0441,
    \u0432 \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u0441\u0442\u0432\u0435
    \u0432\u043B\u0430\u0434\u0435\u044F \u044F\u0437\u044B\u043A\u043E\u043C, \u0438\u043D\u043E\u0433\u0434\u0430
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B \u043F\u0440\u043E\u0441\u0442\u043E\u0440\u0435\u0447\u0438\u044F
    \u0438\u0437 \u0431\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0441\u043A\u043E\u0433\u043E
    \u0434\u0438\u0430\u043B\u0435\u043A\u0442\u0430, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0441\u0447\u0438\u0442\u0430\u043B \"eine, zweie, dreie\" \u0432\u043C\u0435\u0441\u0442\u043E
    \"eins, zwei, drei\", \u043A\u0430\u043A \u043F\u0440\u043E\u0441\u0442\u044B\u0435
    \u0433\u043E\u0440\u043E\u0436\u0430\u043D\u0435 \u043D\u0430 \u0440\u044B\u043D\u043A\u0435.
    \u0421\u0430\u043C \u0413\u0430\u0443\u0441\u0441 \u043D\u0430\u0437\u0432\u0430\u043B
    \u0441\u0432\u043E\u0438 \u043B\u0435\u043A\u0446\u0438\u0438 \xAB\u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0441\u0443\u0445\u0438\u043C\u0438\xBB, \u043D\u043E \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434
    \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430 \u0437\u0430\u043F\u043E\u043C\u043D\u0438\u043B
    \u0438\u0445 \u043A\u0430\u043A \u043E\u0434\u043D\u0438 \u0438\u0437 \u043B\u0443\u0447\u0448\u0438\u0445
    \u0432 \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u0438.  ### \U0001F3B5
    \u0427\u0435\u043B\u043E\u0432\u0435\u043A \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430 
    \u0414\u0430\u043B\u0435\u043A\u043E \u043D\u0435 \u0432\u0441\u0435 \u0437\u043D\u0430\u044E\u0442,
    \u0447\u0442\u043E \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434 \u0431\u044B\u043B
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0432\u044B\u0434\u0430\u044E\u0449\u0438\u043C\u0441\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u043C, \u043D\u043E
    \u0438 \u0442\u0430\u043B\u0430\u043D\u0442\u043B\u0438\u0432\u044B\u043C \u043C\u0443\u0437\u044B\u043A\u0430\u043D\u0442\u043E\u043C.
    \u0412 \u043C\u043E\u043B\u043E\u0434\u043E\u0441\u0442\u0438 \u043E\u043D \u0438\u0433\u0440\u0430\u043B
    \u043D\u0430 \u0432\u0438\u043E\u043B\u043E\u043D\u0447\u0435\u043B\u0438, \u0430
    \u0432 \u0431\u043E\u043B\u0435\u0435 \u0437\u0440\u0435\u043B\u044B\u0435 \u0433\u043E\u0434\u044B
    \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u043B\u0441\u044F \u043D\u0430
    \u0444\u043E\u0440\u0442\u0435\u043F\u0438\u0430\u043D\u043E. \u042D\u0442\u043E
    \u0443\u0432\u043B\u0435\u0447\u0435\u043D\u0438\u0435 \u0434\u043E\u043F\u043E\u043B\u043D\u044F\u043B\u043E
    \u0435\u0433\u043E \u043E\u0431\u0440\u0430\u0437 \u0441\u043A\u0440\u043E\u043C\u043D\u043E\u0433\u043E
    \u0438 \u0438\u043D\u0442\u0435\u043B\u043B\u0438\u0433\u0435\u043D\u0442\u043D\u043E\u0433\u043E
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u0441 \u0442\u043E\u043D\u043A\u043E\u0439
    \u0434\u0443\u0448\u0435\u0432\u043D\u043E\u0439 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u0435\u0439. 
    ### \u2709\uFE0F \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435 \u043F\u0440\u0438
    \u0436\u0438\u0437\u043D\u0438  \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F
    \u043D\u0430 \u0441\u0432\u043E\u044E \u0441\u043A\u0440\u043E\u043C\u043D\u0443\u044E
    \u0436\u0438\u0437\u043D\u044C \u0432 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0435,
    \u0432\u043A\u043B\u0430\u0434 \u0414\u0435\u0434\u0435\u043A\u0438\u043D\u0434\u0430
    \u0431\u044B\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u043D \u043D\u0430\u0443\u0447\u043D\u044B\u043C
    \u043C\u0438\u0440\u043E\u043C. \u041E\u043D \u0431\u044B\u043B \u0447\u043B\u0435\u043D\u043E\u043C
    \u0411\u0435\u0440\u043B\u0438\u043D\u0441\u043A\u043E\u0439 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438
    \u043D\u0430\u0443\u043A (\u0441 1880 \u0433\u043E\u0434\u0430) \u0438 \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u043C
    \u0447\u043B\u0435\u043D\u043E\u043C \u0424\u0440\u0430\u043D\u0446\u0443\u0437\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A (\u0441
    1910 \u0433\u043E\u0434\u0430), \u0430 \u0442\u0430\u043A\u0436\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043F\u043E\u0447\u0435\u0442\u043D\u044B\u0435 \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0438\u0435
    \u0441\u0442\u0435\u043F\u0435\u043D\u0438 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u043E\u0432
    \u041E\u0441\u043B\u043E, \u0426\u044E\u0440\u0438\u0445\u0430 \u0438 \u0411\u0440\u0430\u0443\u043D\u0448\u0432\u0435\u0439\u0433\u0430.
    \u0410 \u0432 1981 \u0433\u043E\u0434\u0443, \u043A 150-\u043B\u0435\u0442\u0438\u044E
    \u0441\u043E \u0434\u043D\u044F \u0435\u0433\u043E \u0440\u043E\u0436\u0434\u0435\u043D\u0438\u044F,
    \u0432 \u0413\u0414\u0420 \u0431\u044B\u043B\u0430 \u0432\u044B\u043F\u0443\u0449\u0435\u043D\u0430
    \u043F\u043E\u0447\u0442\u043E\u0432\u0430\u044F \u043C\u0430\u0440\u043A\u0430
    \u0441 \u0435\u0433\u043E \u0438\u0437\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435\u043C. 
    \u042D\u0442\u0438 \u0444\u0430\u043A\u0442\u044B \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442,
    \u0447\u0442\u043E \u0437\u0430 \u0444\u0430\u0441\u0430\u0434\u043E\u043C \u043F\u0440\u043E\u0432\u0438\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0441\u043A\u0440\u044B\u0432\u0430\u043B\u0441\u044F
    \u0447\u0435\u043B\u043E\u0432\u0435\u043A, \u0447\u044C\u0438 \u0438\u0434\u0435\u0438
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438 \u043C\u0438\u0440, \u0430 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440
    \u0431\u044B\u043B \u043F\u043E\u043B\u043E\u043D \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0445
    \u0433\u0440\u0430\u043D\u0435\u0439: \u043E\u0442 \u0441\u0442\u0440\u043E\u0433\u043E\u0441\u0442\u0438
    \u043C\u044B\u0441\u043B\u0438 \u0434\u043E \u0442\u043E\u043D\u043A\u043E\u0433\u043E
    \u044E\u043C\u043E\u0440\u0430 \u0438 \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439
    \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u043D\u043E\u0441\u0442\u0438."
