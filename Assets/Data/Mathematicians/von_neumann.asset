  shortBioRu: "\u0414\u0436\u043E\u043D \u0444\u043E\u043D \u041D\u0435\u0301\u0439\u043C\u0430\u043D\_\u2014
    \u0432\u0435\u043D\u0433\u0435\u0440\u043E-\u0430\u043C\u0435\u0440\u0438\u043A\u0430\u043D\u0441\u043A\u0438\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A, \u0444\u0438\u0437\u0438\u043A
    \u0438 \u043F\u0435\u0434\u0430\u0433\u043E\u0433 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F,
    \u0441\u0434\u0435\u043B\u0430\u0432\u0448\u0438\u0439 \u0432\u0430\u0436\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u0443\u044E
    \u0444\u0438\u0437\u0438\u043A\u0443, \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u0443\u044E
    \u043B\u043E\u0433\u0438\u043A\u0443, \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437, \u0442\u0435\u043E\u0440\u0438\u044E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432,
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0442\u0438\u043A\u0443, \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0443
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u043E\u0442\u0440\u0430\u0441\u043B\u0438
    \u043D\u0430\u0443\u043A\u0438."
