  achievementsRu: "\u041D\u0430\u0443\u0447\u043D\u043E\u0435 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
    \u041B\u044C\u0432\u0430 \u0421\u0435\u043C\u0451\u043D\u043E\u0432\u0438\u0447\u0430
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E
    \u0438 \u043E\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0442 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u043E\u0431\u043B\u0430\u0441\u0442\u0435\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0415\u0433\u043E
    \u0440\u0430\u0431\u043E\u0442\u044B \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u0434\u0435\u043B\u0438\u0442\u044C
    \u043D\u0430 \u0442\u0440\u0438 \u0433\u043B\u0430\u0432\u043D\u044B\u0445 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F,
    \u0432 \u043A\u0430\u0436\u0434\u043E\u043C \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u0440\u043E\u0440\u044B\u0432
    \u043C\u0438\u0440\u043E\u0432\u043E\u0433\u043E \u0443\u0440\u043E\u0432\u043D\u044F. 
    ### \U0001F9E9 \u0422\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F \u0438
    \u0442\u0435\u043E\u0440\u0438\u044F \u0433\u0440\u0443\u043F\u043F: \u0424\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442
    \u043C\u0438\u0440\u043E\u0432\u043E\u0433\u043E \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F 
    \u041F\u0435\u0440\u0432\u044B\u0435 \u0438, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u043D\u0430\u0438\u0431\u043E\u043B\u0435\u0435 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430
    \u043E\u0442\u043D\u043E\u0441\u044F\u0442\u0441\u044F \u043A \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u0435. \u0423\u0436\u0435 \u0432 1932 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u0441\u0442\u0430\u043B\u043E \u0432\u0435\u0445\u043E\u0439
    \u0432 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.  *   **\u0417\u0430\u043A\u043E\u043D
    \u0434\u0432\u043E\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430:** \u042D\u0442\u043E
    \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u0435\u0433\u043E \u0440\u0430\u043D\u043D\u0435\u0433\u043E \u043F\u0435\u0440\u0438\u043E\u0434\u0430.
    \u041E\u043D \u043E\u0431\u043E\u0431\u0449\u0438\u043B \u0437\u0430\u043A\u043E\u043D
    \u0434\u0432\u043E\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u0438
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0435\u0440\u0430, \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0432
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u0432\u044F\u0437\u044C \u043C\u0435\u0436\u0434\u0443 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\u043C\u0438 \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u0433\u043E
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u0432 \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u043C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435 \u0438
    \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430\u043C\u0438 \u0435\u0433\u043E
    \u0434\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u044F. \u041F\u043E \u0441\u0443\u0442\u0438,
    \u044D\u0442\u043E\u0442 \u0437\u0430\u043A\u043E\u043D \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C
    \u0433\u0440\u0443\u043F\u043F\u044B \u0411\u0435\u0442\u0442\u0438 (\u0447\u0438\u0441\u043B\u043E\u0432\u044B\u0435
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0438
    \"\u0434\u044B\u0440\u043E\u043A\" \u0432 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0435)
    \u043E\u0434\u043D\u043E\u0433\u043E \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0447\u0435\u0440\u0435\u0437 \u0433\u0440\u0443\u043F\u043F\u044B \u0411\u0435\u0442\u0442\u0438
    \u0434\u0440\u0443\u0433\u043E\u0433\u043E. \u042D\u0442\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u0434\u0430\u043B\u043E \u043C\u043E\u0449\u043D\u044B\u0439 \u0438\u043C\u043F\u0443\u043B\u044C\u0441
    \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044E \u0432\u0441\u0435\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438.  *   **\u0422\u0435\u043E\u0440\u0438\u044F
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u0432 \u0438 \u0434\u0432\u043E\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430:** \u0420\u0430\u0437\u0432\u0438\u0432\u0430\u044F
    \u0441\u0432\u043E\u0439 \u0437\u0430\u043A\u043E\u043D \u0434\u0432\u043E\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u0438,
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    \u043E\u0431\u0449\u0443\u044E \u0442\u0435\u043E\u0440\u0438\u044E \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u0432
    \u0434\u043B\u044F \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u044B\u0445
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0433\u0440\u0443\u043F\u043F. \u0421\u0435\u0433\u043E\u0434\u043D\u044F \u044D\u0442\u0430
    \u0442\u0435\u043E\u0440\u0438\u044F \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u043A\u0430\u043A **\u0434\u0432\u043E\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430-\u0432\u0430\u043D
    \u041A\u0430\u043C\u043F\u0435\u043D\u0430** \u0438 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C \u043A\u0430\u043C\u043D\u0435\u043C
    \u0433\u0430\u0440\u043C\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430 \u043D\u0430 \u0433\u0440\u0443\u043F\u043F\u0430\u0445.
    \u042D\u0442\u0430 \u0442\u0435\u043E\u0440\u0438\u044F \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u043E\u0431\u0440\u0430\u0437\u043E\u043C \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u044F\u0435\u0442\u0441\u044F
    \u043D\u0430 \u043B\u043E\u043A\u0430\u043B\u044C\u043D\u043E \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043D\u044B\u0435
    \u0430\u0431\u0435\u043B\u0435\u0432\u044B \u0433\u0440\u0443\u043F\u043F\u044B 
    \u0438 \u0431\u044B\u043B\u0430 \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0430
    \u043D\u0430 \u0441\u043B\u0443\u0447\u0430\u0439 \u043D\u0435\u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u044B\u0445
    \u0433\u0440\u0443\u043F\u043F (\u0434\u0443\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C
    \u0422\u0430\u043D\u043D\u0430\u043A\u0430-\u041A\u0440\u0435\u0439\u043D\u0430).
    \u041E\u043D\u0430 \u043F\u0440\u0435\u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043B\u0430
    \u0446\u0435\u043B\u0443\u044E \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u2014 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0443.  *   **\u0414\u0440\u0443\u0433\u0438\u0435
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F:**     *   **\u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043B\u0430\u0441\u0441\u044B \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430:**
    \u041E\u043D \u0432\u0432\u0435\u043B \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u044B \u0432 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0433\u043B\u0430\u0434\u043A\u0438\u0445 \u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0442\u0435\u043F\u0435\u0440\u044C
    \u043D\u043E\u0441\u044F\u0442 \u0435\u0433\u043E \u0438\u043C\u044F.     *  
    **\u0422\u0435\u043E\u0440\u0438\u044F \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0438:**
    \u0423\u0447\u0435\u043D\u044B\u0439 \u043F\u043E\u0441\u0442\u0440\u043E\u0438\u043B
    \u043F\u0440\u0438\u043C\u0435\u0440, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043E\u043F\u0440\u043E\u0432\u0435\u0440\u0433 \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443
    \u043E \u0442\u043E\u043C, \u0447\u0442\u043E \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u043A\u043E\u043C\u043F\u0430\u043A\u0442\u043E\u0432
    \u0440\u0430\u0432\u043D\u0430 \u0441\u0443\u043C\u043C\u0435 \u0438\u0445 \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0435\u0439,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u0432\u0430\u0436\u043D\u044B\u043C
    \u0438 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u043C \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C.    
    *   **\u041A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044F
    \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439:** \u041E\u043D
    \u043F\u0440\u043E\u0432\u0435\u043B \u043A\u043B\u0430\u0441\u0441\u0438\u0444\u0438\u043A\u0430\u0446\u0438\u044E
    \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439 \u0441\u0444\u0435\u0440
    \u0432\u044B\u0441\u0448\u0438\u0445 \u0440\u0430\u0437\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u0435\u0439,
    \u0447\u0442\u043E \u0431\u044B\u043B\u043E \u0437\u043D\u0430\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0448\u0430\u0433\u043E\u043C \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0433\u043E\u043C\u043E\u0442\u043E\u043F\u0438\u0439. 
    \u041A\u043B\u044E\u0447\u0435\u0432\u0430\u044F \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u044F
    \u044D\u0442\u043E\u0433\u043E \u043F\u0435\u0440\u0438\u043E\u0434\u0430 \u2014
    **\"\u041D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0435 \u0433\u0440\u0443\u043F\u043F\u044B\"**
    (1938), \u0437\u0430 \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0432 1941 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u0421\u0442\u0430\u043B\u0438\u043D\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438. 
    ### \U0001F680 \u0422\u0435\u043E\u0440\u0438\u044F \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F: \"\u041F\u0440\u0438\u043D\u0446\u0438\u043F
    \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C\u0430\"  \u0412 \u043D\u0430\u0447\u0430\u043B\u0435
    1950-\u0445 \u0433\u043E\u0434\u043E\u0432 \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u0441\u043C\u0435\u043B\u044B\u0439
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442 \u0432 \u0441\u0432\u043E\u0435\u0439
    \u043D\u0430\u0443\u0447\u043D\u043E\u0439 \u043A\u0430\u0440\u044C\u0435\u0440\u0435,
    \u043F\u0435\u0440\u0435\u0439\u0434\u044F \u043E\u0442 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438 \u043A \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u043C
    \u0437\u0430\u0434\u0430\u0447\u0430\u043C. \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C
    \u0441\u0442\u0430\u043B\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0432.  *   **\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438:** \u041F\u043E\u0432\u043E\u0434\u043E\u043C
    \u043F\u043E\u0441\u043B\u0443\u0436\u0438\u043B\u0430 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u043D\u0430\u044F \u0437\u0430\u0434\u0430\u0447\u0430,
    \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u0430\u044F \u0441 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435\u043C
    \u0441\u0430\u043C\u043E\u043B\u0435\u0442\u043E\u043C. \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u043E\u0432\u0430\u043B \u043C\u0435\u0436\u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0430\u0440\u043D\u044B\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0438 \u0434\u0435\u043B\u0438\u043B\u0438\u0441\u044C
    \u0441\u0432\u043E\u0438\u043C\u0438 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430\u043C\u0438.
    \u042D\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u0435\u0433\u043E
    \u0438 \u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432 (\u0412.\u0413.
    \u0411\u043E\u043B\u0442\u044F\u043D\u0441\u043A\u043E\u0433\u043E, \u0420.\u0412.
    \u0413\u0430\u043C\u043A\u0440\u0435\u043B\u0438\u0434\u0437\u0435, \u0415.\u0424.
    \u041C\u0438\u0449\u0435\u043D\u043A\u043E) \u043A \u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u043A\u0435
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430.  *   **\u041F\u0440\u0438\u043D\u0446\u0438\u043F
    \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C\u0430 \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430:**
    \u0421\u0444\u043E\u0440\u043C\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0432 1956 \u0433\u043E\u0434\u0443, \u044D\u0442\u043E\u0442 \u043F\u0440\u0438\u043D\u0446\u0438\u043F
    \u0434\u0430\u0435\u0442 **\u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u044B\u0435
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438**
    \u0434\u043B\u044F \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0432, \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u043C\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C\u043E\u0439 \u043E\u0431\u044B\u043A\u043D\u043E\u0432\u0435\u043D\u043D\u044B\u0445
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0441 \u043F\u0430\u0440\u0430\u043C\u0435\u0442\u0440\u043E\u043C
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F. \u0421\u0443\u0442\u044C
    \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430 \u043C\u043E\u0436\u043D\u043E
    \u043A\u0440\u0430\u0442\u043A\u043E \u043E\u043F\u0438\u0441\u0430\u0442\u044C
    \u0442\u0430\u043A:     1.  \u0414\u043B\u044F \u0441\u0438\u0441\u0442\u0435\u043C\u044B
    \u0437\u0430\u0434\u0430\u0435\u0442\u0441\u044F \u0441\u043A\u0430\u043B\u044F\u0440\u043D\u0430\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u044F \u2014 **\u0433\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0438\u0430\u043D**
    `H`, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u044F\u0435\u0442
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F,
    \u0443\u043F\u0440\u0430\u0432\u043B\u044F\u044E\u0449\u0438\u0435 \u043F\u0430\u0440\u0430\u043C\u0435\u0442\u0440\u044B
    \u0438 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \"\u0441\u043E\u043F\u0440\u044F\u0436\u0435\u043D\u043D\u044B\u0435\"
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435.     2.  \u0423\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u0434\u043B\u044F \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F \u0438 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0439
    \u0435\u043C\u0443 \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438
    \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C
    \u0442\u0430\u043A\u043E\u0439 \u043D\u0435\u0442\u0440\u0438\u0432\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u043D\u0430\u0431\u043E\u0440 \u0441\u043E\u043F\u0440\u044F\u0436\u0435\u043D\u043D\u044B\u0445
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0445, \u043F\u0440\u0438
    \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0433\u0430\u043C\u0438\u043B\u044C\u0442\u043E\u043D\u0438\u0430\u043D
    \u0434\u043E\u0441\u0442\u0438\u0433\u0430\u0435\u0442 \u0441\u0432\u043E\u0435\u0433\u043E
    \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C\u0430 \u0432 \u043A\u0430\u0436\u0434\u043E\u0439
    \u0442\u043E\u0447\u043A\u0435 \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438.    
    3.  \u0422\u0430\u043A\u0436\u0435 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u044E\u0442\u0441\u044F
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F \u0442\u0440\u0430\u043D\u0441\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438
    \u043D\u0430 \u043A\u043E\u043D\u0446\u0430\u0445 \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438
    \u0438 \u0443\u0441\u043B\u043E\u0432\u0438\u0435 `M(\u03C8(t1), x(t1)) = 0`
    \u0432 \u043A\u043E\u043D\u0435\u0447\u043D\u044B\u0439 \u043C\u043E\u043C\u0435\u043D\u0442
    \u0432\u0440\u0435\u043C\u0435\u043D\u0438.  *   **\u0417\u043D\u0430\u0447\u0435\u043D\u0438\u0435:**
    \u042D\u0442\u043E \u043F\u0440\u043E\u0440\u044B\u0432\u043D\u043E\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435
    \u0432\u044B\u0432\u0435\u043B\u043E \u0442\u0435\u043E\u0440\u0438\u044E \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u043D\u0430 \u043D\u043E\u0432\u044B\u0439 \u0443\u0440\u043E\u0432\u0435\u043D\u044C.
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0432\u0430\u0440\u0438\u0430\u0446\u0438\u043E\u043D\u043D\u043E\u0433\u043E
    \u0438\u0441\u0447\u0438\u0441\u043B\u0435\u043D\u0438\u044F, \u043F\u0440\u0438\u043D\u0446\u0438\u043F
    \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C\u0430 \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u044D\u0444\u0444\u0435\u043A\u0442\u0438\u0432\u043D\u043E \u0440\u0435\u0448\u0430\u0442\u044C
    \u0437\u0430\u0434\u0430\u0447\u0438 \u0441 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\u0438\u044F\u043C\u0438
    \u043D\u0430 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435 (\u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    `u(t)` \u0434\u043E\u043B\u0436\u043D\u043E \u043B\u0435\u0436\u0430\u0442\u044C
    \u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0437\u0430\u043C\u043A\u043D\u0443\u0442\u043E\u043C
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0435). \u041E\u043D \u0441\u0442\u0430\u043B
    \u043C\u043E\u0449\u043D\u0435\u0439\u0448\u0438\u043C \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C
    \u0434\u043B\u044F \u0440\u0430\u0441\u0447\u0435\u0442\u0430 \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0439 \u0432 \u0430\u0432\u0438\u0430\u0446\u0438\u0438,
    \u043A\u043E\u0441\u043C\u043E\u043D\u0430\u0432\u0442\u0438\u043A\u0435, \u0440\u043E\u0431\u043E\u0442\u043E\u0442\u0435\u0445\u043D\u0438\u043A\u0435
    \u0438 \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u043A\u0435.  \u0417\u0430
    \u044D\u0442\u043E\u0442 \u0446\u0438\u043A\u043B \u0440\u0430\u0431\u043E\u0442
    \u0432 1962 \u0433\u043E\u0434\u0443 \u043A\u043E\u043B\u043B\u0435\u043A\u0442\u0438\u0432
    \u0430\u0432\u0442\u043E\u0440\u043E\u0432 \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D
    \u041B\u0435\u043D\u0438\u043D\u0441\u043A\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438. 
    ### \U0001F52C \u0414\u0440\u0443\u0433\u0438\u0435 \u0437\u043D\u0430\u0447\u0438\u043C\u044B\u0435
    \u0432\u043A\u043B\u0430\u0434\u044B  \u041F\u043E\u043C\u0438\u043C\u043E \u0434\u0432\u0443\u0445
    \u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u044B\u0445 \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0439,
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D \u0432\u043D\u0435\u0441
    \u0432\u0435\u0441\u043E\u043C\u044B\u0439 \u0432\u043A\u043B\u0430\u0434 \u0438
    \u0432 \u0434\u0440\u0443\u0433\u0438\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438: 
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u0439:**
    \u0412 1930-\u0445 \u0433\u043E\u0434\u0430\u0445 \u043E\u043D \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0410.\u0410. \u0410\u043D\u0434\u0440\u043E\u043D\u043E\u0432\u044B\u043C
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u043D\u0430\u0434 \u0437\u0430\u0434\u0430\u0447\u0430\u043C\u0438,
    \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u044E\u0449\u0438\u043C\u0438 \u0432
    \u0440\u0430\u0434\u0438\u043E\u0444\u0438\u0437\u0438\u043A\u0435 \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0440\u0435\u0433\u0443\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F.
    \u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432\u0430\u0436\u043D\u044B
    \u0435\u0433\u043E \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
    \u043F\u043E **\u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u043A\u0435
    \u0440\u0435\u043B\u0430\u043A\u0441\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0445
    \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u0439** \u2014 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0432
    \u0441 \u0434\u0432\u0443\u043C\u044F \u0440\u0430\u0437\u043D\u044B\u043C\u0438
    \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C\u0438 \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u0430\u043C\u0438
    (\"\u0431\u044B\u0441\u0442\u0440\u044B\u043C\u0438\" \u0438 \"\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u044B\u043C\u0438\"
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u044F\u043C\u0438). *   **\u0414\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438\u0433\u0440\u044B:** \u041E\u043D \u0432\u043D\u0435\u0441 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0432\u043A\u043B\u0430\u0434 \u0432 \u0442\u0435\u043E\u0440\u0438\u044E \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0438\u0433\u0440, \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438,
    \u0432 \u0437\u0430\u0434\u0430\u0447\u0438 \u043F\u0440\u0435\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F-\u0443\u0431\u0435\u0433\u0430\u043D\u0438\u044F.
    \u041E\u0434\u043D\u0430 \u0438\u0437 \u0435\u0433\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0445
    \u0440\u0430\u0431\u043E\u0442 \u2014 \"\u041B\u0438\u043D\u0435\u0439\u043D\u0430\u044F
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u0430\u044F
    \u0438\u0433\u0440\u0430 \u0443\u0431\u0435\u0433\u0430\u043D\u0438\u044F\".
    *   **\u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435:** \u041E\u043D
    \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u0430\u0432\u0442\u043E\u0440\u043E\u043C
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u0432 \u0438 \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u044B\u0445
    \u043A\u043D\u0438\u0433 \u0434\u043B\u044F \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432,
    \u0442\u0430\u043A\u0438\u0445 \u043A\u0430\u043A \"\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437 \u0434\u043B\u044F \u0448\u043A\u043E\u043B\u044C\u043D\u0438\u043A\u043E\u0432\"
    \u0438 \"\u0417\u043D\u0430\u043A\u043E\u043C\u0441\u0442\u0432\u043E \u0441
    \u0432\u044B\u0441\u0448\u0435\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439\",
    \u0447\u0442\u043E \u0441\u043F\u043E\u0441\u043E\u0431\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u043E
    \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u0438\u0437\u0430\u0446\u0438\u0438
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u043D\u0430\u043D\u0438\u0439.  \u0414\u043B\u044F \u0431\u043E\u043B\u0435\u0435
    \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0433\u043E \u043F\u043E\u0433\u0440\u0443\u0436\u0435\u043D\u0438\u044F
    \u0432 \u0434\u0435\u0442\u0430\u043B\u0438 \u0435\u0433\u043E \u0436\u0438\u0437\u043D\u0438
    \u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u043D\u0430\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0443\u044E \u0435\u0433\u043E
    \u0430\u0432\u0442\u043E\u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u043A\u043D\u0438\u0433\u0443 \xAB\u0416\u0438\u0437\u043D\u0435\u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u041B. \u0421. \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430,
    \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u0435 \u0438\u043C
    \u0441\u0430\u043C\u0438\u043C\xBB, \u0430 \u0442\u0430\u043A\u0436\u0435 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
    \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u044E \xAB\u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0442\u0435\u043E\u0440\u0438\u044F \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0432\xBB, \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043D\u0443\u044E
    \u0432 \u0441\u043E\u0430\u0432\u0442\u043E\u0440\u0441\u0442\u0432\u0435 \u0441
    \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C\u0438."
  achievementsEn: 
  personalLifeRu: "\u0416\u0438\u0437\u043D\u044C \u041B\u044C\u0432\u0430 \u0421\u0435\u043C\u0451\u043D\u043E\u0432\u0438\u0447\u0430
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430 \u2014 \u044D\u0442\u043E
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439, \u043F\u043E\u0442\u0435\u0440\u044F\u0432
    \u0432 \u0434\u0435\u0442\u0441\u0442\u0432\u0435 \u0437\u0440\u0435\u043D\u0438\u0435,
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043D\u0435 \u0441\u043B\u043E\u043C\u0430\u043B\u0441\u044F,
    \u043D\u043E \u0441\u0442\u0430\u043B \u043E\u0434\u043D\u0438\u043C \u0438\u0437
    \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    XX \u0432\u0435\u043A\u0430. \u0412\u043E\u0442 \u0435\u0451 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u0430\u044F
    \u0445\u0440\u043E\u043D\u0438\u043A\u0430.  ### \U0001F4C5 \u0420\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0434\u0435\u0442\u0441\u0442\u0432\u043E \u041B\u0435\u0432 \u0421\u0435\u043C\u0451\u043D\u043E\u0432\u0438\u0447
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    **3 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F 1908 \u0433\u043E\u0434\u0430
    \u0432 \u041C\u043E\u0441\u043A\u0432\u0435**. \u0415\u0433\u043E \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438
    \u043D\u0435 \u0431\u044B\u043B\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438
    \u2014 \u043E\u0442\u0435\u0446 \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0441\u0447\u0435\u0442\u043E\u0432\u043E\u0434\u043E\u043C,
    \u0430 \u043C\u0430\u0442\u044C, \u0422\u0430\u0442\u044C\u044F\u043D\u0430 \u0410\u043D\u0434\u0440\u0435\u0435\u0432\u043D\u0430,
    \u0431\u044B\u043B\u0430 \u043F\u043E\u0440\u0442\u043D\u0438\u0445\u043E\u0439. 
    \u041F\u0435\u0440\u0435\u043B\u043E\u043C\u043D\u044B\u043C \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C
    \u0441\u0442\u0430\u043B\u0430 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F
    \u0432 **1922 \u0433\u043E\u0434\u0443**. 13-\u043B\u0435\u0442\u043D\u0438\u0439
    \u041B\u0451\u0432\u0430 \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043F\u043E\u0447\u0438\u043D\u0438\u0442\u044C
    \u043A\u0435\u0440\u043E\u0441\u0438\u043D\u043E\u0432\u044B\u0439 \u043F\u0440\u0438\u043C\u0443\u0441,
    \u0447\u0442\u043E\u0431\u044B \u0441\u043E\u0433\u0440\u0435\u0442\u044C\u0441\u044F.
    \u041F\u0440\u043E\u0438\u0437\u043E\u0448\u0435\u043B \u0432\u0437\u0440\u044B\u0432,
    \u0438 \u043C\u0430\u043B\u044C\u0447\u0438\u043A \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0442\u044F\u0436\u0435\u043B\u044B\u0435 \u043E\u0436\u043E\u0433\u0438 \u043B\u0438\u0446\u0430,
    \u0432 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435 \u043A\u043E\u0442\u043E\u0440\u044B\u0445
    **\u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u0437\u0440\u0435\u043D\u0438\u0435**.  ### \U0001F9D1\u200D\U0001F3EB \u0423\u0447\u0451\u0431\u0430
    \u0438 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u041A\u0430\u0437\u0430\u043B\u043E\u0441\u044C,
    \u043C\u0438\u0440 \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0437\u0430\u043A\u0440\u044B\u043B\u0441\u044F.
    \u0420\u043E\u0434\u0438\u0442\u0435\u043B\u0438, \u0437\u0430\u043D\u044F\u0442\u044B\u0435
    \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0435, \u043D\u0435 \u043C\u043E\u0433\u043B\u0438
    \u0432\u043E\u0434\u0438\u0442\u044C \u0435\u0433\u043E \u0432 \u043E\u0431\u044B\u0447\u043D\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443, \u043D\u043E \u043D\u0430 \u043F\u043E\u043C\u043E\u0449\u044C
    \u043F\u0440\u0438\u0448\u043B\u0438 \u043E\u0434\u043D\u043E\u043A\u043B\u0430\u0441\u0441\u043D\u0438\u043A\u0438.
    \u041E\u043D\u0438 \u043F\u043E \u043E\u0447\u0435\u0440\u0435\u0434\u0438 \u0441\u043E\u043F\u0440\u043E\u0432\u043E\u0436\u0434\u0430\u043B\u0438
    \u0435\u0433\u043E \u0434\u043E \u0448\u043A\u043E\u043B\u044B \u0438 \u043F\u043E\u043C\u043E\u0433\u0430\u043B\u0438
    \u0441 \u0443\u0440\u043E\u043A\u0430\u043C\u0438.  \u0413\u043B\u0430\u0432\u043D\u043E\u0439
    \u043E\u043F\u043E\u0440\u043E\u0439 \u0441\u0442\u0430\u043B\u0430 \u0435\u0433\u043E
    \u043C\u0430\u0442\u044C, \u0422\u0430\u0442\u044C\u044F\u043D\u0430 \u0410\u043D\u0434\u0440\u0435\u0435\u0432\u043D\u0430.
    \u041E\u043D\u0430 \u0432\u044B\u0443\u0447\u0438\u043B\u0430 \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0435
    \u044F\u0437\u044B\u043A\u0438, \u0447\u0442\u043E\u0431\u044B \u0447\u0438\u0442\u0430\u0442\u044C
    \u0441\u044B\u043D\u0443 \u0432\u0441\u043B\u0443\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u043A\u043D\u0438\u0433\u0438, \u0438 \u0441\u0442\u0430\u043B\u0430 \u0435\u0433\u043E
    \u043B\u0438\u0447\u043D\u044B\u043C \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u0435\u043C,
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u044F \u043F\u043E\u0434 \u0434\u0438\u043A\u0442\u043E\u0432\u043A\u0443
    \u0441\u0442\u0430\u0442\u044C\u0438 \u0438 \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438. 
    \u0412 **1925 \u0433\u043E\u0434\u0443** \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u043D\u0430 \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0444\u0430\u043A\u0443\u043B\u044C\u0442\u0435\u0442 \u041C\u043E\u0441\u043A\u043E\u0432\u0441\u043A\u043E\u0433\u043E
    \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0430. \u0415\u0433\u043E
    \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u0430\u044F
    \u043F\u0430\u043C\u044F\u0442\u044C \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u043B\u0430
    \u0437\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u0442\u044C \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u044B\u043A\u043B\u0430\u0434\u043A\u0438, \u043D\u0438\u0447\u0435\u0433\u043E
    \u043D\u0435 \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u044F \u043D\u0430
    \u043B\u0435\u043A\u0446\u0438\u044F\u0445. \u0423\u0436\u0435 \u043D\u0430 \u0432\u0442\u043E\u0440\u043E\u043C
    \u043A\u0443\u0440\u0441\u0435 \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u044C\u0441\u044F
    \u043D\u0430\u0443\u043A\u043E\u0439 \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0432\u044B\u0434\u0430\u044E\u0449\u0435\u0433\u043E\u0441\u044F \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0430
    \u041F.\u0421. \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u0432\u0430.
    \u0412 **1929 \u0433\u043E\u0434\u0443** \u043E\u043D \u0431\u043B\u0435\u0441\u0442\u044F\u0449\u0435
    \u043E\u043A\u043E\u043D\u0447\u0438\u043B \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442. 
    ### \U0001F52C \u041D\u0430\u0443\u0447\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430
    \u0415\u0433\u043E \u043A\u0430\u0440\u044C\u0435\u0440\u0430 \u0440\u0430\u0437\u0432\u0438\u0432\u0430\u043B\u0430\u0441\u044C
    \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u043E:  *  
    **1935 \u0433\u043E\u0434** \u2014 \u0431\u0435\u0437 \u0437\u0430\u0449\u0438\u0442\u044B
    \u0435\u043C\u0443 \u0431\u044B\u043B\u0430 \u043F\u0440\u0438\u0441\u0432\u043E\u0435\u043D\u0430
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0434\u043E\u043A\u0442\u043E\u0440\u0430
    \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A, \u0438 \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C
    \u041C\u0413\u0423. *   **1939 \u0433\u043E\u0434** \u2014 \u0431\u044B\u043B
    \u0438\u0437\u0431\u0440\u0430\u043D \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C
    \u0410\u041D \u0421\u0421\u0421\u0420. *   **1958 \u0433\u043E\u0434** \u2014
    \u0438\u0437\u0431\u0440\u0430\u043D \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u043E\u043C
    \u0410\u041D \u0421\u0421\u0421\u0420.  \u0421 **1939 \u0433\u043E\u0434\u0430**
    \u0438 \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0436\u0438\u0437\u043D\u0438
    \u043E\u043D \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u043B \u043E\u0442\u0434\u0435\u043B\u043E\u043C
    \u0432 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u043C
    \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435 \u0438\u043C\u0435\u043D\u0438
    \u0412.\u0410. \u0421\u0442\u0435\u043A\u043B\u043E\u0432\u0430 \u0410\u041D
    \u0421\u0421\u0421\u0420.  \u0412 \u043D\u0430\u0447\u0430\u043B\u0435 1950-\u0445
    \u0433\u043E\u0434\u043E\u0432 \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043F\u043E\u0432\u043E\u0440\u043E\u0442,
    \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u043E \u0441\u043C\u0435\u043D\u0438\u0432
    \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432. \u041F\u043E \u0435\u0433\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u0441\u043B\u043E\u0432\u0430\u043C,
    \u043E\u043D \u0441\u0434\u0435\u043B\u0430\u043B \u044D\u0442\u043E \xAB\u0438\u0437
    \u044D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439\xBB,
    \u0436\u0435\u043B\u0430\u044F, \u0447\u0442\u043E\u0431\u044B \u0435\u0433\u043E
    \u0442\u0440\u0443\u0434\u044B \u043F\u0440\u0438\u043D\u043E\u0441\u0438\u043B\u0438
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u043F\u043E\u043B\u044C\u0437\u0443.
    \u042D\u0442\u043E\u0442 \u0448\u0430\u0433, \u043F\u043E\u043B\u043D\u044B\u0439
    \u0440\u0438\u0441\u043A\u0430, \u043F\u0440\u0438\u0432\u0435\u043B \u0435\u0433\u043E
    \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0438 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u0433\u043E **\u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430
    \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C\u0430** \u2014 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043F\u0440\u0438\u043D\u0435\u0441
    \u0435\u043C\u0443 \u043C\u0438\u0440\u043E\u0432\u0443\u044E \u0441\u043B\u0430\u0432\u0443. 
    ### \U0001F91D \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441
    \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u0443\u0447\u0435\u043D\u044B\u043C\u0438
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0441\u0432\u043E\u0438\u043C \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u044B\u043C
    \u0438 \u0431\u0435\u0441\u043A\u043E\u043C\u043F\u0440\u043E\u043C\u0438\u0441\u0441\u043D\u044B\u043C
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C, \u0447\u0442\u043E
    \u0447\u0430\u0441\u0442\u043E \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u043B\u043E
    \u043A \u0441\u043B\u043E\u0436\u043D\u044B\u043C \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u043C
    \u0441 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438:  *   **\u0413\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u043E\u0435
    \u043C\u0443\u0436\u0435\u0441\u0442\u0432\u043E:** \u0415\u0449\u0435 \u0432
    1939 \u0433\u043E\u0434\u0443, \u0432\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0430
    \u0441\u0442\u0430\u043B\u0438\u043D\u0441\u043A\u0438\u0445 \u0440\u0435\u043F\u0440\u0435\u0441\u0441\u0438\u0439,
    \u043E\u043D \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E \u0432\u044B\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0443 \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0443\u0440\u044B
    \u0410.\u041D. \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430
    \u0432 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u044E \u043D\u0430\u0443\u043A,
    \u043D\u0430\u0440\u0443\u0448\u0438\u0432 \u043D\u0435\u0433\u043B\u0430\u0441\u043D\u044B\u0439
    \u0437\u0430\u043F\u0440\u0435\u0442. \u0422\u0430\u043A\u0436\u0435 \u043E\u043D
    \u0440\u0438\u0441\u043A\u043E\u0432\u0430\u043B, \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u044F
    \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D\u043D\u044B\u0445 \u2014 \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u0440\u0435\u0433\u0443\u043B\u044F\u0440\u043D\u043E \u043F\u0438\u0441\u0430\u043B
    \u043F\u0438\u0441\u044C\u043C\u0430 \u0432 \u043B\u0430\u0433\u0435\u0440\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443 \u0412.\u0410. \u0415\u0444\u0440\u0435\u043C\u043E\u0432\u0438\u0447\u0443.
    *   **\u0423\u0447\u0438\u0442\u0435\u043B\u044C \u0438 \u0434\u0440\u0443\u0433:**
    \u041A \u0441\u0432\u043E\u0438\u043C \u0443\u0447\u0435\u043D\u0438\u043A\u0430\u043C
    \u043E\u043D \u043E\u0442\u043D\u043E\u0441\u0438\u043B\u0441\u044F \u043D\u0435
    \u043A\u0430\u043A \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A, \u0430
    \u043A\u0430\u043A \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A \u0438
    \u0434\u0440\u0443\u0433. \u0415\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A
    \u0415.\u0424. \u041C\u0438\u0449\u0435\u043D\u043A\u043E \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B,
    \u043A\u0430\u043A \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D \u0437\u0430\u0431\u043E\u0442\u0438\u043B\u0441\u044F
    \u043E \u0435\u0433\u043E \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u0435, \u0443\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u044F
    \u0435\u0433\u043E \u0432 \u043A\u043B\u0438\u043D\u0438\u043A\u0443 \u0438 \u043E\u043F\u043B\u0430\u0447\u0438\u0432\u0430\u044F
    \u043B\u0435\u0447\u0435\u043D\u0438\u0435, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043A\u0430\u043A \u043E\u043D\u0438 \u0432\u043C\u0435\u0441\u0442\u0435 \u043A\u0430\u0442\u0430\u043B\u0438\u0441\u044C
    \u043D\u0430 \u043B\u044B\u0436\u0430\u0445 \u0438 \u043A\u043E\u043D\u044C\u043A\u0430\u0445,
    \u043F\u0440\u0438 \u044D\u0442\u043E\u043C \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443. \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u043D\u0430\u0443\u0447\u0438\u043B\u0441\u044F \u043A\u0430\u0442\u0430\u0442\u044C\u0441\u044F
    \u043D\u0430 \u043B\u044B\u0436\u0430\u0445 \u0438 \u043A\u043E\u043D\u044C\u043A\u0430\u0445
    \u0443\u0436\u0435 \u0431\u0443\u0434\u0443\u0447\u0438 \u0441\u043B\u0435\u043F\u044B\u043C.
    *   **\u041F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0430 \u0432 \u0431\u0435\u0434\u0435:**
    \u041E\u0434\u043D\u043E \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u044F\u0440\u043A\u0438\u0445
    \u043F\u0440\u043E\u044F\u0432\u043B\u0435\u043D\u0438\u0439 \u0435\u0433\u043E
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0430 \u2014 \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0441 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u043C \u0412.\u0410. \u0420\u043E\u0445\u043B\u0438\u043D\u044B\u043C.
    \u0422\u043E\u0442 \u043F\u043E\u043F\u0430\u043B \u0432 \u043F\u043B\u0435\u043D,
    \u0430 \u043F\u043E\u0441\u043B\u0435 \u0432\u043E\u0439\u043D\u044B \u2014 \u0432
    \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u0438\u0439 \u043B\u0430\u0433\u0435\u0440\u044C.
    \u0418\u043C\u0435\u043D\u043D\u043E \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u0441\u0432\u043E\u0438\u043C\u0438 \u043D\u0430\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u044B\u043C\u0438
    \u0445\u043B\u043E\u043F\u043E\u0442\u0430\u043C\u0438 \u0434\u043E\u0431\u0438\u043B\u0441\u044F
    \u0435\u0433\u043E \u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0438 \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0432 \u0441\u0432\u043E\u0435\u043C \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0435.
    *   **\xAB\u0422\u0430\u043A \u0441\u0434\u0435\u043B\u0430\u0439\u0442\u0435
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0435\xBB:** \u042D\u0442\u0443
    \u0444\u0440\u0430\u0437\u0443 \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u043F\u0440\u043E\u0438\u0437\u043D\u0435\u0441, \u043A\u043E\u0433\u0434\u0430
    \u043A\u043E\u043B\u043B\u0435\u0433\u0430 \u0441\u043A\u0430\u0437\u0430\u043B,
    \u0447\u0442\u043E \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043D\u0438\u0435
    \u0443\u0447\u0435\u043D\u043E\u0433\u043E \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E
    \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u0442\u044C. \u0414\u043B\u044F \u0441\u0430\u043C\u043E\u0433\u043E
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430 \u044D\u0442\u043E
    \u0431\u044B\u043B \u043E\u0431\u044B\u0447\u043D\u044B\u0439 \u043F\u043E\u0434\u0445\u043E\u0434
    \u043A \u0436\u0438\u0437\u043D\u0438: \u0434\u0435\u043B\u0430\u0442\u044C \u0442\u043E,
    \u0447\u0442\u043E \u0434\u0440\u0443\u0433\u0438\u0435 \u0441\u0447\u0438\u0442\u0430\u044E\u0442
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u043C.  ### \u2764\uFE0F
    \u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C \u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u043B\u0430\u0441\u044C
    \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u043E:  *   **\u041F\u0435\u0440\u0432\u044B\u0439
    \u0431\u0440\u0430\u043A (1941-1952):** \u0415\u0433\u043E \u0436\u0435\u043D\u043E\u0439
    \u0441\u0442\u0430\u043B\u0430 \u0431\u0438\u043E\u043B\u043E\u0433 \u0422\u0430\u0438\u0441\u0438\u044F
    \u0421\u0430\u043C\u0443\u0438\u043B\u043E\u0432\u043D\u0430 \u0418\u0432\u0430\u043D\u043E\u0432\u0430.
    \u041F\u043E \u0438\u0440\u043E\u043D\u0438\u0438 \u0441\u0443\u0434\u044C\u0431\u044B,
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D, \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u043F\u0438\u0441\u0430\u0432\u0448\u0438\u0439 \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0439, \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0441\u043A\u0443\u044E \u0440\u0430\u0431\u043E\u0442\u0443
    \u0434\u043B\u044F \u0436\u0435\u043D\u044B \u043F\u043E \u043C\u043E\u0440\u0444\u043E\u043B\u043E\u0433\u0438\u0438
    \u0441\u0430\u0440\u0430\u043D\u0447\u0438. \u041F\u043E\u0441\u043B\u0435 \u0435\u0451
    \u0443\u0441\u043F\u0435\u0448\u043D\u043E\u0439 \u0437\u0430\u0449\u0438\u0442\u044B
    \u043E\u043D \u043F\u043E\u0441\u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E
    \u043C\u043E\u0436\u0435\u0442 \u0440\u0430\u0437\u0432\u0435\u0441\u0442\u0438\u0441\u044C
    \xAB\u0441 \u0447\u0438\u0441\u0442\u043E\u0439 \u0441\u043E\u0432\u0435\u0441\u0442\u044C\u044E\xBB.
    *   **\u0412\u0442\u043E\u0440\u043E\u0439 \u0431\u0440\u0430\u043A (\u0441 1958):**
    \u0412\u0442\u043E\u0440\u043E\u0439 \u0440\u0430\u0437 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0432\u0440\u0430\u0447\u0435 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0435
    \u0418\u0433\u043D\u0430\u0442\u044C\u0435\u0432\u043D\u0435. \u041F\u043E \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F\u043C,
    \u044D\u0442\u043E \u0431\u044B\u043B\u0430 \u0435\u0433\u043E \u0441\u0430\u043C\u0430\u044F
    \u0431\u043E\u043B\u044C\u0448\u0430\u044F \u043B\u044E\u0431\u043E\u0432\u044C,
    \u043E\u043D \u0431\u044B\u043B \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u043A
    \u043D\u0435\u0439 \u043F\u0440\u0438\u0432\u044F\u0437\u0430\u043D. \u0414\u0435\u0442\u0435\u0439
    \u0432 \u043E\u0431\u043E\u0438\u0445 \u0431\u0440\u0430\u043A\u0430\u0445 \u043D\u0435
    \u0431\u044B\u043B\u043E. *   **\u0425\u0430\u0440\u0430\u043A\u0442\u0435\u0440:**
    \u0411\u043E\u0440\u044C\u0431\u0430 \u0441 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043D\u0435\u0434\u0443\u0433\u043E\u043C \u0437\u0430\u043A\u0430\u043B\u0438\u043B\u0430
    \u0435\u0433\u043E \u0432\u043E\u043B\u044E. \u041E\u043D \u0441\u0442\u0430\u0440\u0430\u043B\u0441\u044F
    \u043D\u0435 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C\u0441\u044F
    \u043F\u0440\u0438\u0441\u043F\u043E\u0441\u043E\u0431\u043B\u0435\u043D\u0438\u044F\u043C\u0438
    \u0434\u043B\u044F \u0441\u043B\u0435\u043F\u044B\u0445, \u043F\u0440\u0435\u0434\u043F\u043E\u0447\u0438\u0442\u0430\u043B
    \u0445\u043E\u0434\u0438\u0442\u044C \u043E\u0434\u0438\u043D, \u0447\u0430\u0441\u0442\u043E
    \u043F\u0430\u0434\u0430\u043B, \u043D\u043E \u043D\u0435 \u0441\u0434\u0430\u0432\u0430\u043B\u0441\u044F.
    \u041F\u043E \u0441\u043B\u043E\u0432\u0430\u043C \u0437\u043D\u0430\u0432\u0448\u0438\u0445
    \u0435\u0433\u043E \u043B\u044E\u0434\u0435\u0439, \u043D\u0438\u043A\u0442\u043E
    \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u0434\u0443\u043C\u0430\u043B
    \u043E \u043D\u0435\u043C \u043A\u0430\u043A \u043E \u0441\u043B\u0435\u043F\u043E\u043C
    \u0438 \u0443\u0449\u0435\u0440\u0431\u043D\u043E\u043C \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0435. 
    ### \U0001F54A\uFE0F \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B
    \u0438 \u0441\u043C\u0435\u0440\u0442\u044C \u0412 \u043A\u043E\u043D\u0446\u0435
    \u0436\u0438\u0437\u043D\u0438 \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0435
    \u043C\u0435\u043C\u0443\u0430\u0440\u044B \u043F\u043E\u0434 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0435\u043C
    \xAB\u0416\u0438\u0437\u043D\u0435\u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u041B. \u0421. \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430,
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430, \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u0435
    \u0438\u043C \u0441\u0430\u043C\u0438\u043C\xBB, \u0433\u0434\u0435 \u0434\u0430\u043B
    \u0440\u0435\u0437\u043A\u0438\u0435 \u0438 \u043E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u043D\u044B\u0435
    \u043E\u0446\u0435\u043D\u043A\u0438 \u043C\u043D\u043E\u0433\u0438\u043C \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C
    \u0438 \u0441\u043E\u0431\u044B\u0442\u0438\u044F\u043C, \u0447\u0442\u043E \u0432\u044B\u0437\u0432\u0430\u043B\u043E
    \u043D\u0435\u043E\u0434\u043D\u043E\u0437\u043D\u0430\u0447\u043D\u0443\u044E
    \u0440\u0435\u0430\u043A\u0446\u0438\u044E \u0432 \u043D\u0430\u0443\u0447\u043D\u043E\u043C
    \u0441\u043E\u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435.  \u0411\u0443\u0434\u0443\u0447\u0438
    \u0430\u043A\u0442\u0438\u0432\u043D\u044B\u043C \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0434\u0435\u044F\u0442\u0435\u043B\u0435\u043C, \u043E\u043D \u043C\u043D\u043E\u0433\u043E
    \u0441\u0438\u043B \u043F\u043E\u0441\u0432\u044F\u0449\u0430\u043B \u0432\u043E\u043F\u0440\u043E\u0441\u0430\u043C
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043D\u0438\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u0432 \u0448\u043A\u043E\u043B\u0435, \u0431\u043E\u0440\u044F\u0441\u044C \u0437\u0430
    \u0443\u043F\u0440\u043E\u0449\u0435\u043D\u0438\u0435 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C
    \u0438 \u0443\u0447\u0435\u0431\u043D\u0438\u043A\u043E\u0432.  \u041B\u0435\u0432
    \u0421\u0435\u043C\u0451\u043D\u043E\u0432\u0438\u0447 \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F **3 \u043C\u0430\u044F
    1988 \u0433\u043E\u0434\u0430 \u0432 \u041C\u043E\u0441\u043A\u0432\u0435** \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 79 \u043B\u0435\u0442. \u041E\u043D
    \u0431\u044B\u043B \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D \u043D\u0430
    **\u041D\u043E\u0432\u043E\u0434\u0435\u0432\u0438\u0447\u044C\u0435\u043C \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435**
    \u0441\u0442\u043E\u043B\u0438\u0446\u044B."
  personalLifeEn: 
  shortBioRu: "\u041B\u0435\u0432 \u0421\u0435\u043C\u0451\u043D\u043E\u0432\u0438\u0447
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D (1908\u20131988) \u2014
    \u043E\u0434\u0438\u043D \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 XX \u0432\u0435\u043A\u0430,
    \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C \u0438 \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u043F\u0443\u0442\u044C \u2014 \u044D\u0442\u043E \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u0439 \u0441\u0438\u043B\u044B
    \u0432\u043E\u043B\u0438, \u043F\u0440\u0435\u043E\u0434\u043E\u043B\u0435\u043D\u0438\u044F
    \u0438 \u0433\u0435\u043D\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043F\u0440\u043E\u0437\u0440\u0435\u043D\u0438\u044F.
    \u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u043F\u043E\u043B\u043D\u0443\u044E
    \u043F\u043E\u0442\u0435\u0440\u044E \u0437\u0440\u0435\u043D\u0438\u044F \u0432
    14 \u043B\u0435\u0442, \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043D\u044B\u043C
    \u043B\u0438\u0434\u0435\u0440\u043E\u043C \u0432 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445,
    \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u0440\u0430\u0437\u043D\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. 
    ### \U0001F52C \u041E\u0441\u043D\u043E\u0432\u043D\u044B\u0435 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F  \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0432 \u0442\u0440\u0435\u0445, \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C
    \u0431\u044B, \u0441\u043E\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E \u0440\u0430\u0437\u043D\u044B\u0445
    \u043E\u0431\u043B\u0430\u0441\u0442\u044F\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438,
    \u0438 \u0432 \u043A\u0430\u0436\u0434\u043E\u0439 \u0434\u043E\u0431\u0438\u043B\u0441\u044F
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u0432 \u043C\u0438\u0440\u043E\u0432\u043E\u0433\u043E
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F.  *   **\u0422\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F
    \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430:** \u0415\u0433\u043E \u043F\u0435\u0440\u0432\u0430\u044F
    \u0431\u043E\u043B\u044C\u0448\u0430\u044F \u043B\u044E\u0431\u043E\u0432\u044C.
    \u041E\u043D \u0434\u043E\u043A\u0430\u0437\u0430\u043B **\u043E\u0431\u0449\u0438\u0439
    \u0437\u0430\u043A\u043E\u043D \u0434\u0432\u043E\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u0438**,
    \u0441\u0432\u044F\u0437\u0430\u0432\u0448\u0438\u0439 \u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432 \u0438 \u0438\u0445
    \u0434\u043E\u043F\u043E\u043B\u043D\u0435\u043D\u0438\u0439. \u0422\u0430\u043A\u0436\u0435
    \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B **\u0442\u0435\u043E\u0440\u0438\u044E
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u0432 \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u044B\u0445
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0433\u0440\u0443\u043F\u043F** (\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u0430
    \u043A\u0430\u043A **\u0434\u0432\u043E\u0439\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430**). \u0412 \u0433\u043E\u043C\u043E\u0442\u043E\u043F\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438 \u043E\u043D \u043E\u0442\u043A\u0440\u044B\u043B
    \u043D\u043E\u0432\u044B\u0435 \u0438\u043D\u0432\u0430\u0440\u0438\u0430\u043D\u0442\u044B
    \u2014 **\u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043A\u043B\u0430\u0441\u0441\u044B \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430**.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F:** \u0412 \u043D\u0430\u0447\u0430\u043B\u0435
    1950-\u0445 \u0433\u043E\u0434\u043E\u0432 \u043E\u043D \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u043E
    \u0441\u043C\u0435\u043D\u0438\u043B \u043E\u0431\u043B\u0430\u0441\u0442\u044C
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 \u0438
    \u0441\u043E\u0437\u0434\u0430\u043B **\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0438\u044E \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u044B\u0445
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u0432**. \u0415\u0435 \u0441\u0435\u0440\u0434\u0446\u0435
    \u2014 **\u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C\u0430
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430**, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u043E\u043C \u0432
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F.
    *   **\u0422\u0435\u043E\u0440\u0438\u044F \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0445
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439 \u0438 \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u0439:**
    \u0412 1930-\u0445 \u0433\u043E\u0434\u0430\u0445, \u043F\u043E\u0434 \u0432\u043B\u0438\u044F\u043D\u0438\u0435\u043C
    \u0444\u0438\u0437\u0438\u043A\u0430 \u0410.\u0410. \u0410\u043D\u0434\u0440\u043E\u043D\u043E\u0432\u0430,
    \u043E\u043D \u0437\u0430\u043B\u043E\u0436\u0438\u043B \u043E\u0441\u043D\u043E\u0432\u044B
    \u0442\u0435\u043E\u0440\u0438\u0438 **\xAB\u0433\u0440\u0443\u0431\u044B\u0445
    \u0441\u0438\u0441\u0442\u0435\u043C\xBB** \u0438 \u0432\u043D\u0435\u0441 \u0432\u043A\u043B\u0430\u0434
    \u0432 \u0430\u0441\u0438\u043C\u043F\u0442\u043E\u0442\u0438\u043A\u0443 \u0440\u0435\u043B\u0430\u043A\u0441\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0445
    \u043A\u043E\u043B\u0435\u0431\u0430\u043D\u0438\u0439.  ### \U0001F4D6 \u0416\u0438\u0437\u043D\u0435\u043D\u043D\u044B\u0439
    \u043F\u0443\u0442\u044C \u0432 \u0434\u0435\u0442\u0430\u043B\u044F\u0445  *  
    **\u0414\u0435\u0442\u0441\u0442\u0432\u043E \u0438 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u044F:**
    \u0420\u043E\u0434\u0438\u043B\u0441\u044F \u0432 \u041C\u043E\u0441\u043A\u0432\u0435
    3 \u0441\u0435\u043D\u0442\u044F\u0431\u0440\u044F 1908 \u0433\u043E\u0434\u0430
    \u0432 \u0441\u0435\u043C\u044C\u0435 \u0441\u0447\u0435\u0442\u043E\u0432\u043E\u0434\u0430
    \u0438 \u043F\u043E\u0440\u0442\u043D\u0438\u0445\u0438. \u0412 13 \u043B\u0435\u0442
    \u0441 \u043D\u0438\u043C \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u0435\u043B
    \u043D\u0435\u0441\u0447\u0430\u0441\u0442\u043D\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439:
    \u043F\u0440\u0438 \u043F\u043E\u043F\u044B\u0442\u043A\u0435 \u043F\u043E\u0447\u0438\u043D\u0438\u0442\u044C
    \u043F\u0440\u0438\u043C\u0443\u0441 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u0435\u043B
    \u0432\u0437\u0440\u044B\u0432. \u041E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0442\u044F\u0436\u0435\u043B\u044B\u0435 \u043E\u0436\u043E\u0433\u0438 \u043B\u0438\u0446\u0430
    \u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u0437\u0440\u0435\u043D\u0438\u0435. \u041F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0430\u044F
    \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u044F \u0442\u043E\u043B\u044C\u043A\u043E
    \u0443\u0445\u0443\u0434\u0448\u0438\u043B\u0430 \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044E,
    \u043F\u0440\u0438\u0432\u0435\u0434\u044F \u043A \u043F\u043E\u043B\u043D\u043E\u0439
    \u0441\u043B\u0435\u043F\u043E\u0442\u0435. *   **\u041C\u0430\u0442\u044C \u2014
    \u0435\u0433\u043E \xAB\u0433\u043B\u0430\u0437\u0430\xBB:** \u0415\u0433\u043E
    \u043C\u0430\u0442\u044C, \u0422\u0430\u0442\u044C\u044F\u043D\u0430 \u0410\u043D\u0434\u0440\u0435\u0435\u0432\u043D\u0430,
    \u0441\u0442\u0430\u043B\u0430 \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0439
    \u043E\u043F\u043E\u0440\u043E\u0439. \u041D\u0435 \u0438\u043C\u0435\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F, \u043E\u043D\u0430
    \u0432\u044B\u0443\u0447\u0438\u043B\u0430 \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0435
    \u044F\u0437\u044B\u043A\u0438, \u0447\u0442\u043E\u0431\u044B \u0447\u0438\u0442\u0430\u0442\u044C
    \u0441\u044B\u043D\u0443 \u0432\u0441\u043B\u0443\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0441\u0442\u0430\u0442\u044C\u0438 \u0438 \u043A\u043D\u0438\u0433\u0438, \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u043B\u0430
    \u0440\u043E\u043B\u044C \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0433\u043E
    \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u044F \u0438 \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u043E\u0440\u0430.
    \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0435\u0439 \u043E\u043D
    \u0441\u043C\u043E\u0433 \u043E\u043A\u043E\u043D\u0447\u0438\u0442\u044C \u0448\u043A\u043E\u043B\u0443
    \u0438 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u0442\u044C \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442.
    *   **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u0438
    \u0431\u043B\u0438\u0441\u0442\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0441\u0442\u0430\u0440\u0442:** \u0412 1925 \u0433\u043E\u0434\u0443 \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B \u043D\u0430 \u0444\u0438\u0437\u043C\u0430\u0442
    \u041C\u0413\u0423. \u0411\u0443\u0434\u0443\u0447\u0438 \u0441\u043B\u0435\u043F\u044B\u043C,
    \u043E\u043D \u043E\u0431\u043B\u0430\u0434\u0430\u043B \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u043F\u0430\u043C\u044F\u0442\u044C\u044E, \u0437\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u044F
    \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0435 \u0432\u044B\u043A\u043B\u0430\u0434\u043A\u0438
    \u043D\u0430 \u0441\u043B\u0443\u0445. \u041E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043D\u0430 \u043B\u0435\u043A\u0446\u0438\u0438 \u043E\u043D, \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440\u0443\u044F\u0441\u044C
    \u043F\u043E \u0433\u043E\u043B\u043E\u0441\u0443, \u0443\u043A\u0430\u0437\u0430\u043B
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0443 \u043D\u0430 \u043E\u0448\u0438\u0431\u043A\u0443
    \u0432 \u0447\u0435\u0440\u0442\u0435\u0436\u0435 \u043D\u0430 \u0434\u043E\u0441\u043A\u0435.
    \u0423\u0436\u0435 \u043D\u0430 \u0432\u0442\u043E\u0440\u043E\u043C \u043A\u0443\u0440\u0441\u0435
    \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u043D\u0430\u0443\u0447\u043D\u0443\u044E
    \u0440\u0430\u0431\u043E\u0442\u0443 \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u041F.\u0421. \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u0432\u0430.
    *   **\u0421\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0432\u0437\u043B\u0435\u0442:** \u0412 1935 \u0433\u043E\u0434\u0443, \u0432
    \u0432\u043E\u0437\u0440\u0430\u0441\u0442\u0435 27 \u043B\u0435\u0442, \u0435\u043C\u0443
    \u0431\u0435\u0437 \u0437\u0430\u0449\u0438\u0442\u044B \u0431\u044B\u043B\u0430
    \u043F\u0440\u0438\u0441\u0443\u0436\u0434\u0435\u043D\u0430 \u0441\u0442\u0435\u043F\u0435\u043D\u044C
    \u0434\u043E\u043A\u0442\u043E\u0440\u0430 \u0444\u0438\u0437\u0438\u043A\u043E-\u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u043D\u0430\u0443\u043A, \u0438 \u043E\u043D \u0441\u0442\u0430\u043B \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u043E\u043C.
    \u0412 1939 \u0433\u043E\u0434\u0443 \u043E\u043D \u0431\u044B\u043B \u0438\u0437\u0431\u0440\u0430\u043D
    \u0447\u043B\u0435\u043D\u043E\u043C-\u043A\u043E\u0440\u0440\u0435\u0441\u043F\u043E\u043D\u0434\u0435\u043D\u0442\u043E\u043C,
    \u0430 \u0432 1958 \u2014 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C
    \u0447\u043B\u0435\u043D\u043E\u043C \u0410\u041D \u0421\u0421\u0421\u0420. *  
    **\u0421\u043C\u0435\u043B\u0430\u044F \u0441\u043C\u0435\u043D\u0430 \u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438:**
    \u041A 1950-\u043C \u0433\u043E\u0434\u0430\u043C \u043E\u043D \u0431\u044B\u043B
    \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043D\u044B\u043C \u043B\u0438\u0434\u0435\u0440\u043E\u043C
    \u0432 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438, \u043D\u043E,
    \u043F\u043E \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0441\u043B\u043E\u0432\u0430\u043C, **\xAB\u0438\u0437 \u044D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0441\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439\xBB** \u0440\u0435\u0448\u0438\u043B
    \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u0442\u044C\u0441\u044F
    \u043D\u0430 \u0431\u043E\u043B\u0435\u0435 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0435
    \u0437\u0430\u0434\u0430\u0447\u0438. \u042D\u0442\u043E\u0442 \u0441\u043C\u0435\u043B\u044B\u0439
    \u0448\u0430\u0433 \u043F\u0440\u0438\u0432\u0435\u043B \u043A \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u044E
    \u0442\u0435\u043E\u0440\u0438\u0438 \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F \u0438 **\u043F\u0440\u0438\u043D\u0446\u0438\u043F\u0430
    \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C\u0430**. *   **\u041B\u0438\u0447\u043D\u0430\u044F
    \u0436\u0438\u0437\u043D\u044C \u0438 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440:**
    \u0415\u0433\u043E \u043B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0431\u044B\u043B\u0430 \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u043E\u0439.
    \u041F\u0435\u0440\u0432\u044B\u0439 \u0440\u0430\u0437 \u043E\u043D \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u0432 1941 \u0433\u043E\u0434\u0443 \u043D\u0430 \u0431\u0438\u043E\u043B\u043E\u0433\u0435
    \u0422\u0430\u0438\u0441\u0438\u0438 \u0418\u0432\u0430\u043D\u043E\u0432\u043E\u0439,
    \u043D\u043E \u0431\u0440\u0430\u043A \u0440\u0430\u0441\u043F\u0430\u043B\u0441\u044F.
    \u0412\u0442\u043E\u0440\u043E\u0439 \u0440\u0430\u0437 \u0436\u0435\u043D\u0438\u043B\u0441\u044F
    \u0432 1958 \u0433\u043E\u0434\u0443 \u043D\u0430 \u0432\u0440\u0430\u0447\u0435
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0435 \u0418\u0433\u043D\u0430\u0442\u044C\u0435\u0432\u043D\u0435.
    \u041E\u043D \u0431\u044B\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0435\u043D
    \u0441\u0432\u043E\u0438\u043C \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u044B\u043C
    \u0438 \u0431\u0435\u0441\u043A\u043E\u043C\u043F\u0440\u043E\u043C\u0438\u0441\u0441\u043D\u044B\u043C
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043E\u043C, \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B \u0432 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438, \u0432 \u0442\u043E\u043C \u0447\u0438\u0441\u043B\u0435
    \u0432 \xAB\u0434\u0435\u043B\u0435 \u041B\u0443\u0437\u0438\u043D\u0430\xBB
    \u0438 \u0432 \u0434\u0438\u0441\u043A\u0443\u0441\u0441\u0438\u044F\u0445 \u043E
    \u0448\u043A\u043E\u043B\u044C\u043D\u043E\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0438,
    \u0437\u0430 \u0447\u0442\u043E \u043D\u0430\u0436\u0438\u043B \u043C\u043D\u043E\u0433\u043E
    \u043D\u0435\u0434\u043E\u0431\u0440\u043E\u0436\u0435\u043B\u0430\u0442\u0435\u043B\u0435\u0439.
    *   **\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0433\u043E\u0434\u044B:**
    \u0412 \u043A\u043E\u043D\u0446\u0435 \u0436\u0438\u0437\u043D\u0438 \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0435 \u043C\u0435\u043C\u0443\u0430\u0440\u044B,
    \u0433\u0434\u0435 \u0434\u0430\u043B \u043E\u0446\u0435\u043D\u043A\u0438 \u043C\u043D\u043E\u0433\u0438\u043C
    \u0441\u043E\u0431\u044B\u0442\u0438\u044F\u043C \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C.
    \u0423\u043C\u0435\u0440 3 \u043C\u0430\u044F 1988 \u0433\u043E\u0434\u0430,
    \u043F\u043E\u0445\u043E\u0440\u043E\u043D\u0435\u043D \u043D\u0430 \u041D\u043E\u0432\u043E\u0434\u0435\u0432\u0438\u0447\u044C\u0435\u043C
    \u043A\u043B\u0430\u0434\u0431\u0438\u0449\u0435.  ### \U0001F3C5 \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
    \u0438 \u043D\u0430\u0433\u0440\u0430\u0434\u044B  - **\u0421\u0442\u0430\u043B\u0438\u043D\u0441\u043A\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F** (1941) \u2014 \u0437\u0430 \u043C\u043E\u043D\u043E\u0433\u0440\u0430\u0444\u0438\u044E
    \xAB\u041D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0435 \u0433\u0440\u0443\u043F\u043F\u044B\xBB.
    - **\u041B\u0435\u043D\u0438\u043D\u0441\u043A\u0430\u044F \u043F\u0440\u0435\u043C\u0438\u044F**
    (1962) \u2014 \u0437\u0430 \u0446\u0438\u043A\u043B \u0440\u0430\u0431\u043E\u0442
    \u043F\u043E \u0442\u0435\u043E\u0440\u0438\u0438 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F.
    - **\u0413\u043E\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043D\u043D\u0430\u044F
    \u043F\u0440\u0435\u043C\u0438\u044F \u0421\u0421\u0421\u0420** (1975) \u2014
    \u0437\u0430 \u0443\u0447\u0435\u0431\u043D\u0438\u043A \xAB\u041E\u0431\u044B\u043A\u043D\u043E\u0432\u0435\u043D\u043D\u044B\u0435
    \u0434\u0438\u0444\u0444\u0435\u0440\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044F\xBB. - **\u0413\u0435\u0440\u043E\u0439
    \u0421\u043E\u0446\u0438\u0430\u043B\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0422\u0440\u0443\u0434\u0430** (1969). - \u041C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u043E
    \u043E\u0440\u0434\u0435\u043D\u043E\u0432, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u043F\u044F\u0442\u044C \u043E\u0440\u0434\u0435\u043D\u043E\u0432 \u041B\u0435\u043D\u0438\u043D\u0430.
    - \u0411\u044B\u043B \u0432\u0438\u0446\u0435-\u043F\u0440\u0435\u0437\u0438\u0434\u0435\u043D\u0442\u043E\u043C
    \u041C\u0435\u0436\u0434\u0443\u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u043E\u044E\u0437\u0430 \u0438 \u043F\u043E\u0447\u0435\u0442\u043D\u044B\u043C
    \u0447\u043B\u0435\u043D\u043E\u043C \u041B\u043E\u043D\u0434\u043E\u043D\u0441\u043A\u043E\u0433\u043E
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u0438 \u0412\u0435\u043D\u0433\u0435\u0440\u0441\u043A\u043E\u0439
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0438 \u043D\u0430\u0443\u043A.  ###
    \U0001F48E \u0418\u0442\u043E\u0433  \u041B\u0435\u0432 \u0421\u0435\u043C\u0451\u043D\u043E\u0432\u0438\u0447
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D \u2014 \u0444\u0438\u0433\u0443\u0440\u0430
    \u043F\u043B\u0430\u043D\u0435\u0442\u0430\u0440\u043D\u043E\u0433\u043E \u043C\u0430\u0441\u0448\u0442\u0430\u0431\u0430.
    \u0415\u0433\u043E \u0436\u0438\u0437\u043D\u044C \u2014 \u044D\u0442\u043E \u043F\u043E\u0431\u0435\u0434\u0430
    \u0434\u0443\u0445\u0430 \u043D\u0430\u0434 \u043E\u0431\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C\u0438,
    \u0430 \u0435\u0433\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u043D\u0430\u0432\u0441\u0435\u0433\u0434\u0430
    \u0438\u0437\u043C\u0435\u043D\u0438\u043B\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443,
    \u043E\u0442 \u0430\u0431\u0441\u0442\u0440\u0430\u043A\u0442\u043D\u043E\u0439
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438 \u0434\u043E \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u0430\u0434\u0430\u0447 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u043F\u043E\u043B\u0435\u0442\u0430\u043C\u0438 \u0438 \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u0430\u043C\u0438. \u041E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0430\u0443\u0447\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u044B, \u043D\u043E
    \u0438 \u043C\u043E\u0449\u043D\u0443\u044E \u043D\u0430\u0443\u0447\u043D\u0443\u044E
    \u0448\u043A\u043E\u043B\u0443, \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u0432
    \u0442\u0430\u043A\u0438\u0445 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432,
    \u043A\u0430\u043A \u0414.\u0412. \u0410\u043D\u043E\u0441\u043E\u0432, \u0412.\u0413.
    \u0411\u043E\u043B\u0442\u044F\u043D\u0441\u043A\u0438\u0439, \u0420.\u0412.
    \u0413\u0430\u043C\u043A\u0440\u0435\u043B\u0438\u0434\u0437\u0435 \u0438 \u0434\u0440\u0443\u0433\u0438\u0435."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u041B\u044C\u0432\u0430 \u0421\u0435\u043C\u0451\u043D\u043E\u0432\u0438\u0447\u0430
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430 \u043F\u043E\u043B\u043D\u0430
    \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u0438\u0441\u0442\u043E\u0440\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \u0435\u0433\u043E \u0444\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u0443\u044E
    \u0432\u043E\u043B\u044E, \u043C\u0443\u0436\u0435\u0441\u0442\u0432\u043E \u0438
    \u043D\u0435\u0437\u0430\u0443\u0440\u044F\u0434\u043D\u044B\u0439 \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440.
    \u0412\u043E\u0442 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0437
    \u0441\u0430\u043C\u044B\u0445 \u044F\u0440\u043A\u0438\u0445 \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432.  ### \U0001F468\u200D\U0001F469\u200D\U0001F467\u200D\U0001F466
    \u041F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0430 \u0434\u0440\u0443\u0437\u0435\u0439
    \u0438 \u0441\u0430\u043C\u043E\u043E\u0442\u0432\u0435\u0440\u0436\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u043C\u0430\u0442\u0435\u0440\u0438  \u041F\u043E\u0441\u043B\u0435 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438
    \u0441 \u043F\u0440\u0438\u043C\u0443\u0441\u043E\u043C, \u043A\u043E\u0433\u0434\u0430
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D \u043E\u0441\u043B\u0435\u043F,
    \u0435\u0433\u043E \u043E\u0434\u043D\u043E\u043A\u043B\u0430\u0441\u0441\u043D\u0438\u043A\u0438
    \u043D\u0435 \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438 \u0442\u043E\u0432\u0430\u0440\u0438\u0449\u0430
    \u0432 \u0431\u0435\u0434\u0435. \u041E\u043D\u0438 \u043F\u0440\u0438\u0448\u043B\u0438
    \u043A \u043D\u0435\u043C\u0443 \u0434\u043E\u043C\u043E\u0439 \u0438 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B\u0438
    \u0441\u0432\u043E\u044E \u043F\u043E\u043C\u043E\u0449\u044C: \u043F\u043E \u043E\u0447\u0435\u0440\u0435\u0434\u0438
    \u0432\u043E\u0434\u0438\u0442\u044C \u0435\u0433\u043E \u0432 \u0448\u043A\u043E\u043B\u0443,
    \u043F\u043E\u043C\u043E\u0433\u0430\u0442\u044C \u043D\u0430 \u0443\u0440\u043E\u043A\u0430\u0445,
    \u043E\u0437\u0432\u0443\u0447\u0438\u0432\u0430\u044F, \u0447\u0442\u043E \u0443\u0447\u0438\u0442\u0435\u043B\u044C
    \u043F\u0438\u0448\u0435\u0442 \u043D\u0430 \u0434\u043E\u0441\u043A\u0435. \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u044D\u0442\u043E\u0439 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0435
    \u0438 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E\u043C\u0443
    \u0443\u043F\u043E\u0440\u0441\u0442\u0432\u0443 \u0441\u0430\u043C\u043E\u0433\u043E
    \u041B\u044C\u0432\u0430, \u043E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B \u0443\u0447\u0435\u0431\u0443,
    \u043D\u043E \u0438 \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B \u0448\u043A\u043E\u043B\u0443
    \u0441 \u0437\u043E\u043B\u043E\u0442\u043E\u0439 \u043C\u0435\u0434\u0430\u043B\u044C\u044E. 
    \u0413\u043B\u0430\u0432\u043D\u043E\u0439 \u0436\u0435 \u043E\u043F\u043E\u0440\u043E\u0439
    \u0438 \"\u0433\u043B\u0430\u0437\u0430\u043C\u0438\" \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430
    \u0441\u0442\u0430\u043B\u0430 \u0435\u0433\u043E \u043C\u0430\u0442\u044C, \u0422\u0430\u0442\u044C\u044F\u043D\u0430
    \u0410\u043D\u0434\u0440\u0435\u0435\u0432\u043D\u0430. \u041D\u0435 \u0438\u043C\u0435\u044F
    \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F,
    \u043E\u043D\u0430 \u0432\u044B\u0443\u0447\u0438\u043B\u0430 \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0435
    \u044F\u0437\u044B\u043A\u0438, \u0447\u0442\u043E\u0431\u044B \u0447\u0438\u0442\u0430\u0442\u044C
    \u0441\u044B\u043D\u0443 \u0432\u0441\u043B\u0443\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0435
    \u0441\u0442\u0430\u0442\u044C\u0438. \u041E\u043D\u0430 \u0431\u044B\u043B\u0430
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u044B\u043C \u0441\u0435\u043A\u0440\u0435\u0442\u0430\u0440\u0435\u043C,
    \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u043B\u0430 \u043F\u043E\u0434
    \u0434\u0438\u043A\u0442\u043E\u0432\u043A\u0443 \u0442\u0440\u0443\u0434\u044B
    \u0438 \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u043A\u043E\u0440\u0440\u0435\u043A\u0442\u0443\u0440\u0443.
    \u0427\u0442\u043E\u0431\u044B \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0442\u044C
    \u0441\u043B\u0435\u043F\u043E\u043C\u0443 \u0441\u044B\u043D\u0443 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0437\u043D\u0430\u043A\u0438, \u043E\u043D\u0438 \u043F\u0440\u0438\u0434\u0443\u043C\u0430\u043B\u0438
    \u0441\u0432\u043E\u044E \u0441\u0438\u0441\u0442\u0435\u043C\u0443 \u043E\u0431\u043E\u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0437\u043D\u0430\u043A \u043F\u0435\u0440\u0435\u0441\u0435\u0447\u0435\u043D\u0438\u044F
    \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432 (`\u2229`) \u0443 \u043D\u0438\u0445
    \u043D\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F \"\u0445\u0432\u043E\u0441\u0442\u0438\u043A
    \u0432\u0432\u0435\u0440\u0445\", \u0438 \u043A\u043E\u0433\u0434\u0430 \u0422\u0430\u0442\u044C\u044F\u043D\u0430
    \u0410\u043D\u0434\u0440\u0435\u0435\u0432\u043D\u0430 \u0447\u0438\u0442\u0430\u043B\u0430
    \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435, \u043E\u043D\u0430 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0430:
    \"\u0410 \u0445\u0432\u043E\u0441\u0442\u0438\u043A \u0432\u0432\u0435\u0440\u0445
    B\". \u041E\u043D \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u0448\u0440\u0438\u0444\u0442\u043E\u043C \u0411\u0440\u0430\u0439\u043B\u044F. 
    ### \U0001F9E0 \u0424\u0435\u043D\u043E\u043C\u0435\u043D\u0430\u043B\u044C\u043D\u0430\u044F
    \u043F\u0430\u043C\u044F\u0442\u044C \u0438 \"\u043D\u0435\u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0435\"
    \u0443\u043F\u043E\u0440\u0441\u0442\u0432\u043E  \u041F\u043E\u0442\u0435\u0440\u044F
    \u0437\u0440\u0435\u043D\u0438\u044F \u043D\u0435 \u0441\u043B\u043E\u043C\u0438\u043B\u0430
    \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430, \u0430 \u0437\u0430\u043A\u0430\u043B\u0438\u043B\u0430
    \u0435\u0433\u043E \u0432\u043E\u043B\u044E. \u041F\u043E \u0432\u043E\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F\u043C
    \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u043A\u0430 \u0418.\u0420. \u0428\u0430\u0444\u0430\u0440\u0435\u0432\u0438\u0447\u0430,
    \u043E\u043D \"\u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u0435\u0451 \u043F\u0440\u0438\u0437\u043D\u0430\u0442\u044C. \u041E\u043D \u043D\u0438\u043A\u043E\u0433\u0434\u0430
    \u043D\u0435 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0441\u044F
    \u043D\u0438\u043A\u0430\u043A\u043E\u0439 \u0442\u0435\u0445\u043D\u0438\u043A\u043E\u0439,
    \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0435\u043D\u043D\u043E\u0439
    \u0434\u043B\u044F \u0441\u043B\u0435\u043F\u044B\u0445. \u0412\u0441\u0435\u0433\u0434\u0430
    \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0445\u043E\u0434\u0438\u0442\u044C
    \u0441\u0430\u043C, \u0431\u0435\u0437 \u0441\u043E\u043F\u0440\u043E\u0432\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0434\u0440\u0443\u0433\u0438\u0445. \u0412 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435
    \u0443 \u043D\u0435\u0433\u043E \u043D\u0430 \u043B\u0438\u0446\u0435 \u0432\u0441\u0435\u0433\u0434\u0430
    \u0431\u044B\u043B\u0438 \u0441\u0441\u0430\u0434\u0438\u043D\u044B \u0438 \u0446\u0430\u0440\u0430\u043F\u0438\u043D\u044B.
    \u041E\u043D \u043D\u0430\u0443\u0447\u0438\u043B\u0441\u044F \u043A\u0430\u0442\u0430\u0442\u044C\u0441\u044F
    \u043D\u0430 \u043A\u043E\u043D\u044C\u043A\u0430\u0445, \u043D\u0430 \u043B\u044B\u0436\u0430\u0445,
    \u043F\u043B\u0430\u0432\u0430\u043B \u043D\u0430 \u0431\u0430\u0439\u0434\u0430\u0440\u043A\u0435\". 
    \u0412 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442\u0435
    \u043E\u043D \u043F\u043E\u0440\u0430\u0436\u0430\u043B \u0432\u0441\u0435\u0445
    \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C\u044E \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0442\u044C
    \u0432 \u043F\u0430\u043C\u044F\u0442\u0438 \u0441\u043B\u043E\u0436\u043D\u0435\u0439\u0448\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0432\u044B\u043A\u043B\u0430\u0434\u043A\u0438, \u043D\u0438\u0447\u0435\u0433\u043E
    \u043D\u0435 \u0437\u0430\u043F\u0438\u0441\u044B\u0432\u0430\u044F \u043D\u0430
    \u043B\u0435\u043A\u0446\u0438\u044F\u0445. \u041E\u043D \u043E\u0431\u043B\u0430\u0434\u0430\u043B
    \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0438\u043D\u0442\u0443\u0438\u0446\u0438\u0435\u0439. \u041E\u0434\u043D\u0430\u0436\u0434\u044B
    \u043D\u0430 \u043B\u0435\u043A\u0446\u0438\u0438 \u043E\u043D, \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440\u0443\u044F\u0441\u044C
    \u043F\u043E \u0433\u043E\u043B\u043E\u0441\u0443, \u0443\u043A\u0430\u0437\u0430\u043B
    \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0443 \u043D\u0430 \u043E\u0448\u0438\u0431\u043A\u0443
    \u0432 \u0447\u0435\u0440\u0442\u0435\u0436\u0435 \u043D\u0430 \u0434\u043E\u0441\u043A\u0435. 
    ### \U0001F9D7 \u0421\u043C\u0435\u043B\u044B\u0439 \u043F\u043E\u0432\u043E\u0440\u043E\u0442
    \u0432 \u043D\u0430\u0443\u043A\u0435  \u0411\u0443\u0434\u0443\u0447\u0438 \u0443\u0436\u0435
    \u0432\u0441\u0435\u043C\u0438\u0440\u043D\u043E \u043F\u0440\u0438\u0437\u043D\u0430\u043D\u043D\u044B\u043C
    \u043B\u0438\u0434\u0435\u0440\u043E\u043C \u0432 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438,
    \u0432 1950-\u0445 \u0433\u043E\u0434\u0430\u0445 \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B \u043A\u0430\u0440\u0434\u0438\u043D\u0430\u043B\u044C\u043D\u0443\u044E
    \u0441\u043C\u0435\u043D\u0443 \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432,
    \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0438\u0432\u0448\u0438\u0441\u044C
    \u043D\u0430 \u043F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438.
    \u042D\u0442\u043E\u0442 \u0440\u0438\u0441\u043A\u043E\u0432\u0430\u043D\u043D\u044B\u0439
    \u0448\u0430\u0433 \u043E\u043D \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u043B
    \"\u0438\u0437 \u044D\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445 \u0441\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0439\":
    \u0435\u043C\u0443 \u0445\u043E\u0442\u0435\u043B\u043E\u0441\u044C, \u0447\u0442\u043E\u0431\u044B
    \u0435\u0433\u043E \u0442\u0440\u0443\u0434\u044B \u043F\u0440\u0438\u043D\u043E\u0441\u0438\u043B\u0438
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0443\u044E \u043F\u043E\u043B\u044C\u0437\u0443.
    \u0414\u043B\u044F \u044D\u0442\u043E\u0433\u043E \u043E\u043D, \u0443\u0436\u0435
    \u0431\u0443\u0434\u0443\u0447\u0438 \u043C\u044D\u0442\u0440\u043E\u043C, \u043F\u043E
    \u0441\u0443\u0442\u0438, \u0441\u0442\u0430\u043B \"\u043D\u0430\u0447\u0438\u043D\u0430\u044E\u0449\u0438\u043C\",
    \u0447\u0430\u0441\u0430\u043C\u0438 \u043E\u0431\u0449\u0430\u044F\u0441\u044C
    \u0441 \u0438\u043D\u0436\u0435\u043D\u0435\u0440\u0430\u043C\u0438 \u0438 \u0444\u0438\u0437\u0438\u043A\u0430\u043C\u0438,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043D\u044F\u0442\u044C \u0438\u0445
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u0438 \u043F\u0435\u0440\u0435\u0432\u0435\u0441\u0442\u0438
    \u0438\u0445 \u043D\u0430 \u044F\u0437\u044B\u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438.
    \u0420\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u043E\u043C \u0441\u0442\u0430\u043B
    \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439 **\u043F\u0440\u0438\u043D\u0446\u0438\u043F
    \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C\u0430 \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430**
    \u2014 \u043E\u0441\u043D\u043E\u0432\u0430 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043E\u043F\u0442\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F. 
    ### \U0001F981 \u041C\u0443\u0436\u0435\u0441\u0442\u0432\u043E \u0438 \u0431\u0435\u0441\u043A\u043E\u043C\u043F\u0440\u043E\u043C\u0438\u0441\u0441\u043D\u043E\u0441\u0442\u044C
    \u0432 \u043F\u043E\u0441\u0442\u0443\u043F\u043A\u0430\u0445  \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u043D\u0435 \u0431\u043E\u044F\u043B\u0441\u044F \u0438\u0434\u0442\u0438 \u043F\u0440\u043E\u0442\u0438\u0432
    \u0441\u0438\u0441\u0442\u0435\u043C\u044B, \u0435\u0441\u043B\u0438 \u0441\u0447\u0438\u0442\u0430\u043B
    \u044D\u0442\u043E \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u043C. 
    *   **\u0412 \u0437\u0430\u0449\u0438\u0442\u0443 \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430:**
    \u0412 1939 \u0433\u043E\u0434\u0443, \u0432\u043E \u0432\u0440\u0435\u043C\u044F
    \u0432\u044B\u0431\u043E\u0440\u043E\u0432 \u0432 \u0410\u043A\u0430\u0434\u0435\u043C\u0438\u044E
    \u043D\u0430\u0443\u043A, \u043E\u043D \u043F\u0443\u0431\u043B\u0438\u0447\u043D\u043E
    \u0432\u044B\u0441\u0442\u0443\u043F\u0438\u043B \u0441 \u0440\u0435\u0447\u044C\u044E
    \u0432 \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0443 \u043A\u0430\u043D\u0434\u0438\u0434\u0430\u0442\u0443\u0440\u044B
    \u0410.\u041D. \u041A\u043E\u043B\u043C\u043E\u0433\u043E\u0440\u043E\u0432\u0430,
    \u043D\u0430\u0440\u0443\u0448\u0438\u0432 \u043D\u0435\u0433\u043B\u0430\u0441\u043D\u044B\u0439
    \u0437\u0430\u043F\u0440\u0435\u0442, \u0447\u0442\u043E \u0431\u044B\u043B\u043E
    \u043E\u0447\u0435\u043D\u044C \u0441\u043C\u0435\u043B\u044B\u043C \u0448\u0430\u0433\u043E\u043C.
    *   **\u041F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0430 \u043E\u043F\u0430\u043B\u044C\u043D\u044B\u0445
    \u043A\u043E\u043B\u043B\u0435\u0433:** \u041E\u043D \u0440\u0435\u0433\u0443\u043B\u044F\u0440\u043D\u043E
    \u043F\u0438\u0441\u0430\u043B \u043F\u0438\u0441\u044C\u043C\u0430 \u0432 \u043B\u0430\u0433\u0435\u0440\u044F
    \u0441\u0432\u043E\u0438\u043C \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C,
    \u0432 \u0447\u0430\u0441\u0442\u043D\u043E\u0441\u0442\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0443
    \u0412.\u0410. \u0415\u0444\u0440\u0435\u043C\u043E\u0432\u0438\u0447\u0443,
    \u0447\u0442\u043E \u0432 \u0442\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u0430
    \u0431\u044B\u043B\u043E \u0440\u0430\u0432\u043D\u043E\u0441\u0438\u043B\u044C\u043D\u043E
    \u043F\u043E\u0434\u0432\u0438\u0433\u0443. \u041E\u043D \u0442\u0430\u043A\u0436\u0435
    \u0434\u043E\u0431\u0438\u043B\u0441\u044F \u043E\u0441\u0432\u043E\u0431\u043E\u0436\u0434\u0435\u043D\u0438\u044F
    \u0438\u0437 \u043B\u0430\u0433\u0435\u0440\u044F \u0434\u0440\u0443\u0433\u043E\u0433\u043E
    \u0441\u0432\u043E\u0435\u0433\u043E \u0443\u0447\u0435\u043D\u0438\u043A\u0430
    \u0438 \u043F\u0440\u0435\u0434\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0435\u043C\u0443
    \u0436\u0438\u043B\u044C\u0435 \u043D\u0430 \u0441\u0435\u043C\u044C \u043B\u0435\u0442.
    \u041E\u0434\u0438\u043D \u0438\u0437 \u0443\u0447\u0435\u043D\u0438\u043A\u043E\u0432
    \u0441\u043F\u0430\u0441 \u0435\u043C\u0443 \u0436\u0438\u0437\u043D\u044C \u0432
    \u0433\u043E\u043B\u043E\u0434\u043D\u044B\u0435 \u0432\u043E\u0435\u043D\u043D\u044B\u0435
    \u0433\u043E\u0434\u044B, \u043F\u0440\u0438\u043D\u0435\u0441\u044F \u0441\u0432\u043E\u0439
    \u043F\u0430\u0435\u043A, \u043A\u043E\u0433\u0434\u0430 \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u0443\u043C\u0438\u0440\u0430\u043B \u043E\u0442 \u0434\u0438\u0441\u0442\u0440\u043E\u0444\u0438\u0438.
    *   **\"\u0422\u0430\u043A \u0441\u0434\u0435\u043B\u0430\u0439\u0442\u0435 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0435\":**
    \u042D\u0442\u0430 \u0444\u0440\u0430\u0437\u0430 \u0441\u0442\u0430\u043B\u0430
    \u0435\u0433\u043E \u0432\u0438\u0437\u0438\u0442\u043D\u043E\u0439 \u043A\u0430\u0440\u0442\u043E\u0447\u043A\u043E\u0439.
    \u041A\u043E\u0433\u0434\u0430 \u043A\u0442\u043E-\u0442\u043E \u0433\u043E\u0432\u043E\u0440\u0438\u043B
    \u0435\u043C\u0443, \u0447\u0442\u043E \u0435\u0433\u043E \u0442\u0440\u0435\u0431\u043E\u0432\u0430\u043D\u0438\u0435
    \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u0442\u044C,
    \u043E\u043D \u043E\u0442\u0432\u0435\u0447\u0430\u043B: \"\u0422\u0430\u043A
    \u0441\u0434\u0435\u043B\u0430\u0439\u0442\u0435 \u043D\u0435\u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0435!\".
    \u042D\u0442\u043E\u0442 \u043F\u0440\u0438\u043D\u0446\u0438\u043F \u043E\u043D
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u043B \u0438 \u043A \u0441\u0430\u043C\u043E\u043C\u0443
    \u0441\u0435\u0431\u0435, \u0434\u0435\u043B\u0430\u044F \u0442\u043E, \u0447\u0442\u043E
    \u0434\u0440\u0443\u0433\u0438\u0435 \u0441\u0447\u0438\u0442\u0430\u043B\u0438
    \u043D\u0435\u043C\u044B\u0441\u043B\u0438\u043C\u044B\u043C \u0434\u043B\u044F
    \u0441\u043B\u0435\u043F\u043E\u0433\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430. 
    ### \U0001F4DC \u041E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u043D\u044B\u0435
    \u043C\u0435\u043C\u0443\u0430\u0440\u044B  \u0412 \u043A\u043E\u043D\u0446\u0435
    \u0436\u0438\u0437\u043D\u0438 \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D
    \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043C\u0435\u043C\u0443\u0430\u0440\u044B
    **\xAB\u0416\u0438\u0437\u043D\u0435\u043E\u043F\u0438\u0441\u0430\u043D\u0438\u0435
    \u041B. \u0421. \u041F\u043E\u043D\u0442\u0440\u044F\u0433\u0438\u043D\u0430,
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430, \u0441\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u043D\u043E\u0435
    \u0438\u043C \u0441\u0430\u043C\u0438\u043C\xBB**, \u0433\u0434\u0435 \u043F\u0440\u0435\u0434\u0435\u043B\u044C\u043D\u043E
    \u043E\u0442\u043A\u0440\u043E\u0432\u0435\u043D\u043D\u043E \u0432\u044B\u0441\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E \u043C\u043D\u043E\u0433\u0438\u0445 \u0441\u043E\u0431\u044B\u0442\u0438\u044F\u0445
    \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u0445. \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043E\u043D \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E \u043E\u043F\u0438\u0441\u0430\u043B
    \u0441\u0432\u043E\u0435 \u0443\u0447\u0430\u0441\u0442\u0438\u0435 \u0432 \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u043E\u043C
    \"\u0434\u0435\u043B\u0435 \u041B\u0443\u0437\u0438\u043D\u0430\", \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0435
    \u0431\u044B\u043B \u0432\u043E\u0432\u043B\u0435\u0447\u0435\u043D \u0441\u0432\u043E\u0438\u043C
    \u0443\u0447\u0438\u0442\u0435\u043B\u0435\u043C \u041F.\u0421. \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u043E\u0432\u044B\u043C.
    \u0412 \u043D\u0438\u0445 \u0442\u0430\u043A\u0436\u0435 \u0435\u0441\u0442\u044C
    \u0438\u0441\u0442\u043E\u0440\u0438\u0438 \u043E \u0442\u043E\u043C, \u043A\u0430\u043A
    \u0435\u0433\u043E \u043D\u0435 \u043F\u0443\u0441\u043A\u0430\u043B\u0438 \u0432
    \u0421\u0428\u0410, \u043F\u0440\u0435\u0434\u043B\u0430\u0433\u0430\u044F \u043F\u043E\u0435\u0445\u0430\u0442\u044C
    \u043D\u0435 \u0441 \u043C\u0430\u0442\u0435\u0440\u044C\u044E, \u0430 \u0441
    \u0434\u0440\u0443\u0433\u043E\u0439 \u0436\u0435\u043D\u0449\u0438\u043D\u043E\u0439,
    \u043D\u0430 \u0447\u0442\u043E \u043E\u043D \u043E\u0442\u0432\u0435\u0442\u0438\u043B
    \u0440\u0435\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C \u043E\u0442\u043A\u0430\u0437\u043E\u043C,
    \u043F\u043E\u0441\u043B\u0435 \u0447\u0435\u0433\u043E \u0435\u043C\u0443 25
    \u043B\u0435\u0442 \u043D\u0435 \u0440\u0430\u0437\u0440\u0435\u0448\u0430\u043B\u0438
    \u0432\u044B\u0435\u0437\u0436\u0430\u0442\u044C \u0437\u0430 \u0433\u0440\u0430\u043D\u0438\u0446\u0443.
    \u042D\u0442\u0438 \u043C\u0435\u043C\u0443\u0430\u0440\u044B \u0440\u0430\u0441\u043A\u0440\u044B\u0432\u0430\u044E\u0442
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0435\u0433\u043E \u043D\u0430\u0443\u0447\u043D\u044B\u0439
    \u043F\u0443\u0442\u044C, \u043D\u043E \u0438 \u0431\u044B\u0442, \u0438\u043D\u0442\u0440\u0438\u0433\u0438
    \u0438 \u0441\u0442\u0440\u0430\u0445\u0438 \u0442\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438."
