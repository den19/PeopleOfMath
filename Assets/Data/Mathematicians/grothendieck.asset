    \"\u0442\u0440\u044E\u043A\", \u0430 \u043D\u0435 \u0431\u043E\u043B\u0435\u0435
    \u043E\u0431\u0449\u0438\u0435 \u043C\u0435\u0442\u043E\u0434\u044B . *   **\"\u041A\u0442\u043E
    \u0441\u0442\u0440\u043E\u0438\u0442 \u0434\u043E\u043C\":** \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u0434\u0435\u043B\u0438\u043B \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432
    \u043D\u0430 \u0434\u0432\u0435 \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0438:
    \u0442\u0435\u0445, \u043A\u0442\u043E \u0443\u043B\u0443\u0447\u0448\u0430\u0435\u0442
    \u0438\u043B\u0438 \u043E\u0431\u0443\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0435\u0442
    \u0433\u043E\u0442\u043E\u0432\u044B\u0439 \"\u0434\u043E\u043C\" \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0437\u043D\u0430\u043D\u0438\u0439, \u0438 \u0442\u0435\u0445, \u043A\u0442\u043E
    \u0441\u0442\u0440\u043E\u0438\u0442 **\u043D\u043E\u0432\u044B\u0435 \u0434\u043E\u043C\u0430**.
    \u041A \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u043C \u043E\u043D \u043F\u0440\u0438\u0447\u0438\u0441\u043B\u044F\u043B
    \u0438 \u0441\u0435\u0431\u044F .  ### \U0001F631 \u0420\u0430\u0437\u0440\u044B\u0432
    \u0441 \u043C\u0438\u0440\u043E\u043C \u0438 \u043F\u043E\u0437\u0434\u043D\u0438\u0435
    \u0433\u043E\u0434\u044B: \u044D\u0437\u043E\u0442\u0435\u0440\u0438\u043A\u0430
    \u0438 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u044F  *   **\"\u0412\u0435\u043B\u0438\u043A\u0438\u0439
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\" 1970 \u0433\u043E\u0434\u0430:**
    \u041E\u043D \u0448\u043E\u043A\u0438\u0440\u043E\u0432\u0430\u043B \u043C\u0438\u0440
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438, \u0443\u0439\u0434\u044F
    \u0438\u0437 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0433\u043E
    \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 \u0432\u044B\u0441\u0448\u0438\u0445
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    (IHES) \u0432 \u0437\u043D\u0430\u043A \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0432\u043E\u0435\u043D\u043D\u043E\u0433\u043E
    \u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F.
    \u041E\u043D \u043D\u0430\u0434\u0435\u044F\u043B\u0441\u044F, \u0447\u0442\u043E
    \u0437\u0430 \u043D\u0438\u043C \u043F\u043E\u0441\u043B\u0435\u0434\u0443\u044E\u0442
    \u0438 \u0434\u0440\u0443\u0433\u0438\u0435, \u043D\u043E \u043E\u0441\u0442\u0430\u043B\u0441\u044F
    \u0432 \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u0435 . *  
    **\u041F\u0443\u0442\u044C \u0432 \u044D\u0437\u043E\u0442\u0435\u0440\u0438\u043A\u0443:**
    \u041F\u043E\u0441\u043B\u0435 \u0443\u0445\u043E\u0434\u0430 \u0438\u0437 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438
    \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u0430\u043A\u0442\u0438\u0432\u043D\u043E
    \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u0442\u044C\u0441\u044F
    \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0435\u0439, \u044D\u043A\u043E\u043B\u043E\u0433\u0438\u0435\u0439,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0438 \u044D\u0437\u043E\u0442\u0435\u0440\u0438\u043A\u043E\u0439.
    \u041E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u0442\u0440\u0443\u0434 **\xAB\u041A\u043B\u044E\u0447 \u043A \u0441\u043D\u0430\u043C,
    \u0438\u043B\u0438 \u0414\u0438\u0430\u043B\u043E\u0433 \u0441 \u0413\u043E\u0441\u043F\u043E\u0434\u043E\u043C
    \u0411\u043E\u0433\u043E\u043C\xBB**, \u0433\u0434\u0435 \u043F\u044B\u0442\u0430\u043B\u0441\u044F
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043D\u0438\u0435
    \u0411\u043E\u0433\u0430 \u0447\u0435\u0440\u0435\u0437 \u0430\u043D\u0430\u043B\u0438\u0437
    \u0441\u043D\u043E\u0432\u0438\u0434\u0435\u043D\u0438\u0439 . *   **\u041E\u0442\u0448\u0435\u043B\u044C\u043D\u0438\u043A
    \u0432 \u041F\u0438\u0440\u0435\u043D\u0435\u044F\u0445:** \u0412 1991 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0438\u0441\u0447\u0435\u0437 \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435
    \u041B\u0430\u0441\u0441\u0435\u0440 \u0432 \u041F\u0438\u0440\u0435\u043D\u0435\u044F\u0445,
    \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E \u043F\u043E\u0440\u0432\u0430\u0432
    \u0441 \u0432\u043D\u0435\u0448\u043D\u0438\u043C \u043C\u0438\u0440\u043E\u043C,
    \u0441\u0435\u043C\u044C\u0435\u0439 \u0438 \u043A\u043E\u043B\u043B\u0435\u0433\u0430\u043C\u0438.
    \u0415\u0433\u043E \u0434\u043E\u0447\u044C \u0419\u043E\u0445\u0430\u043D\u043D\u0430
    \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B\u0430: \"\u041A\u043E\u0433\u0434\u0430
    \u043C\u044B \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u043B\u0438 \u0435\u043C\u0443
    \u043F\u0438\u0441\u044C\u043C\u043E, \u043E\u043D\u043E \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u043B\u043E\u0441\u044C
    \u043E\u0431\u0440\u0430\u0442\u043D\u043E \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u0435\u043B\u044E\"
    . *   **\"\u041F\u0440\u043E\u0431\u043B\u0435\u043C\u0430 \u0437\u043B\u0430\"
    \u0438 15 000 \u0441\u0442\u0440\u0430\u043D\u0438\u0446:** \u0416\u0438\u0432\u044F
    \u0432 \u0438\u0437\u043E\u043B\u044F\u0446\u0438\u0438, \u043E\u043D \u043D\u0430\u043F\u0438\u0441\u0430\u043B
    \u043E\u043A\u043E\u043B\u043E 70 000 \u0441\u0442\u0440\u0430\u043D\u0438\u0446
    \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0435\u0439. \u041E\u0434\u043D\u0430
    \u0438\u0437 \u0441\u0430\u043C\u044B\u0445 \u043E\u0431\u044A\u0435\u043C\u043D\u044B\u0445
    \u0447\u0430\u0441\u0442\u0435\u0439 \u2014 **\xAB\u041F\u0440\u043E\u0431\u043B\u0435\u043C\u0430
    \u0437\u043B\u0430\xBB**, \u0433\u0434\u0435 \u043E\u043D \u043D\u0430 15 000
    \u0441\u0442\u0440\u0430\u043D\u0438\u0446 \u0440\u0430\u0437\u043C\u044B\u0448\u043B\u044F\u0435\u0442
    \u043E \u043C\u0435\u0442\u0430\u0444\u0438\u0437\u0438\u043A\u0435 \u0438 \u0441\u0430\u0442\u0430\u043D\u0435,
    \u043F\u044B\u0442\u0430\u044F\u0441\u044C \u043F\u043E\u043D\u044F\u0442\u044C
    \u043F\u0440\u0438\u0440\u043E\u0434\u0443 \u0437\u043B\u0430 \u0432 \u043C\u0438\u0440\u0435
    . \u041E\u043D \u0443\u0432\u043B\u0435\u043A\u0430\u043B\u0441\u044F \u0434\u0438\u0441\u0442\u0438\u043B\u043B\u044F\u0446\u0438\u0435\u0439
    \u0440\u0430\u0441\u0442\u0435\u043D\u0438\u0439, \u043F\u044B\u0442\u0430\u044F\u0441\u044C
    \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u044C \u0438\u0445 \"\u0441\u0432\u043E\u0439\u0441\u0442\u0432\u0430
    \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438 \u043A
    \u043D\u0435\u0432\u0437\u0433\u043E\u0434\u0430\u043C\" \u2014 \u044D\u0442\u043E
    \u0431\u044B\u043B\u0430 \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u0441\u0432\u043E\u0435\u043E\u0431\u0440\u0430\u0437\u043D\u0430\u044F
    \u0430\u043B\u0445\u0438\u043C\u0438\u044F \u0432 \u043F\u043E\u0438\u0441\u043A\u0430\u0445
    \u043E\u0442\u0432\u0435\u0442\u0430 \u043D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441,
    \u043F\u043E\u0447\u0435\u043C\u0443 \u0432 \u043C\u0438\u0440\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0437\u043B\u043E . *   **\u041F\u0440\u043E\u0441\u044C\u0431\u0430 \u043E
    \u0440\u0435\u0432\u043E\u043B\u044C\u0432\u0435\u0440\u0435:** \u0417\u0430
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0435\u0441\u044F\u0446\u0435\u0432
    \u0434\u043E \u0441\u043C\u0435\u0440\u0442\u0438, \u0432 2014 \u0433\u043E\u0434\u0443,
    \u043E\u043D \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B \u0441\u0432\u043E\u0435\u0433\u043E
    \u0441\u043E\u0441\u0435\u0434\u0430 \u043A\u0443\u043F\u0438\u0442\u044C \u0435\u043C\u0443
    \u0440\u0435\u0432\u043E\u043B\u044C\u0432\u0435\u0440, \u0447\u0442\u043E\u0431\u044B
    \u0437\u0430\u0441\u0442\u0440\u0435\u043B\u0438\u0442\u044C\u0441\u044F . *  
    **\u0417\u0430\u043F\u0440\u0435\u0442 \u043D\u0430 \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044E:**
    \u0412 2010 \u0433\u043E\u0434\u0443 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u043E\u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B \u043F\u0438\u0441\u044C\u043C\u043E,
    \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438
    \u0437\u0430\u043F\u0440\u0435\u0442\u0438\u043B \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C
    \u0438\u043B\u0438 \u043F\u0435\u0440\u0435\u0438\u0437\u0434\u0430\u0432\u0430\u0442\u044C
    \u043B\u044E\u0431\u044B\u0435 \u0441\u0432\u043E\u0438 \u0442\u0435\u043A\u0441\u0442\u044B
    \u0432 \u043B\u044E\u0431\u043E\u0439 \u0444\u043E\u0440\u043C\u0435 . \u042D\u0442\u043E
    \u0431\u044B\u043B \u0435\u0433\u043E \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439
    \u0436\u0435\u0441\u0442 \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044F \u043D\u0430\u0434
    \u0441\u0432\u043E\u0438\u043C \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435\u043C."
