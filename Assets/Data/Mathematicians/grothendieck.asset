    \u043A\u0440\u0443\u0433\u0430 \u043A\u0430\u043A \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u0442\u043E\u0447\u0435\u043A, \u0440\u0430\u0432\u043D\u043E\u0443\u0434\u0430\u043B\u0435\u043D\u043D\u044B\u0445
    \u043E\u0442 \u0446\u0435\u043D\u0442\u0440\u0430. \u042D\u0442\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043F\u043E\u0440\u0430\u0437\u0438\u043B\u043E \u0435\u0433\u043E \u0441\u0432\u043E\u0435\u0439
    \u043F\u0440\u043E\u0441\u0442\u043E\u0442\u043E\u0439 \u0438 \u044F\u0441\u043D\u043E\u0441\u0442\u044C\u044E,
    \u0438 \u0434\u043E\u043B\u0433\u0438\u0435 \u0433\u043E\u0434\u044B \u043E\u043D
    \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B \u0435\u0433\u043E \u043A\u0430\u043A
    \u043C\u043E\u043C\u0435\u043D\u0442, \u043A\u043E\u0433\u0434\u0430 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    \u043E\u0442\u043A\u0440\u044B\u043B\u0430\u0441\u044C \u0435\u043C\u0443 \u0441
    \u043D\u043E\u0432\u043E\u0439, \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E\u0439
    \u0441\u0442\u043E\u0440\u043E\u043D\u044B . *   **\"\u0413\u0440\u0443\u0431\u043E\u0441\u0442\u044C\"
