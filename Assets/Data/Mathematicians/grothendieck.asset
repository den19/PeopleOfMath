  achievementsRu: "\u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0435\u0448\u0438\u043B
    \u0441\u043B\u043E\u0436\u043D\u044B\u0435 \u0437\u0430\u0434\u0430\u0447\u0438
    \u2014 \u043E\u043D \u0441\u043E\u0437\u0434\u0430\u043B \u043D\u043E\u0432\u044B\u0439
    \u044F\u0437\u044B\u043A, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0433\u043E\u0432\u043E\u0440\u044F\u0442
    \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440. \u0415\u0433\u043E \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F
    \u043B\u0435\u0436\u0430\u0442 \u0432 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0435
    \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0442\u0435\u043E\u0440\u0438\u0438
    \u0447\u0438\u0441\u0435\u043B \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438.
    \u0412\u043E\u0442 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u044B\u0439 \u0440\u0430\u0437\u0431\u043E\u0440
    \u0435\u0433\u043E \u043A\u043B\u044E\u0447\u0435\u0432\u044B\u0445 \u0438\u0434\u0435\u0439. 
    ### \U0001F3D7\uFE0F \u0422\u0435\u043E\u0440\u0438\u044F \u0441\u0445\u0435\u043C:
    \u043D\u043E\u0432\u044B\u0439 \u0432\u0437\u0433\u043B\u044F\u0434 \u043D\u0430
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E  \u0413\u043B\u0430\u0432\u043D\u0430\u044F
    \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044F \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430
    \u2014 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435 **\u0442\u0435\u043E\u0440\u0438\u0438
    \u0441\u0445\u0435\u043C** (theory of schemes). \u0414\u043E \u043D\u0435\u0433\u043E
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C
    \u0438\u0437\u0443\u0447\u0430\u043B\u0430 **\u043C\u043D\u043E\u0433\u043E\u043E\u0431\u0440\u0430\u0437\u0438\u044F**
    \u2014 \u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430 \u0440\u0435\u0448\u0435\u043D\u0438\u0439
    \u0441\u0438\u0441\u0442\u0435\u043C \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0439
    \u043D\u0430\u0434 \u043F\u043E\u043B\u044F\u043C\u0438, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440,
    \u043A\u043E\u043C\u043F\u043B\u0435\u043A\u0441\u043D\u044B\u043C\u0438 \u0438\u043B\u0438
    \u0432\u0435\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
    \u0447\u0438\u0441\u043B\u0430\u043C\u0438. \u042D\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u043B\u043E
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0443: \u043E\u0434\u043D\u043E \u0438
    \u0442\u043E \u0436\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u043C\u043E\u0433\u043B\u043E \u0438\u043C\u0435\u0442\u044C \u0440\u0430\u0437\u043D\u043E\u0435
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u0439
    \u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u0438 \u043E\u0442
    \u043F\u043E\u043B\u044F, \u0447\u0442\u043E \u043C\u0435\u0448\u0430\u043B\u043E
    \u0443\u0432\u0438\u0434\u0435\u0442\u044C \u0435\u0434\u0438\u043D\u0443\u044E
    \u043A\u0430\u0440\u0442\u0438\u043D\u0443.  \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
    \u043D\u0430 \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043E\u0431\u044A\u0435\u043A\u0442 \u043D\u0435 \u0447\u0435\u0440\u0435\u0437
    \u0435\u0433\u043E \u0442\u043E\u0447\u043A\u0438, \u0430 \u0447\u0435\u0440\u0435\u0437
    **\u043A\u043E\u043B\u044C\u0446\u043E \u0444\u0443\u043D\u043A\u0446\u0438\u0439**,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u043E\u0436\u043D\u043E \u043D\u0430
    \u043D\u0435\u043C \u0437\u0430\u0434\u0430\u0442\u044C. \u0412\u043C\u0435\u0441\u0442\u043E
    \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B \u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u0442\u044C,
    \u0433\u0434\u0435 \u043D\u0430\u0445\u043E\u0434\u044F\u0442\u0441\u044F \u0440\u0435\u0448\u0435\u043D\u0438\u044F,
    \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0443, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \"\u043F\u043E\u043C\u043D\u0438\u0442\" \u0432\u0441\u0435 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F \u0441\u0440\u0430\u0437\u0443. \u042D\u0442\u043E
    \u043F\u0440\u0438\u0432\u0435\u043B\u043E \u043A \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u044E
    **\u0430\u0444\u0444\u0438\u043D\u043D\u043E\u0439 \u0441\u0445\u0435\u043C\u044B**
    \u043A\u0430\u043A **\u0441\u043F\u0435\u043A\u0442\u0440\u0430** (\u043C\u043D\u043E\u0436\u0435\u0441\u0442\u0432\u0430
    \u043F\u0440\u043E\u0441\u0442\u044B\u0445 \u0438\u0434\u0435\u0430\u043B\u043E\u0432)
    \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u043B\u044C\u043D\u043E\u0433\u043E
    \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u0433\u043E
    \u043A\u043E\u043B\u044C\u0446\u0430.  > \u042D\u0442\u043E \u0431\u044B\u043B\u0430
    \u0441\u043C\u0435\u043B\u0430\u044F \u0438\u0434\u0435\u044F \u2014 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442\u044C
    **\u043B\u044E\u0431\u043E\u043C\u0443** \u043A\u043E\u043C\u043C\u0443\u0442\u0430\u0442\u0438\u0432\u043D\u043E\u043C\u0443
    \u043A\u043E\u043B\u044C\u0446\u0443 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442\u044C
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E. \u0422\u0430\u043A\u043E\u0439
    \u043F\u043E\u0434\u0445\u043E\u0434 \u0438\u043C\u0435\u043B \u0434\u0432\u0430
    \u0432\u0430\u0436\u043D\u044B\u0445 \u043F\u043E\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0438\u044F:
    > 1.  **\u0415\u0434\u0438\u043D\u0441\u0442\u0432\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438
    \u0438 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438:** \u041A\u043E\u043B\u044C\u0446\u043E
    \u0446\u0435\u043B\u044B\u0445 \u0447\u0438\u0441\u0435\u043B \\(\\mathbb{Z}\\)
    \u0442\u043E\u0436\u0435 \u0441\u0442\u0430\u043B\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u043C \u2014 \u0441\u0445\u0435\u043C\u043E\u0439
    \\(\\operatorname{Spec}(\\mathbb{Z})\\). \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u043E
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043C\u0435\u0442\u043E\u0434\u044B \u043A \u0437\u0430\u0434\u0430\u0447\u0430\u043C
    \u0442\u0435\u043E\u0440\u0438\u0438 \u0447\u0438\u0441\u0435\u043B. > 2.  **\u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u044C:**
    \u041F\u043E\u044F\u0432\u0438\u043B\u0430\u0441\u044C \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C
    \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \"\u043E\u0442\u043D\u043E\u0441\u0438\u0442\u0435\u043B\u044C\u043D\u043E\",
    \u043C\u0435\u043D\u044F\u044F \u0431\u0430\u0437\u043E\u0432\u043E\u0435 \u043A\u043E\u043B\u044C\u0446\u043E.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0438\u0437\u0443\u0447\u0430\u0442\u044C
    \u043E\u0434\u043D\u043E \u0438 \u0442\u043E \u0436\u0435 \u0443\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435
    \u043D\u0430\u0434 \u0440\u0430\u0437\u043D\u044B\u043C\u0438 \u043F\u043E\u043B\u044F\u043C\u0438,
    \u043F\u0440\u043E\u0441\u0442\u043E \u043C\u0435\u043D\u044F\u044F \"\u0431\u0430\u0437\u0443\"
    \\(\\operatorname{Spec}(k)\\), \u0441\u043B\u043E\u0432\u043D\u043E \u0440\u0430\u0441\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u044F
    \u043E\u0434\u0438\u043D \u0438 \u0442\u043E\u0442 \u0436\u0435 \u043E\u0431\u044A\u0435\u043A\u0442
    \u043F\u043E\u0434 \u0440\u0430\u0437\u043D\u044B\u043C\u0438 \"\u043B\u0438\u043D\u0437\u0430\u043C\u0438\". 
    \u0421\u0445\u0435\u043C\u044B \u0441\u0442\u0430\u043B\u0438 \u0442\u0435\u043C
    \"\u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C \u044F\u0437\u044B\u043A\u043E\u043C\",
    \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C \u0431\u044B\u043B\u0430
    \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u0430\u043D\u0430 \u0432\u0441\u044F
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0430\u044F
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044F. \u041D\u0430 \u0438\u0445
    \u043E\u0441\u043D\u043E\u0432\u0435 \u043F\u043E\u0441\u0442\u0440\u043E\u0435\u043D\u044B
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0442\u0440\u0443\u0434\u044B, \u0442\u0430\u043A\u0438\u0435 \u043A\u0430\u043A
    **\"\xC9l\xE9ments de g\xE9om\xE9trie alg\xE9brique\" (EGA)** \u2014 \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u0430\u044F
    \u0440\u0430\u0431\u043E\u0442\u0430 \u0441 \u0416\u0430\u043D\u043E\u043C \u0414\u044C\u0451\u0434\u043E\u043D\u043D\u0435,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0447\u0430\u0441\u0442\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    \"\u0415\u0432\u0430\u043D\u0433\u0435\u043B\u0438\u0435\u043C \u043E\u0442 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430\". 
    ### \U0001F52D \u0422\u043E\u043F\u043E\u0441\u044B \u0438 \u044D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438: \u043D\u043E\u0432\u044B\u0439
    \u0432\u0437\u0433\u043B\u044F\u0434 \u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E
    \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044E  \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u043F\u043E\u0448\u0435\u043B \u0435\u0449\u0435 \u0434\u0430\u043B\u044C\u0448\u0435,
    \u043E\u0431\u043E\u0431\u0449\u0438\u0432 \u0441\u0430\u043C\u043E \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u0430. \u0412\u043C\u0435\u0441\u0442\u043E
    \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442\u044C
    \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E \u0447\u0435\u0440\u0435\u0437
    \u0442\u043E\u0447\u043A\u0438, \u043E\u043D \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0442\u044C \u0435\u0433\u043E
    \u0447\u0435\u0440\u0435\u0437 **\u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u044E
    \u043F\u0443\u0447\u043A\u043E\u0432** \u043D\u0430 \u043D\u0435\u043C. \u042D\u0442\u043E
    \u043E\u0431\u043E\u0431\u0449\u0435\u043D\u0438\u0435 \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B
    **\u0442\u043E\u043F\u043E\u0441\u043E\u043C** (topos).  \u0422\u043E\u043F\u043E\u0441\u044B
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u043B\u0438 \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0435 \"\u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\"
    \u0434\u043B\u044F \u0440\u0430\u0437\u043D\u044B\u0445 \u0437\u0430\u0434\u0430\u0447.
    \u0421\u0430\u043C\u0430\u044F \u0432\u0430\u0436\u043D\u0430\u044F \u0438\u0437
    \u043D\u0438\u0445 \u2014 **\u044D\u0442\u0430\u043B\u044C\u043D\u0430\u044F
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F** (\xE9tale topology)
    \u0438 \u043E\u0441\u043D\u043E\u0432\u0430\u043D\u043D\u044B\u0435 \u043D\u0430
    \u043D\u0435\u0439 **\u044D\u0442\u0430\u043B\u044C\u043D\u044B\u0435 \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438**.
    \u042D\u0442\u0430\u043B\u044C\u043D\u0430\u044F \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u044F
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u0435\u0442 \u043F\u043E\u043D\u044F\u0442\u0438\u0435
    \"\u043F\u043E\u043A\u0440\u044B\u0442\u0438\u044F\" \u043D\u0435 \u0432 \u043E\u0431\u044B\u0447\u043D\u043E\u043C
    \u0441\u043C\u044B\u0441\u043B\u0435, \u0430 \u0447\u0435\u0440\u0435\u0437 \u043E\u0441\u043E\u0431\u044B\u0435
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043B\u043E\u043A\u0430\u043B\u044C\u043D\u043E \u0432\u044B\u0433\u043B\u044F\u0434\u044F\u0442
    \u043A\u0430\u043A \u0438\u0437\u043E\u043C\u043E\u0440\u0444\u0438\u0437\u043C\u044B. 
    \u042D\u0442\u043E \u0431\u044B\u043B \u043F\u0440\u043E\u0440\u044B\u0432, \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0432\u0448\u0438\u0439:
    * **\u041F\u0440\u0438\u043C\u0435\u043D\u0438\u0442\u044C \u043C\u0435\u0442\u043E\u0434\u044B
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438 \u0432 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438:** \u042D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0438 \u0432\u0435\u0434\u0443\u0442
    \u0441\u0435\u0431\u044F \u0430\u043D\u0430\u043B\u043E\u0433\u0438\u0447\u043D\u043E
    \u043E\u0431\u044B\u0447\u043D\u044B\u043C \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u044F\u043C, \u043D\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442 \u0432 \u043C\u0438\u0440\u0435
    \u0441\u0445\u0435\u043C, \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u043F\u043E\u043B\u044F
    \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439
    \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043A\u0438.
    * **\u041F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u043C\u043E\u0449\u043D\u044B\u0439
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442:** \u0411\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F
    \u044D\u0442\u043E\u0439 \u0442\u0435\u043E\u0440\u0438\u0438 \u041F\u044C\u0435\u0440
    \u0414\u0435\u043B\u0438\u043D\u044C (\u0443\u0447\u0435\u043D\u0438\u043A \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430)
    \u0441\u043C\u043E\u0433 \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u0442\u0440\u0435\u0442\u044C\u044E
    \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u0443 \u0412\u0435\u0439\u043B\u044F
    \u043E \u0434\u0437\u0435\u0442\u0430-\u0444\u0443\u043D\u043A\u0446\u0438\u044F\u0445,
    \u0447\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u043E\u0434\u043D\u0438\u043C
    \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445 \u0442\u0440\u0438\u0443\u043C\u0444\u043E\u0432
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 XX \u0432\u0435\u043A\u0430.
    * **\u041E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u044B:**
    \u0421\u0430\u043C \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A \u0441\u0447\u0438\u0442\u0430\u043B
    \u0442\u0435\u043E\u0440\u0438\u044E \u0442\u043E\u043F\u043E\u0441\u043E\u0432
    \u0441\u0432\u043E\u0435\u0439 \u0441\u0430\u043C\u043E\u0439 \u0433\u043B\u0443\u0431\u043E\u043A\u043E\u0439
    \u0438 \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u043E\u0439 \u0440\u0430\u0431\u043E\u0442\u043E\u0439,
    \u0432\u0438\u0434\u044F \u0432 \u043D\u0435\u0439 \"\u0441\u0438\u043D\u0442\u0435\u0437
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438, \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438
    \u0438 \u0430\u0440\u0438\u0444\u043C\u0435\u0442\u0438\u043A\u0438\".  ### \U0001F9E9
    \u0414\u0440\u0443\u0433\u0438\u0435 \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0435
    \u0438\u0434\u0435\u0438  \u0412\u043A\u043B\u0430\u0434 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430
    \u043D\u0435 \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
    \u0441\u0445\u0435\u043C\u0430\u043C\u0438 \u0438 \u0442\u043E\u043F\u043E\u0441\u0430\u043C\u0438.
    \u0421\u0440\u0435\u0434\u0438 \u0435\u0433\u043E \"\u0439\u043E\u0433\" (\u043A\u0430\u043A
    \u043E\u043D \u0441\u0430\u043C \u043D\u0430\u0437\u044B\u0432\u0430\u043B \u0441\u0432\u043E\u0438
    \u043A\u043E\u043D\u0446\u0435\u043F\u0446\u0438\u0438) \u0432\u044B\u0434\u0435\u043B\u044F\u044E\u0442\u0441\u044F: 
    * **\u041C\u043E\u0442\u0438\u0432\u044B (Motives):** \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u0437\u0430\u0434\u0443\u043C\u0430\u043B \u043C\u043E\u0442\u0438\u0432\u044B
    \u043A\u0430\u043A \"\u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0430\u043B\u044C\u043D\u044B\u0435
    \u0441\u0442\u0440\u043E\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435 \u0431\u043B\u043E\u043A\u0438\"
    \u0434\u043B\u044F \u0432\u0441\u0435\u0445 \u0442\u0435\u043E\u0440\u0438\u0439
    \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0439. \u0418\u0434\u0435\u044F
    \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E\u0431\u044B \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u044E, \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u043E\u0439,
    \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u044F \u0440\u0430\u0437\u043D\u044B\u0435
    \"\u0444\u0443\u043D\u043A\u0442\u043E\u0440\u044B \u0440\u0435\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438\",
    \u043C\u043E\u0436\u043D\u043E \u0431\u044B\u043B\u043E \u0431\u044B \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C
    \u0432\u0441\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435 \u043A\u043E\u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438 (\u044D\u0442\u0430\u043B\u044C\u043D\u044B\u0435,
    \u0434\u0435 \u0420\u0430\u043C\u0430, \u0441\u0438\u043D\u0433\u0443\u043B\u044F\u0440\u043D\u044B\u0435
    \u0438 \u0434\u0440.). \u0425\u043E\u0442\u044F \u0441\u0430\u043C \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u043D\u0435 \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u043B \u044D\u0442\u0443
    \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443, \u043E\u043D\u0430 \u0441\u0442\u0430\u043B\u0430
    \u043E\u0434\u043D\u043E\u0439 \u0438\u0437 \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u044B\u0445
    \u0432 \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435.
    * **\\(K\\)-\u0442\u0435\u043E\u0440\u0438\u044F \u0438 \u0442\u0435\u043E\u0440\u0435\u043C\u0430
    \u0420\u0438\u043C\u0430\u043D\u0430-\u0420\u043E\u0445\u0430-\u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430:**
    \u041E\u043D \u043E\u0431\u043E\u0431\u0449\u0438\u043B \u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0442\u0435\u043E\u0440\u0435\u043C\u0443 \u0420\u0438\u043C\u0430\u043D\u0430-\u0420\u043E\u0445\u0430,
    \u0441\u043E\u0437\u0434\u0430\u0432 \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E
    \u043D\u043E\u0432\u044B\u0439 \u0444\u043E\u0440\u043C\u0430\u043B\u0438\u0437\u043C
    \\(K\\)-\u0442\u0435\u043E\u0440\u0438\u0438. * **\u0424\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
    \u0430\u043D\u0430\u043B\u0438\u0437:** \u0415\u0433\u043E \u0440\u0430\u043D\u043D\u0438\u0435
    \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0442\u0435\u043E\u0440\u0438\u044E
    **\u044F\u0434\u0435\u0440\u043D\u044B\u0445 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432**
    \u0438 \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0435\u043D\u0437\u043E\u0440\u043D\u044B\u0445 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u0439,
    \u0442\u0430\u043A\u0436\u0435 \u0431\u044B\u043B\u0438 \u043D\u043E\u0432\u0430\u0442\u043E\u0440\u0441\u043A\u0438\u043C\u0438
    \u0438 \u043D\u0430\u0448\u043B\u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435
    \u0432 \u0442\u0435\u043E\u0440\u0438\u0438 \u0440\u0430\u0441\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0439
    \u0438 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u043E\u0439 \u0444\u0438\u0437\u0438\u043A\u0435. 
    ### \U0001F4DD \u041E\u0441\u043E\u0431\u044B\u0439 \u043F\u043E\u0434\u0445\u043E\u0434
    \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435  \u0421\u0442\u0438\u043B\u044C
    \u0440\u0430\u0431\u043E\u0442\u044B \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430
    \u0431\u044B\u043B \u0443\u043D\u0438\u043A\u0430\u043B\u0435\u043D. \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435
    \u043E\u0442 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432-\xAB\u0440\u0435\u0448\u0430\u0442\u0435\u043B\u0435\u0439
    \u0437\u0430\u0434\u0430\u0447\xBB, \u043E\u043D \u0431\u044B\u043B **\xAB\u0441\u043E\u0437\u0434\u0430\u0442\u0435\u043B\u0435\u043C
    \u0442\u0435\u043E\u0440\u0438\u0439\xBB**. \u0415\u0433\u043E \u0446\u0435\u043B\u044C\u044E
    \u0431\u044B\u043B\u043E \u043D\u0435 \u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0430\u0439\u0442\u0438 \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0439
    \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B, \u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E
    \u043E\u0431\u0449\u0443\u044E \u0438 \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u0443\u044E
    \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0443, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u044D\u0442\u0430 \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0430\u0441\u044C
    \u0431\u044B \u0447\u0430\u0441\u0442\u043D\u044B\u043C \u0441\u043B\u0443\u0447\u0430\u0435\u043C
    \u0438 \u0440\u0435\u0448\u0430\u043B\u0430\u0441\u044C \u0431\u044B \"\u043F\u043E\u0447\u0442\u0438
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\".
    \u0415\u0433\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430
    \u0441\u0442\u0440\u043E\u0438\u043B\u0438\u0441\u044C \u0438\u0437 \u0434\u043B\u0438\u043D\u043D\u044B\u0445
    \u0446\u0435\u043F\u043E\u0447\u0435\u043A \u043F\u0440\u043E\u0441\u0442\u044B\u0445,
    \u043F\u0440\u043E\u0437\u0440\u0430\u0447\u043D\u044B\u0445 \u043B\u0435\u043C\u043C,
    \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u043B\u043E \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B
    \u043C\u043E\u043D\u0443\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u043C\u0438,
    \u043D\u043E \u043F\u043E\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u044F\u0441\u043D\u044B\u043C\u0438.  \u0418\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u043E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0435
    \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0435\u043D\u0438\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438 \u0438 \u0441\u043E\u0437\u0434\u0430\u043D\u0438\u0435
    \u043D\u043E\u0432\u043E\u0433\u043E \u044F\u0437\u044B\u043A\u0430 \u0441\u0434\u0435\u043B\u0430\u043B\u0438
    \u0435\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B \u043A\u0440\u0430\u0435\u0443\u0433\u043E\u043B\u044C\u043D\u044B\u043C
    \u043A\u0430\u043C\u043D\u0435\u043C, \u0431\u0435\u0437 \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E
    \u0431\u044B\u043B\u0438 \u0431\u044B \u043D\u0435\u043C\u044B\u0441\u043B\u0438\u043C\u044B
    \u043C\u043D\u043E\u0433\u0438\u0435 \u043A\u0440\u0443\u043F\u043D\u0435\u0439\u0448\u0438\u0435
    \u0434\u043E\u0441\u0442\u0438\u0436\u0435\u043D\u0438\u044F \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0445
    \u0434\u0435\u0441\u044F\u0442\u0438\u043B\u0435\u0442\u0438\u0439, \u0432\u043A\u043B\u044E\u0447\u0430\u044F
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E
    \u0412\u0435\u043B\u0438\u043A\u043E\u0439 \u0442\u0435\u043E\u0440\u0435\u043C\u044B
    \u0424\u0435\u0440\u043C\u0430."
  achievementsEn: 
  personalLifeRu: "\u041B\u0438\u0447\u043D\u0430\u044F \u0436\u0438\u0437\u043D\u044C
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0430 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430
    \u0431\u044B\u043B\u0430 \u0441\u0442\u043E\u043B\u044C \u0436\u0435 \u0441\u043B\u043E\u0436\u043D\u043E\u0439
    \u0438 \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E\u0439, \u043A\u0430\u043A
    \u0438 \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0433\u0435\u043D\u0438\u0439. \u041E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u0430
    \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u043C\u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0441\u0432\u044F\u0437\u044F\u043C\u0438, \u0442\u0440\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C\u0438
    \u0440\u0430\u0437\u0440\u044B\u0432\u0430\u043C\u0438 \u0438, \u0432 \u043A\u043E\u043D\u0435\u0447\u043D\u043E\u043C
    \u0441\u0447\u0451\u0442\u0435, \u043F\u043E\u043B\u043D\u044B\u043C \u043E\u0442\u0448\u0435\u043B\u044C\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E\u043C.
    \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442 \u0435\u0433\u043E
    \u0441\u0442\u0440\u043E\u0439\u043D\u044B\u0445 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0442\u0435\u043E\u0440\u0438\u0439, \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u0430\u044F
    \u0438\u0441\u0442\u043E\u0440\u0438\u044F \u2014 \u044D\u0442\u043E \u0437\u0430\u043F\u0443\u0442\u0430\u043D\u043D\u044B\u0439
    \u043A\u043B\u0443\u0431\u043E\u043A \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u0439,
    \u0434\u043E\u043B\u0433\u0430, \u0431\u043E\u043B\u0438 \u0438 \u043E\u0434\u0438\u043D\u043E\u0447\u0435\u0441\u0442\u0432\u0430. 
    ### \U0001F494 \u0416\u0435\u043D\u0449\u0438\u043D\u044B \u0438 \u0434\u0435\u0442\u0438:
    \u0441\u043B\u043E\u0436\u043D\u044B\u0439 \u0443\u0437\u043E\u0440 \u0441\u0435\u043C\u0435\u0439\u043D\u044B\u0445
    \u0441\u0432\u044F\u0437\u0435\u0439  \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u0431\u044B\u043B \u043E\u0442\u0446\u043E\u043C \u043F\u043E \u043C\u0435\u043D\u044C\u0448\u0435\u0439
    \u043C\u0435\u0440\u0435 \u043F\u044F\u0442\u0435\u0440\u044B\u0445 \u0434\u0435\u0442\u0435\u0439
    \u043E\u0442 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u0436\u0435\u043D\u0449\u0438\u043D,
    \u043D\u043E \u0435\u0433\u043E \u0440\u043E\u043B\u044C \u0432 \u0438\u0445
    \u0436\u0438\u0437\u043D\u0438 \u0431\u044B\u043B\u0430, \u043C\u044F\u0433\u043A\u043E
    \u0433\u043E\u0432\u043E\u0440\u044F, \u043D\u0435\u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439.
    \u0415\u0433\u043E \u043F\u043E\u0433\u043B\u043E\u0449\u0435\u043D\u043D\u043E\u0441\u0442\u044C
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0439 \u0438 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0435
    \u0432\u0437\u0433\u043B\u044F\u0434\u044B \u043D\u0430 \u043E\u0431\u0449\u0435\u0441\u0442\u0432\u043E
    \u0447\u0430\u0441\u0442\u043E \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0438
    \u0441\u0435\u043C\u044C\u044E \u043D\u0430 \u0432\u0442\u043E\u0440\u043E\u043C
    \u043F\u043B\u0430\u043D\u0435.  *   **\u041F\u0435\u0440\u0432\u0430\u044F \u0441\u0435\u043C\u044C\u044F:
    \u0421\u0435\u0440\u0436 \u0438 \u0410\u043B\u0438\u043D \u0414\u0440\u0438\u043A\u0435\u0440.**
    \u0415\u0449\u0435 \u0432 \u041D\u0430\u043D\u0441\u0438, \u0431\u0443\u0434\u0443\u0447\u0438
    \u043C\u043E\u043B\u043E\u0434\u044B\u043C \u0430\u0441\u043F\u0438\u0440\u0430\u043D\u0442\u043E\u043C,
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A \u0436\u0438\u043B \u043D\u0430
    \u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0435 \u0443 \u0410\u043B\u0438\u043D
    \u0414\u0440\u0438\u043A\u0435\u0440 (Marcelle \"Aline\" Driquert), \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u044B\u043B\u0430 \u0441\u0442\u0430\u0440\u0448\u0435 \u0435\u0433\u043E.
    \u0423 \u043D\u0438\u0445 \u0437\u0430\u0432\u044F\u0437\u0430\u043B\u0438\u0441\u044C
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F, \u0438 \u0432 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0435
    \u0440\u043E\u0434\u0438\u043B\u0441\u044F \u0435\u0433\u043E **\u043F\u0435\u0440\u0432\u044B\u0439
    \u0441\u044B\u043D \u0421\u0435\u0440\u0436 (Serge)**. \u041E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u0431\u044B\u043B\u0438 \u043D\u0435\u0434\u043E\u043B\u0433\u0438\u043C\u0438,
    \u0438 \u0432\u043E\u043A\u0440\u0443\u0433 \u043E\u043F\u0435\u043A\u0438 \u043D\u0430\u0434
    \u0421\u0435\u0440\u0436\u0435\u043C \u0440\u0430\u0437\u0433\u043E\u0440\u0435\u043B\u0438\u0441\u044C
    \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u044B\u0435 \u0441\u043F\u043E\u0440\u044B,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0432 1962 \u0433\u043E\u0434\u0443
    \u0434\u043E\u0448\u043B\u0438 \u0434\u0430\u0436\u0435 \u0434\u043E \u0441\u0443\u0434\u0430.
    \u0412 \u0438\u0442\u043E\u0433\u0435 \u0421\u0435\u0440\u0436 \u0432\u044B\u0440\u043E\u0441
    \u0441 \u043C\u0430\u0442\u0435\u0440\u044C\u044E. \u0412\u0437\u0440\u043E\u0441\u043B\u044B\u0439
    \u0421\u0435\u0440\u0436, \u043F\u043E \u0435\u0433\u043E \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C
    \u0441\u043B\u043E\u0432\u0430\u043C, \u043F\u0440\u043E\u0448\u0435\u043B \u0447\u0435\u0440\u0435\u0437
    \"\u0433\u0440\u0430\u043D\u0434\u0438\u043E\u0437\u043D\u0443\u044E \u043A\u0430\u0440\u044C\u0435\u0440\u0443
    \u043F\u043E\u043B\u043D\u043E\u0433\u043E \u043D\u0435\u0443\u0434\u0430\u0447\u043D\u0438\u043A\u0430\",
    \u043F\u0435\u0440\u0435\u0431\u0438\u0432\u0430\u044F\u0441\u044C \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u043C\u0438
    \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u043A\u0430\u043C\u0438, \u0438 \u0432
    \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \u043C\u043E\u043C\u0435\u043D\u0442
    \u0441\u0442\u0430\u043B \u043F\u043E\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0438\u043D\u0434\u0438\u0439\u0441\u043A\u043E\u0433\u043E \u0433\u0443\u0440\u0443.
    \u042D\u0442\u0430 \u043D\u0435\u043F\u0440\u043E\u0441\u0442\u0430\u044F \u0438\u0441\u0442\u043E\u0440\u0438\u044F
    \u0441 \u0421\u0435\u0440\u0436\u0435\u043C \u0441\u0442\u0430\u043B\u0430 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0442\u0440\u0435\u0449\u0438\u043D\u043E\u0439 \u0432 \u0441\u0435\u043C\u0435\u0439\u043D\u043E\u0439
    \u0436\u0438\u0437\u043D\u0438 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430. 
    *   **\u0411\u0440\u0430\u043A \u0441 \u041C\u0438\u0440\u0435\u0439 \u0414\u044E\u0444\u0443\u0440.**
    \u0421\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F,
    \u0443\u0436\u0435 \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435,
    \u0441\u043B\u043E\u0436\u0438\u043B\u0438\u0441\u044C \u0441 **\u041C\u0438\u0440\u0435\u0439
    \u0414\u044E\u0444\u0443\u0440 (Mireille Dufour)**. \u0421\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F,
    \u0447\u0442\u043E \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A \u043F\u043E\u043E\u0431\u0435\u0449\u0430\u043B
    \u0441\u0432\u043E\u0435\u0439 \u0443\u043C\u0438\u0440\u0430\u044E\u0449\u0435\u0439
    \u043C\u0430\u0442\u0435\u0440\u0438 \u0425\u0430\u043D\u043A\u0435 \u0436\u0435\u043D\u0438\u0442\u044C\u0441\u044F
    \u043D\u0430 \u041C\u0438\u0440\u0435\u0439, \u0438 \u0431\u0440\u0430\u043A
    \u0431\u044B\u043B \u0437\u0430\u043A\u043B\u044E\u0447\u0435\u043D \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E
    \u0432 \u043A\u043E\u043D\u0446\u0435 1950-\u0445 \u0433\u043E\u0434\u043E\u0432.
    \u0423 \u043D\u0438\u0445 \u0440\u043E\u0434\u0438\u043B\u043E\u0441\u044C \u0442\u0440\u043E\u0435
    \u0434\u0435\u0442\u0435\u0439:     *   **\u0414\u043E\u0447\u044C \u0419\u043E\u0445\u0430\u043D\u043D\u0430
    (Johanna)** (\u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C 16 \u0444\u0435\u0432\u0440\u0430\u043B\u044F
    1959 \u0433\u043E\u0434\u0430 \u0432 \u0411\u043E\u0441\u0442\u043E\u043D\u0435,
    \u0421\u0428\u0410).     *   **\u0421\u044B\u043D \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440
    (Alexandre) \u043C\u043B.** (\u0440\u043E\u0434\u0438\u043B\u0441\u044F 18 \u0438\u044E\u043B\u044F
    1961 \u0433\u043E\u0434\u0430).     *   **\u0421\u044B\u043D \u041C\u0430\u0442\u044C\u0451
    (Matthieu)** (\u0440\u043E\u0434\u0438\u043B\u0441\u044F 23 \u0430\u043F\u0440\u0435\u043B\u044F
    1965 \u0433\u043E\u0434\u0430).      \u042D\u0442\u043E\u0442 \u0431\u0440\u0430\u043A
    \u0441\u0447\u0430\u0441\u0442\u043B\u0438\u0432\u044B\u043C \u043D\u0435 \u0431\u044B\u043B.
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A \u043C\u043E\u0433 \u043F\u0440\u0438\u0432\u043E\u0434\u0438\u0442\u044C
    \u0432 \u0438\u0445 \u043E\u0431\u0449\u0438\u0439 \u0434\u043E\u043C \u0434\u0440\u0443\u0433\u0438\u0445
    \u0436\u0435\u043D\u0449\u0438\u043D, \u0430 \u0432 \u043A\u0430\u043A\u043E\u0439-\u0442\u043E
    \u043C\u043E\u043C\u0435\u043D\u0442 \u0434\u0430\u0436\u0435 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F
    \u043C\u0435\u0436\u0434\u0443 \u041C\u0438\u0440\u0435\u0439 \u0438 \u043E\u0434\u043D\u043E\u0439
    \u0438\u0437 \u0435\u0433\u043E \u043B\u044E\u0431\u043E\u0432\u043D\u0438\u0446,
    \u043F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0430\u043C,
    \u043F\u0435\u0440\u0435\u0440\u043E\u0441\u043B\u0438 \u0432 \"\u043F\u0430\u043A\u0442\"
    \u043F\u0440\u043E\u0442\u0438\u0432 \u0435\u0449\u0435 \u043E\u0434\u043D\u043E\u0439
    \u0441\u043E\u043F\u0435\u0440\u043D\u0438\u0446\u044B. \u041F\u043E\u0441\u043B\u0435
    \u0435\u0433\u043E \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \"\u043F\u043E\u0432\u043E\u0440\u043E\u0442\u0430\" \u0432 1970 \u0433\u043E\u0434\u0443
    \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u0441 \u041C\u0438\u0440\u0435\u0439
    \u0441\u0442\u0430\u043B\u0438 \u0432\u0440\u0430\u0436\u0434\u0435\u0431\u043D\u044B\u043C\u0438.
    \u041A\u0430\u043A\u043E\u0435-\u0442\u043E \u0432\u0440\u0435\u043C\u044F \u043E\u043D
    \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F \u043F\u043B\u0430\u0442\u0438\u0442\u044C
    \u0430\u043B\u0438\u043C\u0435\u043D\u0442\u044B, \u0438 \u041C\u0438\u0440\u0435\u0439
    \u0431\u044B\u043B\u0430 \u0432\u044B\u043D\u0443\u0436\u0434\u0435\u043D\u0430
    \u043E\u0434\u043D\u0430 \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u0442\u044C
    \u0434\u0432\u043E\u0438\u0445 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0445
    \u0441\u044B\u043D\u043E\u0432\u0435\u0439 \u0432 \u043F\u0440\u0438\u0433\u043E\u0440\u043E\u0434\u0435
    \u041F\u0430\u0440\u0438\u0436\u0430. \u041F\u043E \u0438\u0440\u043E\u043D\u0438\u0438
    \u0441\u0443\u0434\u044C\u0431\u044B, \u043F\u043E\u0437\u0434\u043D\u0435\u0435
    \u041C\u0438\u0440\u0435\u0439 \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0430
    \u0432\u0441\u043B\u0435\u0434 \u0437\u0430 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u043E\u043C
    \u043D\u0430 \u044E\u0433 \u0424\u0440\u0430\u043D\u0446\u0438\u0438, \u0447\u0442\u043E\u0431\u044B
    \u0441\u044B\u043D\u043E\u0432\u044C\u044F \u043C\u043E\u0433\u043B\u0438 \u0432\u0438\u0434\u0435\u0442\u044C\u0441\u044F
    \u0441 \u043E\u0442\u0446\u043E\u043C. \u041E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u0440\u0430\u0437\u0432\u043E\u0434 \u0441\u043E\u0441\u0442\u043E\u044F\u043B\u0441\u044F
    \u043B\u0438\u0448\u044C \u0432 1981 \u0433\u043E\u0434\u0443. \u041C\u0438\u0440\u0435\u0439
    \u0443\u043C\u0435\u0440\u043B\u0430 \u0432 2008 \u0433\u043E\u0434\u0443, \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u043D\u0430\u044F
    \u0441\u0432\u043E\u0438\u043C\u0438 \u0434\u0435\u0442\u044C\u043C\u0438.  *  
    **\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439 \u0441\u044B\u043D:
    \u0425\u0430\u043D\u0441 \u0438 \u0414\u0436\u0430\u0441\u0442\u0438\u043D \u0421\u043A\u0430\u043B\u044C\u0431\u0430.**
    \u041F\u043E\u043C\u0438\u043C\u043E \u044D\u0442\u0438\u0445 \u0447\u0435\u0442\u044B\u0440\u0435\u0445
    \u0434\u0435\u0442\u0435\u0439, \u0443 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430
    \u0431\u044B\u043B \u0435\u0449\u0435 \u043E\u0434\u0438\u043D \u0441\u044B\u043D
    \u043F\u043E \u0438\u043C\u0435\u043D\u0438 **\u0425\u0430\u043D\u0441 (Hans)**
    (\u0438\u043B\u0438 \u0414\u0436\u043E\u043D) \u043E\u0442 \u0436\u0435\u043D\u0449\u0438\u043D\u044B
    \u043F\u043E \u0438\u043C\u0435\u043D\u0438 **\u0414\u0436\u0430\u0441\u0442\u0438\u043D
    \u0421\u043A\u0430\u043B\u044C\u0431\u0430 (Justine Skalba)**. \u0421\u0443\u0434\u044C\u0431\u0430
    \u0425\u0430\u043D\u0441\u0430 \u0442\u0443\u043C\u0430\u043D\u043D\u0430: \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u043E\u0434\u043D\u0430\u0436\u0434\u044B \u0443\u043F\u043E\u043C\u044F\u043D\u0443\u043B,
    \u0447\u0442\u043E \u043D\u0435 \u043F\u043E\u043B\u0443\u0447\u0430\u043B \u0438\u0437\u0432\u0435\u0441\u0442\u0438\u0439
    \u043E \u043D\u0435\u043C \u0434\u043E\u043B\u0433\u043E\u0435 \u0432\u0440\u0435\u043C\u044F. 
    ### \U0001F333 \u0421\u0435\u043C\u0435\u0439\u043D\u044B\u0435 \u0443\u0437\u044B:
    \u0441\u0435\u0441\u0442\u0440\u0430 \u0438 \u043C\u0430\u0442\u044C  \u041E\u0441\u043E\u0431\u043E\u0435
    \u043C\u0435\u0441\u0442\u043E \u0432 \u0436\u0438\u0437\u043D\u0438 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430
    \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0438 \u0435\u0433\u043E \u043C\u0430\u0442\u044C
    \u0425\u0430\u043D\u043A\u0430 \u0438 \u0441\u0432\u043E\u0434\u043D\u0430\u044F
    \u0441\u0435\u0441\u0442\u0440\u0430 \u041C\u0430\u0439\u0434\u0438.  *   **\u041C\u0430\u0442\u044C,
    \u0425\u0430\u043D\u043A\u0430 (Johanna \"Hanka\" Grothendieck):** \u0418\u0445
    \u0441\u0432\u044F\u0437\u044C \u0431\u044B\u043B\u0430 \u0433\u043B\u0443\u0431\u043E\u043A\u0430
    \u0438 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u0430. \u041F\u043E\u0441\u043B\u0435
    \u0432\u043E\u0439\u043D\u044B \u043E\u043D\u0438 \u0436\u0438\u043B\u0438 \u0432\u043C\u0435\u0441\u0442\u0435
    \u0432 \u041C\u043E\u043D\u043F\u0435\u043B\u044C\u0435, \u0442\u044F\u0436\u0435\u043B\u043E
    \u0440\u0430\u0431\u043E\u0442\u0430\u044F, \u0447\u0442\u043E\u0431\u044B \u0432\u044B\u0436\u0438\u0442\u044C.
    \u0425\u0430\u043D\u043A\u0430 \u0431\u043E\u043B\u0435\u043B\u0430 \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437\u043E\u043C,
    \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u044B\u043C \u0432 \u043B\u0430\u0433\u0435\u0440\u044F\u0445
    \u0434\u043B\u044F \u0438\u043D\u0442\u0435\u0440\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445,
    \u0438 \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0430\u0441\u044C \u0432 1957
    \u0433\u043E\u0434\u0443. \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u043F\u043E\u0441\u0432\u044F\u0442\u0438\u043B \u0441\u0432\u043E\u044E \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u0443\u044E
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u044E \u0438\u043C\u0435\u043D\u043D\u043E
    \u0435\u0439. \u0423\u0445\u043E\u0434 \u043C\u0430\u0442\u0435\u0440\u0438 \u0441\u0442\u0430\u043B
    \u0434\u043B\u044F \u043D\u0435\u0433\u043E \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0439
    \u043F\u043E\u0442\u0435\u0440\u0435\u0439 \u0438, \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E,
    \u043F\u043E\u0432\u043B\u0438\u044F\u043B \u043D\u0430 \u0435\u0433\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0436\u0435\u043D\u0438\u0442\u044C\u0441\u044F \u043D\u0430 \u041C\u0438\u0440\u0435\u0439,
    \u0447\u0442\u043E\u0431\u044B \u0441\u0434\u0435\u0440\u0436\u0430\u0442\u044C
    \u043F\u0440\u0435\u0434\u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0435 \u043E\u0431\u0435\u0449\u0430\u043D\u0438\u0435. 
    *   **\u0421\u0432\u043E\u0434\u043D\u0430\u044F \u0441\u0435\u0441\u0442\u0440\u0430,
    \u041C\u0430\u0439\u0434\u0438 (Maidi Raddatz):** \u0421\u0432\u043E\u0434\u043D\u0430\u044F
    \u0441\u0435\u0441\u0442\u0440\u0430 \u041C\u0430\u0439\u0434\u0438 (\u0434\u043E\u0447\u044C
    \u0425\u0430\u043D\u043A\u0438 \u043E\u0442 \u043F\u0435\u0440\u0432\u043E\u0433\u043E
    \u0431\u0440\u0430\u043A\u0430) \u043F\u043E\u0441\u043B\u0435 \u0432\u043E\u0439\u043D\u044B
    \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043B\u0430 \u0432
    \u0421\u0428\u0410. \u0412 \u043A\u043E\u043D\u0446\u0435 1970-\u0445 \u0433\u043E\u0434\u043E\u0432,
    \u0441\u043F\u0443\u0441\u0442\u044F \u0434\u043E\u043B\u0433\u0438\u0435 \u0433\u043E\u0434\u044B,
    \u043E\u043D\u0430 \u0440\u0435\u0448\u0438\u043B\u0430 \u043D\u0430\u0432\u0435\u0441\u0442\u0438\u0442\u044C
    \u0431\u0440\u0430\u0442\u0430. \u042D\u0442\u0430 \u0432\u0441\u0442\u0440\u0435\u0447\u0430
    \u043E\u0431\u0435\u0440\u043D\u0443\u043B\u0430\u0441\u044C \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\u043E\u0439.
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439,
    \u043F\u043E-\u0432\u0438\u0434\u0438\u043C\u043E\u043C\u0443, \u0442\u043E\u0441\u043A\u043E\u0432\u0430\u043B
    \u043F\u043E \u043D\u0435\u0439 \u0438 \u0434\u0430\u0436\u0435 \u043F\u0440\u0438\u0441\u043B\u0430\u043B
    \u0434\u0435\u043D\u0435\u0433 \u043D\u0430 \u0434\u043E\u0440\u043E\u0433\u0443,
    \u0432\u043D\u0435\u0437\u0430\u043F\u043D\u043E \u043E\u0431\u0432\u0438\u043D\u0438\u043B
    \u0441\u0435\u0441\u0442\u0440\u0443 \u0432 \u0442\u043E\u043C, \u0447\u0442\u043E
    \u043E\u043D\u0430 \u0432\u0442\u043E\u0440\u0433\u043B\u0430\u0441\u044C \u0432
    \u0435\u0433\u043E \u043B\u0438\u0447\u043D\u043E\u0435 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432\u043E,
    \u0438 \u0432\u044B\u0433\u043D\u0430\u043B \u0435\u0451 \u0438\u0437 \u0434\u043E\u043C\u0430.
    \u0418\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F \u043F\u043E\u0441\u043B\u0435
    \u044D\u0442\u043E\u0433\u043E \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0440\u0430\u0437\u043E\u0440\u0432\u0430\u043B\u0438\u0441\u044C. \u0415\u0433\u043E
    \u043F\u043B\u0435\u043C\u044F\u043D\u043D\u0438\u0446\u0430 \u0414\u0438\u0430\u043D\u0430
    \u0442\u0430\u043A \u0432\u0441\u043F\u043E\u043C\u0438\u043D\u0430\u043B\u0430
    \u0442\u043E \u0432\u0440\u0435\u043C\u044F: \"\u041C\u044B \u0432\u0441\u0435
    \u0435\u0449\u0435 \u043E\u0431\u043C\u0435\u043D\u044F\u043B\u0438\u0441\u044C
    \u043F\u0430\u0440\u043E\u0439 \u043F\u0438\u0441\u0435\u043C \u043F\u043E\u0437\u0436\u0435,
    \u043D\u043E \u043E\u043D\u0438 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0438\u0441\u044C
    \u0432\u0441\u0435 \u0445\u0443\u0436\u0435 \u0438 \u0445\u0443\u0436\u0435...
    \u042F \u043F\u043E\u043C\u043D\u044E \u043E\u0434\u043D\u043E \u043F\u0438\u0441\u044C\u043C\u043E,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043E\u043D\u0430 \u0434\u0430\u0436\u0435
    \u043D\u0435 \u043E\u0442\u043A\u0440\u044B\u043B\u0430. \u041E\u043D\u0430 \u0432\u044B\u0431\u0440\u043E\u0441\u0438\u043B\u0430
    \u0435\u0433\u043E \u043F\u0440\u044F\u043C\u043E \u0432 \u043C\u0443\u0441\u043E\u0440\u043A\u0443\". 
    ### \U0001F64F \"\u0412\u0435\u043B\u0438\u043A\u0438\u0439 \u043F\u043E\u0432\u043E\u0440\u043E\u0442\"
    \u0438 \u0440\u0430\u0437\u0440\u044B\u0432 \u0441 \u0441\u0435\u043C\u044C\u0435\u0439 
    \u041A\u043B\u044E\u0447\u0435\u0432\u044B\u043C \u043C\u043E\u043C\u0435\u043D\u0442\u043E\u043C,
    \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0432\u0448\u0438\u043C \u0435\u0433\u043E
    \u0441\u0435\u043C\u0435\u0439\u043D\u0443\u044E \u0436\u0438\u0437\u043D\u044C,
    \u0441\u0442\u0430\u043B 1970 \u0433\u043E\u0434, \u043A\u043E\u0433\u0434\u0430
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A \u0443\u0448\u0435\u043B
    \u0438\u0437 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u0430 \u0432\u044B\u0441\u0448\u0438\u0445
    \u043D\u0430\u0443\u0447\u043D\u044B\u0445 \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439
    (IHES). \u041E\u043D \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0440\u0432\u0430\u043B
    \u0441 \u0430\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u043C\u0438\u0440\u043E\u043C, \u043D\u043E \u0438 \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u044C\u043D\u043E
    \u043F\u0435\u0440\u0435\u0441\u043C\u043E\u0442\u0440\u0435\u043B \u0441\u0432\u043E\u044E
    \u0436\u0438\u0437\u043D\u044C, \u0443\u0439\u0434\u044F \u0432 \u044D\u043A\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0438 \u043F\u0430\u0446\u0438\u0444\u0438\u0441\u0442\u0441\u043A\u0438\u0439
    \u0430\u043A\u0442\u0438\u0432\u0438\u0437\u043C. \u0415\u0433\u043E \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435
    \u0441\u0442\u0430\u043B\u043E \u043E\u0442\u0447\u0443\u0436\u0434\u0435\u043D\u043D\u044B\u043C.
    \u0414\u043E\u0447\u044C \u0419\u043E\u0445\u0430\u043D\u043D\u0430 \u0431\u044B\u043B\u0430
    \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0430 \u0432 \u0413\u0430\u043C\u0431\u0443\u0440\u0433,
    \u0430 \u0437\u0430\u0442\u0435\u043C, \u0432 14 \u043B\u0435\u0442, \u043E\u043D
    \u0437\u0430\u0431\u0440\u0430\u043B \u0435\u0451 \u0438\u0437 \u0448\u043A\u043E\u043B\u044B,
    \u0441\u0447\u0438\u0442\u0430\u044F \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0432\u0440\u0435\u0434\u043D\u044B\u043C, \u043D\u043E \u0442\u0430\u043A \u0438
    \u043D\u0435 \u0441\u0442\u0430\u043B \u0443\u0447\u0438\u0442\u044C \u0435\u0451
    \u0441\u0430\u043C.  \u0421\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0435\u043C
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A \u0441\u0431\u043B\u0438\u0437\u0438\u043B\u0441\u044F
    \u0441 \u0434\u0435\u0442\u044C\u043C\u0438 \u2014 \u0432 \u043F\u0438\u0441\u044C\u043C\u0430\u0445
    1979-1980 \u0433\u043E\u0434\u043E\u0432 \u043E\u043D \u043F\u0438\u0441\u0430\u043B
    \u043E \u0442\u0435\u043F\u043B\u044B\u0445 \u043E\u0442\u043D\u043E\u0448\u0435\u043D\u0438\u044F\u0445
    \u0441 \u043D\u0438\u043C\u0438 \u0438 \u043E \u0442\u043E\u043C, \u0447\u0442\u043E
    \u043E\u043D\u0438 \u043D\u0430\u043A\u043E\u043D\u0435\u0446 \u043D\u0430\u0447\u0430\u043B\u0438
    \u043D\u0430\u0432\u0435\u0449\u0430\u0442\u044C \u0435\u0433\u043E \u043F\u043E
    \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439 \u0438\u043D\u0438\u0446\u0438\u0430\u0442\u0438\u0432\u0435.
    \u041E\u0434\u043D\u0430\u043A\u043E \u044D\u0442\u0438 \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u044B
    \u0431\u044B\u043B\u0438 \u043D\u0435\u0434\u043E\u043B\u0433\u0438\u043C\u0438
    \u0438 \u0441\u043E\u0448\u043B\u0438 \u043D\u0430 \u043D\u0435\u0442. \u041F\u043E\u0432\u0437\u0440\u043E\u0441\u043B\u0435\u0432,
    \u0431\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E \u0435\u0433\u043E
    \u0434\u0435\u0442\u0435\u0439 \u0438\u0437\u0431\u0440\u0430\u043B\u0438 \u0436\u0438\u0437\u043D\u044C,
    \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u043E\u043D \u0441\u0430\u043C \u043D\u0430\u0437\u044B\u0432\u0430\u043B
    \"\u043E\u0442\u0449\u0435\u043F\u0435\u043D\u0446\u0430\u043C\u0438\" (breakaways):
    \u043E\u043D\u0438 \u043D\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u044F
    \u0438 \u043F\u0435\u0440\u0435\u0431\u0438\u0432\u0430\u043B\u0438\u0441\u044C
    \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u043C\u0438 \u0437\u0430\u0440\u0430\u0431\u043E\u0442\u043A\u0430\u043C\u0438
    \u0438 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u043E\u043C.  ###
    \U0001F56F\uFE0F \u041E\u0442\u0448\u0435\u043B\u044C\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0438 \u043F\u043E\u043B\u043D\u044B\u0439 \u0443\u0445\u043E\u0434  \u0412
    1990 \u0433\u043E\u0434\u0443 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u0441\u0436\u0435\u0433 \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u0447\u0430\u0441\u0442\u044C
    \u0441\u0432\u043E\u0438\u0445 \u0431\u0443\u043C\u0430\u0433 \u0438 \u0443\u0435\u0434\u0438\u043D\u0438\u043B\u0441\u044F
    \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435 \u041B\u0430\u0441\u0441\u0435\u0440
    \u0432 \u041F\u0438\u0440\u0435\u043D\u0435\u044F\u0445. \u0412 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    20 \u0441 \u043B\u0438\u0448\u043D\u0438\u043C \u043B\u0435\u0442 \u0436\u0438\u0437\u043D\u0438
    \u043E\u043D \u0432\u0435\u043B \u0436\u0438\u0437\u043D\u044C \u043E\u0442\u0448\u0435\u043B\u044C\u043D\u0438\u043A\u0430,
    \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043D\u0435
    \u043E\u0431\u0449\u0430\u044F\u0441\u044C \u0441 \u043B\u044E\u0434\u044C\u043C\u0438,
    \u0432\u043A\u043B\u044E\u0447\u0430\u044F \u0441\u0432\u043E\u044E \u0441\u0435\u043C\u044C\u044E.
    \u041E\u043D \u0443\u043C\u0435\u0440 13 \u043D\u043E\u044F\u0431\u0440\u044F
    2014 \u0433\u043E\u0434\u0430 \u0432 \u0431\u043E\u043B\u044C\u043D\u0438\u0446\u0435
    \u0433\u043E\u0440\u043E\u0434\u0430 \u0421\u0435\u043D-\u0416\u0438\u0440\u043E\u043D,
    \u043E\u0434\u0438\u043D\u043E\u043A\u0438\u0439 \u0438 \u0437\u0430\u0431\u044B\u0442\u044B\u0439
    \u043C\u0438\u0440\u043E\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u043E\u043D
    \u043A\u043E\u0433\u0434\u0430-\u0442\u043E \u0438\u0437\u043C\u0435\u043D\u0438\u043B."
  personalLifeEn: 
  shortBioRu: "\u0410\u043B\u0435\u043A\u0441\u0430\u0301\u043D\u0434\u0440 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u0301\u043A
    (1928\u20132014) \u2014 \u043E\u0434\u0438\u043D \u0438\u0437 \u0432\u0435\u043B\u0438\u0447\u0430\u0439\u0448\u0438\u0445
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432 XX \u0432\u0435\u043A\u0430,
    \u0447\u044C\u044F \u0436\u0438\u0437\u043D\u044C \u0431\u044B\u043B\u0430 \u0441\u0442\u043E\u043B\u044C
    \u0436\u0435 \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u043D\u043E\u0439
    \u0438 \u043D\u0435\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u043E\u0439,
    \u043A\u0430\u043A \u0438 \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0438\u0434\u0435\u0438. \u041E\u043D \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u043F\u0435\u0440\u0435\u043E\u0441\u043C\u044B\u0441\u043B\u0438\u043B \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u0443\u044E
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u044E, \u043D\u043E \u0435\u0433\u043E
    \u043F\u0443\u0442\u044C \u0431\u044B\u043B \u043E\u0442\u043C\u0435\u0447\u0435\u043D
    \u0432\u043E\u0439\u043D\u043E\u0439, \u043F\u043E\u043B\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0440\u0430\u0434\u0438\u043A\u0430\u043B\u0438\u0437\u043C\u043E\u043C \u0438
    \u0434\u043E\u0431\u0440\u043E\u0432\u043E\u043B\u044C\u043D\u044B\u043C \u0437\u0430\u0442\u0432\u043E\u0440\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E\u043C. 
    ### \U0001F4DC \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u0438 \u0431\u0443\u0440\u043D\u043E\u0435 \u0434\u0435\u0442\u0441\u0442\u0432\u043E 
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A \u0440\u043E\u0434\u0438\u043B\u0441\u044F
    \u0432 \u0411\u0435\u0440\u043B\u0438\u043D\u0435 28 \u043C\u0430\u0440\u0442\u0430
    1928 \u0433\u043E\u0434\u0430 \u0432 \u0441\u0435\u043C\u044C\u0435 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u0435\u0440\u043E\u0432-\u0430\u043D\u0430\u0440\u0445\u0438\u0441\u0442\u043E\u0432. 
    *   **\u041E\u0442\u0435\u0446, \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440
    \xAB\u0421\u0430\u0448\u0430\xBB \u0428\u0430\u043F\u0438\u0440\u043E** (\u043E\u043A.
    1890\u20131942): \u0420\u043E\u0434\u0438\u043B\u0441\u044F \u0432 \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u043E\u0439
    \u0441\u0435\u043C\u044C\u0435 \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u041D\u043E\u0432\u043E\u0437\u044B\u0431\u043A\u043E\u0432
    (\u0420\u043E\u0441\u0441\u0438\u0439\u0441\u043A\u0430\u044F \u0438\u043C\u043F\u0435\u0440\u0438\u044F).
    \u0421 \u044E\u043D\u043E\u0441\u0442\u0438 \u0443\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u043B
    \u0432 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u043E\u043D\u043D\u043E\u043C
    \u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0438, \u0431\u044B\u043B \u043F\u0440\u0438\u0433\u043E\u0432\u043E\u0440\u0435\u043D
    \u043A \u0441\u043C\u0435\u0440\u0442\u043D\u043E\u0439 \u043A\u0430\u0437\u043D\u0438,
    \u0437\u0430\u043C\u0435\u043D\u0435\u043D\u043D\u043E\u0439 \u043F\u043E\u0436\u0438\u0437\u043D\u0435\u043D\u043D\u043E\u0439
    \u043A\u0430\u0442\u043E\u0440\u0433\u043E\u0439, \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
    \u0431\u0435\u0436\u0430\u043B \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u0438
    1917 \u0433\u043E\u0434\u0430. \u0412 \u0431\u043E\u044F\u0445 \u043F\u043E\u0442\u0435\u0440\u044F\u043B
    \u043B\u0435\u0432\u0443\u044E \u0440\u0443\u043A\u0443. \u0412 1921 \u0433\u043E\u0434\u0443
    \u044D\u043C\u0438\u0433\u0440\u0438\u0440\u043E\u0432\u0430\u043B \u0432 \u0413\u0435\u0440\u043C\u0430\u043D\u0438\u044E,
    \u0430 \u0437\u0430\u0442\u0435\u043C \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E.
    *   **\u041C\u0430\u0442\u044C, \u0418\u043E\u0433\u0430\u043D\u043D\u0430 \xAB\u0425\u0430\u043D\u043A\u0430\xBB
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A** (1900\u20131957): \u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u0430
    \u0438\u0437 \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430\u043D\u0442\u0441\u043A\u043E\u0439
    \u0441\u0435\u043C\u044C\u0438 \u0432 \u0413\u0430\u043C\u0431\u0443\u0440\u0433\u0435,
    \u0431\u044B\u043B\u0430 \u0436\u0443\u0440\u043D\u0430\u043B\u0438\u0441\u0442\u043A\u043E\u0439
    \u0438 \u043B\u0435\u0432\u043E\u0439 \u0430\u043A\u0442\u0438\u0432\u0438\u0441\u0442\u043A\u043E\u0439. 
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440 \u043D\u043E\u0441\u0438\u043B
    \u0444\u0430\u043C\u0438\u043B\u0438\u044E \u043C\u0430\u0442\u0435\u0440\u0438,
    \u0442\u0430\u043A \u043A\u0430\u043A \u0435\u0433\u043E \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438
    \u043D\u0435 \u0431\u044B\u043B\u0438 \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E
    \u0436\u0435\u043D\u0430\u0442\u044B. \u0412 1933 \u0433\u043E\u0434\u0443, \u043F\u043E\u0441\u043B\u0435
    \u043F\u0440\u0438\u0445\u043E\u0434\u0430 \u0413\u0438\u0442\u043B\u0435\u0440\u0430
    \u043A \u0432\u043B\u0430\u0441\u0442\u0438, \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438
    \u0431\u0435\u0436\u0430\u043B\u0438 \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E,
    \u043E\u0441\u0442\u0430\u0432\u0438\u0432 5-\u043B\u0435\u0442\u043D\u0435\u0433\u043E
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0430 \u043D\u0430 \u043F\u043E\u043F\u0435\u0447\u0435\u043D\u0438\u0435
    \u043F\u0430\u0441\u0442\u043E\u0440\u0430 \u0412\u0438\u043B\u044C\u0433\u0435\u043B\u044C\u043C\u0430
    \u0425\u0435\u0439\u0434\u043E\u0440\u043D\u0430 \u0432 \u0413\u0430\u043C\u0431\u0443\u0440\u0433\u0435. 
    \u0412 1939 \u0433\u043E\u0434\u0443, \u043E\u043F\u0430\u0441\u0430\u044F\u0441\u044C
    \u0437\u0430 \u0435\u0433\u043E \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u044C,
    \u043F\u0440\u0438\u0435\u043C\u043D\u044B\u0435 \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u0438
    \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0438 \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0430
    \u043A \u0431\u0438\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u043C
    \u0440\u043E\u0434\u0438\u0442\u0435\u043B\u044F\u043C \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u044E.
    \u041E\u0434\u043D\u0430\u043A\u043E \u0440\u0430\u0437\u0440\u0430\u0437\u0438\u043B\u0430\u0441\u044C
    \u0412\u0442\u043E\u0440\u0430\u044F \u043C\u0438\u0440\u043E\u0432\u0430\u044F
    \u0432\u043E\u0439\u043D\u0430.  *   **\u041E\u0442\u0435\u0446** \u0431\u044B\u043B
    \u0430\u0440\u0435\u0441\u0442\u043E\u0432\u0430\u043D \u0438 \u0432 1942 \u0433\u043E\u0434\u0443
    \u0434\u0435\u043F\u043E\u0440\u0442\u0438\u0440\u043E\u0432\u0430\u043D \u0432
    \u041E\u0441\u0432\u0435\u043D\u0446\u0438\u043C, \u0433\u0434\u0435 \u043F\u043E\u0433\u0438\u0431.
    *   **\u041C\u0430\u0442\u044C \u0438 \u0441\u044B\u043D** \u0431\u044B\u043B\u0438
    \u0438\u043D\u0442\u0435\u0440\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u044B
    \u0432 \u043B\u0430\u0433\u0435\u0440\u044F \u0434\u043B\u044F \xAB\u043D\u0435\u0431\u043B\u0430\u0433\u043E\u043D\u0430\u0434\u0435\u0436\u043D\u044B\u0445
    \u0438\u043D\u043E\u0441\u0442\u0440\u0430\u043D\u0446\u0435\u0432\xBB (\u0420\u044C\u0435\u043A\u0440\u043E,
    \u0413\u044E\u0440\u0441). \u041C\u0430\u0442\u044C \u0437\u0430\u0440\u0430\u0437\u0438\u043B\u0430\u0441\u044C
    \u0442\u0443\u0431\u0435\u0440\u043A\u0443\u043B\u0435\u0437\u043E\u043C, \u043E\u0442
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043F\u043E\u0437\u0436\u0435
    \u0443\u043C\u0435\u0440\u043B\u0430. *   **\u0421\u0430\u043C \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A**
    \u0431\u044B\u043B \u0440\u0430\u0437\u043B\u0443\u0447\u0435\u043D \u0441 \u043C\u0430\u0442\u0435\u0440\u044C\u044E
    \u0438 \u0434\u043E \u043A\u043E\u043D\u0446\u0430 \u0432\u043E\u0439\u043D\u044B
    \u0436\u0438\u043B \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435 \u0428\u0430\u043C\u0431\u043E\u043D-\u0441\u044E\u0440-\u041B\u0438\u043D\u044C\u043E\u043D,
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439 \u0442\u0435\u043C, \u0447\u0442\u043E
    \u0435\u0435 \u0436\u0438\u0442\u0435\u043B\u0438 \u0443\u043A\u0440\u044B\u0432\u0430\u043B\u0438
    \u0435\u0432\u0440\u0435\u0439\u0441\u043A\u0438\u0445 \u0434\u0435\u0442\u0435\u0439.
    \u0422\u0430\u043C \u043E\u043D \u043F\u043E\u0441\u0435\u0449\u0430\u043B \u0448\u043A\u043E\u043B\u0443
    \u041A\u043E\u043B\u043B\u0435\u0436 \u0421\u0435\u0432\u0435\u043D\u043E\u043B\u044C,
    \u0433\u0434\u0435 \u0432\u043F\u0435\u0440\u0432\u044B\u0435 \u043F\u0440\u043E\u044F\u0432\u0438\u043B\u0441\u044F
    \u0435\u0433\u043E \u0442\u0430\u043B\u0430\u043D\u0442 \u043A \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0435. 
    ### \U0001F393 \u041E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u043D\u0430\u0447\u0430\u043B\u043E \u043F\u0443\u0442\u0438  \u041F\u043E\u0441\u043B\u0435
    \u0432\u043E\u0439\u043D\u044B \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u0432\u043E\u0441\u0441\u043E\u0435\u0434\u0438\u043D\u0438\u043B\u0441\u044F
    \u0441 \u043C\u0430\u0442\u0435\u0440\u044C\u044E, \u0438 \u043E\u043D\u0438
    \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B\u0438 \u0432 \u041C\u043E\u043D\u043F\u0435\u043B\u044C\u0435,
    \u0433\u0434\u0435 \u043E\u043D \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
    \u0432 \u0443\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442. \u0412
    1948 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u0441\u0442\u0435\u043F\u0435\u043D\u044C \u0431\u0430\u043A\u0430\u043B\u0430\u0432\u0440\u0430.
    \u0423\u0436\u0435 \u0442\u043E\u0433\u0434\u0430 \u043E\u043D \u043F\u0440\u043E\u044F\u0432\u0438\u043B
    \u0441\u0435\u0431\u044F \u043A\u0430\u043A \u043D\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043C\u044B\u0439
    \u043C\u044B\u0441\u043B\u0438\u0442\u0435\u043B\u044C, \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E,
    \u043F\u043E\u0447\u0442\u0438 \u0431\u0435\u0437 \u043F\u043E\u043C\u043E\u0449\u0438
    \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u0435\u0439,
    \xAB\u043F\u0435\u0440\u0435\u043E\u0442\u043A\u0440\u044B\u0432\xBB \u0442\u0435\u043E\u0440\u0438\u044E
    \u043C\u0435\u0440\u044B \u041B\u0435\u0431\u0435\u0433\u0430.  \u041F\u043E
    \u0441\u043E\u0432\u0435\u0442\u0443 \u0441\u0432\u043E\u0435\u0433\u043E \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u043E\u0440\u0430
    \u043E\u043D \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F \u0432
    \u041F\u0430\u0440\u0438\u0436, \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0441\u0435\u0449\u0430\u0442\u044C
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440 \u0410\u043D\u0440\u0438 \u041A\u0430\u0440\u0442\u0430\u043D\u0430
    \u0432 \u0412\u044B\u0441\u0448\u0435\u0439 \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u0448\u043A\u043E\u043B\u0435. \u041E\u0434\u043D\u0430\u043A\u043E \u0443\u0440\u043E\u0432\u0435\u043D\u044C
    \u043F\u0430\u0440\u0438\u0436\u0441\u043A\u043E\u0439 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0448\u043A\u043E\u043B\u044B \u0431\u044B\u043B \u0434\u043B\u044F \u043D\u0435\u0433\u043E
    \u043F\u043E\u043D\u0430\u0447\u0430\u043B\u0443 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
    \u0432\u044B\u0441\u043E\u043A. \u041F\u043E \u0440\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u0438
    \u041A\u0430\u0440\u0442\u0430\u043D\u0430 \u0438 \u0410\u043D\u0434\u0440\u0435
    \u0412\u0435\u0439\u043B\u044F \u043E\u043D \u043F\u0435\u0440\u0435\u0435\u0445\u0430\u043B
    \u0432 \u0423\u043D\u0438\u0432\u0435\u0440\u0441\u0438\u0442\u0435\u0442 \u041D\u0430\u043D\u0441\u0438,
    \u0433\u0434\u0435 \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C
    \u0416\u0430\u043D\u0430 \u0414\u044C\u0451\u0434\u043E\u043D\u043D\u0435 \u0438
    \u041B\u043E\u0440\u0430\u043D\u0430 \u0428\u0432\u0430\u0440\u0446\u0430 \u0437\u0430\u043D\u044F\u043B\u0441\u044F
    \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u043C
    \u0430\u043D\u0430\u043B\u0438\u0437\u043E\u043C.  \u0412 \u041D\u0430\u043D\u0441\u0438
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B
    \u0444\u0443\u0440\u043E\u0440: \u0435\u043C\u0443 \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0438\u043B\u0438
    \u0441\u043F\u0438\u0441\u043E\u043A \u0438\u0437 14 \u043D\u0435\u0440\u0435\u0448\u0435\u043D\u043D\u044B\u0445
    \u0437\u0430\u0434\u0430\u0447 \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
    \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0432\u0435\u043A\u0442\u043E\u0440\u043D\u044B\u0445 \u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0441\u0442\u0432,
    \u0438 \u043E\u043D \u0440\u0435\u0448\u0438\u043B \u0438\u0445 \u0432\u0441\u0435
    \u0437\u0430 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043C\u0435\u0441\u044F\u0446\u0435\u0432.
    \u042D\u0442\u043E \u0441\u0442\u0430\u043B\u043E \u043E\u0441\u043D\u043E\u0432\u043E\u0439
    \u0434\u043B\u044F \u0435\u0433\u043E \u0434\u043E\u043A\u0442\u043E\u0440\u0441\u043A\u043E\u0439
    \u0434\u0438\u0441\u0441\u0435\u0440\u0442\u0430\u0446\u0438\u0438, \u0437\u0430\u0449\u0438\u0449\u0435\u043D\u043D\u043E\u0439
    \u0432 1953 \u0433\u043E\u0434\u0443.  ### \U0001F4A1 \u041C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u043F\u0440\u043E\u0440\u044B\u0432 \u0438 \xAB\u0437\u043E\u043B\u043E\u0442\u044B\u0435
    \u0433\u043E\u0434\u044B\xBB  \u041D\u0430\u0447\u0430\u0432 \u0441 \u0444\u0443\u043D\u043A\u0446\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0430\u043D\u0430\u043B\u0438\u0437\u0430, \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u0432 \u0441\u0435\u0440\u0435\u0434\u0438\u043D\u0435 1950-\u0445 \u0440\u0435\u0437\u043A\u043E
    \u0441\u043C\u0435\u043D\u0438\u043B \u043E\u0431\u043B\u0430\u0441\u0442\u044C
    \u0438 \u0441\u043E\u0441\u0440\u0435\u0434\u043E\u0442\u043E\u0447\u0438\u043B\u0441\u044F
    \u043D\u0430 \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438. \u0415\u0433\u043E \u0440\u0430\u0431\u043E\u0442\u044B,
    \u0432 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E\u0441\u0442\u0438 \xAB\u0422\u043E\u0445\u043E\u043A\u0443
    paper\xBB (1957), \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u043B\u0438 \u0440\u0435\u0432\u043E\u043B\u044E\u0446\u0438\u044E
    \u0432 \u044D\u0442\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438, \u043F\u0440\u0438\u043C\u0435\u043D\u0438\u0432
    \u043C\u043E\u0449\u043D\u044B\u0439 \u0430\u043F\u043F\u0430\u0440\u0430\u0442
    \u0433\u043E\u043C\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0430\u043B\u0433\u0435\u0431\u0440\u044B \u0438 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0439.  \u0412 1958 \u0433\u043E\u0434\u0443
    \u043E\u043D \u0431\u044B\u043B \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D
    \u043D\u0430 \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0447\u0442\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u043D\u044B\u0439 \u0418\u043D\u0441\u0442\u0438\u0442\u0443\u0442
    \u0432\u044B\u0441\u0448\u0438\u0445 \u043D\u0430\u0443\u0447\u043D\u044B\u0445
    \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0439 (IHES)
    \u043F\u043E\u0434 \u041F\u0430\u0440\u0438\u0436\u0435\u043C. \u042D\u0442\u043E
    \u0441\u0442\u0430\u043B\u043E \u043D\u0430\u0447\u0430\u043B\u043E\u043C \u0435\u0433\u043E
    \u0441\u0430\u043C\u043E\u0433\u043E \u043F\u043B\u043E\u0434\u043E\u0442\u0432\u043E\u0440\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0438\u043E\u0434\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \xAB\u0437\u043E\u043B\u043E\u0442\u044B\u043C
    \u0432\u0435\u043A\u043E\u043C\xBB.  *   \u041F\u043E\u0434 \u0435\u0433\u043E
    \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C \u0432
    IHES \u0440\u0430\u0431\u043E\u0442\u0430\u043B \u0437\u043D\u0430\u043C\u0435\u043D\u0438\u0442\u044B\u0439
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440 \u043F\u043E \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438 (SGA), \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u044B
    \u043A\u043E\u0442\u043E\u0440\u043E\u0433\u043E \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u043B\u0438\u0441\u044C
    \u0432 \u0432\u0438\u0434\u0435 \u043C\u043D\u043E\u0433\u043E\u0442\u043E\u043C\u043D\u044B\u0445
    \u0442\u0440\u0443\u0434\u043E\u0432. *   \u0421\u043E\u0432\u043C\u0435\u0441\u0442\u043D\u043E
    \u0441 \u0416\u0430\u043D\u043E\u043C \u0414\u044C\u0451\u0434\u043E\u043D\u043D\u0435
    \u043E\u043D \u043D\u0430\u0447\u0430\u043B \u043F\u0443\u0431\u043B\u0438\u043A\u0430\u0446\u0438\u044E
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0433\u043E
    \u0442\u0440\u0443\u0434\u0430 \xAB\u042D\u043B\u0435\u043C\u0435\u043D\u0442\u044B
    \u0430\u043B\u0433\u0435\u0431\u0440\u0430\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438\xBB (EGA), \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u043E\u043B\u0436\u0435\u043D \u0431\u044B\u043B \u0441\u0442\u0430\u0442\u044C
    \u043D\u043E\u0432\u044B\u043C \u0411\u0438\u0431\u043B\u0438\u0435\u0439 \u0434\u043B\u044F
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432. \u0411\u044B\u043B\u043E
    \u0432\u044B\u043F\u0443\u0449\u0435\u043D\u043E 4 \u0442\u043E\u043C\u0430 (\u0432
    8 \u043A\u043D\u0438\u0433\u0430\u0445), \u0440\u0430\u0431\u043E\u0442\u0430
    \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C \u043D\u0435\u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u043D\u043E\u0439.
    *   \u0412 1966 \u0433\u043E\u0434\u0443 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u0431\u044B\u043B \u0443\u0434\u043E\u0441\u0442\u043E\u0435\u043D \u0424\u0438\u043B\u0434\u0441\u043E\u0432\u0441\u043A\u043E\u0439
    \u043C\u0435\u0434\u0430\u043B\u0438 \u2014 \u0432\u044B\u0441\u0448\u0435\u0439
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B \u0434\u043B\u044F \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u043E\u0432.
    \u041E\u0434\u043D\u0430\u043A\u043E \u043E\u043D \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043B\u0438\u0447\u043D\u043E \u043F\u0440\u0438\u0435\u0445\u0430\u0442\u044C
    \u043D\u0430 \u0446\u0435\u0440\u0435\u043C\u043E\u043D\u0438\u044E \u0432 \u041C\u043E\u0441\u043A\u0432\u0443
    \u0432 \u0437\u043D\u0430\u043A \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0430
    \u043F\u0440\u043E\u0442\u0438\u0432 \u043F\u043E\u0434\u0430\u0432\u043B\u0435\u043D\u0438\u044F
    \u0438\u043D\u0430\u043A\u043E\u043C\u044B\u0441\u043B\u0438\u044F \u0432 \u0421\u0421\u0421\u0420. 
    ### \U0001F6A9 \u0420\u0430\u0437\u0440\u044B\u0432 \u0441 \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442\u043E\u043C
    \u0438 \u0443\u0445\u043E\u0434 \u0438\u0437 \u043D\u0430\u0443\u043A\u0438 
    \u0412 1970 \u0433\u043E\u0434\u0443 \u0432 \u0436\u0438\u0437\u043D\u0438 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430
    \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u0435\u043B \u0440\u0435\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u043F\u0435\u0440\u0435\u043B\u043E\u043C. \u041E\u043D \u0443\u0437\u043D\u0430\u043B,
    \u0447\u0442\u043E IHES \u0447\u0430\u0441\u0442\u0438\u0447\u043D\u043E \u0444\u0438\u043D\u0430\u043D\u0441\u0438\u0440\u0443\u0435\u0442\u0441\u044F
    \u0437\u0430 \u0441\u0447\u0435\u0442 \u0432\u043E\u0435\u043D\u043D\u044B\u0445
    \u0441\u0440\u0435\u0434\u0441\u0442\u0432, \u0438, \u0431\u0443\u0434\u0443\u0447\u0438
    \u0443\u0431\u0435\u0436\u0434\u0435\u043D\u043D\u044B\u043C \u043F\u0430\u0446\u0438\u0444\u0438\u0441\u0442\u043E\u043C
    \u0438 \u044D\u043A\u043E\u043B\u043E\u0433\u043E\u043C, \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E
    \u043F\u043E\u0434\u0430\u043B \u0432 \u043E\u0442\u0441\u0442\u0430\u0432\u043A\u0443. 
    *   \u041E\u043D \u043E\u0441\u043D\u043E\u0432\u0430\u043B \u0433\u0440\u0443\u043F\u043F\u0443
    \xAB\u0412\u044B\u0436\u0438\u0432\u0430\u043D\u0438\u0435\xBB (Survival), \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0431\u043E\u0440\u043E\u043B\u0430\u0441\u044C \u043F\u0440\u043E\u0442\u0438\u0432
    \u044D\u043A\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043A\u0430\u0442\u0430\u0441\u0442\u0440\u043E\u0444\u044B \u0438 \u043C\u0438\u043B\u0438\u0442\u0430\u0440\u0438\u0437\u043C\u0430.
    *   \u041F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E
    \u0443\u0448\u0435\u043B \u0438\u0437 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0439
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438. \u0414\u043E \u0441\u0432\u043E\u0435\u0439
    \u0444\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u0439 \u043F\u0435\u043D\u0441\u0438\u0438
    \u0432 1988 \u0433\u043E\u0434\u0443 \u043E\u043D \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u043B
