    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A \u043F\u0440\u043E\u0432\u0435\u043B
    \u043F\u043E\u0447\u0442\u0438 \u043A\u0430\u043A \u043E\u0442\u0448\u0435\u043B\u044C\u043D\u0438\u043A
    \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435 \u041B\u0430\u0441\u0435\u0440
    \u0432 \u041F\u0438\u0440\u0435\u043D\u0435\u044F\u0445. \u041E\u043D \u043E\u0442\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0441\u044F
    \u043E\u0442 \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u043E\u0432 \u0441 \u0432\u043D\u0435\u0448\u043D\u0438\u043C
    \u043C\u0438\u0440\u043E\u043C \u0438 \u0434\u0430\u0436\u0435 \u0437\u0430\u043F\u0440\u0435\u0442\u0438\u043B
    \u043F\u0443\u0431\u043B\u0438\u043A\u043E\u0432\u0430\u0442\u044C \u0441\u0432\u043E\u0438
    \u0440\u0430\u0431\u043E\u0442\u044B \u0438 \u043F\u0435\u0440\u0435\u0438\u0437\u0434\u0430\u0432\u0430\u0442\u044C
    \u0441\u0442\u0430\u0440\u044B\u0435 \u0442\u0440\u0443\u0434\u044B.  *   \u0412
    1988 \u0433\u043E\u0434\u0443 \u043E\u043D \u043E\u0442\u043A\u0430\u0437\u0430\u043B\u0441\u044F
    \u043E\u0442 \u043F\u0440\u0435\u0441\u0442\u0438\u0436\u043D\u043E\u0439 \u043F\u0440\u0435\u043C\u0438\u0438
    \u041A\u0440\u0430\u0444\u043E\u0440\u0434\u0430. *   \u041E\u043D \u043E\u0441\u0442\u0430\u0432\u0438\u043B
    \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
    \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
    \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u0432\u043E\u043F\u043B\u043E\u0449\u0435\u043D\u043D\u043E\u0435
    \u0432 \u0442\u044B\u0441\u044F\u0447\u0430\u0445 \u0441\u0442\u0440\u0430\u043D\u0438\u0446
    \u0441\u0435\u043C\u0438\u043D\u0430\u0440\u043E\u0432 SGA \u0438 EGA, \u0430
    \u0442\u0430\u043A\u0436\u0435 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u043C\u0430\u0441\u0441\u0438\u0432\u043D\u044B\u0445 \u0430\u0432\u0442\u043E\u0431\u0438\u043E\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0445
    \u0438 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0441\u043A\u0438\u0445 \u0440\u0443\u043A\u043E\u043F\u0438\u0441\u0435\u0439,
    \u0441\u0430\u043C\u043E\u0439 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439
    \u0438\u0437 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
    \xABR\xE9coltes et Semailles\xBB (\xAB\u0416\u0430\u0442\u0432\u044B \u0438 \u043F\u043E\u0441\u0435\u0432\u044B\xBB). 
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440 \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u0441\u043A\u043E\u043D\u0447\u0430\u043B\u0441\u044F 13 \u043D\u043E\u044F\u0431\u0440\u044F
    2014 \u0433\u043E\u0434\u0430 \u0432 \u0433\u043E\u0440\u043E\u0434\u0435 \u0421\u0435\u043D-\u0416\u0438\u0440\u043E\u043D
    (\u0424\u0440\u0430\u043D\u0446\u0438\u044F)."
  shortBioEn: 
  interestingFactsRu: "\u0416\u0438\u0437\u043D\u044C \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440\u0430
    \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A\u0430 \u0431\u044B\u043B\u0430
    \u043F\u043E\u043B\u043D\u0430 \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u044B\u0445
    \u043F\u043E\u0432\u043E\u0440\u043E\u0442\u043E\u0432 \u0438 \u0438\u0441\u0442\u043E\u0440\u0438\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043F\u043E\u0440\u0430\u0436\u0430\u044E\u0442
    \u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \u043D\u0435
    \u043C\u0435\u043D\u044C\u0448\u0435, \u0447\u0435\u043C \u0435\u0433\u043E \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435
    \u0442\u0435\u043E\u0440\u0438\u0438. \u0412\u043E\u0442 \u043B\u0438\u0448\u044C
    \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0437 \u0441\u0430\u043C\u044B\u0445
    \u044F\u0440\u043A\u0438\u0445 \u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445
    \u0444\u0430\u043A\u0442\u043E\u0432, \u0440\u0438\u0441\u0443\u044E\u0449\u0438\u0445
    \u0435\u0433\u043E \u043D\u0435\u043E\u0440\u0434\u0438\u043D\u0430\u0440\u043D\u044B\u0439
    \u043F\u043E\u0440\u0442\u0440\u0435\u0442.  ### \U0001F9D2 \u0414\u0435\u0442\u0441\u0442\u0432\u043E,
    \u0432\u043E\u0439\u043D\u0430 \u0438 \u044E\u043D\u043E\u0448\u0435\u0441\u0442\u0432\u043E:
    \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u044F \u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F 
    *   **\u041F\u043E\u0431\u0435\u0433 \u0438 \u043F\u043B\u0430\u043D \u0443\u0431\u0438\u0439\u0441\u0442\u0432\u0430
    \u0413\u0438\u0442\u043B\u0435\u0440\u0430:** \u0412 \u0434\u0432\u0435\u043D\u0430\u0434\u0446\u0430\u0442\u044C
    \u043B\u0435\u0442, \u043D\u0430\u0445\u043E\u0434\u044F\u0441\u044C \u0432 \u043B\u0430\u0433\u0435\u0440\u0435
    \u0434\u043B\u044F \u0438\u043D\u0442\u0435\u0440\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445
    \u0432\u043E \u0424\u0440\u0430\u043D\u0446\u0438\u0438, \u0413\u0440\u043E\u0442\u0435\u043D\u0434\u0438\u043A
    \u043F\u0440\u0438\u043D\u044F\u043B \u0434\u0435\u0440\u0437\u043A\u043E\u0435
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435. \u041E\u043D \u0441\u0431\u0435\u0436\u0430\u043B
    \u0438 \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043F\u0440\u043E\u0431\u0440\u0430\u0442\u044C\u0441\u044F
    \u043A \u0413\u0438\u0442\u043B\u0435\u0440\u0443, \u0447\u0442\u043E\u0431\u044B
    \u0443\u0431\u0438\u0442\u044C \u0435\u0433\u043E . \u042D\u0442\u043E\u0442
    \u044D\u043F\u0438\u0437\u043E\u0434 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0443\u044E \u0441\u043C\u0435\u043B\u043E\u0441\u0442\u044C
    \u0438 \u0440\u0435\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u044C,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043E\u043D \u043F\u0440\u043E\u043D\u0435\u0441
    \u0447\u0435\u0440\u0435\u0437 \u0432\u0441\u044E \u0436\u0438\u0437\u043D\u044C.
    *   **\u0421\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0435
    \u043F\u0435\u0440\u0435\u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0438:**
