    \u0431\u0443\u0434\u0443\u0449\u0435\u043C\u0443 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A\u0443.
    \u0420\u0430\u0431\u043E\u0442\u0430 \u0431\u044B\u043B\u0430 \u0430\u0431\u0441\u043E\u043B\u044E\u0442\u043D\u043E
    \u0432\u0435\u0440\u043D\u043E\u0439, \u043D\u043E \u0431\u0435\u0441\u043F\u043E\u043B\u0435\u0437\u043D\u043E\u0439
