    \u041B\u0435\u0431\u0435\u0433\u0430, \u043D\u0435 \u0437\u043D\u0430\u044F,
    \u0447\u0442\u043E \u044D\u0442\u043E \u0443\u0436\u0435 \u0431\u044B\u043B\u043E
    \u0441\u0434\u0435\u043B\u0430\u043D\u043E \u0434\u043E \u043D\u0435\u0433\u043E
    . \u0423\u0437\u043D\u0430\u0432, \u0447\u0442\u043E \u043E\u043D \u0441\u043E\u0432\u0435\u0440\u0448\u0438\u043B
    \u044D\u0442\u043E \u043F\u0435\u0440\u0435\u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435,
    \u043E\u043D \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0443\u0442\u0432\u0435\u0440\u0434\u0438\u043B\u0441\u044F \u0432 \u0441\u0432\u043E\u0435\u043C
    \u043F\u0440\u0438\u0437\u0432\u0430\u043D\u0438\u0438 \u043C\u0430\u0442\u0435\u043C\u0430\u0442\u0438\u043A\u0430
    . *   **\u041F\u0435\u0440\u0432\u043E\u0435 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043A\u0440\u0443\u0433\u0430:** \u0412 \u0442\u043E\u043C \u0436\u0435 \u043B\u0430\u0433\u0435\u0440\u0435
    \u0434\u043B\u044F \u0438\u043D\u0442\u0435\u0440\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0445
