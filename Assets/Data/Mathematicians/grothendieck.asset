    \u0430 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u044B \u0441\u043C\u0435\u0449\u0430\u043B\u0438\u0441\u044C
    \u0432 \u0441\u0442\u043E\u0440\u043E\u043D\u0443 \u0444\u0438\u043B\u043E\u0441\u043E\u0444\u0438\u0438,
    \u044D\u043A\u043E\u043B\u043E\u0433\u0438\u0438 \u0438 \u044D\u0437\u043E\u0442\u0435\u0440\u0438\u043A\u0438. 
    ### \U0001F4D6 \u041E\u0442\u0448\u0435\u043B\u044C\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u043E
    \u0438 \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435  \u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
